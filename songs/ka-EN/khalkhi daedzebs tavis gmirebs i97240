<?xml version="1.0" encoding="UTF-8"?><song><title>khalkhi daedzebs tavis gmirebs</title>
<lyrics>[V1]
 khalkhi daedzebs tavis gmirebs
 vitsit vin aris dzlieri
 didi mepe qʼvela khalkhistvis
 upalta upalia is
 zetsidan movida mitsʼaze
 sitsotskhle shestsʼira gvikhsna

[C1]
   shevdzakhebt chven
   samqʼaros shemomkmeds
   shen gaimarjve sikʼvdilze
   da shevdzakhebt chven
   samqʼaros shemomkmeds
   chveni gmiri khar samudamod

[V2]
 qʼovlisshemdzle ghmerti gmiria
 man gaimarjva sikʼvdilze
 bneleti gaanadgura
 sitsotskhle mogvanichʼa chven gakhda sinatle
 qʼvela khalkhis
 dideba dagvibruna chven

