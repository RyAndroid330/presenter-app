<?xml version="1.0" encoding="UTF-8"?><song><aka>adide upali o sulo chemo</aka>
<lyrics>[V1]
 adide upali o sulo chemo
 taqʼvani etsi mas
 ise rogorts arasdros umghere
 mis tsʼminda sakhels umghere

[C1]
   mze amodis
   akhali dghe dgeba
   dro dgeba gimghero isev
   qʼvela sikʼetistvis
   da qʼvela amosuntkvistvis
   mzis chasvlisas me isev
   gimghereb

[V2]
 riskhvashi neli sikʼetit savse
 tsʼqʼalobit khar
 mdidari mudam
 atiatas mizezs vipʼovi
 ghmerto
 rom gavagrdzelo
 sheni dideba

[V3]
 gaivlis dro
 dasasrulits mova
 davtʼoveb mets am samqʼaros
 suli gaagrdzelebs
 isev simgheras
 atiatas tsʼels da usasrulod

