<?xml version="1.0" encoding="UTF-8"?><song><aka>meomaria chveni upali abraamis ghmerti</aka>
<lyrics>[V1]
 meomaria chveni upali
 abraamis ghmerti
 moses upali
 is gvidzghveba brdzolashi
 rotsa kʼi shemogvitʼevs
 paraoni

[C1]
   moses upalma
   chvenma upalma
   metsʼamul zghvashi
   chaqʼara mtʼrebi
   suli sheubera
   da zghvam dapara lashkari
   paraonis

[V2]
 vin aris
 chveni uplis msgavsi
 kebata ghirsi
 sastsʼaul mokmedi
 vis dzaludzs mtʼrebisgan
 ikhsnas eri
 tu ara uplis kheli

[B1]
   tsekʼvit vadidot upali
   rogorts daviti da mariami
   vadidot erma chveni upali
   tsekʼvit da simgherit
   aleluia

[V3]
 meomaria chveni upali
 abraamis ghmerti
 moses upali
 is gvidzghveba brdzolashi
 rotsa kʼi shemogvitʼevs
 paraoni

[C2]
   moses upalma
   chvenma upalma
   metsʼamul zghvashi
   chaqʼara mtʼrebi
   suli sheubera
   da zghvam dapara lashkari
   paraonis

[V4]
 vin aris
 chveni uplis msgavsi
 kebata ghirsi
 sastsʼaul mokmedi
 vis dzaludzs mtʼrebisgan
 ikhsnas eri</lyrics>
<title>Warrior is our Lord, God of Abraham</title>
</song>