<?xml version="1.0" encoding="UTF-8"?><song><title>ieso mkhsneli khar,</title>
<lyrics>[V1]
 ieso mkhsneli khar,
 arvin ar shegedreba shen,
 chemi ghmerti khar,
 me gadideb shen,
 qʼvelapristvis rats
 gamikʼete
 nugeshi khar, saqʼrdeni,
 dzala shenshia
 chemma gulma, mtelma
 arsebam
 dae, taqʼvani gtses shen

[C1]
   shesdzakhe dedamitsʼav,
   umghere ghmerts
   dideba, keba, mepeta mepes
   taqʼvans stsemen mtebi,
   zghvebi imghereben
   misi sakhelis tsʼinashe,
   mteli chemi arsebit
   gadideb shen,
   mkholod shenshia chemi
   sikharuli,
   araperze ar vzrunav,
   rodesats chemtan khar</lyrics>
<aka>My Jesus, My Savior (Georgian)</aka>
