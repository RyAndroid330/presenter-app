<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 vin aris bavshvi mdzinare
 kalak betlemis bagashi
 bavshvi romelsats erebi
 motsʼitsʼebit esalmebian

[C1]
   es es aris mesia
   zetsidan movlenili mkhsneli
   mas visats angelozebi
   ertkhmad kebas umgherian

[V2]
 da chvents vuertdebit zetsis khmas
 angelozta tsʼmida galobas
 dghemde vzeimobt mis shobas
 mepeta mepis dabadebas

[C2]
   dghes dghes chven vzeimobt
   da vudzghvnit mas keba-didebas
   vzeimobt dghes rotsa samqʼaros
   imedi da mkhsneli moevlina

