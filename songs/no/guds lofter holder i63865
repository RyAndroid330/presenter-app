<?xml version="1.0" encoding="UTF-8"?><song><title>Guds løfter holder</title>
<lyrics>[V1]
 Guds løfter holder,
 Hva enn jeg mister,
 hva enn som brister,
 de brister ei.
 Om him'lens stjerner
 enn slukker alle,
 Guds løfter svikter aldri nei!</lyrics>
<key>E</key>
<presentation>v1 </presentation>
</song>