<?xml version="1.0" encoding="UTF-8"?><song><title>Roe Piye Ma</title>
<key>Em</key>
<lyrics>[V1]
.   Em                    B7
 // Piyêm, to ma ra wazena kê
.B7                  Em
 Ma ju minya hes bikime //
.   Em             B7
 // Ma pêro piya bime
.Am               B7
 Ma telewe de vındeme //

[C1]
   // Roê piyê ma, bê ma ser
   Zerria ma -be xoa pırr ke
   Tı vênena, comerda
   Ma raa xora berê //

[V2]
.   Em                 B7
 // Piyêm, nıka to pinime
.B7             Em
 Asmen ra bê ma ser //
.   Em           B7
 // Çıme ma to serê
. Am            B7
 Canweşiye bıdê ma //</lyrics>
<author>Eren Atik</author>
</song>