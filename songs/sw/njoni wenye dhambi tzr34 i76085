<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<lyrics>[V1]
.      C           G
 Njoni!Njoni!Wenye dhambi,
.       F  G   C
 Njoni, msikawie;
.     C       G         F  G    C
 Yesu anawangojea ndiye awapendaye;
.   F      C
 Ajuaye awezaye
.    F          C
 kuwaponya ni Yeye.
.   C      G
 Ajuaye awezaye
.    F     G    C
 kuwaponya ni Yeye.

[V2]
 Ewe muhitaji uje;
 Anakukaribisha,
 Imani, kweli, na toba,
 Neema ya kutosha,
 Jua sana, kwake Bwana
 Bure utapata.

[V3]
 Njoni, mliolemewa
 Na dhambi ya Adamu;
 Mkingoja kujiponya
 Mtapotea mumu;
 Si wa haki, ni wakosa
 Waoshwao kwa damu.

[V4]
 Ikamtokea dhiki,
 Mle Gethisemani;
 Kisha alipoangikwa
 Akalia mtini;
 ' Imekwisha', alitosha
 Dhabihu ya thamani.

[V5]
 Kristo aliye Mbinguni
 Hutuombea huko;
 Basi mtumai yeye;
 Kamwe mwingine hako
 Yesu pweke, Yesu pweke,
 Ndiye Mwokozi wako.

[V6]
 Wamsifu-sifu sana
 Mbinguni malaika;
 Wachanganya nyimbo zao
 Na waliookoka:
 Aleluya wataimba
 Waliooshwa taka.</lyrics>
<key>C</key>
<title>Njoni Wenye Dhambi TZR34</title>
</song>