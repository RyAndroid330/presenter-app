<?xml version="1.0" encoding="UTF-8"?><song><title>Yote Namtolea Yesu TZR52</title>
<lyrics>[V1]
 Yote namtolea Yesu
 Nampa moyo wote,
 Nitampenda siku zote,
 Namwandama kila saa.

[V2]
 Yote kwa Yesu,
 Yote kwa Yesu,
 Yote kwako, Ee mwokozi,
 Natoa sasa.

[V3]
 Yote namtolea Yesu,
 Nainamia pake;
 Nimeacha na anasa,
 Kwako Yesu nipokee,

[V4]
 Yote namtolea Yesu,
 Nifanye niwe wako;
 Nipe Roho yako, Bwana,
 Anilinde daima,

[V5]
 Yote namtolea Yesu,
 Nami naona sasa;
 Furaha ya ukombozi,
 Nasifu jina lake,</lyrics>
<hymn_number>52</hymn_number>
</song>