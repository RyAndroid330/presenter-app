<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>40</hymn_number>
<lyrics>[V1]
 Nasikia kwitwa
 Na sauti yako
 Nikasafiwe kwa damu
 Ya kwangikwa kwako.

[V2]
 Nimesogea Mtini pako,
 Unisafi kwa damu ya kwangikwa kwako.

[V3]
 Ni mnuonge kweli,
 Umenipa nguvu,
 Ulivyonisafi taka,
 Ni utimilivu.

[V4]
 Yesu hunijuvya;
 Mapenzi, imani;
 Tumai, amani, radhi,
 Hapa na Mbinguni.

[V5]
 Huipa imara,
 Kazi yake, ndani:
 Huongezeka neema,
 Ashindwe Shetani.

[V6]
 Huishuhudia,
 Myoyo ya imani
 Ya kuzipata ahadi,
 Wakimuamini.

[V7]
 Napata wokovu,
 Wema na neema;
 kwako Bwana nina nguvu
 Na haki daima.</lyrics>
<title>Nasikia Kuitwa TZR40</title>
</song>