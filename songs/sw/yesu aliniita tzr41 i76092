<?xml version="1.0" encoding="UTF-8"?><song><title>Yesu Aliniita TZR41</title>
<lyrics>[V1]
 Yesu aliniita, 'njoo,
 Raha iko kwangu,
 Kichwa chako ukilaze
 Kifuani mwangu.'
 Nilikwenda kwake mara,
 Sana nilichoka;
 Nikapata kwake raha,
 Na furaha tena.

[V2]
 Yesu aliniita, 'njoo,
 Kwangu kuna maji,
 Maji ya uzima, bure,
 Unywe uwe hai, '
 Nilikwenda kwake mara
 Na maji nikanywa:
 Naishi kwake, na kiu
 Kamwe sina tena.

[V3]
 Yesu aliniita, 'njoo,
 Dunia ni giza,
 Ukinitazama nuru
 Takung'arizia.'
 Nilikwenda kwake mara
 Yeye jua langu,
 Ni kila wakati mwanga
 Safarini mwangu.</lyrics>
<hymn_number>41</hymn_number>
</song>