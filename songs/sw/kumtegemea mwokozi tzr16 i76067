<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16</hymn_number>
<lyrics>[V1]
 Kumtegemea Mwokozi,
 Kwangu tamu kabisa;
 Kukubali neno lake
 Nina raha moyoni.

[V2]
 Yesu,Yesu namwamini,
 Nimemwona thabiti;
 Yesu,Yesu,yu thamani,
 Ahadi zake kweli.

[V3]
 Kumtegemea Mwokozi,
 Kwangu tamu kabisa,
 Kuamini damu yake
 Nimeoshwa kamili.

[V4]
 Kumtegemea Mwokozi,
 Kwangu tamu kabisa,
 Kwake daima napata
 Uzima na amani.

[V5]
 Nafurahi kwa sababu
 Nimekutegemea;
 Yesu,Mpendwa na Rafiki
 Uwe nami dawamu.</lyrics>
<title>Kumtegemea Mwokozi TZR16</title>
</song>