<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>128</hymn_number>
<lyrics>[V1]
 Mmoja apita wote,
 Atupenda;
 Zaidi ya ndugu wote,
 Atupenda;
 Rafiki wa duniani,
 Wote hatuwaamini;
 Yesu kwa kila zamani,
 Atupenda.

[V2]
 Kumjua ni uzima,
 Atupenda;
 Jinsi ajaavyo wema
 Atupenda;
 Yeye ametununua
 Kwa damu aliyomwaga,
 Dhambini kutuokoa,
 Atupenda.

[V3]
 Sasa tunaye rafiki,
 Atupenda;
 Hupenda kutubariki;
 Atupenda;
 Twapenda kumsikia,
 Atwita kukaribia,
 Nasi tutamwamania,
 Atupenda.

[V4]
 Husamehe Dhambi zetu,
 Atupenda;
 Hushinda adui zetu,
 Atupenda;
 Anatwonea huruma,
 Hatupati ila mema,
 Anatwongoza salama,
 Atupenda.</lyrics>
<title>Mmoja Apita Wote TZR128</title>
</song>