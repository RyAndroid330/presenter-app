<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Msalabani pa mwokozi,
 Hapo niliomba upozi,
 Akaniokoa mpenzi,
 Mwana wa Mungu.

[V2]
 Mwana wa Mungu, Mwokozi wangu,
 Akaniokoa mpenzi, Mwana wa Mungu.

[V3]
 Chini ya mti msumbufu,
 Niliomba utakatifu,
 Alinikomboa kwa damu,
 Mwana wa Mungu.

[V4]
 Mwana wa Mungu, Mwokozi wangu,
 Alinikomboa kwa damu, Mwana wa Mungu.

[V5]
 Aliniokoa dhambini,
 Ikawa kunikaa ndani,
 Aliponifia mtini,
 Mwana wa Mungu.

[V6]
 Mwana wa Mungu, Mwokozi wangu,
 Aliponifia Mtini, Mwana wa Mungu.

[V7]
 Damu ya Yesu ya thamani,
 Huniokoa makosani,
 Huniendesha wokovuni,
 Mwana wa Mungu.

[V8]
 Mwana wa Mungu, Mwokozi wangu,
 Huniendesha wokovuni, Mwana wa Mungu.

[V9]
 Hicho kijito cha gharama,
 Leo jivike kwa kuzama,
 Kwake uuone uzima,
 Mwana wa Mungu.

[V10]
 Mwana wa Mungu, Mwokozi wangu,
 Kwake u uone uzima, Mwana wa Mungu.</lyrics>
<title>Msalabani pa Mwokozi TZR77</title>
<hymn_number>77</hymn_number>
</song>