<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>137</hymn_number>
<title>Yesu Mponya TZR137</title>
<lyrics>[V1]
 Yesu ndiye mganga wetu
 Aponya wagonjwa wote;
 Mganga wetu ni Yesu,
 Aponyaye hasira.

[V2]
 Tumsifu huyo Yesu
 Tumsifu milele,
 Kwani Mponya mtakata
 Mwokozi wa wanyonge

[V3]
 Mganga wetu ni Yesu
 Huondoa matusi;
 Mganga wetu ni Yesu,
 Mwenye kuponya choyo.

[V4]
 Mganga wetu ni Yesu
 Huponya wivu wetu;
 Yesu ndiye aponyae
 Kelele za nyumbani.

[V5]
 Mganga wetu ni Yesu
 Mponya wa tamaa mbaya;
 Mganga wetu ni Yesu
 Uasherati hufuta

[V6]
 Mganga wetu ni Yesu
 Aponya kiu cha pombe,
 Mganga wetu ni Yesu
 Kila dhambi uponya</lyrics>
</song>