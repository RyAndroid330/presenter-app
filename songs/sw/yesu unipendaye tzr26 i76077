<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Yesu unipendaye
 Kwako nakimbilia,
 Ni wewe utoshaye,
 Mwovu akinijia;
 Yafiche ubavuni,
 Mwako maisha yangu;
 Nifiikishe mbinguni
 Wokoe moyo wangu.

[V2]
 Ngome nyingine sina;
 Nategemea kwako.
 Usinitupe Bwana ,
 Nipe neema yako,
 Ninakuamania
 Mwenye kuniwezesha;
 Shari wanikingia,
 Vitani wanitosha.

[V3]
 Nakutaka Mpaji
 Vyote napata kwako;
 Niwapo muhitaji,
 Utanijaz vyako;
 Nao waangukao
 Wanyonge wape nguvu;
 Poza wauguao,
 Uongoze vipofu.

[V4]
 Bwana umeniosha
 Moyo kwa damu yako;
 Neema ya kutosha
 Yapatikana kwako;
 Kwako Bwana naona
 Kisima cha uzima;
 Mwangu moyoni Bwana,
 Bubujika daima.</lyrics>
<title>Yesu Unipendaye TZR26</title>
<hymn_number>26</hymn_number>
</song>