<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Nitwae hivi nilivyo,
 Umemwaga damu yako,
 Nawe ulivyoniita,
 Bwana Yesu,naja,naja.

[V2]
 Hivi nilivyo;si langu
 Kujiosha roho yangu;
 Nisamehe dhambi zangu,
 Bwana Yesu,naja,naja.

[V3]
 Hivi nilivyo; sioni
 Kamwe furaha moyoni;
 Daima ni mashakani,
 Bwana Yesu,naja,naja.

[V4]
 Hivi nilivyo kipofu,
 maskini na mpungufu;
 Wewe u mtimilifu;
 Bwana Yesu,naja,naja.

[V5]
 Nawe hivi utanitwaa;
 Nisithubutu kukawa,
 Na wewe hutanikataa,
 Bwana Yesu,naja,naja.

[V6]
 Hivi nilivyo;mapenzi
 Yamenipa njia wazi;
 Hali na mali sisazi,
 Bwana Yesu,naja,naja.</lyrics>
<title>Nitwae Hivi Nilivyo TZR49</title>
<hymn_number>49</hymn_number>
</song>