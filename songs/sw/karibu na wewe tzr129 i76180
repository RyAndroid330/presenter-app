<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>129</hymn_number>
<lyrics>[V1]
 Karibu na wewe,
 Mungu wangu
 Karibu zaidi,
 Bwana wangu
 Siku zote niwe
 Karibu na wewe,
 Karibu zaidi
 Mungu wangu.

[V2]
 Mimi nasafiri
 Duniani,
 Pa kupumzika
 Sipaoni,
 Nilalapo niwe
 Karibu na wewe,
 Karibu zaidi
 Mungu wangu.

[V3]
 Na kwa nguvu zangu
 Nikusifu;
 Mwamba, uwe maji
 Ya wokovu;
 Mashakani niwe
 Karibu na wewe;
 Karibu zaidi
 Mungu wangu.

[V4]
 Na nyumbani mwa juu,
 Baba yangu,
 Zikikoma hapa
 Siku zangu,
 Kwa furaha niwe
 Pamoja na wewe,
 Karibu kabisa
 Mungu wangu.</lyrics>
<title>Karibu Na Wewe TZR129</title>
</song>