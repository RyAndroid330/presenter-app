<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8</hymn_number>
<lyrics>[V1]
 Taji mvikeni,
 Taji nyingi tena,
 Kondoo mwake kitini,
 Bwana wa mabwana;
 Name tamsifu
 Alikufa kwangu,
 Ni mfalme mtukufu,
 Mkuu wa Mbingu.

[V2]
 Taji mvikeni
 Mwana wa bikira;
 Anazovaa kichwani
 Aliteka nyara;
 Shiloh wa wanabii,
 Mchunga wa watu,
 Shina na tanzu vya Yese,
 Wa Bethirehemu.

[V3]
 Taji mvikeni
 Bwana wa mapenzi;
 Jeraha zake ni shani
 Ni vito vya enzi,
 Mbinguni hakuna
 Hata malaika
 Awezaye kuziona
 Pasipo kushangaa.</lyrics>
<title>Taji Mvikeni TZR8</title>
</song>