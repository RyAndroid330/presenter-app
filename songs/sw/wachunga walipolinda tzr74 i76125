<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>74</hymn_number>
<lyrics>[V1]
 Wachunga walipolinda
 Kucha nyama zao,
 Malaika mtukufu
 Alishuka kwao.

[V2]
 Wakacha sana wachunga,
 Akawatuliza,
 'Nawaletea habari
 Ya kuwapendeza.'

[V3]
 'Mji ule wa Daudi
 Leo amezawa
 Mwokozi ni Kristo Bwana,
 Ilivyoandikwa.'

[V4]
 'Huyo mwana wa Mbinguni
 Ataonekana,
 Amelazwa kihorini
 Malazi hapana.'

[V5]
 Alipokwisha yanena
 Malaika hao
 Waliimba wimbo huu
 Usio na mwisho:

[V6]
 'Enzi ni yake Mungu juu,
 Na nchi salama,
 Kwa watu nao radhi kuu,
 Sasa na daima'.</lyrics>
<title>Wachunga Walipolinda TZR74</title>
</song>