<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>106</hymn_number>
<lyrics>[V1]
 Mungu awe nanyi daima,
 Hata twonane ya pili,
 Awachunge kwa fadhili,
 Mungu awe nanyi daima.

[V2]
 Hata twonane huko juu,
 Hata twonane kwake kwema;
 Hata twonane huko juu,
 Mungu awe nanyi daima.

[V3]
 Mungu awe nanyi daima;
 Ziwafunike mbawaze,
 Awalishe, awakuze;
 Mungu awe nanyi daima.

[V4]
 Mungu awe nanyi daima;
 Kila wakati wa shani
 Awalinde hifadhini;
 Mungu awe nanyi daima.

[V5]
 Mungu awe nanyi daima;
 Awabarikie sana,
 Awapasulie kina;
 Mungu awe nanyi daima.</lyrics>
<title>Mungu awe Nanyi Daima TZR106</title>
</song>