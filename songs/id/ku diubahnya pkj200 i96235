<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>200</hymn_number>
<lyrics>[V1]
 'Ku diubahNya saat 'ku berserah,
 berserah kepada Yesus.
 'Ku diubahNya hingga jadi baru
 dan menjadi milikNya.
 Kegemaran lama t'lah lenyap
 dan yang baru lebih berkenan.
 'Ku diubahNya saat 'ku berserah
 dan menjadi milikNya!</lyrics>
<title>'Ku Diubahnya PKJ200</title>
</song>