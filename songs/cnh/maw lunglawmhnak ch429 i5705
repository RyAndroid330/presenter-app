<?xml version="1.0" encoding="UTF-8"?><song><title>MAW LUNGLAWMHNAK CH429</title>
<lyrics>[V1]
 Rian hrang tuan le sifahnak a dih lai, Lawmhnak khuatha chungah ka
 phak tikah, Ka dawtmi Bawipa sin ka um tikah, A zungzal in lawmhnak kha
 ka hmuh lai.

[C1]
   Maw lunglawmhnak (lunglawmhnak), ka hmuh lai ta, (ka hmuh lai ta),
   Ka hmuh lai ta (Maw lunglawmhnak), ka hmuh lai ta (ka hmuh lai ta), A
   dawtnak in a hmai ka zoh tikah, Kei ca sunparnak, Lawmhnak a si lai.

[V2]
 A dong lo a kan zaangfahnak thawngin, Vancung khua ah umnak ka hmuh
 tikah, Amah hmai tha kha ka zoh tikah cun, A zungzal in lawmhnak kha ka
 hmuh lai.

[C2]
   Maw lunglawmhnak (lunglawmhnak), ka hmuh lai ta, (ka hmuh lai ta),
   Ka hmuh lai ta (Maw lunglawmhnak), ka hmuh lai ta (ka hmuh lai ta), A
   dawtnak in a hmai ka zoh tikah, Kei ca sunparnak, Lawmhnak a si lai.

[V3]
 Khi hmun ah ka hawi kha ka ton hna lai, Ka velchum ah lawmhnak, ti
 bang a luang, Ka Bawipa minthmai tha ka hmuh tikah, A zungzal in lawmhnak
 kha ka hmuh lai.

[C3]
   Maw lunglawmhnak (lunglawmhnak), ka hmuh lai ta, (ka hmuh lai ta),
   Ka hmuh lai ta (Maw lunglawmhnak), ka hmuh lai ta (ka hmuh lai ta), A
   dawtnak in a hmai ka zoh tikah, Kei ca sunparnak, Lawmhnak a si lai.</lyrics>
<key>Ab</key>
<hymn_number>429</hymn_number>
</song>