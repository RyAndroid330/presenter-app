<?xml version="1.0" encoding="UTF-8"?><song><title>NA SUALNAK KHA CHIATA LAW CH244</title>
<lyrics>[V1]
 Misual mi Jesuh nih an auh hna, A sinah ra tuah, Ra tuah u, sual
 ngaichihmi vialte, Jesuh kehram ah,

[C1]
   Na sualnak kha chiah dingin, Bawi Jesuh sinah kal tuah, Na sualnak
   kha chia ta law, Jesuh ke-hram ah.

[V2]
 A zummi kal u lawmhnak kawl tuah, Bawipa sin kal tuah, Na lungchung
 retheihnak thilrit kha, Jesuh sin chia tuah,

[C2]
   Na sualnak kha chiah dingin, Bawi Jesuh sinah kal tuah, Na sualnak
   kha chia ta law, Jesuh ke-hram ah.

[V3]
 Na zumhnak nih khan an lawmhter lai, Jesuh sin kal tuah, Na thlarau
 ca-ah lawmhnak a tam, Jesuh sin kal tuah,

[C3]
   Na sualnak kha chiah dingin, Bawi Jesuh sinah kal tuah, Na sualnak
   kha chia ta law, Jesuh ke-hram ah.

[V4]
 Ra tuah u, nannih umnak a um, Jesuh sin kal tuah, Thilrit nan ngeihmi
 vialte zong kha, Jesuh sin chia tuah.

[C4]
   Na sualnak kha chiah dingin, Bawi Jesuh sinah kal tuah, Na sualnak
   kha chia ta law, Jesuh ke-hram ah.</lyrics>
<key>G</key>
<hymn_number>244</hymn_number>
</song>