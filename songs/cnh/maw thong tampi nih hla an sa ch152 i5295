<?xml version="1.0" encoding="UTF-8"?><song><title>MAW THONG TAMPI NIH HLA AN SA CH152</title>
<lyrics>[V1]
 Maw thong tampi nih hla an sa, (Ka khamhtu thangthatnak,)2 Kan Pathian
 tlanhnak thawngtha le, (Dawtnak le zaangfahnak,)3

[V2]
 Kan siangpahrang a kan Hruaitu, (Thawnnak run kan pe tuah),2 Vawlei
 cung mi vial te sinah, (Na tha chin thanh awkah)3

[V3]
 Kan Bawi Jesuh na min thiang hi, (Damnak le hnangamnak)2 Misualmi
 vialte hna ca-ah, (Daihnak nunnak a si)3

[V4]
 Sualnak vialte Teitu nih cun, (Chuahnak nawl a pek hna)2 A thur bik
 ca'h thi a thlet i, (Kei ca zong a si ve)3.</lyrics>
<key>G</key>
<hymn_number>152</hymn_number>
</song>