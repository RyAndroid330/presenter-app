<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>52</hymn_number>
<lyrics>[V1]
 Sifah innak ca thinphang hlah, Pathian nih an zoh lai, Amah dawtnak
 thla tang um tuah, Pathian nih an zoh lai.

[C1]
   Pathian nih an zoh lai, Nifa kalnak khuallam ah khan, Amah nih an
   zohkhenh, Pathian nih an zoh lai (an zoh lai)

[V2]
 A fakpi rian na tuan tikah, Pathian nih an zoh lai, Na kalnak lam
 phannak um lo, Pathian nih an zoh lai.

[C2]
   Pathian nih an zoh lai, Nifa kalnak khuallam ah khan, Amah nih an
   zohkhenh, Pathian nih an zoh lai (an zoh lai)

[V3]
 Na duh vialte kha an pek lai, Pathian nih an zoh lai, Pek lo in zei
 hmanh um lai lo, Pathian nih an zoh lai.

[C3]
   Pathian nih an zoh lai, Nifa kalnak khuallam ah khan, Amah nih an
   zohkhenh, Pathian nih an zoh lai (an zoh lai)

[V4]
 Tukforhnak kha na hmuh tikah, Pathian nih an zoh lai, Amah tangchung
 ah va um tuah, Pathian nih an zoh lai.

[C4]
   Pathian nih an zoh lai, Nifa kalnak khuallam ah khan, Amah nih an
   zohkhenh, Pathian nih an zoh lai (an zoh lai)</lyrics>
<key>Bb</key>
<title>PATHIAN NIH AN ZOH LAI CH52</title>
</song>