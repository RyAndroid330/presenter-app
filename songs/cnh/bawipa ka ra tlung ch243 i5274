<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>243</hymn_number>
<key>Ab</key>
<lyrics>[V1]
 Pathian sin in ka tlau hnuah, Atu ka ra tlung; Sualnak lam sau tuk
 zulh hnuah, Bawipa ka ra tlung.

[C1]
   Ka ra tlung, ka ra tlung, Tlau ti lo dingin, Na ta zungzal si
   dingin, Bawipa ka ra tlung.

[V2]
 Kum tampi ka lohlak hnuah, Atu ka ra tlung; Ngaihchihnak mitthli tla
 bu-in, Bawipa ka ra tlung.

[C2]
   Ka ra tlung, ka ra tlung, Tlau ti lo dingin, Na ta zungzal si
   dingin, Bawipa ka ra tlung.

[V3]
 Sual le tlau hi ka ba ko cang, Atu ka ra tlung; Na dawtnak bia ka zumh
 cang lai, Bawipa, ka ra tlung.

[C3]
   Ka ra tlung, ka ra tlung, Tlau ti lo dingin, Na ta zungzal si
   dingin, Bawipa ka ra tlung.

[V4]
 Ka ruahnak le thinlung a zaw, Atu ka ra tlung, Thazang le ruahchannak
 ka pe, Bawipa ka ra tlung.

[C4]
   Ka ra tlung, ka ra tlung, Tlau ti lo dingin, Na ta zungzal si
   dingin, Bawipa ka ra tlung.</lyrics>
<title>BAWIPA, KA RA TLUNG CH243</title>
</song>