<?xml version="1.0" encoding="UTF-8"?><song><title>JESUH NIH A KA DAWT CH381</title>
<lyrics>[V1]
 Jesuh a ka dawt ka hngalh, Baibal ca chungah aa ttial, Ngakchia zong
 kha a dawt hna, Jesuh zaang an fah ca ah.

[C1]
   Keimah a ka dawt, Keimah a ka dawt, Keimah a ka dawt, Baibal ca in
   ka hngalh.

[V2]
 Jesuh a ka dawt a si, Vancung kutka a hun cang, Ka sualnak kha a tawl
 lai, Ngakchiasem a luhter lai.

[C2]
   Keimah a ka dawt, Keimah a ka dawt, Keimah a ka dawt, Baibal ca in
   ka hngalh.

[V3]
 Jesuh a ka dawt ko ta, Keimah a ka kalpi lai, Amah nih ka thih tikah,
 A ka lak lai vancung ah.

[C3]
   Keimah a ka dawt, Keimah a ka dawt, Keimah a ka dawt, Baibal ca in
   ka hngalh.</lyrics>
<key>Eb</key>
<hymn_number>381</hymn_number>
</song>