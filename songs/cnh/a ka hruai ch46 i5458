<?xml version="1.0" encoding="UTF-8"?><song><author>He Leadeth Me</author>
<hymn_number>46</hymn_number>
<key>D</key>
<lyrics>[V1]
 Pathian nih a ka hruai zungzal, Vancung lungdaihnak in a khat, Ka
 tuahnak le ka umnak ah, Jesuh kut in a ka hruai ko.

[C1]
   A ka hruai ko, A ka hruai ko, Amah kut in a ka hruai ko, A kut in a
   ka hruai ca ah, Lung fek zulhnak ka lung a si.

[V2]
 A caanah sifahnak lakah, A caan ah lunglawmhnak lakah, Ti daihnak le
 tilet lak ah, Jesuh kut in a ka hruai ko.

[C2]
   A ka hruai ko, A ka hruai ko, Amah kut in a ka hruai ko, A kut in a
   ka hruai ca ah, Lung fek zulhnak ka lung a si.

[V3]
 Bawipa, na kut tlaih ka duh ko, Zeitik hmanh ah al ka duh lo, Khuazei
 hmanh ah na ka hruai ca'h, Hnangam te in ka um zungzal.

[C3]
   A ka hruai ko, A ka hruai ko, Amah kut in a ka hruai ko, A kut in a
   ka hruai ca ah, Lung fek zulhnak ka lung a si.

[V4]
 Vawlei riantuan a dih tikah, Na liannak in ka tei tikah, Jordan na ka
 tanpi caah, Thihnak tilet ka tih lai lo.

[C4]
   A ka hruai ko, A ka hruai ko, Amah kut in a ka hruai ko, A kut in a
   ka hruai ca ah, Lung fek zulhnak ka lung a si.</lyrics>
<title>A KA HRUAI CH46</title>
</song>