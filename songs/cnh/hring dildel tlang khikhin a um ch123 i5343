<?xml version="1.0" encoding="UTF-8"?><song><title>HRING DILDEL TLANG KHIKHIN A UM CH123</title>
<key>E</key>
<lyrics>[V1]
 Kal-va-ry tlang cungah a thi, Jerusalem lengah; Kannih tlanh awkah
 Bawi Jesuh, Vailam cungah an tar.

[C1]
   Amah a kan dawt hringhran ca, Amah daw ve u si, A kan tlanhnak a
   lianngan ca'h, Amah rian kan tuan lai.

[V2]
 Kan hngal kho lo, kan chim kho lo, Amah sifah innak, Siseh kannih
 vialte ca ah, A thih kha kan zumh ko.

[C2]
   Amah a kan dawt hringhran ca, Amah daw ve u si, A kan tlanhnak a
   lianngan ca'h, Amah rian kan tuan lai.

[V3]
 Kannih sualngaihthiamnak caah, Amah kha a thi cang, A thi in a kan
 tawl ca ah, Vancung khua kan phak lai.

[C3]
   Amah a kan dawt hringhran ca, Amah daw ve u si, A kan tlanhnak a
   lianngan ca'h, Amah rian kan tuan lai.

[V4]
 Sual leiba a kan champiaktu, Midang hohmanh um lo, Amah lawng nih
 vancung kutka, A kan hunpiak khawh lai.

[C4]
   Amah a kan dawt hringhran ca, Amah daw ve u si, A kan tlanhnak a
   lianngan ca'h, Amah rian kan tuan lai.</lyrics>
<hymn_number>123</hymn_number>
</song>