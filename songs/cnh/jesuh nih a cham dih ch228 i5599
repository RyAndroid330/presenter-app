<?xml version="1.0" encoding="UTF-8"?><song><title>JESUH NIH A CHAM DIH CH228</title>
<key>Eb</key>
<lyrics>[V1]
 Khamhbawi bia kha ka theih, Na zaang a tlawm taktak, Zaang tlawmmi
 ni-fa-te, Thlacam pah in va hngak.

[C1]
   Jesuh a cham dih, Lei ka bat vialte, Sualnak in ka lung a thur, A
   thian a ranter ve.

[V2]
 Atu kan hngalh Bawipa, Nang hlei mi dang um lo; Thinghmui hma damter
 kho, Lunghak nemter khotu.

[C2]
   Jesuh a cham dih, Lei ka bat vialte, Sualnak in ka lung a thur, A
   thian a ranter ve.

[V3]
 Na zaangfahnak chim awkah, Zei hmanh san ka tlai lo, Ka lung sualnak
 fak tuk, Na thi in ka tawl ko.

[C3]
   Jesuh a cham dih, Lei ka bat vialte, Sualnak in ka lung a thur, A
   thian a ranter ve.

[V4]
 Ka thihnak kha a phan, Vancung lei ah ka kal, Khamhbawi thangthatnak
 hla Vanmi hmaiah ka sak.

[C4]
   Jesuh a cham dih, Lei ka bat vialte, Sualnak in ka lung a thur, A
   thian a ranter ve.

[V5]
 Vancung khua ngan chungah, A-mah sin ka phan lai, Bawi Jesuh kehram
 ah, Ka ngeihmi ka chiah lai.

[C5]
   Jesuh a cham dih, Lei ka bat vialte, Sualnak in ka lung a thur, A
   thian a ranter ve.</lyrics>
<hymn_number>228</hymn_number>
</song>