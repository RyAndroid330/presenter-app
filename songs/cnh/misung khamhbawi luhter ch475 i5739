<?xml version="1.0" encoding="UTF-8"?><song><title>MISUNG KHAMHBAWI LUHTER CH475</title>
<key>Eb</key>
<lyrics>[V1]
 Khamhtu innka hram a dir, Luhter tuah, luhter tuah, luhter tuah, Hlan
 zongah inn a kingh tawn, Luhter tuah, luhter tuah, luhter tuah.

[C1]
   Khamhtu cu innka hram ah a dir, An ngan ko rih tuan in an hngah
   cang, Na lung innka kau pi'n hung, Misung Khamhbawi luhter tuah, luhter
   tuah, luhter tuah.

[V2]
 Zumh awktlak hawitha a si, Luhter tuah, luhter tuah, luhter tuah,
 Zungzal in an kilven lai, Luhter tuah, luhter tuah, luhter tuah.

[C2]
   Khamhtu cu innka hram ah a dir, An ngan ko rih tuan in an hngah
   cang, Na lung innka kau pi'n hung, Misung Khamhbawi luhter tuah, luhter
   tuah, luhter tuah.

[V3]
 Innka kingh in umter hlah, Luhter tuah, luhter tuah, luhter tuah, A ra
 than ti sual lai lo, Luhter tuah, luhter tuah, luhter tuah.

[C3]
   Khamhtu cu innka hram ah a dir, An ngan ko rih tuan in an hngah
   cang, Na lung innka kau pi'n hung, Misung Khamhbawi luhter tuah, luhter
   tuah, luhter tuah.</lyrics>
<hymn_number>475</hymn_number>
</song>