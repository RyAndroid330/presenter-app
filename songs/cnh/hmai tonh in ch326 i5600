<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>326</hymn_number>
<title>HMAI TONH IN CH326</title>
<key>Bb</key>
<lyrics>[V1]
 Hmaitonh in ka khamhtu Khrih cu, Ka hoi kho ve te hnga maw, A ka lak
 tikah ka hoi lai, Kei ca a thimi Khrih cu.

[C1]
   Hmaitonh in ka hoi khawh te lai, Arfi pinlei van ah khin, Hmaitonh
   in a suparnak he, Ka hmuh te lai tu hnuah.

[V2]
 Zumhnak lawngin atu ka hmuh, Muihnak nih phen hmanhseh law, Siseh Ni
 sung bik a ra lio, A sunpar lianhngannak he.

[C2]
   Hmaitonh in ka hoi khawh te lai, Arfi pinlei van ah khin, Hmaitonh
   in a suparnak he, Ka hmuh te lai tu hnuah.

[V3]
 Zeitluk thanuamnak dah si lai, Ngaihchiat sifah loh tik ah, Lam kawi
 vialte samh an si lai, Muihnak zong a um lai lo.

[C3]
   Hmaitonh in ka hoi khawh te lai, Arfi pinlei van ah khin, Hmaitonh
   in a suparnak he, Ka hmuh te lai tu hnuah.

[V4]
 Hmaitonh in tonnak caan nuam bik, Hmaitonh in hmuh le hngalh caan, A
 ka dawtu Jesuh Khrih he, Hmaitonh in ton caan a si.

[C4]
   Hmaitonh in ka hoi khawh te lai, Arfi pinlei van ah khin, Hmaitonh
   in a suparnak he, Ka hmuh te lai tu hnuah.</lyrics>
</song>