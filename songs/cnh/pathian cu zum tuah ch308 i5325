<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>308</hymn_number>
<title>PATHIAN CU ZUM TUAH CH308</title>
<key>A</key>
<lyrics>[V1]
 Pathian zum u, dawtmi fa hna, Zum tuah, Amah nih lam an hruai lai,
 Pathian zum u, Thluachuahnak ca, Atu an pek hna lai.

[C1]
   Zum u, Pathian bia bangin, Nifatin Amah kha zoh u, Pathian kha zum
   u, Pathian kha zum u, Nan lam hruaitu cu a si.

[V2]
 Pathian zum u, rawhnak a nai, Zum tuah, A vel-ngeihnak na hmuh lai,
 Pathian zum u, Harnak caan ah, A thla in an huh lai.

[C2]
   Zum u, Pathian bia bangin, Nifatin Amah kha zoh u, Pathian kha zum
   u, Pathian kha zum u, Nan lam hruaitu cu a si.

[V3]
 Pathian zum u, ngaihchiat zongah, Zum tuah, Lungfahnak a daihter lai,
 Pathian zum u, Thilrih zongah, Thazang thar hmuh awkah.

[C3]
   Zum u, Pathian bia bangin, Nifatin Amah kha zoh u, Pathian kha zum
   u, Pathian kha zum u, Nan lam hruaitu cu a si.

[V4]
 Pathian zum u, Khual lam zongah Zum u, Vel le laksawng nan hmuh lai,
 Zum u, A aunak cu ngai u, Vancung i ton awk ah.

[C4]
   Zum u, Pathian bia bangin, Nifatin Amah kha zoh u, Pathian kha zum
   u, Pathian kha zum u, Nan lam hruaitu cu a si.</lyrics>
</song>