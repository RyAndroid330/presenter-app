<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>442</hymn_number>
<lyrics>[V1]
 Vancung khua ka ruahchan, Je-ho-va Pathian khua, A sui hmai niti'n ka
 hmuh lai, Lung-lawmhnak a tling lai.

[C1]
   Ngaih-chiatnak a um lo, ngaih-chiatnak a um lo, Dawtnak a tling,
   vancung sui ram, ngaih-chiatnak a um lo.

[V2]
 Vancung khua ka ruahchan, A kan Khamhbawi umnak, A ka dawtnak
 thang-thatnak hla, A zungzal an sa ko.

[C2]
   Ngaih-chiatnak a um lo, ngaih-chiatnak a um lo, Dawtnak a tling,
   vancung sui ram, ngaih-chiatnak a um lo.

[V3]
 Vancung khua ka ruahchan, Vancung mithiang mi nih, Puanrang aih in an
 um cio ko, Kannih zong kan um lai.

[C3]
   Ngaih-chiatnak a um lo, ngaih-chiatnak a um lo, Dawtnak a tling,
   vancung sui ram, ngaih-chiatnak a um lo.

[V4]
 Vancung khua ka ruah tawn, A tlung ciami kan hawi, Kan ton tikah
 thennak um lo, Zungzal kan i nuam lai.

[C4]
   Ngaih-chiatnak a um lo, ngaih-chiatnak a um lo, Dawtnak a tling,
   vancung sui ram, ngaih-chiatnak a um lo.</lyrics>
<key>A</key>
<title>NGAIHCHIATNAK A UM LO CH442</title>
</song>