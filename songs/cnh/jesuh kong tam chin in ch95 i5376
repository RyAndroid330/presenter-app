<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>95</hymn_number>
<key>Ab</key>
<lyrics>[V1]
 Jesuh kong tam chin ka hngalh lai, A vel kong tam chin in chim ning; A
 khamhnak tling cu hngalh chin in, Kei dawt ruang i a thihnak zong.

[C1]
   Jesuh kong tam chin in, Jesuh kong tam chin in, A khamhnak tling cu
   hngalh chin in, Kei dawt ruang i a thihnak zong.

[V2]
 Jesuh kong tam chin in hngal ning, A thiannak tam chin in hngal ning;
 Pathian thlarau cawnpiak tu nih, Khrih kong dihlak a ka hmuhsak.

[C2]
   Jesuh kong tam chin in, Jesuh kong tam chin in, A khamhnak tling cu
   hngalh chin in, Kei dawt ruang i a thihnak zong.

[V3]
 A bia thawngin tam chin ka hngalh, Ka Bawipa he cun kan um ti; A awnem
 cu ka theih zungzal, Zumh tlak a bia kei ca a si.

[C3]
   Jesuh kong tam chin in, Jesuh kong tam chin in, A khamhnak tling cu
   hngalh chin in, Kei dawt ruang i a thihnak zong.

[V4]
 A sunparnak a sang hringhran, A pennak ram a kau chinchin; Daihnak
 Bawipa a ratnak zong, A lianhngannak in ka hngalh chin.

[C4]
   Jesuh kong tam chin in, Jesuh kong tam chin in, A khamhnak tling cu
   hngalh chin in, Kei dawt ruang i a thihnak zong.</lyrics>
<title>JESUH KONG TAM CHIN IN CH95</title>
</song>