<?xml version="1.0" encoding="UTF-8"?><song><title>KA RA LIO CH248</title>
<key>F</key>
<lyrics>[V1]
 Ngaihchiat lung rawh ka phak ahcun, Pathian auhnak ka ngaih lai,
 Pathian nang kan zumh ca-ah khan, Ka hung ni-hin na sinah.

[C1]
   Ka hun lioah, Ka hun lioah, Thlua-chuahnak hmuh ka duh ca, Ka hun
   lioah, Ka hun lioah, Ka lung daihnak hmuh ka duh.

[V2]
 A thiang nunnem nun tha bikmi, Jesuh sinah kei ka hung, Pathian nang
 mah kut chungah khan, Ka zohkhenh ka domh-tlai tuah.

[C2]
   Ka hun lioah, Ka hun lioah, Thlua-chuahnak hmuh ka duh ca, Ka hun
   lioah, Ka hun lioah, Ka lung daihnak hmuh ka duh.

[V3]
 Pathian nangmah sin kep lawngah, Ka thlarau daihnak a um, Ka thih
 tikah vanmi lakah, Ka thlarau nang na hmuh lai.

[C3]
   Ka hun lioah, Ka hun lioah, Thlua-chuahnak hmuh ka duh ca, Ka hun
   lioah, Ka hun lioah, Ka lung daihnak hmuh ka duh.

[V4]
 Ka sinah um, i lawm ko ning, Hi vawlei lam har ahhin, Ngaihchiatnak
 lawmhnak siter tuah, Khuamui kha ceunak siter.

[C4]
   Ka hun lioah, Ka hun lioah, Thlua-chuahnak hmuh ka duh ca, Ka hun
   lioah, Ka hun lioah, Ka lung daihnak hmuh ka duh.</lyrics>
<hymn_number>248</hymn_number>
</song>