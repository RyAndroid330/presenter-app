<?xml version="1.0" encoding="UTF-8"?><song><key>Ab</key>
<lyrics>[V1]
 Chungkhar dawtnak um tikah, Zeizong te aa dawh, Chungkhar dawtnak um
 tikah, Lunglawmhnak a tam, Daihnak tampi a um i, Kaa kip ah nihnak a um,
 Dai tein caan nih a dih, Dawtnak umnak ah.

[C1]
   Dawtnak sung, Dawtnak thiang, Dai tein caan nih a dih, Dawtnak umnak
   ah.

[V2]
 Chungkhar dawtnak um tikah, Thlam chung hmanh a nuam, Huatnak le
 nah-chuahnak nih, Zei an tuah kho lo, Kan nunnak nuamhter awkah, Kan
 lamhmi kip vawlei cu, Dawtnak umnak hmun ah cun, Pangpar an cang dih.

[C2]
   Dawtnak sung, Dawtnak thiang, Dai tein caan nih a dih, Dawtnak umnak
   ah.

[V3]
 Chungkhar dawtnak um tikah, Zeizong te aa rem, Dawtnak umnak hmun ah
 cun, Zeizong te a thaw, Innpa he remnak a si, Rualchan he dawtnak a si,
 Khualtlung nih an i lawm i, Thangthatnak a tam.

[C3]
   Dawtnak sung, Dawtnak thiang, Dai tein caan nih a dih, Dawtnak umnak
   ah.

[V4]
 Bawi Jesuh Khrih nangmah nih, Kan sinah um tuah, Kan innchungkhar
 lakah hin, Nang Bawi ah si ko, Nang kan sin na um ahcun, Zeihmanh kan tih
 ti lai lo, Nangmah nih kannih inn cu, Thlua-chuahnak pe ko.

[C4]
   Dawtnak sung, Dawtnak thiang, Dai tein caan nih a dih, Dawtnak umnak
   ah.</lyrics>
<title>CHUNGKHAR DAWTNAK UM TIKAH CH400</title>
<hymn_number>400</hymn_number>
</song>