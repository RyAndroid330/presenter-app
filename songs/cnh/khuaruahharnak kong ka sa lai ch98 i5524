<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Khuaruahharnak kong ka sa lai, Khamhbawi Jesuh Khrih kong kha, Vancung
 khua in amah a ra, Vailamtahnak kha a in,

[C1]
   Khuaruahhar nak bia ka sak lai, Kei ca a thimi kong kha Vancungmi he
   kan sak te lai, Hi bia kha ka sak ti lai.

[V2]
 Ka tlau tikah a ka hmuh cang, Lampalh tu kha a hmuh cang, A kut
 chungah a ka pom cang, Lamtha chung ah a ka sanh.

[C2]
   Khuaruahhar nak bia ka sak lai, Kei ca a thimi kong kha Vancungmi he
   kan sak te lai, Hi bia kha ka sak ti lai.

[V3]
 Ka zawt tikah Khrih a ka damh, ka rilh tam ca zaang a tlawm, ka mitcaw,
 tihnak kha a um, Him in lam a ka hmuhsak.

[C3]
   Khuaruahhar nak bia ka sak lai, Kei ca a thimi kong kha Vancungmi he
   kan sak te lai, Hi bia kha ka sak ti lai.

[V4]
 Keimah cungah khuamui a tlung, Ngaihchiat lam ah ka kal ko. Kei he
 Jesuh zungzal a um, Him in lam a ka hmuhsak.

[C4]
   Khuaruahhar nak bia ka sak lai, Kei ca a thimi kong kha Vancungmi he
   kan sak te lai, Hi bia kha ka sak ti lai.

[V5]
 Ka thihnak caan kha a phak tiang, Jesuh a ka domhtlaih rih, Ka dawtmi
 ka hmuh khawh hna tiang, Vancung khua a ka kaipi.

[C5]
   Khuaruahhar nak bia ka sak lai, Kei ca a thimi kong kha Vancungmi he
   kan sak te lai, Hi bia kha ka sak ti lai.</lyrics>
<key>Eb</key>
<title>KHUARUAHHARNAK KONG KA SA LAI CH98</title>
<hymn_number>98</hymn_number>
</song>