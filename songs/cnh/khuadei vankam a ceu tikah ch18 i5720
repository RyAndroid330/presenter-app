<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>18</hymn_number>
<key>C</key>
<lyrics>[V1]
 Khuadei vankam ceu in, Ka lung nih a au i, Jesuh thangthat siseh,
 Riantuan thlacam zongah, Jesuh sinah kaa hrim, Jesuh thangthat siseh.

[V2]
 Ka ngaih a chiat ahcun, Ka lung a ka hnemh tawn, Jesuh thangthat
 siseh, Kaa lawmhnak zor hmanhseh, Ka hnangamnak a si, Jesuh thangthat
 siseh.

[V3]
 Vancung zungzal lawmhnak, Aa dawh bik hla tha cu, Jesuh thangthat
 siseh, Khuamui tihnak zongah, A thangthat hla thawngin, Jesuh thangthat
 siseh.

[V4]
 Leicung i ka nun lio, Ka hla tha bikmi cu, Jesuh thangthat siseh, Amah
 thangthatnak hla, Zungzal in hmun ko seh, Jesuh thangthat siseh.</lyrics>
<title>KHUADEI VANKAM A CEU TIKAH CH18</title>
</song>