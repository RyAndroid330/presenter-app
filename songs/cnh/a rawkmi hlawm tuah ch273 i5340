<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
 A rawkmi kha hlawm tuah, Thi deng zohkhenh tuah, Sualnak thlan in
 zaangfah in hung chuak tuah, A palhmi kha hram tuah, A rilmi tung tuah;
 Jesuh khamh thiamnak kong kha va chim tuah.

[C1]
   A rawkmi kha hlawm tuah, Thi deng zohkhenh tuah, Jesuh tlaih-channak
   nih, An khamh hna lai.

[V2]
 Sualnak ngaihchih-mi fa, A ngan ko rih hna, Amah bia zeiah an rel lo
 nain, Lungtak in va sawm tuah, Nem tein sawm tuah, An zumh ahcun
 ngaih-thiamnak an hmuh lai.

[C2]
   A rawkmi kha hlawm tuah, Thi deng zohkhenh tuah, Jesuh tlaih-channak
   nih, An khamh hna lai.

[V3]
 Mi lungthin chungah khan, Rul-hreu a hrolh ca, Thihnak le rawhnak nih
 khan a uk cang, Sihmanhseh dawtnak in, Na tongh hna ahcun, A rawk cia
 lung kha a nung than kho lai.

[C3]
   A rawkmi kha hlawm tuah, Thi deng zohkhenh tuah, Jesuh tlaih-channak
   nih, An khamh hna lai.

[V4]
 A rawkmi kha hlawm tuah, Tuan awk rian a si, Jesuh nih thazang fehnak
 an pek lai, Dawtnak in kirter tuah, A bi lam chungah, An nih ca Khamhtu a
 thih kha chim hna.

[C4]
   A rawkmi kha hlawm tuah, Thi deng zohkhenh tuah, Jesuh tlaih-channak
   nih, An khamh hna lai.</lyrics>
<title>A RAWKMI HLAWM TUAH CH273</title>
<hymn_number>273</hymn_number>
</song>