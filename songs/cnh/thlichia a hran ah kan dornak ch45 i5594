<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>45</hymn_number>
<key>F</key>
<lyrics>[V1]
 Kan himnak lung Jesuh a si, Thlichia a hran ah kan dornak, Harnak
 zeikhom in kan khamh rih, Thlichia a hran ah kan dornak,

[C1]
   Maw, retheimi caah Jesuh kan lungpi, Retheimi ca lungpi a si, Maw,
   retheimi caah Jesuh kan lungpi, Thlichia a hran ah kan dornak.

[V2]
 Chun ah naidem, zan ah dornak, Thlichia a hran ah kan dornak, Tihnung
 ral nih kan doh hmanhseh, Thlichia a hran ah kan dornak,

[C2]
   Maw, retheimi caah Jesuh kan lungpi, Retheimi ca lungpi a si, Maw,
   retheimi caah Jesuh kan lungpi, Thlichia a hran ah kan dornak.

[V3]
 Thlichia nih a kan dum tikah, Kan dornak kha Jesuh a si, Himnak hmun
 in kan zam lai lo, Thlichia a hran ah kan dornak,

[C3]
   Maw, retheimi caah Jesuh kan lungpi, Retheimi ca lungpi a si, Maw,
   retheimi caah Jesuh kan lungpi, Thlichia a hran ah kan dornak.

[V4]
 Maw, kan lungpi, himnak fek bik, thlichia a hran ah kan dornak, Kannih
 naih ah zungzal um tuah, Thlichia a hran ah kan dornak.

[C4]
   Maw, retheimi caah Jesuh kan lungpi, Retheimi ca lungpi a si, Maw,
   retheimi caah Jesuh kan lungpi, Thlichia a hran ah kan dornak.</lyrics>
<title>THLICHIA A HRAN AH KAN DORNAK CH45</title>
</song>