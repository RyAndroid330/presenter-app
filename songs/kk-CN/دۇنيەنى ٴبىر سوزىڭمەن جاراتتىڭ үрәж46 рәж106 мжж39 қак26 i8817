<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>46</hymn_number>
<author>ابدۋاليەۆا ٴجۇلدىز</author>
<key>C</key>
<lyrics>[V1]
.     Am                     Dm
 دۇنيەنى ٴبىر سوزىڭمەن جاراتتىڭ
.  G                 C
 الەمدى شىندىعىڭا قاراتتىڭ
.     Am                    Dm
 رۋحىڭمەن كيەلى سەنىم بويلاتىپ،
.       E7
 وسى ٴاندى جۇرەگىمدە وياتتىڭ.

[C1]
.    Am                G
   و، يسا،سەن الەمنىڭ تىرەگى،
.         F                       E7
   ادامزاتتىڭ تىلەگى، تىرشىلىكتىڭ وزەگى
.      Am                  G
   و، ٸسا ٴامىر بەردىڭ ومىرگە
.               F                      E7
   سەنگەن ادام وزىڭە، ٴتىرىلسىن دەپ ماڭگىگە.

[V2]
 الەمدى سۇيگەندىكتەن سونشالىق،
 قۇدايىم، بەردىڭ بىزگە۔قۇرباندىق.
 يسا بوپ، دۇنيەگە كەلدىڭ سەن،
 قۇتقارام، كۇنادان دەپ، حالقىندى،

[V3]
 ماداقتاپ، قۇرمەتتەيمىن ٴوزىڭدى
 عالامعا جەتكىزەرمىن ٴسوزىڭدى.
 وياتىپ، سەنىڭ بەرگەن رۋحىڭمەن،
 شىندىقتى اشىپ بەردىڭ ەركىڭمەن</lyrics>
<title>دۇنيەنى ٴبىر سوزىڭمەن جاراتتىڭ ҮРәж46 РӘЖ106 МЖЖ39 Қак26</title>
</song>