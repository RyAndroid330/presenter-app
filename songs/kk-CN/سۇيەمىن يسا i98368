<?xml version="1.0" encoding="UTF-8"?><song><title>سۇيەمىن يسا</title>
<lyrics>[V1]
 // جالعىزىم مەنىڭ سۇيەمىن سەنى يسا/اكە،
 ماحابباتىمسىڭ، جارىعىمسىڭ سەن يەم.
 ٴۇمىتىم مەنىڭ، ەشبىر قالدىرمايسىڭ سەن،
 شىن جۇرەگىممەن سەنى اڭسايمىن مەن. //

[C1]
   // يسا!
   شىنايى، ٴتىرى جالعىزىم سەن مەنىڭ! //

[V2]
 // ٴتاڭىرىم جالعىز سەنى العىستايم
 جالعىز كيەلىسىڭ،
 جالعىز مەيىرىمدى ىزگى،
 ٴتاڭىرىم تەك سەنى سۇيەمىن.
 سەنى قاستەرلەيمىن،
 باس ٴيىپ ساعان كەلەمىن //</lyrics>
<author>جانات كۋساينوۆا</author>
</song>