<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 كۇنى۔ٴتۇنى تالمايمىن،
 ٴتاڭىردى ماداقتايمىن.
 جاراتقانى قانشا مىڭ،
 ساناۋدان مەن شارشادىم.

[C1]
   كۇنى، ايى، جارىعى،
   وزەن، كولى، ارىعى.
   باقا، شايان، بالىعى،
   ورمان، تاۋى، قورىعى.
   اۋا، سۋى، گۇلدەرى،
   ارىستان مەن پىلدەرى.
   كەڭ دالاسى، شولدەرى.
   باۋ باقشاسى، بەلدەرى.

[V2]
 دوستار، بەرى كەلىڭدەر،
 ماعان جاردەم بەرىڭدەر.
 ون۔اق ساۋساق بار مەندە،
 بىرگە ساناپ كورىڭدەر.

[V3]
 ٴبارىن ساناپ بىتپەيمىز،
 سانىنا دا جەتپەيمىز.
 گۇلدەندىرگەن ٴومىردى،
 ماداقتايىق ٴتاڭىردى.

[C2]
   ارپا، بيداي، سۇلىسى،
   تارى، تالقان، كۇرىشى.
   انار، الما، ٴجۇزىمى،
   جال، جاياسى، شۇجىعى.
   قۇرت، ىرىمشىك، ايرانى،
   بال، شەكەرى، مايلارى.
   قىمىز، شۇبات، ساۋمالى،
   جەمىس۔جيدەك، باۋلارى.</lyrics>
<title>كۇنى، ٴتۇنى تالمايمىن РӘЖ252</title>
<hymn_number>252</hymn_number>
</song>