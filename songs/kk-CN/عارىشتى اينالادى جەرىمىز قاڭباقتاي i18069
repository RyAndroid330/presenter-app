<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.Am          Dm
 عارىشتا اينالادى،
.E7            Am
 جەرىمىز قاڭباقتاي!
.Am              Dm
 شەكسىز الەم ورتاسىندا،
.G             C
 وسىنداي كىشكەنتاي!

[C1]
.     Am         Dm
   // دوسىم قول ۇسىن جاقىنىڭا!
   دوسىم قول ۇسىن جاقىنىڭا!
   دوسىم قول ۇسىن جاقىنىڭا!
   كوزىڭنەن توگىلسىن نۇر! //

[V2]
 جاماندىقتى ۇمىتشى،
 قۋانىش كەلدى!
 كەڭ بايتاق جەرىمىزگە،
 شاتتىعىن بەردى!

[C2]
   // دوسىم قۋانتشى جاقىنىڭدى!
   دوسىم قۋانتشى جاقىنىڭدى!
   دوسىم قۋانتشى جاقىنىڭدى!
   كوزىڭنەن توگىلسىن نۇر! //

[V3]
 كوكتەگى اكەم، الەمدە،
 ٴبارىن سۇيەدى!
 اسىعايىق جارىعىنا،
 ونىڭ كيەلى!

[C3]
   // دوسىم ٴتاڭىردى ماداقتايىق!
   دوسىم ٴتاڭىردى ماداقتايىق!
   دوسىم ٴتاڭىردى ماداقتايىق!
   كوزىڭنەن توگىلسىن نۇر! //</lyrics>
<title>عارىشتى اينالادى جەرىمىز قاڭباقتاي</title>
</song>