<?xml version="1.0" encoding="UTF-8"?><song><title>و يسا سەن كەرەمەت ۇلىسىڭ</title>
<lyrics>[V1]
 // و، يسا سەن كەرەمەت ۇلىسىڭ،
 و، يەم سالتاناتقا بولەندىڭ.
 جارىق نۇردى سەن شاپانداي كيەسىڭ،
 شىندىق ٴسوزىڭ سەنىڭ شىنايى ٴومىر بەردى! //

[C1]
   // پاتشا سەن ورناتقان بيلىكتى
   ەشكىم ەشقاشان قوزعاي المايدى.
   يسا توگىلگەن سەنىڭ قانىڭ
   اسا باعالى، تەڭدەسى جوق بۇكىل الەمدە. //</lyrics>
<author>جانات كۋساينوۆا</author>
</song>