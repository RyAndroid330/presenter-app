<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>130</hymn_number>
<author>جاڭقاباەۆا نۇرسۇلۋ</author>
<lyrics>[V1]
.      Cm       Fm     G        Cm
 ٴومىردىڭ ماقساتى نە دەپ ويلايسىڭ؟
.        Fm             Bb      Eb
 كۇناسىز بولام دەپ كىمدى الدايسىڭ؟
.         C                   Fm
 باقىتتى سەن نەگە بولا المايسىڭ؟
.       Cm        Fm    G      Cm
 //  قۇدايسىز ومىردەن شىندىق تاپپايسىڭ.  //

[V2]
 بۇل جالعان دۇنيەدە ادالدىقتى سەن،
 تاپتىم دەپ ويلادىڭ، ٴبىراق تاپپادىڭ.
 سەبەبى ٴومىردىڭ ناعىز شىندىعى،
 //  قۇدايدىڭ جولىندا، سونى تۇسىنگىن.  //

[V3]
 ٴتاڭىردىڭ سوزىنەن سۋسىن تارتىڭدار،
 شىندىقتىڭ نانىنان تەگىن الىڭدار.
 سوندا قۇدايمەنەن ماڭگى بولارسىڭ،
 //  جۇماقتىڭ تورىندە باقىت تابارسىڭ.  //</lyrics>
<key>G</key>
<title>ٴومىردىڭ ماقساتى نە دەپ ويلايسىڭ؟ РӘЖ130 ҮРәж159</title>
</song>