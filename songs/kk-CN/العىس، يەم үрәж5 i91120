<?xml version="1.0" encoding="UTF-8"?><song><title>العىس، يەم ҮРәж5</title>
<lyrics>[V1]
. G             D
 الدىڭا سەنىڭ كەلەم،
. Am                         Em
 ايتقىم كەلەدى مەنىڭ ساعان، ٸەم:
.   C       D
 // العىس، ٸەم! //
. G            D
 ماعان بەرگەندەرىڭە،
.Am                     Em
 جارىلقاۋ راقىمىڭدى توككەنىڭە
.   C       D
 // العىس، ٸەم! //

[C1]
.   G
   قۋانىشپەن مەن،
.    D
   ماداق انىمەن،
.   Em
   سوزام قولىمدى
.    G    D/F#
   ساعان ايتامىن:
.   Em     C
   العىس، ٸەم،
.   G    D/F#
   ساعان ايتام:
.   Em    C
   العىس، يەم!

[V2]
 ومىرىمە سەن كەلدىڭ،
 تۇنەكتى سەرپىپ ماعان نۇر بەردىڭ،
 // العىس، يەم! //
 كۇنام مەن ۇياتتى الدىڭ،
 ٴالسىز بەن اۋرۋدى ساۋىقتىردىڭ.
 // العىس، يەم! //</lyrics>
<key>G</key>
<author>دُن مُِن</author>
<hymn_number>5</hymn_number>
</song>