<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>177</hymn_number>
<title>سەنى ىزدەيم ҮРәж177</title>
<aka>ازاتتىعىڭدا تۇرام</aka>
<lyrics>[V1]
. G    A
 سەنى ىزدەيم،
. Bm   D
 قۇدىرەتتى!
. G      A
 باسىمدى يەم،
. Bm
 جىعىلامىن.
. G     A    Bm        D
 ساعان ۇقساس پاتشا جوق كىشىپەيىل،
. G       A    Bm   A
 قۇتقارىپ الىپ ەمدەگەن.

[P1]
.   Bm   D
   قۇرالاقانمىن،
.   D   A
   ٴبارىن سەن بەردىڭ.
.  Bm       A
   باسقا ەش نارسە،
.   G   A
   ماڭىزدى ەمەس.

[C1]
.   D  A  Bm
   سەنى سۇيەم،
.   C     D
   قۇتقاردىڭ سەن.
.  A      Bm
   تەك ساعان مۇقتاجبىن،
.   G    D
   كەرەكسىڭ سەن.

[C2]
.   G  A
   سٸىنامىن،
.   A  Bm  D
   بەيبىت ٸەم.
.   G    A
   تىنىم تابام،
.   Bm    A
   ازات ەتتىڭ.

[B1]
.  D
   ازاتتىعىڭدا تۇرام.
.   Bm
   ازاتتىعىڭدا تۇرام.
.   D       G
   ادالدىق ۇسىنام.
.   D       G
   ادالدىق ۇسىنام.</lyrics>
<key>G</key>
</song>