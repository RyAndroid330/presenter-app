<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am              Dm
 يسا سەنى سۇيەدى، ەي، باۋىرىم،
.G                   C
 ەسىگى اشىق سەن ٴۇشىن ٴار قاۋىمنىڭ.
.    Am                  Dm
 //  تاۋبەگە كەل اعايىن، وتىنەمىن،
.E                  Am
 كىمگە كەرەك ۋاقىتشا ساۋىعىڭ.  //

[C1]
   ماڭگىلىك ٴومىر بەرەدى،
   ونىڭ قولىندا سەبەبى.
   كۇتىڭدەر، ىزدەڭدەر، اسىعىڭدار.
   يسا جاقىندا كەلەدى، كەلەدى.
   يسا جاقىندا كەلەدى.

[V2]
 كوككە ٴبىزدى وزىمەن اكەتەدى،
 قابىلداساڭ يسانى سول جەتەدى.
 //  اتىمەن تەك ۇلىنىڭ كەلەرسىڭ،
 اق نيەتپەن ايتىلعان ۋادە ەدى.  //</lyrics>
<title>يسا سەنى سۇيەدى، ەي، باۋىرىم ҮРәж76 Қак13 МЖЖ58 РӘЖ116</title>
