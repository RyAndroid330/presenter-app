<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[C1]
.     D              Em
   كيەلى قۇداي بىزدەردى
.  D         A7
   ساقتاپ ٴجۇرشى ٴارقاشان.
.        Em           D
   // سيىنىپ كەلەمىن ساعان،
.    G       A        D
   تىنىشتىق بەرشى ماعان //

[V1]
.  D               A
 كەشكە ساعان كەلەمىن،
.  A              D
 الدىڭدا تىزە بۇگەمىن.
.   D Em               D
 ٴاربىر اتقان ارايلى كۇن،
.   A7
 ٴبارى دە سەنىڭ بەرگەنىڭ.

[V2]
 اداسىپ ٴجۇردىم، بىلمەدىم،
 قاتەلىكتى كوپ ىستەدىم.
 كەشىرشى، مەنى قۇدايىم،
 جانىمدا بولشى ٴاردايىم.

[V3]
 پەرىشتەلەرىڭ قورعاسىن،
 ٴاربىر تۇندە بىزدەردى.
 ەشبىر جاماندىق بولماسىن،
 كورەيىن ٴتاتتى تۇستەردى.</lyrics>
<title>كيەلى قۇداي بىزدەردى РӘЖ250</title>
<hymn_number>250</hymn_number>
</song>