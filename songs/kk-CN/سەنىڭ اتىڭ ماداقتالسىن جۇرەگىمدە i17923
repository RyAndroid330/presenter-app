<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ////  سەنىڭ اتىڭ ماداقتالسىن
 جۇرەگىمدە، ومىرىمدە يسا!  ////

[C1]
   //  توگىلگەن كيەلى سەنىڭ قانىڭ،
   ٴومىرىمدى تولىقتاي وزگەرتتى!
   ايقىشتاعى شالىنعان قۇربانىڭ،
   جۇرەگىمنەن ول كەتپەيدى! يسا!  //

[B1]
   ////  يسانىڭ كيەلى قانى، اقتادى مەنى ماڭگىگە!  ////</lyrics>
<title>سەنىڭ اتىڭ ماداقتالسىن جۇرەگىمدە</title>
</song>