<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[V1]
.D
 قۋان بىزبەن،
.D
 قۋان قۇدايعا،
.Cm
 قۋان بىزبەن،
. D  Cm  D
 ٴان شىرقا.

[V2]
.D
 كەلىڭدەر، شالقيىق،
.Cm
 كەلىڭدەر، تولقيىق،
.D
 قۇدايدى ماداقتاپ،
.D   Cm  D
 شاتتانايىق.

[C1]
.      Gm
   /// ٴبىزدىڭ قۇداي بىزبەن، ///
.     Cm
   // يسا ٴارقاشان مەنىمەن //
.  Cm      D
   كەل، شىرقا،
.  Cm      D
   كەل، شىرقا،
.          Gm   Cm  Gm
   سۇيىكتى اكە الدىندا.</lyrics>
<title>قۋان بىزبەن ҮРәж105</title>
<hymn_number>105</hymn_number>
