<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>69</hymn_number>
<lyrics>[V1]
.  Bm           G        F#
 جىلدار وتسە دە توقتالماستان،
.Bm        B7
 ۇمىتپەن ٴومىر ٴسۇر ٴارقاشان.
.G                 A           D
 قيىندىق بولسا جولىڭدا، يسا جانىڭدا،
. G          F#7
 تاستامايدى سەنى ەشقاشان.

[C1]
.   Bm             G         F#
   ٴبىل، ول كەلىپ وياتادى الەمدى،
.   Bm                   B7
   ٴبىل، ول كەلىپ قۋانتادى بار ەلدى.
.     G       Em         F#
   ٴبىل، ول كەلىپ باقىتسىزدىق بولمايدى،
.   G      F#7       Bm
   ٴوزى ٴبىزدى قولدايدى.

[V2]
 جاڭبىرلى كۇز جابىرقاتسا،
 جاڭبىرى قارمەن الماسسا.
 جەردەگى ۋاقىت ورالمايدى، شىنايى ٴۇمىت
 جوعالمايدى، ەش جوعالمايدى.

[C2]
   ٴبىل، ول كەلىپ كورىنەدى الەمگە.
   ٴبىل، ول كەلىپ باس يگىزەر بار ەلگە.
   ٴبىل، ول كەلىپ قۋانتادى سەنگەندى،
   سەنىممەنەن جەڭگەندى.</lyrics>
<key>D</key>
<title>جىلدار وتسە دە توقتالماستان РӘЖ82</title>
</song>