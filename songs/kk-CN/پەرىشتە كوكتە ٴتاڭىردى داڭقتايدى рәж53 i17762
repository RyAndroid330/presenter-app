<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>53</hymn_number>
<author>نېىزۋېستنыي</author>
<key>Dm</key>
<lyrics>[V1]
.   Dm               A7
 پەرىشتە كوكتە ٴتاڭىردى داڭقتايدى،
.A7            Dm
 ۇلىنىڭ ۇلىسىن ماداقتايدى، ماداقتايدى.
.    Gm       C       F      Dm
 // ماڭگىلىك داڭق، ماڭگىلىك داڭق،
. A7           Dm           D
 ماسىحكە داڭق، // اتاق پەن داڭق // .

[V2]
 پەرىشتە اۋەنىمەن بىرىككىم كەلەدى،
 حالقىڭمەن قوسىلا دارىپتەيمىن، دارىپتەيمىن.
 // جەڭىمپاز، داڭقتى يساعا قۋانىپ،
 جۇرەگىم شاتتانىپ // اندەتەمىن // .

[V3]
 جەردەگى قاۋىمىڭ كۇتەدى ٴوزىڭدى،
 كۇيەۋ جىگىت كەلەر كۇندى اڭسايدى، كۇندى اڭسايدى.
 // پاك، تازا قالىڭدىق دايار تۇر كۇتۋمەن،
 جۇرەگى شاتتانىپ، // ماداقتايدى // .

[V4]
 ٴماسىح قۇداي ۇلى، ول ماڭگى پاتشامىز،
 كوككە اكەتەم دەگەن ۋادەسىن ساقتايدى.
 // جۇرەگىم ٴتاڭىردى، يسا ٴماسىحتى،
 داڭققا لايىقتىنى // ماداقتايدى // .</lyrics>
<title>پەرىشتە كوكتە ٴتاڭىردى داڭقتايدى РӘЖ53</title>
</song>