<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>28</hymn_number>
<author>تاش ئاكا</author>
<lyrics>[V1]
.Dm             Gm
 باقىتتى ٴومىر ٴبىر سەندە،
.A     Asus       Dm
 اداسىپ جۇرگەن كەزدە
.Bb       C              Dm
 ويلاماعان ٴبىر جول باستادىم.
.Dm         Gm
 جاقىنىم بولدى ٴبىر دوس
. A  Asus        Dm
 ٴومىرىمدى وزگەرتتى.
.Bb      C           Dm
 ريزاشىلىعىم شەكسىز وعان.

[C1]
.  Dm       F            C
    العىس ساعان، العىس ساعان
.  Gm          Am          Dm
   قۇدايدىڭ قۇرباندىق توقتىسى.
.  Dm       F            C
    العىس ساعان، العىس ساعان
.  Gm         Am          Dm
   ماڭگىلىك ساعان مەن ريزامىن.</lyrics>
<key>Dm</key>
<title>باقىتتى ٴومىر ٴبىر سەندە МЖЖ28</title>
</song>