<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>253</hymn_number>
<lyrics>[V1]
.            C      C G
 كۇنادان تازالايمىن،
.         G          C
 كەلشى، ماعان، بالام.
 تار جولدا جەتەلەيمىن،
 جول كورسەتىپ ساعان.

[C1]
.                    F C
   ساعان اكە بولامىن،
.     G                C
   قالدىرمايمىن جالعىز.
   قۋانىشتى جۇزىڭمەن
   ايتارسىڭ سەن العىس.

[V2]
 ۇيىمە اپارامىن
 قارسى الىپ مەن سەنى،
 قاسىڭنان تابىلامىن
 شاقىرساڭ سەن مەنى.

[V3]
 قۇتقارىلعانداردىڭ.
 قۇداي بەرگەن ورىن بۇل،
 شارشاپ۔شالدىققاننىڭ</lyrics>
<key>C</key>
<title>كۇنادان تازالايمىن РӘЖ253</title>
</song>