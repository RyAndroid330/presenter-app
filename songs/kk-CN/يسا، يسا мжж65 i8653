<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>65</hymn_number>
<lyrics>[V1]
.Am
  يسا، يسا!
.Dm               Am
 كيەلى تاڭدالعان ٸسا!
.Am
 يسا، يسا!
.Dm                 Am
 تىرىلگەن جاراتقان ٸسا!
.    Dm                         C
 //   سەنىڭ اتىڭ بال سياقتى ەرنىمە،
.Dm                        C
 سەنىڭ رۋحىڭ سۋ سياقتى جانىما.
.E7                Am
 سەنى سۇيەمىن۔اۋ، ٸسا!  //
.E
 يسا، يسا!
.E7               Am
 كيەلى تاڭدالعان ٸسا!

[C1]
.      Dm
   //   جاراتقان يەم جالىنام ساعان!
.  Am
    جاراتقان يەم باتا بەر ماعان!
.  Dm              G
    ٴسوزىڭدى سەنىڭ تاراتايىن،
.  E                 Am (A7)
    حالقىما سەنى اڭساعان!  //

[V2]
 //  يسا، مەنى قۇتقاردىڭ
 سەن ولىمنەن،
 سودان بەرى ۇلگى الام،
 تەك وزىڭنەن!  //

[V3]
 //  مەن اداسىپ جۇرگەندە،
 ٴوزىڭ تاپتىم،
 ۇلىڭدى قيىپ، مەن ٴۇشىن،
 كۇنامدى جاپتىڭ!  //</lyrics>
<key>Am</key>
<title>يسا، يسا! МЖЖ65</title>
</song>