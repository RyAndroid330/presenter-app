<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>135</hymn_number>
<author>شىنتەمىروۆ ٴابىلحايىر</author>
<key>C</key>
<lyrics>[V1]
.      Em                     Am
 ىزدەپ جۇرگەن بار الەمنىڭ ادامى،
.    B7                       Em
 بار ەكەن۔اۋ بۇل ٴومىردىڭ عاجابى!
.   C                       Am
 قۇداي ونى بىزدەر ٴۇشىن جىبەرگەن،
.   B7
 بولماسىن دەپ ادامزاتتىڭ ازابى.
.  Em                         Am
 ەندى ٴبىلدىم، ەندى سەزدىم قۇدايىم،
.  B7                        Em
 سەن قاسىمدا ٴجۇرىپسىڭ عوي ٴاردايىم.
.  C                      Am
 اكەم۔اي دەپ جىلاعانىم سول ەدى۔اق،
.  B7
 اجەپتاۋىر ٴجىبىپ قالدى ماڭدايىم.

[C1]
.   Am          Em      Am       Em
   وۋ، كوكتەگى اكە، وۋ، كوكتەگى اكە!
.       C                       B7
   //  جەتەلەدىڭ مەنى عاجاپ ومىرگە اكە!  //

[V2]
 بۇل ومىردەن شىندىق تاپپاي ٴوزىڭسىز،
 كوپ قينالدىم سەنىڭ اسىل ٴسوزىڭسىز.
 وزىمدى۔ٴوزىم الداۋمەنەن ٴجۇرىپپىن،
 بولامىن دەپ بۇل ومىردە كۇناسىز.
 كەشىر اكە، كەشىر مەنىڭ كۇنامدى،
 قولىڭ سوزىپ قابىل الشى بالاڭدى.
 قۇتقارا گور ازاپ شەككەن جانىمدى،
 بىلمەپپىن۔اۋ اكە، سەنىڭ بارىڭدى.

[V3]
 بالاڭ بۇگىن اقىلعا كەپ ويلاندى،
 جۇرەكتە ٴبىر جاڭا سەزىم وياندى.
 كوز الدىدا ايقىش اعاش كورىنىپ،
 ەندى عانا قىزىل قانعا بويالدى.
 ٴوز ۇلىڭدى ٴبىزدىڭ جەرگە جىبەردىڭ،
 كۇنام ٴۇشىن قۇرباندىعىڭدى بەردىڭ.
 نەتكەن شەكسىز، نەتكەن ىستىق ماحاببات!
 ٴوز قانىڭمەن كۇنامدى سەن كەشىردىڭ.</lyrics>
<title>ىزدەپ جۇرگەن بار الەمنىڭ ادامى РӘЖ135 Қак23</title>
</song>