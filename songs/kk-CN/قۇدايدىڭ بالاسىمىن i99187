<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 قۇتقاردىڭ مەنى، ٴاسىم انىڭمەن قورشادىڭ مەنى يەم!
 ازات ەتتىڭ سەن جاۋلاردان مەنى، بار قورقىنىش كەتتى.

[C1]
   // كۇنانىڭ قۇلى ەمەسپىن.
   قۇدايدىڭ بالاسىمىن! //

[V2]
 تۋىلماي تۇرىپ تاڭدادىڭ مەنى، ٴسۇيىپ ەسىم بەردىڭ،
 قايتا تۋىلدىم، وتباسىم بولىپ، توگىلگەن قانىڭمەن.

[B1]
   قۇشاعىڭا الىپ كوكتەگى اكەنىڭ
   قورشايدى مەنى ۇرانى ازاتتىقتىڭ،
   قۇتقارىلدىق ٴبىز كۇنانىڭ قۇلدىعىنان.
   ۇلى مەن قىزىمىز بوستاندىق جاريالايمىن!
   و۔و۔و۔و...

[C2]
   // مەنىڭ كۇشىم تەڭىزدەردى اشتىڭ سەن،
   ماحاببات جويدى قورقىنىشتى.
   قۇتقاردىڭ ەندى جار سالامىن،
   قۇدايدىڭ بالاسىمىن! //</lyrics>
<title>قۇدايدىڭ بالاسىمىن</title>
<author>بِتهِل مُسِك</author>
</song>