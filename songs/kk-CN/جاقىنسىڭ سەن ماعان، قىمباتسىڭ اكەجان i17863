<?xml version="1.0" encoding="UTF-8"?><song><author>نۇر</author>
<title>جاقىنسىڭ سەن ماعان، قىمباتسىڭ اكەجان</title>
<key>F</key>
<lyrics>[V1]
.   Dm              Gm  A         Asus/Dm/F
 //  جاقىنسىڭ سەن ماعان، قىمباتسىڭ اكەجان!
.Dm         Gm
 تاستامايسىڭ سەن، بالاڭدى،
.F       C      F       C
 تەك ادالدىقپەن، شىدامدىلىقپەن
.F      A       Dm
 بالاڭدى قۇتقاراسىڭ! //

[C1]
.     Dm        Gm
   //  شىن جۇرەكتەن سەنى ىزدەيمىن،
   سەنەمىن مەن، سەنى تابامىن!
   الىس ەمەس، سەن جاقىنداسىڭ!
   ىزدەگەندەرگە، تابىلاسىڭ،
   ەسىك قاققانعا، اشىلاسىڭ،
   ويتكەنى سەن ۔ ٴتىرى قۇدايسىڭ!
   كەشىرىپ، سۇيەسىڭ،
   سەن مەنى قۇتقارعان تۋعان اكەمسىڭ! //

[V2]
 // كورمەسەم الىستان، جاقىندايسىڭ ماعان
 سويلەيسىڭ سەن جۇرەگىمە،
 داۋىستى ەستىپ جىگەرىم ارتىپ
 ان۔جىرىمدى ارنايمىن. //</lyrics>
</song>