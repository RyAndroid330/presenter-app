<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>144</hymn_number>
<title>ٴتاڭىر بىزبەن بىرگە بول МЖЖ144</title>
<key>C</key>
<lyrics>[V1]
.C
 ٴتاڭىر بىزبەن بىرگە بول،
.G
 جارىلقاشى بىزدەردى.
. F
 ٴبىزدىڭ جۇرەكتەر،
.        C         G
 سەنىڭ رۋحىڭمەن تولسىن.

[C1]
.      F         G         C
   //   العىستار ايتامىز ساعان،
.           Am
   ساعان ماڭگى يسا.
.  F       G         C
    يەم جارقىراشى ماڭگى،
   اm
   ماڭگى جارقىراشى.  //
.  F         G         C
    راحمەت ساعان، و، قۇداي!

[V2]
 ٴبىز سەنىمەن بولعىمىز
 كەلەدى يسا،
 سەنىڭ اتىڭدى
 بىزدەر قاستەرلەيمىز.</lyrics>
</song>