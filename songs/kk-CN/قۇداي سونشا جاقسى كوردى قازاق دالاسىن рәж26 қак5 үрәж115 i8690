<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26</hymn_number>
<author>ابدۋاليەۆا ٴجۇلدىز</author>
<key>Bm</key>
<lyrics>[V1]
. Bm          Em          F#7    Bm F#7
 قۇداي سونشا جاقسى كوردى قازاق دالاسىن،
. Bm      Em7          A         D
 ول جىبەردى ٴوزى سۇيگەن يسا بالاسىن.
.     G         A           F#m         Bm
 //  كۇناسىنان قۇتقارىلسىن، امان بولسىن دەپ،
.  Em           A          F#7       Bm
 سۇيگەندىكتەن قۇرباندىققا بەردى بالاسىن.  //

[V2]
 و، جاراتقان نەتكەن شەكسىز ماحابباتىڭ،
 بىتپەس سونشا بىزگە توگەر شاپاعاتىڭ.
 //  سيىنامىز ٴبىر وزىڭە، قۇداي اكە،
 تىنىشتىقتا، قۋانىشتا ٴبىر وزىڭدە.  //

[V3]
 تالاي ادام بىلمەي كەتتى بۇل شىندىقتى،
 بىلسە داعى، قابىلداماي قۇرباندىقتى.
 //  ەي، ادامزات ايالداشى، قابىلداشى،
 يسا توككەن كۇناڭ ٴۇشىن تازا قاندى.  //</lyrics>
<title>قۇداي سونشا جاقسى كوردى قازاق دالاسىن РӘЖ26 Қак5 ҮРәж115</title>
</song>