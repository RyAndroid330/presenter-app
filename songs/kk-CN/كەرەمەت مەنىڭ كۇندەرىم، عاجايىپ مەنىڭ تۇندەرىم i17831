<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.C
 // كەرەمەت مەنىڭ كۇندەرىم،
.G
 عاجايىپ مەنىڭ تۇندەرىم.
 قاسىمداسىڭ سەن ماڭگى يسا!
 بولدىڭ سەن مەنىڭ تىرەگىم،
 تىنىشتىعىڭدا جۇرەگىم،
 العىس ايتىپ ٴان ايتامىن مەن. //

[C1]
   // ەركەلەگەن قۇستارىنا،
   ماداقتاعان باۋىرلارىما،
   اينالاڭا قاراشى جاڭا،
   بۇل كەرەمەت قۇدايدىڭ ٴىسى! //

[C2]
   // العىستايدى ٴاربىر دەمىم سەنى يەم!
   العىستايدى ٴاربىر ٴىسىم سەنى يسا!
   العىستايدى وي۔پىكىرىم، جان دۇنيەم!
   العىستايدى! //</lyrics>
<title>كەرەمەت مەنىڭ كۇندەرىم، عاجايىپ مەنىڭ تۇندەرىم</title>
<author>نۇر</author>
</song>