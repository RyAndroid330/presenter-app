<?xml version="1.0" encoding="UTF-8"?><song><title>سەنىمەن كەلەدى تىلدەسكىم ҮРәж176 РӘЖ19</title>
<key>G</key>
<lyrics>[V1]
.   Em        Am   B7  Em
 سەنىمەن كەلەدى تىلدەسكىم،
.  Em    Am    B7  Em   E7
 ناعىز جاقىن جان دوسىم مەنىڭ.
.     Am       D             G Em
 //  جوعارىدان سەن ماعان قاراپ،
. Am         B7        Em
 ٴدۇرسىلىن ەستيسىڭ جۇرەكتىڭ.  //

[V2]
 سەنىمەن تىلدەسكىم كەلەدى،
 جەڭىلدەتىپ قايعى۔مۇڭىمدى.
 //  بۇل ٴومىر مەنى تۇسىنبەيدى،
 اشامىن ساعان بار سىرىمدى.  //

[V3]
 تىلدەسكىم كەلەدى سەنىمەن،
 ويتكەنى الىستا دوستارىم.
 //  قايعىمدى بولىسپەي ولارمەن،
 ٴبارىن دە ساعان مەن بەرەمىن!  //

[V4]
 اينالامدى تۇنەك باسقاندا،
 تىلدەسۋدى كۇتەم اسىعا.
 //  جوعارىدان سەن ماعان قارا،
 سەنىمدى دوسىم، كەل قاسىما.  //</lyrics>
<hymn_number>176</hymn_number>
</song>