<?xml version="1.0" encoding="UTF-8"?><song><title>جەدەل حابار РӘЖ239</title>
<key>G</key>
<lyrics>[V1]
.Em
 جەدەل حابار كەلەدى،
.Am
 كەلەدى كەلەدى!
.B7                          Em
 نە بولىپ قالدى، نە بولىپ قالدى؟
.Em
 بەتلەحەم قالاسىندا،
.  Am
 قالاسىندا، قالاسىندا،
.B7
 تۋدى يسا ۔ ٴماسىح!
.              Em
 تۋدى يسا ۔ ٴماسىح!

[V2]
 وعان ورىن بولمادى،
 بولمادى، بولمادى،
 ادام ۇيىندە، ادام ۇيىندە،
 كەدەيلىكتە تۋىلدى،
 تۋىلدى،تۋىلدى،
 اقىردا جاتتى،
 اقىردا جاتتى!

[V3]
 باقتاشىلار سول ٴتۇنى،
 سول ٴتۇنى، سول ٴتۇنى،
 قۋاندى شەكسىز، قۋاندى شەكسىز،
 پەرىشتەلەر جاريالاپ،
 جاريالاپ، جاريالاپ،
 قۋاندى شەكسىز،
 قۋاندى شەكسىز.

[V4]
 كوكتە قۇداي داڭقتالسىن،
 داڭقتالسىن، داڭقتالسىن،
 بەرگەن ۇلى ٴۇشىن! بەرگەن ۇلى ٴۇشىن!
 جەر جۇزىندە تىنىشتىق،
 تىنىشتىق، تىنىشتىق،
 بولسىن ماڭگىلىك،
 بولسىن ماڭگىلىك.</lyrics>
<hymn_number>239</hymn_number>
</song>