<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>281</hymn_number>
<key>D</key>
<lyrics>[V1]
.D     G    A  D
 مەن قوزىسى يسانىڭ،
.D    G    A     D
 شاتتانادى جۇرەگىم،
.D     G            A
 قامقور بولدى جول سىلتەپ،
.    G         A
 ورىندالدى تىلەگىم.
.        G         D
 جاقسى كورىپ كۇن سايىن،
.    G    A    D
 سۇيەتىنىن بىلەمىن.

[V2]
 ۇيدەن شالعاي جۇرسەم دە،
 سۇيەنىشىم، تىرەگىم،
 اشىقسام ٴنار بەرەتىن،
 جايلاۋىندا جۇرەمىن.
 شولدەسەم ول اپارار،
 تۇنىق سۋعا ۇنەمى.

[V3]
 قوزىسىمىن يسانىڭ،
 مەن باقىتتى بالامىن.
 جەردەگى ٴومىر بىتكەندە،
 كوكتەگى ۇيىمە بارامىن.
 قۇشاعىندا اكەنىڭ،
 الاڭسىز دەمالامىن.</lyrics>
<title>مەن قوزىسى يسانىڭ РӘЖ281</title>
</song>