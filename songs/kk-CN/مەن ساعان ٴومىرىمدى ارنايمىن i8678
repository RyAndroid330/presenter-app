[C1]
.            Em       Am
   // مەن ساعان ٴومىرىمدى ارنايمىن،
.    D    G
   يسا، مەنى سەن قولدانشى.
.         Em     D
   ٴار كۇندە سوزىڭە ۇمتىلامىن،
.       B      Em      D   Em
   ٴتاڭىرىم ساعان مەن سەنەمىن. //</lyrics>
