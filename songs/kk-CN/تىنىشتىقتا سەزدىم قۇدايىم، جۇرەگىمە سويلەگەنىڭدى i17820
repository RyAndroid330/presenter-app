<?xml version="1.0" encoding="UTF-8"?><song><author>نۇر</author>
<title>تىنىشتىقتا سەزدىم قۇدايىم، جۇرەگىمە سويلەگەنىڭدى</title>
<key>C</key>
<lyrics>[V1]
.F        G        Am      Dm
 // تىنىشتىقتا سەزدىم قۇدايىمنىڭ،
 جۇرەگىمە سويلەگەنىن.
 بالام بەرگەن اق جارىلقاۋىڭدى
 قابىلدا اتىمدى مەنىڭ //

[C1]
   // اق باتا ۔ سەن مەنىڭ قورعانىمسىڭ!
   اق باتا كوكتەن جارىلقاۋىمسىڭ!
   قۇدايدىڭ بەرگەن سيى،
   تاڭىرمەن جۇرگەن جولى،
   اق باتا، اق باتا! //

[V2]
 // قايدا جۇرسەم دە سەزەمىن سەنى،
 جانىمدا جۇرەگىمدەسىڭ.
 شىن ٴومىر بەرگەن قۇدايىم،
 باتاڭا تولى ٴومىرىم! //</lyrics>
</song>