<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[C1]
.  G        C       G        D
   ٴجۇر، ىبىرايىم، دايىندال جولعا،
.   G   C       D    G
   ٴجۇر ىبىرايىم، قۇدايىڭ قاسىڭدا.

[V1]
.   G            C             D       G
 سوندا ول ٴبارىن تاستاپ، بوتەن ەلگە بەتتەدى،
.   G           C             D       G
 قۇدايعا سەنىم ارتىپ، ايتقانىنان كەتپەدى.
 اشتىقتا دا قۇدايعا، سەنۋدەن ول تالمادى،
 قاناحان ەلىنە قاراي ساپارىن جالعادى.
 مال كوبەيىپ لۇتپەن بولىنۋگە تۋرا كەلدى،
 اعاسى جەر تاڭداۋعا ىنىسىنە جول بەردى.

[V2]
 سارا كارى، ۇرپاق جوق قۇداي بەردى ۋادەسىن،
 جۇلدىزداي كوبەيتەمىن، ۇرپاعىن، نەسىبەسىن
 قۇداي سىناپ: «ىسقاقتى قۇرباندىققا شال»، ۔ دەدى،
 سەنىمىمەن قۇتقارىپ: «مىنا قويدى ال»، ۔ دەدى.
 ەگەردە سەن قۇدايعا سەنىم ارتساڭ وسىلاي،
 جاقىندايسىڭ قۇدايعا، ىبىرايىم دوسىڭداي.</lyrics>
<title>ٴجۇر، ىبىرايىم، دايىندال جولعا РӘЖ242</title>
<hymn_number>242</hymn_number>
</song>