<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>27</hymn_number>
<author>ارمان كاينازاروۆ</author>
<title>ٴبارى جاقسى بولىپ كورىندى МЖЖ27</title>
<aka>جالعان بايلىق</aka>
<lyrics>[V1]
.Bm                     Em
 ٴبارى جاقسى بولىپ كورىندى،
. A                     D/Bm
 ٴبارى جاقسى بولىپ سەزىلدى.
.Bm                 F#/F#7
 وتكىزگەن مىناۋ كۇندەرىم،
.Em      A       D
 نە جاقسىلىق اكەلدى؟

[C1]
   بىرەۋلەر ىزدەيدى بايلىقتى
   بايلىقتان ىزدەيدى باقىتتى.
   مىناۋ جالعان دۇنيەدە
   ىزدەۋمەن وتەر ۋاقىتتى.

[V2]
 ەڭ جاقسىسى ٴومىردىڭ
 قۇدايعا عانا باعىنۋ.
 مويىنسۇنىپ ٴارقاشان
 شىن جۇرەكتەن تابىنۋ.

[V3]
 كوزىمىزدى اشايىق،
 اياقتى نىق باسايىق.
 قۇداي سوزىمەن سەرگەك بوپ
 يسانىڭ كەلۋىن توسايىق.

[V4]
 ماڭگىلىك قامقور قۇدايىڭ
 ٴبىر وزىڭە جار ەكەن.
 بۇدان اسقان تىنىشتىق
 باقىتتى ٴومىر بار ما ەكەن؟</lyrics>
<key>Bm</key>
</song>