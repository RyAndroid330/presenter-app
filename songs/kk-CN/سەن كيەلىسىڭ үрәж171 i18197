<?xml version="1.0" encoding="UTF-8"?><song><title>سەن كيەلىسىڭ ҮРәж171</title>
<lyrics>[V1]
.     G
 // سەن كيەلىسىڭ، //
.    C
 // سەن كۇشتىسىڭ، //
.    Am
 // سەن لايىقسىڭ، //
.    D
 // بار ماداققا. //

[V2]
.    G
 // مەن ەرەمىن، //
.    C
 // مەن تىڭدايمىن، //
.    Am
 // سەنى سۇيەمىن، //
.  D G D G
 ٴار كۇنىمدە.

[C1]
.    C
   ٴان سالامىن، / پاتشالار پاتشاسى،
.   D
   سٸىنامىن، / يەلەر يەسى،
.   Em
   لايىقتى / سەن كۇشتى قۇداي،
.   Bm
   پاتشاعا / ٴبارىنىڭ يەسى.
.   C
   مەن سۇيەمىن، / سەن يمانۋيل،
.   D
   قۇرمەتتەيم، / سەن ۇلى ەسىم،
.   Em
   باس يەمىن / مەنىڭ پاتشامسىڭ
.   Bm
   الدىندا. / سەن توقتىسىڭ.

[C2]
   ٴان سالامىن، / ٴتىرىسىڭ قۇداي،
   سيىنامىن، / راقىمدىسىڭ سەن،
   لايىقتى / پاتشالىعىڭ ماڭگى،
   پاتشاعا. / ماڭگى بار بولۋشى.
   مەن سۇيەمىن، / سەن العاشقى، سوڭعىسىڭ،
   قۇرمەتتەيم، / باسى دا، سوڭى.
   باس يەمىن / قۇتقارۋشىم ٴماسىحسىڭ،
   الدىندا. / جان دوسىم ٴوزىڭ.

[B1]
.   C
   تىنىشتىق يەسى،
.   D         G
   سەن ٴۇشىن ٴومىر سۇرەمىن.</lyrics>
<key>G</key>
