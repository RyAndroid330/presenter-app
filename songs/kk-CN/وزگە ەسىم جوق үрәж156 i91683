<?xml version="1.0" encoding="UTF-8"?><song><title>وزگە ەسىم جوق ҮРәж156</title>
<key>C</key>
<lyrics>[V1]
. C        F
 وزگە ەسىم جوق
. G       C
 ٸسانىڭ ەسىمىنەن.
.          F
 وزگە ەسىم جوق
.  G           Am
 ەسىمىنەن ٴتاڭىردىڭ.

[V2]
. C        F
 وزگە ەسىم جوق
. G  Am   G   F
 ٸسانىڭ ەسىمىنەن،
.  C          G
 ول لايىق قۇرمەتكە،
. C         G
 ول لايىق ماداققا،
.    C
 ول لايىق،
. F     G    C
 دارىپتەيىك ونى.

[C1]
.    C       G        Am    C
   ۇلى ونىڭ ەسىمى، بارىنەن ۇلى.
.   F        C   Dm    F     G
   جوعارى ەسىمى ونىڭ بۇلتتان دا.
.  C     G     Am      C
   بيىك ونىڭ ەسىمى، كوكتەن دە بيىك،
.   Dm            Em
   داڭق، قۇرمەت، ماداق بەر
.   C         G
   ونىڭ ۇلى ەسىمىنە.</lyrics>
<hymn_number>156</hymn_number>
<author>رُبِرت گَي</author>
</song>