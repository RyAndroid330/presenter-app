<?xml version="1.0" encoding="UTF-8"?><song><title>كوك اسپاندا</title>
<lyrics>[V1]
.Em           Am
 كوك اسپاندا، العاشقى،
.B7           Em
 تۇنگى جۇلدىز قالقيدى!
 بالالارعا ايتادى،
 بۇل كۇن دە اياقتالدى!
 // ۇل۔قىزدار ۇيىقتايدى،
 جۇلدىزدار جارقىرايدى! //
 مامالارىمەن بىرگە
 بالالار سيىنادى
 شۇكىر بۇل كۇنگە</lyrics>
<key>G</key>
</song>