<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>38</hymn_number>
<author>ھەمرا ئاكا</author>
<title>جاراتۋشى قۇداي جوق دەسە МЖЖ38</title>
<lyrics>[V1]
.   Em         C     D  Am
 // دۇنيە باستان۔اياق اداسقان.
. Bm                 D
 جاراتۋشى قۇداي جوق دەسە. //

[C1]
.  Em                 C
   بار! بار! بار! بار! قۇداي.
.  G            D  Am   Bm
   كوكتە ونىڭ ماڭگى تاعى بار.
   بار! بار، بار، بار! يسا
   قۇتقارۋشى ۇلى ٴماسىح بار!

[V2]
 // ادامدار كۇناسىنا باتىپ جاتىر،
 قۇتقارۋشى قۇداي جوق دەسە. //

[C2]
   بار! بار، بار، بار! قۇداي.
   كوكتەن كەلگەن قۇتقارۋشى بار!
   بار! بار،بار،بار،بار! قۇداي!
   كوكتەن كەلگەن يسا ٴماسىح بار.

[V3]
 // ادامدار قيىنشىلىقتىڭ استىندا.
 ەگەر بىزدە ٴۇمىت جوق دەسە. //

[C3]
   بار! بار، بار، بار! قۇداي.
   قۇتقارۋشى يسا ٴماسىح بار.
   بار، بار، بار بار! يسا.
   قۇتقارۋشى ۇلى ٴماسىح بار.</lyrics>
<key>Em</key>
<aka>دۇنيە باستان۔اياق اداسقان</aka>
</song>