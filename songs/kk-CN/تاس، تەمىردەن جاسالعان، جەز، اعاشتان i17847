<?xml version="1.0" encoding="UTF-8"?><song><title>تاس، تەمىردەن جاسالعان، جەز، اعاشتان</title>
<lyrics>[V1]
.    Dm                      Gm        Dm
 // تاس، تەمىردەن جاسالعان، جەز، اعاشتان،
.Gm         C7    F          Dm
 كەلمەدىم سيىنۋعا تاڭىرگە جالعان،
.Gm                  F      Dm
 كەلمەدىم مەن سەنۋگە، وتىرىككە،
.Bb                         Gm       A
 شىن ٴتاڭىردى تانۋعا، كەلدىم بۇل ومىرگە! //

[C1]
   جۇرەكتەرىڭ الىستاماسىن تاڭىردەن
   ومىرلەرىڭ ورالماسىن جابىرلەنگەن،
   الدانباسىن جۇرەكتەرىڭ، قۇر بوستارعا،
   ۇمىتىلماسىن قۇدايدىڭ ٴبىر جاقسىلىعى دا!</lyrics>
<key>F</key>
<author>نۇر</author>
</song>