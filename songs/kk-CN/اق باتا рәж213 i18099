<?xml version="1.0" encoding="UTF-8"?><song><aka>ەلىڭنىڭ قامىن ويلا دەپ</aka>
<lyrics>[V1]
.    Am
 ەلىڭنىڭ قامىن ويلا دەپ،
.  Dm
 جەرىندى جاۋدان قورعا دەپ،
.   Dm            Am
 باسسىن ٴىسىڭ وڭعا دەپ،
.  E7
 شايتاننىڭ قۇلى بولما دەپ،
.     Dm             E7
 // باباڭ بەرگەن اق باتا،
.  Am
 باسىڭا قونسىن باق باتا! //

[V2]
 قۇدايدان باتا قونسىن دەپ،
 عۇمىرىڭ ۇزاق بولسىن دەپ،
 ٴورىسىڭ مالعا تولسىن دەپ،
 جۋاداي جاۋىڭ سولسىن دەپ،
 // اتاڭ بەرگەن اق باتا،
 باسىڭا قونسىن باق باتا! //

[V3]
 راحاتىڭ كورەر الدا دەپ،
 ماڭگىلىكتەن قالما دەپ،
 بەتىنەن جاننىڭ الما دەپ،
 جارىڭا جارا سالما دەپ،
 // اكەڭ بەرگەن اق باتا،
 باسىڭا قونسىن باق باتا! //

[V4]
 // سۋ سۇراسا ٴسۇت بەرگەن،
 نان سۇراسا بال بەرگەن،
 ٴتۇن ۇيقىسىن ٴتورت بولگەن،
 سەن ٴۇشىن تىلەك تىلەگەن،
 اناڭ بەرگەن اق باتا،
 باسىڭا قونسىن باق باتا! //

[V5]
 قۇدايسىز كۇنىڭ قۇرىسىن،
 وزىڭە ٴوزىڭ ۇرىسىڭ،
 قۇدايسىز مىنا جالعاندا،
 قاشادى سەنىڭ ىرىسىڭ،
 // قۇداي بەرسە اق باتا،
 باسىڭا قونار باق باتا! //</lyrics>
<key>Am</key>
<title>اق باتا РӘЖ213</title>
<hymn_number>213</hymn_number>
</song>