<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16</hymn_number>
<author>مانار ر</author>
<title>كوكتەگى اكەمىز Қак16</title>
<key>F</key>
<lyrics>[V1]
.     Dm    Am
 كوكتەگى اكەمىز،
.   Gm    Dm                Gm
 كيەلى ەسىمىڭ قاستەرلەنە بەرسىن!
.Dm     A            Dm
 پاتشالىعىڭ جەرگە كەلسىن!
.Dm       Gm     Am    Dm
 ەركىڭ كوكتە ورىندالعانداي،
.Am        Gm     Dm
 جەردە دە، ورىندالسىن!
.Dm                   Am Gm Dm
 كۇندەلىكتى نانىمىزدى، بەرە گور!
.Dm
 كىنالىنى كەشىرگەندەي،
.Gm               Dm
 كۇنامىزدى كەشىرە گور!
.Dm         Am   Dm
 جاماندىققا تۇسىرمەي،
.Dm          Am Gm  Dm
 ازعىندىقتان ساقتاي گور!</lyrics>
</song>