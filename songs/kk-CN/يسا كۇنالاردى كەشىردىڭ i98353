<?xml version="1.0" encoding="UTF-8"?><song><author>جانات كۋساينوۆا</author>
<lyrics>[V1]
 // يسا كۇنالاردى سەن كەشىردىڭ،
 ماعان جاڭا ٴومىردى سيلادىڭ.
 قاسيەتتى قانىڭ سەنىڭ توگىلدى،
 مەن ٴۇشىن ايقىشتا. //

[C1]
   // بۇكىل الەم ٴتاڭىر سەنى داڭقتايدى،
   جالعىز سەنى كيەلى ماداقتايدى! //

[B1]
   سەن ۇلىسىڭ!
   يسا ساعان ماداق
   سەن كيەلىسىڭ!
   يسا ساعان ماداق
   سەن سۇلۋسىڭ!
   يسا ساعان ماداق
   سەن عاجاپسىڭ!
   يسا ساعان ماداق</lyrics>
<title>يسا كۇنالاردى كەشىردىڭ</title>
</song>