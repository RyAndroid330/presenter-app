<?xml version="1.0" encoding="UTF-8"?><song><title>كۇننەن ۇيرەن جارىقتى سيلاۋدى</title>
<key>Bb</key>
<lyrics>[V1]
.Bb                     Cm
 كۇننەن ۇيرەن جارىقتى سيلاۋدى،
.F                   Bb
 الەمگە مەيىرىممەن قاراۋدى.

[C1]
.     Bb            Bb7      Eb
   // جاۋابىن كۇتپە ىزگى ٴىسىڭنىڭ،
.            Bb     F    Bb
   كۇنگە كىم نەنى بەرە الادى؟ //

[V2]
 كۇننەن ۇيرەن بار جولدى تازالاپ،
 قينالعان ادامعا كۇش بەرۋدى.

[C2]
   // كۇننەن ۇيرەن شاتتانىپ، جارقىراپ.
   كوكتە تۇرىپ، جەردى جىلىتۋدى! //

[V3]
 وكىنبەي، كۇرسىنبەي، ابىرجىماي،
 قۋانتا ٴبىل كۇن قۋانتقانداي.

[C3]
   // كۇن سياقتى تاڭىرگە سەن ۇمتىل،
   جاماندىقتان، جاقسىلىققا بەت بۇر! //

[V4]
 قىمباتتى دوسىم قايدا جۇرسەڭ دە،
 اينالاڭ ٴماسىح جارىعى بولسىن.

[C4]
   // ادامدار كورىپ جاقسى ٴىسىڭدى،
   كوكتەگى اكەنى ماداقتاسىن! //

[V5]
 ول جانىپ تۇرعاندا ۇيرەن دوسىم،
 اسپاننان جولداپ، نازىك سالەمىن.

[C5]
   // جۇرەككە شەرتىپ ايتادى بىزگە،
   شىندىقتىڭ كۇنى جوق بولار كەزىن! //</lyrics>
<hymn_number>107</hymn_number>
</song>