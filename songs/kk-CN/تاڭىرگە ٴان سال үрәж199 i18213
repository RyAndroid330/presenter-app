<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>199</hymn_number>
<title>تاڭىرگە ٴان سال ҮРәж199</title>
<key>Em</key>
<lyrics>[V1]
. Em               B7
 تاڭىرگە ٴان سال، الەم،
. Em             B7       Em
 قۇتقارعانىن ونىڭ پاش ەتىڭدەر.
. Em             B7
 ونىڭ عاجايىپ ىستەرىن،
. Em        B7       Em
 بىلۋگە ٴتيىستى ٴار ادام.

[V2]
. E      Am   D   G
 ويتكەنى ول قۇدىرەتتى،
.      B7
 كۇشپەنەن،
. Em     E7
 ۇلىلىقپەنەن.
. Am     D  G
 شاتتان، الەم،
.  Am       C      B7  D
 ٴتاڭىر ۔ ٴبىزدىڭ پاتشامىز.</lyrics>
</song>