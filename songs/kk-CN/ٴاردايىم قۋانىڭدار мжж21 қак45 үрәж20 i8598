<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<author>مولدابەكوۆ مۇسا</author>
<key>Am</key>
<lyrics>[V1]
.Am       G     Am
 ٴاردايىم قۋانىڭدار،
.Dm     G      C/Am
 تاعى دا قۋانىڭدار.
.   Dm        G       C/Am
 // ەش نارسەنى ۋايىمداماي
. F      G        Am
 ٴتاڭىردى ماداقتاڭدار. //

[C1]
.     F         G      C/Am
   // قۋانىڭدار، قۋانىڭدار!
.  Dm      G     C/Am
   تاعى دا قۋانىڭدار!
.  F         G      C/Am
   قۋانىڭدار، قۋانىڭدار!
.  F       G     Am
   يەمىزگە قۋانىڭدار. //

[V2]
 وزدەرىڭە سوندا قۇداي
 تىنىشتىق سيلايدى.
 // اقىل مەنەن ويلارىڭدى
 يسا ماسىحتە ساقتايدى. //</lyrics>
<title>ٴاردايىم قۋانىڭدار МЖЖ21 Қак45 ҮРәж20</title>
</song>