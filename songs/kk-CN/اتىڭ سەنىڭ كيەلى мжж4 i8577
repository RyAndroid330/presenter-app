<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4</hymn_number>
<author>نۇر</author>
<lyrics>[V1]
.   Am            Dm
 // اتىڭ سەنىڭ كيەلى،
.Dm             Am
 يسا ٴبىزدى سۇيەدى.
.Am            Dm
 كۇنامىزدى كەشىرىپ،
.E              Am
 بولدىق ٴومىر تيەگى. //

[C1]
.     Am               Dm
   // قۋانايىق، شاتتانايىق،
.  Dm                  Am
   جارتى جولدا توقتامايىق.
.  Am             Dm
   يسا ٴماسىح ارقىلى
.  E                Am
   ماڭگىلىككە اتتانايىق! //

[V2]
 // يسا سەنى ساعىنامىن،
 ايتقانىڭا باعىنامىن.
 يسا ٴسوزى ارقىلى
 قۇدايىمدى تانىعانبىز. //

[V3]
 // سەن بۇل جەردىڭ تۇزىسىڭ،
 سەن بۇل جەردىڭ نۇرىسىڭ.
 قۇداي اكە جىبەرگەن
 قۇتقارۋشى ۇلىسىڭ. //</lyrics>
<key>Am</key>
<title>اتىڭ سەنىڭ كيەلى МЖЖ4</title>
</song>