<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>32</hymn_number>
<title>بۇل ٴبىزدىڭ قۇداي ҮРәж32</title>
<key>E</key>
<lyrics>[V1]
. E      E/G#
 ماعان كەرەگى
. C#m
 راقىمدىلىق،
. A           E
 سوزىڭە مەن سەنەمىن.
. E/G#       C#m
 كۇتەم سەنى جاقىنداتشى،
. A         B
 كيەلى رۋحىڭمەن جاڭارت.

[P1]
.   E/G#    A
   اياعىڭا جىعىلام
.    F#m    B/D#
   الدىڭدا باس يەم
.   E/G#     A
   وسى جەردە تابىنام

[V2]
 جۇرەگىمدەسىڭ،
 جولىما نۇر شاش.
 سوزدەرىڭنىڭ كۇشىمەن
 قۇن تولەدىڭ،
 ازات ەتتىڭ،
 رۋحىڭمەن مەن ازاتپىن.

[C1]
.    E
   ٴوز ەركىڭمەن ٴبارىن بەردىڭ،
.     B
   ايقىش اعاشتا قۇن تولەدىڭ.
.     F#7
   ماحابباتىڭ
.   C#m
   بىزگە توكتىڭ.
.     A     E
   ٴبىزدىڭ قۇداي
.   E
   ولىمنەن ومىرگە ٴوتتى.
.    B
   ماڭگىگە يەمىز دارىپتەلسىن،
.       F#m7            C#m
   قۇل، ول ۔ پاتشا ازات ەتتى،
.    A       E
   ٴبىزدىڭ قۇداي.</lyrics>
</song>