<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<key>Em</key>
<lyrics>[V1]
.D   Am         B7
 يسا، كەرەمەتسىڭ سەن!
.Em  G          A
 يسا، كەرەمەتسىڭ سەن!
.     D
 سۇيگەنىم مەنىڭ ٴوزىڭسىڭ!
.      Am       B7         Em
 ٴبىر وزىڭە ٴومىرىمدى ارنايمىن، و، يسا!
.G   A          D
 يسا، كەرەمەتسىڭ سەن!

[V2]
 يسا سەنى سۇيەم مەن، يسا سەنى سۇيەم مەن
 // ەسىمىڭدى انگە سالىپ، ماداقتايمىن تەك ٴوزىڭدى جان اكەم
 يسا سەنى سۇيەم مەن //

[V3]
 // يسا قۇن تولەدىڭ سەن
 بەرىپ ازاتتىق ايقىشتا، كۇنادان سەن ماڭگىلىككە اقتادىڭ
 يسا قۇن تولەدىڭ سەن //</lyrics>
<title>يسا، كەرەمەتسىڭ سەن! ҮРәж71 МЖЖ61</title>
</song>