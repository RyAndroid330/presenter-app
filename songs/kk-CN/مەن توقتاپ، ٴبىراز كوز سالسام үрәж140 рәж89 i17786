<?xml version="1.0" encoding="UTF-8"?><song><title>مەن توقتاپ، ٴبىراز كوز سالسام ҮРәж140 РӘЖ89</title>
<lyrics>[V1]
.  Am
 مەن توقتاپ، ٴبىراز كوز سالسام،
. F  G          C
 ٴومىردىڭ وتكەن جولىنا،
.      Am            Dm
 //  ٴار كۇنا كەلىپ ويىما،
.  E7           Am
 باتادى مەنىڭ جانىما.  //

[V2]
 مەن قىلعان قانشا كۇنا بار،
 ەستىسە ادام ۇيالار،
 //  شىندىقتى ايتسام قۇدايعا،
 كۇنادان مەنى قۇتقارار.  //

[V3]
 كۇنامدى الىپ موينىما،
 باس ٴيىپ ٴتاڭىر الدىندا،
 //  ٴوتىنىپ، تاۋبە قىلايىن،
 اپارشى ٴومىر جولىنا.  //

[V4]
 شىندىقتى كوردىم جولىڭنان،
 وزگەرتكەن مەنىڭ ويىمدى،
 //  قۇتقارىپ الشى ٴتاڭىرىم،
 ۇسىنىپ، سوزام قولىمدى.  //

[V5]
 ٴوزىمدى ساعان ارنايىن،
 جۇرەكتە سەنى ساقتايىن.
 //  دۇنيەگە ايتىپ شىندىقتى،
 ماڭگىلىك سەنى داڭقتايىن.  //</lyrics>
<key>C</key>
<author>بولوت ئالداشېۋ</author>
<hymn_number>140</hymn_number>
</song>