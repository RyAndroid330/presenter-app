<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>62</hymn_number>
<key>E</key>
<lyrics>[V1]
. E               A
 جۇرەگىممەن، ٴتاڭىرىم،
.          B
 سەنى، اڭسايمىن،
.E           A         B
 جۇرەگىممەن اڭسايمىن سەنى.
. E                A
 جۇرەگىممەن داۋىستايمىن،
.     B
 ٴتاڭىرىم، ساعان،
.E
 جۇرەگىممەن
.      A              B
 ٴۇنىڭدى ەستۋدى اڭسايمىن.

[C1]
.  E     B         AE
   سەن، سەن كەلشى ماعان،
.      A        E
   ماڭگىگە، ماڭگىگە،
.    A           B
   ٴشولىمدى قاندىرشى.
.   E     B         AE
   سەن، سەن كەلشى ماعان،
.     A        E
   مەنىمەن بىرگە بول،
.     A        B
   ٴومىردىڭ قاينارىسىڭ.
.     A            B      E
   ٴتاڭىر ۔ ٴومىرىمنىڭ بۇلاعى.</lyrics>
<title>جۇرەگىممەن ҮРәж62</title>
</song>