<?xml version="1.0" encoding="UTF-8"?><song><author>هِللسُنگ, هِللسُنگ ُنِتِد</author>
<hymn_number>39</hymn_number>
<key>Bm</key>
<lyrics>[V1]
.  Bm      G     D
 ٴماسىح قانىمەن مەنى قۇتقاردى،
.      A         Bm
 كەشىردى، ازات ەتتى، ٴتىرىلتتى.
.    G       D
 ۇلىلىعىڭ سەنىڭ بويىمدا تۇر،
.      A            Bm
 ماڭگىلىك سەنەمىن، ماڭگىلىك سەنەمىن.

[V2]
. Bm     G         D
 سەن اقيقاتىڭمەن تۇتقىندادىڭ،
. A          Bm
 راقىمىڭمەن جارامدى ەمدەدىڭ.
.       G        D
 كيەلى سوزىڭمەن مەنى جەتەلەيسىڭ،
.     A              G
 ماحابباتىڭ ادال، ماحابباتىڭ ادال!

[C1]
.  D       A
   بىلەم: بەردىڭ،
.   Bm     G
   جالعىز ٴوز ۇلىڭدى،
.   G     A
   بىلۋگە سەنى،
.  Bm      G
   بولسىن دەپ مەيىرىمىڭدە،
.  D    A    Bm    G
   سەن مەن ٴۇشىن ايقىشتا قۇربان بولدىڭ،
.   D     A        Bm    G
   سەن ٴسۇيدىڭ، ٴسۇيدىڭ لايىقسىز حالىقتى.</lyrics>
<title>بىلۋگە سەنى ҮРәж39</title>
</song>