<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>93</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.     Dm
 قوزىنى جەتەكتەگەندەي،
.    Gm       A7   Dm
 باعۋشىم، العا اپار،
.       Dm
 سەنىڭ ٴۇنىڭ كەڭ جايلاۋعا،
.   Gm      A7    Dm
 تۇنىق سۋعا شاقىرار.
.         Gm  C         F
 // قۇتقارۋشىم! قۇتقارۋشىم!
.      Gm         A7   Dm
 مەن ٴۇشىن سەن قان توكتىڭ. //

[V2]
 ماعان دوس بول جەر بەتىندە،
 ساقتا قوزىلارىڭدى،
 جەتەكتە كوك شالعىنمەنەن،
 قۇتقار اداسقانداردى.
 // قۇتقارۋشىم! قۇتقارۋشىم!
 سەن كۇنامدى كەشىردىڭ. //

[V3]
 يگىلىگىڭدى بەرە گور،
 ۋادەڭدى سەن ورىندا،
 ۇزاق جولدان قايتقان كەزدە،
 يەم، مەنى قابىلدا.
 // قۇتقارۋشىم! قۇتقارۋشىم!
 جاقىنداتا گور مەنى. //

[V4]
 ماعان وسيەتىڭدى سە،
 سۇيۋگە قابىلەت بەر،
 ۇيرەت سۇيىسپەنشىلىكپەن،
 مەنى ٴومىر سۇرۋگە.
 // قۇتقارۋشىم! قۇتقارۋشىم!
 مەنى جالعىز قالدىرما. //</lyrics>
<title>قوزىنى جەتەكتەگەندەي РӘЖ138</title>
</song>