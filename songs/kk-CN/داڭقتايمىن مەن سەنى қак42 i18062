<?xml version="1.0" encoding="UTF-8"?><song><author>سەرىكباەۆ ەركىنبەك</author>
<hymn_number>42</hymn_number>
<key>G</key>
<lyrics>[V1]
.    C              G
 داڭقتايمىن مەن سەنى!
.     C             G
 ماداقتايمىن مەن سەنى!
.    C              G
 تابىنامىن مەن ساعان،
.     D       Em  Am           D
 و، يسا! و، يسا! مەن سەنى سۇيەمىن!
. G   C         D
 ٴولىمدى سەن جەڭدىڭ،
.G           C        D
 كۇنا قۇلدىعىنان بوساتتىڭ!
.G     C           D
 جەڭىس سەن الىپ بەردىڭ،
.G          C    D
 وسى دۇنيەدە ريزامىن!</lyrics>
<title>داڭقتايمىن مەن سەنى Қак42</title>
</song>