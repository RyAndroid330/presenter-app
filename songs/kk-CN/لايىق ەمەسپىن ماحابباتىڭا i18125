<?xml version="1.0" encoding="UTF-8"?><song><title>لايىق ەمەسپىن ماحابباتىڭا</title>
<key>D</key>
<lyrics>[V1]
.D              A      D
 لايىق ەمەسپىن ماحابباتىڭا،
.G              B     Em
 لايىق ەمەسپىن شاپاعاتىڭا.

[C1]
.            G       A      D   Bm
   // جىلدار بويى سەنسىز اداستىم،
.  Em          A       Dm
   كۇنانىڭ تورىندا شاتاستىم! //

[V2]
 باسقالارداي دەگەنىممەن ٴجۇردىم،
 ٴمانسىز ماقساتسىز ٴومىردى ٴسۇردىم.

[C2]
   // جۇرەگىم مۇزداپ قاتايا بەردى،
   ارام پٸعىلدان شالقايا بەردىم! //

[V3]
 سەن جۇرەگىمنىڭ ەسىگىن قاقتىڭ،
 ويانىپ، ونى ايقارا اشتىم.

[C3]
   // اداسقان ۇلىڭدى سەن كەشىردىڭ،
   كۇنانى ىستەگەم، سەن ٴوشىردىڭ! //

[V4]
 باقىتتان كوپ قۋانا جىلادىم،
 جانىمدى ماسىحكە مەن ارنادىم.

[C4]
   // وزىنە كەلگەندى ول اقتايدى،
   كۇنالارعا جىبەرمەي ساقتايدى! //</lyrics>
<hymn_number>116</hymn_number>
</song>