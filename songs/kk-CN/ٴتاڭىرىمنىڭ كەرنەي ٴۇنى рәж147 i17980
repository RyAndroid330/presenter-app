<?xml version="1.0" encoding="UTF-8"?><song><author>بلَكك، جَمِس مِلتُن (١٨٥٦-١٩٣٨)</author>
<hymn_number>147</hymn_number>
<key>D</key>
<lyrics>[V1]
.        D
 ٴتاڭىرىمنىڭ كەرنەي ٴۇنى،
.    G         D
 جەر بەتىنە جەتكەندە،
.   D
 جارقىراپ ماڭگى، تاڭ نۇرى شىعادى.
.   D
 قۇتقارىلعاندى تۇگەندەپ،
.   G            D
 ٴبارىن شاقىرعان كەزدە،
.  A7             D
 اراسىندا مەنى دە ول اتايدى.

[V2]
.     D    A7  D    G
 /// اسپاندا جينالعاندا،   ///
.         D          A7      D
 ٴتاڭىرىمنىڭ ەركىمەن مەن بولامىن.

[V3]
 ماسىحتە تىرىلگەن جانداردىڭ
 يگىلىك كۇنىندە،
 تازالانعانداردى ٴماسىح قانىمەن،
 پاتشانىڭ مەكەنىنە شاقىرىپ
 كىرگىزگەن كەزدە،
 شاقىرعان ۇنگە مەن جاۋاپ بەرەمىن.

[V4]
 سەن ٴۇشىن ەڭبەك ەتىپ،
 تاڭ اتقاننان كۇن باتقانشا،
 ٴتاڭىرىم، بارىنە قىزمەت ەتەمىن.
 جەر بەتىندەگى جۇمىستى
 ەركىڭمەن توقتاتقاندا،
 اسپانداعى تۇگەندەۋگە بارامىن.</lyrics>
<title>ٴتاڭىرىمنىڭ كەرنەي ٴۇنى РӘЖ147</title>
</song>