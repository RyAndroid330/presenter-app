<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>118</hymn_number>
<author>الما, نۋرلان ابٸشەۆ</author>
<lyrics>[V1]
. Em
 وسى الەمدە مەن ٴجۇردىم
.   D
 ايالادىم ارمانداي
.  C
 ومىردەگى بار بايلىق
.  G
 كەلدى ماعان قينالماي.
 قاراڭعىدا ٴجۇر ەدىم
 يسا اشتى كوزىمدى.
 ايتىپ جەتكىزە الماي
 جۇرەكتەگى سەزىمدى.

[C1]
   // كيەلى قۇداي (يەم)
   جانىم مەنىڭ سەنى اڭسايدى.
   جالعىز بولا الماي
   ساعان قارادى
   سەنى ىزدەپ كۇتەدى. //

[V2]
 كوڭىلىمدى جۇباتتى
 بەردى ماعان قۋاتتى.
 سۇيەم دەگەن سوزىمەن
 جۇرەگىمدى قۋانتتى.
 مەنى ولىمنەن قۇتقارعان
 سۇيەمىن مەن يسانى.
 قۇدايىم بولىپ كەلگەن
 سۇيەمىن ٴتاڭىرىمدى.</lyrics>
<key>G</key>
<aka>كيەلى قۇداي</aka>
<title>وسى الەمدە مەن ٴجۇردىم МЖЖ118 ҮРәж154</title>
</song>