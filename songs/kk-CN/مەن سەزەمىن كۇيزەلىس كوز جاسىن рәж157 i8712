<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.     Em     C      D      G
 مەن سەزەمىن كۇيزەلىس كوز جاسىن،
.    C         Am        B    Em
 كەزدەسەر كۇن مەن اۋىر قوشتاسۋدى.
.     Em        C     D     G
 ٴۇمىت پەن قايعىنىڭ ارالاسقان
.    C       Am    B         Em
 ٴدامىن كوردىم ىستىق توستاعاننىڭ.

[C1]
.   Em         Am       B     Em
   سەن ۋايىمداما، كوڭىلسىز بولما
.    C        Am      B       Em
   نەدەن قورقامىز، قۇداي قاسىمىزدا
.     Em       Am     D      G
   سەن ۋايىمداما،كوڭىلسىز بولما
.     Am  C B    Em
   قۇداي قاسىمىزدا.

[V2]
 وتكەن كۇندەر ٴۇشىن قايعىرمايمىن،
 كورىپ ۋاقىتتىڭ وتە از قالعانىن.
 قابىلدادىم وسى قۇرباندىقتى،
 توگىلگەن مەن ٴۇشىن كۇناسىز قاندى.

[V3]
 بوستاندىق ىزدەدىم بۇل ومىردە،
 تۇرمىستىق قايعى مەن قاسىرەتتەن.
 بار ٴومىرىم از عانا شۋماقتاي
 وڭاشادا دۇعا ەتكەن كەزدە.</lyrics>
<title>مەن سەزەمىن كۇيزەلىس كوز جاسىن РӘЖ157</title>
<hymn_number>125</hymn_number>
</song>