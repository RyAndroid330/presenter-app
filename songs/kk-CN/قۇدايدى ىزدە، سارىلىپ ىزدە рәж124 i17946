<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>100</hymn_number>
<key>G</key>
<lyrics>[V1]
.     Cm            G
 قۇدايدى ىزدە، سارىلىپ ىزدە،
.         G                  Cm
 كەشىكپەي، دوسىم، ساعىنىپ ىزدە.
.  C              Fm
 كۇنى۔ٴتۇنى كەزىپ دالانى،
.        G
 جان جۇرەگىڭمەن، تابىنىپ ىزدە.

[C1]
.    C                   Fm
   ىزدەگەن تابار، قۇدايدى ىزدە،
.          G                    Cm
   جول بولىپ بالكىم، جولىعار سىزگە.

[V2]
 ٴسوز بولىپ ٴتاڭىر جەرگە كەلەدى،
 سەنىمىڭ بولسا، بويعا ەنەدى.
 وعان جۇگىنۋ تىم قيىن ەمەس،
 «كەش قالما» دەگەن ويعا كەلەدى.

[V3]
 جۇرەكتى قاقسا، اشىپ ەسىگىن،
 قۇرمەتتە اركەز ٴتاڭىر ەسىمىن.
 شولدەگى سۋداي قۇدايدى اڭسا،
 تابارسىڭ سوندا ٴومىر شەشىمىن.</lyrics>
<title>قۇدايدى ىزدە، سارىلىپ ىزدە РӘЖ124</title>
</song>