<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>14</hymn_number>
<author>هِللسُنگ ُنِتِد</author>
<key>Em</key>
<lyrics>[V1]
. Em
 اكەم، سەنى مەن سۇيەمىن،
. C                    G
 جۇرەگىمنىڭ قالاۋىنان دا،
.      D/F#
 سەن كەرەكسىڭ.
. Em
 ٸسا، سۇيىكتى قۇتقارۋشىم،
.  C                        G
 ٴبارى ٴۇشىن ساعان قارىزدارمىن،
.                D#
 ساعان ٴبارىن بەرەم.

[P1]
.   Am        C    Dsus4 D
   ماداقتايدى پەرىشتەلەر،
.    Am     C       Dsus4 D
   ٴبىز بالاڭبىز، تابىنامىز.

[C1]
.    G            D
   الەمىمسىڭ، قۇدايىمسىڭ،
.    C               D
   ٴومىرىمدى ساعان ارنايم.
.     G            D
   ٴتاڭىرىمسىڭ، سەنى سۇيەم،
.   C                 D/Cm
   سەنەن ەشكىم ايىرا المايدى.

[V2]
 مەندە باردىڭ ٴبارىن بەرەم،
 پاتشام، سەن ٴۇشىن ٴومىر سۇرەم،
 تەك سەن ٴۇشىن.
 ٴاربىر كۇنىم سەنىڭ سيىڭ،
 سەنىڭ ەركىڭمەن وتكىزەمىن مەن،
 تەك سەن ٴۇشىن.</lyrics>
<title>الەمىمسىڭ ҮРәж14</title>
</song>