<?xml version="1.0" encoding="UTF-8"?><song><author>جانات كۋساينوۆا</author>
<lyrics>[V1]
.    Gm             D7 Cm             Gm
 // سۇيەمىن سەنى اكە، سۇيەمىن سەنى اكە!
.Eb     Bb     Cm       Gm
  شىن جۇرەكپەن سەنى سۇيەمىن!
.Cm  Eb        D7
 سۇيەمىن سەنى اكە! //

[C1]
.      Gm/Eb/Cm/D         Gm/Eb
   // اكە ۔ يەم ساعان ريزامىن!
.  Cm     D         Gm
    تەك ساعان تابىنامىن
.       Bb         Eb/Cm/DE
   ماڭگى ٴومىر سيلاعان ٴۇشىن! //

[V2]
 // سۇيەمىن سەنى يسا
 سۇيەمىن سەنى يسا
 شىن جۇرەكپەن سەنى سۇيەمىن
 سۇيەمىن سەنى يسا! //

[C2]
   // يسا يەم ساعان ريزامىن
   تەك ساعان تابىنامىن
   ماڭگى ٴومىر سيلاعان ٴۇشىن! //</lyrics>
<key>Bb</key>
<title>سۇيەمىن سەنى اكە، شىن جۇرەكپەن</title>
</song>