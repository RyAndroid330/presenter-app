<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // مۇمكىندىكتى قۇداي بەردى،
 قۇرباندىعىڭدى بەرۋدى،
 شەكسىز جارىلقاۋىن توگەدى.
 مىڭداعان ادام ىشىنەن،
 سەنى باۋىرىم تاڭدادى،
 قۇرباندىعىڭدى ول كۇتەدى. //

[C1]
   // قۇداي جار بولسىن، قۇرباندىعىڭ قابىلدانسىن،
   كوكتە باۋىرىم، جينالسىن سي۔تارتۋلارىڭ.
   قۇداي جار بولسىن، قۇرباندىعىڭ تازا بولسىن،
   قۇداي جار بولسىن! //

[V2]
 // شىن جۇرەگىڭمەن ەگىلگەن،
 العىستارمەن بەزەنگەن،
 جەمىس شىعادى اعاشىڭنان.
 جامان جەمىس الماۋ ٴۇشىن،
 جاقسى اعاشتى وتىرعىز،
 نە ەكسەڭ سونى ورىپ الاسىڭ. //</lyrics>
<title>قۇداي جار بولسىن، قۇرباندىعىڭ قابىلدانسىن</title>
<author>نۇر</author>
</song>