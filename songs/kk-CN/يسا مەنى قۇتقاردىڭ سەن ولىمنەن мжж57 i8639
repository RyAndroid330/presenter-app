<?xml version="1.0" encoding="UTF-8"?><song><title>يسا مەنى قۇتقاردىڭ سەن ولىمنەن МЖЖ57</title>
<lyrics>[V1]
 // يسا مەنى قۇتقاردىڭ سەن ولىمنەن،
 سودان بەرى ۇلگى الام تەك وزىڭنەن. //

[C1]
   // جاراتقان يەم جالىنام ساعان،
   جاراتقان يەم باتا بەر ماعان،
   ٴسوزىڭدى سەنىڭ تاراتايىن
   حالقىما سەنى اڭساعان. //

[V2]
 // مەن اداسىپ جۇرگەندە ٴوزىڭ تاپتىڭ،
 ۇلىڭدى قيىپ مەن ٴۇشىن كۇنامدى جاپتىڭ. //</lyrics>
<hymn_number>57</hymn_number>
<author>قابدەشوۆ رۋسلان</author>
</song>