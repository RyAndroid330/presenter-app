<?xml version="1.0" encoding="UTF-8"?><song><title>كۇلىمدەپ كۇننىڭ كوزى РӘЖ94 ҮРәж91</title>
<lyrics>[V1]
.Em               C
 كۇلىمدەپ كۇننىڭ كوزى،
.Am           B7
 بويىما جىلۋ بەردى.
.Em             C
 كيەلى ٴتاڭىر ٴسوزى،
.Am           B7
 جانىما قۋات بەردى.

[C1]
.     C                D
   // ٴتاڭىرىم، سۇيەم دەدى.
.  G           Em
   جانارىم كۇلىمدەدى.
.  C              B7
   ارمانىم بۇدان ارتىق،
.         Em
   بار ما ەدى؟ //

[V2]
 جارقىراپ كورىنەدى،
 ماڭگىلىك ٴومىر لەبى.
 جۇرەكتەن سەزىلەدى،
 ٴتاڭىردىڭ ىستىق دەمى.

[C2]
   // ٴومىردىڭ قاينار كوزى،
   كيەلى ٴتاڭىر ٴسوزى.
   سول ٴتۇنى جەر بەتىنە،
   كەلدى ٴوزى. //

[V3]
 جۇباتىپ كوڭىلىمدى،
 وزگەرتكەن ٴومىرىمدى.
 قۋانتقان جۇرەگىمدى،
 سۇيەمىن ٴتاڭىرىمدى.

[C3]
   // اعىلىپ توگىلەدى،
   ٴومىرىم بەرەكەلى.
   كۇنانىڭ قۇلدىعىندا،
   جوقپىن ەندى. //</lyrics>
<key>Em</key>
<hymn_number>106</hymn_number>
<author>شىنتەمىروۆ ٴابىلحايىر</author>
</song>