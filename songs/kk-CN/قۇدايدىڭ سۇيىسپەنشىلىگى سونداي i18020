<?xml version="1.0" encoding="UTF-8"?><song><title>قۇدايدىڭ سۇيىسپەنشىلىگى سونداي</title>
<key>G</key>
<lyrics>[V1]
.    G  C G
 ///  قۇدايدىڭ سۇيىسپەنشىلىگى،
 سونداي كەرەمەت! ///
.D  C D G
 ول كەرەمەت!

[C1]
.  G
   سونداي بيىك، ودان بيىك ەشنارسە جوق!
.  C
   سونداي تەرەڭ، ودان تەرەڭ ەشنارسە جوق!
.  G
   سونداي كەڭ، ودان كەڭ ەشنارسە جوق!
.  D  C/D G
   ول كەرەمەت!

[V2]
 /// قۇدايدىڭ ادالدىعى،
 سونداي كەرەمەت! ///
 ول كەرەمەت!

[V3]
 /// قۇدايدىڭ قۇرمەتى،
 سونداي كەرەمەت!
 ول كەرەمەت! ///</lyrics>
</song>