<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.Dm               A7
 مىنە بۇگىن كەلدى ۋاقىت ساعان
.      Dm
 الدىڭ اۋىر جازا.
.Dm             A7
 بولساڭداعى مەيىرىمگە تولعان
.    Dm         (D7)
 كۇنالاردان تازا.

[C1]
.     Gm                 C7
   // جاس كەلەدى مولدىرەپ جانارىما،
.  F                 Dm
   قالاي عانا شىدادىڭ ازابىنا؟
.  Gm                   A
   ايقىش اعاش، قاعىلعان تەمىر شەگە،
.  A7       Dm
   جازىقسىز قولدارىڭا! //

[V2]
 شاقىردىڭ سەن بارلىق ادامزاتتى
 عاجايىپ ومىرگە.
 ٴوز قولىڭمەن سالىپ بەرگەن
 جولىڭ جۇماقتىڭ تورىنە!

[C2]
   // ماڭگىلىكتىڭ جەتەلەپ ەسىگىنە
   قۇتقارىلۋ سيلادىڭ بار الەمگە.
   ايتشى، نەگە باردىڭ سەن
   ٴوز ەركىڭمەن وسى ٴبىر ولىمگە؟!/ //

[V3]
 بىزدەر ٴۇشىن بۇل دۇنيەگە كەلىپ
 ولىمنەن ٴتىرىلدىڭ،
 جەر بەتىنە رۋحىڭدى جىبەرىپ
 بيىكتەن كورىندىڭ!

[C3]
   // سەنەمىن مەن سەن مەنىڭ قاسىمداسىڭ.
   ساعان دەگەن سەنىمىم تاۋسىلماسىن.
   كۇتەمىن مەن ٴوزىڭدى يسا يەم
   ايتقانىڭ ورىندالسىن!/ //</lyrics>
<title>مىنە بۇگىن كەلدى ۋاقىت ساعان РӘЖ139 МЖЖ111</title>
<hymn_number>139</hymn_number>
<author>شىنتەمىروۆ ٴابىلحايىر</author>
</song>