<?xml version="1.0" encoding="UTF-8"?><song><author>جُهن لَُدُن</author>
<hymn_number>134</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em  D     Bm   Em
 ىبرايىمنىڭ قۇدايى،
. C     D          Em
 ٴبىز ٴۇشىن قان توككەن.
.Em    D    Bm/Em
 قۇرباندىققا يسا،
.C  D     Em
 كەلدى كوكتەن.

[C1]
.      E   E7   Am  D7    G    Em
   //   تاعزىم ەتىپ الدىنا كەلەمىن،
.  Em7 Am   D7     G
    ادىلەتتى پاتشامنىڭ!
.  E   E7   Am  D7     G   Em
    تاعزىم ەتىپ الدىنا كەلەمىن،
.  Em7  Am    D     Em
    مەيىرىمدى پاتشامنىڭ!  //

[V2]
 ٴسۇيىپ ٴبىزدى قۇتقاردى،
 ٴتاڭىرىمىز ۇلى.
 ماڭگى ٴتىرى سوزدەرى،
 تيەدى جىلى.

[V3]
 ٴتاڭىر سەنىڭ راقىمىڭ،
 تىنىشتىق بەرەدى..
 جارىق، نۇرىڭ جانىما،
 ەڭ كەرەگى.</lyrics>
<title>ىبرايىمنىڭ قۇدايى РӘЖ134</title>
</song>