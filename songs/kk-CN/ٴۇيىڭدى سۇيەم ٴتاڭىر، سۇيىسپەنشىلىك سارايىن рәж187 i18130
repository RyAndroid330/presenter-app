<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>187</hymn_number>
<lyrics>[V1]
. Em     B        Em
 ٴۇيىڭدى سۇيەم ٴتاڭىر،
.Em            B7   Em
 سۇيىسپەنشىلىك سارايىن.
.   Em  Am          Em
 //  ٴماسىح قانىمەن وتەلگەن،
.  B    B7   Em
 قاۋىمدى سۇيەمىن. //

[V2]
 الماس۔قاۋىمىڭدى
 سۇيەمىن مەن قۇداي،
 // بوساعاسىن ساقتايسىڭ
 سەن كوزدىڭ قاراسىنداي. //

[V3]
 قىمباتتى قاۋىمدى،
 ٴتىرى جان جيىنىڭ،
 // جان۔تانىممەن وتىنىشتە،
 ەسكە تۇسىرەمىن. //

[V4]
 قۇتقارۋشىم، يەم،
 قاۋىمدى سەن باسقار،
 // توزەتىندەي كۇش۔قۋات بەر،
 مەن وزىڭە كەلەم. //

[V5]
 قاۋىممەن بىرلىكتە،
 تۇرار مەنىڭ جانىم،
 // قاسىرەتتى ايقىش قىزمەتىن،
 كوتەرەم سالماعىن. //

[V6]
 سەنىڭ داڭقىڭدى،
 ٴبىز بىرگە بولىسەمىز.
 // سوندا امان قالىپ جانىم،
 الدىڭدا جىرلايمىن. //</lyrics>
<key>G</key>
<title>ٴۇيىڭدى سۇيەم ٴتاڭىر، سۇيىسپەنشىلىك سارايىن РӘЖ187</title>
</song>