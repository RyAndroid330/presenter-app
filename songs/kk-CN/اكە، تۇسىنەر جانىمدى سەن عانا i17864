<?xml version="1.0" encoding="UTF-8"?><song><author>نۇر</author>
<key>Eb</key>
<lyrics>[V1]
. Cm
 تولقۋىمدى مەنىڭ وسىنداي
. Fm
 تۇسىنەر جالعىز سەن عانا،
.         Fm             Cm
 // تەربەتەسىڭ مەنى تولقىنداي
. Fm         G        Cm
 سەزدىرمەي سىرىمدى باسقاعا //

[C1]
.       Fm        Cm
   // اكە! اكە! اكە! اكە!
.   Fm         G        Cm
   تۇسىنەر جانىمدى سەن عانا! //

[V2]
 اكە۔ساعان ايتسام بارلىعىن،
 ساقتالعاندى كوڭىلدە،
 // جاقسىنىڭ ساقتايسىڭ جالىنىن،
 جاماننىڭ جاباسىڭ جولدارىن! //

[V3]
 راقىمدىلىعىڭ سەنىڭ شەكسىز،
 قۇتقارىپ الدىڭ كەكسىز،
 // تازالايسىڭ مەنى التىنداي،
 توزاقتىڭ وتىنا لاقتىرماي! //</lyrics>
<title>اكە، تۇسىنەر جانىمدى سەن عانا</title>
</song>