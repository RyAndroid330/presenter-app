<?xml version="1.0" encoding="UTF-8"?><song><author>الىمبەكوۆ عالىمجان, قىزىلبورىكوۆ بولات</author>
<hymn_number>49</hymn_number>
<title>ەكى مىڭ جىلداي ەرتەرەك ҮРәж49 Қак33 РӘЖ109</title>
<key>A</key>
<lyrics>[V1]
.     C               A
 ەكى مىڭ جىلداي ەرتەرەك،
. D                  A
 ادام بوپ جەرگە كەلىپسىڭ،
.   D            A
 موينىڭا الىپ كۇنامدى،
.      E7          A
 مەن ٴۇشىن ازاپ شەگىپسىڭ.

[V2]
 كوپ كۇنا جاساپ مەن بىلمەي،
 جۇرگەنىم ساعان مالىم۔ٴدى،
 كىتاپتان تاپتىم ىنجىلدەي،
 ارايلاپ اتقان تاڭىمدى.

[V3]
 دۇنيەگە يسا جارىقسىڭ،
 ماڭگىلىك ٴومىر بەرەتىن.
 ايقىشقا بارىپ قاعىپسىڭ،
 توزاقتى بىزدەر كورەتىن.

[V4]
 مەيىرىم شاشقان كوزىڭنەن،
 قۇدايدىڭ نۇرىن سەزەمىن،
 كيەلى سەنىڭ سوزىڭنەن،
 كۇش۔قۋات الىپ كەلەمىن.

[V5]
 كەشىگىپ قالماي تۇرعاندا،
 كەشىرىمىن تەز الۋعا،
 اسىققىن سەن دە، باۋىرىم،
 جۇماقتا ماڭگى بولۋعا.</lyrics>
</song>