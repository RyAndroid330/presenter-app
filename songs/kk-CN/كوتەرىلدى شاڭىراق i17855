<?xml version="1.0" encoding="UTF-8"?><song><title>كوتەرىلدى شاڭىراق</title>
<lyrics>[V1]
 كوتەرىلدى شاڭىراق،
 جۇماقتاعى تورىندە.
 اكە ٴبارىن شاقىرىپ،
 دايىنداعان ۇيىنە.

[C1]
   // تويعا شاقىرىلعان كەزىڭدە
   دايىن بول قاشاندا
   دۇنيەگە بايلانبا
   قۇششاعىنا سيعىزادى
   اكەمىز شاقىرعاندا
   الدانىپ قالىپ قالما //

[C2]
   // ەستىمگەن كوز كورمەگەن توي باستالدى ماڭگىلىك
   قۇتقارىلعان ٴاربىر جاننىڭ دايىندادى اكە ورنىن //
   // كۇتىپ وتىر ٴار بالاسىن داستارحاننىڭ باسىندا
   كەلسىن قالسىن دەپ ماڭگى جايىنداعان وتباسىندا. //</lyrics>
<author>نۇر</author>
</song>