<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>124</hymn_number>
<author>نەٸزۆەستەن</author>
<key>F#</key>
<lyrics>[V1]
.D#m        G#m
 قۇتقارۋشىم، عاجاپسىڭ،
.A#           D#m
 مەن ٴۇشىن سەن كوتەردىڭ.
.         G#m
 ەڭ اۋىرىن ازاپتىڭ،
.C#7          F#     D#m
 سەنى دوس دەپ وتەرمىن.

[C1]
.     D#m          G#m
   //  ەسىمدە توگىلگەن قانىڭ،
.  C#7           F#
   قولدارىڭ جارا باسقانى.
.  D#m            G#m
    كەلىپ تاڭىرگە مەن تاعى،
.  A#       A#sus  D#m/D#7
    باس ٴيىپ العىس ايتامىن. //

[V2]
 ايتقان ٴسوزىڭ ەسىمدە:
 «كەشىر اكە ولاردى».
 كەز بولعانىڭ ەسىمدە،
 و، يسا، ماعان جولدا.

[V3]
 شاقىرماساڭ سەن مەنى،
 تارتپاساڭ جىلى سوزبەنەن
 جۇرەر ەدىم اداسىپ،
 ٴار قيلى جالعان جولمەن.

[V4]
 ٴماسىح مەنى سۇيگەندە،
 ومىرىمە ەندى نۇر.
 تەك يسادا تىنىشتىق،
 شاتتىق، ٴومىر ماقساتىم.</lyrics>
<title>قۇتقارۋشىم، عاجاپسىڭ ҮРәж124</title>
</song>