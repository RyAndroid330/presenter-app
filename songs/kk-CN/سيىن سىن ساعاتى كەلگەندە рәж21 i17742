<?xml version="1.0" encoding="UTF-8"?><song><title>سيىن سىن ساعاتى كەلگەندە РӘЖ21</title>
<lyrics>[V1]
.  Em  B7          Em B7
 سيىن سىن ساعاتى كەلگەندە،
.Em  B7     Em E
 وزىڭدى۔ٴوزىڭ جەڭگەندە.
.     Am       D        G  Em
 // سيىن بويىڭدى كۇنا جايلاسا،
.  Am          B       Em
 قۇداي كەشىرسىن دەپ سيىن. //

[V2]
 سيىن اشۋدى جەڭگەندە،
 باسىڭا قاۋىپ تونگەندە.
 // سيىن جاقىن ادامىڭ ٴۇشىن.
 دۇشپانىڭ ٴۇشىن دە سيىن. //

[V3]
 سيىن رۋحىڭ السىزدەنگەندە،
 مەنمەندىگىڭ ٴۇشىن سيىن.
 // سيىن جاقىنىڭنان ايىرىلعاندا،
 جاڭا ٴومىر ٴۇشىن سيىن. //

[V4]
 سيىن قۋانىشتى ساتتەردە،
 قيىنشىلىقتان وتكەندە.
 // سيىن جەڭىستەرگە جەتكەندە،
 قۇدايدى ماداقتاپ سيىن. //</lyrics>
<key>G</key>
<hymn_number>21</hymn_number>
</song>