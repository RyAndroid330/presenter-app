<?xml version="1.0" encoding="UTF-8"?><song><author>باۋىرجان پۋلاتوۆ</author>
<key>Am</key>
<lyrics>[V1]
.Am          G      Am
 سەن ٴبىر جەمىس اعاشسىڭ .
.           G       Am
 ورناتىلعان سۋدىڭ بويىنا
.    Dm      G     C/Am
 // ازعىرعان اداسقان دەسە
.Dm      E       Am
 باۋىرىم ەشبىر مويىما //

[C1]
.      Am     G     Am
   // ٸسا ٴجۇزىم بۇتاعى
.   Dm    E     Am
   قۇداي اكە باعبانى
.     G         C
   بىرگە بولساڭ يسامەن
.   E           Am
   جەمىسىڭ مول بولادى! //

[V2]
 قورىققان ٴتىرى قۇدايدان
 ول اقىلدى دانا جان دەگەن.
 // جاۋاپ بەرشى تاس اتقاندارعا
 باۋىرىم ال سەن نان مەنەن //

[V3]
 جۇرەگىڭدى تولتىر كۇندە وقىپ.
 كوكتەگى اكەمىز سوزىنە.
 // باۋىرىم كورسەت سەن سونى
 قالاساڭ نەنى وزىڭە. //

[V4]
 ۋاقىتىڭدى كوپ ٴبول كىتاپقا.
 وندا ٴومىر بۇلاق كوزى بار.
 // قۇتقارۋشى ەسىك، جول. شىندىق،
 ماڭگى ٴومىر يسا ٴسوزى بار. //</lyrics>
<title>يسا ٴجۇزىم بۇتاعى</title>
</song>