<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>30</hymn_number>
<author>ايگۇل ماحانوۆا</author>
<lyrics>[V1]
.D        A  G       A
 قۇدىرەتتى قۇدايىمسىڭ!
.D      A    G    A
 سەنىڭ تاعىڭ ەڭ ۇلى،
.D     A  G       A
 ەسىمىڭ سەنىڭ بيىكتە.
.D      A    G    A
 شىنىمەن مەن وزگەردىم!
.D     A   G    A
 وسىعان قۋانامىن.
.D     A  G          A
 اتىڭدى ماداقتايمىن ٸەم!

[C1]
.             Bm      F#m
   //  سەن ٴبارىنىڭ يەسى!
.     G      A        Bm
   ٴتاڭىرسىڭ سەن ماڭگى!  //

[V2]
 تاعىڭ سەنىڭ كيەلى،
 ادىلەتتى بارىنەن.
 قولدارىمدى ساعان كوتەرەم.
 مەن وزىڭە ۇقساتتىڭ
 وسىعان قۋانامىن.
 بارلىق ٴومىرىم سەندە بولسىن.</lyrics>
<key>D</key>
<title>قۇدىرەتتى قۇدايىمسىڭ! Қак30 МЖЖ80</title>
</song>