<?xml version="1.0" encoding="UTF-8"?><song><title>وسى ومىردە قينالعان كەزدە МЖЖ119</title>
<key>Am</key>
<lyrics>[V1]
.Am         G
 وسى ومىردە قينالعان كەزدە،
.F                 E
 ەسىمە سەنى الامىن.
 ٴاربىر كۇنىمدە قۋانعان كەزدە،
 ەسىمە سەنى الامىن.

[C1]
   جانىمداسىڭ سەن مەنىڭ ٴارقاشان،
   جان۔تانىممەن ۇمتىلامىن مەن ساعان.
   سەنىمىم بار ەشقاشان سارقىلمايتىن،
   ٴۇمىتىم بار وشپەيتىن ماڭگى.

[V2]
 وسى ومىردە قينالعان كەزدە،
 جانىما سەنى شاقىرام.
 ٴاربىر كۇنىمدە قۋانعان كەزدە،
 جانىما سەنى شاقىرام.</lyrics>
<hymn_number>119</hymn_number>
</song>