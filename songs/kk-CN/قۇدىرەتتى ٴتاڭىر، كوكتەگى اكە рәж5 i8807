<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>5</hymn_number>
<title>قۇدىرەتتى ٴتاڭىر، كوكتەگى اكە РӘЖ5</title>
<key>D</key>
<lyrics>[V1]
. Bm         F#     Bm     A7
 قۇدىرەتتى ٴتاڭىر، كوكتەگى اكە،
. G         D        A      D
 جاراتقان ٴبىزدى پاتشاسىڭ جەردە.
.     G         D       A      Bm
 //  كورەگەن، ماڭگى، كەرەمەت، دانا،
.  Em      D           F#   Bm
 جىبەرشى جارىق، بول بىزبەن بىرگە.  //

[V2]
 يگى ىستەر كوزى، كوكتەگى اكە،
 وزىڭە سەنگەن قالدىرما ٴبىزدى.
 //  تىنىشتىعىڭدى ورناتىپ جۇرەككە
 باتاڭمەن بەر كوكتەن مول بەرەكە.  //

[V3]
 كوكتەگى اكە، جاماندىقتان ساقتاپ،
 قاسيەتتى بولۋعا جەتەلە.
 //  جانىمىزدى جادىرات جاقسى انمەن،
 سەنىمدە نىعايت اق باتاڭمەن.  //</lyrics>
</song>