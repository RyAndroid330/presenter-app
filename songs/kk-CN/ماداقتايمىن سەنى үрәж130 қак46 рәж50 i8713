<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.   Dm
 ماداقتايمىن سەنى
.        Bb
 ارداقتايمىن سەنى
.Gm      C      F    A7
 انگە قوسىپ سەنى جىرلايمىن.
.     Dm
 اكە دەيمىن سەنى
.       Bb
 دارىپتەيمىن سەنى
.  Gm         A7          Dm
 ٴار ٴسوزىڭدى سەنىڭ تىڭدايمىن

[C1]
.     Gm   C  F  Dm
   // و، يسا، و، يسا،
.   Gm      A7        Dm (D7)
   و، يسا ماڭگىلىك سەن جاسا!  //

[V2]
 ساعىنامىن سەنى
 سۇيەمىن دەپ سەنى
 ٴتاڭىرىم دەپ سەنى سانايمىن
 پانام دەيمىن سەنى
 قۇرمەتتەيمىن سەنى
 اللەلۋيا ساعان ايتامىن</lyrics>
