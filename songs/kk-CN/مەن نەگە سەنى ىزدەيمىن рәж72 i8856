<?xml version="1.0" encoding="UTF-8"?><song><title>مەن نەگە سەنى ىزدەيمىن РӘЖ72</title>
<key>C</key>
<lyrics>[V1]
.   Am
 مەن نەگە سەنى ىزدەيمىن،
.F         E7
 سەن مەنىڭ جانىمداسىڭ.
 سەنسىز مەن تۇسىنبەيمىن،
.  Am
 ٴومىردىڭ ماعىناسىن.
.    A
 // ەشقاشان كونە الماسپىن،
.  Dm
 تاعدىردىڭ سالعانىنا،
. Am
 ايبىندى قۇتقارۋشىم،
.   Dm        E7          Am
 ايبىندى قۇتقارۋشىم، سەن تۇرعاندا. //

[V2]
 اكەلىك كۇنىمدى اڭساپ،
 ويلانىپ، تولعانامىن،
 كەتسەمدە الىس ۔ ۇزاق،
 وزىڭە ورالامىن.
 // جەتسەمدە تالاي۔تالاي،
 ٴومىردىڭ شىڭدارىنا
 سەن مەنىڭ ارمانىم بوپ،
 سەن مەنىڭ ارمانىم بوپ، قالا بەرشى. //

[V3]
 كوزىمدى جۇمعان كەزدە،
 كورەمىن نۇر بەينەڭدى،
 كەۋدەمدى كۇي كەرنەگەن
 عاجايىپ ٴبىر سەزىمدى
 // سەن مەنىڭ باقىتىمسىڭ،
 ارايلى اق تاڭىمسىڭ،
 ماڭگىلىك ايتىپ وتەر،
 ماڭگىلىك ايتىپ وتەر، ٴان جىرىمسىڭ. //</lyrics>
<hymn_number>72</hymn_number>
</song>