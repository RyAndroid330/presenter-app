<?xml version="1.0" encoding="UTF-8"?><song><author>جانات كۋساينوۆا</author>
<key>D</key>
<lyrics>[C1]
.     D            A      B
   //  ٴبارى دە جاقسى بولادى،
.  Em                 A
    ٴاردايىم سەن قاسىمدا ،
.           G    Bm
   يسا ۔ ٴتاڭىرىم!
.          Em          A
   مەن سەنەمىن سەن جەتەلەيسىڭ مەنى! //

[V1]
.   D            A    Bm
 //  نۇرسىڭ سەن ومىرىمدە،
.G          D   A
 ەڭ جاقىن جۇرەگىمە،
.D          A       Bm    G
 باقىتسىزدىقتان ٴبىزدى ساقتايسىن،
.D      A      D
 اركەزدە بىزبەن بىرگە! //

[C2]
   // ٴبارى دە جاقسى بولادى،
   ٴاردايىم سەن قاسىمدا ،
   يسا ۔ ٴتاڭىرىم!
   مەن سەنەمىن سەن جەتەلەيسىڭ مەنى! //

[B1]
.     A      Bm      G          A   B
   //  مەنىڭ اتىم ماڭگى ۔ ٴومىر كىتابىندا،
.  G     Em     A   D
    جازىلدى مەن سەنەمىن!
.  Bm      G  A      Bm
    بۇكىل الەم شايقالسا دا،
.  G       Em         A    Bm
    يسا ٴتاڭىر ۔ مەنىڭ تىرەگىم! //</lyrics>
<aka>ٴبارى دە جاقسى بولادى</aka>
<title>نۇرسىڭ سەن ومىرىمدە</title>
</song>