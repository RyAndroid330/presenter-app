<?xml version="1.0" encoding="UTF-8"?><song><tempo>٥٦</tempo>
<author>رُِبِن مُرگَن, بِن فِِلدِنگ</author>
<title>بىلەم، سەندە مەن كىممىن</title>
<time_sig>س: ٠٢٧</time_sig>
<lyrics>[V1]
 كىممىن مەن،
 شاقىراتىنداي ۇلى پاتشا!
 جوعالدىم، تاپتى مەنى ول
 ماحابباتىمەن،
 ماحابباتىمەن.

[C1]
   ازاتتىق بەردى
   يسا ماڭگىلىك.
   مەن قۇداي ۇلى!
   ٴدال سولاي!

[V2]
 قۇن تولەپ ازاتتىق بەردى
 راقىمىمەن.
 كۇناعا قۇل بولدىم. يسا
 مەن ٴۇشىن ٴولدى.۔2

[C2]
   ازاتتىق بەردى
   يسا ماڭگىلىك.
   مەن قۇداي ۇلى!
   ٴدال سولاي!
   اكەم ۇيىندە
   ورىن بار ماعان.
   مەن قۇداي ۇلى!
   ٴدال سولاي!

[B1]
   مەن تاڭدالدىم،
   تاستالمادىم،
   بىلەم سەندە مەن كىممىن!
   سەن جاقتاۋشىم،
   سەن قولداۋشىم،
   بىلەم سەندە مەن كىممىن!</lyrics>
</song>