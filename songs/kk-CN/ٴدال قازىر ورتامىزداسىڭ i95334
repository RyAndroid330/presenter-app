<?xml version="1.0" encoding="UTF-8"?><song><author>سِنَكه</author>
<title>ٴدال قازىر ورتامىزداسىڭ</title>
<aka>سەنسىڭ قۇدايىم</aka>
<lyrics>[V1]
.     F                   C
 // ٴدال قازىر ورتامىزداسىڭ
. G             Am7
 سٸىنامىن، سيىنامىن.
.F                      C
 سەن ٴبىزدى وزگەرتىپ جاتسىڭ،
.G              Am7
 سيىنامىن، سيىنامىن. //

[C1]
.          F
   // ۋادەڭە ساي ٴومىردى بەردىڭ،
.  C
   تۇنەكتى جارىپ نۇر بولىپ كەلدىڭ،
.   G                  Am
   ٴٸا، ول سەنسىڭ ۔ قۇدايىم. //

[V2]
.G     F            C
 تولتىرشى ٴاربىر جۇرەكتى،
.G              Am
 سيىنامىن، سيىنامىن.
.F                C
 ەمدەشى ٴاربىر جۇرەكتى،
.G             Am
 سيىنامىن، سيىنامىن.
.G     F            C
 سويلەشى ٴاربىر جۇرەككە،
.G              Am
 سيىنامىن، سيىنامىن.
.F                C
 وزگەرتشى ٴومىرىمىزدى،
.G             Am
 سيىنامىن، سيىنامىن.

[B1]
.      F
   // كورمەسەمدە سەن عاجاپ جاسايسىڭ،
.   C
   سەزبەسەمدە سەن عاجاپ جاسايسىڭ.
.    G
   جالعاسادى ىستەرىڭ قۇدايىم،
.   Am
   جالعاسادى ىستەرىڭ قۇدايىم. //</lyrics>
<key>F</key>
</song>