<?xml version="1.0" encoding="UTF-8"?><song><title>سۇيىسپەنشىلىكپەن اندەتىپ РӘЖ34</title>
<lyrics>[V1]
.   Bm                G  A
 سۇيىسپەنشىلىكپەن اندەتىپ،
.  F#7    Bm
 سەنىمدە بىرگە ٴجۇرۋشى ەك.
.    Em          Bm
 //  اسۋى بيىك جولداردا،
. F#             Bm (B7)
 بورانعا قارسى تۇرۋشى ەك.  //

[V2]
 از عانا ەڭبەك ەتسەك تە،
 وت بولىپ جانىپ تۇرۋشى ەك.
 //  تۇنگى اسپانعا قاراۋمەن،
 الىسقا كوزدى تىگۋشى ەك.  //

[V3]
 ٴبىزدى قورقىتقان سوزدەردى،
 تايسالماي قارسى الۋشى ەك.
 //  قۇدايدىڭ ٴسوزىن ورىنداپ،
 دۇنيەدە تازا ٴجۇرۋشى ەك.  //

[V4]
 شۋاقتى قىمبات جۇماققا،
 اندەتىپ بىرگە بارامىز.
 //  قايعىسى، مۇڭى جوق جەردە،
 ماڭگىلىك جاساپ قالامىز.  //</lyrics>
<key>D</key>
<author>simوn كھوrوlsكiۇ</author>
<hymn_number>156</hymn_number>
</song>