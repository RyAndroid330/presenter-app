<?xml version="1.0" encoding="UTF-8"?><song><title>ٴجۇسىپ جاقىپ بالاسى، راحٸلا ونىڭ اناسى РӘЖ245</title>
<key>C</key>
<lyrics>[V1]
.    C             Dm      C
 ٴجۇسىپ جاقىپ بالاسى، راحٸلا ونىڭ اناسى،
.C       Dm          G       C
 وتاندارى ولاردىڭ، يەرۋساليم قالاسى.

[C1]
.   F                   C
   كەڭ بايتاق قازاق دالاسى،
.    F                C
   ٴبىز قۇدايدىڭ بالاسى.
.     F         G
   كوكتەگى وتانىمىز
.               C
   يەرۋساليم قالاسى.

[V2]
 ٴجۇسىپ جاقسى كٸىندى، جاسادى ٴىستى ٴتيىمدى،
 ازعىرىلماي كۇناعا، قۇدايىنا سيىندى.

[C2]
   يسا ٴبىزدى اقتادى،
   امان۔ەسەن ساقتادى،
   ازعىرىلساڭ ايرىلدىڭ،
   ورنىڭنان ەدەم باقتاعى.

[V3]
 ٴجۇسىپ بارىنە كونەدى، قۇدايعا ەركىن بەرەدى،
 قيىندىقتا مويىماي، جەڭىسپەنەن كەلەدى.

[C3]
   ٴبىز دە يساعا سەنەيىك،
   جەتەگىنە ەرەيىك،
   قۇدايدى تەرەڭ قاستەرلەپ،
   رۋحاني جەمىس بەرەيىك.</lyrics>
<hymn_number>245</hymn_number>
</song>