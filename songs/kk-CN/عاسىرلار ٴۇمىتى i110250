<?xml version="1.0" encoding="UTF-8"?><song><title>عاسىرلار ٴۇمىتى</title>
<lyrics>[V1]
 يسانىڭ حابارى
 عاسىرلاردىڭ ٴۇمىتى
 ەشقاشان ول وشپەيدى
 جارقىراپ جانادى
 يسانىڭ قاۋىمىن
 ەشكىم جەڭە المايدى
 جۇلدىزداي جارقىرايدى
 نۇرىن ول توگەدى
 ەشكىم جەڭە المايدى

[C1]
   ٴماسىح ولگەن
   ٴبىراق قايتا ٴتىرىلدى
   ٴٸا، ول قايتادان كەلەدى
   ٴماسىح ۔ پاتشا
   ماڭگى جەڭىستە
   ٴٸا، بارلىق ماقتاۋ وعان ٴتان
   ٴٸا، بارلىق ماقتاۋ يساعا

[V2]
 بارلىق ۇرپاقتار ٴۇشىن
 ونىڭ ٴسوزى جاۋاپ
 الەم ونى وزگەرتپەيدى
 داق تۇسىرە المايدى
 ٴبىز مويىندايمىز
 جانە جاريالايمىز
 سەنەمىز جازىلعانعا
 سەنەمىز سەن ايتقانعا

[B1]
   ٴان سال الليلۋييا
   ٴماسىح قۇتقارۋشىمىز
   ٴان سال الليلۋييا
   ٴبىزدىڭ قۇداي قۇدىرەتتى</lyrics>
</song>