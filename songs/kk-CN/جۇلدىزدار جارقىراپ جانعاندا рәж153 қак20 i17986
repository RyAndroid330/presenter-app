<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.      Am       E         Am
 جۇلدىزدار جارقىراپ جانعاندا،
.     A7                Dm
 جارىق اي كورىنىپ اسپاندا،
.          Dm       G     C       Am
 //  ٴتاڭىرىم، وزىڭە جۇرەكتى اشقاندا،
.      Dm         E         Am
 ٴتاڭىرىم، سەن مەنى قۇتقاردىڭ.  //

[V2]
 ٴومىردىڭ تابا الماي باقىتىن،
 جولىمنىڭ بىلە الماي باعىتىن،
 //  تۇنشىعىپ تۇڭعيىق تۇبىندە قالعاندا،
 ٴتاڭىرىم، سەن مەنى قۇتقاردىڭ.  //

[V3]
 كۇنانىڭ شىعا الماي تورىنان،
 اداسىپ ٴجۇرىپپىن جولىمنان.
 //  جۇرەكتى تاعى دا جالعىزدىق باسقاندا،
 ٴتاڭىرىم، سەن مەنى قۇتقاردىڭ.  //

[V4]
 ٴومىردىڭ قايعى مەن ازابىن،
 ۇمىتتىم كۇنانىڭ مازاعىن.
 //  ٴتاڭىرىم قۇتقاردى، قۋانىش سيلادى،
 ٴتاڭىرىم، كۇنادان قۇتقاردى.  //</lyrics>
<key>C</key>
<title>جۇلدىزدار جارقىراپ جانعاندا РӘЖ153 Қак20</title>
<author>شىنتەمىروۆ ٴابىلحايىر</author>
