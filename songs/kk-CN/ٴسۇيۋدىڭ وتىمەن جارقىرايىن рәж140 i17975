<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>140</hymn_number>
<title>ٴسۇيۋدىڭ وتىمەن جارقىرايىن РӘЖ140</title>
<key>Bm</key>
<lyrics>[V1]
.      Bm        F#      Bm
 ٴسۇيۋدىڭ وتىمەن جارقىرايىن،
.Bm         F#       Bm
 تۇنەكتەن ٴبىرجولا ارىلايىن.
.    B7       Em     A7   D7      Bm
 // ٴتاڭىرىم شەككەن ازابىڭا كوز سالايىن،
.     Em    F#         Bm
 ايقىشتى اركەز ەسكە الايىن. //

[V2]
 تۇنگى ساپاردا جارىقتى كوردىم،
 جارىققا قاراي بەتىمدى بۇردىم.
 // ٴتاڭىرىم نۇرىڭمەن جۇرەك وتىن تۇتاتشى،
 جەتەلەشى قولىڭنان ۇستاتشى. //

[V3]
 رۋحىڭ وت جالىن بوپ جارقىراسىن،
 قۋانىش تاسقىنى سارقىراسىن.
 // يسانىڭ الاۋى جۇرەگىڭدى جاندىرسىن،
 بۇلاعىڭمەن ٴشولىڭدى قاندىرسىن. //

[V4]
 قۇدايدىڭ وتى مەندە لاۋلاسىن،
 رۋحىم ساۋلەسىمەن نۇرلانسىن.
 // بەينەڭدى سەنىڭ مەنەن ەل كورىپ تاڭدانسىن،
 بۇكىل ادامزات سەنى داڭقتاسىن. //</lyrics>
</song>