<?xml version="1.0" encoding="UTF-8"?><song><title>اندەتەمىن ساعان يەرۋساليم МЖЖ14 РӘЖ39</title>
<lyrics>[V1]
.   Bm                   Em
 اندەتەمىن ساعان يەرۋسالٸم،
.F#             Bm
 بەرەكەلى بولسىن يەرۋساليم.
.   Bm               Em
 ٴتاڭىر جارىلقاسىن، ٸەرۋساليم،
.    G          F#    A  D
 بەيبىتشىلىكتە بول، يەرۋساليم.

[C1]
.    Bm      Em    A  D
   شالوم، شالوم، يەرۋساليم،
.    G       Em
   شالوم، شالوم،
.  G            F#          Bm
   بەيبىتشىلىكتە بول يەرۋسالٸم!
   ٴتاڭىر جارىلقاسىن، يەرۋساليم!.

[V2]
 بەيبىتشىلىكتە بول، يەرۋساليم،
 قورعانىڭ نىق بولسىن، يەرۋساليم.
 قۋانىشقا تولسىن جۇرەگىمىز،
 ٴان ايتىلسىن ساعان، يەرۋساليم.

[V3]
 ۇمىتا المايمىن سەنى، يەرۋساليم،
 ويىمنان شىعارمايمىن، يەرۋساليم.
 ەسىمدەسىڭ سەن، يەرۋساليم،
 ماداقتايمىن سەنى، يەرۋساليم.</lyrics>
<key>D</key>
<hymn_number>14</hymn_number>
</song>