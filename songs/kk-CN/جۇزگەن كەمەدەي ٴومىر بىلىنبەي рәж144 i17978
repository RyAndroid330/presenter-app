<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>144</hymn_number>
<key>C</key>
<lyrics>[V1]
.      C
 جۇزگەن كەمەدەي ٴومىر بىلىنبەي،
.        Dm
 زىمىراپ وتە شىعار،
.  Dm
 نە كۇتەر الدا، تولقىن بار جولدا،
.              C
 كەيدە قۇزعا ۇرار.
.  C
 سەن دە، مەن دە، ٴبىز مۇلدە بىلمەيمىز،
.  Dm         F
 تەك قۇداي عانا بىلەر،
.         C               Dm
 ۋاقىت تا كەلەر ٴبىز كوكتى كورەر،
.                C
 بار ارمان ورىندالار.

[C1]
.           F
   و، قايدا سول جۇماق ٴتورى،
.    C
   تەك سوندا بولعىم كەلەدى،
.    G
   جارىق ماڭگى سونبەس جەردە،
.     G
   ٴولىم، قايعى بولماس ەلدە.
.    F
   و، قايدا سول جۇماق ٴتورى،
.   C
   دوستارىمنىڭ بولار ٴبارى،
.   Dm                     C
   توقتالماس بالا كۇلكىسى، شاتتىق ٴۇنى.

[V2]
 جاز دا وتەدى، قىس تا جەتەدى،
 ۋاعىمەن، كوپ كۇتتىرمەي،
 جاستىق تۇرمايدى، جىلدار ۇرلايدى،
 قارتتىق كەلەر بىلدىرمەي.
 كۇش بىتكەن كەزدە، ٴۇمىت جوق وزگە،
 تەك كوككە كوز تىگەرمىز.
 ارمان بوپ كەلگەن، ۇمىتپەن سەنگەن،
 جارىق جۇلدىز كورەمىز.</lyrics>
<title>جۇزگەن كەمەدەي ٴومىر بىلىنبەي РӘЖ144</title>
</song>