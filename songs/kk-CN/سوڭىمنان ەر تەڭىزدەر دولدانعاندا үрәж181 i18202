<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>181</hymn_number>
<key>Am</key>
<lyrics>[V1]
. Am                     E
 سوڭىمنان ەر تەڭىزدەر دولدانعاندا،
.                           E
 سوڭىمنان ەر تۇنەك سالتانات قۇرعاندا،
.   F                    E
 // سوڭىمنان ەر تىكەندى جولدارمەن،
. Am      E    Am
 سوڭىمنان ەر مەنىڭ. //

[V2]
 سوڭىمنان ەر ازاپ شەككەن كەزىڭدە،
 سوڭىمنان ەر كۇشىڭ تاۋسىلعان كەزدە،
 // سوڭىمنان ەر كومەك بەرەم ساعان،
 سوڭىمنان ەر مەنىڭ. //

[V3]
 سوڭىمنان ەر جاۋ سەنى ازعىرعاندا،
 سوڭىمنان ەر دوسىڭ سىرت اينالعاندا،
 // سوڭىمنان ەر تاستامايمىن سەنى،
 سوڭىمنان ەر مەنىڭ. //

[V4]
 سوڭىمنان ەر ەرتەڭىڭ تۇنەرگەندە،
 سوڭىمنان ەر كوزىڭ قاراۋىتقان كەزدە،
 // سوڭىمنان ەر ماڭگى ۇيگە كىرەسىڭ،
 سوڭىمنان ەر مەنىڭ. //</lyrics>
<title>سوڭىمنان ەر تەڭىزدەر دولدانعاندا ҮРәж181</title>
</song>