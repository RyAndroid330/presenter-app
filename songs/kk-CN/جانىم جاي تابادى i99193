<?xml version="1.0" encoding="UTF-8"?><song><title>جانىم جاي تابادى</title>
<lyrics>[V1]
 //// جانىم جاي تابادى. ////
 قۇدايدا!

[C1]
   // وزەندەي بەيبىت عۇمىر كەشسەم دە،
   قايعى باسسادا تولقىنداي،
   قانداي جاعداي بولماسادا ٴومىرىم
   جانىم جاي تابادى قۇدايدا! //</lyrics>
<author>بلِسس، پهِلِپ پَُل (١٨٣٨-١٨٧٦), سپَففُرد، هُرَتُِ گَتِس (١٨٢٨-١٨٨٨)</author>
</song>