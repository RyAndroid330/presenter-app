<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>198</hymn_number>
<author>مانار ر.</author>
<key>D</key>
<lyrics>[V1]
.D                  A
 ٴتاڭىر ساعان باتا بەردى
.A7                  D
 شەكسىز ٴسۇيىپ جارىلقادى
.D
 // &quot;باسىن ٴيىپ بالام كەلدى&quot;
.G             A   D
 دەپ قۇشاعىن ساعان جايدى //

[V2]
 ٴتاڭىر سەنى جارىلقادى،
 ماڭگى ٴومىردى سيعا تارتتى.
 // سەن ارقىلى باسقالاردى
 قۇتقارۋعا وسيەت ەتتى. //

[V3]
 سوزىنەن يسا قۋات العىن:
 «قيىندىق كورسەڭ جار بولامىن.
 // جۇرسەڭ۔داعى قيىر شەتتە،
 قاسىڭدا بىرگە مەن بولامىن». //</lyrics>
<title>ٴتاڭىر ساعان باتا بەردى ҮРәж198</title>
</song>