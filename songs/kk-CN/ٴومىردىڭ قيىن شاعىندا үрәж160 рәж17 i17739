<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>160</hymn_number>
<author>م.يۋ. لېرمونتوۋ</author>
<title>ٴومىردىڭ قيىن شاعىندا ҮРәж160 РӘЖ17</title>
<lyrics>[V1]
.   Bm
 ٴومىردىڭ قيىن شاعىندا،
.          D
 جۇرەكتى مۇڭ باسسا،
.         Bm         Em
 //  ٴبىر عاجايىپ دۇعانى مەن،
.   Bm   F#    Bm
 قايتالايمىن جاتقا.  //

[V2]
 سول ٴسوزدىڭ ۇندەستىگىندە،
 قۇدىرەتتى كۇش بار،
 //  قاسيەتتى ٴبىر كوركەمدىك،
 سول سوزدەردەن شىعار.  //

[V3]
 جۇرەكتىڭ جۇگى جەڭىلدەپ،
 جانىم راحات تابار.
 //  جان۔دۇنيەمە تۇسكەن جارىق،
 ٴۇمىت وتىن جاعار.  //

[V4]
 اۋىرلىق جۇرەكتەن تۇسەدى،
 كۇمان دا الىستايدى.
 //  جىلايمىن دا، سەنەمىن دە،
 جانىم راحات تابادى!  //</lyrics>
<key>D</key>
</song>