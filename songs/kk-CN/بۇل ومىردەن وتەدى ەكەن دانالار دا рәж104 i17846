<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<author>ەشىنتەمىروۆ ٴابىلحايىر</author>
<key>Bm</key>
<lyrics>[V1]
.   Am                 Em    F#
 بۇل ومىردەن وتەدى ەكەن دانالار دا،
.F#      Em       Am
 وتەدى ەكەن اق جاۋلىقتى انالار دا.
.  B7                        Em
 دۇنيەنى ٴدۇر سىلكىنتكەن پاتشالار دا،
. Am          Em
 وتەدى ەكەن اسىل سۇلۋ ارۋلار دا.

[C1]
.        Bm             F#
   //  ەي، ادامدار، ويلانىڭدار،
.     Em          Bm
   وتكەنگە كوز سالىڭدار.
.        F#
   بۇل ومىردە ماڭگى جۇرگەن،
.     Bm
   ايتىڭدارشى كىم بار؟.  //

[V2]
 كورگەن تۇستەي وتە شىعار كوز الدىڭنان،
 ٴومىر جالعان، ونى ەشكىم بىلە الماعان.
 بۇل ٴومىردىڭ بار بەيمالىم قۇپياسىن،
 قانشا ىزدەپ تالاي ادام تابا الماعان.

[V3]
 تىڭدا بۇگىن، تىڭدا ٴۇنىن جاراتقاننىڭ
 باعۋشىسىن باتقان كۇن مەن اتقان تاڭنىڭ.
 پەندەلەرى ٴجۇرسىنشى دەپ ماڭگىلىكتە،
 سۇيگەندىكتەن بىزدەر ٴۇشىن توكتى قانىن.

[V4]
 ماڭگىلىككە بارار جولدى كورسەتىپ،
 يسا ٴماسىح كوككە كەتكەن ٴتىرىلىپ.
 جاراتقاننىڭ الارىنان بەرەرى كوپ،
 سەن دە العىن، قالما دوسىم كىدىرىپ.</lyrics>
<title>بۇل ومىردەن وتەدى ەكەن دانالار دا РӘЖ104</title>
</song>