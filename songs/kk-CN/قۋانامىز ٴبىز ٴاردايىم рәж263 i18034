<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>263</hymn_number>
<key>D</key>
<lyrics>[C1]
.     D           A
   قۋانامىز ٴبىز ٴاردايىم،
.  Em           A    D
   شاتتانىپ ٴارقاشاندا!
.  D          A
   قۇدايدىڭ قۋانىش نۇرى،
.  Em          G/A  D
   سونبەيدى ەشقاشاندا!

[V1]
 كۇرەستە كومەكتەسەدى،
 ول ٴبىزدى جەتەكتەيدى.
 ازاپ قايعىدان ساقتايدى،
 ٴوتىنىشتى تىڭدايدى.

[V2]
 ٴماسىح جولىمەن جۇرەمىز،
 قول استىندا بولامىز،
 قيىنشىلىق تۇسكەن كەزدە،
 قورعاۋسىز ٴبىز قالمايمىز.

[V3]
 ٴومىر بەرگەن شاتتىق ٴۇمىت،
 جارىق كۇندەي نۇر توكتى.
 كۇناكاردى ٴسۇيىپ يەم،
 مول يگىلىكتەر بەردى.</lyrics>
<title>قۋانامىز ٴبىز ٴاردايىم РӘЖ263</title>
</song>