<?xml version="1.0" encoding="UTF-8"?><song><title>اۋمين</title>
<lyrics>[V1]
 /ٴتاڭىر يە، بىرگە بولىپ
 قورعان بولىپ ساعان، جارىلقاسىن
 بەت ٴجۇزىن، بۇرىپ ساعان
 تىنىشتىق سيلاسىن/

[C1]
   /اۋمين، اۋمين، اۋمين
   اۋمين، اۋمين، اۋمين/

[V2]
 /ٴتاڭىر يە، بىرگە بولىپ
 قورعان بولىپ ساعان، جارىلقاسىن
 بەت ٴجۇزىن، بۇرىپ ساعان
 تىنىشتىق سيلاسىن/

[C2]
   /اۋمين، اۋمين، اۋمين
   اۋمين، اۋمين، اۋمين/
   /// اۋمين، اۋمين، اۋمين
   اۋمين، اۋمين، اۋمين ///

[V3]
 /ول سەنىمەن، بىرگە بولسىن
 ۇرپاعىڭنان ۇرپاعىڭا
 ٴوز ٴۇيىڭ دە، جۇرەگىڭدە
 نەمەرەڭمەن، شوبەرەڭدە/

[V4]
 /ول سەنىمەن، بىرگە بولسىن
 ۇرپاعىڭنان ۇرپاعىڭا
 ٴوز ٴۇيىڭ دە، جۇرەگىڭدە
 نەمەرەڭمەن، شوبەرەڭدە/

[V5]
 /قۇداي ٴجۇرسىن
 قولداپ، قورعاپ
 ول قاسىڭدا، تاستامايدى
 قامقورلايدى، جەتەلەيدى
 ٴارقاشاندا، ول قاسىڭدا/

[V6]
 /تاڭ سارىدەن
 قارا تۇنگە
 ٴاربىر جەردە
 ول جانىڭدا
 جىلاساڭ دا، قۋانساڭ دا
 ول سەنىمەن، تاستامايدى/
 //// ٴارقاشان دا، ول قاسىڭدا ////

[C3]
   /اۋمين، اۋمين، اۋمين
   اۋمين، اۋمين، اۋمين/</lyrics>
<author>كُدي كَرنِس, كَرِ جُبِ, ستِڤِن فُرتِكك, كهرِس برُون</author>
</song>