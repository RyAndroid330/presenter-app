<?xml version="1.0" encoding="UTF-8"?><song><title>ٴتاڭىردىڭ رۋحى مەنى تولتىرعاندا ҮРәж200 МЖЖ139 РӘЖ173</title>
<key>C</key>
<lyrics>[V1]
.Am          Dm     Em     Am
 ٴتاڭىردىڭ رۋحى مەنى تولتىرعاندا،
 // داۋىتشە دۇعا ەتەمىن. //
 // دۇعا ەتەمىن، دۇعا ەتەمىن،
 داۋىتشە دۇعا ەتەمىن //

[V2]
 ٴتاڭىردىڭ رۋحى مەنى تولتىرعاندا،
 // داۋىتشە ٴان سالامىن. //
 // ٴان سالامىن، ٴان سالامىن
 داۋىتشە ٴان سالامىن //

[V3]
 ٴتاڭىردىڭ رۋحى مەنى تولتىرعاندا،
 // داۋىتشە ٴبي بيلەيمىن //
 // ٴبي بيلەيمىن، ٴبي بيلەيمىن،
 داۋىتشە ٴبي بيلەيمىن //

[V4]
 ٴتاڭىردىڭ رۋحى مەنى تولتىرعاندا،
 // داۋىتشە دۇعا ەتەمىن. //
 // دۇعا ەتەمىن، ٴان سالامىن
 داۋىتشە ٴبي بيلەيمىن //

[V5]
 // ٴتاڭىر رۋحى مەنى تولتىرعاندا،
 داۋىتشە ماداقتايمىن. //
 // ماداقتايمىن، ماداقتايمىن،
 داۋىتشە ماداقتايمىن. //</lyrics>
<hymn_number>200</hymn_number>
<author>فرِد هَممُند</author>
</song>