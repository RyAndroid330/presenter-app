<?xml version="1.0" encoding="UTF-8"?><song><title>يسا ٴتاڭىرىم، بارلىق ٴومىرىم</title>
<lyrics>[V1]
 ەي، يسا ٴتاڭىرىم، بارلىق ٴومىرىم
 تەك وزىڭمەن مايلانعانىن مەن كوردىم
 // وزىڭنەن باسقا، ٴتاڭىر جوق اسقان،
 جۇرەككە ٴسوزىن رۋحىمەن باسقان ە۔ە۔ي!
 قۇدايىم ۔ سەن! جۇرەك يەسى! //

[C1]
   // باق قونىپ باسقا، تىنىم كەلىپ جانعا،
   وزىڭمەن يسا،
   وزىڭنەن ارتىق،
   جۇرەككە ىستىق، ەشكىم جوق باسقا.
   جاماندىق كەتىپ، جاقسىلىق ەگىپ،
   سەن جانىمىزعا، اق باتا بەرىپ
   جارىلقاۋ توگىپ، الدىڭ قۇشاعىڭا. //
   ەي، جان تىنىشتىعىن،</lyrics>
<author>نۇر</author>
</song>