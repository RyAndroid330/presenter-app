<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>189</hymn_number>
<author>نۋراباەۆا باحىت</author>
<lyrics>[V1]
 وتكەن ىسكە وكىنىپ،
 الدىڭا مەن كەپ تۇرمىن.
 // تاپسىردىم ٴومىرىمدى،
 وزىڭە مويىن بۇردىم. //

[V2]
 تىلىممەنەن، ويمەنەن
 ٴولتىرىپپىن تالايدى.
 // وزىڭمەنەن جۇرەگىم
 ٴبىر بولۋدى قالايدى. //

[V3]
 سەنسىڭ جاسىل جايلاۋىم،
 سەنسىڭ تىنىش ٴومىرىم.
 // پەندەمىن ٴبىر كۇنالى،
 كەشىرە گور، ٴتاڭىرىم. //

[V4]
 ماداقتايىن تەك سەنى،
 قۇدىرەتتى قۇدايىم،
 // قابىل الشى دۇعامدى،
 قىزمەتىڭە جارايىن. //</lyrics>
<title>وتكەن ىسكە وكىنىپ РӘЖ189</title>
</song>