<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>17</hymn_number>
<author>لِنني لِبلَنك, پَُل بَلُكهِ</author>
<title>بارلىق كۇشتەردەن بيىكسىڭ</title>
<lyrics>[V1]
.G      C        D    G
 بارلىق كۇشتەردەن بيىكسىڭ،
.G     C          D         G
 جاراتىلىستاردان، تابيعاتتاردان.
.      Em         Bm          C   G
 جوعارى بۇكىل اقىلدان، دانالىقتان.
. Am                D
 پاتشالاردىڭ پاتشاسى سەن!

[V2]
.G       C          D       G
 اتاقتان، داڭقتاردان ول جوعارى،
.G     C            D          G
 جوعارى عاجاپتاردان ادامزات كورگەن.
.    Em           Bm           C   G
 جەر بەتىندەگى زور بايلىقتان جوعارى،
.Am         C           B7
 تەڭدەسى جوق مەيىرىم بەرگەن!

[C1]
.  G    Am    D           G
    اياۋسىز ايقىشقا تاڭدىردى،
.  G  Am     D            G
   اكەسى باس تارتىپ قالدىردى.
.  G      Em  Bm          C  G
    راۋشانداي جەرگە تاپتالعان،
.        Am    G    C   D
   بار كۇنامنان اقتاعان،
.         G
   ول جوعارى!</lyrics>
<key>G</key>
</song>