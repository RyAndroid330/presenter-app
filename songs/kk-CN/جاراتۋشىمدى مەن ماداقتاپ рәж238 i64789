<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>238</hymn_number>
<key>C</key>
<lyrics>[V1]
.      C
 جاراتۋشىمدى مەن ماداقتاپ،
. G          C
 انىمە قوسقىم كەلەدى.
.    F          G         C Am
 // بىزگە كەلدى اسپاندى تاستاپ،
.   F      G               C
 قۇتقاردى ٴبىزدى سەبەبى //

[V2]
 قۇتقارۋشىمدى مەن داڭقتايمىن،
 راقىمى، مەيىرى ٴۇشىن.
 // سوزدەرىن ەسىمدە ساقتايمىن،
 جۇرەككە بەردى ٴوز كۇشىن //

[V3]
 بار ادامزاتتىڭ، بار الەمنىڭ،
 العىسىنا قۇداي لايىق.
 // ول پاتشاسى جەر مەنەن كوكتىڭ،
 الدىنا ونىڭ بارايىق //</lyrics>
<title>جاراتۋشىمدى مەن ماداقتاپ РӘЖ238</title>
</song>