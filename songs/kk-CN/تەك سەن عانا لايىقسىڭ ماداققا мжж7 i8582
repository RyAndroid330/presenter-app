<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7</hymn_number>
<aka>اسقار تاۋلاردان دا ۇلىسىڭ</aka>
<key>F</key>
<lyrics>[V1]
.   F            C      Bb/F
 //  اسقار تاۋلاردان دا ۇلىسىڭ،
.Dm              C             F  C
 اسپانداعى جۇلدىزداردان دا بيىكسىڭ. //

[C1]
.     F            C        Bb        Dm
   // ٴٸا، ساعان ۇقساس ەشكىم جوق ٴتاڭىرىم
.   F          C            Bb      Dm
   ٴٸا، تىزە بۇگىپ كەلىپ تۇرمىن الدىڭا! //

[B1]
.       Dm   Bb            C
   ////  تەك سەن عانا لايىقسىڭ ماداققا،
.      F             Dm                 (C)
   تەك سەن عانا لايىقسىڭ قۇرمەتكە! ////</lyrics>
<title>تەك سەن عانا لايىقسىڭ ماداققا МЖЖ7</title>
</song>