<?xml version="1.0" encoding="UTF-8"?><song><title>الدەكىم ٴۇيىن قۇمعا تۇرعىزىپتى РӘЖ224</title>
<lyrics>[V1]
.     D/A      A/D    G/D       Bm
 /// الدەكىم ٴۇيىن قۇمعا تۇرعىزىپتى! ///
.  Em  A  D
 جاۋىن جاۋدى.

[V2]
 /// جاۋىن جاۋىپ، سۋ كوتەرىلىپ تاسىدى! ///
 سوندا ٴۇي قۇلادى!

[V3]
 /// ەكىنشىسى ٴۇيىن، جارتاسقا تۇرعىزىپتى! ///
 جاۋىن جاۋدى.

[V4]
 /// جاۋىن جاۋىپ، سۋ كوتەرىلىپ تاسىدى! ///
 ٴبىراق، ٴۇي قۇلامادى!

[V5]
 /// ۇيلەرىڭنىڭ نەگىزى ٴماسىح بولسىن! ///
 جاۋىن جاۋماسىن!

[V6]
 /// جاۋىن جاۋىپ، سۋ كوتەرىلىپ تاسىيدى! ///
 سوندا ٴۇي قۇلاماس!</lyrics>
<key>D</key>
<hymn_number>224</hymn_number>
</song>