<?xml version="1.0" encoding="UTF-8"?><song><author>نۇر</author>
<lyrics>[V1]
.    Em
 //   تاڭداپ وتكەن اۋەلى باستان،
.Am                     Em
 كۇنالارمەن اجىراتىپ تاستاپ
.Am                       Em  G
 سەن تاڭداعان جۇلدىز مەن ەدىم و۔و۔وي!
.F                 Em
 ساعان كۋا بولادى اسپان!  //

[C1]
.      Am          Em
   //   جاساما كۇنا ەي حالقىم،
.  Am            Em
    جاقىنداپ قارا قۇدايعا!
.  Am         Em    G
    سوزدەرىمە قۇلاق سال،
.  F            Em
   قۇداي ٴسوزىن ايتامىن!  //

[V2]
 //  جاقىن بارىپ جانىڭا حالقىم،
 قۇداي ٴسوزىن جەتكىزەيىن،
 تىڭدا مەنىڭ ٴسوزىمدى حالقىم، و۔و۔وي!
 ازاتتىعىمدى بىلدىرەيىن!  //

[V3]
 //  تىڭدا، تىڭدا، تىڭداڭىزدار،
 قۇداي ٴسوزىن ايتايىن ۇيقاس
 ولەڭمەنەن ايتايىن دوستار، و۔و۔وي!
 قۇتقارۋشى بولادى يسا!  //</lyrics>
<key>Em</key>
<title>جاساما كۇنا ەي حالقىم</title>
</song>