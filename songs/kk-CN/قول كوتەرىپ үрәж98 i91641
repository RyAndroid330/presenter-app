<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>98</hymn_number>
<title>قول كوتەرىپ ҮРәж98</title>
<lyrics>[V1]
. E           B      A
 قول كوتەرىپ ماداقتايىق،
.    E              A
 بىزگە كەلگەن يسا ٴماسىح،
. E                 B       F
 تەك سەن عانا مەنى باسقارماقسىڭ.

[C1]
.   E                B7
   دارىپتەيمىن سەنى تەك،
.   A               E
   بوس ويىمدى لاقتىرىپ.
.   E                B7
   جانىما كەلشى، كيەلى رۋح،
.     A              E
   بولەپ وزىڭە تولتىرشى.
.    E            A         B7
   ٴبىر وزىڭە ارنايمىن ٴومىرىمدى.</lyrics>
<key>E</key>
</song>