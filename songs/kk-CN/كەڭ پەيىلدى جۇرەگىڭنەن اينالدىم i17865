<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Dm
 ۇلى سەنىڭ كيەلى عوي،
.      Gm
 اتىڭ ادال!
.                 C7
 باس يەمىن ٴيىلىپ كەپ،
.         F  A
 تاق الدىندا!
 ٴتاڭىر سەنىڭ مەيىرىمىڭە بولەنىپ،
 قۋان اكە وتىرمىن مەن قاسىڭدا.

[C1]
   // كەڭپەيىلدى جۇرەگىڭنەن اينالدىم،
   راقىمڭمەن تۇنىپ تۇرعان بويىمدى،
   قۋانىش پەن ٴۇمىت بەرىپ ەرتەڭگە
   جارىلقايمىن سەنىڭ عاجاپ اتىڭدى //

[V2]
 تاڭ اتپاستان اسىعامىن وزىڭە،
 قادايمىن مەن ٴجۇزىمدى مەن كوزىڭە
 رۋحىنا كيەلى شولدەپ جەتەمىن
 كەتپەشى سەن، كەتپەشى سەن قاسىمنان

[C2]
   // كۇنا ٴىستى مويىندايمىن وزىڭە،
   جاسىرمايمىن ايتامىن بار ٴسوزىمدى.
   ٴسۇرتىپ تاستاپ كوزدەن اققان جاسىمدى،
   قۇشاقتادىڭ كەشتىم دەگەن ەسىمدە. //</lyrics>
<key>F</key>
<title>كەڭ پەيىلدى جۇرەگىڭنەن اينالدىم</title>
<author>نۇر</author>
</song>