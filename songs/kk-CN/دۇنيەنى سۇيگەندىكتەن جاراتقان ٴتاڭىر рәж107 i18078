<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>107</hymn_number>
<title>دۇنيەنى سۇيگەندىكتەن جاراتقان ٴتاڭىر РӘЖ107</title>
<key>C</key>
<lyrics>[V1]
.Am
 دۇنيەنى سۇيگەندىكتەن،
.        Dm
 جاراتقان ٴتاڭىر،
.G                           C
 كۇناكار بۇل دۇنيەگە ۇلىن بەرگەن!
.Am                       Dm
 توگىلگەن قانىمەن قۇتقارىپ ٴبىزدى،
.G                              C
 ماڭگىلىك ٴومىردى، بىزگە سيلىق ەتكەن!

[C1]
   دۇنيەنىڭ كۇنالارىن مويىنىنا الىپ،
   ول سەنىڭ كۇناڭ ٴۇشىن، قۇربان بولعان!
   بۇگىن دە سەنى كۇتەدى، قۇشاعىن جايىپ،
   قابىل ال، ونىڭ سيىن بەرگەن ساعان!

[V2]
 كۇنانىڭ تۇتقىنىندا، ٴبىز جاساپ كەلدىك،
 ازعىرىپ كۇنالارعا جەتەلەنىپ،
 قولىمىزبەن جاساعان جاماندىق ٴۇشىن،
 ايىپسىز، يسانىڭ قولى شەگەلەنگەن!

[V3]
 ول سەنىڭ جۇرەگىڭدى تەبىرەنتكەندە،
 قانشا رەت تاستامايمىن دەدىڭ، كۇنالاردى!
 قۇمارلىق كۇنالارى ەلەستەگەندە،
 كەتتىڭ سەن كۇنا تولعان شەكسىز شولگە!</lyrics>
</song>