<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<author>ئې. شارыپانوۋا, ئا. گونچاروۋ</author>
<key>D</key>
<lyrics>[V1]
.  Bm Em     Bm   F#
 سيىنۋدى ۇيرەتشى ٴتاڭىرىم،
.  F#7          Bm
 كٸەلى زاڭىڭدى ساقتايىن.
.        G   A     A7    D
 //  تاكاپپار جۇرەگىمدى وزگەرتشى،
.     F#m   F#        G Bm
 يماندى بولايىن ٴاردايىم.  //

[V2]
 ورىن ال ماڭگىلىك جۇرەگىمنەن،
 كيەلى رۋحىڭمەن باسقارىپ.
 //  ماداقتايىن سەنى جان۔دۇنيەممەن،
 وسيەتتەرىڭدى ورىنداپ.  //

[V3]
 تازارىپ كيەلى قانىڭمەنەن،
 جۇرەگىمدى تازا ساقتايىن.
 //  شىنايى سۇيەيىن جاقىنىمدى،
 كيەلى اتىڭدى داڭقتايىن.  //</lyrics>
<title>سيىنۋدى ۇيرەتشى ٴتاڭىرىم РӘЖ22 ҮРәж180</title>
</song>