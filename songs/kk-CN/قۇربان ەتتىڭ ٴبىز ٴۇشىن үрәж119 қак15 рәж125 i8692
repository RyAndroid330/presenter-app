<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<author>شىنتەمىروۆ ٴابىلحايىر</author>
<lyrics>[V1]
.   Am                  F
 قۇربان ەتتىڭ ٴبىز ٴۇشىن،
.   G        Am
 قاسيەتتى جانىڭدى.
.    F
 توگىپ كەتتىڭ مەن ٴۇشىن،
.     G          Am
 ٴوز كيەلى قانىڭدى.

[C1]
.     Am              F
   // كۇنالاردان قۇتقارىپ،
.  G              Am
   ماڭگى ٴومىر سيلادىڭ.
.    Am          F
   جان۔تانىممەن ۇمتىلام،
.     G          Am
   ۇسىنعاندا باعىڭدى.  //

[V2]
 سەن الەمدى جاراتقان
 ٴبىر قۇدايدىڭ ۇلىسىڭ
 شىنايى ٴومىر بەرەتىن،
 ٴمولدىر بۇلاق كوزىسىڭ.

[C2]
   // و، ٴتاڭىرىم جاساعان،
   پاتشالىعىڭ جاقىنداپ،
   وسى الەمگە جارقىراپ،
   توگىپ تۇرعان نۇرىسىڭ.  //

[V3]
 جانعا ٴدارۋ بەرەتىن،
 جۇرەككە جىلۋ توگەتىن.
 جاراتقان ٴوزىڭ پەندەڭە
 كوڭىلىندى بولەتىن.

[C3]
   // قانداي شەكسىز ماحاببات
   قانداي ىستىق قۇشاعىڭ.
   قۋانعاندا وزىڭە،
   قياعا سامعاپ ۇشامىن.  //

[V4]
 نۇرىڭدى توكشى حالقىما،
 قاراڭعىدان قۇتقارشى،
 شىندىق تاپسىن جولىڭنان
 كۇناسىنان ارىلتشى.

[C4]
   // جاراتقان ٴبىزدىڭ يەمىز،
   ٴتاڭىرىمىز باعۋشى.
   تار جولمەنەن جەتەلەپ،
   ماڭگى ومىرگە اپارشى.  //</lyrics>
<key>C</key>
<title>قۇربان ەتتىڭ ٴبىز ٴۇشىن ҮРәж119 Қак15 РӘЖ125</title>
</song>