<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>182</hymn_number>
<key>Bb</key>
<lyrics>[V1]
.       Gm
 قۋانىڭدار دوستارىم،
.  Cm
 ماداقتاڭدار ٴتاڭىردى.
.   Bb
 // يسانى جەرگە جىبەرىپ،
. Cm
 سىيلاعان ماڭگى ٴومىردى. //

[V2]
 شاتتانىڭدار باۋىرلار،
 شىرقاتىپ اسەم انمەنەن،
 // اشىلدى بىزگە قۇپيا،
 اتا۔باباڭ سەزبەگەن. //

[V3]
 تاماشاعا بولەنسىن
 تابيعات بىتكەن ٴسۇيسىنىپ،
 // يسانىڭ ٴسوزىن ەستىسىن
 بارلىق حالىق قۇلشىنىپ. //

[V4]
 اقيقاتتى تانىسىن،
 تۇنەكتەگى جۇرتشىلىق.
 // اشىلسىن ٴبارى پەردەنىڭ،
 ارايلاپ اتسىن كۇن شىعىپ. //

[V5]
 ويان باۋىر، قالعىما.
 جىگەرىڭە جىگەر قوس.
 // قۇدايدىڭ بەرگەن بۇيرىعىن
 ورىنداماي جۇرمە بوس. //</lyrics>
<title>قۋانىڭدار دوستارىم РӘЖ182</title>
</song>