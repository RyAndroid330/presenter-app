<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G                    Em
 جۇرەمىن سەنىڭ مەن جولىڭمەن
.C                     D7
 باعىتپەن قۇدايدىڭ كورسەتكەن.
.G                   Em
 جاقىن تانۋعا سەنى ٴتاڭىر،
.C                   D
 رۋحىڭا تولتىر، كيەلى رۋح

[B1]
.   Em      C    Am         D       G
   ٴومىرىڭدى پاش ەتتىڭ، قاسٸەتتى قانىڭمەن
.   Em           C           Am        D
   ٸسا باعىت بەر، شىندىق جول يسا يە كورسەت!

[C1]
.  C    G       D7               Em
   سەن دەپ ٴومىر سۇرەم ساعان عانا ەرەم،
.  C    G             Am        D
   سەنىڭ ىزگى ٴسوزىڭ تارالسىن الەمگە
.  C       G            D7        Em
   جەڭىمپاز بولام مەن، كەلەدى وسى كۇن،
.  C        D                G
   ارتقا شەگىنبەيمىن ۔ ۇلى پاتشام</lyrics>
<title>جۇرەمىن سەنىڭ مەن جولىڭمەن</title>
</song>