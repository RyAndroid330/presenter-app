<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>88</hymn_number>
<author>قابدەشوۆ رۋسلان, نەٸزۆەستەن</author>
<title>كوك اسپان كۇتەدى مەنى</title>
<key>Em</key>
<lyrics>[V1]
.Em               B
 كوك اسپان كۇتەدى مەنى
. B                Em
 قۋانىشتىڭ بولماي شەگى
. Em                B
 كەزدەسەم ٴتاڭىرىم ٸسامەن
. B                Em
 كيەلى رۋحپەن، اكەممەن.

[C1]
.       E              Am
   // گۇل ٴتاجى، ارينە گۇل ٴتاجى
.     D                G
   بەرەتىن سيلىعى اكەمنىڭ.
.  Em                      Am
   گۇل ٴتاجى، ارينە گۇل ٴتاجى
.    B                 Em
   بەرەتىن سيلىعى اكەمنىڭ./
   //  اللەلۋيا! اللەلۋيا! ////  ////

[V2]
 بۇل جۇماقتىڭ قالاسى شاشباۋىن
 اينالا پەرىشتە تولعان گۇل.
 جارقىراپ جۇزدەرى دوستاردىڭ
 يسانىڭ كەلۋىن كۇتىپ تۇر.

[V3]
 كەزدەسەم پەتىرمەن، جوحانمەن
 جانە كوپ كيەلى باۋىرمەن.
 قۇشاقتايد(ى) مەنى ولار جاقىن كەپ،
 قۋانىش تاۋسىلمايد(ى) تاسىپ كەڭ.</lyrics>
</song>