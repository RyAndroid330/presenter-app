<?xml version="1.0" encoding="UTF-8"?><song><author>هِبِر، رِگِنَلد (١٧٨٣-١٨٢٦), ديكِس، جُهن بَككهُس (١٨٢٣-١٨٧٦)</author>
<hymn_number>86</hymn_number>
<key>C</key>
<lyrics>[V1]
. C                    G
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
. F          C
 قۇدىرەتتى قۇداي.
. C           G
 ەرتە تۇرىپ قۋانىپ
.             C
 ٴان سالامىز وعان:
. C                    G
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
. F          C
 جاناشىر دا كۇشتى.
. F           G             C
 ۇشبىرلىك قۇداي ۔ ماڭگى ماحاببات.

[V2]
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
 قۇرمەتپەن تابىنىپ،
 كوكتە كيەلىلەر داڭقتاپ تاعزىم ەتەدى.
 پەرىشتەلەر ٴبارى تىزەسىن بۇگەدى،
 ماڭگىلىك يەسى مەيىرلى، يگى

[V3]
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
 تىلسىم قۇپيالى.
 كورە الماس ولىلەر اسقاق داڭقىن ونىڭ.
 ول عانا تەك جالعىز، ۇلى قۇداي بيىك
 عاجاپ، مىقتى، پاك، تازا، قاسيەتتى.

[V4]
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
 قۇدىرەتتى پاتشا،
 قۇداي اتىن داڭقتايدى
 اسپان، تەڭىز، جەردە.
 كيەلى، كيەلى، كيەلى ٴتاڭىر يە ۔
 ٴبىز دە دارىپتەيمىز
 ماڭگى قۇدايدى داڭق پەن ماداقپەن.</lyrics>
<title>كيەلى، كيەلى ҮРәж86</title>
</song>