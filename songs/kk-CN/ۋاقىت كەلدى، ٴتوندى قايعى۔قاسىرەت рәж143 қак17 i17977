<?xml version="1.0" encoding="UTF-8"?><song><author>الىمبەكوۆ عالىمجان, جاڭقاباەۆا نۇرسۇلۋ</author>
<hymn_number>143</hymn_number>
<key>F</key>
<lyrics>[V1]
.     Dm
 ۋاقىت كەلدى، ٴتوندى قايعى۔قاسىرەت،
.Dm               Gm
 تەمىر شەگە سۇيەكتەن دە ٴوتىپ ەدى.
.     A7                  Dm
 // يسا يەم، قانداي جازا شەگىپ ەڭ؟
. Gm            A7     Dm
 كوز جاسىمدى توقتاتارعا كۇشىم جوق. //

[V2]
 جىلا ەلىم، جىلاي ٴتۇسشى، قازاعىم،
 يسا يەم ٴتانىن بەردى ٴبىز ٴۇشىن.
 // ازاپ شەكتى، توكتى قانىن، ول ۔ شىندىق،
 بار ماعىنا وسىندا ەكەن، ٴبىز بىلدىك. //

[V3]
 كەشىر ٴبىزدى، اينالايىن قۇدايىم،
 ساعان ەلىم تاعزىم ەتۋگە دايىن.
 // جار سالامىز قازاق دەگەن ەلىمە،
 يسا كەلدى كەڭ دالامنىڭ تورىنە. //</lyrics>
<title>ۋاقىت كەلدى، ٴتوندى قايعى۔قاسىرەت РӘЖ143 Қак17</title>
</song>