<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>89</hymn_number>
<author>زافار</author>
<key>Em</key>
<lyrics>[V1]
.Em         C
 كوكتەگى اكەمىزگە بولسىن دەيمىن ماداق!
.  D                   B             Em
 ونىڭ مەيىرىمدىلىگى بىزبەن بىرگە بولماق.
.Em         C
 كوكتەگى اكەمىزگە بولسىن دەيمىن ماداق!
.  D                B            Em  D/F#
 ونىڭ راقىمدىلىعى بىزگە جەتىپ تۇرماق.

[C1]
.      G            D
   // سان۔سالتانات ٸەمىزگە!
.   C         Em     D/F#
   بار ماقتاۋ قۇدايعا!
.  G        D
   كيەلى رۋحىن بىزدەرگە
.  C              B7
   جار بولسىن، اۋمٸن! //

[V2]
 // قۇتقارۋشىم ساعان دا بولسىن دەيمىن ماداق!
 سەندە عانا سايا تاپتى كۇناكار ۇرپاق. //

[V3]
 // كيەلى رۋح ساعان دا بولسىن دەيمىن ماداق!
 ومىردەگى شىندىق جولدى كورسەتتىڭ انىق. //

[B1]
.  Em               C
   كوكتەگى اكەمىزگە بولسىن دەيمىن ماداق،
.  Em                  C
   قۇتقارۋشىم ساعان دا بولسىن دەيمىن ماداق،
.  Em                  C
   كيەلى رۋح ساعان دا، بولسىن دەيمىن ماداق!</lyrics>
<title>كوكتەگى اكەمىزگە بولسىن دەيمىن ماداق! МЖЖ77 РӘЖ4</title>
</song>