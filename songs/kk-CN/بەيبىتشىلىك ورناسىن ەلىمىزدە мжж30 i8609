<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>30</hymn_number>
<lyrics>[V1]
.F#                   D#m
 بەيبىتشىلىك ورناسىن ەلىمىزدە،
.B                      C#
 بارلىق ۇلتتار بىرىگىپ جەرىمىزدە.
.F#                       D#m
 تۋىسقانداي ٴومىر ٴسۇر باۋىرلارىم،
.B                        C#
 دوستىق بولسىن ماڭگىلىك تورىمىزدە.

[C1]
.  F#           D#m
   نيەتىمىز اق بولسىن،
.  B               C#
   حالقىمىزعا باق قونسىن.
.  F#             D#m             A#m B C#
   باتا بەرىپ ساق قىلسىن جاراتقان يە.
.  F#             D#m
   ۇمىتپاڭدار دوستارىم،
.  B              C#
   ۇلكەن كىشى جاستارىم.
.  F#                D#m     A#m    B C#
   بۇل ومىردە شىندىق جول يسا ماسىحتە.

[V2]
 بىرىگۋمەن جەڭەيىك جاماندىقتى،
 كۇنالارعا تەڭەيىك ناداندىقتى.
 ٴبىلىم الىپ، كوركەيىپ جەتىلەيىك،
 سوندا عانا بىلەمىز بار شىندىقتى.

[V3]
 قالايدى ول وسى جولدا جۇرگەنىڭدى،
 قۋانىشقا كەنەلىپ كۇلگەنىڭدى.
 وسيەتتەرىن ورىنداپ قىزمەت ەتىپ.
 ادال بولىپ ۇزاق ٴومىر سۇرگەنىڭدى.</lyrics>
<key>F#</key>
<title>بەيبىتشىلىك ورناسىن ەلىمىزدە МЖЖ30</title>
</song>