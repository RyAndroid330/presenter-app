<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>103</hymn_number>
<title>ماداقتا يسانى МЖЖ103</title>
<lyrics>[V1]
.   D  A    G  A
 // ماداقتا يسانى،
.D  A    G  A
 ماداقتا يسانى!
.  D          G
 ٴار كۇندە، ٴار كۇندە
.D    A          D
 ونىڭ اتىن ماداقتا! //
. Bm
 ەش نارسەدەن قورىقپا،
.A
 يسا بىرگە بولادى.
.G           A   Bm
 جەڭىسكە سەن يە بولاسىڭ!

[C1]
.   G    A     Bm
   قۇدايدى ٴبىلۋ باقىت،
.   G    A             D
   قۇدايمەن تاتۋ بولۋ باقىت.
.   G    A    Bm
   قۇدايمەن بولۋ باقىت،
.   G    A             D
   قۇدايمەن تاتۋ بولۋ باقىت.</lyrics>
<key>D</key>
</song>