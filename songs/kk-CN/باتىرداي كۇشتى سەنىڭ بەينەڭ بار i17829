<?xml version="1.0" encoding="UTF-8"?><song><author>نۇر</author>
<title>باتىرداي كۇشتى سەنىڭ بەينەڭ بار</title>
<key>D</key>
<lyrics>[V1]
.   Bm             D
 //  باتىرداي كۇشتى سەنىڭ بەينەڭ بار،
.Em             F#             Bm
 گۇلدەن دە نازىك، اكە سەنىڭ مىنەزىڭ،
.Bm              D
 سەن ٴۇشىن قىمبات بۇكىل ادامزات،
.Em                     F#         Bm
 قىمبات قوي اكە، سەنىڭ ٴبىزدى سۇيگەنىڭ! //

[C1]
.     Bm    Em       A7           D
   //  جارىلقاۋدى يسا ماسىحپەن بەردىڭ،
.       Bm          Em      F#           Bm/B7
   جۇرەكتەردى تولتىردىڭ، قۋانىش پەن العىسقا!
.       Em       A7           D
   جارىلقاۋدى يسا ماسىحپەن بەردىڭ،
.       Bm          Em        F#          Bm
   جۇرەكتەردى تولتىردىڭ، جارىلقاۋ مەن باتاعا! //

[V2]
 // العىس ايتامىز اكە وزىڭە،
 باتاڭدى بەرىپ، جىبەردىڭ وسى ومىرگە!
 جولدى تۇزەتىپ، وزىڭە قاراي،
 بالالارىڭدى جەتەلەيسىڭ ماڭگىگە! //</lyrics>
</song>