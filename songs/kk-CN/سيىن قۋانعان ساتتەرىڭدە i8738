<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.C#m      G#         C#m
 سيىن قۋانىشتى كەزىڭدە
.C#m      G#   C#m
 قيىن شاقتاردا سيىن.

[C1]
.     F#m        B       E  C#m
   // سيىن باقىتسىزدىق تونگەندە،
.  F#m       G#7      C#m
   قىسىلعان كەزدە دە سٸىن. //

[V2]
 سيىن اشۋدى جەڭگەندە.
 قاۋىپ تونگەن كەزدە سيىن.

[C2]
   // سۇراپ، جاقىنىڭ ٴۇشىن سيىن.
   دۇشپانىڭ ٴۇشىن سيىن. //

[V3]
 سيىن السىزدەنگەن كەزىندە.
 مەنمەندىگىڭ ٴۇشىن سيىن.

[C3]
   // سيىن جاقىنىڭنان ايىرىلعاندا.
   جاڭا ٴومىر ٴۇشىن سيىن! //

[V4]
 سيىن سىن ساعاتى قەلگەندە،
 وزىڭدى۔ٴوزىن جەنگەندە.

[C4]
   // سيىن بويىندى كۇنا جايلاسا،
   قۇداي كەشىرسىن دەپ سيىن. //</lyrics>
<title>سيىن قۋانعان ساتتەرىڭدە</title>
<hymn_number>153</hymn_number>
</song>