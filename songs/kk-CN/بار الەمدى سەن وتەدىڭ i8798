<?xml version="1.0" encoding="UTF-8"?><song><title>بار الەمدى سەن وتەدىڭ</title>
<lyrics>[V1]
.G        D        Em
 بار الەمدى سەن وتەدىڭ
.        Bm             Csus2
 بەردىڭ ماحاببات پەن جارىق
.           Am7         D
 تاستاي جۇرەكتى ٴجىبىتىپ
.           D7
 سەن ٴۇمىت بەردىڭ

[V2]
 سەنىڭ الدىڭدا ٴبىز تۇرمىز
 ٴبارىمىز ساعان قىمباتپىز
 بارىنە ساعان ريزامىز
 و، قۇدايىم

[C1]
.        G               D
   ماداقتايمىن سەنى تابىنامىن
.       Em7              Bm
   ماداقتايدى سەنى ماڭگى ەلىم
.   C                G
   كۇشىڭ شەكسىز قۇدايىم
.      Am7                 D
   راقىمىڭ ۇرپاقتان ۔ ۇرپاقتارعا</lyrics>
<key>G</key>
<aka>الەمدى سەن قۇتقاردىڭ</aka>
</song>