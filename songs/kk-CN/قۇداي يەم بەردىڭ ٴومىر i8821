<?xml version="1.0" encoding="UTF-8"?><song><author>خj ئاكا</author>
<title>قۇداي يەم بەردىڭ ٴومىر</title>
<lyrics>[V1]
.   Em            D          C                 Em
 // قۇداي يەم، بەردىڭ ٴومىر، سۇيگەندىكتەن، ٴوز پەندەڭدى! //
.   Em             D          C          Em
 // الايدا ٴبىز، ناداندىقپەن، ۇمىتتىق، مەيىرىمىڭدى! //

[C1]
.  Am          Em       C           D
   كەلدى يسا، ارامىزعا، نۇرلاندىرىپ تۇنەكتى!
.   Am              Em          C        D
   ٴولدى ٴماسىح، بىزدەر ٴۇشىن ۔ كيەلى، قانىن توكتى!

[V2]
 // قارعىس، كۇنا اقتالدى، ٴماسىح ۔ يسا قانىمەن! //
 // ماڭگىلىككە، جەتىستىك، راببىمىزدىڭ، قۇربانىمەن! //</lyrics>
<key>G</key>
</song>