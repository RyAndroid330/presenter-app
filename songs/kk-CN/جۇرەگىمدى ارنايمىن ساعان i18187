<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
.    Eb
 /// جۇرەگىمدى ارنايم ساعان،
.        Gm                   Bb
 بار جانىممەن مەن ۇمتىلام ساعان! ///
.            F
 ٸ۔سا ۇلىسىڭ!(...ٴتىرىسىڭ! سەن كيەلىسىڭ!)

[P1]
.           Cm
   ماحابباتىڭدى توكشى
.                   Gm
   جاڭبىر ىسپەتتى توگىلشى
.                 Eb
   تولتىرشى ٴبىزدى
.                        F
   ٴوز رۋحىڭمەن تولتىرشى!
   كۇنامدى سەن كەشىردىڭ
   ٴوز باۋىرىڭا الدىڭ
   ريزامىن ساعان
   شىن جۇرەكتەن ريزامىن!

[C1]
.     Cm      Gm      Eb     F
   يسا ۇلىسىڭ! يسا ۇلى قۇداي!
.   Cm       Gm       Eb     F
   ٸسا ٴتىرسىڭ! يسا ٴتىرى قۇداي!
.   Cm            Gm     Eb       F
   ٸسا كيە۔ٴلىسىڭ! يسا كٸ۔ەلى قۇداي!</lyrics>
<title>جۇرەگىمدى ارنايمىن ساعان</title>
<author>جانات كۋساينوۆا</author>
</song>