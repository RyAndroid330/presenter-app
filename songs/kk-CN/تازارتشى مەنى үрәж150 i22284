<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>150</hymn_number>
<title>تازارتشى مەنى ҮРәж150</title>
<aka>ورىنداعىم كەلەدى ەركىڭدى</aka>
<lyrics>[V1]
.A#m           F#
 ورىنداعىم كەلەدى ەركىڭدى،
.  D#m             F7
 تازارتشى مەنى، وتىنەم، قانىڭمەن!
.A#m             F#
 كورگىم كەلەدى سەنىڭ داڭقىڭدى،
.   D#m           F7
 تولتىرشى مەنى ماحابباتىڭمەن!

[C1]
.  A#        D#m               F7
   سەنسىز ەشبىر بىلمەيمىن جولدى،
.             A#m            G#   F#
   قالاي ٴومىر سۇرەم، قايدا بارام!
.           D#m         F7
   وتىنەم ۇيرەتشى ٴسۇيۋدى،
.              A#m
   سەن سۇيگەندەي!

[B1]
.       F#       C#   D#m     A#m
   // تازارتشى مەنى ٴوز قانىڭمەن!
.     F#      C#   D#m     A#m
   تايدىرما مەنى ٴوز جولىڭنان! //
.    F#         D#m
   تازارت ٴبىزدى!
.    A#m
   تازارت ٴبىزدى!</lyrics>
<key>F</key>
</song>