<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>158</hymn_number>
<key>A</key>
<lyrics>[V1]
.     A             F#m
 تابيعاتىڭمەن، ماحابباتىڭمەن،
.     D                 E
 ٴومىرىمدى مەنىڭ باۋراپ الدىڭ سەن
 اياۋلى اكەم، راقىمىن توككەن
 نۇرعا تولى ٴجۇزىڭ كورىكتى نەتكەن.

[C1]
.         A             F#m
   ٴان ايتامىن مەن ساعىنىشىمدى باسىپ
.         D            E
   ٴان ايتامىن مەن قۋانىشىم تاسىپ
   ٴان ايتامىن مەن الاقانىمدى جايىپ
   ٴان ايتامىن مەن جۇرەك ٴۇنىن قوسىپ.</lyrics>
<title>تابيعاتىڭمەن، ماحابباتىڭمەن</title>
</song>