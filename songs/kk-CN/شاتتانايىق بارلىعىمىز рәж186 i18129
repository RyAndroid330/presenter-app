<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>186</hymn_number>
<title>شاتتانايىق بارلىعىمىز РӘЖ186</title>
<lyrics>[V1]
.    D          Bm
 //   شاتتانايىق بارلىعىمىز،
.Em          A
 يسا ٴتاڭىر ۔ ان۔جىرىمىز.  //

[C1]
.      D
   //   قۇدىرەتتى قۇدايىم،
.  Bm
   ماڭگىلىكتىڭ قۇدايى.
.  Em
   قۇربان ەتتىڭ ولىمگە،
.  A
   كۇنام ٴۇشىن ۇلىڭدى.  //

[V2]
 //  بۇل ومىردە مەن اداستىم،
 سەن مەنى ٴسۇيدىڭ، تاڭداپ الدىڭ.  //</lyrics>
<key>D</key>
</song>