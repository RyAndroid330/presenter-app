<?xml version="1.0" encoding="UTF-8"?><song><title>ٴتاڭىردى ماداقتايىق</title>
<lyrics>[V1]
.  Bm       G
 كەلىڭدەر، دوستارىم
. A       Bm
 ٸەنى، ماداقتايىق
.          G
 قۋانىپ، ٴان ايتىپ
.   A            Bm
 بي۔بيلەپ، جىرلايىق

[C1]
.   G       A     Bm
   كيەلى ٴبىزدىڭ قۇداي
.    G     A
   ۇلى ٴبىزدىڭ ٴتاڭىر
.   G         A       Bm
   ماڭگىلىك ٴبىزدىڭ پاتشانىڭ
.     G    A     Bm
   ەسىمى ماداقتالسىن

[P1]
   // رەپ
.  G
   جارتاستاي بەرىك
.  A
   قورعانىمسىڭ سەن
   شىن جۇرەكتەن وعان
.  F#               Bm
   سەنىم ارتامىن مەن
   قۇتقارۋشى قۇدايىم
.  A
   جالعىز ٴوزىڭسىڭ سەن
   ماڭگىلىك وزىڭە
.  F#               Bm
   العىس ايتامىن مەن //

[V2]
 بارلىق ۇلتتار، قۇدايعا
 قول سوعىڭدار، دارىپتەڭدەر
 شاتتىق ۇنمەن، داۋىستاڭدار
 يەنى، ماداقتاڭدار

[P2]
   رەپ
   قول سوعىپ، ٴتاڭىردى ماداقتايىق
   بي۔بيلەپ، ٴان سالىپ، شاتتانايىق
   ٴتاڭىردى ماداقتاۋدان، جالىقپايىق
   قانە دوستار، تاڭىردەن، كۇش الايىق</lyrics>
<key>Bm</key>
<author>مولدابەكوۆ مۇسا</author>
</song>