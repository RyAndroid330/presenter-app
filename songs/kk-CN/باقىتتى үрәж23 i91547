<?xml version="1.0" encoding="UTF-8"?><song><title>باقىتتى ҮРәж23</title>
<lyrics>[V1]
. D              G
 باقىتتى سەنىڭ ۇيىڭدە،
.  G            D
 ماداقتاعان تەك سەنى.
.  D              G
 باقىتتى جۇرەگىن ارناپ،
. Em          A  D
 باعىتتاعان ٴار ادام.
. D          D     A
 كۇش۔قۋات تولتىراسىڭ،
.       G       A
 كەزدەسكەنشە وزىڭمەن.

[V2]
. D       A   Bm       G
 تىڭداشى، و، قۇداي يەمىز،
. D       A      Bm
 جارىلقاشى ٴبىزدىڭ جەردى،
.G
 وتىنەمىز.

[B1]
.         D       A
   //// كٸەلىسىڭ سەن!
.    D       A
   كٸەلىسىڭ سەن!
.    B        G
   كٸەلى قۇدايسىڭ! ////</lyrics>
<key>D</key>
<author>هِللسُنگ</author>
<hymn_number>23</hymn_number>
</song>