<?xml version="1.0" encoding="UTF-8"?><song><author>دُن مُِن, پَُل كيلِ</author>
<hymn_number>78</hymn_number>
<title>يسا ۔ ٴتاڭىر، پاتشامىز ҮРәж78</title>
<key>G</key>
<lyrics>[V1]
.G             Em
 يسا ۔ ٴتاڭىر، پاتشامىز،
.C         D
 كەلشى وسىندا!
.Em               Bm
 تاعىڭنان، ورىن الشى،
.C        Am      D
 ماداقتى، قابىل الشى!

[C1]
.  Em     Bm         Em
   سيىنام ساعان ۔ قۇتقارۋشىم،
.  C       D          G   Em
   ماداقتايمىن سەنى ۔ ماسىعىم،
.  C         D        G    Em
   پاتشا بوپ كەلشى، تاڭىر۔ٸسا،
.        C         D       G
   قازىر كەلشى، باسقارا كورشى!</lyrics>
</song>