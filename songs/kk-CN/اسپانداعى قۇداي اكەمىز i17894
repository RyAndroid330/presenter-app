<?xml version="1.0" encoding="UTF-8"?><song><title>اسپانداعى قۇداي اكەمىز</title>
<lyrics>[V1]
.Dm        C         Dm
 // اسپانداعى قۇداي اكەمىز،
.Bb         C        Dm
 سەنىڭ اتىڭ كيەلى بولسىن
 سەنىڭ پاتشالىعىڭ كەلسىن
 يسانىڭ اتىنان اۋمين! //

[C1]
   // سەن نۇرىڭدا بىزگە ازىرلەپ
   بەرگەنىڭ ٴۇشىن راحمەت يەم!
   سەن شىندىقسىڭ، تار جولسىڭ يسا
   سەن ماڭگى ٴومىرسىڭ! //</lyrics>
<key>F</key>
<author>نۇر</author>
</song>