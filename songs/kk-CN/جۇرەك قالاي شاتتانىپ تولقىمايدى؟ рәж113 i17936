<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.      Bm                    Bm
 جۇرەك قالاي شاتتانىپ تولقىمايدى؟!
.D                 Em
 ىزگى حابار تانىتسا شىن قۇدايدى.
.     Em                     Bm
 //  وسيەتى ٴتاڭىردىڭ ٴدانىن ەكسە،
.     Em                F#      B
 جايلاپ ٴوسىپ، ول نەگە جايقالمايدى؟!  //

[V2]
 ىزگى حابار ۔ ىزگىلىك قاينار كوزى،
 ول ۔ قۇدايدىڭ يسا اتتى ٴتىرى ٴسوزى.
 //  ادام اتا، حاۋا انا بويعا ەنگىزگەن،
 بار كۇنادان قۇتقارار سونىڭ ٴوزى.  //

[V3]
 قۇداي ەركىن مەن قالاي تىڭدامايىن،
 مەنىڭ جانىم شىندىققا قۇمار ٴدايىم.
 //  كۇش۔قۋات بەر، جەتەلە رۋحىڭمەنەن،
 بولاتتايىن بەرىك بوپ شىڭدالايىن.  //

[V4]
 سەنىڭ اتىڭ ٴتاڭىرىم، دارىپتەلسىن!
 «پاتشالىعى ٴتاڭىردىڭ جاقىن» دەپسىڭ.
 //  تاراتايىن انىممەن حابارىڭدى،
 تاڭداۋلىڭدى مىڭ۔مىڭداپ الىپ كەلسىن.  //</lyrics>
<title>جۇرەك قالاي شاتتانىپ تولقىمايدى؟! РӘЖ113</title>
<hymn_number>113</hymn_number>
</song>