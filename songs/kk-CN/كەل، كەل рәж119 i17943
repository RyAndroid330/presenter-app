<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<title>كەل، كەل! РӘЖ119</title>
<key>D</key>
<lyrics>[V1]
.  D       A7      D
 كەل، كەل! كەل، كەل!
.Em         D
 سەنى يسا بىلەدى، كەل، كەل!
.      G           A7       D         Bm
 // قۇتقارۋ تەك تىلەگى، جۇرەكتى اش كىرەدى،
.       Em       A7    D      D
 بىرگە ٴومىر سۇرەدى، كەلشى، كەلشى. //

[V2]
 كەل، كەل! كەل، كەل!
 نازىك ٴۇنىن ەستىشى، كەلشى.
 // ٴسوزىن تىڭدا جالىقپا، شاقىرادى جارىققا
 ٴوز جولىڭدى انىقتا، كەلشى، كەلشى. //

[V3]
 كەل، كەل! كەل، كەل!
 تىنىش ومىرگە ەنشى، كەلشى.
 // قۇتقارۋشىعا سەنشى، قولىڭدى وعان بەرشى،
 راقىمدىلىعىن كورشى، كەلشى، كەلشى. //</lyrics>
</song>