<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.  C        G
 يساعا ٴبارىن بەرەمىن،
.F      G7  C
 راقىمىنا سەنەمىن،
 سوزدەرىن جۇرەكتە ساقتاپ،
 جەتەگىنە ەرەمىن.

[C1]
.   C        F     G         C
   ٴبارىن ارنايىن، وتتاي جانايىن،
.      F              G7        C
   جالعىز ساعان، قۇتقارۋشىم، ٴبارىن ارنايىن.

[V2]
 ارنايمىن ساعان ٴبارىن دە،
 جۇرەگىمدە مەكەندە،
 راقىمىڭ مەن مەيىرىمىڭە،
 تولسىن سانا، سەزىمدە.

[V3]
 ماسىحكە ٴبارىن بەرەمىن،
 تاڭىرىممەن بىرگەمىن.
 مويىنسۇنىپ، ٴۇمىت ارتىپ،
 باۋىرىنا ەنەمىن.

[V4]
 اكە، الدىڭا كەلەمىن،
 سيىمدى اكەلەمىن،
 تىنىشتىق بەردىڭ جۇرەككە،
 كۇن سايىن اندەتەمىن.</lyrics>
<title>يساعا ٴبارىن بەرەمىن РӘЖ84</title>
<hymn_number>84</hymn_number>
</song>