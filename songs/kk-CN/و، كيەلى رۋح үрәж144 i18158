<?xml version="1.0" encoding="UTF-8"?><song><author>اقتانجانوۆ س., بولاتوۆ ق.</author>
<hymn_number>144</hymn_number>
<key>C</key>
<lyrics>[V1]
.C       Am
 و كيەلى رۋح
.F           G
 كەلشى مەنىڭ تورىمە
.C           Am    F        G
 تاعدىرىمدى بەردىم سەنىڭ ەركىڭە
.C      Am
 ساعان سەندىم
.F        G
 ساعان بەردىم ٴبارىن دە

[V2]
 و، كيەلى رۋح، ٴبارى سەنىڭ قولىڭدا.
 ادامدىعىم، ادالدىعىم، ارىم دا.
 بار كۇنامدى قۇربان قىلدىم جولىڭا.

[V3]
 كەل، كيەلى رۋح، جانۇياما، بالاما،
 سەن جوق جەردە تىنىشتىعىم بولا ما؟
 ٴوزىڭ كەلىپ ۇيالاشى ساناما.

[V4]
 و، كيەلى رۋح، كەلشى مەنىڭ قازاعىما.
 ٴتوزىپ بولدىق بۇل جالعاننىڭ مازاعىنا.
 كۇشىڭدى بەر، شىعار جالعان ازابىنان</lyrics>
<title>و، كيەلى رۋح ҮРәж144</title>
</song>