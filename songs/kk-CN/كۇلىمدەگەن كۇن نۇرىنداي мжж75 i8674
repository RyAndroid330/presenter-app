<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am         Dm
 كۇلىمدەگەن كۇن نۇرىنداي،
.F          E
 جانىمداسىڭ سەن مەنىڭ.
.Am         Dm
 كوكتەمدەگى اق جاۋىنداي
.F         E
 سەنى اڭساپ جۇرەمىن.
.   Dm        G            C   Am
 // كەتەر ەدىم سەن بولماساڭ اداسىپ،
.Dm          C         E      Am
 كەتەر ەدى۔اي جۇرەگىمدى مۇڭ باسىپ. //

[V2]
 ساعان دەگەن جاڭا ٴانىم
 تاۋسىلمايتىن ٴداريا.
 ماعان دەگەن مەيىرىمىڭ
 اشىلمايتىن قۇپيا.
 // ايسىز تۇندە جارىق شاشتىڭ جولىما.
 ناعىز باقىت الىپ بەردىڭ قولىما. //

[V3]
 جۇرەگىمنىڭ نازىك ٴۇنىن
 سەزەسىڭ سەن بىلەمىن.
 ٴومىرىمنىڭ ٴاربىر كۇنىن
 تىنىشتىققا بولەدىڭ.
 // سەن مەنىڭ بيىك ۇشقان ارمانىمسىڭ.
 بارىنەن دە سەن بۇگىن جوعارىسىڭ. //</lyrics>
<title>كۇلىمدەگەن كۇن نۇرىنداي МЖЖ75</title>
<hymn_number>75</hymn_number>
</song>