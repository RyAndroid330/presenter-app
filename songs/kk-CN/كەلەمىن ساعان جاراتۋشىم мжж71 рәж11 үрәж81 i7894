<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<author>ِڤَ-لِنَ هِللمَرك</author>
<title>كەلەمىن ساعان جاراتۋشىم МЖЖ71 РӘЖ11 ҮРәж81</title>
<lyrics>[V1]
.    Am
 // كەلەمىن ساعان جاراتۋشىم
.      F
 سەنىڭ شەكسىز ماحابباتىڭ،
.       G
 تاۋسىلمايدى راقىمىڭ.  //

[C1]
.       C
   // ۇلىسىڭ سەن،
.                Am
   سەن عاجايىپ ۇلىسىڭ.
.                    F
   سەنەن ارتىق ەشكىم جوق،
.          G
   ساعان ەشكىم تەڭ كەلمەس.  //

[V2]
 // كەلەمىن ساعان، اڭساپ سەنى.
 جۇرەگىمدى جادىراتشى،
 ماڭگىلىككە جاساشى.  //</lyrics>
<key>C</key>
</song>