<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>109</hymn_number>
<author>سېرگېي دانىلьچېنكو (سېرژ دانى)</author>
<title>مەن ٴۇشىن ولگەنىڭە МЖЖ109</title>
<key>D</key>
<lyrics>[V1]
.D      A       Bm
 مەن ٴۇشىن ولگەنىڭە،
.G    D         A
 قانىڭدى توككەنىڭە،
.D        A     Bm
 قايتا تىرىلگەنىڭە،
. G     D     A D
 ٴولىمدى جەڭگەنىڭە.

[C1]
.  D    A   Bm
   راحمەت ساعان ٴتاڭىر يسا!
.  G   D    Em       A
   راحمەت ساعان ٴتاڭىر يسا!
.  D       A     Bm
   راحمەت ساعان ٴتاڭىر يسا!
.  G          D
   جۇرەگىم ساعان ريزا،
.  G         D A  D
   جۇرەگىم ساعان رٸزا!</lyrics>
</song>