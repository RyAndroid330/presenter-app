<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>184</hymn_number>
<title>ماڭگىلىك سەنىمەن، بىرگە بولعىم كەلەدى РӘЖ184 МЖЖ108</title>
<lyrics>[V1]
.Em      C        Am            B7  Em
 ماڭگىلىك سەنىمەن، بىرگە بولعىم كەلەدى.
.Em      C        Am          B7  Em
 ومىرلىك سەرىگىم، جانىم ساعان سەنەدى.
.   Am         D7   G        Em
 //  قۇدايىمسىڭ سەن، قۋانامىن مەن.
.Am       B7           Em      (E/E7)
 قۋات الىپ ٴاربىر سوزىڭنەن. //

[V2]
 قاراڭعى تۇندەردە، سىرلاسامىن وزىڭمەن.
 جارىق نۇر توگىلەر، مەيىرىم شاشقان جۇزىڭنەن.
 // قۇدايىمسىڭ سەن، قۋانامىن مەن،
 قورعاۋشىمداي قاسىمدا جۇرسەڭ. //

[V3]
 كوكتەن سەن كەلەرسىڭ، كۇندەردىڭ ٴبىر كۇنىندە.
 كۇتەمىن سەنى مەن، ەش ۇزىلمەس ۇمىتپەن.
 // قۇدايىمسىڭ سەن، قۋانامىن مەن،
 ەرەكشە ٴبىر عاجاپ سەزىممەن. //</lyrics>
<key>Em</key>
</song>