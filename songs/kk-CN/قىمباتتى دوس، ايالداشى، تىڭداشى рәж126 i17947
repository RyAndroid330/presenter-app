<?xml version="1.0" encoding="UTF-8"?><song><title>قىمباتتى دوس، ايالداشى، تىڭداشى РӘЖ126</title>
<key>Bb</key>
<lyrics>[V1]
.      Bb         Cm        F   Bb
 قىمباتتى دوس، ايالداشى، تىڭداشى،
.          Cm          F        Bb
 قۇدايدان سەن ٴوتىنىپ ٴبىر سۇراشى.
.            Eb        Bb      Cm
 // سەن بەيباقتى قۇتقارادى كۇنادان،
.        F                   Bb
 سەن دە ونى بار نيەتپەن سۇراشى. //

[V2]
 تازالاشى جۇرەگىڭدى، ويىڭدى،
 تازالاشى لاستانعان بويىڭدى.
 // سەن بەيباقتى قۇتقارادى كۇنادان،
 تەك سۇراي ٴبىل شىن جۇرەكتەن يسادان! //</lyrics>
<hymn_number>115</hymn_number>
</song>