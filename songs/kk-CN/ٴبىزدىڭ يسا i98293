<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ٴبىزدىڭ يسا تاعايىندالعان ۇلى پاتشا،
 قۇتقارۋشىم راقىمدى، يگى قۇداي.
 ٴبىزدىڭ يسا قۇداي تاڭداپ العان توقتىسى،
 شىنايى، ٴتىرى جول ماڭگىلىك بىزگە اشقان،
 يسا ماداق ساعان.

[C1]
   // ماداقتالسىن سەنىڭ اتىڭ يسا،
   تابىنسىن بۇكىل الەم سەنىڭ الدىڭا كەلىپ. //
   يسا ماداق ساعان.</lyrics>
<title>ٴبىزدىڭ يسا</title>
<author>جانات كۋساينوۆا</author>
</song>