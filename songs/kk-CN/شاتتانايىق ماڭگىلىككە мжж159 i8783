<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>159</hymn_number>
<title>شاتتانايىق ماڭگىلىككە! МЖЖ159</title>
<lyrics>[V1]
.    E          C#m
 //   شاتتانايىق ماڭگىلىككە!
.F#m       B7
 يسا ٴتاڭىر قۇدىرەتتى!  //

[C1]
.      E
   //   ماڭگىلىكتىڭ قۇدايى!
.  C#m
    قۇدىرەتتى قۇدايىم!
.  F#m
    ٴبىز ٴۇشىن سەن ۇلىڭدى،
.  B7
    قۇربان ەتتىڭ ماڭگىگە!  //

[V2]
 //  بۇل ومىردە مەن اداستىم.
 سەن مەنى ٴسۇيدىڭ، تاڭداپ الدىڭ.  //</lyrics>
<key>E</key>
</song>