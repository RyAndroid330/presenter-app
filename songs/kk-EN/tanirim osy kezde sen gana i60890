<?xml version="1.0" encoding="UTF-8"?><song><author>Janat Kýsaınova</author>
<title>Táńirim osy kezde Sen ǵana</title>
<aka>Meniń júregim</aka>
<key>Bm</key>
<lyrics>[V1]
.Bm        D   G
 Meniń júregim, ańsap jylaǵanda,
.Em                        F#          F#7
 Bar qaıǵy qasiretti, Saǵan bergim keledi.
.Bm            D  G
 Táńirim tek Seni, júregim izdeıdi,
.Em                       F#           F#7
 Qysylyp shyǵatyn esik tappaı dúrsildeıdi!

[C1]
.   Bm  A              G
   Táńirim,osy kezde Sen ǵana,
.  D                Em
    Maǵan jaqynsyń, Iem!
.  Em7             D          F#    F#7
    Meni, qushaǵyńa tartyp, qysasyń Sen!
.  Bm  A          G
    Ózińe, jaqyndattyń meni,
.  D         Em      G     D       F#   F#7
    Jubatasyń Sen, Óz qolyńda, meni sábıdeı!

[V2]
 Osyny túsinbeı, Senen alystap,
 Qushaǵyńnan, sytylyp, shyqqym keledi!
 Alaıda Táńirim, osy ýaqytta,
 Seniń, Rýhyńa tolyp, rahattamyn men!</lyrics>
</song>