<?xml version="1.0" encoding="UTF-8"?><song><aka>Táńirdi madaqta</aka>
<key>Eb</key>
<lyrics>[C1]
.  Eb    G#     Eb  A#     Cm
    Táńirdi madaqta jan-dúnıem!
.  G#    Eb  A#
    Kıeli esimin!
.        G#         Eb A#       Cm
   Bar daýyspen madaqta jan-dúnıem!
.  G#      A#   Eb
    Táńirdi madaqta!

[V1]
.G#  Eb      A#     Cm
 Tamasha araıly tań atty,
.G#  Eb       A#        Cm
 Táńirim ǵajap kún jaratty.
.G#  Eb     A#        Cm
 Osynaý keremet raqymy úshin,
.G#  Eb     A#    Eb
 Arnaıyq biz madaqty.

[V2]
 Raqymyń men mahabbatyń sheksiz,
 Táńirim Sen ulysyń.
 On myń sebep te az bolar maǵan
 Máńgi aıtar jyrymsyń!

[V3]
 Qýatym kemip sarqylǵan kúni,
 Ajalym jetip aqyrǵy.
 Jan-dúnıem Seni jyrlaıdy taǵy,
 Máńgilikke Atyńdy!

[C2]
.  Eb    G#     Eb  A#     Cm
    Táńirdi madaqta jan-dúnıem!
.  G#    Eb  A#
    Kıeli esimin!
.        G#         Eb A#       Cm
   Bar daýyspen madaqta jan-dúnıem!
.  G#       A#   Eb/Cm
    Táńirdi madaqta!
.  G#       A#   Eb/Cm
    Táńirdi madaqta!
.  G#       A#   Eb
    Táńirdi madaqta!</lyrics>
<title>On myń sebep</title>
<author>Jonas Myrin, Matt Redman</author>
</song>