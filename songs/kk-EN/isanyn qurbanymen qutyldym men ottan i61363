<?xml version="1.0" encoding="UTF-8"?><song><title>Isanyń qurbanymen qutyldym men ottan</title>
<time_sig>4/4</time_sig>
<lyrics>[V1]
.   C             G         Am        F
 // Isanyń qurbanymen, qutyldym men ottan,
. C           G        Am         F
 Isanyń jarasymen jazyldym, esh kúmán joq.
. C         G         Am      F
 Isanyń qanymen, aqtaldym kúnádan.
. C          G         Am        F
 Isanyń ólimimen, berildi máńgi ómir maǵan. //

[C1]
.    C                G          Am   F
   Jarylqashy meniń janym - Táńirdi! Táńirdi!
.    C               G                 Am  F
   Meniń búkil jan-dúnıem, Kıeli atyn Onyń!
.    C                G          Am   F
   Jarylqashy meniń janym - Táńirdi! Táńirdi!
.    C             G                Am  F
   Jáne umytpa, barlyq ıgi isterin Onyń!

[B1]
.  C G          Am
   Men senemin Seniń, qurbanyńa
.  F
   Kıeli qanyńa, máńgi ómirge!
.   C  G        Am
   Meniń atym Kóktegi Kitapta jazylǵanyna,
.  F
   Men senemin !</lyrics>
<key>C</key>
<tempo>124</tempo>
<author>Novoye Pokoleniye (g. Riga, Laviya), Oskar Sprogis</author>
