<?xml version="1.0" encoding="UTF-8"?><song><author>Shyntemirov Ábilhaıyr</author>
<hymn_number>153</hymn_number>
<key>C</key>
<lyrics>[V1]
.      Am       E         Am
 Juldyzdar jarqyrap janǵanda,
.     A7                Dm
 Jaryq aı kórinip aspanda,
.         Dm       G     C        Am
 //  Táńirim, Ózińe júrekti ashqanda,
.     Dm         E         Am
 Táńirim, Sen meni qutqardyń.  //

[V2]
 Ómirdiń taba almaı baqytyn,
 Jolymnyń bile almaı baǵytyn,
 //  Tunshyǵyp tuńǵıyq túbinde qalǵanda,
 Táńirim, Sen meni qutqardyń.  //

[V3]
 Kúnániń shyǵa almaı torynan,
 Adasyp júrippin jolymnan.
 //  Júrekti taǵy da jalǵyzdyq basqanda,
 Táńirim, Sen meni qutqardyń.  //

[V4]
 Ómirdiń qaıǵy men azabyn,
 Umyttym kúnániń mazaǵyn.
 //  Táńirim qutqardy, qýanysh syılady,
 Táńirim, kúnádan qutqardy.  //</lyrics>
<title>Juldyzdar jarqyrap janǵanda РӘЖ153 Қак20</title>
</song>