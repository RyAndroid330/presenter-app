<?xml version="1.0" encoding="UTF-8"?><song><author>John Laudon</author>
<hymn_number>134</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em  D     Bm   Em
 Ybraıymnyń Qudaıy,
.C    D           Em
 Biz úshin qan tókken.
.Em    D    Bm/Em
 Qurbandyqqa Isa,
.C  D     Em
 keldi kókten.

[C1]
.      E   E7   Am  D7    G    Em
   //   Taǵzym etip aldyna kelemin,
.  Em7 Am   D7      G
    Ádiletti Patshamnyń!
.  E   E7   Am  D7     G   Em
    Taǵzym etip aldyna kelemin,
.  Em7  Am    D      Em
    Meıirimdi Patshamnyń!  //

[V2]
 Súıip bizdi qutqardy,
 Táńirimiz uly.
 Máńgi tiri sózderi,
 tıedi jyly.

[V3]
 Táńir Seniń raqymyń,
 Tynyshtyq beredi..
 Jaryq, nuryń janyma,
 eń keregi.</lyrics>
<title>Ybraıymnyń Qudaıy РӘЖ134</title>
</song>