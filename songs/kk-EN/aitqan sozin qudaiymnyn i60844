<?xml version="1.0" encoding="UTF-8"?><song><title>Aıtqan sózin Qudaıymnyń</title>
<lyrics>[V1]
 Aıtqan sózin Qudaıymnyń
 Ashýlanbaı qabyldashy.
 Qutqarylyp sen de búgin
 Jaryqqa sol jaqyndashy.

[C1]
   Erteńgi kún belgisiz ǵoı
   Búgin kelshi qutqarylshy
   Sózin tyńdap asyǵyp sen
   Jaryqqa sol jaqyndashy.

[V2]
 Bul ómirden alarym joq,
 Jaqsylyqpen tapqanym joq
 Senýshideı ómir súrip,
 Jaqyndashy sol jánnatqa</lyrics>
</song>