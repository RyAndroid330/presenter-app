<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>112</hymn_number>
<author>John Laudon</author>
<key>G</key>
<lyrics>[V1]
. E      D   Bm C  Am       Bm     E
 Qudaıy Israıldiń men úshin qanyn tókken,
.E      D   Bm    C    Am      Bm    E
 Qudaı Toqtysy - Isa, tynyshtyq Patshasy,

[V2]
. Am         Dm    G    Em
 Tize búgip tabynamyn, Iem,
.  Am             D    E
 Sen - Táńirsiń, jer Patshasy.
. Am          D   G     Em
 Tize búgip tabynamyn, Iem,
. Am            Bm         E
 Qymbatty Isa, Sen - Patshamsyń!</lyrics>
<title>Qudaıy Israıldiń ҮРәж112</title>
</song>