<?xml version="1.0" encoding="UTF-8"?><song><key>F</key>
<lyrics>[V1]
.    F       Dm       C
 Saban tóselgen astaýda,
.   Dm            A7
 Bala jatyr shyraıly.
.  Dm           C
 Anasy otyr qasynda,
.  Dm           A
 Qýanyshpen qaraıdy.

[C1]
.   F             C
   Ol aspannan kelgen,
.      Dm            A7
   Qutqarylý syıyn bergen,
.     F         C
   Qudaı Uly - Másih,
.       A7        Dm
   Jumaqtyń joly ashyq.

[V2]
 Astaýda Ol nege jatyr,
 Maldarǵa jem beretin?
 Osy jerge qınalǵandar,
 Emin erkin keletin.

[V3]
 Ol Patshasy bar álemniń,
 Uly sot bop keledi.
 Jer betindegi bar eldiń,
 Júrekterin kóredi.</lyrics>
<title>Saban tóselgen astaýda РӘЖ166</title>
