<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>112</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.Dm     A         Dm
 Qutqarýshym ǵajapsyń,
.Gm       C      F
 Seni dos dep ótermin.

[C1]
.  Bb     C      F
   Eń aýyryn azaptyń,
.  Gm        A7       Dm
   Men úshin Sen kóterdiń.

[V2]
 Esimde tókken qanyń,
 Qoldaryń jara basqan.

[C2]
   Qaıyrylyp Táńirge men,
   Bas ıip alǵys aıtam.

[V3]
 Aıtqan sóziń esimde:
 «Keshir Áke olardy».

[C3]
   Kez bolǵanyń esimde,
   O, Isa, jolda maǵan.

[V4]
 Shaqyrmasań Sen meni,
 Tartpasań jyly sózben,

[C4]
   Júrer edim adasyp,
   Ár qıly jalǵan jolmen.

[V5]
 Másih meni súıgende,
 Ómirime endi nur.

[C5]
   Tek Isada tynyshtyq,
   Shattyq ómir maqsatym.</lyrics>
<title>Qutqarýshym ǵajapsyń, Seni dos dep ótermin</title>
</song>