<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Qudaı panasynda turǵan adam,
 Qudirettiniń saıasynda tabady tynym. //

[V2]
 // Bas saýǵalaıtyn panam, qorǵanym,
 Senimimdi Saǵan artam Qudaıym. //

[V3]
 // Ol meni qutqarady, qorǵap-qorshaıdy,
 Meni aman-esen saqtap qurmettke Ol bóleıdi.
 Men Oǵan sıynam, Ol qulaǵyn salady,
 Azap shekken kezde, maǵan Ol jar bolady. //</lyrics>
<title>Qudaı panasynda</title>
<author>Janat Kýsaınova</author>
</song>