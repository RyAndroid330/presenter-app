<?xml version="1.0" encoding="UTF-8"?><song><author>Neızvesten</author>
<key>D</key>
<lyrics>[V1]
.D     G    A  D
 Men qozysy Isanyń,
.D     G    A     D
 Ár kezde júregim shat!
.D     G            A
 Qamqor bolyp jol kórsetip,
.    G         A
 Tilegimdi oryndaıdy,
.        G         D
 Jaqsy kórip kún saıyn,
.    G    A    D
 atymdy Ol biledi!

[V2]
 Eger shalǵaı júrsem de,
 Súıenishim tilegim,
 Ash bolsam men azyq berip,
 Jaıly óriske jeteleıdi,
 Shóldesem Ol aparar,
 Tunyp turlarǵan sýǵa!</lyrics>
<title>Men qozysy Isanyń</title>
</song>