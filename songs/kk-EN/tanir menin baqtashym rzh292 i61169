<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>292</hymn_number>
<title>Táńir meniń Baqtashym РӘЖ292</title>
<key>E</key>
<lyrics>[V1]
.    E               C#m
 Táńir meniń Baqtashym!
.    F#m   B7   E
 Sońynan erdim Onyń!

[C1]
.      E            C#m
   Sońynan, sońynan,
.      A     B7   E
   Sońynan erdim Onyń!

[V2]
 Ol móldir sýǵa aparady,
 Sońynan júrsem Onyń!

[C2]
   Sońynan, sońynan,
   Sońynan júrsem Onyń!

[V3]
 Baǵyt tap shyndyq jolyna,
 Sońyńnan júrip qýanam!

[C3]
   Sońyńnan,Sońyńnan,
   Sońyńnan, júrip qýanam!</lyrics>
</song>