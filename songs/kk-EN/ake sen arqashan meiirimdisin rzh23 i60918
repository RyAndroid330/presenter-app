<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<key>G</key>
<lyrics>[V1]
.          G        C        G
 Áke, Sen árqashan meıirimdisiń,
.D                   G          D
 Ýádeńe óte beriksiń, eshkimge uqsamaıtyn.
.  G               C      G
 Qolyńda kóterip júresiń Óziń,
.                D          G         E
 Jeteleıdi tiri Sóziń, balańdy tastamaısyń.

[C1]
.   Am    D      G   Em
   Meıirimdi! Meıirimdi!
.     Am    D     G        E
   Madaqtaımyn máńgige meıirińdi.
   Meıirimdi! Meıirimdi!
   Ardaqtaımyn kıeli meıirińdi.

[V2]
 Áke, Sen kúnámdi eske almaısyń,
 Kúsh berip árkez qoldaısyń,
 Kúreste tastamaısyń.
 Janymdy meıirimińe bólediń,
 Raqymyń sheksiz, kóremin, tek Ózińe senemin.</lyrics>
<title>Áke, Sen árqashan meıirimdisiń РӘЖ23</title>
</song>