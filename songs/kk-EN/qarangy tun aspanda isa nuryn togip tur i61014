<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C          Am
 Qarańǵy tún aspanda,
.F         G
 Isa nuryn tógip tur
 Samal jeldiń lebimen,
 Jańa ánin berip tur!
 Ol - tynyshtyq Iesi,
 Adamzatqa Kıeli,
 Ol - Patshasy ómirdiń,
 Isa - Saǵan kelip tur!

[C1]
   // Bulttardan bıik Iem,
   Kún sáýlesi astynda,
   Óz - Patshalyǵyn qurar,
   Kútedi Ol jannatynda! //

[V2]
 Júregimniń tórinde,
 Isa - Ózi sóılep tur,
 Júregim taza bolsa,
 aq batasyn berip tur.
 Ol - tynyshtyq Iesi,
 Kók pen jerdiń, Kıeli,
 Rýhym sonda shattanyp,</lyrics>
<title>Qarańǵy tún aspanda, Isa nuryn tógip tur</title>
<author>Nur</author>
</song>