<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.D        Bm
 Isa meni súıedi,
.G          D
 Nyq bilemin osyny,
.D         Bm
 Balalaryn shaqyryp,
.Em  A    D
 Kóteredi qolyna!

[C1]
.  D        Bm
    Isa meni súıedi,
.  D        A
    Isa meni súıedi!
.  D        Bm
    Isa meni súıedi,
.  Em        A        D
   Kıeli kitap solaı deıdi!

[V2]
 Meıirimdi júregi,
 Aıqyshqa Ol kóterdi!
 Men úshin Ol qan tógip,
 Sol qanymenen jýdy!

[V3]
 Isa meni súıedi,
 Isa tálim beredi,
 Júregim jaralansa,
 Zulymdyq nıetinen!

[V4]
 Isa máńgi meniki.
 Qaýipsizbin men endi.
 Meniń janym Isada,
 Qudaı meni saqtaıdy.</lyrics>
<title>Isa meni súıedi</title>
<author>Bradbury, William Batchelder (1816-1868), Warner, Anna B. (1827-1915)</author>
</song>