<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>171</hymn_number>
<title>Shattanyńdarshy báriń de! РӘЖ171</title>
<lyrics>[V1]
.    G                   C
 Shattanyńdarshy báriń de!
. D               G
 El jurtym, sýym, jerim de.
.    G               Am
 Shabyndyqtar men ormandar,
.       D        G
 Shattyqtan qalmańdar.

[C1]
.    Am              G
   Másih tiri! Másih tiri!
.      D          G
   Másih ólimnen tirildi!
.       Am           G
   Ol tirildi! Ol tirildi!
.     D      G
   Shynymen tirildi!

[V2]
 Ólimniń kisenin buzdyń!
 Kúná baılanysyn úzdiń!
 Kóterildiń kók aspanǵa,
 Ákege, Qudaıǵa.

[V3]
 Senimde biz nyq basaıyq,
 Jumaqqa qadam jasaıyq,
 Táńirdi ánge qosaıyq,
 Ony dáripteıik.</lyrics>
<key>G</key>
</song>