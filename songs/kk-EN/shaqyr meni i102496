<?xml version="1.0" encoding="UTF-8"?><song><time_sig>4/4</time_sig>
<title>Shaqyr meni</title>
<lyrics>[V1]
 Shaqyr meni estımin,
 Shaqyr men baramyn,
 Sońyńnan Qudaı,
 Shetine jerdiń.

[C1]
   Júregimdesiń meniń
   Sen jaqtyń otyńdy.
   Qudaıym, Seniń
   Izińmen júrem.

[V2]
 Jeteleshi,
 Meni, Qudaıym.
 Bolamyn birge
 Sen bar jerlerde.
 Seni sondaı súıem.</lyrics>
<tempo>68</tempo>
<author>Olʹga Mantula (Basarab)</author>
</song>