<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>287</hymn_number>
<key>D</key>
<lyrics>[V1]
.    D                      G
 Perishte kórindi, tas domalatyldy,
.D            A
 Ólim qashty, jeńdi, Ol tirildi!
.D          G          G         D
 Ol tozaqtan kúshti, Ol ólimnen kúshti,
.  G      A        D
 Jasasyn Isa! Ol tirildi!

[V2]
 Qorqynyshty basyp, úreıdi qýady,
 Qorqynyshtan kúshti, bizdiń Isa!
 Bizdi jubatady, úreıdi basady,
 Jasasyn Isa! Ol tirildi!

[V3]
 Kúnádan azatpyz, baqytty balamyz,
 Kúnádan bosatty, bizdiń Isa!
 Ol kúnádan ústem, Ol ólimnen kúshti,
 Jasasyn Isa! Ol tirildi!</lyrics>
<title>Perishte kórindi РӘЖ287</title>
</song>