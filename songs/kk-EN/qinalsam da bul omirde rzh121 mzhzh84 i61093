<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>121</hymn_number>
<title>Qınalsam da bul ómirde РӘЖ121 МЖЖ84</title>
<key>F</key>
<lyrics>[V1]
.  Dm
 Qınalsam da bul ómirde,
.  C
 Sen turasyń júregimde,
.Dm
 Tar jolmenen ótip kelem,
.  C
 Jalǵyz Óziń tiregim de.

[P1]
.    Bm                 C        Dm
   Elim alys, biraq Saǵan qaıyrylmaıdy,
.    Bm          C         F       A
   O, Qudaıym, kómegińsiz esh bolmaıdy!

[C1]
.    Dm    A      A             Dm
   Qudaı Áke, qutqara gór baýyrymdy,
.   Dm     A                Dm
   Isa, Iem, qutqara gór elimdi.
.       Bm          C       Dm
   //  Ótinip men Senen surap turmyn!  //

[V2]
 Daýyl soǵyp doldansa da,
 Jalǵyz Sensiń elge pana,
 Jumyr jer men kók aspan da,
 Barlyq bılik Sende Isa.

[V3]
 Janym kúıedi solar úshin,
 Árbir beıbaq qazaq úshin,
 Arashala tozaq ottan,
 Meniń halqym qutqarylsyn.</lyrics>
</song>