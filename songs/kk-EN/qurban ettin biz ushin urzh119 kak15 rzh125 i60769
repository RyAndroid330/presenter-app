<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<author>Shyntemirov Ábilhaıyr</author>
<key>C</key>
<lyrics>[V1]
.   Am                 F
 Qurban ettiń biz úshin,
.   G        Am
 Qasıetti janyńdy.
.    F
 Tógip kettiń men úshin,
.    G          Am
 Óz Kıeli qanyńdy.

[C1]
.     Am              F
   // Kúnálardan qutqaryp,
.  G              Am
   Máńgi ómir syıladyń.
.    Am          F
   Jan-tánimmen umtylam,
.     G          Am
   Usynǵanda baǵyńdy.  //

[V2]
 Sen álemdi jaratqan
 Bir Qudaıdyń Ulysyń
 Shynaıy ómir beretin,
 Móldir bulaq kózisiń.

[C2]
   // O, Táńirim jasaǵan,
   Patshalyǵyń jaqyndap,
   Osy álemge jarqyrap,
   Tógip turǵan nurysyń.  //

[V3]
 Janǵa dárý beretin,
 Júrekke jylý tógetin.
 Jaratqan Óziń pendeńe
 Kóńilindi bóletin.

[C3]
   // Qandaı sheksiz mahabbat
   Qandaı ystyq qushaǵyń.
   Qýanǵanda Ózińe,
   Qııaǵa samǵap ushamyn.  //

[V4]
 Nuryńdy tókshi halqyma,
 Qarańǵydan qutqarshy,
 Shyndyq tapsyn jolyńnan
 Kúnásinan aryltshy.

[C4]
   // Jaratqan bizdiń Iemiz,
   Táńirimiz Baǵýshy.
   Tar jolmenen jetelep,
   Máńgi ómirge aparshy.  //</lyrics>
<title>Qurban ettiń biz úshin ҮРәж119 Қак15 РӘЖ125</title>
</song>