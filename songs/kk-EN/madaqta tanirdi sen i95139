<?xml version="1.0" encoding="UTF-8"?><song><title>Madaqta Táńirdi sen</title>
<lyrics>[V1]
 Madaqta Táńirdi sen
 Máńgilik mahabbatpen
 Madaqta jan umytpa
 Qudaı adal barlyq jolda
 Madaqta jan ári bil
 Tastamaıdy Ol eshqashan
 Madaqta jan ár isin
 Ómirińde oryn alǵan

[V2]
 Jer menen máńgilikte
 Ne degen Uly jospar
 Bári daıyn men úshin
 Jan dúnıem Ony dańqta
 Keshti kúnámdi endi men
 Kirshiksiz tazamyn
 Uıat penen qaıǵy da joq
 Ol berdi baqyt tájin

[C1]
   // Madaqta janym, máńgi umytpa
   Bar raqymdylyǵyn Onyń //

[V3]
 // Jeńis bizde, Jeńimpaz bizben
 Kóteremiz biz Isa týyn
 Tyńda ólim qaıda ýly tisiń
 Taptaldy kúná ólim //

[V4]
 // Qutqardy Isa kúshti qolymen
 Berdi bizderge senim, úmit
 Al endi joq qarǵys ómirde
 Oǵan sengenderde //</lyrics>
</song>