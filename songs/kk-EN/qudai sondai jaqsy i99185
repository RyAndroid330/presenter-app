<?xml version="1.0" encoding="UTF-8"?><song><title>Qudaı sondaı jaqsy</title>
<lyrics>[V1]
 Mahabbatyń ǵajap Seniń,
 Raqymdy Qudaıym!
 Tolyǵymen qun tólediń,
 Laıyqsyz bolsam da!

[C1]
   Qudaı sondaı jaqsy,
   Qudaı sondaı jaqsy,
   Qudaı sondaı jaqsy,
   Ol sondaı jaqsy!

[V2]
 Ómir boıy qarap ótem,
 Seniń Atyń
 Kúnákardy qutqardyń,
 Ólimdi jeńdiń!

[V3]
 Jarylqashy Qudaı!</lyrics>
</song>