<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9</hymn_number>
<author>Ábdýalıeva Júldyz</author>
<lyrics>[V1]
.Dm                  Gm
 Araıly búgin tań atty,
.A                        Dm
 Qushaǵyn Qudaı bizge ashty.
.Dm                 Gm
 Kezdesip búgin,Táńirim,
.Gm           A
 Taǵzym ettim aldyńda.

[C1]
.  D                         Gm
   Sezdiń be júrek, sezdiń be?
.       C7             F
   Kezdeser kúndi Qudaımen.
.  Dm                         Eb
   Keshtiń be meni, keshtiń be?
.  Dm           A       Dm
   Kúnámdy meniń Qudaıym.

[V2]
 Senimen bolý tamasha,
 Qolymdy berdim balasha.
 Jetelep meni kelesiń,
 Tastama, Isa, tastama.

[V3]
 Kónlińdi burshy jerime,
 Qazaq degen elime.
 Jalynyp, Isa, suraımyn,
 Qutqarshy qazaq elimdi</lyrics>
<key>Dm</key>
<title>Araıly búgin tań atty МЖЖ9 Қак29 ҮРәж10</title>
</song>