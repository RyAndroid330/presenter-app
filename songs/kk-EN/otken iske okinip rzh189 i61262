<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ótken iske ókinip,
 Aldyńa men kep turmyn.
 // Tapsyrdym ómirimdi,
 Ózińe moıyn burdym. //

[V2]
 Tilimmenen, oımenen
 Óltirippin talaıdy.
 // Ózińmenen júregim
 Bir bolýdy qalaıdy. //

[V3]
 Sensiń jasyl jaılaýym,
 Sensiń tynysh ómirim.
 // Pendemin bir kúnáli,
 Keshire gór, Táńirim. //

[V4]
 Madaqtaıyn tek Seni,
 Qudiretti Qudaıym,
 // Qabyl alshy duǵamdy,
 Qyzmetińe jaraıyn. //</lyrics>
<title>Ótken iske ókinip РӘЖ189</title>
<author>Nýrabaeva Bahyt</author>
<hymn_number>189</hymn_number>
</song>