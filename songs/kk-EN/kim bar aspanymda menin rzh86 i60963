<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.    Em           Am              B7
 Kim bar aspanymda meniń? Sen ǵana,
 Ómirimniń máni tek Sen, o, Isa!
.     Am                   D
 // Sen men úshin otta boldyń,
.  G                Em
 Meni qanyńmen aqtadyń,
. Am     B7           Em (E)
 Kókke, Ákeme, o, Isa, jol ashtyń. //

[V2]
 Jalǵan dúnıe qyzyq emes,
 Sen ǵana, Qajetsiń maǵan ómirde, o, Isa!
 // Bu dúnıe meni aıamas,
 Kómegińsiz ońaı bolmas,
 Meniń jiger-kúshim Sensiń, o, Isa!. //

[V3]
 Joqshylyqta tastamaıtyn Sen ǵana,
 Júzim ónimin bermese, o, Isa!
 // Bıdaı egisin salmasa,
 Malǵa jut túsip qyrylsa,
 Úmitim jalǵyz Ózińde, o, Isa!. //

[V4]
 Jaý men otta qaldyrmaıtyn Sen ǵana!
 Kúná jan-jaqtan talasa, o, Isa!
 // Ottyń jalyny sharpysa,
 Barlyq jaýlarym jabylsa,
 Sen Qamalymsyń, Kúshimsiń - o, Isa!. //

[V5]
 Bul ómirmen qoshtasqanda - Sen ǵana!
 Seniń qolyńda tynyshtyq - o, Isa!
 // Qaıǵy janymdy qysqanda,
 Tabıǵat kúshi óshkende,
 Ánim óshpes ot ishinde - o, Isa!. //</lyrics>
<title>Kim bar aspanymda meniń? РӘЖ86</title>
<hymn_number>86</hymn_number>
</song>