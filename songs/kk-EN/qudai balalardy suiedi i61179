<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[C1]
.  D                   Bm
   Qudaı balalardy súıedi,
.      G     Em  A
   Álemniń balalaryn!
.     D          Bm       Em        A
   Atymyzdy Ol biledi, atymyzdy biledi,
.      G         A           D
   Bárimizdi qolymenen qorǵaıdy!

[V1]
.D                  Bm
 Men skımos, kishkentaı qardan
.Em   A   D
 úıdi salamyn!
.Bm/A          Em
 Shanamen syrǵanaımyn men,
.   G     A    D
 Taýdan domalaımyn!

[V2]
 Uzyn shashtan órimim,
 Taqııam ushqyr meniń!
 Denemniń túsi sap-sary,
 Kúrishti unatamyn!

[V3]
 Afrıka elinde turam,
 Onda óte ystyq!
 Shashym buıra qap-qaramyn,
 Barlyq tisterim aq!</lyrics>
<title>Qudaı balalardy súıedi</title>
</song>