<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>90</hymn_number>
<author>Shyntemirov Ábilhaıyr</author>
<lyrics>[V1]
.Bm    Em   F#7     Bm
 Ómirimdi Saǵan arnadym,
.  G             A
 Bir Ózińe umtylamyn.
.Bm    Em   F#7    Bm
 Senimimdi jasyrmadym,
. G            A
 Bir Ózińe sıynamyn.

[C1]
.      G                   D
   // Tek Seniń máńgilik adaldyǵyń,
.     G                D
   Bolsyn dep ómirlik qorǵanyshym.
.    Bm     Em   F#7      Bm
   Kúndiz-túni Saǵan qaraımyn,
.      G      F#7  Bm
   Eń Uly meniń Qudaıym. //

[V2]
 Salshy meni Óz jolyńa,
 Qarańǵyda adaspaıyn.
 Alshy meni Óz qolyńa,
 Saǵan kelip panalaıyn.</lyrics>
<key>Bm</key>
<title>Ómirimdi Saǵan arnadym РӘЖ90 Қак39 ҮРәж162</title>
</song>