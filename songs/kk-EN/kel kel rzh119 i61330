<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<title>Kel, kel! РӘЖ119</title>
<lyrics>[V1]
.  D       A7      D
 Kel, kel! Kel, kel!
.Em         D
 Seni Isa biledi, kel, kel!
.      G           A7       D          Bm
 // Qutqarý tek tilegi, júrekti ash kiredi,
.      Em       A7    D       D
 Birge ómir súredi, kelshi, kelshi. //

[V2]
 Kel, kel! Kel, kel!
 Názik únin estishi, kelshi.
 // Sózin tyńda jalyqpa, shaqyrady jaryqqa
 Óz jolyńdy anyqta, kelshi, kelshi. //

[V3]
 Kel, kel! Kel, kel!
 Tynysh ómirge enshi, kelshi.
 // Qutqarýshyǵa senshi, qolyńdy Oǵan bershi,
 Raqymdylyǵyn kórshi, kelshi, kelshi. //</lyrics>
<key>D</key>
</song>