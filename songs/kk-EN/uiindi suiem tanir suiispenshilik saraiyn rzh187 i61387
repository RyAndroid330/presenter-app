<?xml version="1.0" encoding="UTF-8"?><song><title>Úıińdi súıem Táńir, súıispenshilik saraıyn РӘЖ187</title>
<lyrics>[V1]
.Em     B       Em
 Úıińdi súıem Táńir,
.Em             B7   Em
 Súıispenshilik saraıyn.
.   Em Am          Em
 //  Másih qanymen ótelgen,
.  B    B7   Em
 Qaýymdy súıemin. //

[V2]
 Almas-Qaýymyńdy
 Súıemin men Qudaı,
 // Bosaǵasyn saqtaısyń
 Sen kózdiń qarasyndaı. //

[V3]
 Qymbatty Qaýymdy,
 Tiri jan jıynyń,
 // Jan-tánimmen ótinishte,
 Eske túsiremin. //

[V4]
 Qutqarýshym, Iem,
 Qaýymdy Sen basqar,
 // Tózetindeı kúsh-qýat ber,
 Men Ózińe kelem. //

[V5]
 Qaýymmen birlikte,
 Turar meniń janym,
 // Qasiretti aıqysh qyzmetin,
 Kóterem salmaǵyn. //

[V6]
 Seniń dańqyńdy,
 Biz birge bólisemiz.
 // Sonda aman qalyp janym,
 Aldyńda jyrlaımyn. //</lyrics>
