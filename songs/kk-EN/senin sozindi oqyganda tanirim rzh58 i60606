<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<title>Seniń sózińdi oqyǵanda Táńirim РӘЖ58</title>
<key>Am</key>
<lyrics>[V1]
.    Am                     E
 Seniń sózińdi oqyǵanda Táńirim,
. E                Am
 Kúnákar ekenime ókindim.
.     Am                    E
 Bul jaratqan dúnıe ótip keterin,
.    Dm            E          Am
 Bilgenimde, bir Ózińe shyn sendim.

[C1]
.         Am      Dm      Am
   // O, Qudaıym, o, Qudaıym,
.     Am                    Dm
   Oıymda da, sezimimde bir Óziń,
.      E                   Am
   Dańqtala ber júregimniń túbinde. //

[V2]
 O, Qudaıym, júregimde Sen jasa,
 Qasıetti Rýhyńmen baǵytta.
 Sıynǵanda, únimdi esti aspanda,
 Qoldap-qorǵap júrshi Óziń janymda.

[V3]
 Seni dańqtap árbir qutty kúninde,
 Jınalamyz biz sıyný úıinde.
 Oıymda da, sezimim de bir Óziń,
 Dańqtala ber júregimniń túbinde.

[V4]
 Ókinesiń osy sózdi uqpasań,
 Uly Qudaı aıtqan sózdiń birinde.
 O, baýyrym, qaıyrylsańshy Táńirge,
 Ýaqytty uttyrmastan bekerge.

[C2]
   // O, baýyrym, o, baýyrym.
   O, baýyrym, qaıyrylsańshy Táńirge,
   Ýaqytty uttyrmastan bekerge. //

[V5]
 Osy kúnge yrazamyz biz-daǵy,
 Jaryq kún men tynyshtyq bergenińe.
 Uly Táńir, Óziń bergen elime,
 Ulasa ber tynyshtyǵy jerimde.

[C3]
   // O, Qudaıym, O, Qudaıym,
   Uly Táńir, Óziń bergen elime,
   Ulasa ber tynyshtyǵy jerimde. //</lyrics>
</song>