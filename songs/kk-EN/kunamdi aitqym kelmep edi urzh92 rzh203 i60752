<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>92</hymn_number>
<title>Kúnámdi aıtqym kelmep edi ҮРәж92 РӘЖ203</title>
<key>C</key>
<lyrics>[V1]
.    Am
 Kúnámdi aıtqym kelmep edi,
.               C
 Sonda aıaq-qolym syrqyrap,
.     Am               Dm
 Kúni boıy júrdim yńqyldap.
.     Dm            Am
 Kúni boıy júrdim yńqyldap.

[C1]
.     Dm                 G
   Ádiletsiz isi keshirilgen,
.      Am
   Kúnási aqtalǵan baqytty!
.      Dm                G
   Moınyna Táńir kúná qoımaǵan,
.         Am
   Táńirdi aldamaıtyn baqytty!

[V2]
 Sebebi Seniń qolyń
 Zildeı bolyp ústimde jatty
 Sonda jazdyń aptabyndaǵy
 Kók shópteı solyp qaldym

[V3]
 Kúnámdi Saǵan arttym
 Qylmys pen ádiletsizdikti
 Ózińe jasyrmaı aıttym
 Sonda Óziń meni keshirdiń

[V4]
 Qudaısyz adamdar baqytsyz
 Al eger Táńirge senimińdi
 Júkteseń Ol baqyt beredi
 Raqymmenen Qudaı qorshaıdy

[V5]
 Táńirge qýanyńdar,
 Ádilder shattanyńdar!
 Shyn júrekten adaldar,
 Qýanyp án salyńdar!</lyrics>
</song>