<?xml version="1.0" encoding="UTF-8"?><song><title>Qudaısyz ómir - baqytsyz ómir ҮРәж116 РӘЖ123</title>
<lyrics>[V1]
.    Dm                 A
 Qudaısyz ómir - baqytsyz ómir,
.  Gm          A         Dm
 Kúnáǵa toly aldamshy ómir.
.        Dm         Gm    C       F
 // Nege shyndyqty bile almaısyń sen?
.   Dm           Gm       A        Dm
 Aıtshy baýyrym, kimdi aldaısyń sen?. //

[V2]
 Mine, taǵy da jylap tursyń sen,
 Qaıǵy-qasiret artyp júrmin dep.
 // Nege Qudaıdy tanymaısyń sen?
 Aıtshy, baýyrym, kimdi aldaısyń sen? //

[V3]
 Kúnáǵa batyp, qınalasyń sen,
 Muńyńdy aıtyp, tunjyraısyń sen?
 // Nege Qudaıdy tyńdamaısyń sen?
 Aıtshy baýyrym, kimdi aldaısyń sen? //

[V4]
 Kúnáńdi aıtsań Táńir aldynda,
 Keneler ediń sheksiz baqytqa.
 // Kelshi Qudaıǵa, kelshi baýyrym,
 Isanyń Sózin alshy qolyńa. //</lyrics>
<key>F</key>
<hymn_number>116</hymn_number>
<author>Shyntemirov Ábilhaıyr</author>
</song>