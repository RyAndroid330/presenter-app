<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>160</hymn_number>
<author>M.YU. Lermontov</author>
<title>Ómirdiń qıyn shaǵynda ҮРәж160 РӘЖ17</title>
<key>D</key>
<lyrics>[V1]
.  Bm
 Ómirdiń qıyn shaǵynda,
.          D
 Júrekti muń bassa,
.        Bm         Em
 //  Bir ǵajaıyp duǵany men,
.   Bm   F#    Bm
 Qaıtalaımyn jatqa.  //

[V2]
 Sol sózdiń úndestiginde,
 Qudiretti kúsh bar,
 //  Qasıetti bir kórkemdik,
 Sol sózderden shyǵar.  //

[V3]
 Júrektiń júgi jeńildep,
 Janym rahat tabar.
 //  Jan-dúnıeme túsken jaryq,
 Úmit otyn jaǵar.  //

[V4]
 Aýyrlyq júrekten túsedi,
 kúmán da alystaıdy.
 //  Jylaımyn da, senemin de,
 janym rahat tabady!  //</lyrics>
</song>