<?xml version="1.0" encoding="UTF-8"?><song><author>Janat Kýsaınova</author>
<title>O Isa shyn júrekten</title>
<aka>Laıyqsyń Sen uly dańqqa</aka>
<key>Bb</key>
<lyrics>[C1]
.  Dm           Dm              Gm
    Laıyqsyn! Laıyqsyn Sen, uly dańqqa!
.  Bb               Am              Am
    Búkil adamzat Seni qasterlesin, Isa!

[V1]
.Dm                 Dm            Am
  O, Isa, shyn júrekten Seni madaqtaımyn
.Gm              Gm               Bb Am
  Janadan shyqqan ánimen Seni dáripteımin
.Dm           Dm                      Am
  Jasaǵan keremetterińniń bárin jarııalaımyn
.Gm                       Gm      Bb Am
  Aıqyshtaǵy qurbandyǵyńdy men umytpaımyn</lyrics>
</song>