<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>263</hymn_number>
<title>Qýanamyz biz árdaıym РӘЖ263</title>
<lyrics>[C1]
.     D         A
   Qýanamyz biz árdaıym,
.  Em           A     D
   Shattanyp árqashanda!
.  D          A
   Qudaıdyń qýanysh nury,
.  Em           G/A   D
   Sónbeıdi eshqashanda!

[V1]
 Kúreste kómektesedi,
 Ol bizdi jetekteıdi.
 Azap qaıǵydan saqtaıdy,
 Ótinishti tyńdaıdy.

[V2]
 Másih jolymen júremiz,
 Qol astynda bolamyz,
 Qıynshylyq túsken kezde,
 Qorǵaýsyz biz qalmaımyz.

[V3]
 Ómir bergen shattyq úmit,
 Jaryq kúndeı nur tókti.
 Kúnákardy súıip Iem,
 Mol ıgilikter berdi.</lyrics>
<key>D</key>
</song>