<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>239</hymn_number>
<title>Jedel habar РӘЖ239</title>
<key>G</key>
<lyrics>[V1]
.Em
 Jedel habar keledi,
.Am
 Keledi keledi!
.B7                          Em
 Ne bolyp qaldy, ne bolyp qaldy?
.Em
 Betlehem qalasynda,
.  Am
 Qalasynda, qalasynda,
.B7
 Týdy Isa - Másih!
.             Em
 Týdy Isa - Másih!

[V2]
 Oǵan oryn bolmady,
 Bolmady, bolmady,
 Adam úıinde, adam úıinde,
 Kedeılikte týyldy,
 Týyldy,týyldy,
 Aqyrda jatty,
 Aqyrda jatty!

[V3]
 Baqtashylar sol túni,
 sol túni, sol túni,
 Qýandy sheksiz, Qýandy sheksiz,
 Perishteler jarııalap,
 jarııalap, jarııalap,
 Qýandy sheksiz,
 Qýandy sheksiz.

[V4]
 Kókte Qudaı dańqtalsyn,
 Dańqtalsyn, dańqtalsyn,
 Bergen Uly úshin! Bergen Uly úshin!
 Jer júzinde tynyshtyq,
 Tynyshtyq, tynyshtyq,
 Bolsyn máńgilik,
 Bolsyn máńgilik.</lyrics>
</song>