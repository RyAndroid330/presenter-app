<?xml version="1.0" encoding="UTF-8"?><song><aka>Bar álem jyrlańdar Ieni, </aka>
<key>D</key>
<lyrics>[V1]
.Bm                 A
 Bar álem jyrlańdar Ieni,
.               Bm
 Ándetip aldyna kelińder!
.Bm                 A
 Moıyndańdar Iem dep Qudaıdy,
.        G  A  Bm
 Ol bizdi jaratqan!

[C1]
.    G       A       Bm  G     A       Bm
   Alǵys jyr aıtyńdar qaqpadan ótkende!
.    G   A             G    A           Bm
   Alǵys aıtyńdar Qudaıǵa, alańǵa kirgende!
.    A          Bm
   Alańǵa kirgende!

[V2]
 Jaratqan Iemiz meıirimdi,
 Máńgilik raqym etedi,
 Urpaqtan urpaqqa bizderge
 Adal bop qala beredi!</lyrics>
<title>Alańǵa kirgende Қак44</title>
