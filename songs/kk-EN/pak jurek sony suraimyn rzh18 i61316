<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>18</hymn_number>
<title>Pák júrek sony suraımyn РӘЖ18</title>
<key>D</key>
<lyrics>[V1]
.D                       A
 Pák júrek,taǵzym etetin pák júrek,
.             Em         G       A  D
 Kókke jetetin pák júrek, sony suraımyn!
.D                       A
 Pák júrek,bárin súıetin pák júrek,
.                  Em   G      A  D
 Adal nıetti pák júrek, sony suraımyn!

[C1]
.     G     A         D
   // Tas júregimdi jibit,
.        Bm           Em
   Bershi Óziń senim úmit,
.        A        G     D
   Bolsynshy, oı-sanam tynysh!
.  G     A           D
    Shaqyram Táńir Seni,
.       Bm           Em
   Qanyńmen tazart meni,
.       G        A      D
   Suraımyn Senen pák júrek! //</lyrics>
</song>