<?xml version="1.0" encoding="UTF-8"?><song><author>Qabdeshov Rýslan</author>
<hymn_number>57</hymn_number>
<lyrics>[V1]
 // Isa meni qutqardyń Sen ólimnen,
 Sodan beri úlgi alam tek Ózińnen. //

[C1]
   // Jaratqan Iem jalynam Saǵan,
   Jaratqan Iem bata ber maǵan,
   Sózińdi Seniń tarataıyn
   Halqyma Seni ańsaǵan. //

[V2]
 // Men adasyp júrgende Óziń taptyń,
 Ulyńdy qıyp men úshin kúnámdy japtyń. //</lyrics>
<title>Isa meni qutqardyń Sen ólimnen МЖЖ57</title>
</song>