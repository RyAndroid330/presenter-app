<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<title>O, Qudaı Saǵan kelemin РӘЖ15</title>
<key>D</key>
<lyrics>[V1]
.    D      Em7    D
 Qaıǵy tartyp qınalǵanda,
.  G     A7      D
 O, Qudaı, Saǵan kelem.
.      D       Em7    D
 Álsiz bolyp, kúsh ketkende,
.  G    A7   D
 Qushaǵyńa enem.

[C1]
.      G       Bm     D
   O, Qudaı Saǵan kelemin
.       Em    A7    D
   Rýhymdy qaıta tirilt.
.      G       Bm     D
   Meıirimmen qýat berip,
.       Em    A7    D
   Tas júregimdi jibit.

[V2]
 Azapty ómir súrip keldim,
 Qaıdan tynyshtyq tabamyn?
 Saǵan keldim, Qutqarýshym.
 Qasyńda máńgi qalamyn.

[V3]
 Janym keıip, nalyp turmyn,
 Ómir solaı óte me?
 Eńsem túsip, sharshap turmyn,
 Óziń meni jetele.</lyrics>
</song>