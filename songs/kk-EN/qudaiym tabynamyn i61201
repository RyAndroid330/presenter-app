<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Qudaıym tabynamyn,
 Bir Ózińe tabynam!
 Sen bizge ómir berdiń,
 Sen álemdi jarattyń!

[C1]
   Kel dostarym, kel bıleıik,
   Madaqtaıyq biz Qudaıdy,
   Án salaıyq, bı bıleıik,
   Madaqtaıyq biz Qudaıdy!

[V2]
 Rahmet Saǵan Qudaı Iem!
 Rahmet Saǵan Táńir Iem!
 Seniń atyń madaqtalsyn,
 Qudaıym dep tabynamyn!</lyrics>
<title>Qudaıym tabynamyn</title>
</song>