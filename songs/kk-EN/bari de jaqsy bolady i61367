<?xml version="1.0" encoding="UTF-8"?><song><title>Bári de jaqsy bolady</title>
<aka>Nursyń Sen ómirimde</aka>
<key>D</key>
<lyrics>[C1]
.     D           A      B
   //  Bári de jaqsy bolady,
.  Em                A
    Árdaıym Sen qasymda ,
.          G    Bm
   Isa - Táńirim!
.          Em          A
   Men senemin Sen jeteleısiń meni! //

[V1]
.   D            A    Bm
 //  Nursyń Sen ómirimde,
.G          D   A
 Eń jaqyn júregime,
.D          A      Bm    G
 Baqytsyzdyqtan bizdi saqtaısyn,
.D      A      D
 Árkezde bizben birge! //

[C2]
   // Bári de jaqsy bolady,
   Árdaıym Sen qasymda ,
   Isa - Táńirim!
   Men senemin Sen jeteleısiń meni! //

[B1]
.     A      Bm      G         A   B
   //  Meniń atym máńgi - Ómir Kitabynda,
.  G     Em     A   D
    Jazyldy men senemin!
.  Bm      G  A       Bm
    Búkil álem shaıqalsa da,
.  G      Em         A    Bm
    Isa Táńir - meniń tiregim! //</lyrics>
<author>Janat Kýsaınova</author>
</song>