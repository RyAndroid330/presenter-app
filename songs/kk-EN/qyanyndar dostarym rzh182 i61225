<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>182</hymn_number>
<title>Qýanyńdar dostarym РӘЖ182</title>
<key>Bb</key>
<lyrics>[V1]
.       Gm
 Qýanyńdar dostarym,
.  Cm
 Madaqtańdar Táńirdi.
.   Bb
 // Isany jerge jiberip,
. Cm
 Syılaǵan máńgi ómirdi. //

[V2]
 Shattanyńdar baýyrlar,
 Shyrqatyp ásem ánmenen,
 // Ashyldy bizge qupııa,
 Ata-babań sezbegen. //

[V3]
 Tamashaǵa bólensin
 Tabıǵat bitken súısinip,
 // Isanyń sózin estisin
 Barlyq halyq qulshynyp. //

[V4]
 Aqıqatty tanysyn,
 Túnektegi jurtshylyq.
 // Ashylsyn bári perdeniń,
 Araılap atsyn kún shyǵyp. //

[V5]
 Oıan baýyr, qalǵyma.
 Jigerińe jiger qos.
 // Qudaıdyń bergen buıryǵyn
 Oryndamaı júrme bos. //</lyrics>
</song>