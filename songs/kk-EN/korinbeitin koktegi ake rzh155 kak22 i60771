<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.    Cm
 Qaıǵy tartyp qınalǵanda
.   Ab
 Jol taba almaı adasqanda,
.     Fm
 Bir Ózińe keldim Áke,
.      G
 Kórinbeıtin bolsań da.
.   Cm
 Qarańǵyda jatqanymda,
.     Ab
 Kúnáǵa ábden batqanymda
.       Fm
 Bar ekensiń sezdim Áke,
.    G
 Kórinbeıtin bolsań da.

[C1]
.    Fm                  G
   Kórinbeıtin Kóktegi Áke,
.      Cm            Ab
   Bir Ózińe sıynamyn men.
.   Fm                G       Cm
   Júregimnen shyqqan osy ánimmen,
.   Fm              G
   Bar álemdi jaratqan Iem,
.         Cm                Ab
   Aspannan nan jaýdyrtqan Iem,
.          Fm               G       Cm
   //  Kórinbeıtin Kóktegi meniń Ákem.  //

[V2]
 Jan júregim jylaǵanda,
 Álsizdenip qulaǵanda,
 Umtylamyn Saǵan Áke,
 Kórinbeıtin bolsań da.
 Óziń meni qutqarǵanda,
 Kóńilimdi jubatqanda.
 Basymdy ıdim Saǵan Áke,
 Kórinbeıtin bolsań da.</lyrics>
<aka>Qaıǵy tartyp qınalǵanda</aka>
<title>Kórinbeıtin Kóktegi Áke, РӘЖ155 Қак22</title>
