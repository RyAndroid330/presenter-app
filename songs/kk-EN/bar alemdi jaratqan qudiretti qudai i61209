<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[V1]
.Em         Bm          Em      Bm
 Bar álemdi jaratqan, Qudiretti Qudaı
. C         Am      B
 Jalǵyz Óziń ómirimdi meniń ózgerttiń.
. Em         Bm          Em      Bm
 Máńgi jyrlaımyn endi Seniń uly isińdi
.   C          Am          B
 Seniń sheksiz raqymyńdy maǵan syılaǵan.

[C1]
.   Em     C     D                G
   Saǵan Qudaı, madaq pen dańq bolsyn,
.    C          B       Em  B
   Basymdy Saǵan ǵana ıemin.
.   Em     C     D       G
   Saǵan Qudaı ómirim arnalsyn,
.    C         B          Em
   Qabyl al, duǵamdy sıynam men.

[V2]
 Bar álemdi jaratqan, Qudiretti Qudaı!
 Sensiń maǵan túnekte jaryq syılaǵan
 Sheksiz meıirimińdi júrekke sezdirdiń,
 Qyzmet etemin shyn júrekpen tek Saǵan!</lyrics>
<title>Bar álemdi jaratqan qudiretti Qudaı</title>
</song>