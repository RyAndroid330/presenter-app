<?xml version="1.0" encoding="UTF-8"?><song><author>Arman Kaınazarov</author>
<title>Másihtegi azattyq</title>
<lyrics>[V1]
.Em
 Másihtegi azattyq
.G
 Janǵa berdi bostandyq
 Meıirimin bildirgen,
 Jalǵyz Isa Iem!
 Másihtegi azattyq
 Jubanysh pen tynyshtyq!
 Ómirdegi bereke,
 Jalǵyz Isa Iem!

[C1]
   Mereıimdi ósirdi,
   Jańa bolmys syılady,
   Maǵan bergen shattyǵy,
   Jan dúnıeme sımady!
   // Úmitimdi jalǵady,
   Nurly kúnge aldaǵy,
   Senimimdi oıatty mahabbaty! //

[V2]
 Másihtegi azattyq,
 Raqymdylyq, qurbandyq!
 Óz isimen kórsetken,
 Jalǵyz Isa Iem!
 Másihtegi azattyq,
 Asyp tasqan adaldyq!
 Óz ómirin úlgi etken,
 Jalǵyz Isa Iem!</lyrics>
</song>