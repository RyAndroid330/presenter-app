<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>100</hymn_number>
<key>C</key>
<lyrics>[V1]
.      Am
 Aıtshy: Qannyń jigerin sen bildiń be?
.            E7
 Aqtaldyń ba Isa Qanymen?
.    Am                 Dm
 Rahatyn Onyń janyńmen sezdiń be?
.    Am        E7    Am
 Tazardyń ba, Isa qanymen?

[C1]
.   Am   Dm
   Tazartyl!
.    Am         F      E7
   Onyń Qany kúnányń daǵyn ketirer,
.      Am              Dm
   Aıqyshta Másihtiń tógilgen Qany,
.    Am         C7       Am
   Qardaı áppaq qyp aǵartady.

[V2]
 Kúnde sen Onyń aldynda tursyń ba?
 Aqtaldyń ba, Isa Qanymen?
 Raqymdylyǵyn sezdiń be Qudaıdyń,
 Tazardyń ba, Isa Qanymen?

[V3]
 Másihtiń kelýine daıynbysyń?
 Aqtaldyń ba, Isa Qanymen?
 Qasıetti ólkege kirer janyń,
 Tazarsań Qanymen Másihtiń.

[V4]
 Keshirim surap jamandyqtan jerin,
 Másihtiń Qanymen aqtal sen!
 Aıqyshta Qany tógilgen sen úshin,
 Másihtiń Qanymen tazar sen.</lyrics>
<title>Aıtshy: Qannyń jigerin sen bildiń be? РӘЖ100</title>
</song>