<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>267</hymn_number>
<title>Qudaı qaýymy Patshasyn РӘЖ267</title>
<key>A</key>
<lyrics>[V1]
.   A
 Qudaı qaýymy Patshasyn,
.   Bm
 Árdaıym madaqtaımyz,
.  D
 Ol Áke, al biz bir úıdiń,
.  E
 Bir týǵan shyraqtary.

[C1]
.    A           D
   Allelýııa, allelýııa,
.    C#        F#m
   Qudaıǵa madaq bolsyn.
.    D          F#m     D
   Mol qýanysh syılaıdy Ol,
.    E          A7
   Kıeli úıge halyq tolsyn.
   Alǵys Táńir, alǵys Táńir,
   Isa tókken pák qanyn,
   Bizder úshin qurban bolyp,
   Attyrdy baqyt tańyn.

[V2]
 Árqashanda aq batańmen,
 Isimizdi jarylqaı ber.
 Kıeli rýh berip boıǵa,
 Duǵamyzdy qabyldaı gór.

[V3]
 O, Táńirim, allelýııa,
 Sen qýanysh syılaısyń.
 Rýhyńmenen jelep-jebep,
 Qushaǵyńa jınaısyń.</lyrics>
</song>