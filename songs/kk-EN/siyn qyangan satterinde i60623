<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>153</hymn_number>
<title>Sıyn qýanǵan sátterińde</title>
<key>D</key>
<lyrics>[V1]
.C#m      G#          C#m
 Sıyn qýanyshty kezińde
.C#m       G#   C#m
 Qıyn shaqtarda sıyn.

[C1]
.     F#m        B       E  C#m
   // Sıyn baqytsyzdyq tóngende,
.  F#m       G#7      C#m
   qysylǵan kezde de sıyn. //

[V2]
 Sıyn ashýdy jeńgende.
 Qaýip tóngen kezde sıyn.

[C2]
   // Surap, jaqynyń úshin sıyn.
   Dushpanyń úshin sıyn. //

[V3]
 Sıyn álsizdengen kezinde.
 Menmendigiń úshin sıyn.

[C3]
   // Sıyn jaqynyńnan aıyrylǵanda.
   Jańa ómir úshin sıyn! //

[V4]
 Sıyn syn saǵaty qelgende,
 Ózińdi-ózin jengende.

[C4]
   // Sıyn boıyndy kúná jaılasa,
   Qudaı keshirsin dep sıyn. //</lyrics>
</song>