<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Kóterildi shańyraq,
 Jumaqtaǵy tórinde.
 Áke bárin shaqyryp,
 Daıyndaǵan úıine.

[C1]
   // Toıǵa shaqyrylǵan kezińde
   Daıyn bol qashanda
   Dúnıege baılanba
   Quaǵyna syıǵyzady
   Ákemiz shaqyrǵanda
   Aldanyp qalyp qalma //

[C2]
   // Estimgen kóz kórmegen toı bastaldy máńgilik
   Qutqarylǵan árbir jannyń daıyndady Áke ornyn //
   // Kútip otyr ár balasyn dastarhannyń basynda
   Kelsin qalsyn dep máńgi jaıyndaǵan otbasynda. //</lyrics>
<title>Kóterildi shańyraq</title>
<author>Nur</author>
</song>