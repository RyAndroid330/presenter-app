<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>168</hymn_number>
<key>C</key>
<lyrics>[V1]
 여호와 우리 주여

[V2]
.C          G/B
 Ёхова бидний Эзэн
.    Am           Em
 Таны алдар нэр орчлон дэлхийд
.  F              C/E   A7
 Юутай үзэсгэлэнт сайхан бэ
.   Dm       D    G7
 Юутай үзэсгэлэнт сайхан бэ/*2

[P1]
.  Am            Em
   Эзэний гараараа бүтээсэн
.  Am           Em
   Уудам хөх тэнгэр
.  Am                Em
   Эзэний бий болгосон од сарыг
.  F   D      G7
   Би харан байна

[C1]
.  C          G/B
   Хүн би чинь хэн болоод
.       Am          Em
   Агуу Эзэн намайг бодно вэ
.  F               C/E     A7
   Хүний хүү би чинь хэн болоод
.    Dm   D    G7
   Намайг Эзэн дуудна вэ</lyrics>
<aka>여호와 우리 주여</aka>
<title>Ёхова бидний эзэн Мд168</title>
</song>