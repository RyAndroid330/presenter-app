<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>57</hymn_number>
<title>Бидний зүрх бидний хүслэн Мд57</title>
<key>G</key>
<lyrics>[V1]
.       G              Em
 Бидний зүрх бидний хүслэн
.      C                         D7
 Ард түмэн бүр нэрийг тань магтах нь
.       G              Em
 Бидний гуйлт бидний нулимс
.      C                    D7
 Өнцөг булан бүрд Таныг дуулна

[V2]
.      Em         Bm
 Нэгэн хоолойгоор нэгдэн
.     G                      D7
 Олон аймгийн бүх хэлээр хамтдаа
.         G              Em
 Үндэстэн бүр Таныг магтах нь
.       C       D          G
 Бидний зүрх бидний чин хүслэн</lyrics>
</song>