<?xml version="1.0" encoding="UTF-8"?><song><aka>Эзэний нэрийг дээдэлье</aka>
<key>G</key>
<lyrics>[V1]
.G2     C             D  -C
 Эзэний нэрийг дээдэлье__
.G2   C             D -C
 Эзэн Таныг бид магтъя
.G2    C              D -C
 Авран хамгаалахаар миний
.G2       C          D      -C
 Амьдралд ирсэнд баярлаж байна

[C1]
.  G2        C        D
   Тэнгэрээс газар дэлхийд
.      C       G
   Зам заахаар ирж
.        C2             D
   Миний өрийг төлөхийн тулд
.            C      G2
   Загалмайд цовдлогдон
.        C               D
   Хадан булшнаас дахин амилж
.          B/D#      Em
   Тэнгэрт одсон Их Эзэн
.       C      D      G2
   Таны нэрийг дээдэлье</lyrics>
<title>Lord, I Lift Your Name on High Мд431</title>
<hymn_number>431</hymn_number>
<author>Рикк Фоундс</author>
<copyright>1989 Мараната Праисе, Инк.</copyright>
</song>