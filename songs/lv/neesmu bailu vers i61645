<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9964</hymn_number>
<author>Bethel Music</author>
<key>G</key>
<lyrics>[V1]
 Neesmu Bailu Vergs!

[V2]
.G
 Ar melodiju, Tu mani modini
.   Em      D      G
 Ar dziesmu aplencot
.G
 No naidnieka, Tu mani izglabi
.     Em     D      G
 Izzud visas bailes man.

[V3]
.          Em    D      G
 Es vairs neesmu bailu vergs,
.     Em    D     G
 Esmu Dziva Dieva berns

[V4]
.G
 Tiku izredzets, pirms mani radiji
.Em        D     G
 Milestiba varda nosauci
.G
 No jauna dzimis es, Tava gimene
.Em                   D     G
 Nu Tavas asins manas venas plust

[V5]
.Em      D         G             C
 Tu juru skel, lai varu tikt tai pari
 Tu milestiba, manas bailes noslicini
 Tu mani atdzemdini, lai es varu dziedat
.Em         D     G
 Esmu Dziva Dieva berns!
 Capo4</lyrics>
<title>Neesmu Bailu vers</title>
</song>