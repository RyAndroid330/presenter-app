<?xml version="1.0" encoding="UTF-8"?><song><title>Gelin övelim</title>
<lyrics>[V1]
 // Karaniktan bizi Cikardin aydinla koydun,
 Bizi sevgilisyile sardı Isa meshidir adi. //

[V2]
 // Gelin şimdi isayi yüceltelim bize sevgiyi öğreten Tanriyi ilan edelim. //

[V3]
 // Bizi O kadar cok sevdi Sonsuz yaşami bize verdi,
 Sana hamt ve övgü adina layik sin sen rab isa. //

[V4]
 // Gelin Şimdi Isayi yüceltelim bize sevgiyi öğreten.
 Tanriyi ilan edelim. //</lyrics>
</song>