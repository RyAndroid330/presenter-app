<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // O Mesihtir, Rab ve Allahtır,
 O tek yoldur, gerçek hayattır. //

[C1]
   // Aleluya, Şeytan yenildi,
   Aleluya, şükür İsa'ya. //

[C2]
   // O padişah padişahlara,
   O hakimdir, tüm hakimlere. //

[C3]
   // Şifa bulduk
   Yaralariylan.
   Aydınlandık
   Onun kaniylan. //

[C4]
   // Teşekkürler
   Allahımıza.
   O affetti
   Günahımızı. //</lyrics>
<title>O Mesihtir, Rab ve Allahtır BG654</title>
