<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>693</hymn_number>
<lyrics>[V1]
 // Hastayım ben, hastayım ben,
 Başım yastıkta yatıyom ben. //

[V2]
 Allah, seni bekliyom. Allah, sen tez gelesen,
 Ellerimden tutasan, Allah, ben de kalkayım.

[C1]
   // A..a..a... Allah, a..a..a... Allah,
   Brakma beni, Allah, çekeyim ! //

[C2]
   Allah, seni bekliyom, Allah, bana gelesen,
   Ve acımı alasan, Allah, ben de kalkayım.

[C3]
   Rab beni ilaçladı. Rabbimi ben övecem.
   Rabbe hizmet edecem. Rab İsamla olacam.</lyrics>
<title>Hastayım ben, hastayım ben BG693</title>
</song>