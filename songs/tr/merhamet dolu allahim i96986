<?xml version="1.0" encoding="UTF-8"?><song><author>Adil Yaşar</author>
<title>Merhamet Dolu Allahım</title>
<lyrics>[V1]
 // Merhamet Dolu Allahım
 Sevgin bana Sınırsızdır
 Esirge bütün Suçlarımı
 Kaldır benden Yüklerimi //

[V2]
 // Allahım Ey Allahım
 Duy benim Dualarımı
 Yalvarıyom sana barıyom
 Işit Beni Ey güçlü Rab Tanrı
 Suçlarımdan Günahımdan
 Arıt beni Kudretli Allahım //

[V3]
 // Güç ver sen bana Kutsal Ruh
 Yılmadan Hep sadık Kalayım
 Ömrümün bütün günlerinde
 Seninlen Hep Yaşayım //</lyrics>
</song>