<?xml version="1.0" encoding="UTF-8"?><song><title>Gücümsün</title>
<lyrics>[V1]
 // Güçsüzlüğümde benim gücümsün
 Yüreğimdeki boşluğu dolduransın
 İhtiyacım Olan tek Tanrımsın
 Sen benim kurtarıcımsın //

[V2]
 PR // Övgüler sana yüce İsa
.    
     Yüreğimi sunarım Ben Sana
.    
     Övgüler Sana Yüce İsa
.    
     Hayatımı Sunarım ben sana //

[V3]
 // Elimden tutup beni kaldıran Tanrım
.    
     Kendi çocuğun sen yaptın
.    
     Merhamettinle beni sen kurtardın
.    
     Sonsuz yaşamı Sagladın //</lyrics>
<author>Sabri Levit</author>
</song>