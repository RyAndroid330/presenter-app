<?xml version="1.0" encoding="UTF-8"?><song><title>Konuş, Ya Rab</title>
<key>Dm</key>
<lyrics>[C1]
.     Dm                   Gm   Dm
   // Konuş, ya Rab, kulun dinliyor
.  Dm                   Gm   Dm
   Konuş, ya Rab, kulun dinliyor  //

[V1]
.Dm                      C
 Rab bir şey söylüyor musun?
.Dm                      A
 Rab bir şey gösteriyor musun?

[V2]
.Bb            C  Dm    Bb      C
 'Kimi göndereyim?' diyor Rabbim
.Bb               C
 'Bizim için kim gidecek?'
.Bb            C Dm Bb     C
 İstediğin yere ben gideyim
.Bb              C
 Bur'dayım, beni gönder!</lyrics>
