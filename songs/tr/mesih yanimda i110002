<?xml version="1.0" encoding="UTF-8"?><song><author>Başkent Kilisesi, Saint Patrick of Ireland</author>
<title>Mesih Yanımda</title>
<capo>2</capo>
<key>A</key>
<lyrics>[V1]
.G          Am
 Mesih yanımda.
.D       C G
 Mesih önümde.
.         Bm Em
 Mesih arkamda,
.A7         D7
 Kalbimde kral.
.D7        G C
 Mesih başımda,
.G        Em A
 Beni taşıyan.
.D        G C
 Mesih içimde.
.D7        G
 Yoktur emsal!

[V2]
.G          Am
 Mesih sağımda.
.D        C G
 Mesih solumda.
.         Bm Em
 Mesih çevremde
.A7         D7
 Güçlü kalkan.
.D7       G  C
 Mesih uykumda.
.G       Em   A
 Mesih şafağımda.
.D         G C
 Birlikte yolda
.D7      G
 O koruyan!

[V3]
.G         Am
 Sesimi duyan,
.D       C  G
 Yüzümü gören
.         Bm Em
 Rab için ilham,
.A7      D7
 Esin alsın.
.D7       G C
 Mesih'i ansın
.G      Em A
 Beni düşünen.
.D       G  C
 Beni sayarken
.D7          G
 Rab taçlansın!</lyrics>
</song>