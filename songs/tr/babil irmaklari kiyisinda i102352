<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em                  Am
 Babil Irmakları Kıyısında Oturup,
.B7              C   Em
 Siyon'u Andıkça Ağladık;
.Em                  Am
 Çevredeki Kavaklara Lirlerimizi Astık
.B7               C          Em
 Çünkü Orada Bizi Tutsak Edenler
.Am             C
 Bizden Ezgiler,Bize Zulmedenler
.B7            C      Em
 Bizden Şenlik İstiyorlar,
.Am                  C
 &quot;Siyon Ezgilerinden Birini
.B7            C       Em
 Okuyun Bize!&quot; Diyorlardı.

[V2]
.Am                 Em
 Nasıl Okuyabiliriz RAB'bin Ezgisini
.B7             C          Em
 El toprağında? El Toprağında?

[V3]
.Em                 Am
 Ey Yeruşalim, Seni Unutursam,
.B7               C         Em
 Sağ Elim Kurusun,Seni Anmazsam,
.Em                   Am
 En Büyük Sevincimden Üstün Tutmazsam,
.B7             C    Em
 Dilim Damağıma Yapışsın</lyrics>
<title>Babil Irmakları Kıyısında</title>
<author>Eren Atik</author>
</song>