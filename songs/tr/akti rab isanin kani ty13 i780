<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13</hymn_number>
<key>D</key>
<lyrics>[V1]
.  D
 Aktı Rab İsa'nın kanı,
.  G  D G  D A
 Öldü Hükümranım.
.A7 D
 Suçluydum ben - kutsal olan
.  A     A7   D
 Olur mu kurbanım?

[C1]
.                           A
   Çarmıhta, çarmıhta, kurtuluş buldum orda,
.        A7                  D
   Suç yükü de kayboldu kalbimin.
.      G           D
   Görüşüm şifa buldu imanla,
.      A     A7          D
   Yok artık sonu sevincimin!

[V2]
.D
 Suçlarımdan mı çarmıhta
.   G D  G  D  A
 O derin ah çekti?
.A7  D
 Yüce lütuf! Eşsiz feda!
.  A      A7 D
 Görülmemiş sevgi!

[V3]
.  D
 Güneş görkemini örttü,
.   G D  G  D  A
 Tümüyle karardı.
.A7   D
 İnsanı Yaratan öldü,
.  A   A7  D
 İnsanın kurbanı!

[C2]
   Gözyaşım sel gibi aksa,
   Borçluyum sevgine,
   Veririm kendimi sana,
   Rabbim, sevinç ile!</lyrics>
<title>Aktı Rab İsa'nın Kanı TY13</title>
</song>