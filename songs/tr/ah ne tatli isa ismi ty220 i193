<?xml version="1.0" encoding="UTF-8"?><song><title>Ah, Ne Tatlı İsa İsmi! TY220</title>
<lyrics>[V1]
.G          C   D    C
  Ah, ne tatlı İsa ismi!
.D               C      G
  Diriltiyor ruh ve cismi,
.G/B            D7/C   C
  Mutlu eder hem kalbimi,
.       Am7 D    G
 Yüce ismi  İsamın!

[C1]
.  G     C
   İsam, ne tatlı ismin!
.  D     C/G          G
   İsam, her gün aynısın!
.  Em7    C
   İsam, gök yankı etsin!
.            Am7 D    G
   Sonsuz hamde layıksın!

[V2]
.G      C        D   C
  İsamı ben çok severim,
.D              C    G
  Bilir ağrı kederlerim'.
.Em7            C
  Endişemi hep söylerim,
.        Am7 D   G
 Tatlı ismi  İsamın!

[V3]
.G         C    D    C
  Cevap gelirse İsamdan,
.D                C    G
  Sevinç coşar yüreğimden.
.Em7             C
  Siler yaşları gözümden,
.         Am7 D   G
 Kutsal ismi  İsamın!

[V4]
.G       C   D    C
  İsa ismi unutulmaz,
.D                C    G
  Sözlerle hiç anlatılmaz!
.Em7              C
  Bütün evren hamdetse az,
.       Am7 D   G
 Yüce ismi  İsamın!</lyrics>
<key>G</key>
<hymn_number>220</hymn_number>
</song>