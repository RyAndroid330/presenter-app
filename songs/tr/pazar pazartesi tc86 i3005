<?xml version="1.0" encoding="UTF-8"?><song><title>Pazar, Pazartesi TÇ86</title>
<key>G</key>
<lyrics>[C1]
.  G D         G
   Pazar, pazartesi, salı ve çarşamba,
.               D               G
   Perşembe ve cuma, cumartesi de:
.      G                  D          G
   // Mutluyum, mutluyum, İsa benim dostumdur.  //

[C2]
   // İncili oku sen, Çünkü Rab'bin sözüdür.  //

[C3]
   // Dua et, dua et, Rab duamızı dinler.  //

[C4]
   // Bağışla, bağışla, barış dünyada olsun.  //

[C5]
   // Yardım et, yardım et, iş böyle hafiflesin.  //

[C6]
   // Sevindir, sevindir, herkes dostunuz olsun.  //

[C7]
   // Teşvik et, teşvik et, dost ayağa kalkacak.  //</lyrics>
<author>Hiltrud Ströhlein</author>
<hymn_number>86</hymn_number>
</song>