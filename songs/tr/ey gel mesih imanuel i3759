<?xml version="1.0" encoding="UTF-8"?><song><author>French, unknown</author>
<title>Ey Gel, Mesih, İmanuel</title>
<key>E</key>
<lyrics>[V1]
.   C#m         F#m B C#m
 Ey gel, Mesih, İmanuel,
.   E           F#m  C#m
 Tutsak İsrail kurtulsun.
.  F#m        E       B
 Acıyla sürgünde bekliyor
.   C#m        F#m  B   E
 Mesih İsa gelinceye kadar.

[C1]
.    B      G#m   F#m  C#m
   Sevin! Coşun! İmanuel,
.    E            F#m  C#m
   Sana gelir, Ey, İsrail!

[V2]
.   C#m             F#m  B  C#m
 Ey gel, Mesih, ey güçlü Rabbimiz,
.   E              F#m  C#m
 Bulut, korku, ve görkemiyle
.  F#m        E       B
 Sinada eskiden Musa'dan
.   C#m        F#m  B   E
 Kutsal Yasa halkına verdin.

[V3]
.      C#m         F#m B   C#m
 Gel, Yesse'nin kökündeki Fidan
.      E           F#m     C#m
 Bizi koru Şeytan saldırısından,
.  F#m        E       B
 Cehennemden kurtar bizi,
.   C#m      F#m B   E
 Sonsuz zafer ver bize!

[V4]
.   C#m       F#m B C#m
 Yücelerden doğan Güneş,
.   E           F#m  C#m
 Gelişinle hayran kalalım!
.  F#m        E       B
 Gece karanlık bulutları
.   C#m        F#m  B   E
 Ve ölüm gölgesi dağıtılsın!

[V5]
.   C#m           F#m B  C#m
 Ey,gel, Davud'un Oğlu, Mesih,
.   E        F#m      C#m
 Cennet evimizi bize açtın!
.  F#m          E     B
 Senin sevinçli yolunda
.  C#m    F#m  B  E
 Sonsuzca kalalım!</lyrics>
</song>