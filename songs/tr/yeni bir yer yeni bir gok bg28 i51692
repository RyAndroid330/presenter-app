<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>28</hymn_number>
<author>Jay Moussa-Mann</author>
<title>Yeni bir yer, Yeni bir gök BG28</title>
<lyrics>[C1]
   // Yeni bir yer yeni bir gök
   Kutsal olan yeni bir kent //
   // Süzlü olan gelin için
   hazırlanır hiç beklemeden //

[V1]
 // Gözlerimden tüm yaşları
 silecektir Allahımız //
 // Olmayacak orda elem
 yok olacak olüm keder //

[V2]
 // Olmayacak hic yas orda
 yok olacak tüm alayışlar //
 // elem acı son bulacak
 eski şeyler hep geçecek //

[V3]
 // Yücelikte oturan Rab
 imanlılarla olacak //
 // Görkemli ve ulu Tanrı
 aramızda olacak //</lyrics>
</song>