<?xml version="1.0" encoding="UTF-8"?><song><title>Kim sana güç veriyor</title>
<lyrics>[V1]
 Kim sana güç veriyor
 Kim seni besliyor
 Canına can katan Kim
 Yaşamını veren Kim

[C1]
   Yüce Tanrı değil mi
   Yeri Göğü yaratan
   Ekmek veren topraktan
   Beni seni yaratan

[V2]
 Kim verdi ömrünü senin
 Kim yaşatıyor seni
 Baba Anne diye söyleten Kim
 Sabah uyandıran Kim

[V3]
 Göklerden yamur veren Kim
 Alev alev parlayan Kim
 Yakıp tüketen ateş Kim
 Sonsuz yaşam veren kim</lyrics>
<author>Yaşar Atanasov</author>
</song>