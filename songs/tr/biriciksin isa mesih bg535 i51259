<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>535</hymn_number>
<title>Biriciksin, İsa Mesih BG535</title>
<lyrics>[C1]
   // Biriciksin, İsa Mesih.
   Allahın Oğlu sensin.
   Bizim günahlarımız için,
   Gerildin sen çarmıha. //

[C2]
   // İsa Rabbim, sen bizi kurtar,
   Şu yalancı dünyadan,
   Bizi senin ismin için,
   Çok kötü görüyorlar. //

[C3]
   // Tezlerde gel, İsa Mesih,
   Yavrularını al sen.
   Sen bilirsin, ey Allahım,
   Bizim kalplerimizi. //

[C4]
   // Allah, nerde ben gezersem
   Hep seni düşünüyom.
   Benim aklım hep sendedir,
   Sözlerini düşünüyom. //</lyrics>
</song>