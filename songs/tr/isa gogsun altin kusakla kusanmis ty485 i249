<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>485</hymn_number>
<author>Levent Kınran, Jenny Midyat, Jenny Midyat</author>
<title>İsa, Göğsün Altın Kuşakla Kuşanmış TY485</title>
<lyrics>[V1]
.Em      Bm      Em
 İsa, göğsün altın kuşakla kuşanmış,
.                      B7
 Saçların karlar gibi bembeyaz,
. Am         Em
 Giysilerin ayağına uzanmış,
.                     Bm7  Em   Bm7  Em
 Başın ak yapağı gibi bembeyaz! Bembeyaz!

[V2]
.(Em)                   Bm      Em
 Rab gözlerin alev alev yanan ateş,
.                    B7
 Yüzün kuvvetle parlayan güneş,
.Am                  Em
 Sesin gürül gürül akan sular,
.                   Bm7    Em    Bm7    Em
 Ayakların kor gibi parlak tunç! Parlak tunç!

[V3]
. Am              Em
 Ölmüştün ama dirildin Sen,
.B7                 Em     E
 Hem de sonsuza dek dirisin!
.Am              Em
 Ölümün anahtarı Sendedir,
.B7          Em        E
 Ölüler diyarı yetkindedir!
.Am                 Em
 İlk ve son Sensin korkmayız biz,
. B7           Em D Em
 Bir kandillik gibi sağ elindeyiz! Elindeyiz!</lyrics>
<key>Em</key>
</song>