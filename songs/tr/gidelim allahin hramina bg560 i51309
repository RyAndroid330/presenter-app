<?xml version="1.0" encoding="UTF-8"?><song><title>Gidelim Allahın hramına BG560</title>
<lyrics>[V1]
 /// Gidelim Allahın hramına.
 Dua edelim beraber ///

[V2]
 Ruhta İsaya.
 Odur kurtarıcımız.
 İsaya, odur sevincimiz. ///  ///

[V3]
 Brak herşeyi burda.
 Gözlerini dik Allahına. ///
 Ruhta İsaya.
 Odur kurtarıcımız.
 İsaya, odur sevincimiz. ///

[V4]
 Kaldır ellerini sen.
 Şükür et, Rabbimize. ///
 Ruhta İsaya.
 Odur kurtarıcımız.
 İsaya, odur sevincimiz. ///</lyrics>
<hymn_number>560</hymn_number>
</song>