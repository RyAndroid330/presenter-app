<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>512</hymn_number>
<lyrics>[V1]
 // Allahım nerdesin ?
 Aç gözlerini,
 Allahım, inansınlar,
 Görsünler, Allahım. //

[C1]
   Rab İsam,
   Şükürler sana.
   Rab İsam,
   Kanını döktün.

[C2]
   Rab İsam,
   Bizim için sen öldün.
   // Yaşlarımla, Rab İsam,
   Ayaklarını yıkadım. //

[C3]
   Saçlarımla, Rab İsam,
   Sildim ben onları. //
   //  İnanın, siz kardaşlar,
   İnanın, kızkardaşlar !
   İsa tezde gelecek,
   Bizi burdan alacak.</lyrics>
<title>Allahım nerdesin ? BG512</title>
</song>