<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>137</hymn_number>
<author>Ahmet Gül</author>
<lyrics>[V1]
.    Dmin
 // Sevgi, sevinç, selamet
 Yolunda durdum.
.Gmin
 Gelip geçenleri
.Cmin         Dmin
 Çok mutlu buldum! //
 Takıldım peşlerine,
 Yola koyuldum.
.Gmin
 Onlar gibi artık
.Cmin         Dmin
 Ben de kurtuldum.

[V2]
 // Rab İsa'nın adına
 Vaftiz olundum.
 Mesih'in kanıyla
 Satın alındım. //
 Kurtuluşun tek yolu
 İsa Mesih'tir.
 O'na gelenleri
 Tertemiz yıkar.

[V3]
 // İnayeti sonsuzdur
 Mesih İsa'nın.
 En değerli payı
 Budur insanın. //
 Kurtarıcı İsa'ya
 Sadık olalım.
 Kutsal yaşamını
 Örnek alalım.

[V4]
 // Rab'bin hizmetinde
 İşlek olalım.
 Verdiği Ruhundan
 Bol bol alalım. //
 Gidelim milletlere,
 Müjde verelim!
 Kurtarıcı İsa
 Geldi diyelim.</lyrics>
<key>Bb</key>
<title>Sevgi, Sevinç, Selamet TY137</title>
</song>