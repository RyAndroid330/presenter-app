<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>244</hymn_number>
<lyrics>[V1]
 //  Sabah inayetin için,
 Gece sadakatin için  //
 //  Sana şükür yükseltirim,
 Kutsal olan yüce Tanrım!  //

[V2]
 //  Sazım ile, sözüm ile,
 Davullarla, kaşıklarla,  //
 //  Sesim ile, canım ile
 Sana şükür yükseltirim!  //</lyrics>
<title>Sabah İnayetin İçin TY244</title>
</song>