<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>467</hymn_number>
<author>Ali Yazar</author>
<lyrics>[V1]
.Em           Am
 // Uzun yıllar yüreğimde
.F              Em
 Sevinç, sevgi aradım ben. //
.   Am             Em
 // Kerelerce seni sordum,
.F          Em
 Aradım hep seni durdum. //

[V2]
 // Uzun yıllar hep istedim
 Seni sende tanıyayım. //
 // Ben sevgini yüreğimde,
 Seni bende yaşayayım. //

[V3]
 // Evet, şimdi seni buldum
 Senin ile doluverdim. //
 // Ben sendeyim, sen de bende,
 Herkes görsün seni bende. //

[V4]
 // Bağışlarken, hem severken
 Hoşgörüyle davranırken, //
 // Senin gibi düşünürken,
 Herkes bende seni görsün. //

[V5]
 // Tüm yaşamım sende olsun
 Herkes bende seni görsün. //
 // Elem, acı olsa bile,
 Herkes bende seni görsün. //</lyrics>
<key>C</key>
<title>Uzun Yıllar Yüreğimde TY467</title>
</song>