<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>262</hymn_number>
<author>Kamil Musa, Ali Yazar</author>
<lyrics>[V1]
 //  Tanrı'nın tüm kurtardığı
 Köleler dönecek bir gün.  //
 //  Sevinç sözü dillerinde
 Koşuyorlar sonsuz kente.  //

[V2]
 //  Onların başını saran
 Sonsuz bir coşkuları var.  //
 //  Akla sığmaz sevinçleri,
 Esenlik buldular şimdi.  //

[V3]
 //  Üzgün ve iç çekmeleri,
 Bak, ta uzaklara kaçtı.  //
 //  Siliyor gözyaşlarını,
 Bak, Tanrı'nın ta kendisi.  //</lyrics>
<title>Tanrı'nın Tüm Kurtardığı TY262</title>
</song>