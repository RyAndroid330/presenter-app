<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Müjdeyi yaydilar
 Rab Mesihtir die bagirdilar
 Biran bile olsa susmadilar
 Resulerin isleri. //

[V2]
 // Bize sözü tanittilar
 her seyi sevgiyle yaptilar
 Ölüm pahasina bile olsa
 Resulerin isleri. //

[V3]
 // Diyar diyar gezdiler
 ölümü göze alip yörüdüler
 mujdeyle sevindiler
 Resulerin isleri. //

[V4]
 // Rab bin sözüyle doydular
 kuzunun buyruguna
 uydular kutsal ruh ile doluydular
 Resulerin isleri. //

[V5]
 // Bu yol ugruna can verdiler
 sessiz kalmayip Rab bi övdüler
 sevgiyle göçüp gittiler
 Resulerin isleri. //</lyrics>
<title>Resullerin İşleri</title>
<author>Hüseyin Kumbe, Ahmed Muzafer</author>
</song>