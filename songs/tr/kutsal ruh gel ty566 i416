<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>566</hymn_number>
<author>Gloria Clarke</author>
<title>Kutsal Ruh Gel! TY566</title>
<key>Am</key>
<lyrics>[V1]
.    Amin
 // Kutsal Ruh gel!  //
.Dmin   Amin  E     Amin
 Çölümüzden bizi kaldır,
.     Dmin Amin  E
 Kuru kemiklerimize,
.Amin              Dmin
  // Sözünü söyle, bizi yenile,
.Amin        E
 Üzerimize üfle!  //
.   Amin   Dmin G     C
 // Kalkacağız, coşacağız,
.F      Dmin      E       Amin
 Sözlerini yerine getireceğiz.  //

[V2]
.    Amin
 // Kutsal Ruh gel!  //
.Dmin  Amin  E     Amin
 Ölüm__den bizi kurtar,
.     Dmin Amin  E
 Kuru yüreklerimize,
.Amin              Dmin
  // Sözünü söyle, bizi yenile,
.Amin        E
 Üzerimize üfle!  //
.   Amin   Dmin G     C
 // Kalkacağız, coşacağız,
.F      Dmin      E       Amin
 Sözlerini yerine getireceğiz.  //</lyrics>
</song>