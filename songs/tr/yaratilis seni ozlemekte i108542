<?xml version="1.0" encoding="UTF-8"?><song><author>Barış Örün, Bedros Mığdısı</author>
<title>Yaratılış Seni Özlemekte</title>
<key>Em</key>
<lyrics>[V1]
.Em - B - Em - Am - E7 - Am - B - Em - B - B7 - Em
 Lal lal, lal lal - lal lal, lal lal - lal ... ...

[V2]
.Em            B         Em
 İlan ediyoruz özgür yaşamı,
.Am                E7        Am
 Ruhta ve gerçekte övgü sunmayı,
.B              Em
 İsa gibi seven ruhsal hayatı,
.B             B7         Em
 Kutsal Ruh'la güçle dolmayı...

[V3]
.Em            B          Em
 İlan ediyoruz sonsuz yaşamı,
.Am             E7     Am
 Kuru kemiklere buyurmayı,
.B               Em
 Tanrı oğlu gibi yaşamayı,
.B             B7         Em
 Kutsal Ruh'la güçle dolmayı...

[C1]
.  Am      E   B             Em
   Kilise uyan Rab'bin Sözü'yle,
.  C         Am    B       Em
   Yaratılış seni, beklemekte...
.  Am        E   B           Em
   Karanlığı yar Rab'bin önünde,
.  C         Am    B      Em
   Yaratılış seni, özlemekte...</lyrics>
