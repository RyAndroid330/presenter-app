<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>530</hymn_number>
<title>Beni seversen, beni istersen BG530</title>
<lyrics>[V1]
 // Beni seversen, beni istersen, //
 // Benim olasın, benim olasın
 Sevinçle beklerim. //

[V2]
 // Kalbine bir baktım,
 Ne kadar kararmış. //
 // Benim olasın, beni bulasın,
 Aydınlatacam. //

[V3]
 // Günahlarına af
 İstedin mi sen ? //
 // Günahlarına af istedin mi ?
 Ben verecem. //

[V4]
 // O, İsa Mesih'im,
 Seninle olayım. //
 // Senin olayım, seni bulayım,
 Cennete gireyim. //

[V5]
 // Beni seversen,
 Beni istersen, //
 // Benim olasın, beni bulasın,
 Cennete girecen. //</lyrics>
</song>