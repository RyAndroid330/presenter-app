<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Verdin bana kurtuluş,
 Ebedi hayatını.
 Esenlik yüreyime geldi.
 Yüceltelim İsa'yı. //

[C1]
   Mesih'im, Mesih'im,
   Kahrımı sen al benim.
   Mesih'im, Mesih'im,
   Dertlerimi sen doğrult.

[V2]
 // Saalam inanç yap beni.
 Bu bedende günah yapmayım.
 Kızgınlık, sövmek olmasın.
 İşleyesin her gün benimle. //

[V3]
 // İsa'nın sevgisinden ver,
 Seveyim kardeşlerimi.
 Olalım hepsimiz beraber.
 Onun yolunda yürüyelim. //</lyrics>
<title>Verdin bana kurtuluş BG546</title>
<hymn_number>546</hymn_number>
</song>