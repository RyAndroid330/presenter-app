<?xml version="1.0" encoding="UTF-8"?><song><title>İsterim göreyim seni BG604</title>
<lyrics>[V1]
 İsterim göreyim seni,
 Bütün yüreyimle.
 // Göreyim senin evini,
 Aydınlık göklerde. //

[V2]
 Ne zaman gösterdin bana,
 Senin evini sen.
 // Atlıyor benim yüreyim,
 Ne olacak orada. //

[V3]
 Burda tatlılık kayboldu,
 Sönüyor ot gibi.
 // Söylenmemiş sevinç orda,
 Kaynıyor her daima. //

[V4]
 Överler sayısız asker,
 Gökteki Babamı.
 // Diz çökerler taht önünde,
 Överler Allahı. //

[V5]
 Göklerdeki toplantıda.
 Yer veresin bana.
 // Bakayım sana, Babacığım,
 Temiz yüreyimle. //</lyrics>
<hymn_number>604</hymn_number>
</song>