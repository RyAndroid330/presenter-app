<?xml version="1.0" encoding="UTF-8"?><song><title>Korkma, Korkma Diyor Tanrı</title>
<lyrics>[C1]
   //  Korkma, korkma diyor Tanrı,
   Ben seninle beraberim.  //
   //  Etrafına hiç bakınma,
   Çünkü senin Tanrın benim.  //

[V1]
 //  Göz yaşını görüyorum
 Duvalarını duyuyor  //
 //  Acılarını biliyor
 Sana yardım edecegim  //
 //  Acılarını biliyor
 Göz yaşını silecegim  //

[V2]
 // Korkma korkma diyor tanrim
 Ben seninle beraberim  //
 // Hic kuşkusuz güven bana
 Çünkü senin tanrın benim  //

[V3]
 //  Pekiştireceğim seni,
 Sana yardım edeceğim.  //
 //  Adaletimin eliyle
 Sana destek olacağım.  //</lyrics>
</song>