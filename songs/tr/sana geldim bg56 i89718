<author>Cemil Osman</author>
<presentation>C</presentation>
<key>C</key>
<lyrics>[V1]
.        C            G            F            C
 // Sana Geldim Beni Affetin Beni Affetin Beni Affetin //
.   F    G      C        F      G   C       Bmb5
 // Beni-i Kurtaran Sensin, Seni İzlerim //

[C1]
.     Am    G         F      G
   //  Benim İçin Sen Ölümü Yendin
.      F         G      C    E
   Çarmıhta Kanını Döktün //

[V2]
.           C            G              F              C
 // Krallım Sensin Güvenirim Sana Güvenirim Sana Güvenirim //
.   F    G        C           F     G        C    Bmb5
 // Beni-i Güçlendiren Sensin, Sana Hamdederim //

[C2]
.     Am     G      F       G
   //  Benim İçin Savaşan Sensin
.  F       G         C
   Zafer Kazanan Sensin //</lyrics>
<title>Sana Geldim BG56</title>
</song>