<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>230</hymn_number>
<author>Memduh Uysal</author>
<lyrics>[V1]
 Gelelim, diyelim,
 Sen sevecensin,
 Tanrımız, Rabbimiz,
 Tek egemensin.
 //  Sevginle, lütfunla
 Avut bizleri.
 Ruhunla pekiştir
 Sen sevgimizi.  //

[V2]
 Şimdi hep birlikte
 Sana yöneldik.
 Tanrımız, Rabbimiz,
 Mesih İsamız.
 //  Elinle kanat ger
 Üzerimize.
 Koyma hiç yalnız
 Sakın sen bizi.  //

[V3]
 Gücünle, Ruhunla
 Doldur kalpleri.
 Tanrımız, Rabbimiz,
 Dinsin gözyaşı.
 //  Söz söyle, kalbimiz
 Coşsun sevinçle.
 Gerçekte ve ruhta
 Tapındır bizi.  //</lyrics>
<title>Gelelim, Diyelim TY230</title>
</song>