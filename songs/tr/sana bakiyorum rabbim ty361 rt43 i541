<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>361</hymn_number>
<title>Sana Bakıyorum, Rabbim TY361 RT43</title>
<key>Dm</key>
<lyrics>[V1]
. Dm      A   (Dm  A)
 Sana bakıyorum, Rabbim. (3x)
.             Dm D7
 Arkama bakmadan!
.                 Gm       C
 //  İzlerim yolunu, Rabbim
.              F         Dm
 İzlerim sevinçle, Rabbim
.          Gm         A
 İzlerim durmadan, Rabbim
.               Dm   (D7)
 Arkama bakmadan  //

[V2]
.(Dm)       A
 Seni seviyorum, Rabbim. (3x)
.             Dm D7
 Arkama bakmadan!
.                 Gm       C
 //  Severim huzurunu, Rab.
.               F        Dm
 Severim dostluğunu, Rab.
.              Gm         A
 Severim durmadan, Rabbim.
.             Dm     (D7)
 Arkama bakmadan  //

[V3]
.(Dm)         A
 Seni bekliyorum, Rabbim. (3x)
.             Dm D7
 Ruhunla dolayım!
.               Gm         C
 //  Severim gelişini, Rab.
.             F        Dm
 Özlerim gelişini, Rab.
.              Gm        A
 Hazırla beni, ey Rabbim.
.            Dm     (D7)
 Seninle olayım  //</lyrics>
</song>