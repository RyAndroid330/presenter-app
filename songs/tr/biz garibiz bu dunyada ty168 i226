<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am        G        Am
 // Biz garibiz bu dünyada,
.Am        G      Am
 Çadırımız yıkılacak. //

[V2]
.   Am           G
 // Bir gün geri döneceğiz,
.F        E
 Öz vatana gideceğiz. //

[V3]
.Am        G
 Bu dünyayı bırakıp da
.F         E
 Göç etmeye hazır mısın?

[V4]
.Am       G     Am
 Allahıma gidiyorum,
.Am          G        Am
 Gelmeye sen hazır mısın?
.Am         G     Am
 Rab yanına gidiyorum,
.Am          G        Am
 Gelmeye sen hazır mısın?

[V5]
.   Am          G
 // Herkes yolcu bu dünyada,
.F          E
 Fakirler de, zenginler de. //

[V6]
.   Am        G
 // Göçecekler bu dünyadan,
.F            E
 Zenginler de, fakirler de. //

[V7]
 // Ölüm bugün sana gelse,
 Göç etmeye hazır mısın? //

[V8]
 // Ne getirdin bu dünyaya?
 Gideceksin öyle bur'dan. //

[V9]
 // Bugün sıra sana gelse,
 Göç etmeye hazır mısın? //

[V10]
 // Ne ekersen bu dünyada,
 Biçeceksin o dünyada. //

[V11]
 Günahından arındınsa,
 Bulacaksın huzur or'da.
 Günahından yıkandınsa,
 Bulacaksın yaşam or'da.</lyrics>
<key>Am</key>
<title>Biz Garibiz Bu Dünyada TY168</title>
<hymn_number>168</hymn_number>
<author>Ali Yazar</author>
</song>