<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 İşit İsa güdücü nazik,
 Kuzusunu sen şimdi.
 // Geceleyin ol benimle,
 Koru beni sabaha kadar. //

[V2]
 Bütün gün sen beni güttün,
 Arttırayım şanını.
 // Beni doyurdun, ısıttın,
 İşit gece dualarımı. //

[V3]
 Affet işlediğim günahı,
 Düşüncemi koru.
 // Ölürsem senin olayım,
 Beni göke sen toplayasan. //</lyrics>
<title>İşit İsa güdücü nazik BG606</title>
<hymn_number>606</hymn_number>
</song>