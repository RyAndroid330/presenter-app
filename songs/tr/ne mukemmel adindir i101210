<?xml version="1.0" encoding="UTF-8"?><song><author>Peter Jacobs</author>
<lyrics>[V1]
 // Ey Egemen Rab
 Ne mükemmel adındır
 Ne yüce adın var yeryüzünde
 Görkeminle göklerin tümünü kapladın
 Ne yüce adın var yeryüzünde //

[C1]
   Seyrederken göklerini
   Ayı, yıldızları
   Önünde neyim ki düşünürüm
   Aksine beni seversin
   Ve bana bir taç verdin
   Sonsuza dek yüceltirim ismin'</lyrics>
<title>Ne Mükemmel Adındır</title>
</song>