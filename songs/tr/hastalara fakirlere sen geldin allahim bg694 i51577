<?xml version="1.0" encoding="UTF-8"?><song><title>Hastalara, fakirlere sen geldin, Allahım BG694</title>
<lyrics>[V1]
 // Hastalara, fakirlere sen geldin, Allahım. //
 // Sen açtın kalbimi, sen şifaladın beni. //

[C1]
   A...a...a - sen açtın kalbimi.
   A...a...a - sen şifaladın beni

[C2]
   // Çok hastaydım, Allahım. Sen düzeltirdin beni. //
   // Sen şifaladın beni, sen açtın kalbimi. //

[C3]
   // Sen kanara, Allahım. Sen göklerde dirisin. //
   // Yeni Yeruşalimde güneş gibi parlarsın. //

[C4]
   // Gök kapısını açtım, Allahımı ben buldum. //
   // Allahımla bile olayım, göklere uçayım. //

[C5]
   // Gece gündüz dua ediyom. Allahım sana yalvarıyom. //
   // Gel Allahım, bile olalım. Cennete gidelim. //

[V2]
 // İman ederim İsa'ya, inanırım Tanrı Ooluna. //
 // Eminim ölüp dirildi, cezamı da o çekti. //</lyrics>
<hymn_number>694</hymn_number>
</song>