<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>663</hymn_number>
<title>Sabahlayın kalktın mı BG663</title>
<lyrics>[V1]
 // Sabahlayın kalktın mı
 sen uykudan, //
 // Şükür ettin mi //
 Kurtarıcına
 İsa Mesih'e ?

[V2]
 // Ne vakıt alıyorsu.n
 Niymetinden, //
 // Şükür ettin mi //
 Kurtarıcına
 İsa Mesih'e ?

[V3]
 // Na zaman görüyon
 Onun iyiliyini, //
 // Şükür ettin mi //
 Kurtarıcına
 İsa Mesih'e ?

[V4]
 // Ne vakıt işidiyon
 Onun buyurduğunu, //
 // Hazır mısın sen //
 Geçesen ölümden hayata ?</lyrics>
</song>