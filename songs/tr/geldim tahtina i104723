<?xml version="1.0" encoding="UTF-8"?><song><author>Elhan Yashar</author>
<title>geldim tahtina</title>
<lyrics>[V1]
 \\Geldim tahtına,
 Sığındım lütfuna

[C1]
   \\Bağışla beni,
   affet beni,
   arıt beni günahımdan.

[V2]
 \\Bağırdım İsa'ya,
 Kulak verdi yakarışıma.

[C2]
   \\Şükrederim,
   hamd ederim,
   kurtardı beni Kral İsa.

[V3]
 \\Ben artık kurtuldum,
 esenliğe kavuştum.</lyrics>
</song>