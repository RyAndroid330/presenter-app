<?xml version="1.0" encoding="UTF-8"?><song><aka>Kelamın değer yüreğime</aka>
<lyrics>[V1]
.Em
 // Kelamın değer yüreğime //
.Am                C
 // Dilim lal olur dizim çöker
.D           Em
 Eğilirim hürmetimden //

[V2]
.   Em
 // Sevdan bir ateştir sanki //
.   Am             C
 // Yakar kor eder ciğerimi
.D           Em
 Küle çevirirdi beni //

[V3]
.   Em
 // Cemalini gördüğümde //
.   Am            C
 // Hayran olurum güzelliğine
.D              Em
 Gözlerim dalar heybetine //

[V4]
.   Em
 // Ya Rab senin varlığında //
.   Am            C
 // Yaşam bulurum senin ruhunda
.D              Em
 Gözlerim bakar Semâya //</lyrics>
<key>Em</key>
<title>Dilim lal olur RT116</title>
<author>Özgür Tunç</author>
<hymn_number>116</hymn_number>
</song>