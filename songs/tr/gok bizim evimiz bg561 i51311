<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>561</hymn_number>
<lyrics>[V1]
 // Gök bizim hramımız
 İsa gene kapımız. Aleluya! //

[V2]
 // Ol benimle, ey Rabbim.
 Ömrümün olduğu kadar. Aleluya! //

[V3]
 // İsa benim yoldaşım.
 Benim için o öldü. Aleluya! //

[V4]
 // Karanlığın içindeydim,
 Rabbim şılattı beni, Aleluya! //

[V5]
 // Vaz geçmişim dünyadan.
 Unutmuşum her şeyi. Aleluya! //

[V6]
 // İleri giderim ben.
 Hiç geri dönmeyecem. Aleluya! //

[V7]
 // Çeki çekmeye geldim.
 Allahım, bu dünyaya. Aleluya! //

[V8]
 // Koru beni günahtan.
 Rab, aydınlatır beni. Aleluya! //</lyrics>
<title>Gök bizim evimiz BG561</title>
</song>