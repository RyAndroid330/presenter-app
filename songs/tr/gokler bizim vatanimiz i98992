<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Gökler bizim vatanımız.
 Dünya da biz kiracıyız. //
 // Umudumuz bitmesin hiç,
 Oraya biz varacağız. //

[C1]
   Bu vatan hepimizin.
   Hediyesi Rab'bimizin.
   Gelin O'na iman edin,
   Huzur diyarına girin.

[V2]
 // İsa diridir gökler de,
 Oturur Tahtın sağında. //
 // Gelecek tekrar dünya ya,
 Alacak bizi yanına. //

[V3]
 // Umudumu ben rüyamda,
 Gördüm melekler yanımda. //
 // Sıkıntılı bir anımda,
 Aldı beni RAB yanına. //</lyrics>
<title>Gökler bizim vatanımız</title>
<author>Durmuş Tünel</author>
</song>