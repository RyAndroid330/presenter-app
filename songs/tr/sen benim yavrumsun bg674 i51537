<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>674</hymn_number>
<title>Sen benim yavrumsun BG674</title>
<lyrics>[V1]
 // Sen benim yavrumsun,
 Sen benim kuzumsun. //
 // Ben seni görüyom,
 Ben seni seviyom. //

[V2]
 // Gel benim evime,
 An benim adımı. //
 // Şükür amin olsun
 İsa Mesih'e. //

[V3]
 // Ben seni yıkadım,
 Benim temiz kanımla. //
 // Ben sana veriyom
 Benim temiz Ruhumdan. //

[V4]
 // Gez benim adımla,
 An benim adımı. //
 // Şükür amin olsun
 İsa Mesih'e. //

[V5]
 // Sen benim yavrumsun,
 Sen benim kuzumsun. //
 // Ben seni görüyom,
 Ben seni seviyom. //</lyrics>
</song>