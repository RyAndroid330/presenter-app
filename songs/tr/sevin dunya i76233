<?xml version="1.0" encoding="UTF-8"?><song><author>Handel, George Frederick (1685-1759), Watts, Isaac (1674-1748), Hillsong Worship</author>
<presentation>V1 V2 V3 V4</presentation>
<title>Sevin Dünya</title>
<key>C</key>
<lyrics>[V1]
.C                 G     C
 Sevin dünya! Rab'dir gelen,
.     F     G7   C
 Kral kabul edilsin!
.    F      C     F     C
 Herkes O'nda bulsun güven
.    C                G7
 Sesleri çınlasın! Sesleri çınlasın!
.    C       F       C G7 C
 Sesleri sev-i-nçle çınlasın!

[V2]
.C                G     C
 Sevinsin yer! Hükümran'a
.    F      G7   C
 Haykırsın yeryüzü.
.   F      C      F      C
 Yayla ve dağ, kara, derya!
.    C                   G7
 Hoş şarkı duyulsun! Hoş şarkı duyulsun!
.   C          F       C G7 C
 Hoş şarkı, hoş şarkı duyulsun!

[V3]
.C                 G      C
 Günah ve dertler son bulsun,
.    F     G7  C
 Kaybolsun acılar!
.    F        C      F         C
 Kaldırdı laneti, teselli getirdi
.   C               G7
 Mesih'in gelişi! Mesih'in gelişi!
.   C         F     C G7 C
 Mesih'in dünya-ya gelişi!

[V4]
.C               G       C
 Sevin dünya! Barış Prensi
.     F   G7    C
 Tüm dünyaya sunar
.   F         C    F         C
 Yüce görkemini, ebedi lütfunu
.  C                G7
 Eşsiz sevgisini, Eşsiz sevgisini
.  C        F         C  G7  C
 Eşs-i-z ve s-o-nsuz sevgisini!</lyrics>
</song>