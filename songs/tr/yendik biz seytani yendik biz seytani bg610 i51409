<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>610</hymn_number>
<title>Yendik biz şeytanı, yendik biz şeytanı BG610</title>
<lyrics>[V1]
 // Yendik biz şeytanı, yendik biz şeytanı,
 Yendik biz şeytanı İsa'yla. //

[V2]
 // O Aleluya, o Aleluya
 Yendik biz şeytanı İsa'yla. //

[V3]
 // İsa'nın adını, İsa'nın adını
 İsa'nın adını övüyoz. //

[V4]
 // O Aleluya, o Aleluya
 İsa'nın adını övüyoz. //
 // Artık biz serbeziz, artık biz serbeziz,
 Artık biz serbeziz Şeytandan. //

[V5]
 // O Aleluya, o Aleluya
 Artık biz serbeziz Şeytandan. //
 // Yendik biz şeytanı, yendik biı şeytanı,
 Yendik biz şeytanı İsa'yla. //

[V6]
 // O Aleluya, o Aleluya
 Yebdik biz şeytanı İsa'yla. //</lyrics>
</song>