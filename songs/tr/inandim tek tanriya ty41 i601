<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 İnandım tek Tanrı'ya,
 Evreni yaratana,
 // Kurtarıcı İsa'ya,
 Benim için ölene.  //

[C1]
   Üçüncü gün dirildi,
   Baba Tanrı'ya gitti.
   // O'na iman edene
   Verir sonsuz yaşamı!  //

[C2]
   Döktüğü temiz kanı
   Yıkar her günahkârı.
   // Mesih yine gelecek,
   İnanlıyı alacak.  //

[C3]
   Mesih İsa yargıçtır,
   Ölü ve dirilerin.
   // Vardır sonsuz yaşamı
   İmana gelenlerin!  //

[C4]
   Bu müjdeye inandım!
   Günahımdan yıkandım!
   // Rab'bin Kutsal Ruhunu
   Ben inayetle aldım!  //</lyrics>
<title>İnandım Tek Tanrı'ya TY41</title>
<author>Erol Özer, Ali Yazar</author>
<hymn_number>41</hymn_number>
</song>