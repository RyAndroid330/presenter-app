<?xml version="1.0" encoding="UTF-8"?><song><author>Cihan Duman</author>
<title>sonsuz yaşam isam</title>
<lyrics>[V1]
 // Sevinsin sana siğinan herkes
 Esenlik içinde yatsın uyusun
 Sana güvensin ya rab ömrünü versin
 Sonsuz yaşamında kendini bulsun //

[V2]
 // Sende sevinc bulup hep cosacagim
 Yolundan hiç sapmayip hep koşacağım
 Sensin benim babam sensin efendim
 Adını yürekten haykiracagim //

[V3]
 // Herkes bırakıp gitse sen benimlesin
 Övgüler sana olsun dünya dinlesin
 Hem yarım hem yoldaşım hem sirdasimsin
 Gücün ve kudretinle yer gök inlesin //</lyrics>
</song>