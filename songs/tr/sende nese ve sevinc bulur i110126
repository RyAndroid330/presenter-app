<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Sende neşe ve sevinç bulur,
 Günahtan sana yönelenler. //
 // Rab yücedir desin her diller.
 Kurtarışını özleyenler. //

[V2]
 // Ne olur ya Rab, kurtar beni,
 Yardımıma koş, yetiş ya Rab. //
 // Günahtan döndüm, tövbe ettim.
 Merhamet ya Rab, işit beni. //

[V3]
 // Senin sevgin eşsiz ve derin.
 Sana geldim biter kederim. //
 // Bugün yarın hep seninleyim.
 Çünkü sen bende ben sendeyim. //</lyrics>
<title>Sende neşe ve sevinç bulur</title>
<author>Durmuş Tünel</author>
</song>