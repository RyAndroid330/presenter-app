<?xml version="1.0" encoding="UTF-8"?><song><title>Tezde yavrum benim BG689</title>
<lyrics>[V1]
 // Tezde yavrum benim,
 Tezde geleceyim ben
 Göstereyim size,
 Benim sevincimi. //

[C1]
   Öğren sen üzülesen,
   Öğren sen aalayasan,
   Öğren sen taşıyasan
   Kurtarıcım gibi.

[C2]
   // Yara ilaçlayacam,
   Verecem teselli..
   Göstereyim size
   Benim sevincimi. //

[C3]
   // Kimler üzülürse,
   Söylesinler bana.
   Onlar söylesinler,
   Ben şifalayacam. //

[C4]
   // Çok az vakıt kaldı,
   İsa gelecek.
   O toplasın bizi
   Allahın yanına. //</lyrics>
<hymn_number>689</hymn_number>
</song>