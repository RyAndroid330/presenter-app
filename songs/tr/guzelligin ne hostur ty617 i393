<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>617</hymn_number>
<lyrics>[V1]
 //  Güzelliğin ne hoştur,
 Ne tatlıdır bakışın.
 Güzelliğin görkemlidir,
 Sarılmak istiyorum sana.  //

[V2]
 //  Rab senin güzelliğin
 Hiç azalıp tükenmeyecek.
 Senin çehrenin nuru
 Daima parlayacak.  //</lyrics>
<title>Güzelliğin Ne Hoştur TY617</title>
</song>