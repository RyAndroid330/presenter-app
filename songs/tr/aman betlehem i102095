<?xml version="1.0" encoding="UTF-8"?><song><title>AMAN BETLEHEM</title>
<lyrics>[V1]
 // Aman beytlehem canım beytlehem
 İsa mesih'i mi görmedin mi //
 // şimdi burdan geçip gitti
 Şu karşıki tapınağa sor //

[V2]
 // Aman tapınak canım tapınak
 İsa mesih'i mi görmedin mi //
 // Şimdi burda şifa verdi
 Şu karşı ki çarmıha sor //

[V3]
 // Aman çarmıh canım çarmıh
 İsa mesih'i mi görmedin mi //
 // şimdi benden indirdiler
 Şu karşıki mezara sor //

[V4]
 // Aman mezar güçsüz mezar
 İsa mesih'i mi görmedin mi //
 // şimdi burdan kıyam etti
 Şu karşıki göklere sor //

[V5]
 // Aman gökler canım gökler
 İsa mesih'i mi görmedin mi //
 // şimdi burdan uçup gitti
 Baba'nın sağ tarafına //

[V6]
 // Aman Baba canım Baba
 İsa mesih'i mi görmedin mi //
 // İsa bende ben ondayım
 Kutsal Ruh ta O sizdedir //</lyrics>
</song>