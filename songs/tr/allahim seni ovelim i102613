<?xml version="1.0" encoding="UTF-8"?><song><title>Allah'ım Seni Övelim</title>
<lyrics>[V1]
 // Allah'ım Seni Övelim
 Sana Hizmet Edelim
 Sonsuza kadar seni sevelim,
 Seni sevelim,Seni sevelim //

[V2]
 // Şükür Olsun Sana Ey Baba
 Benim Duva'mı Duyduğuna-aaa
 Duyduğuna-aaa Duyduğuna-aaa //

[V3]
 // Gelin Siz İnsanlar
 İsa'ya Kurtuluşa,Kurtuluşa,
 Kurtuluşa //

[V4]
 // Allah'ım Benim Derdimi Bilirsin
 İhtiyacıma cevap verebilirsin,
 Verebilirsin,verebilirsin //</lyrics>
</song>