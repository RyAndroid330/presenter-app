<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>209</hymn_number>
<author>Chris Tomlin, Matt Maher</author>
<title>Rab, Muhtacım RT209</title>
<lyrics>[V1]
.G           Csus2   G
 Rab geldim, diz çökerim
.G          Em7 D       G
 Bir tek sende, var esenlik
.G            Csus2    G
 Sen olmazsan, dağılırım
.G        Em7 D Csus2  G
 Çünkü senle, coşar kalbim

[C1]
.  G             Csus   G D
   Rab varlığına ben muhtacım
.  Em7    Csus G D
   Her anda muhtacım
.  G        D       Em7  Csus2
   Tek kalemsin, kalkanımsın
.  G            D  G  Csus2
   Ya Rab ben muhtacım

[V2]
.G           Csus2    G
 Düştüğümde, lütfun artar
.G         Em7 D       G
 Sonsuz sevgin çeker beni
.G             Csus2   G
 // Kollarında özgürüm ben
.G        Em7  D  Csus2 G
 Sende kaldıkça güçlenirim //

[B1]
.  C        G     D      Em7
   Kalbime öğret sana dönsün
.  C            D      G
   Dalgalar yükseldiğinde
.         C        G  D      Em7
   // Suya battığımda haykırayım
.  C           D       Dsus
   İsa sen tek çaremsin //</lyrics>
<aka>Rab geldim, diz çökerim</aka>
</song>