<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>215</hymn_number>
<author>Ali Yazar</author>
<title>Rab'be Şükür Yükseltin! TY215</title>
<lyrics>[V1]
 //  Rab'be şükür yükseltin!  //
 //  Çünkü Tanrı iyidir.  //
 //  O'na övgüler sunun,  //
 //  İnayeti sonsuzdur!  //

[V2]
 //  Rab'dir benim sevincim,  //
 //  Umudum ve övüncüm,  //
 //  Kurtarıcım ve Rabbim,  //
 //  Benim yaşam ekmeğim.  //</lyrics>
</song>