<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<author>Onur Yöş</author>
<key>Gm</key>
<lyrics>[V1]
.Em           Am
 Yüce Rab, sana tapınıyorum,
.     D              G  B
 Çünkü sensin benim Rab'bim.
.Em          Am
 Ellerimi sana kaldırıyorum,
.     D              G  B
 Çünkü sensin benim Rab'bim.

[C1]
.  Em Am  D       G    B
   İ__sa, hayatımın efendisi,
.  Em  Am D        G   B
   İs__a,  yüreğimin sahibi,
.  Em        Am        D
   Senden başka bir tanrı yok,
.    G     B    Em
   Benim hayatımda.

[V2]
.Em                Am
 Sevgin senin, dünyaya gelişin,
.      D              G          B
 Çarmıhtaki ellerin değiştirdi her şeyi.
.Em              Am
 Kurtuluşum, benim sevgili dostum,
.   D                  G        B
 Açıyorum kalbimi senin eşsiz sevgine.</lyrics>
<title>Yüce Rab, Sana Tapınıyorum RT59</title>
<capo>3</capo>
</song>