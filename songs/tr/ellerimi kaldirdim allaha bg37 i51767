<?xml version="1.0" encoding="UTF-8"?><song><title>Ellerimi kaldırdım Allaha BG37</title>
<lyrics>[V1]
 // Ellerimi kaldırdım Allaha
 Allahtan ben istedim //
 // Çok insan gelsin imana //

[V2]
 Ben Allahtan istiyorum
 Dua evini mubareklesin
 Sevgisini versin bana
 /// Sonuna kadar durayım ///

[V3]
 A a a Allahım İsa Mesih kurtarıcım
 A a a Allahım İsa Rab'bim kurtarıcım
 /// Bir tanesin sen ///</lyrics>
