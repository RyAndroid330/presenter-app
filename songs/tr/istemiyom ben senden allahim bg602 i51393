<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>602</hymn_number>
<title>İstemiyom ben senden, Allahım BG602</title>
<lyrics>[V1]
 // İstemiyom ben senden, Allahım,
 İstemiyom ben senden zenginlik.
 Ben istiyom, Rabbim, senin olayım,
 Sana, Rabbim, çalışayım. //

[C1]
   // Allahım, İsa, gel yanıma.
   Yıka beni senin kanınla.
   Affet benim günahlarım.
   Sonsuz yaşamak ver bana. //

[C2]
   // İnanın siz kardaşlarım,
   İnanın siz kızkardaşlarım,
   İnanın İsa tez gelecek,
   Herkese dava verecek. //</lyrics>
</song>