<?xml version="1.0" encoding="UTF-8"?><song><title>Mesih İsa gelecek, bize şifa verecek BG634</title>
<lyrics>[V1]
 // Mesih İsa gelecek, bize şifa verecek //

[C1]
   // O mubarek Mesih İsa.
   Yüzü, gözü nurluydu //

[C2]
   // Mesih İsa gelecek,
   Bizi alıp gidecek //

[C3]
   // Mesih İsa gelecek, Bizi göklere
   teslim edecek //

[C4]
   // Mesih İsa bu muydu ?
   Gökteki melekler duydu //</lyrics>
<hymn_number>634</hymn_number>
</song>