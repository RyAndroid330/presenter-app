<?xml version="1.0" encoding="UTF-8"?><song><title>kutsal mesih</title>
<lyrics>[V1]
 // Kutsal mesih tanrının oğlu //

[V2]
 // Ben biliyorum akan bir dere
 O derede sifa var size //

[V3]
 // Bu kendi dere İsa Mesih tir
 Kurtarıcımız bağışlayıcımız //

[V4]
 Gelin insanlar sizde Mesihe
 Af etsin sizin günahlarnızı
 Gelin hastalar İsa çağırıyor
 Bu diri sudan size de versin</lyrics>
</song>