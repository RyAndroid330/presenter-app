<?xml version="1.0" encoding="UTF-8"?><song><author>Durmuş Tünel</author>
<title>Kara Günler Üstüme Gelince</title>
<lyrics>[V1]
 Kara günler üstüme gelince
 Şeytan saldırıp gücüm bitince
 // Sazım ve sözüm ile
 Dua ve övgü ile
 Yüceltirim Tanrımı  //

[V2]
 // Rab Kurtarır  //

[V3]
 Sorun sıkıntılarım artınca
 Yokluktan dertten kaygılanınca
 // Yalvarırım Rabbime
 Alçalırım önünde
 Sığınırım Tanrıma  //

[V4]
 // Rab lûtfeder  //

[V5]
 Şeytan ayartmak istediğinde
 Günahlar çekici geldiğinde
 // Tövbe ile alçalıp
 Bağlanırım sözüne
 Güvenirim Rabbime  //

[V6]
 // Rab bağışlar  //

[V7]
 Korku, düşmanlar çoğaldığında
 Gücüm, cesaretim yok olunca
 // Kalkanımdır Rab İsa
 Korur beni mutlaka
 Güçlü olan yanımda  //

[V8]
 // Rab gücümdür  //</lyrics>
</song>