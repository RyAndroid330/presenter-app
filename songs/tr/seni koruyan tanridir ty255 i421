<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[C1]
.   Em                Am
   Seni koruyan Tanrı'dır,
.              F      G
   Seni sarsılmaya koymaz.
.  Em                F
   Uyuklamaz ve yorulmaz,
.           Dm      Em
   Seni koruyan uyumaz.

[V1]
 // Arıyorum tüm dağları,
 Yardım nereden gelecek? //
 Yeri ve göğü yaratan
 // Tanrıdandır bana yardım. //

[V2]
 // Sağ yanımda O gölgedir,
 Gündüz iken güneş vurmaz. //
 Geceleyin ay dokunmaz,
 // Tanrı eli üstümdedir. //

[V3]
 // Rab her şeyden beni korur,
 Benim ruhumu kurtarır. //
 Şimdiden ebede kadar
 // Şükür olsun, Tanrı korur. //</lyrics>
<title>Seni Koruyan Tanrı'dır TY255</title>
<author>Ali Yazar</author>
<hymn_number>255</hymn_number>
</song>