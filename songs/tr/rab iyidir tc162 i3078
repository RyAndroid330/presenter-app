<?xml version="1.0" encoding="UTF-8"?><song><author>Hiltrud Ströhlein</author>
<hymn_number>162</hymn_number>
<title>Rab İyidir TÇ162</title>
<lyrics>[V1]
.D       A           D           G
 Rab iyidir, Rab iyidir, Rab iyidir,
.        D  A  D
 Rab iyidir bana!

[V2]
 /// Beni sever,  /// Rab iyidir bana.
 /// ... (çocuğun adı) sever,  /// Rab iyidir ona.
 /// İsa geldi,  /// Tanrı'dan geldi.
 /// Sevinirim,  /// Rab iyidir bana.

[V3]
 // Teşekkürler,  // Beni sevdiğin için teşekkürler!
 // Teşekkürler,  // Dostum olduğun için teşekkürler!
 // Teşekkürler,  // Gözlerimi verdiğin için teşekkürler!
 // Teşekkürler,  // Görebildiğim için teşekkürler!

[V4]
 ..... (Kendiniz de başka sözlerle yeni kıtalar yapabilirsiniz.)</lyrics>
<key>D</key>
</song>