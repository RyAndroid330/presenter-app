<?xml version="1.0" encoding="UTF-8"?><song><author>Mustafa Abidov</author>
<hymn_number>62</hymn_number>
<key>Em</key>
<lyrics>[C1]
.  Em  Am              Em
    Dünya'nın kuruluşundan
.  Am          Em
   Vaat edilen İsa
.     Am             Em
   // İnsanlara doğruluğu
.  C   D   Em
   Öğreten İsa //

[C2]
.  Am           Em
   Sen kurban oldun
.  Am              Em
   Hiç ağızını açmadan
.     Am          Em
   // Benim yerime Sen
.  C    D       Em
   Golgotaya gittin //

[C3]
.  Am                  Em
   Çarmıhta yaşam bitmedi
.  Am                 Em
   Tanrı Mesih'i dirilti
.     Am              Em
   // Yaşamım Senin elinde
.  C       D         Em
   Sen Dirisin İsa Rab'bim //</lyrics>
<title>Vaat Edilen İsa BG62</title>
</song>