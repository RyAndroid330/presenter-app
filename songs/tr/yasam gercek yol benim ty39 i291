<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>39</hymn_number>
<lyrics>[V1]
 // Yaşam, gerçek, yol ben'im,
 İsa Mesih'tir adım.  //
 // Bana gelen herkese
 Kollarımı açarım.  //

[C1]
   // Yaşam ekmeği ben'im,
   Acıkan bana gelsin.  //
   // Yaşam suyu var bende,
   Susayan gelsin içsin.  //

[C2]
   // Karanlıkta yürüyen,
   Gerçek nuru özleyen,  //
   // Yürü benim ardımca,
   Nuruyum ben dünyanın.  //

[C3]
   // İyi çobandır adım,
   Kuzuları severim.  //
   // Tanrı'nın atadığı
   Gerçek kurban ben oldum.  //

[C4]
   // Yaşam, gerçek, yol ben'im,
   İsa Mesih'tir adım.  //
   // Bana gelen herkese
   Kollarımı açarım.  //</lyrics>
<title>Yaşam, Gerçek, Yol Ben'im TY39</title>
</song>