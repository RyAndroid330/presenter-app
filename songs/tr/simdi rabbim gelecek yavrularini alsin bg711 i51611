<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>711</hymn_number>
<lyrics>[V1]
 // Şimdi Rabbim gelecek, yavrularını alsın,
 Yavrularını alsın, onun yanına. //

[V2]
 // Allah sensin İsa. Sen bizim Rabbimiz.
 Al bizi yanına, seninle olalım. //

[V3]
 // İman et Rab İsaya. sana sabur veriyor.
 O dermanı veriyor bütün dünyaya. //

[V4]
 // Allah sensin İsa. Sen bizim Rabbimiz.
 Al bizi yanına seninle olalım. //</lyrics>
<title>Şimdi Rabbim gelecek, yavrularını alsın BG711</title>
</song>