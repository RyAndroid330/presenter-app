<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>90</hymn_number>
<author>Ahmet Gül</author>
<lyrics>[V1]
 Yıllarca günahımla
 Dolaşmaktan yoruldum.
 // Rab İsa'ya imanla
 Günahımdan kurtuldum.  //

[C1]
   Rab'bin çocuğu oldum,
   Artık çok sevinçliyim.
   // Her gün Rab'den öğrenir,
   Rabbimin izindeyim.  //

[C2]
   Rab'bin kutsal işine
   Seçilmişim, işlerim.
   // Ebedi yaşam benim
   Bereketlidir payım.  //

[C3]
   Rab ile övünürüm,
   Sonsuz O'na güvenim.
   // Bana karşı olanı
   İyilikle yenerim.  //

[C4]
   Birlikte ilahiler
   Rab'bi över, söylerim.
   // Rab'bin himayesinde
   Her an emniyetteyim.  //

[C5]
   Rab'bin doğru yolunda
   İtaatle yürürüm.
   // Yenikler dünyasında
   Yenenlerden üstünüm.  //

[C6]
   Hamtlar, şükürler olsun
   Sevgisi sonsuz Rab'be!
   // Kavuşturdu beni de
   Yeniden doğmuşlara.  //</lyrics>
<title>Yıllarca Günahımla TY90</title>
</song>