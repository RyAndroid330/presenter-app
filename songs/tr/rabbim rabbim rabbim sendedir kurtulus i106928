<?xml version="1.0" encoding="UTF-8"?><song><title>Rabbim Rabbim Rabbim sendedir kurtuluş</title>
<lyrics>[V1]
 Rabbim Rabbim Rabbim sendedir kurtuluş

[V2]
 // Gökten yıldızlar düşecek İsa Mesih gelecek //

[V3]
 // Allah bizi çok sevdi İsa Mesihi verdi //

[V4]
 // Çarmıhta İsa gerildi Günahlarımızı Yüklendi //

[V5]
 // Büyük müjde incilde Yaşam gerçek İsa'da //</lyrics>
</song>