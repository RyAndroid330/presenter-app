<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>53</hymn_number>
<author>Erol Özer</author>
<title>Kurtarıcım Mesih'tir TY53</title>
<lyrics>[V1]
.   Am                E                 Am
 // Kurtarıcım Mesih'tir, benim için O öldü. //
. Dm                 Am
 Ölümden O dirildi, Şeytan'a galip geldi.
. Dm                  E
 Ölümden O dirildi, Şeytan'a galip geldi.

[C1]
.     Am                E                  Am
   // Kurtarıcım Mesih'tir, benim için O öldü. //

[V2]
.   Am                E                  Am
 // Tahtı O'nun göktedir, tacımız elindedir. //
.Dm                     Am
 Gel, ey günahkâr O'na! Tam hayat verir Sana.
.Dm                     E
 Gel, ey günahkâr O'na! Tam hayat verir Sana.

[V3]
.   Am              E                    Am
 // Uyanık olman gerek, Mesih tekrar gelecek. //
.Dm                   Am
 Ümit olunca gerçek, müminler hep gülecek.
.Dm                   E
 Ümit olunca gerçek, müminler hep gülecek.

[V4]
.   Am              E                   Am
 // Gözyaşları silecek, elemler hep bitecek. //
.Dm                   Am
 Sonsuzluklar boyunca olacağız O'nunla.
.Dm                   E
 Sonsuzluklar boyunca olacağız O'nunla.</lyrics>
<key>Am</key>
</song>