<?xml version="1.0" encoding="UTF-8"?><song><title>Tanrım Beni Neden Terkettin</title>
<key>Am</key>
<lyrics>[V1]
.   Am              G                 F
 // Tanrım, Tanrım, beni neden terk ettin? //
.F                 E
 Niçin bana yardım etmekten
.Am          G
 Haykırışıma kulak vermekten
.F           E
 Uzak duruyorsun ya Rab

[V2]
.   Am            G
 // Ey Tanrım, gündüz sesleniyorum,
.F             E
 yanıt vermiyorsun bana
.Am            G                     F
 Gece sesleniyorum, yine rahat yok bana
.F                 E
 Tek Kaldım Burada Bir Başıma //

[C1]
.      Am                G
   /// Ama sen benden ya Rab
.    F             E
   Biran bile hiç uzak durma
.  Am                  G
   Bu Dertten Kurtar Beni
.     F                 E
   Seslendiğimde koş yardımıma ///</lyrics>
<author>Eren Atik</author>
</song>