<?xml version="1.0" encoding="UTF-8"?><song><title>Özledim Seni</title>
<key>Am</key>
<lyrics>[C1]
.  Am               Dm
   // Özledim seni,  Beklerim seni
.  Em             Am
    İsterim seni, Rab'bim //

[V1]
.Am
 // Sensin beni çağıran
.Em
  Sensin beni arayan
.Dm
  Sensin beni kurtaran
.F         G
  Efendim Rab'bim İsa //

[V2]
.Am
 // Mutluyum ben seninle
.Em
  Özgürüm sözlerinle
.Dm
  Güçlüyüm ben sevginde
.F         G
  Efendim Rab'bim İsa //

[V3]
.Am
 // Bağışlandım kanınla
.Em
  Aklandım ben Ruhunla
.Dm
  Aydınlandım sözünle
.F         G
  Efendim Rab'bim İsa //</lyrics>
<author>Bedros Mığdısı</author>
</song>