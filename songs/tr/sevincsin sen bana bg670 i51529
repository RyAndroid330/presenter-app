<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Sevinçsin sen bana,
 Benim canıma.
 Senin inayetine
 Mesih'te olayım. //

[C1]
   // Sevinç, sevinç var
   Sade Mesih'te.
   Esinlik, sevgi taşıyor
   Senin tahtından. //

[C2]
   // Brak sen kendini
   İsa'nın eline.
   Tatlı söylesin
   Kendi sözlerini. //

[C3]
   // Sadık köle ol
   Merhametli Baba'na.
   Sana teslim etsin
   Allahın gerçeyini. //</lyrics>
