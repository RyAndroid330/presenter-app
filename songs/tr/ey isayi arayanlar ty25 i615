<?xml version="1.0" encoding="UTF-8"?><song><title>Ey İsa'yı Arayanlar TY25</title>
<lyrics>[V1]
 Ey İsa'yı arayanlar,
 Umutları yok olanlar,
 //  Üzgün, dertli, kederliler,
 İsa Mesih dirilmiştir!  //

[C1]
   Melek gökten gönderildi,
   Mezar taşı kaldırıldı.
   //  İnsanlara müjdelendi,
   İsa Mesih dirilmiştir!  //

[C2]
   Sevinç size inanlılar!
   Müjde size günahlılar!
   //  Tüm evrene bildirilsin,
   İsa Mesih dirilmiştir!  //</lyrics>
<hymn_number>25</hymn_number>
<author>Ali Yazar</author>
</song>