<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>11</hymn_number>
<title>Git, O Koyu Bahçeye TY11</title>
<key>Em</key>
<lyrics>[V1]
.   Em      G        Em
 // Git, o koyu bahçeye
.Em    G         Em
 Denenmeye düşen can. //
.Em
 Bir an İsa'yla bekle;
.G
 Bak, sen O'nun haline.
.G                    Em
 Kanlı terler dökenden
.G            Em
 Dua etmeyi öğren.

[V2]
.   Em       G       Em
 // Bak, Golgota yoluna,
.Em   G          Em
 O dövülmüş, yaralı. //
.Em
 Ama yine insana
.G
 Derin sevgiyle bağlı.
.G                 Em
 Çarmıhı taşıyandan
.G               Em
 Nasıl taşıdı, öğren.

[V3]
.   Em       G       Em
 // Git, Golgota dağına,
.Em      G         Em
 Bak, o kurban İsa'ya, //
.Em
 Bütün insan uğruna
.G
 Akan suçsuz o kana.
.G                   Em
 Ve tamamdır diyenden
.G             Em
 Ölmesini de öğren.</lyrics>
</song>