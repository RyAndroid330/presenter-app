<?xml version="1.0" encoding="UTF-8"?><song><title>Kutsal Kan</title>
<lyrics>[V1]
 // Sen Tanrı'nın oğlu günahsız bir kuzuydun
 biz günah içindeyken çarmıhta sunu oldun
 Aklanıyor yürekler dökülen kutsal kanla
 lütuf bulur bu kanla yıkananlar //

[V2]
 // Rab İsa ne yüce bir adın var
 rabisa doyulmaz bir sevgin var
 adın bana sevinci umudu anlatıyor
 Rab İsa gel artık ey maranata //

[V3]
 // Biz layık değildik hiç Senin yüce ismine
 Merhametine yarab bize sonsuz sevgine
 Şimdi kötüden hiç korkmam çünkü sen benimlesin
 Sana şükürler olsun yürekler sevginle dolsun //</lyrics>
<author>Cihan Duman</author>
</song>