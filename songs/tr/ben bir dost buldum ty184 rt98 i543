<?xml version="1.0" encoding="UTF-8"?><song><title>Ben Bir Dost Buldum TY184 RT98</title>
<key>F</key>
<lyrics>[V1]
.Dm
 Ben bir dost buldum,
.A7            Dm
 Öyle bir dost ki!
 Kalbime giren,
 Beni affeden!

[C1]
.                Gm
   // Suç yükümü taşıyan,
.             Dm
   Borçlarımı ödeyen,
.            A7
   Sevgisini gösteren
.                  Dm
   Bir dost buldum ben. //

[V2]
.Dm
 Bu dost İsa'dır,
.A7         Dm
 Bambaşka İsa!
 Kurban edilen
 Tanrı kuzusu!

[C2]
.                Gm
   // Yaşam yolu gösteren,
.            Dm
   Günahları kaldıran,
.             A7
   Sevmeyi de öğreten
.                 Dm
   Dost buldun mu sen? //

[V3]
.Dm
 Gelin insanlar,
.A7           Dm
 Gelin bu dosta!
 O'nu çağırın,
 Sevinçle coşun!

[C3]
.                 Gm
   // Hastalıktan kaldıran,
.              Dm
   Ölüm bağını çözen,
.            A7
   Karanlığı alt eden
.            Dm
   Dostu çağırın! //</lyrics>
<hymn_number>184</hymn_number>
<author>Memduh Uysal</author>
</song>