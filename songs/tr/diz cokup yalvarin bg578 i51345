<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>578</hymn_number>
<title>Diz çöküp yalvarın BG578</title>
<lyrics>[V1]
 Diz çöküp yalvarın,
 El kaldırın, aalayın.
 // Çekinizi görüyorum
 Çilenizi yazıyorum. //

[V2]
 Sizin için, yavrum,
 Ben kanımı döktüm.
 // Günahlarınızı ben
 Çileylen taşıdım. //

[V3]
 Yıldızlar düşecek,
 Dünya bitkisi olacak.
 // Ben gelecem,
 Hepsinizi kurtaracam. //

[V4]
 Sizin günahlarınız
 Yaralarımı açıyor.
 // Sevgi, sevinciniz de,
 Yarama meylem oluyor. //

[V5]
 Evime toplanın,
 El ele tutunun.
 // Beraber sizi bulayım,
 Hepsinizi alayım. //

[V6]
 Uykudan uyanın,
 Aydınlıkta bekleyin.
 // Rüzgyarlan ben gelecem,
 Cennete uçuracam. //</lyrics>
</song>