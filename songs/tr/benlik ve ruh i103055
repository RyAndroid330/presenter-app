<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Benliğe Göre ben yaşıyorsam
 Benlikle ilgili işleri düşünürüm
 Buda bana ölüm ve yargı getirir //

[V2]
 Benliğin işleri her tür pislik sefahat putpereslik büyücülük ve benzeri işlerdir
 // Bunları yapan kişi yaşamı Miras alamaz //

[V3]
 // Ruhun izinden ben gidiyorsam
 Ruhla ilgili işleri düşünürüm
 Buda bana Yaşam Esenlik getirir //

[V4]
 Ruhun Meyvesi Sevgi Sevinç Esenlik sabır şevkat her tür iylik ve benzeri işlerdir
 // Bunları Yapan kişi Huzur ve Esenlik Bulacak //</lyrics>
<title>Benlik ve Ruh</title>
<author>Adil Yaşar</author>
</song>