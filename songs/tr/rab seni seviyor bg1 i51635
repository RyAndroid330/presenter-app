<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1</hymn_number>
<author>Hasan Civelek - Ferdi Jeko Dimitrov</author>
<key>C</key>
<lyrics>[V1]
.Am            G
 Rab seni seviyor
.Em               F
 Her derdini biliyor
.Am          G
 O seni iyi tanır
.Em               F
 sıkıntından kurtarır

[C1]
.  C
   Gel tapın Ona
.        G
   Rahat verir O sana
.     Em
   Olacak O her zaman
.  F            Am
   Derdine derman

[V2]
.Am            G
 Her zor durumda
.Em            F
 Çağır Onu duada
.Am            G
 Herşeyi Ona getir
.Em               F
 O sana cevap verir

[V3]
.Am               G
 Elemlere sen dayan
.Em               F
 Rab'le ol herzaman
.Am               G
 Gel tapın sen Ona
.Em                F
 Yaşam verir O sana</lyrics>
<title>Rab Seni Seviyor BG1</title>
</song>