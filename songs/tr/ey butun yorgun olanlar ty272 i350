<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Ey bütün yorgun olanlar,  //
 //  Yükleri ağır gelenler,  //
 //  Bana gelin çekinmeden  //
 //  Size rahat veririm ben.  //

[V2]
 //  Boyunduruğum' takının,  //
 //  Canlarınız rahat bulsun.  //
 //  Boyunduruğum kolaydır,  //
 //  Yüküm ise çok hafiftir.  //

[V3]
 //  Bana gelin ey yorgunlar,  //
 //  Hem de benden tam öğrenin.  //
 //  Ben yumuşak huyluyum,  //
 //  Hem de alçak gönüllüyüm.  //</lyrics>
<title>Ey Bütün Yorgun Olanlar TY272</title>
<author>Ali Yazar</author>
<hymn_number>272</hymn_number>
</song>