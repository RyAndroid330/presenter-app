<?xml version="1.0" encoding="UTF-8"?><song><title>Baba, Senin Sevgin TY444 TÇ6 RT4</title>
<key>G</key>
<lyrics>[V1]
.Em
 Baba, Senin sevgin ne
.   D
 kadar büyük ve derin!
.       C
 Sensiz nasıl yaşadığımı
.D        B7
 Anlayamam ki!

[V2]
.Em
 Şimdi Sen beni kurtardın,
.D
 Ben Senin çocuğun oldum,
.C
 Ve bütün yaşamımda
.   D           B7
 Seninle kalayım.

[C1]
.     Em   C
   // Seni öveceğim
.  D    G
   Sana tapacağım,
.  Em    Am       D
   Sonsuzlara dek,
.            B7  (Em)
   sevgili Babam.  //</lyrics>
<hymn_number>444</hymn_number>
<author>Ian Smale</author>
</song>