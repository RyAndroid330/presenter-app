<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.G
 Ne büyük ölçüde yaşamım değişti
.   C            G
 Kalbime gireli İsa!
 Çoktan özlediğim nur bol bol verildi
.   A            D
 Kalbime gireli İsa!

[C1]
.     G            G7
   Kalbime gireli İsa!
.      C           G
   Kalbime gireli İsa!
.                                 G7
   Canım sel gibi akan sevinçle coşar
.     D            G
   Kalbime gireli İsa!

[V2]
 Amaçsız ve sapık yolumu bıraktım
 Kalbime gireli İsa!
 Sayısız kötülüklerimden arındım
 Kalbime gireli İsa!

[V3]
 Kavuştum sarsılmaz ve sağlam umuda
 Kalbime gireli İsa!
 Artık yoktur şüphe bulutu yolumda
 Kalbime gireli İsa!

[V4]
 Ölüm deresi artık parlaktır bana
 Kalbime gireli İsa!
 Ve bakarım göksel kentin kapısına
 Kalbime gireli İsa!

[V5]
 O kentte konutum olacak bilirim
 Kalbime gireli İsa!
 Ben mutlu, çok mutlu, yoluma giderim
 Kalbime gireli İsa!</lyrics>
<title>Ne Büyük Ölçüde Yaşamım Değişti TY84</title>
<hymn_number>84</hymn_number>
</song>