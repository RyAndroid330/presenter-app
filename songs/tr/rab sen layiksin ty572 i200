<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>572</hymn_number>
<title>Rab Sen Layıksın TY572</title>
<key>A</key>
<lyrics>[C1]
.      A
   Rab sen layıksın,
.      D
   Rab sen layıksın,
.     A               E
   Ancak sen layıksın Rab,
.      A                D
   Rab sen layıksın bizden almaya,
.  A        E      A
   Yücelik, şükür, övgü!

[V1]
.   E                A
 Gökler, dünya ile denizi yarattın.
.   E                   A
 Sende istek, kudret vardır.
.             D              A
 Sen Rab layıksın bizden almaya
.         E        A
 Yücelik, şükür, övgü!

[V2]
.    E                 A
 Sen bizi kurtardın günah ve ölümden,
.  E                A
 Yeni yaşamı sağladın!
.             D              A
 Sen Rab layıksın bizden almaya
.         E        A
 Yücelik, şükür, övgü!

[V3]
.   E               A
 Bizleri Mesih'e benzer yapacaksın,
.   E                  A
 Kutsal Ruh'un yardımıyla!
.             D              A
 Sen Rab layıksın bizden almaya
.         E        A
 Yücelik, şükür, övgü!</lyrics>
</song>