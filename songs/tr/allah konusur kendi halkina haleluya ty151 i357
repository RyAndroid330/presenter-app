<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[C1]
.     Am                                 E
   // Allah konuşur kendi halkına, haleluya!
.                                   Am
   Hikmet, yaşam sözleriyle, haleluya! //

[V1]
 Açın fikrinizi, inananlar,
.               E
 Allah mesajlar veriyor
.Am
 Açın kalbinizi, soylu işçiler,
.Dm             E
 Rabbiniz konuşuyor!
.Dm             E
 Rabbiniz konuşuyor!

[V2]
 İnanan Mesih'e Gelsin
.            E
 Kulağı Olan işitsin.
.Am
 Hikmet yolunu Öğrensin,
.Dm               E
 Sonsuz yaşam edinsin
.Dm               E
 Sonsuz yaşam edinsin

[V3]
 İnanan Mesih'e koşuyor
.              E
 O'nu bulanlar coşuyor.
.Am
 Gerçekçi olan kişilerde
.Dm            E
 İsa Mesih yaşıyor!
.Dm            E
 İsa Mesih yaşıyor!</lyrics>
<title>Allah Konuşur Kendi Halkına, Haleluya! TY151</title>
