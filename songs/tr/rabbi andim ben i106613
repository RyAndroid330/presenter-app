<?xml version="1.0" encoding="UTF-8"?><song><author>Hüseyin Kumbe, Ahmed Muzafer</author>
<title>Rabbi Andım Ben</title>
<lyrics>[V1]
 // Rabbi andım Ben duamda
 İşitti sesimi O anında
 Diz çöküp af diledim
 Bağışla beni Rabbim dedim //

[C1]
   // Geçmişim nekadar Karanlık
   Günyah üstüne Günyahmiş
   Aldanmışım çok acıyımış
   Günyahım Bana zararlıymış //

[V2]
 // Tövbe edip bağırdım
 Her duamda ağladım
 Günahlarımı İtiraf edip
 Rabbe umut Bağladım //

[V3]
 // Rab Mesih Kapimi çaldı
 Karanlığımı aydınlattı
 Günyahlarimi silip bağışladı
 Beni yep yeni İnsan yaptı //</lyrics>
</song>