<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Son zamanlar geliyor
 Allahın son günü geliyor.

[V2]
 // Bizi alacak onunla bile
 Onunla beraber göklere //

[C1]
   // Gel Rabbim, gel İsa.
   Gel alasın sen bizi. //

[C2]
   Sonsuzca seni ben öveceyim
   Sevinecek canım seninle.
   // Sen benim yaşlarımı silecen.
   Bana sevincini verecen. //

[C3]
   O günde seni ben göreceyim
   Seninle beraber olacam.
   // Sana türküler söyleyecem. //
   Sana ben hamd edeceyim.</lyrics>
<title>Son zamanlar geliyor BG688</title>
<hymn_number>688</hymn_number>
</song>