<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ben senin aklınla
 yürüyom, İsa.
 Ben senin aklınla
 görüyom, İsa.
 Ben senin aklınla
 yaşayayım, İsa.
 Ver Rabbim, ver. //

[V2]
 // Diri suyunla
 suladın sen beni.
 Vergilerinle
 geldin sen bana.
 İncilinle doyurdun
 beni, İsa.
 Ver Rabbim, ver. //

[V3]
 // Sen benim aklım
 oldun, İsa.
 Sen benim fikrimde
 oldun, İsa.
 Sen benim hayatım
 oldun, İsa.
 Ver Rabbim, ver. //

[V4]
 // Geceleri sen koru
 beni, İsa.
 Gündüzleyin sen ol
 benimle, İsa.
 Sevindir her vakıt
 sen beni, İsa.
 Ver Rabbim, ver. //

[V5]
 // Ver bana sabırını
 sen, İsa.
 Tut beni imanda
 sen, İsa.
 Bul bizi duada
 sen, İsa.
 Ver Rabbim, ver. //</lyrics>
<title>Ben senin aklınla BG527</title>
