<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8</hymn_number>
<title>Çobanlar Geliyor, Müjde Veriyor TY8 TÇ27</title>
<key>D</key>
<lyrics>[V1]
.D       A7         D  A7     D
 Çobanlar geliyor, müjde veriyor
.D       A7         D  A7      D
 Davut'un şehrinde Mesih'im doğdu

[C1]
.     G        D          G        D
   // Beytlehem şehrinde yemlikte yatıyor
.   D      A7         D A7        D
   Sevinin, sevinin, Mesih'im doğdu!  //

[V2]
 Meryem'in Yusuf'un sonsuz sevinci,
 Melekler göklerde söyler ilahi

[V3]
 Söyleyin müjdeyi bütün dünyaya!
 Günahı kaldıran Kurtarıcımız</lyrics>
</song>