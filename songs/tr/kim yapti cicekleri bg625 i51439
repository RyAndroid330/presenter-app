<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>625</hymn_number>
<lyrics>[V1]
 Kim yaptı çiçekleri ?
 Kim çiyle suladı ?
 // Kim verdi kokuları ?
 Kim güzellik düzeltti ? //

[V2]
 Kim kuşlara kanatları
 Verdi yiyin uçsunlar ?
 // Kim öğretti, yuvayı
 Samandan kursunlar ? //

[V3]
 Karıncaya kim öğretti,
 Saklasın tohumları ?
 // Arılara da, bal etsin
 O güzel çiçeklerden ? //

[V4]
 Her şeyi sen yaptın,
 Allahım.
 Her şeyi sen düzelttin.
 // Kuşlar gökte uçsun diye,
 Sen kanat yaratmışsın. //

[V5]
 Sen yaptın mavi gökleri,
 Gündüzü ve de geceyi.
 // Sana şükürler bu yerden
 En ufak bir şey için. //</lyrics>
<title>Kim yaptı çiçekleri ? BG625</title>
</song>