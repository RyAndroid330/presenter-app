<?xml version="1.0" encoding="UTF-8"?><song><author>Rumen İliev</author>
<lyrics>[V1]
 // Sevgi dolu Allahımız
 Senden uzaklaşmak düşmektir
 Sana doğru dönmek kalkmaktır
 Senin önünde durmak
 Sonsuza dek yaşamaktır //

[V2]
 Ya'Rabb bütün işlerimize yardımını
 Sıkıntılarımıza rehberliğini
 Tehlikelerimizde korumnı
 Üzüntülerimize esenliğini
 // Rabbimiz Mesih İsa adıyla bağışla! //</lyrics>
<title>Sevgi Dolu Allahimiz</title>
</song>