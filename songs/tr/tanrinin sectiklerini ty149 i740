<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>149</hymn_number>
<title>Tanrı'nın Seçtiklerini TY149</title>
<lyrics>[V1]
 // Tanrı'nın seçtiklerini
 Kim suçlayabilir?  //
 // Tanrı'nın ta kendisi
 Bizi haklı çıkarır.  //

[V2]
 // Oğlunu esirgemedi,
 Ta ölüme verdi.  //
 // Böyle bizi kurtardı,
 Bizi ne kadar sevdi.  //

[V3]
 // Rab İsa ölüp dirildi,
 Babasına gitti.  //
 // Satın aldım der Mesih
 Senin seçtiklerini.  //</lyrics>
</song>