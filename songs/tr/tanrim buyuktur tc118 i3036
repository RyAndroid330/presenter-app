<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>118</hymn_number>
<key>F</key>
<lyrics>[C1]
.         F
   // Tanrım büyüktür, güçlü ve kuvvetli,
.     C7             F
   yapamayacağı şey yok. x x //
.  F
   Dağlar O'nundur, nehirler O'nun,
.     (Bb)                C7
   Gökleri de O yarattı. x x

[C2]
   Toprak O'nundur, sular da O'nun,
   Tohumları O yarattı.

[C3]
   Güneş O'nundur, yağmur da O'nun,
   Tohumları O büyüttür.

[C4]
   Atı yarattı, samanları da,
   Atlar asla aç kalmazlar.

[C5]
   Büyük ağaçları, tatlı muzları,
   Erikleri de yarattı.

[C6]
   Domatesleri, patatesleri,
   Biberleri O yarattı.

[C7]
   Karpuz ve kavun-ları yarattı,
   Sevinçle onları yeriz.</lyrics>
<title>Tanrım Büyüktür TÇ118</title>
</song>