<?xml version="1.0" encoding="UTF-8"?><song><title>Sizin için ben öldüm BG687</title>
<lyrics>[V1]
 // Sizin için ben öldüm,
 Kanımı size döktüm.
 İnanın yavrularım,
 Sizinle ben olayım. //

[C1]
   // Çarmıhta öldüm,
   Üçüncü gün dirildim.
   Sizin için çok aaladım,
   Sizi ben kurtarayım. //

[C2]
   // Şimdi gökte diriyim,
   İnanın, yavrularım.
   Yanıma geleseniz,
   Cenneti göreseniz. //</lyrics>
