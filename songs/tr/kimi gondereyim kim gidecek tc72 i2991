<?xml version="1.0" encoding="UTF-8"?><song><author>Hiltrud Ströhlein</author>
<hymn_number>72</hymn_number>
<key>D</key>
<lyrics>[C1]
.  D               A7       D
   Kimi göndereyim, kim gidecek?
.                 A7   D
   Rab bize sesleniyor.
.               D               A7 D
   Kimi göndereyim, kim gidecek?
.                  A7 D
   Rab bizi çağırıyor.
.                D
   Burdayım, beni gönder!
.                  A D A D
   Yaşamım senin olsun!
.                D
   Burdayım, beni gönder!
.               A7 D
   Senin olayım!
.  D                      A7    D
   Her şey tersine dönse? Yine de!
.  D                     A7   D
   İnsanlar karşı olsa? Yine de!
.  D
   Yine de giderim,
.    A D  A  D
   Ulusları çağrırım.

[V1]
.D
 Yine de giderim.
.A7           D
 Onlar da kurtulsunlar.

[V2]
 Sen beni donatırsın, şükrolsun!
 Beni yönlendirirsin, şükrolsun!
 Korkum yok, kuşkum yok,
 Beni yüreklendirdin.
 Korkum yok, kuşkum yok,
 Sana güvenirim.</lyrics>
<title>Kimi Göndereyim, Kim Gidecek? TÇ72</title>
</song>