<?xml version="1.0" encoding="UTF-8"?><song><author>Yaşar Atanasov</author>
<title>kendimi sana adadım</title>
<lyrics>[V1]
 Kendimi sana adadım
 Yalnızlıktan bıktım
 Umudum sendedir
 iman veren tek Allahsın
 Yaşam veren yaratansın

[V2]
 Koro:Ama sen benimlesin
.    
     Devamlı beni gözlersin
.    
     Sevgi dolu Allahımsın
.    
     Güven veren Yaratansın

[V3]
 Günden güne değişiyorum
 Senden başka sığınağım yok
 Günden güne anlıyorum
 İman etmek güvenmektir
 Şimdi artık biliyörum</lyrics>
</song>