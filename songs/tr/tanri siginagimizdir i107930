<?xml version="1.0" encoding="UTF-8"?><song><title>Tanrı sığınağımızdır</title>
<lyrics>[V1]
 // Ne müthiştir yüce Rabbim İsa mesihim
 Sağ eli zaferle dolu tanrımız bizim
 Sevinsin tüm kuzuların coşsun seninle
 Herşeye egemen kral Rabbim bizimle //

[V2]
 // Tanrı sığınağımızdır gücümüz bizim
 Yardımcım ve kurtarıcım İsa mesihim
 Hep sana övgüler olsun yücelik olsun
 Senin sevgin imanımız yolumuz bizim //</lyrics>
<author>Cihan DUMAN</author>
</song>