<?xml version="1.0" encoding="UTF-8"?><song><author>Davut Yasmin</author>
<hymn_number>497</hymn_number>
<lyrics>[V1]
.  Am       Em
 Affet beni Rab,
.  F         C
 Affet günahımı.
.   Dm           Am
 Önüne geldim şimdi Rab
.B7          E
 Kirli bir kuzu.

[V2]
.    Am        Em
 Sil gözyaşlarımı,
.    F        C
 Sil günahlarımı
.    Dm           Am
 Lekesiz bir kuzu olarak
.B7      E       Am
 Al beni de yanına.</lyrics>
<key>Am</key>
<title>Affet Beni Rab TY497</title>
</song>