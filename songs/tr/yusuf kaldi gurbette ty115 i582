<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>115</hymn_number>
<author>Ali Yazar</author>
<title>Yusuf Kaldı Gurbette TY115</title>
<lyrics>[V1]
.Em          B7
 Yusuf kaldı gurbette,
.Em          B7
 Uzun yıllar hapiste,
.   B          Am
 //  Söylenmedi, bekledi,
.C         B7
 Tanrı onu kurtardı. //

[V2]
.Em          B7
 Eyüp Rab'be güvendi,
.Em        B7
 Denenmeye dayandı,
.   B         Am
 //  Hastalığa sabretti,
.C          B7
 Kötü günde hamdetti. //

[V3]
.Em         B7
 Hatırlayın İsa'yı,
.Em       B7
 Hakarete uğradı,
.   B          Am
 //  Çarmıhtaki ölümü
.C          B7
 Bize yaşam sağladı. //

[V4]
.Em        B7
 Diri olan Mesihim,
.Em         B7
 İzlerinden giderim,
.   B         Am
 //  Sıkıntıda ümitle
.C         B7
 Dayanırım seninle. //</lyrics>
<key>Em</key>
</song>