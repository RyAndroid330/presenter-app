<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<lyrics>[V1]
 Merhameti lütfu bol olan, kuzu övülmeye layıktır
 // O suçumuzu kaldıran, Rab İsa hamda layıktır. //

[C1]
   // Rab'bi yüceltir dilimiz
   Rab sana tapınır yüreğimiz
   Kutsal Ruh'un sevinç verir
   Biz oynarız dans ederiz.
   Rab seni bize gönderen
   Göksel Baba'ya övgüler olsun
   Bizi sana layık gören
   Tanrı'ya şükürler olsun. //

[V2]
 O bizi kucaklayıp seven İblise karşı güç veren
 // Bize sonsuz yaşam veren Rab İsa hamda layıktır. //</lyrics>
<title>Merhameti Lütfu Bol Olan</title>
</song>