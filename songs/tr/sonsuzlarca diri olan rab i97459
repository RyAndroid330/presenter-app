<?xml version="1.0" encoding="UTF-8"?><song><title>Sonsuzlarca Diri olan Rab</title>
<lyrics>[V1]
 Sonsuzlarca Diri olan Rab tanrıma tapınırım
 // Kaybolmuştum beni buldu
 Mahfa giden yoldan //

[V2]
 Canım Rabbi Yüceltir
 Ruhum hamt yükseltir ona
 // Kurtarışı mükemmeldir
 Biz olan insanlara //

[V3]
 Yetki görkem güç sahibi
 Tanrı sesleniyor bize
 // Herkez davetlidir diyor
 Bu büyük şölene //</lyrics>
<author>Adil Yaşar</author>
</song>