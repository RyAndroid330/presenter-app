<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Gelin, gelin kardeşler,
 Hep beraber biz olalım.
 Hep beraber yalvaralım,
 Beraber göke varalım. //

[C1]
   Şükür olsun Allaha,
   Şükür edelim,
   Allahı sevindirelim.
   Şükür olsun Allaha,
   Şükür edelim,
   Hepsini sevindirelim.

[C2]
   // Gelin, gelin kardeşler.
   Çok, çok kalaba gelin.
   Allahımızı övelim,
   Allahı sevindirelim. //

[C3]
   // Benim zayıf kullarım,
   Onlara darılmayalım.
   Allahın kuvvetinlen,
   Onlara dayak olalım. //

[C4]
   // Diz çöküp isteyelim,
   Verecek O, bekleyelim.
   Allahımın verdiyine
   Hepsimiz sevinelim. //

[C5]
   // Gelin, gelin kardeşler.
   Çok kalaba olalağım.
   Allahın kuvvetiylen
   Şeytanı ezelim. //</lyrics>
<title>Gelin, gelin kardeşler BG556</title>
