<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>308</hymn_number>
<title>Ey Rab İsam, Bana Gel! TY308 RT16</title>
<key>Em</key>
<lyrics>[V1]
.Em     B          Em
 Ey Rab İsam, bana gel!
. G            D    G
 Sen benim rehberim ol.
.B               Em
 Canım Senin elinde,
.B      B7       Em
 Ey sevgili Rab İsam.

[C1]
.     G           Am
   // Gelişine susadım, (eko)
.   D7          G
   Huzuruna susadım. (eko)
.  Em              B
   Yalvarırım, Rab İsam, (eko: yalvarırım)
.   B7                Em
   Hep benim rehberim ol.  //

[V2]
.Em       B       Em
 Kalbim' açmayacağım,
. G        D       G
 Kimse' koymayacağım.
.B              Em
 Tek Seni istiyorum,
.B     B7          Em
 Ey haçlanmış Rab İsam.

[V3]
.Em    B      Em
 Sana güveniyorum.
. G           D    G
 Her şeyde önderim ol.
.B               Em
 Kalbimde egemen ol,
.B      B7       Em
 Ey sevgili Rab İsam.</lyrics>
</song>