<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>679</hymn_number>
<title>Seni arıyorlar, sana, Allah BG679</title>
<lyrics>[V1]
 Seni arıyorlar, sana, Allah,
 Diz çöküyorlar,
 Şükür, şükür, Allahım, sana.

[C1]
   İncilini ben okuyom.
   Senin gönlünü yapıyom.
   Şükür, şükür,
   Allahıma, Aleluya.

[C2]
   Allah, senden istiyom,
   Hayatım gönlünce olsun.
   Şükür, şükür, Rab İsam, sana.

[C3]
   Allah, senden istiyom,
   Gökleri bana açasan.
   Şükür, şükür, Rab İsam, sana.</lyrics>
</song>