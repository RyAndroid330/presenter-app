<?xml version="1.0" encoding="UTF-8"?><song><author>Randy Rothwell</author>
<hymn_number>440</hymn_number>
<lyrics>[V1]
.Am
 Rab'bin görkemli sesi duyulacaktır
.                     E
 Ve yüreğim ezgi söyleyecek

[V2]
 Rab'bin dağına gelip
.                    Am
 &quot;Onun gücünü gör&quot; diyecek

[C1]
   Rab'bimiz ne güçlüdür
.                   E
   Rab'bimiz ne güçlüdür

[C2]
   Sözünün gücünde sesi duyulacak
.                   Am
   Rab'bimiz ne güçlüdür

[V3]
 Körlerin gözleri açılacak
 Sağırlar işitecek
 Sakatlar geyik gibi zıplayacak
 Dilsizler ezgi söyleyecek.</lyrics>
<key>Am</key>
<title>Rab'bin Görkemli Sesi Duyulacaktır TY440</title>
</song>