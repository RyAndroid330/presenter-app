<?xml version="1.0" encoding="UTF-8"?><song><title>Yalnız gezerdim, kendimi bilmezdim BG720</title>
<lyrics>[C1]
   Yalnız gezerdim, kendimi bilmezdim.
   // Üvey baba elinde çok çileliydim. //

[C2]
   Allahım, Allahım,
   // Sensin benim yardımcım.
   Hem kurtarıcım. //

[C3]
   Çok hastaydım ben, kendimi bilmezdim.
   // Allah beni düzeltti, hepsini affetti. //

[C4]
   Çok hastaydım ben, çok yalnızdım ben.
   // İsa bana eş oldu, hem kardeş oldu. //

[C5]
   Yalvar İsa'ya, o işitecek.
   // Er geç size gelecek, eger beklerseniz. //</lyrics>
<hymn_number>720</hymn_number>
</song>