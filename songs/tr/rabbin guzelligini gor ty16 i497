<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16</hymn_number>
<author>Graham Kendrick</author>
<key>C</key>
<lyrics>[V1]
.G          C         G    C G
 Rab'bin güzelliğini gör, (eko)
.          C          G    C Em
 Güzel çehresine bir bak. (eko)
.                     C     Em
 Bak kurban olan kuzuya, (eko)
.                  C     Em
 Adın yazılı avcunda. (eko)
.                   G     Em
 Acımız kalbini deldi. (eko)
.                 Cmaj7 Em
 Gururumuzun simgesi, (eko)
.   F     D  F D
 Dikenli taç.

[V2]
.G       C          G    C G
 Günahları üstlenirken, (eko)
.           C           G    C Em
 Kalbinden sırf sevgi akar. (eko)
.                   C      Em
 Dudaklarında adım var, (eko)
.                  C      Em
 Cezamın yükünü taşır. (eko)
.                     G     Em
 Bu sevgi beni şaşırttı. (eko)
.                     Cmaj7 Em
 Kurbanı beni hür kıldı. (eko)
.   F      D
 Hayat buldum!</lyrics>
<title>Rab'bin Güzelliğini Gör TY16</title>
</song>