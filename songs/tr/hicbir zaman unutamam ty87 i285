<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>87</hymn_number>
<author>Erol Özer, Ali Yazar</author>
<lyrics>[C1]
   Hiçbir zaman unutamam
   Rab'bin iyiliklerini.
   Coşar kalbim sevinç ile
   Düşündükçe sevgisini.
   Coşar kalbim sevinç ile,
   Tanrımın kayrası ile.

[C2]
   //  Kardeş, nasıl unutayım
   Çamurdan çıkarışını.
   Coşar kalbim sevinç ile
   Düşündükçe sevgisini.  //

[C3]
   //  Ne kötüydü eski yaşam!
   Sevgi, sevinç neredeydi?
   Boşa geçti hep günlerim,
   Benliğim de mutsuz idi.  //

[C4]
   //  Ne güzelmiş yeni yaşam
   Mesih'in sevgisi ile!
   Gerçek yol ve sonsuz yaşam
   Söz verildi İsa ile.  //</lyrics>
<title>Hiçbir Zaman Unutamam TY87</title>
</song>