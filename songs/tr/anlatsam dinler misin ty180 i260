<?xml version="1.0" encoding="UTF-8"?><song><author>Memduh Uysal</author>
<hymn_number>180</hymn_number>
<lyrics>[V1]
.   Bm
 // Anlatsam dinler misin?
.Em
 Yoksa lanet mi edersin?
.D               C
 Anlatayım da dinle,
.D            C     Bm
 Sen de kavuş esenliğe. //

[C1]
.  Em                D
   Tanrı sevdi seni, bu haber hep aynı,
.  Bm                    D
   Günahından seni kurtardı.
.  D                C
   Kurtuluş sunmaya atadı Mesih'i,
.  C         D         Bm
   Açmalısın O'na kalbini.

[V2]
.   Bm
 // Kulak verdin mi bu söze?
.Em
 Bu haber tüm hepimize.
.D                C
 Şimdi gelin Mesih'e,
.D          C         Bm
 Katılın gökteki sevince. //</lyrics>
<key>Bm</key>
<title>Anlatsam Dinler Misin? TY180</title>
</song>