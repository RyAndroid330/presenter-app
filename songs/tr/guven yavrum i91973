<?xml version="1.0" encoding="UTF-8"?><song><author>Adil Yaşar</author>
<title>Güven Yavrum</title>
<lyrics>[V1]
 // Güven yavrum güven bana her zaman seninleyim her zaman sana desteğim //

[V2]
 // Al beni yaralı elerine rab isa her zaman benimle ol herzaman ve beni kayır //

[V3]
 // Göz yaşlarımız dinecek bir gün acılarımız sona erişecek hep beraber rab bin olacağız cennete seninle sevineceğiz //

[V4]
 // Mutlu günler çok yakında inan yavrum inan buna gelişim çok tez //

[V5]
 // hazırla beni rab bim sana uygun et beni Her Zaman ayık tut beni ve sana sadık //</lyrics>
</song>