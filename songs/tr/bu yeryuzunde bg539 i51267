<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Bu yeryüzünde
 Nereye gideyim,
 İlahi söyleyim,
 Allahı arayım? //

[C1]
   // A a a, Rabbim sevgilim,
   A a a, Rabbim kuvvetli,
   A a a, Aleluya. //

[V2]
 // Bizi çok sevdi, İsa Rabbim,
 Haca teslim bize oldu. //

[V3]
 // İsa Mesih'te benim şifam,
 Odur bana gökte çoban. //

[V4]
 // Gel, Rabbim İsa, al bizi sen,
 Rahatına götür bizi. //</lyrics>
<title>Bu yeryüzünde BG539</title>
<hymn_number>539</hymn_number>
</song>