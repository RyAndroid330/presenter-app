<?xml version="1.0" encoding="UTF-8"?><song><title>Gücü Her Şeye Yeten Rab Tanrı</title>
<lyrics>[V1]
 // Gücü Her Şeye Yeten Rab Tanrı
 Senin İşlerin Büyük
 Ve şaşılacak işlerdir Ey Ulusların Kralı //

[V2]
 // Rab Senden Korkmayıp
 Adını Yüceltmeyecek Olan kim Var?
 Çünkü Kutsal Olan Yalnız sensin Rab İsa //

[V3]
 // Ey Tanrımızın Bütün Kulları
 Küçük Büyük Ondan
 Korkan Hepiniz Onu siz övün ona siz Tapının //</lyrics>
</song>