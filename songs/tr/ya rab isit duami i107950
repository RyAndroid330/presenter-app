<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ya Rab işit duamı, yalvarmama kulak ver. //
 // Açtım sana elimi, duy kabimin sesini. //

[V2]
 // Canım kurak yer gibi, susamıştır Rab Sana. //
 // Yüreğim ezilmekte, bir yanıt ver Rab bana. //

[V3]
 // Yüzünü örtme bana, güveniyom Rab Sana. //
 // Sabah duyur kayranı, bildir bana yolunu. //

[V4]
 // Doğruluk diyarında, yolunu göster bana. //
 // Kaldır beni ayağa, Ya Rab adın uğruna. //</lyrics>
<title>Ya Rab işit duamı</title>
</song>