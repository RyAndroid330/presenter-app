<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>657</hymn_number>
<lyrics>[C1]
   // Rabbim bizi çok sevdi,
   Gökyüzünden o indi,
   Yeryüzünde yaşadı.
   Tanrı'yı açıkladı. //

[C2]
   // İmanuel doğdu dünyaya.
   Bizi kurtarsın günahtan.
   İmanuel, İmanuel,
   Yücedir o, dünyada. //

[C3]
   // Çok çekiler o çekti,
   Günahları yüklendi.
   Bizim için o öldü,
   Üç gün sonra dirildi. //

[C4]
   // Büyük müjde İncilde,
   Yol ve yaşam İsa'da.
   Herkes duysun, öğrensin,
   Kurtuluşumuz Mesih'te. //</lyrics>
<title>Rabbim bizi çok sevdi BG657</title>
</song>