<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>537</hymn_number>
<key>D</key>
<lyrics>[C1]
.  D            G
   Güçlü Tanrı, Galip Olan,
.                    D
   Ordular Rabbi'dir O,
.             G
   Önderimiz, savaştığımızda,
.                       D
   Şeytan'ı yeneriz, kutsal adında.

[V1]
.                   A
 Bu yerde Şeytan'ın yetkisi yok,
.               D
 Hiçbir yetkisi yok!
.      G
 Çünkü Rab'bin gücü bur'da,
.    D
 Tam aramızdadır,
.   G             A  D
 Onun hiçbir yetkisi yok.

[V2]
.                 A
 Bu yerde İsa'nın yetkisi var,
.                D
 Tam bir yetkisi var!
.      G
 Çünkü Rab'bin gücü bur'da,
.    D
 Tam aramızdadır,
.     G             A  D
 O'nun tam bir yetkisi var.</lyrics>
<title>Güçlü Tanrı, Galip Olan TY537</title>
</song>