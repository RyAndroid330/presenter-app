<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>75</hymn_number>
<author>Jürg Heusser, Ali Yazar</author>
<lyrics>[V1]
.Em
 Canım köle pazarında
.Am        D     Em
 Umutsuzdu, perişandı.
.   Am
 // Beni sevdin, satın aldın,
.G            D          Em
 Rabbim sensin, Rabbim sensin. //

[V2]
.Em
 Günah zincirinden çözdün,
.Am          D         Em
 Özgür ettin, hayat verdin.
.   Am
 // Utancımı sen kaldırdın,
.Em            D           Em
 Rabbim sensin, Rabbim sensin. //

[V3]
.Em
 Beni sana asker yazdın,
.Am          D       Em
 Mesih sensin komutanım.
.   Am
 //  Önden giden paşam sensin,
.Em            D          Em
 Rabbim sensin, Rabbim sensin. //</lyrics>
<key>C</key>
<title>Canım Köle Pazarında TY75</title>
</song>