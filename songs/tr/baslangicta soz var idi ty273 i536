<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>273</hymn_number>
<lyrics>[V1]
 // Başlangıçta Söz var idi,
 Söz Tanrı'nın kendisiydi.  //
 // O'nsuz hiçbir şey olmadı,
 Her şey O'nun ile oldu.  //

[V2]
 // Yaşam O'nun kendisiydi
 Ve insanların ışığı;  //
 // Işık karanlıkta parlar
 Karanlık O'nu bilmedi.  //

[V3]
 // İnsan aydınlansın diye
 Işık dünyamıza geldi.  //
 // Aramızda konut kurdu,
 Dünya görkemiyle doldu.  //

[V4]
 // O'nu kabul edenlere,
 Yaşamına alanlara  //
 // Gerçek Tanrı çocukları
 Olma yetkisini verdi.  //</lyrics>
<title>Başlangıçta Söz Var İdi TY273</title>
</song>