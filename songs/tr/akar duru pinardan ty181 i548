<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em             Am
  Akar duru pınardan
.                  G
 Taze sular durmadan.
.                      F
 Gel, ey susamış insan,
.Dm               G  Em
  Yaşam suyudur akan.

[V2]
.Em                  Am
  Yaşam veren bu pınar
.                    G
 Gökten inen İsa'dır.
.                   F
 Bezgin canı diriltir,
.Dm                G  Em
  Sonsuz yaşamı verir.

[V3]
.Em            Am
  Köle isen günaha,
.                G
 Özgürlük verir İsa.
.                   F
 Kırar günah gücünü,
.Dm           G      Em
  Bağışlar suçlarını.

[V4]
.Em                    Am
  Sen de gel bu pınara,
.                   G
 İç ondan kana kana.
.                      F
 Hamdet her zaman O'na,
.Dm              G    Em
  İsa'dan hiç ayrılma.</lyrics>
<key>C</key>
<title>Akar Duru Pınardan TY181</title>
<hymn_number>181</hymn_number>
<author>Ali Yazar</author>
</song>