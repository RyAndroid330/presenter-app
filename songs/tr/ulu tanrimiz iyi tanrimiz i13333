<?xml version="1.0" encoding="UTF-8"?><song><title>Ulu Tanrımız, İyi Tanrımız</title>
<key>Dm</key>
<lyrics>[V1]
.Giriş: Dm C Bb A
  
.Dm                C   Bb
  // Görkem hüküm sürene
.            C     Dm
 Övgü tahtta oturana
.           C       Bb
 Onur harikalar yapana
.                     A
 Ne ulusun, Tanrı! //
 Ne ulusun!

[C1]
.  Dm               C        Bb
   Gökleri övgüyle dolduracağız
.                   A         Dm
   En yüce hamtları yükselteceğiz
.                  C         Bb
   Seni her şeyden çok seveceğiz
.           A               Dm (veya Bb - en son)
   Ulu Tanrımız, iyi Tanrımız__
.            A               Dm
   (Ulu Tanrımız, iyi Tanrımız)

[V2]
.Dm             C     Bb
  // Görkem ölümü yenene
.              C     Dm
 Övgü bizi güçlü kılana
.              C       Bb
 Onur 'Benimsiniz' diyene
.                     A
 Ne iyisin, Tanrı! //
 Ne iyisin!

[B1]
.  Bb                      Dm               C         Bb
    // Yüce adın yayıldıkça, Krallar Kralı, Rabler Rabbi
.  (Bb)                      A
   Övgüler de dünyanın dört bucağında artıyor //</lyrics>
