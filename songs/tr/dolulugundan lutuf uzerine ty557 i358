<?xml version="1.0" encoding="UTF-8"?><song><title>Doluluğundan Lütuf Üzerine TY557</title>
<key>Em</key>
<lyrics>[C1]
.      Em          Am
   //  Doluluğundan lütuf üzerine
.  B7             Em
    Hepimiz lütuf aldık.  //

[V1]
.              Am
 Lütuf, lütuf Babamızdan
.B7        Em   B7
 Yaşamımı doldursun.
.Em            Am
 Lütuf, lütuf Babamızdan
. B7              Em
 İsa Mesih'le geldi.

[C2]
.      Em          Am
   //  Doluluğundan sevgi üzerine
.  B7             Em
    Hepimiz sevgi aldık.  //

[V2]
.              Am
 Sevgi, sevgi Babamızdan
.B7        Em   B7
 Yaşamımı doldursun.
.Em           Am
 Sevgi, sevgi Babamızdan
. B7              Emin
 İsa Mesih'le geldi.

[V3]
 Sevinç...

[V4]
 Huzur...</lyrics>
<hymn_number>557</hymn_number>
</song>