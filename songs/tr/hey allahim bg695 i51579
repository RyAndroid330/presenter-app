<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>695</hymn_number>
<lyrics>[C1]
   // Hey Allahım,
   Çok sevdim seni.
   Yüzünü görmeden
   İnandım sana. //

[V1]
 // Şükür senin adına.
 Şükür senin kanına.
 Koy sevaplı elini
 Benim başıma. //

[C2]
   // Yıka beni, Allahım,
   Kuvvetli suyunla.
   Yıka beni, Allahım,
   O temiz kanınla. //

[C3]
   // Ellerimi kaldırdım,
   Sana duamı verdim.
   Ben sana yemin ettim,
   Seninle olayım. //

[C4]
   // Ver bana şifa, Allahım,
   Şifanı bulayım.
   Ver bana sevinç, Allahım,
   Sevinçli olayım. //

[C5]
   // Koru beni, Allahım,
   Son güne kadar.
   Affet beni, Allahım,
   Son güne kadar. //</lyrics>
<title>Hey Allahım BG695</title>
</song>