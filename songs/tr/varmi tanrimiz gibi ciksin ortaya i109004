<?xml version="1.0" encoding="UTF-8"?><song><author>Mustafa Abidov</author>
<key>Am</key>
<lyrics>[V1]
.Am         Em  F    G       Am
 Tanrım, Tanrım Sana yalvarırım,
.Am         Em  F    G      Am
 Tanrım, Tanrım Sana yaklaşırım.
.   Dm             G
 // Kime gideyim? Kime söyleyeyim?
.F       Dm       Am
 Derdimi bilen Sensin //

[C1]
.  Am           G
   Kötü günümde yanımdasın,
.  Dm      F              Am
   Sıkıntı günümde bırakmasın.
.  Am                   G
   Korkma çocuğum Sen dedin,
.  Dm     F            Am
   Yanına gelecem Ben senin.

[C2]
.     Dm
   // Nasıl sevmem Seni?
.  G
   Nasıl övmem Seni?
.  F     Dm         Em
   Varmı Tanrımız gibi? //
.  F          Am
   Çıksın ortaya.

[V2]
 Geldin, geldin Sen beni çok sevdin,
 Geldin, geldin Sen cevap verdin.
 // Kime gideyim? Kime söyleyeyim?
 Her şeyi bilen Sensin //</lyrics>
<title>Varmı Tanrımız Gibi? Çıksın Ortaya</title>
</song>