<hymn_number>344</hymn_number>
<title>Maranata, Maranata TY344</title>
<lyrics>[V1]
 //  Maranata, maranata,  //
 //  Gel, ya Rab İsa, bize gel!  //
 //  Maranata, maranata,
 Gel, ya Rab İsa, haleluya!  //
 Haleluya, haleluya,
 Haleluya, amin.
 Maranata, maranata,
 Amin.</lyrics>
</song>