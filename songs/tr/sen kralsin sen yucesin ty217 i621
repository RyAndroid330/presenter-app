<?xml version="1.0" encoding="UTF-8"?><song><title>Sen Kralsın, Sen Yücesin TY217</title>
<lyrics>[V1]
 //  Sen Kralsın, sen yücesin,
 Rabbim ve Kurtarıcımsın.  //
 //  Kapalı olan kalbimi
 Sana açan, İsam sensin.  //

[V2]
 //  Sen Kralsın, sen yücesin,
 Rabbim ve Kurtarıcımsın.  //
 //  Kutsal Ruhunla doldurup
 Beni yükselten, İsam sensin.  //

[V3]
 //  Sen Kralsın, sen yücesin,
 Rabbim ve Kurtarıcımsın.  //
 //  Sen yaşamsın, sen gerçeksin,
 Ekmeğim, diri suyumsun.  //

[V4]
 //  Sen Kralsın, sen yücesin,
 Rabbim ve Kurtarıcımsın.  //
 //  Tapınırım, tapınırım,
 Rab İsam, sana tapınırım.  //</lyrics>
<author>Antalyalı Selahattin</author>
<hymn_number>217</hymn_number>
</song>