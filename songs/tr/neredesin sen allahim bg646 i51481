<?xml version="1.0" encoding="UTF-8"?><song><title>Neredesin, sen Allahım ? BG646</title>
<lyrics>[V1]
 // Neredesin, sen Allahım ? //
 İşit beni, sen Allahım.
 // Zor haldeyim, gel
 gıor beni. //
 // Vur kapımı, ben açayım. //

[V2]
 // Açıp da sana bakayım. //
 // Söyle derdini sen bana. //
 Yardımcıyım, yavrum, sana.
 // Yardımcıyım, kuzum, sana. //

[V3]
 // Kaldır ellerini bana. //
 Yardımcıyım, yavrum, sana.
 // Yardımcıyım, kuzum, sana. //
 // Neredesin, deme bana ! //

[V4]
 Hepsinizi görüyorum.
 // Hepsinizi yazıyorum. //
 // İsa Mesih davet etti. //
 // Herkese iman inan verdi. //

[V5]
 // Size ruhumu eyledim. //
 Size şifalar verdim.
 // Size cennet eyledim. //</lyrics>
<hymn_number>646</hymn_number>
</song>