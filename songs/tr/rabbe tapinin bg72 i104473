<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ya RAB bütün varlığımla sana yaklaşıyorum, Tanrım ben sana güveniyorum //

[V2]
 Çünkü beni kurtaran tanrı sensin
 Sana umut bağlayan hiç utançla duşmez.

[V3]
 // Ey ilahi varlıklar Rabbi övün
 Onun guçunu yüceliğini görün
 Kutsal giyisiler içinde
 Rabbe tapının onu övun //

[V4]
 Ya rab sevgin göklere
 Gök yüzüne etişir
 Doğruluğun ulu dağlara benzer

[V5]
 Bizi kurtaran tanrı rab Mesih
 Sana umut bağlayan hiç utanca duşmez.

[V6]
 // Ey ilahi varlıklar, Rabi övun,
 Onun gücünu yüceliğini görun
 Kutsal giyisiler içinde
 Rabe tapının onu övün //</lyrics>
