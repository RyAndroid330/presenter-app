<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>703</hymn_number>
<lyrics>[V1]
 // Çok bekledim ben seni.
 Şimdi sen beni buldun. //
 // Sen yeni insan oldun.
 Beni nasıl unuttun ? //

[V2]
 // Bensiz sen duramazdın.
 Beni nasıl unuttun ? //
 // Ben seni çok severdim.
 Şimdi sen benim oldun. //

[V3]
 // Benim İsa Mesihim,
 Benim güzel Allahım. //
 // Çok çileye dayandın,
 Günahımı yüklendin. //

[V4]
 // Kalbimizi biliyorsun.
 Sen bizi görüyorsun. //
 // Seni seven çok oldu,
 İnançların az oldu. //

[V5]
 // Koruyun kendinizi,
 Her gün hazırda olun. //
 // Anlamadan gelecem.
 Ben sizi alacam. //

[V6]
 // Korkma, yavrum, gel beri.
 Seviyorum ben sizi. //
 // Affedecem hepsinizi.
 Cennette bile olalım. //

[V7]
 // Sayama siz toplanın.
 Ben size çoban oldum. //
 // Suyunuzdan geçin siz,
 Kutsal Ruh'u vereyim. //</lyrics>
<title>Çok bekledim ben seni BG703</title>
</song>