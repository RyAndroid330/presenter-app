<?xml version="1.0" encoding="UTF-8"?><song><title>Ne zaman ben düşsem</title>
<capo>3</capo>
<key>Fm</key>
<lyrics>[C1]
.  Dm       Am
   Ne zaman ben düşsem
.   Dm    Am
   Yolumu şaşırsam,
.  C      Em
   Sen tutarsın beni,
.   Am    C      Em
   Aşırtırsın yükseklerden.

[C2]
.  Em       F
   Felaket geçinceye dek,
.   Dm          Em
   Kanatlarının altında.
.  Em       F
   Fırtına dinene dek,
.   Dm            Em
   Sığınırım huzuruna.

[C3]
.  C             Em   Dm              Em
   Beklerim Yaşarım, İmanımı artır Rab İsa.
.   C          Em    Dm               Em
   Yolunu gözlerim, Gel ya Rab Maranata.</lyrics>
<author>Liza Kuşoğlu</author>
</song>