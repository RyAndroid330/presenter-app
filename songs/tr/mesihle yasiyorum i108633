<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[V1]
.   Gm                Eb
 // Günahın değil Mesihin özgürü oldum
.     Cm                 Eb      D
 Dünyanın değil Rabbin çocuğu oldum
.   F            Eb Dm Cm
 Ve artık ben yaşamıyorum
.Cm       Cm6    D4
 Mesih bende yaşıyor //

[C1]
.         Eb                    F         Bb
   // Ben Mesih'le birlikte çarmıha gerildim
.     Eb                   F        Bb
   Ve Mesih'le birlikte vaftizde öldüm
.          Cm                Gm
   Ve Mesih'le birlikte dirildim
.         Cm                Gm
   Ve onunla birlikte yaşıyorum //
.         D         Gm
   yaşıyorum, yaşıyorum

[V2]
.          Gm            Eb
 // Ben gerçek evime,yuvama geri döndüm
.        Cm             Eb    D
 Kaybolmuştum ama İsa beni buldu
.F              Eb   Dm  Cm
 Beni buldu ölümden kurtardı
.Cm        Cm6        D4
 Bana sonsuz yaşam verdi //</lyrics>
<title>Mesih'le Yaşıyorum</title>
<author>Mikerem Drumeva</author>
</song>