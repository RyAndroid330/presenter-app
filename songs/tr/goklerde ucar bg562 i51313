<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>562</hymn_number>
<title>Göklerde uçar BG562</title>
<lyrics>[V1]
 // Göklerde uçar
 Bir melek gibi,
 Yerlerde açar,
 Bir çiçek gibi. //

[C1]
   Allahım, Allahım,
   Rabbim, Babacım,
   Allahım, Allahım
   İsa Rabbicim.

[V2]
 // Nereye gitsem
 Aklımdasın.
 Gece gündüz sen
 Aklımdasın. //

[V3]
 // Sen üzelsin,
 Güvercin gibi.
 Dilim öter,
 Bir bülbül gibi. //</lyrics>
</song>