<?xml version="1.0" encoding="UTF-8"?><song><title>Rab İhtiyacım Var TY555</title>
<lyrics>[V1]
.C       G        Am
  Rab ihtiyacım var,
. Dm     G
 Sana muhtacım.
.C        G         Am
 Ya Rab, merhamet göster.
. Dm      G    Dm
 Affet, beni affet
.  G          C
 Ve temiz olurum.

[V2]
.Am  Dm        G         C
 Ya Rab, yollarımı bilirsin,
.Dm                 G
 Hiçbir şey gizleyemem.
.Am  Dm         G        C
 Ya Rab, günlerimi bilirsin,
.    Dm             G
 Yaşamımı sana veririm.</lyrics>
<key>C</key>
<hymn_number>555</hymn_number>
</song>