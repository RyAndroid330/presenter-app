<?xml version="1.0" encoding="UTF-8"?><song><author>Durmuş Tünel</author>
<lyrics>[V1]
 Günah işlediğimde,
 İmanımı yargılama.
 Yabancı değilim ben,
 Kardeşinim unutma!
 // Suçluysam gözün yumma.
 Göster günahım bana. //

[C1]
   // Nerde benim suçum nerde?
   Nerde benim hatam nerde?
   Gösterin günahlarımı,
   Tövbe edeyim, tövbe. //

[V2]
 Günah işlediğimde,
 Kardeşim uyarırsa,
 Ya Rab yumuşak huyla,
 Kabullenmemi sağla.
 // Kır gururu kalbimden,
 At kibiri gönlümden. //</lyrics>
<title>Günah işlediğimde</title>
</song>