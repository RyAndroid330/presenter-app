<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>664</hymn_number>
<lyrics>[V1]
 // Sade sen, İsa,
 Benim kayamsın.
 O tatlı adın
 Aldı kahrımı. //

[C1]
   Şükürler, övgüler
   olsun İsa'ya.
   Şükürler, övgüler
   Baba Tanrı'ya.

[C2]
   // Sana güvendim,
   Kalbimi verdim.
   Beni götür sen
   Aydınlığına. //

[C3]
   // Sen kullan beni,
   Kendi elinle,
   Uygun olayım,
   Sana ey Babam. //

[C4]
   // Kalbimi pakla,
   Senin kanınla.
   Sonsuz hayat ver,
   Bütün canlara. //</lyrics>
<title>Sade sen, İsa BG664</title>
</song>