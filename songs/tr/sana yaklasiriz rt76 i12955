<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>76</hymn_number>
<author>Ümit Tokgöz</author>
<aka>Esenliğin Gelsin</aka>
<key>G</key>
<lyrics>[V1]
.        Em
 // Sana yaklaşırız
.    Bm
 Önünde alçalırız
.    Am
 Günahımızdan döner
.     C    B7
 Yüzünü ararız //

[P1]
.        Am      Bm
   Sesimizi işit bizi affet
.        F          B7
   Sesimizi işit ve bize şifa ver

[C1]
.      Em
   Esenliğin gelsin
.      C
   Sevgin dökülsün
.        D        Bm      Em
   Kurtuluşun aksın ülkemize
.      Em
   Müjden duyulsun
.        C
   Yürekler açılsın
.    D         Bm       Em
   Adın yücelsin ülkemizde

[B1]
.          Am         D
   // Adın uğruna ya Rab
.  Bm          Em
    Sesimizi işit
.  C            Am
    Doğruluğumuzdan değil
.  B7
    Lütfundan diliyoruz! //</lyrics>
<title>Sana Yaklaşırız RT76</title>
</song>