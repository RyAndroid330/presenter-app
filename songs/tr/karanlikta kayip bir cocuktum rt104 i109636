<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<author>Melih, Josh Park, IPCA Kilisesi</author>
<title>Karanlıkta kayıp bir çocuktum RT104</title>
<lyrics>[V1]
.  G                       B7
 Karanlıkta kayıp bir çocuktum
. Em7                  C2
 Ölüler diyarına yolcuydum
. G                   B7
 Yakarışımı duy, dedim sessizce
.     Em7        C2 C2
 Senin yüzünü aradım

[C1]
.   G              D
   İşte Işık, İşte İsa!
.   Em7
   Sesimi işittin ve elimden tuttun
.        G         B7
   Sevginle ruhumu sardın
.       Em7        C2  G B7 Em7 C2
   İşte Işık, İşte İsa!

[B1]
.  D                  C2
   Artık sadece yaşam var
.  D             Em7
   sevgi ve umut var
.     C                G D/F# Em7
   Kalbimde taht kuran Tanrı'ya
.         Am7     A7     D
   Sonsuz yücelik ve şan var</lyrics>
<key>G</key>
<aka>İşte Işık, İşte İsa</aka>
</song>