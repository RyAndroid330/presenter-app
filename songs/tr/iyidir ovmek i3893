<?xml version="1.0" encoding="UTF-8"?><song><author>Amanda Falk, Bethel Music</author>
<title>Iyidir Ovmek</title>
<lyrics>[V1]
.    G         C     D   C     D
 // Iyidir Ismini ovmek Rab Isam
. G         C       D   C     D
 Onur ve yucelik sana her zaman!
. G      C        D
 Seni ovmek Rab Isam
.       Am       D
 Ve gucune guvenmek! //

[V2]
.         G      C       D C D
 // Cunku Sen buyuksun Rab,
. G    C      D   C D
 Buyuktur islerin!
. G      C     D
 Sen buyuksun Rab,
.            Am
 Buyuktur sevgin,
.            D
 Buyuktur ismin! //

[V3]
. G       C       G
 Iyidir ismini ovmek!</lyrics>
<key>G</key>
</song>