<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>153</hymn_number>
<author>Hiltrud Ströhlein</author>
<title>İki Gözüm Var TÇ153</title>
<lyrics>[V1]
.E                   B7
  İki gözüm var, iki kulağım var,
.            E
 Ve tek bir burnum var.
.                   B7
 İki elim var, iki ayağım var,
.            E
 Ve tek bir göbeğim var.
.    B7          E
 Ayrıca gülmek için
.       B7        E
 Ya da konuşmak için
.           B7       E
 Tanrı bana ağız verdi.
.           B7   E
 Bununla O'nu överim.</lyrics>
<key>E</key>
</song>