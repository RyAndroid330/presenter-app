<?xml version="1.0" encoding="UTF-8"?><song><title>O Vadideki Zambaktan Güzel TY350</title>
<lyrics>[V1]
 O vadideki zambaktan güzel,
 O sabah yıldızından parlak.
 O kardan daha da saf, meltemden taze,
 Güzel tüm her şeyden daha güzel.

[C1]
   Benim Kurtarıcım ve Allah'ın Oğlu
   İsmi her şeyden üstün,
   Her şey O'nun isminde!
   Dünyanın yaratıcısı ve ebedi hakimi
   Yücelerin yücesisin, Rab İsa Mesih!</lyrics>
<hymn_number>350</hymn_number>
</song>