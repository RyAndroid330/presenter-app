<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
 Varlığının Sakinliginde
 Dinliyorum Rab
 Sakince Sessizce
 Seninim

[V2]
 Sozlerin konuşsun
 Ruhun kendine çeksin
 Senden duyduklarıma
 İtaat edeceğim

[V3]
 Senin Kutsal hikmetin
 Ruhumun susadığı
 Sende bulduğum huzur
 Ve yaşam özlemim.</lyrics>
<title>Varlığının Sakinliğinde</title>
<author>Turgay Üçal</author>
</song>