<?xml version="1.0" encoding="UTF-8"?><song><author>Seli MIĞDISI</author>
<key>Bb</key>
<lyrics>[V1]
.Dm
 Ben yalnız olmam
.Gm          Dm
 Yanımda Sensin
.Gm                F
  // Ben öksüz kalmam
.Dm
 Babam Sensin //

[V2]
.Dm         Cm
  Beni bilir beni anlar
.Gm           Dm
 &quot;Yavrum&quot; dersin
.Dm          Cm
  Dar günümde yanımdasın
.Gm        Dm
 Beni seversin

[V3]
.Dm           Gm
  // Suçlarımı affedersin
.Cm           Gm
 Beni yenilersin
.Gm         Cm
  Bu dünyada tek ışığım
.Gm         Dm
 Rabbim Sensin //

[V4]
.Dm
  Sen varsan yanımda
.Gm         Dm
 Ateşten yanmam
.Gm                F
  // Sen varsan hayatımda
.Dm
 İblis'e kanmam //

[V5]
.Dm            Cm
  Sen tesellim, Sen umudum
.Gm         Dm
 Yaşam kaynağım
.Dm             Cm
  Sen kurtarıcım yüce Rabbim
.Gm       Dm
 ve sığınağım

[V6]
.Dm            Gm
  // Bu dünyada gerçek dostum
.Cm          Gm
 Derde dermanım
.Gm           Cm
  Yerleş yüreğimde Rabbim
.Gm         Dm
 Artsın imanım //</lyrics>
<title>Babam Sensin</title>
</song>