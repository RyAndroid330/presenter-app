<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>638</hymn_number>
<title>Ne için be, ey yavrum BG638</title>
<lyrics>[C1]
   Ne için be, ey yavrum,
   Gene suç işledin?
   // Benim dediğimi,
   Benim sözümü
   Sen yine tutmadın. //

[C2]
   Kalbini ver bana,
   Temizleyim seni.
   // Kuvvetle ateş
   Ben sana vereyim.
   Her zaman. her yerde. //

[C3]
   Sen ne zaman, yavrum,
   Diz çöküp yalvarsan,
   // Kalbini pakla !
   Temiz tutasan,
   her vakıt, her zaman. //

[C4]
   Senin için, yavrum,
   Çarmıha gerildim.
   // Tükürüp, sövüp,
   Dövdüler beni.
   Kanımı ben döktüm. //

[C5]
   Benim yavrularım,
   Ruh onlara güder.
   // Sesimi tanıp,
   Beni seslerler,
   Her zaman, her yerde. //</lyrics>
</song>