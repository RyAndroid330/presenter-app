<?xml version="1.0" encoding="UTF-8"?><song><title>Rab'bim çobanımdır benim BG41</title>
<lyrics>[V1]
 // Rab'bim çobanımdır benim eksiğim olmaz //
 Beni yemyeşil çayırda beni yemyeşil çayırda
 yatırır sakin sular kıyısında

[V2]
 // Karanlık ölüm vadisinden geçsem bile //
 kötülükten korkmam, kötülükten korkmam
 çünkü Sen benimlesin Sen benimlesin

[V3]
 // Bana doğru yollarda öncülük edersin //
 Senin çomağın senin değneyin
 güven verendir bana, güven verendir

[V4]
 // Ömrüm boyunca iyilik sevgi izleyecek beni //
 hep Tanrımın evinde, hep Rab'bimin evinde
 ben oturayacağım, ben oturacağım

[V5]
 // Ya Rab bütün yüreğimle Sana şükredeceğim //
 yaptıgın harikalar yaptığın mucizeler
 hepsini anlatacağım ve duyuracağım</lyrics>
<hymn_number>41</hymn_number>
</song>