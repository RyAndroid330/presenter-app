<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Çok yalnız gezdim
 karanlıkta, ben giderdim. //

[V2]
 // Mesih beni satın aldı,
 Günahımdan kurtardı. //

[V3]
 Çarmıhta çok acı çekti,
 Suçumuzu O yüklendi.
 // Kanını dökerek,
 Cennete davet etti. //

[V4]
 // Bu dünyanın ateşinden,
 Beni çektin, yaşam verdin. //

[V5]
 // Artık çok mutluyum ben,
 Cennete davet ettin. //</lyrics>
<title>Çok yalnız gezdim</title>
</song>