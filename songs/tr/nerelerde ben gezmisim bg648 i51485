<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Nerelerde ben gezmişim,
   Başıma çare bulmadım. //

[C2]
   // Olamam, olamam Allahım.
   Ben sensiz burada duramam. //

[C3]
   // Köyden köye ben gezerdim,
   Şifa, Rabbim, bulamadım. //

[C4]
   // Doktorlara ben gitmiştim,
   Derman, Rabbim, bulamadım. //

[C5]
   // Ben, Allahım, hasta oldum,
   Sende Allahım umudum. //

[C6]
   // Ben, Allahım, kimsesizim,
   Brakma beni yalnızım ben. //</lyrics>
<title>Nerelerde ben gezmişim BG648</title>
<hymn_number>648</hymn_number>
</song>