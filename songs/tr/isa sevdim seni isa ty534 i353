<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   G                Emin
 // İsa, sevdim seni İsa,
.        C     Amin
 Sana bağlıyım ben,
.             G
 Her şeyimsin sen. //

[V2]
.     Amin      D
 Merhamet ve sevgi,
.    Bmin    Emin
 Doludur yüreğin.
.      Amin   D
 Benim uğruma Rab,
.       Bmin       Emin
 Yalnız sen can verdin.
.      C        Amin
 Eşin, benzerin yok
.   D
 Rabbim!</lyrics>
<title>İsa, Sevdim Seni İsa TY534</title>
<hymn_number>534</hymn_number>
</song>