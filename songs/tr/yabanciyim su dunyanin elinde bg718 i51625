<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>718</hymn_number>
<lyrics>[V1]
.   Am.               C.        Am
 // Allahimla olayım, onunla bile. //
.Am.             C
 Yerim, mekyanım vardır benim,
.                 Am
 Cenette mekyanım var,
.                C
 Cenette mirasım var.
.C.                 Am
 İstemiyom şu dünyanın olayım.
.   Am.                 C.            Am
 // Çünkü ben hazır oldum, göke gideyim. //
.C.           Am
 Yoruldun mu, Rabbi ara, bulursun.
.   Am.        C.            Am
 // Bilirim ki Allahım, bana yardımcı. //
.C.                Am           c
 Şu dünyanın yolunda Rab benimle,
.   Am.        C.                   Am
 // Bana her vakıt İsa, yoldaş oluyor. //
.C.                 Am.      C
 Kurtarıcı Rab Mesihe gelesen,
.   Am.                  C.        Am
 // Bekliyor seni şimdi, iman edesin. //
.C.                      Am.       C
 Artık vakıt yaklaşıyor, Rab gelsin.
.   Am.                  C.          Am
 // Her canın sorgusunu, o yapacaktır. //</lyrics>
<key>Am</key>
<title>Yabancıyım şu dünyanın elinde BG718</title>
</song>