<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>587</hymn_number>
<title>Ey Allahım, Allahım ! BG587</title>
<lyrics>[C1]
   // Ey Allahım, Allahım ! //

[C2]
   // Koru bizi, Allahım ! //

[C3]
   // Beyaz gömlek verdim sana. //

[C4]
   // Al da giy sen onu. //

[C5]
   // İsa Mesih gelecek, //

[C6]
   // Bizi burdan alacak. //</lyrics>
</song>