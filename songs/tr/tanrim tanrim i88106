<?xml version="1.0" encoding="UTF-8"?><song><title>Tanrım Tanrım</title>
<lyrics>[V1]
 // Tanrım, Tanrım senden başkasına güvenemem
 kollarına aldın beni kalbimdesin sen benim //

[V2]
 // Ekmeğim suyum sensin Tanrım
 kalbimdesin yüreğimdesin //

[V3]
 // Acılanıyor yüreğim, yaralanıyor benim kalbim
 yıka beni kanınla doldur beni Kutsal Ruhunla //</lyrics>
</song>