<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Sevinin kardaşlar, her zaman sevinin !
 İsa tezde gelecek inanmış olanlara. //

[V2]
 // Ayrılmayın Rabden, imanda siz olun.
 İsa tezde gelecek, bizi burdan alacak. //

[V3]
 // Bu yoldan dönmeyin, hiç geri dönmeyin,
 Boşuna çalışmayın, imanınız sönmesin. //

[V4]
 // İsa bizi sevdi, bizim için öldü,
 Bizim için gerildi, bizim için dirildi. //

[V5]
 // Birlik olsun bizde, sevinçle dolalım,
 Atalım kötülüğü, bakalım Rab İsa'ya. //

[V6]
 // Aleluya Rabbe, övgüler Babaya!
 Sonsuzca şükür olsun, sade İsa Mesih'e ! //</lyrics>
<title>Sevinin kardaşlar, her zaman sevinin ! BG669</title>
<hymn_number>669</hymn_number>
</song>