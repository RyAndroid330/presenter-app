<?xml version="1.0" encoding="UTF-8"?><song><author>Yaşar Atanasov</author>
<lyrics>[V1]
 Bir gece uyandım
 Derin derin ağladım
 Yalnız ben yapamam
 Ayrı ben kalamam

[V2]
 Koro:Sensiz yaşayamam
.    
     Ayrı kalamam
.    
     Sensiz mutsuzum
.    
     Yüce Allahım

[V3]
 Günahlıyım Allahım
 Yalvardım yakardım
 Kurtar beni Allahım
 Hıçkırdım Ağladım

[V4]
 Şükür olsun kurtuldum
 Sonsuz hayatı ben aldım
 Tamamlandı sevincim
 Yaşam huzur ben buldum</lyrics>
<title>Bir gece uyandım</title>
</song>