<?xml version="1.0" encoding="UTF-8"?><song><title>Hayatımda Rab Yücelsin, Rab Yücelsin TY321</title>
<lyrics>[V1]
. C G AmEm Dm        G    F        G
 Hayatımda Rab yücelsin, Rab yücelsin.
.C G AmEm  Dm       G7      C
 Hayatımda Rab yücelsin bugün.

[V2]
.C GAm Em Dm        G     F       G
 Aramızda Rab yücelsin, Rab yücelsin...

[V3]
.C  G AmEm Dm
 Ülkemizde Rab yücelsin, Rab yücelsin...

[V4]
.C GAm Em    Dm        G     F       G
 Kilisesinde Rab yücelsin, Rab yücelsin...

[V5]
.C GAm Em   Dm        G     F       G
 Dünyamızda Rab yücelsin, Rab yücelsin...</lyrics>
<key>C</key>
<hymn_number>321</hymn_number>
<author>Bob Kilpatrick</author>
</song>