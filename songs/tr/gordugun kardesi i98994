<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Gördüğün kardeşi,
 Sevmez isen eğer,
 Görmediğin RAB'bi,
 Nasıl seveceksin?

[V2]
 Seni sevenleri,
 Sevmez isen eğer,
 Peki düşmanını,
 Nasıl seveceksin?

[C1]
   // Dünyadan geçmezsen,
   Candan geçmez isen,
   Rab İsa uğruna,
   Nasıl öleceksin. //

[V3]
 Kardeşi ezersen,
 Onu hor görürsen,
 Taptığın RAB'bini,
 Nasıl yüceltirsin?

[V4]
 Kardeşe sırt döner,
 Muhtaca git dersen,
 Rab'bin yanına sen,
 Nasıl gideceksin?</lyrics>
<title>Gördüğün kardeşi</title>
<author>Durmuş Tünel</author>
</song>