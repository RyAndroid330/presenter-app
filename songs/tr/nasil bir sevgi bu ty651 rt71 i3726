<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>651</hymn_number>
<author>Adrienne Neusch</author>
<title>Nasıl Bir Sevgi Bu TY651 RT71</title>
<key>C</key>
<lyrics>[V1]
.Am       G           Fmaj7
 Sessizlikte Seni beklerken
.Am      G          F7
 Her şey eriyip gidiyor
.Am        G          Fmaj7
 Bu dünya beni tatmin edemez
.Am    G      Fmaj7
 Aradığım Senin yüzün

[P1]
.  Dm        C             G/B
   Senden gelen bir ses duydum
.  Dm         C               G/B
   &quot;Gel, çocuğum, sevgimi dökeyim&quot;

[C1]
.  Am
   Nasıl bir sevgi bu!
.  F7
   Bilgimi aşıyor
.  Dm      E        Am
   Deniz gibi beni sarıyor
.  (Am)
   Çocuğun olarak
.  Fmaj7
   Sevginde kalayım
.  Dm      E         Am
   Babam beni çok seviyor

[V2]
.Am       G           Fmaj7
 Sevgin derinlere indikçe
.Am       G       F7
 Duvarlarım yıkılıyor
.Am        G          Fmaj7
 Yeni bir özgürlüğe kavuştum
.Am        G       Fmaj7
 Geri dönmem, asla dönmem

[P2]
.  Dm         C             G/B
   Tekrar, tekrar sesini duyarım
.  Dm         C               G/B
   &quot;Gel, çocuğum, sevgimi dökeyim&quot;</lyrics>
</song>