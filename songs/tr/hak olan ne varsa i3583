<?xml version="1.0" encoding="UTF-8"?><song><author>Turgay Üçal</author>
<lyrics>[V1]
 Hak olan ne varsa
 Pak olan ne varsa
 Asl olan ne varsa
 Sendendir Allah'ım

[C1]
   Sendendir, Sendendir,
   Sendendir Allah'ım

[V2]
 Mesih'e çağrılma
 Mesih'le aklanma
 Mesih'te kutsanma
 Sendendir Allah'ım

[C2]
   Sendendir, sendendir
   Sendendir Allah'ım</lyrics>
<title>Hak olan ne varsa</title>
</song>