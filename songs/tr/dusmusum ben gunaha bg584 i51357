<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>584</hymn_number>
<lyrics>[V1]
 // Düşmüşüm ben günaha,
 Diri suyla beni yıka. //
 Sende kalmak isterim,
 Buldun ve sevdin beni

[V2]
 // Ne yıkar günahımı?
 Ancak İsa'nın kanı. //
 İsa herkesi sever,
 Hep yardım etmek ister.

[V3]
 // Senin diri sözlerin
 Derin kalbime girer. //
 İsa, senin ışığın,
 Beni günahtan çeker.

[V4]
 // Herkes seni inkyar etti,
 Kimse seni sevmedi. //
 Sözlerini attılar,
 Seni ölüme koydular.</lyrics>
<title>Düşmüşüm ben günaha BG584</title>
</song>