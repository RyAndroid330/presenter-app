<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ya Rab senden başka
 kime gideyim
 sensin beni yaradan,
 en iyi anlayan //

[C1]
   // Sana sığınıyorum
   Sana bağrıyorum
   Beni rahatlatan Allah'ı
   Senin sevgin çok, büyük
   Senin sabrın çok büyük
   Beni ayakta tutan Rabbim //

[V2]
 // Her gün senin yüzunu arıyorum ben
 çünkü derdime çare oluyorsun sen //

[V3]
 // Sözünü okumaktan
 tat alıyorum,yaşamam için ümit veriyor //</lyrics>
<title>Ya rab senden başka</title>
</song>