<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.E  B7  E        B7  E
 Selam Ayşe*, selam Ayşe!
.     B7 E        B7 E
 Hoş geldin, hoş geldin!
.E    B7    E        B7    E
 İsa'nın sözünü, İsa'nın sözünü
.   B7   E      B7   E
 Dinleyelim, dinleyelim!

[V2]
 Selam Ayşe, selam Ayşe!
 Hoş geldin, hoş geldin!
 İsa seni seviyor, İsa seni seviyor.
 Sevinelim, sevinelim!

[V3]
 *(Çocukların isimlerini kullanın!)</lyrics>
<title>Selam Ayşe TÇ164</title>
<author>Hiltrud Ströhlein</author>
<hymn_number>164</hymn_number>
</song>