<?xml version="1.0" encoding="UTF-8"?><song><title>Tanrı, Kral Rabbimiz'e Şükredin TY614</title>
<key>G</key>
<lyrics>[V1]
.G
 Tanrı, Kral Rabbimiz'e şükredin,
 Sevgisi sonsuzdur!
.C
 O iyidir, her şeyden üstündür,
.G
 Sevgisi sonsuzdur!
.     D         C/E
 Hamdedin, hamdedin.

[V2]
.G
 Güçlü eliyle, kolunu uzatır,
 Sevgisi sonsuzdur!
.C
 Yeni doğuş için şükredin,
.G
 Sevgisi sonsuzdur!
.     D         C/E
 Hamdedin, hamdedin.
.     D         C/E
 Hamdedin, hamdedin.

[C1]
.      G
   Sonsuzca Tanrı sadık,
.      Em
   Sonsuzca O güçlü,
.      D
   Sonsuzca Rab bizimle,
.      C         G
   Sonsuzca. Sonsuzca

[V3]
 Güneşin doğuşundan batışına kadar,
 Sevgisi sonsuzdur!
 Tanrı'nın lütfuyla devam edelim,
 Sevgisi sonsuzdur!
 Hamdedin, hamdedin.
 Hamdedin, hamdedin.

[V4]
 Sevgisi sonsuzdur!
 Sevgisi sonsuzdur!
 Sevgisi sonsuzdur!
 Sonsuzdur!</lyrics>
<author>Chris Tomlin</author>
<hymn_number>614</hymn_number>
</song>