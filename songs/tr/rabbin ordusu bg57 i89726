<?xml version="1.0" encoding="UTF-8"?><song><aka>Genç Birliği Bulgaristan</aka>
<lyrics>[C1]
.  Em              C
   Biz genciz genç birliğiz
.      D                Em
   Rabbin ordusu yiğit savaşçılarıyız
.  Em      C
   Şeytanı Yeneriz
.       D         Em
   Tanrıya şükrederiz

[V1]
.Em
 Zamanı bekleriz
.C             D          Em
 yine birlikte olmak için biz
.Em        C
 Dua ilahi söyleriz
.       D         Em
 Biz Rabbi yüceltiriz

[V2]
 Biribirimizi severiz
 Canımızı vereriz
 Genç birliği derler bize
 Biz herkezi severiz

[V3]
 Şimdi Tanrıdan aldıklarımızı
 Herkezle paylaşırız
 Sevinip coşarız
 Herkeze bereket olarız

[V4]
 Evlerimize gideriz
 Yine beraber olma
 zamanını bekleriz
 Biz ruhta biriz
 Tanrıyı severiz</lyrics>
<key>Em</key>
<title>Rab'bin Ordusu BG57</title>
<hymn_number>57</hymn_number>
<author>Mustafa Abidov</author>
</song>