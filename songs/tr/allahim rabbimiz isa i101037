<?xml version="1.0" encoding="UTF-8"?><song><author>Adil Yaşar, Mehmet Akyürek</author>
<lyrics>[V1]
 // Allahım Rabbimiz İsa Canımızı kölelikten kurtardın çaresiz Perişan kalmışken Rabbim isa Elini Uzattın //

[V2]
 // Sade seni düşünecem sade seni Ben övecem sade sana tapınacam Rabbim isa //

[V3]
 // Tanrım ve Kurtarıcım sensin Benim için çarmıhta sen öldün Yüreğim Günahlarlan doluyken Kanınla beni sen Yıkadın //</lyrics>
<title>Allahım Rabbimiz İsa</title>
</song>