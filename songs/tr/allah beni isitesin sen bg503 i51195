<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>503</hymn_number>
<lyrics>[V1]
 Allah, beni işitesin sen.
 Acılarımı görüyorsun.
 // Bağırıp aalıyorum sana ben.
 İlaçlayasın sen beni. //

[V2]
 Dayan, yavrum, çilene,
 Ben girecem yüreyine.
 // Kalbini yıkayacam, yavrum,
 Benim temiz kanımla. //

[V3]
 Yaralarım acıyor benim.
 Ciyerlerim sızlıyor benim.
 // Sade sana bağırıyorum ben,
 Mehlem sen veresen bana. //

[V4]
 Sayamdan ayrılma benim.
 Sürümden ayrılma benim.
 // Ben seni görüyorum, yavrum.
 Ben seni ilaçlayacam. //

[V5]
 Karanlıktan çıkardım seni.
 Çileden kurtardım ben seni.
 // Şimdi benim adımdan, yavrum,
 Köy kasaba isteyim gezesin. //</lyrics>
<title>Allah, beni işitesin sen BG503</title>
</song>