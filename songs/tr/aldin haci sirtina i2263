<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Aldın haçı sırtına taşıdın ta Golgota'ya
 Gel dedin gel dedin ardım sıra gel dedin

[V2]
 Aldım haçı sırtıma geldim senin yanına
 Gel dedin gel dedin haç üstüne gel dedin

[V3]
 Gördüm seni çarmıhta günah hüküm hep orada
 Gel dedin gel dedin merhamete gel dedin

[V4]
 Aldın beni yanına taşıdın sonsuzluğa
 Gel dedin gel dedin mutluluğa gel dedin</lyrics>
<title>Aldın Haçı Sırtına</title>
<author>Turgay Üçal, Turgay Üçal</author>
</song>