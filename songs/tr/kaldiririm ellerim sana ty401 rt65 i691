<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>401</hymn_number>
<author>Sefa Görmezöz, Gürkan Çamsun</author>
<lyrics>[V1]
.         Em               B7
 //  Kaldırırım ellerim' Sana,
.                   Em
 Överim Seni, İsa Mesih  //
.        D             G
 //  Yücedir, yücedir İsa,
.     D             Em
 Yücelsin topluluğunda  //

[V2]
.            Em               B7
 //  Hiç bir şey alamaz ki benden,
.                      Em
 Sendeki sonsuz sevincimi  //
.          D               G
 //  Dans ederim Senin önünde,
.     D              Em
 Dudaklarımda ezgilerle  //

[V3]
.            Em                 B7
 //  Yol, gerçek ve yaşam Mesih'te
.                      Em
 O'nda sonsuz umut bulunur.  //
.         D               G
 //  Şükrederim Mesih İsa'ya
.      D            Em
 Hamdolsun İsa Rabbime.  //

[V4]
.        D                 G
 //  Halelu-, Hale-, Haleluya!
.    D                 Em
 Halelu-, Hale-, Haleluya!  //</lyrics>
<key>G</key>
<title>Kaldırırım Ellerim' Sana TY401 RT65</title>
</song>