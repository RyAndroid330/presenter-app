<?xml version="1.0" encoding="UTF-8"?><song><title>Sına Beni</title>
<key>C</key>
<lyrics>[V1]
.C    G         Am
 Rab kalbimi tanırsın
.F         G         C  G
 Oturup kalkışımı bilirsin
. C          G       Am
 Niyetimi uzaktan anlarsın
. F        G          C  G
 Gittiğim yolu gözetlersin

[C1]
.  F      G        Em      Am
   Ey Tanrı, açıp yokla canımı
.  F         G        C    C7
   Sına beni öğren kaygılarımı
.  F          G               Em      Am
   Bak, seni gücendiren bir yönüm var mı?
.  F             G7      C
   Önder ol bana yaşam yolunda

[V2]
. C     G         Am
 İç varlığımı yarattın
.  F        G          C  G
 Annemin rahminde beni ördün
.  C       G         Am
 Canım sana övgüler sunar
.F           G          C   G
 Müthiş ve harika işlerin var

[V3]
.  C        G         Am
 Kör karanlığa gömülsem
.F         G        C  G
 Ruhun beni asla bırakmaz
.  C         G          Am
 Seherin kanatlarıyla uçsam
.F         G          C  G
 Sen yine sevginle sararsın</lyrics>
<aka>Rab Kalbimi Tanırsın</aka>
<author>Jerry Mattix</author>
</song>