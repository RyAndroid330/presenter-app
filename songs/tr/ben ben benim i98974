<?xml version="1.0" encoding="UTF-8"?><song><title>Ben Ben Benim</title>
<lyrics>[V1]
.BEN BEN BENİM
 BEN YAHWEYİM
 ADONAYIM ELOHIM
 YAŞAM GERÇEK VE YOL BENİM
 KUTSAL OLAN MESİHİM

[V2]
 BAŞLANGIÇTAKİ SÖZ BENİM
 SİZDE YAŞAYAN BENİM
 BEN ÇOBANIM BEN KUZUYUM
 CANIM FEDA EDENİM

[V3]
 YENİ AHİD OLAN BENİM
 ÇARMIHTA KURBAN BENİM
 ÖLÜMÜDE YENEN BENİM
 SONSUZ YAŞAM VERENİM

[V4]
 ÖZGÜR KILAN ŞİFA VEREN
 BAĞLARI ÇÖZEN BENİM
 BANA IMAN EDENLERİN
 HAYATIN TAZELERİM

[V5]
 IŞIK BENİM SEVGİ BENİM
 YAŞAM SUYU EKMEĞİM
 RUHTA BENİM BİLGE BENİM
 SİZİ SEVEN MESİHİM</lyrics>
<key>B</key>
<author>&quot;Edwin&quot; Corc Bahçecioğlu</author>
</song>