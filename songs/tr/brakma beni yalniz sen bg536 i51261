<?xml version="1.0" encoding="UTF-8"?><song><title>Brakma beni yalnız sen BG536</title>
<lyrics>[V1]
 // Brakma beni yalnız sen.
 Sana güveniyom ben. //

[C1]
   // Rabbim, Rabbim,
   Rabbim'de kurtuluş. //

[C2]
   // Gece gündüz bağırıyom,
   Senden, Allahım, bekliyom. //

[C3]
   // Ellerimi kaldırıyom,
   Ben sana yalvarıyom. //

[C4]
   // Sana avuç açanlar,
   Cenneti alajaklar. //

[C5]
   // İsam seni seviyom,
   Senden imdat bekliyom. //</lyrics>
<hymn_number>536</hymn_number>
</song>