<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>526</hymn_number>
<lyrics>[V1]
 // Ben seni çok sevdim.
 Senin yoluna çektim.
 Sen bana yardım et,
 Sana güveniyom ben. //

[C1]
   Haleluya sana.
   Haleluya sana.
   Şükür, şükür
   İsa Mesih'e.

[V2]
 // Büyük derdim var benim.
 Sen bilirsin, Allahım.
 Sen bana yardım et.
 Sana güveniyom ben. //</lyrics>
<title>Ben seni çok sevdim BG526</title>
</song>