<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>655</hymn_number>
<title>O, Rab İsam, sen büyüksün BG655</title>
<lyrics>[V1]
 // O, Rab İsam, sen büyüksün,
 Herşeyi sen görüyorsun //

[C1]
   // O, Rab İsam, bizim için öldün,
   Bizim için kanını döktün. //

[C2]
   // Kanın bizi kurtarıyor,
   Hastalıktan kaldırıyor //

[C3]
   // Sen hacında can verirken,
   Acıları sen çekerken //

[C4]
   // Üç gün sonra kıyam ettin.
   Rab İsam, sen göke gittin //

[C5]
   // Ver bize sen saburundan.
   Ver bize sen merhametinden //</lyrics>
</song>