<?xml version="1.0" encoding="UTF-8"?><song><author>Dencian</author>
<lyrics>[V1]
 // Dağlar var olmadan
 dünyayı yaratmadan
 önceden sonsuza dek
 tek Allah sensin //

[C1]
   // Bunun için günlerimi
   saymaya bana öğret Allahım
   Hikmet edineyim //

[V2]
 // En güzel yıllar da
 kederle geçiyor
 Çarçabuk bitiyoruz
 uçup gidiyoruz //

[V3]
 // Rab Allahımız
 hoşnut kalsın
 elimizin yaptığı
 boşa çıkmasın //</lyrics>
<title>Dağlar var olmadan</title>
</song>