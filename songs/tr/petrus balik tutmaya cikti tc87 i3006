<?xml version="1.0" encoding="UTF-8"?><song><title>Petrus Balık Tutmaya Çıktı TÇ87</title>
<key>C</key>
<lyrics>[V1]
.Am      Em   Dm       Am
 Petrus balık tutmaya çıktı,
.Am    Em           Am
 Fakat başarılı olmadı.
.  Am     Em   Dm        Am
 &quot;Tekrar göle çık&quot;, dedi İsa.
.  Am    Em       Dm     E
 &quot;Ağını sağ yana at!&quot; dedi.

[C1]
.           C        G7
   // Beni seviyor musun?
.                 C
   Beni seviyor musun?
.                 F
   Beni seviyor musun?
.      C     G7  C      E
   İsa hâlâ soruyor. //

[V2]
 Petrus tekrar göle çıktı,
 Ağını sağ yana göle attı.
 Büyük mucize birden oldu:
 Çok ve de iri balık vardı.

[V3]
 İsa bir sofra hazırladı,
 Petrus'u sofraya çağırdı.
 Petrus'la balık ve ekmek yedi,
 İnkar ettiğini de affetti.

[V4]
 İsa bizi de sofraya çağırır,
 Günahlarımızı affeder.
 Biz de O'nu yürekten sevelim!
 O'nun ardından gidelim!

[C2]
   // Artık seni seviyorum!
   Artık seni seviyorum!
   Artık seni seviyorum!
   İsam sana söylüyorum. //</lyrics>
<hymn_number>87</hymn_number>
<author>Hiltrud Ströhlein</author>
</song>