<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.D              DDim D
 Sevinç günü! Yüreğimden
.          A           D
 O gün Rab'be teslim oldum.
.                DDim D
 Kalbim coşar sevincimden,
.        A           D
 Rab İsa'da rahat buldum.

[C1]
.           G          D
   Sevinç günü ve af günü!
.            A          D
   Rab kaldırdı suç yükümü.
.          G         D
   Bana verdi yardımını
.           E            A
   Ve lütfundan da tattırdı, haleluya!
.         D
   Sevinç günü ve af günü!
.            A7         D
   Rab kaldırdı suç yükümü.

[V2]
 Sevinç günü beni kılan
 Tatlı Mesihime tabi!
 Yüreğimi her günahtan
 Arıtsın O'nun sevgisi!

[V3]
 Artık Rab'bin evladından
 Sayılırım ben günahkâr!
 Baba, her gün ben emrinden
 Hoşnudum, sevincim artar.

[V4]
 Böylece o kefarette
 Kımıldanmaz temel buldum.
 Aracı'mdır İsa gökte,
 Sevinç ile geçer ömrüm!</lyrics>
<title>Sevinç Günü! Yüreğimden TY85</title>
<hymn_number>85</hymn_number>
<author>P. Doddridge, E. F. Rimbault</author>
</song>