 // Sarsıldı karanlık adını duyunca //
.   Dm                 Dm             F
 // Kör gözler açılır, ölüler can bulur //
.   Dm              C               F
 // Dağlar denizler önümüzden kaçacak //
.   Dm              Dm          F
 // Diriliş dolacak her bir sokağa //</lyrics>
