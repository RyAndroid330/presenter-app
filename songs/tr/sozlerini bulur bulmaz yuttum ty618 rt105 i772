<?xml version="1.0" encoding="UTF-8"?><song><author>Mine Özden</author>
<hymn_number>618</hymn_number>
<aka>Seninim Ben</aka>
<lyrics>[V1]
.Am        Dm               Am
 Sözlerini bulur bulmaz yuttum,
.           Dm                Am
 Bana neşe, yüreğime sevinç oldu.

[C1]
.           Dm G         C  F
   Seninim ben, Seninim ben,
.           Dm E       Am
   Seninim ben, hamdolsun.

[V2]
.   Am          Dm            Am
 // Sözlerin ne tatlıdır ağzımda,
.            Dm              Am
 Baldan daha tatlıdır damağımda. //

[B1]
.  F          G      Am  F
   Adımlarıma çıra oldun.
.         G       Am G
   Yoluma ışık oldun.
.                    Am
   Çünkü... Seninim ben.</lyrics>
<key>Am</key>
<title>Sözlerini Bulur Bulmaz Yuttum TY618 RT105</title>
</song>