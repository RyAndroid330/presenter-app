<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>465</hymn_number>
<author>Andy Park</author>
<title>Yalnız Sen, Ya Rab TY465 RT223</title>
<lyrics>[V1]
.G           Am7
 Yalnız Sen, ya Rab
.    D          C        G C D
 Kalbimi tatmin edebilirsin
.    G         Am7
 Hiç bir şey alamaz
.   D          C     D G
 Sana yaklaşmanın yerini

[C1]
.         Em      C        D
   Yalnız Sen, özlemimi bilirsin
.         Em      C         D
   Yalnız Sen, beni yenilersin
.         Em      C          D
   Yalnız Sen, kalbimi güldürürsün
.         Em       C   Am D G
   Yalnız Sen, çağrımı duyarsın

[V2]
. G      Am7
 Seni severim
.      D            C       G C D
 Gel, doldur kalbimdeki özlemi
. G           Am7
 Doldur, beni ne olur
.   D        C       D G
 Sevgini yaşayayım içimde</lyrics>
<key>G</key>
</song>