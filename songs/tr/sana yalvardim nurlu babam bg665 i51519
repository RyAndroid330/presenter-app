<?xml version="1.0" encoding="UTF-8"?><song><title>Sana yalvardım, nurlu Babam BG665</title>
<lyrics>[V1]
 // Sana yalvardım, nurlu Babam,
 İşit beni şimdi sen. //
 // Hiç kimsem yok ki,ben aalaşayım,
 Büyük gamım var, Allahım. //

[V2]
 // Gel Allahım, gel Tanrım benim,
 Kalpten sana yalvardım. //
 // Ne varsa bende, sana verecem.
 Sade, Allahım, benim ol. //

[V3]
 // Sen biriciksin, Rabbim İsa.
 Beni pakla temizle. //
 // Allahım benim, beni tanıdın
 Daha dünyaya gelmeden. //

[V4]
 // Sen ya Rab İsam, yaşattın beni.
 Yapayım işlerini. //
 // Sen nurlu İsa çok merhametli
 Fakirlerin kardeşi. //</lyrics>
<hymn_number>665</hymn_number>
</song>