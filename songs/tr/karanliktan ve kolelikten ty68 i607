<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>68</hymn_number>
<title>Karanlıktan Ve Kölelikten TY68</title>
<key>G</key>
<lyrics>[V1]
.G              C      G
 Karanlıktan ve kölelikten
.       D    D7    G
 Sana, İsam, geliyorum!
.G           C      G
 Özgürlüğe beni erdiren,
.        A D G
 İsam, geliyorum!
.C               G
 Dertlerimden kutsal şifana,
.D               A7       D
 Yoksulluktan zengin menbana,
.G             C        G
 Günahımdan, yükümden sana,
.        A D G
 İsam, geliyorum!

[V2]
 Utanacak düşkün halimden
 Sana, İsam, geliyorum!
 Yardımına sığınırım ben,
 İsam, geliyorum!
 Kederimden hoş teselline,
 Fırtınamdan sakinliğine,
 Ahlarımdan hamt sevincine,
 İsam, geliyorum!

[V3]
 Gururumdan, mağrur halimden
 Sana, İsam, geliyorum!
 Her emrine razıyım kalpten,
 İsam, geliyorum!
 Benliğimden tatlı sevgine,
 Mutsuzluktan mutlu haline,
 Kuş gibi uçarak önüne,
 İsam, geliyorum!

[V4]
 Ölüm mezar korkularımdan
 Sana, İsam, geliyorum!
 Güvenliğe, hayata candan,
 İsam, geliyorum!
 Ölmüşlükten dirilişine,
 Boş çabamdan kurtuluşuna,
 Bakmak için tatlı yüzüne,
 İsam, geliyorum!</lyrics>
</song>