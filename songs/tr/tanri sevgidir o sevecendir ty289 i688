<?xml version="1.0" encoding="UTF-8"?><song><title>Tanrı Sevgidir, O Sevecendir TY289</title>
<key>G</key>
<lyrics>[C1]
.     Em          D             C
   // Tanrı sevgidir, O sevecendir,
.            Bm    Am         B7
   Bağışlayandır, yaşam verendir.  //

[V1]
.Am         Bm  Am          Bm
 Tanrı'nın özü sevgidir, sevgi.
.Am              C         Bm
 Allah'ın sözü, varlığı sevgi.

[V2]
.Am         Bm  Am          Bm
 Sevgi bulunan yerde Tanrı var.
. Am           C          Bm
 Tanrı olduğu yerde sevgi var.

[V3]
.Am         Bm    Am       Bm
 Sevmeyen insan Allah'ı bilmez.
. Am              C           Bm
 Çünkü Rab Allah sevgidir, sevgi.

[V4]
.Am         Bm   Am          Bm
 Biz seviyoruz, çünkü Rab sevdi.
. Am             C         Bm
 Mesih'i verdi, yaşam sağladı.

[V5]
.Am           Bm  Am         Bm
 Ey tüm insanlar, Tanrı bizleri
.Am              c         Bm
 Yürekten sevdi, İsa'yı verdi.

[V6]
.Am          Bm Am       Bm
 Biz de böylece birbirimizi
.Am             C         Bm
 Candan sevmeli ve saymalıyız.</lyrics>
<author>Ali Yazar</author>
<hymn_number>289</hymn_number>
</song>