<?xml version="1.0" encoding="UTF-8"?><song><title>Canım Yalnız Tanrı'da Huzur Bulur</title>
<lyrics>[V1]
 // Canım yalnız Tanrı'da huzur bulur,
 Kurtuluşum yalnız O'ndan gelir.  //
 // Tek kayamdır O benim kurtuluşum,
 Güçlü kalem O'dur sarsılmam.  //

[V2]
 // Ey canım her zaman Tanrı'ya güven.
 Çünkü umudum, sevincim O'ndadır.
 Tek kayamdır O benim kurtuluşum,
 Kalem O'dur asla sarsılmam.  //

[V3]
 // Ne mutlu gücünü senden alan insana
 Çünkü Rab İsa bir güneş, bir kalkandır.  //
 // Kendi halkına lütuf ve yücelik sağlar,
 Güçlü kalem O'dur sarsılmam.  //

[V4]
 // Ey canım her zaman Tanrı'ya güven,
 Otur önünde içini dök O'na.
 Kurtuluşum ve onurum Rab'be bağlıdır.
 Güçlü kalem O'dur sarsılmam.  //</lyrics>
<author>Şaban Ok</author>
</song>