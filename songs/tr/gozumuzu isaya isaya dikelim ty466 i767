<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>466</hymn_number>
<author>Claudia Williams</author>
<key>Dm</key>
<lyrics>[C1]
.   Dm.      A.      A.       Dm
   Gözümüzü İsa'ya, İsa'ya dikelim,
.   D.      Gm.
   Cesaretimizi yitirmeyelim,
.   D.           Dm
   İsa'yı düşünelim.

[V1]
.Dm.                        A
 Kendisini bekleyen sevinç uğruna
.A                       Dm
 Utancı hiçe sayıp çarmıhta,
.D.                     Gm
 Çarmıhtaki ölüme bile katlandı,
.A           Dm
 İsa'yı düşünelim.

[V2]
.Dm.                        A
 Kendisini bekleyen sevinç uğruna
.A.                     Dm
 Çarmıhtaki ölüme katlandı,
.D.                          Gm
 Tanrı'nın tahtının sağında oturdu,
.A.            Dm
 İsa'yı düşünelim.

[V3]
.Dm.                          A
 Biz de her yükten ve bizi kolayca
.A.                       Dm
 Kuşatan günahtan sıyrılarak,
.D.                    Gm
 Önümüze konan yarışı sabırla,
.A.           Dm
 Sabırla koşalım.</lyrics>
<title>Gözümüzü İsa'ya, İsa'ya Dikelim TY466</title>
</song>