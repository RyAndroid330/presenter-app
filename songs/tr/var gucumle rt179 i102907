<?xml version="1.0" encoding="UTF-8"?><song><author>Reuben Morgan, Hillsong</author>
<hymn_number>179</hymn_number>
<aka>Ellerine Teslim Olurum</aka>
<lyrics>[V1]
.D       F#m/C#
 Ellerine
.   A/C#      Bm7
 Teslim olurum
.F#m/A  G
 Tamamen
.  Asus4 A
 Seninim Rab
.D         F#m/C#
 Tüm dünyam
.  A/C#         Bm7
 Senin ellerinde
.   F#m/A   G
 Sonsuza dek
.  Asus4  A Em7
 Seninim__

[V2]
.A         D A/C#  G/B
 Sana güveniyorum__
.        D/F# A/F# G
 İsa, sana aitim___
.              Em7
 Yaşama sebebim
.               Asus4 A
 Tapınma sebebim
.        D A
 Sensin İsa

[V3]
.D            F#m/C#      Bm7
 Gittiğin yere giderim Rab
.   F#m/A  G  Asus4  A D
 Gözyaşı ve sevinçte de
.           F#m/C# A/C# Bm7
 Her durumda güvenirim__
.F#m/A    G   Asus4 A Em7
 Vaatlerin sonsuzdur

[V4]
.   A         D A/C#  G/B
 // Sana güveniyorum__
.        D/F# A/F# G
 İsa, sana aitim___
.              Em7
 Yaşama sebebim
.               Asus4 A
 Tapınma sebebim
.        D     A
 Sensin İsa //

[V5]
.       Dsus4 D    Em7     Asus4 A
 // Tapınırım, tapınırım sana //</lyrics>
<key>D</key>
<title>Var gücümle RT179</title>
</song>