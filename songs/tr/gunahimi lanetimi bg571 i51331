<?xml version="1.0" encoding="UTF-8"?><song><title>Günahımı, lanetimi BG571</title>
<lyrics>[V1]
 // Günahımı, lanetimi
 Acı çektim, zehire yandım. //
 // Yüceliyimi ona indim.
 O kırıldı, alçak oldu. //

[V2]
 // Onun yaralarından,
 Yüksekliyimden barış oldu. //
 // Hepimiz yolu şaşırdık,
 Kendi yolumuza döndük. //

[V3]
 // Rabbim bilir günahımı.
 Yolumuza gene koydu. //
 // Acımızı taşıdı,
 İnançları o yüklendi. //

[V4]
 // Yollandırdı cezıya yavrusunu,
 Ama bizi ceza bozdu. //</lyrics>
<hymn_number>571</hymn_number>
</song>