<?xml version="1.0" encoding="UTF-8"?><song><title>Korkma diyorsun bana</title>
<lyrics>[V1]
 Korkma diyorsun bana, seni yalnız bırakmam.
 // Ateşten bile geçerken, korurum seni yakmam //

[V2]
 // Sen sözüne sadıksın ya'Rab fakat ben zayıf, güçsüzüm //
 // Dokun bana gözlerimi aç //

[V3]
 // Gözlerimi aç seni göreyim, ordularından cesaret alayım //

[V4]
 // İmanımı arttır ya'Rab //

[V5]
 Günah bekler pusuda, binbir tuzaklar kurar
 // Uyanık durmak için lütfen yardım et bana //

[V6]
 Sil bütün suçlarımı, temiz bir yürek yarat
 // Kutsal ruhuna layık yeni yaşam ver bana //</lyrics>
</song>