<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>707</hymn_number>
<lyrics>[V1]
 // Çok çeki geçirdim, İsam,
 Çok çeki geçirdim ben.
 Günahımı görüyorsun,
 Sana söylerim. //

[C1]
   A-a-a-a-a
   Sen bizi buldun.
   A-a-a-a-a
   Selamet verdin.

[C2]
   // Ne söyleyim sana, Allah,
   Ne söyleyim sana, ben?
   Çok tatlısın, seven Allah,
   Çok tatlı zengin. //

[C3]
   // İsterim gezeyim, Allah,
   İsterim gezeyim ben.
   Bu dünyada, seven Allah,
   Çok tatlı zengin. //

[C4]
   // Üzgün ve zayıfım, Allah,
   Üzgün ve zayıfım, ben.
   Bana kuvvet ver sen, Allah,
   Senin gücünden. //</lyrics>
<title>Çok çeki geçirdim, İsam BG707</title>
</song>