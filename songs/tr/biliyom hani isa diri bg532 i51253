<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>532</hymn_number>
<title>Biliyom hani İsa diri BG532</title>
<lyrics>[V1]
 // Biliyom hani İsa diri,
 Ondan Kurtuluşum gelir. //

[C1]
   İsa diri, diridir O,
   Her nerde olsa.
   // Gözlerimiz görecek
   İsa'nın yüzünü. //

[V2]
 // Sade İsa'nın kanı
 Bizi kurtaracak. //

[V3]
 // Var bir açık kapı,
 Bana ve de sana. //

[V4]
 Merhamet, merhamet diliyom ben
 Yalvarıyom İsaya ben.</lyrics>
</song>