<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>713</hymn_number>
<lyrics>[C1]
   Şükür sana, şükür sana
   Allahım, yerden göke kadar.
   Şükür Babam, şükür İsa
   Şükür Mukaddes Ruh sana !

[C2]
   Allah bizi öyle sevdi,
   Biricik olunu bize verdi.
   // Ona iman eden kişi
   Ölmüş olsa yaşayacak. //

[C3]
   İsa bizi satın aldı,
   Çarmıhın üstünde o kanadı.
   // Yalvarırım, sana İsam,
   Yıka bizi sen kanınla //

[C4]
   Biz Allahı bulamazdık,
   O bizi aradı,kırda buldu.
   // Dar yoluna bizi koydu,
   Yazdı bizi kitabına. //

[C5]
   Rab İsamız gelecektir,
   Dünyayı davaya verecektir
   // Tohumları alacaktır,
   Dikenleri yakacaktır. //</lyrics>
<title>Şükür sana, şükür sana BG713</title>
</song>