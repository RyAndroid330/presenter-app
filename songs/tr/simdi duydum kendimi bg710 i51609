<?xml version="1.0" encoding="UTF-8"?><song><title>Şimdi duydum kendimi BG710</title>
<lyrics>[V1]
 Şimdi duydum kendimi
 Hayatım tez geçiyor.
 // Ben hazır değilmişim,
 Ebedi hayatına. //

[V2]
 İsa bana soracak
 Ben oraya gidince:
 // &quot;Yavrum, ne getirdin sen
 Şu dünya hayatından ?&quot; //

[V3]
 Hastalara gittin mi ?
 Fakirlere verdin mi ?
 // Kardaşa af ettin mi ?
 Yüreyin temiz midir ? //

[V4]
 Allahını duydun mu ?
 Yolunca gider misin ?
 // Size verdim İncili.
 Ne anladın sen ondan ? //

[V5]
 Bir gün Allahımızın
 Yanına biz gidecez,
 // Sorgumuz olacaktır
 Onun beyaz tahtından. //

[V6]
 O, sevgili Babacım,
 Sana yalvarıyorum
 // Beni fikirli et sen,
 Bu yeryüzündeyken. //

[V7]
 Hep yolunda olayım,
 Her şey gönlünce olsun.
 // Burdaki hayatımı
 Sana teslim edeyim. //</lyrics>
<hymn_number>710</hymn_number>
</song>