<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em        G         D
 // Ben sana susadım!
.            Bm            Em
 Rab İsa sana muhtacım. //
.          Am         G
 Tut elimden sen beni,
.              D         Em
 Sensin benim tek kralım.
.           Am        G
 Tut elimden sen beni,
.                D        Em
 Sensin ya Rab tek Kralım.
.    Em        G   D
 // RAB İsa ismini,
.             Bm        Em
 Çağırırım duy beni. //
.Am.                 G
 Yalvarırım ben sana,
.      D            Em
 Bağışla affet beni.
.         Am         G
 Yalvarırım Rab sana!</lyrics>
<title>Ben sana susadım!</title>
<author>Edip Avcıoglu</author>
</song>