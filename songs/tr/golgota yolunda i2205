<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Golgota yolunda kara bağlarım
 Matem tuttar sinemi dağlar yararım

[V2]
 Gözyaşlarım sel gibi çağlar coşarım
 Bana olan aşkına ağlar yanarım

[V3]
 Kurtuluşum sende sana koşarım
 Bana olan aşkınla dağlar aşarım</lyrics>
<title>Golgota Yolunda</title>
<author>Turgay Üçal, FERDİ KOÇ</author>
</song>