<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>540</hymn_number>
<title>Seni Severim, Severim TY540</title>
<key>G</key>
<lyrics>[V1]
.     G   D    Am  Em
 Seni severim, severim,
.C  D       G   D    Am  Em
 İ__sa seni severim, severim,
.C  D      G
 İ__sa, Kralım.

[V2]
 Kralımsın sen (2x)
.        D
 Ve seni severim.
.          G
 Kralımsın sen (2x)
.        D      C
 Ve seni överim.

[V3]
.      Em        C
 Şimdi diz çöküp önünde
.   G      D   C
 Ya-şamımı veririm.
.      Em         C
 Bütün ümidimi ve düşlerimi
.  G        D   C
 Ellerine bırakırım.</lyrics>
</song>