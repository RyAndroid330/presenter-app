<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>304</hymn_number>
<title>Büyük Ve Yücedir, İşlerin Senin TY304</title>
<key>Em</key>
<lyrics>[V1]
.Em        Am    Em    Am
 Büyük ve yücedir işlerin Senin
.Em     Am     Em    B7
 Her şeye gücü yeten Rab
.Em    Am      Em       Am
 Çağların kralı, yolların senin
.Em       D  E  E7
 Doğru ve adildir!

[V2]
.Am     Em             Am        B7
 Adından kim korkmaz, seni yüceltmez?
.Am        Em      Am          B7
 Çünkü kutsal olan tek Sen varsın!

[V3]
.Em   Am       Em    Am
 Ulusların tümü önüne gelip
.Em   Am     Em    B7
 Sana tapınacaklar ya Rab

[V4]
.Em  Am    Em  Am
 Haleluya! Haleluya!
. Em  D     E
 Haleluya Amin!

[C1]
.               B7             Em
   Lay lay lay lay, la lay la lay la lay,
.            D                  G
   La la la lay, lay la lay la lay lay lay,
.            Am             Em
   La la la lay, la lay la lay la lay,
.            B7                       Em
   La lay la lay lay la la la lay lay lay,</lyrics>
</song>