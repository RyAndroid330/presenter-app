<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>567</hymn_number>
<lyrics>[V1]
 // Günahımızı affediyorsun,
 şifa veriyon, sevgi veriyon.
 Şükür olsun sana, şimdiden ebedince. //

[V2]
 // Bizim için çarmıha gerildin,
 Üçüncü günü kıyam da ettin.
 Şimdi yerin gökün kudreti sendedir. //

[V3]
 // Yalvarıyoz sana, İsa Mesih,
 Yine gelesin bu dünyamıza.
 Bizi alasın, seninle olalım ebedince. //</lyrics>
<title>Günahımızı affediyorsun BG567</title>
</song>