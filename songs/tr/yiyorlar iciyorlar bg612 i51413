<?xml version="1.0" encoding="UTF-8"?><song><title>Yiyorlar, içiyorlar BG612</title>
<lyrics>[C1]
   // Yiyorlar, içiyorlar,
   Günah işleyorlar,
   İsa'nın ismini
   İstemiyorlar. //

[C2]
   // Ver Allahım, ver bana,
   İman sevgi ver bana,
   Köyden köye gezeyim,
   İsmini ben öveyim. //

[C3]
   // İsa Mesih gelecek,
   Bu karanlık dünyadan
   Bizi alıp gidecek,
   Bize cennet verecek. //

[C4]
   // İman edin İsa'ya.
   Çünkü bir gün gelecek,
   İnanları alacak,
   İmansızlar yanacak. //</lyrics>
<hymn_number>612</hymn_number>
</song>