<?xml version="1.0" encoding="UTF-8"?><song><title>Allahım, güzelsin BG510</title>
<lyrics>[C1]
   Allahım, güzelsin,
   Bu dünyaya gelecen.
   // Al bizi, Allahım,
   Biz cennette olalım. //

[C2]
   Kuvvetsin, Allahım,
   kuvvetini duyduk biz.
   // Gel, İsa, yanıma.
   Yıka bizi kanınla. //

[C3]
   Kanını döktün sen,
   günahlarımız için.
   // Pakla bizi, Mesihim,
   O diri kanınla sen! //

[C4]
   Üzüldüm yürekten,
   İsa Rabbiciğime ben.
   // Korusun günahtan.
   Sade ona yalvaralım. //</lyrics>
<hymn_number>510</hymn_number>
</song>