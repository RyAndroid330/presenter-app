<?xml version="1.0" encoding="UTF-8"?><song><title>Benim RAB'bim bana yeter</title>
<lyrics>[V1]
 // Benim RAB'bim bana yeter.
 Neyleyim cihanı. //
 // Terk etmem İsa'yı,
 Verseler dünyayı. //

[V2]
 // Benim payım Rab İsa'dır.
 En büyük kârımdır. //
 // Kalsam da hep yalnız,
 İsa'm yanımdadır. //

[V3]
 // Benim RAB'bim güvenilir.
 Sözleri yok olmaz. //
 // O'na inananlar,
 Asla mahvolmazlar. //</lyrics>
<author>Durmuş Tünel</author>
</song>