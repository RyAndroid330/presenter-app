<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>85</hymn_number>
<title>Parlayan Aya Bak TÇ85</title>
<key>C</key>
<lyrics>[V1]
.C        G
 Parlayan aya bak,
.C           G
 Gece yıldızlara bak!
.F       C      E        Am
 Sayısız hepsi hesaplanamaz.
.D         D7        G
 Eşsiz mükemmel yapılmış.
.F    G7        C
 İsmine övgü olsun!

[V2]
 Dalgaların sesi,
 Yağmur sesini dinle!
 Sayısız damla denize düşer.
 Eşsiz, mükemmel yapılmış.
 İsmine övgü olsun!</lyrics>
</song>