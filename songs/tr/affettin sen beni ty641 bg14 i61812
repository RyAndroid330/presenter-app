<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>641</hymn_number>
<author>Bünyamin Yasmin</author>
<key>Em</key>
<lyrics>[C1]
.     Em   D  Em      D
   // Affettin, affettin,
.  Em    D      C
   affettin Sen beni //

[V1]
.Em   C             Am             Em
 Beni redetmedin Sen beni kabul ettin,
.(Em) C    D       Em
 Beni ismimle çağırdın.
.Em   C            Am          Em
 Beni terk etmedin kollarına aldın,
.(Em) C         D         Em
 suçlamadın Sen beni affettin.

[V2]
.Em  C                 Am      Em
 Günahıma bakmadın suçumu saymadın,
.(Em) C        D          Em
 Sen beni şefkatinle çağırdın.
.Em   C               Am       Em
 Derdimi dinledin hatamı affettin,
.(Em)   C      D            Em
 göz yaşlarımı sevginle sildin.

[V3]
.   Am                    Em
 // Çağırırım ismini, yakarırım duy beni,
.     D                   C           Em
 yalvarırım tut beni, ihtiyacım var Sana.
.      Am               Em
 Benim en zor anımda güçsüzlüğüme bakma,
.     D                            Em
 beni al Kollarına sar beni ve bırakma // .</lyrics>
<title>Affettin Sen beni TY641 BG14</title>
</song>