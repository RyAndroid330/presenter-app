<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Brak hayatı aç kalbini yürü sevgiye doğru //
 // Bırak geçen şeyleri yürü sevene doğru //
 // Benim arzum isteğim seni gönül bağımdan //
 // Sonsuza kadar tutmak sevgimin kucağında //

[V2]
 // Güneş, yıldız, ay çürür fani dünya yok olur //
 // Kalk sevdiğim ey canım sarıl seni sevene //
 // Benim arzum isteğim seni gönül bağımdan //
 // Sonsuza kadar tutmak sevgimin kucağında //

[V3]
 // Deniz akar denize dolaşarak yolunda //
 // Ateş arar günseşi birleşir kaynağında //
 // Benim arzum isteğim seni gönül bağımdan //
 // Sonsuza kadar tutmak sevgimin kucağında //</lyrics>
<title>Bırak hayatı aç kalbini</title>
</song>