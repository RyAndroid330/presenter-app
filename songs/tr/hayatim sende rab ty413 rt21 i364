<?xml version="1.0" encoding="UTF-8"?><song><title>Hayatım Sende, Rab TY413 RT21</title>
<lyrics>[C1]
.        G
   // Hayatım Sende, Rab,
.     Em
   Kuvvetim Sende, Rab,
.   C2
   Ümidim Sende, Rab,
.     G      D
   Sende, ya Rab! //
.           G      D       G
   (son) Sende, ya Rab, Sende!

[V1]
.     C      D      G
 Seni överim hayatımla,
.     C      D       G
 Seni överim kuvvetimle.
.  D          G         E       Am
 Bütün hayatımla, bütün kuvvetimle,
.  F             Dsus D
 Bütün ümidim Sende!__</lyrics>
