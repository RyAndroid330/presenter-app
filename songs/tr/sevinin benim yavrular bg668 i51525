<?xml version="1.0" encoding="UTF-8"?><song><title>Sevinin, benim yavrular BG668</title>
<lyrics>[V1]
 // Sevinin, benim yavrular, //
 Benim gelişime.
 // Geri dönmeyin siz //
 Beni bekleyin, yavrular.

[V2]
 // Siz öleseniz de,
 yaşayacaksınız. //
 Benim ismimde siz ölün.
 // Benim emrimdedir bu //
 Seveseniz birbirinizi.

[V3]
 // Bu sevgi var mı sizde, //
 İnanın ki, siz hepiniz bende.
 // Beni seven, beni sevenler, //
 Onlar da kardaşını sever.

[V4]
 // Benimle misiniz, yavrular ? //
 Bir şeyden korkmayın siz.
 // Sade siz dayanın. //
 Benim geldiyim güne kadar.
 // Sevinin siz yavrular, //
 Beraberce gökte olacaz.</lyrics>
<hymn_number>668</hymn_number>
</song>