<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<author>David Goodman</author>
<title>Huzur Geldi, Savaş Bitti TY22</title>
<lyrics>[V1]
.Am           E     Am
 Huzur geldi, savaş bitti,
.Am        E     Am
 Kazanıldı ruh zaferi!
.Am             E     Am
 Hamtlar olsun, sevdi bizi,
.Am  Dm/B E   Am  Dm/B E
 Halelu___ya, halelu___ya!

[V2]
 Ölüm dehşetini saçtı,
 İsa bu kudreti yendi.
 Alkışlayın bu zaferi,
 Haleluya, haleluya!

[V3]
 Üçüncü gün kıyam etti,
 Mesih muzaffer dirildi.
 Şan şerefle işte geldi,
 Haleluya, haleluya!</lyrics>
<key>Am</key>
</song>