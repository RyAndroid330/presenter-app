<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Siz hepiniz dayanın,
 Geleceğim güne kadar.
 Kelamımı dinleyin,
 Sizinle ben olayım. //

[C1]
   Ben gelecem,
   Yavrularım,
   Dayanın sona kadar.
   O çok büyük ateşten
   Sizi ben kurtarayım.

[V2]
 // Büyük ateş gelecek,
 Bütün dünya yanacak.
 Ben sizin Allahınızım,
 Sizi ben kurtarayım. //

[V3]
 // Gelin siz yavrularım,
 Ben sizi çok seviyom.
 Çünkü ateş gelecek,
 Sizi ben kurtaracam. //</lyrics>
<title>Siz hepiniz dayanın BG686</title>
<hymn_number>686</hymn_number>
</song>