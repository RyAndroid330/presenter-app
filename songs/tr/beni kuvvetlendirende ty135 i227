<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Beni kuvvetlendirende
 Her şey yapabilirim.  //
 //  Ne zaman da zayıf isem,
 O zaman kuvvetliyim.  //

[V2]
 //  Kendi zayıflıklarını
 Bilenlerin hepsine.  //
 //  Rab yakın ve yardım eder,
 Bu söz geçerli bize.  //

[V3]
 //  İsa'ya güvendiğimde
 İmkansız bir şey kalmaz.  //
 //  O'nun yolunda yürürken
 Mümkün olmayan olmaz.  //

[V4]
 //  Beni kuvvetlendirende
 Her şey yapabilirim.  //
 //  Hayat tecrübelerimde
 Galip gelebilirim.  //</lyrics>
<title>Beni Kuvvetlendirende TY135</title>
<author>David Goodman</author>
<hymn_number>135</hymn_number>
</song>