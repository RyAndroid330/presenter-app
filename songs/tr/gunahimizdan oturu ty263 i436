<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>263</hymn_number>
<author>Ali Yazar</author>
<title>Günahımızdan Ötürü TY263</title>
<lyrics>[V1]
 //  Günahımızdan ötürü
 O ezildi, yaralandı.  //
 O ezildi, yaralandı.
 //  Fesadımızdan ötürü,  //
 //  Acı çekti, zedelendi.  //

[V2]
 //  Tüm cezamız O'na indi,  //
 //  O vuruldu, alçaltıldı.  //
 O'nun yaralarıyla biz
 //  Esenlik ve barış bulduk.  //

[V3]
 //  Hepimiz yolu şaşırdık,
 Kendi yolumuza döndük.  //
 Kendi yolumuza döndük.
 //  Rab bizlerin günahını  //
 //  O'nun üzerine koydu.  //

[V4]
 //  Acımızı O taşıdı,  //
 //  Elemleri O yüklendi.  //
 Sandık cezaya uğradı,
 //  Ama bizim cezamızdı.  //

[V5]
 //  O'na kötülük ettiler,
 Ağzını açmadı bile.  //
 Ağzını açmadı bile.
 //  Boğazlanan kuzu gibi  //
 //  O hiç karşılık vermedi.  //

[V6]
 //  Rab tarafından vuruldu,  //
 //  Tamamen O alçaltıldı.  //
 O'nun elemleriyle biz
 //  Yaşıyoruz ve kurtulduk.  //</lyrics>
</song>