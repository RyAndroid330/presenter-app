<?xml version="1.0" encoding="UTF-8"?><song><title>İsa Mesih, beni zor durumdayken</title>
<key>Em</key>
<lyrics>[V1]
.Em               C        D
  İsa Mesih, beni zor durumdayken
.Em                 C       D
  Seslendim sana ve yardım ettin
.Em                 C    D
  Rab İsa her zaman yanımdasın
.Em                 C        D
  Kalbimdesin, benimle birlikte

[C1]
.  C           G
    Beni sevdin ve gösterdin
.  D                Em7
    Çarmıh üzerinde ölümünle
.  C            G
    Üç gün geçti ve dirildin
.  D               Em7     C    G     D G
    Beni sevdiğine eminim ben, eminim ben

[V2]
.Em              C     D
  İsa Mesih seni çok severim
.Em               C      D
  Çünkü önce beni sen kurtardın
.Em                  C   D
  Günahlarım çokken, çaresizken
.Em              C     D
  Benim uğruma öldün dirildin

[V3]
.Em              C     D
  İsa Mesih sana iman ettim
.Em                 C       D
  &quot;Kurtarıcım ve Tanrımsın&quot; dedim
.Em             C   D
  Ama yüreğimi açan sensin
.Em                 C       D
  Sözlerin ve lütfunla bunu yaptın</lyrics>
<aka>Beni sevdiğine eminim ben</aka>
<author>Mustafa Atlıg, Nick Mott, Ronya Atlıg</author>
</song>