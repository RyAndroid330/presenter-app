<?xml version="1.0" encoding="UTF-8"?><song><title>O güzel evim benim BG653</title>
<lyrics>[V1]
 O güzel evim benim,
 Bahçem, benim renkliğim,
 // Niçin böyle düşmüşsün,
 O yaz çiçek gibi. //

[V2]
 Kalk artık, uyan artık.
 Kaldır başını bana.
 // Vakıt geldi, açılasan,
 Salasan hoş kokunu. //

[V3]
 Hatırla, sen evimi,
 Senin ilk sevgini.
 // Nasıl kokunu salardın,
 Yemişi getirirdin. //

[V4]
 Bak dinlemeyenlere !
 Düşmüşler, yaprak gibi.
 // Sürülmüşler ilk lüzgyarda,
 Gidyorlar cendeme. //

[V5]
 Kalk artık, uyan artık,
 Kaldır başını bana.
 // Bekle beni ben geliyom,
 Alayım seni göke. //</lyrics>
<hymn_number>653</hymn_number>
</song>