<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>672</hymn_number>
<title>Sevmişin beni BG672</title>
<lyrics>[V1]
 Sevmişin beni,
 Ben de seni.
 // Hep geriye kaldınız,
 Kabahatlı gibi. //

[V2]
 Sevin siı beni,
 Hem de dinleyin.
 // Deli gibi gezecekler,
 Dinlemezler. //

[V3]
 Sevin Allahı,
 Sevin güdücüyü.
 // Gökteki cenneti
 Sizde de olsun. //

[V4]
 Sevmişin beni,
 Neye sevmişin.
 // Neye sakındın, yavrum,
 Saklanma benden. //

[V5]
 Saklanma benden,
 Söyle sen beni.
 // Sevindir beni,
 Sonra ben seni. //

[V6]
 Severim sizi,
 Hepinizi.
 // Neye inandınız,
 Alacam sizi. //

[V7]
 Sevinin siz, en çok
 Siz sevinin.
 // Gökte cennetim,
 Size de olsun. //</lyrics>
</song>