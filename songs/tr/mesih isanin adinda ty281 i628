<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>281</hymn_number>
<author>Ali Yazar</author>
<title>Mesih İsa'nın Adında TY281</title>
<lyrics>[V1]
 //  Mesih İsa'nın adında
 Göktekiler, yerdekiler  //
 //  Diz çöksünler, eğilsinler,
 Tanrım, sana tapınsınlar.  //

[V2]
 //  Tanrı yüceliği için
 Her dil İsa Rab'dir desin.  //
 //  Her dil O'nu açıklasın,
 Evet, İsa Rab'dir desin!  //

[V3]
 //  Mesih İsa'nın adında
 Yerdekiler, göktekiler  //
 //  Eğilsinler, diz çöksünler,
 Baba, sana tapınsınlar.  //</lyrics>
</song>