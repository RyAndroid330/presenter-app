<?xml version="1.0" encoding="UTF-8"?><song><title>Ne para ne de dünya 'nın sevgisi</title>
<lyrics>[C1]
   // Ne para ne de dünya'nın sevgisi,
.      
       acımı dindiremiyor
   kimse kalbimi teselli edemiyor //

[C2]
   // Güçlü olmak istiyorum
.      
       Teselli bulmak
   yardımcım olsun istiyorum //

[C3]
   // Çarmıha gerilmiş Isa'yı
   hayatıma ve de kalbime istiyorum
   kurtulmak istiyorum //</lyrics>
<author>bulgaristan ilahisi</author>
</song>