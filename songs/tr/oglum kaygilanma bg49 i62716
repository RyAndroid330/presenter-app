<hymn_number>49</hymn_number>
<lyrics>[V1]
.Em            D          C
 // Oğlum kaygılınma dedim sana,
.Em          D          C
 Her dilediğini söyle Bana. //

[C1]
.     G                 D
   // Ben senin Zengin Baban,
.       Am        Em
   Herşeye gücü yeten.
.       C          D
   Bana derdini anlat,
.     Am           Em
   Bende huzur bul sen. //

[V2]
 // Artık kaygılanmak yok bana,
 Her dilediğimi bıraktım sana. //

[C2]
   // Sen benim Zengin Babam,
   Herşeye Gücü yeten.
   Sana derdimi anlattım,
   Sende huzur buldum. //</lyrics>
<key>Em</key>
<title>Oğlum Kaygılanma BG49</title>
</song>