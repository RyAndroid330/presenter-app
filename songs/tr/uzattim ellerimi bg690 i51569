<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>690</hymn_number>
<lyrics>[V1]
 // Uzattım ellerimi
 Ben Allahıma. //
 // Alacak Rabbim beni
 Onun yanına. //

[V2]
 // Dayanın yavrularım,
 Dayma dayanın. //
 // Dayanın kuzularım,
 Dayma dayanın. //

[V3]
 // Artık vakıt geliyor,
 Alacam sizi . //
 // Kuşlar gibi uçacanız
 Benim yanıma. //

[V4]
 // Melek gibi çok parlak
 Olacağınız. //
 // Dayanın yavrularım,
 Dayma dayanın. //

[V5]
 // Dayanın kuzularım,
 Dayma dayanın. //
 // Dayanın ümmetlerim,
 Dayma dayanın. //</lyrics>
<title>Uzattım ellerimi BG690</title>
</song>