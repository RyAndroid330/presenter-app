<?xml version="1.0" encoding="UTF-8"?><song><title>Koru Beni Ey Tanrım RT30</title>
<lyrics>[V1]
.Em        D      Em
 Koru beni ey Tanrım
.C           D       Em
 Çünkü Sana sığınıyorum
.Em        D      Em
 Kaseme düşen Sensin
.C          D      G
 Yaşamım Senin elinde!

[C1]
.            Em    Am      G     Em
   // Rab'be dedim ki efendim Sensin
.         C        B7           Em
   Senden öte mutluluk yoktur bana //

[V2]
.Em          D      Em
 Gözümü Rab'den ayırmam
.C           D    Em
 Sağımdadır sarsılmam
.Em           D        Em
 Bu yüzden sevinç doluyum
.C          D      G
 Yüreğim coşuyor Sende

[B1]
.     C                  D
   // Yaşamım Senin elinde
.                     C
   Yaşamım Senin elinde
.                     D
   Överim Seni Rab İsa'm //</lyrics>
<key>G</key>
<author>Jeremy Perigo, Alper Gürsu, Metin Özkaya</author>
<hymn_number>30</hymn_number>
</song>