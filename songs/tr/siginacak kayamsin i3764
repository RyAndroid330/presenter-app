<?xml version="1.0" encoding="UTF-8"?><song><title>Sığınacak Kayamsın</title>
<lyrics>[V1]
 // Sığınacak kayamsın kulemsin Rab Isa
 Desteğim kuvetim yaşama gucumsun //

[V2]
 // Sen Kralımsın Allahım
 sevdiğim taptığım kralsın //

[V3]
 // Her günumu yöneten
 hamtların Allahısın //

[V4]
 // Merhametin sonsuzdur Allahım Rab Isa
 Seversin Sen beni çennetini verersin //

[V5]
 // Sen Kralımsın Allaım
 sevdiğim taptığım kıralsın //

[V6]
 // Her günumu yöneten
 hamtların Allahısın //</lyrics>
</song>