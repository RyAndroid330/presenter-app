<?xml version="1.0" encoding="UTF-8"?><song><title>Sen Benim Hayatıma Girdiğinden Beri TY577</title>
<lyrics>[V1]
 // Sen benim hayatıma girdiğinden beri,
 Bambaşka bir insan oldum o günden beri. //
 Eski Adem'den kalmamış günah izleri,
 // Rab İsa giydirdi bana yeni Adem'i. //

[C1]
   (Erkekler) // Yeniden doğdum İsa'yla,
   (Bayanlar) Şükür, kurtuldum İsa'yla,
   (Erkekler) Sevinci buldum İsa'yla,
   (Herkes) İsa'yla.
   (Erkekler) Güler, oynarım İsa'yla,
   (Bayanlar) Ağlar, coşarım İsa'yla,
   (Erkekler) Şimdi mutluyum İsa'yla,
   (Herkes) İsa'yla. //

[V2]
 // İsa giydirecek bana yaşam tacını,
 Çünkü O taşıdı günahımı, acımı. //
 Şimdi O'na bırakırım tüm hayatımı,
 // Rab İsa yönetsin benim tüm yaşantımı. //</lyrics>
<author>Şaban Ok</author>
<hymn_number>577</hymn_number>
</song>