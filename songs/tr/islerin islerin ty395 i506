<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>395</hymn_number>
<title>İşlerin - İşlerin TY395</title>
<lyrics>[V1]
.   D
 // İşlerin - İşlerin
.Bm7
 Ne ulu, - Ne ulu,
.G        Em7
 Gücün, - Gücün,
.Asus4            (A)
 Ne yüce! - Ne yüce! //

[C1]
.  C  G     D
   Yücedir işlerin,
.  C   G    D
   Yücedir, Rab!
.  C  G      D
   Ulu ve güçlü,
.  C         Asus4 A
   Uludur, Rab.

[V2]
 // Hakimsin, - Hakimsin,
 Daima, - Daima,
 Güçle, - Güçle,
 Hakimsin! - Hakimsin! //

[V3]
 // Çünkü Rab, - Çünkü Rab,
 Yüceliğin, - Yüceliğin,
 Tüm yeryüzü, - Tüm yeryüzü,
 Hamd eder! - Hamd eder! //</lyrics>
<key>D</key>
</song>