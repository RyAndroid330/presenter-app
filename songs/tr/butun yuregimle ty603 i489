<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>603</hymn_number>
<author>Armin Knothe</author>
<lyrics>[V1]
 Bütün yüreğimle
 Ve bütün gücümle Rab,
 Bütün canımla
 Seni hep seveceğim.

[V2]
 Bütün yüreğimle
 Ve bütün gücümle Rab,
 Tüm varlığımla
 Seni hep seveceğim.
 //  İsa, İsa önce sen beni sevdin.  //
 //  Önce sen beni sevdin.  //

[V3]
 //  Bütün aklımla,
 Bütün gücümle,
 Seni hep seveceğim.  //</lyrics>
<title>Bütün Yüreğimle TY603</title>
</song>