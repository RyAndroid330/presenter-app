<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>518</hymn_number>
<lyrics>[V1]
 // Bak bu dünya, ne dünya
.    
     Çok aldattı, oynattı.
.    
     Çok aldattı, oynattı.
.    
     İstediyi gibi yaptı. //

[V2]
 // Allahım beni buldu,
.    
     Beni elimden tuttu.
.    
     'Bu yoldan gitme.' dedi.
.    
     'Ne için yanacan.' dedi. //

[V3]
 // Vakıt yoktur, yavrular.
.    
     Kuvvetimi brakacam.
.    
     Birer birer tutacam.
.    
     Hepinizi alacam. //

[V4]
 // Dünyayı kurtaracam.
.    
     Sonra par par yakacam.
.    
     İnsanları alacam.
.    
     Göklere uçuracam. //

[V5]
 // İnanmadık insanlar,
.    
     Bunu hepsi görecek.
.    
     Gözleri yukarıda kalacak,
.    
     Boynu bükük olacak. //</lyrics>
<title>Bak bu dünya, ne dünya BG518</title>
</song>