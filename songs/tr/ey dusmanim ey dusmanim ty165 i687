<?xml version="1.0" encoding="UTF-8"?><song><author>Suna Uysal, Ali Yazar</author>
<hymn_number>165</hymn_number>
<lyrics>[C1]
   //  Ey düşmanım, ey düşmanım,
   Ben düşersem, ben kalkarım.  //
   //  Düştüğüm için sevinme,
   Rab'dir elimden tutanım.  //

[C2]
   //  Karanlıkta oturursam,
   Rabbim bana ışık olur.  //
   //  O'ndan uzaklaşsam bile
   Beni arayıp da bulur.  //

[C3]
   //  O zaman düşman görecek
   Ve onu utanç örtecek.  //
   //  Rab İsa adaletiyle
   Beni hep destekleyecek.  //</lyrics>
<title>Ey Düşmanım, Ey Düşmanım TY165</title>
</song>