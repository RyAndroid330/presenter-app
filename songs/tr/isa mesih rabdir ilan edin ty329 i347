<?xml version="1.0" encoding="UTF-8"?><song><title>İsa Mesih Rab'dir, İlan Edin! TY329</title>
<lyrics>[C1]
   İsa Mesih Rab'dir, ilan edin!
   Kurtarıcımızdır, şükredin!
   İsa Mesih Rab'dir, iman edin!
   Kutsal olan yaşam verendir!

[V1]
 //  (Kadın) İsa, (Erkek) İsa,
 (Kadın) Egemensin, (Erkek) Egemensin,  //
 //  Kalplerdesin, işlerdesin,
 Tüm evrende bir çaresin.  //

[V2]
 //  (Kadın) Baba, (Erkek) Baba,
 (Kadın) Bağışlarsın, (Erkek) Bağışlarsın,  //
 //  Temizlersin, denetlersin,
 Her günümde benimlesin.  //

[V3]
 //  (Kadın) Kardeş, (Erkek) Kardeş,
 (Kadın) Dinle beni, (Erkek) Dinle beni,  //
 //  Kalbim' açtım, gönlüm' verdim,
 Rab İsa'da yaşam buldum.  //</lyrics>
<author>Faruk Peker</author>
<hymn_number>329</hymn_number>
</song>