<?xml version="1.0" encoding="UTF-8"?><song><author>Twila Paris</author>
<hymn_number>526</hymn_number>
<title>Rab'bi Beklerim TY526</title>
<lyrics>[V1]
 Rab'bi beklerim,
 Sözünü beklerim,
 Kelamına güvenirim,
 Beklerim, beklerim.

[V2]
 Rab'bi beklerim,
 Sözünü beklerim,
 Gelinceye kadar beklerim.
 Bilgeliğini ararım.
 Hareket etmeden, konuşmadan,
 Rab'bi beklerim,
 Rab'bi beklerim.</lyrics>
</song>