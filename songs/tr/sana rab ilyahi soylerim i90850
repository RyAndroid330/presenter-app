<?xml version="1.0" encoding="UTF-8"?><song><author>Dechko Dechkov</author>
<title>Sana Rab ilyahi söylerim</title>
<key>D</key>
<lyrics>[C1]
.      D             A
   // Sana Rab ilahi söylerim
.  G                   F#m      Bm
   Kabul et sen bu kurbanımı //
.          Bm      A     G
   // Görkemli Kralsı sen
.    F#m     Bm
   Ve layıksın //

[C2]
   // Övüyoum Tanrım, şimdi ben seni
.      
       tüm kalbimle seni, yüceltirim //
   // Kutsal, ve okadar iyi
.      
       ve layıksın //

[C3]
   // Hamdolsun hamdolsun
   Senin Yüce ismine //
   // Muhteşemsin ey Rabbim
   ve layıksın //</lyrics>
</song>