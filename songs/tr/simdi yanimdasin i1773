<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.D           G                Bm
 Önündeyim Senin. Rab Seni överim.
.             G     A            D
 Sevgine muhtacım. İsa, çok muhtacım.

[V2]
.D          G                Bm
 Rab Sana aitim. Yaşamını verdin.
.             G     A            Bm
 Lütfuna muhtacım. İsa, çok muhtacım.

[P1]
.  Bm   G          D    A
   Kollarında tut. Beni bırakma.
.  Bm      G         D        A
   Sonsuza dek ben Seninleyim Rab

[C1]
.     D         A
   Şimdi yanımdasın
.           Bm
   Herşey değişti, Rab
.               G
   Herşey çok değişti, Rab
.         D         A
   Ve ben çok farklıyım
.           Bm
   Çok değiştim
.             G               D
   Seninleyim Rab. Seninleyim Rab

[B1]
.         A       Bm A
   Sana ezgi söylerim
.  Bm      G             D          G
   Varlığında Rabbim hep kalmak isterim.</lyrics>
<title>Şimdi Yanımdasın</title>
<capo>2</capo>
<author>Hillsong</author>
</song>