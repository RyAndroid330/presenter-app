<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>667</hymn_number>
<lyrics>[V1]
 /// Sevin sen, İsa'yı çağır !
 Gece gündüz Onu an ! ///
 // Gunahlarını
 Denize O attı. //

[V2]
 /// Senin için Rab İsa
 Haçta çekti acıyı. ///
 // Adını yazdı
 Hayat kitabına. //

[V3]
 /// Sen Hizmet et İsa'ya,
 Ödülün büyük olsun ! ///
 // Sevinçle senin
 Yüreyinde kalsın. //</lyrics>
<title>Sevin sen, İsa'yı çağır ! BG667</title>
</song>