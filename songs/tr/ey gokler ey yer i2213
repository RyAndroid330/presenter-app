<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am         E  Am
 // Ey gökler, ey yer! //
.   Dm       E7        Am
 // Tanrımız övgüye değer. //
.   Am      E7       Am
 // Hepimiz günahlıydık //
.G       F      E
 Lütfuna muhtaçtık,
.   G            F         B7       E7   Am
 // Gökten gelen Mesih'le, biz affa ulaştık. //

[V2]
.   Am         E  Am
 // Ey gökler, ey yer! //
.   Dm      E7         Am
 // Hepimiz o lütfa bedel. //
.   Am      E7       Am
 // Hepimiz günahlıydık, //
.G       F      E
 Sevgiye hep açtık,
.   G            F        B7        E7   Am
 // Gökten gelen o aşkla, biz hakka ulaştık. //

[V3]
.   Am         E  Am
 // Ey gökler, ey yer! //
.   Dm       E7          Am
 // Rabbimiz her şeye yeter. //
.   Am      E7       Am
 // Hepimiz günahlıydık, //
.G      F         E
 Günaha bağlanmıştık,
.   G            F        B7       E7       Am
 // Gökten gelen bağışla, lütfunla aklanmıştık. //

[V4]
.   Am         E  Am
 // Ey gökler, ey yer, //
.   Dm      E7         Am
 // yolumuz sonsuza gider. //</lyrics>
<title>Ey Gökler Ey Yer</title>
<author>Turgay Üçal</author>
</song>