<?xml version="1.0" encoding="UTF-8"?><song><title>Rab'be Hamdedin, Hamdedin! TY352</title>
<key>A</key>
<lyrics>[C1]
.     A         D           A
   // Rab'be hamdedin, hamdedin!
.            D      E    A
   Rab'be göklerden hamdedin!  //

[V1]
.        E    E7          A
 Bütün melekleri, O'na hamdedin,
.         E       E7   A
 Ey bütün ordusu, hamdedin!
.         E      E7       A
 Ey güneş ve ay, O'na hamdedin,
.        E           E7   A
 Ey göklerin gökleri hamdedin!

[V2]
 Ateş ve dolu, O'na hamdedin,
 Kar ile buğu, hamdedin!
 Dağlar ve tepeler, O'na hamdedin,
 Meyvalı ağaçlar hamdedin!

[V3]
 Genç yiğitler, kızlar, O'na hamdedin,
 İhtiyarlar ve çocuklar, hamdedin!
 Dünyanın kralları, O'na hamdedin,
 Reisler ve hakimler, hamdedin!</lyrics>
<author>Bünyamin Yasemin</author>
<hymn_number>352</hymn_number>
</song>