<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>118</hymn_number>
<title>Tanrı Bizim Kayamızdır TY118</title>
<key>F</key>
<lyrics>[V1]
.   Dm          Am     Dm
 // Tanrı bizim kayamızdır,
.Dm        Am     Dm
 Sığınacak gücümüzdür. //
.   Gm                  Bb
 // Denenmede, zorluklarda
.Dm          Am      Dm
 Hemen hazır yardımcıdır. //
.           Am     Dm      Am7
 // Biz korkmayız, biz korkmayız. //

[V2]
.   Dm          Am      Dm
 // Bütün dünya alt üst olsa,
.Dm         Am       Dm
 Dağlar denize devrilse, //
.   Gm                  Bb
 // Sular kükreyip karışsa,
.Dm         Am       Dm
 Evren korkudan titrese, //
.           Am     Dm      Am7
 // Biz korkmayız, biz korkmayız. //

[V3]
.   Dm          Am     Dm
 // Çünkü Tanrı kayamızdır,
.Dm        Am     Dm
 Sığınacak gücümüzdür. //
.   Gm                  Bb
 // Sıkıntıda, zorluklarda //

[V4]
 Hemen hazır yardımcıdır. //
.            Am     Dm      Am7
 //  Bir korkmayız, biz korkmayız.</lyrics>
</song>