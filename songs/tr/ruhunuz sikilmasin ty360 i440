<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>360</hymn_number>
<author>Suna Uysal, Memduh Uysal, Memduh Uysal</author>
<lyrics>[V1]
 //  Ruhunuz sıkılmasın,
 Baba'ya iman edin.
 Kaygınız çoğalmasın,
 Bana da iman edin.  //

[V2]
 //  İnanın Baba'dayım,
 Ve Baba da bendedir.
 Sizi öksüz bırakmam,
 Size yine gelirim.  //

[V3]
 //  Beni seviyorsanız
 Sözümü tutarsınız.
 Beni seven kişiyi
 Babam da sevecektir.  //

[V4]
 //  Beni Babam gönderdi.
 Esenlik veriyorum.
 Boşa kaygılanmayın,
 Teselli ediyorum.  //

[V5]
 //  Yaşam gerçektir adım.
 Kurtarıcı Rab, benim.
 Bana iman edene
 Sonsuz yaşam veririm.  //
 Sonsuz yaşam veririm.</lyrics>
<title>Ruhunuz Sıkılmasın TY360</title>
</song>