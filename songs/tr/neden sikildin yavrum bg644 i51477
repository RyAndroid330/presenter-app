<?xml version="1.0" encoding="UTF-8"?><song><title>Neden sıkıldın, yavrum BG644</title>
<lyrics>[V1]
 // Neden sıkıldın, yavrum,
 Neden düşündün.
 Neden sen bana, yavrum,
 Hiç güvenmedin ? //

[V2]
 // Bilmez misin, sen yavrum,
 Ben kurban gittim.
 Hepiniz için, yavrum,
 Kanımı döktüm. //

[V3]
 // Dooru yoldan git, yavrum.
 İman et bana.
 Yerin hazırdır, yavrum,
 Gökler yüzünde. //

[V4]
 // Kaldır kafanı, yavrum.
 İnat olma sen.
 Aala bana, yavrum, sen.
 Aala bana sen. //

[V5]
 // Düşünceni sen, yavrum,
 Teslim et bana.
 Al benim Ruhumu,
 Şen ol dünyada. //</lyrics>
<hymn_number>644</hymn_number>
</song>