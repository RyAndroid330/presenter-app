<?xml version="1.0" encoding="UTF-8"?><song><author>Turgay Üçal</author>
<title>Ol Sözünde Rab Allah</title>
<lyrics>[V1]
 Ol sözünde Rab Allah Seni bilirim
 Sevincinde senle sevinirim

[V2]
 Senden geldim Rab Allah sana giderim
 Ruhun ile benden sana dönerim

[V3]
 Yolun uzun Rab Allah bitmez seferim
 Mesih'inde sende sana gelirim</lyrics>
</song>