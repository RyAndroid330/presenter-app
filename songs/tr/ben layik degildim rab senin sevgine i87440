<?xml version="1.0" encoding="UTF-8"?><song><author>Edip Avcıoğlu</author>
<title>Ben Layık Değildim, Rab Senin Sevgine</title>
<lyrics>[V1]
.   Am             Dm                  Am
 // Ben layık değildim, Rab senin sevgine
.               G              Am
 Ama sen lütfedip kendine çektin. //

[V2]
 // Ellerimi sana ben açıyorum,
 Bağışla Rab İsa, senden diliyorum. //

[V3]
 // Dualar sana ben yapıyorum,
 Sen kabul et İsa, sana yalvarıyorum. //</lyrics>
<key>Am</key>
</song>