<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Yabancıyız bu Dünyada
 Günahlı insanlarız
 Kötülükler yapıyoruz
 Biz bu yeryüzünde //

[V2]
 // Bıktım artık bu Günahtan
 Kurtulmak istiyorum
 Biri bana yardim etsin
 Diye ben bağırıyorum //

[V3]
 // Biri bana yardim etti
 Biri bana güc verdi
 O Rab İsa mesihti
 O beni kurtardı //

[V4]
 // Şükürler olsun Mesihe
 O beni kurtardi
 Günahlarımdan kurtuldum
 Rab İsa sayesinde //

[V5]
 // Sonsuz yaşam var şimdi
 Artık bende sahibim
 Günahlarımdan kurtuldum
 Rab İsa sayesinde //</lyrics>
<title>Yabancıyız bu Dünyada</title>
</song>