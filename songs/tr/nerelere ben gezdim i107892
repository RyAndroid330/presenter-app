<?xml version="1.0" encoding="UTF-8"?><song><title>nerelere ben gezdim</title>
<lyrics>[V1]
 // Nerelere ben gezdim
 başıma çare bulmadım //

[V2]
 // Olamam, olamam Allah'ım
 Ani sensiz benim babacım //

[V3]
 // Ben Allah'ım hastayım
 Sende Allah'ım umudum //

[V4]
 // Doktorlara ben gezdim
 Şifa Allah'ım bulmadım //

[V5]
 // Köyden köğe ben gezdim
 Şifa Allah'ım bulmadım //

[V6]
 // Ben Allah'ım kimsesiz
 Brakma beni sen yalniz //</lyrics>
</song>