<?xml version="1.0" encoding="UTF-8"?><song><title>Bak Elemler Adamı TY654</title>
<key>Em</key>
<lyrics>[V1]
.    Em           D
 Bak elemler adamına
.       C   D    Em
 Çarmıhta O ölmekte
.      Em         D
 Mesih böyle reddedildi
.   Am      D   Em
 Acıya terk edildi

[V2]
.D/F#  G           D
 Oʼydu beklenen Peygamber
.      C          B
 Davut oğlu Mesihʼti
.      C           D
 Oğluyla Tanrı gönderdi
.     Am     D    Em
 Diri ve gerçek sözü

[V3]
.     Em            D
 Görüldü mü tüm dünyada
.      C     D   Em
 Böyle derin bir acı?
.     Em              D
 Dostları korkup terk etti
.     Am     D   Em
 Düşmanları suçladı

[V4]
.D/F#   G            D
 Kalktı eller vurmak için
.     C          B
 Korumadı hiç kimse
.      C             D
 Fakat en derin darbeyi
.   Am    D     Em
 Adalet Oʼna vurdu

[V5]
.      Em        D
 Sen günahı küçümseyen
.     C   D  Em
 Onu hafife alan
.       Em         D
 Bak ve gör bu kötülüğü
.    Am     D   Em
 Hak ettiği cezayı

[V6]
.D/F#    G         D
 Bak verilen o kurbana
.     C       B
 Yükünü taşıyana
.       C            D
 Oʼydu Mesih, Tanrı sözü
.    Am     D    Em
 İnsanoğlu çarmıhta

[V7]
.      Em         D
 Sağlam temelimiz Oʼnda
.    C      D  Em
 Ebedi sığınağımız
.     Em          D
 Kurtuluş kayamız Oʼdur
.   Am      D  Em
 İsmiyle övünürüz

[V8]
.D/F#   G         D
 Tanrı kuzusu çarmıhta
.    C         B
 Günahı bağışlatan
.    C        D
 Utandırılmayacaklar
.    Am    D   Em
 İsmine güvenenler</lyrics>
<author>Thomas Kelly</author>
<hymn_number>654</hymn_number>
</song>