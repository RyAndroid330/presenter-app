<?xml version="1.0" encoding="UTF-8"?><song><author>Hiltrud Ströhlein</author>
<hymn_number>113</hymn_number>
<title>Sevinirim, Sevinirim TÇ113</title>
<lyrics>[C1]
.  D                      A7         D
    Sevinirim, sevinirim, kalbim coşuyor.
.  D                       A7        D
   Alkışlarım, alkışlarım, çok sevinirim.
.      A7                      D
   Rab Tanrı beni (seni, bizi) çok sevdi,
.   A7                      D
   İsa'yı bana (sana, bize) gönderdi.

[C2]
   Rab İsa'nın doğuşunu
   Kutlarız büyük coşkuyla.

[C3]
   İsa Beytlehem'de doğdu.
   İşte, Tanrı insan oldu.

[C4]
   Melekler gökten seslendi:
   İşte, kurtarıcı geldi.

[C5]
   Çobanlar koşup geldiler,
   Bu armağanı gördüler.

[C6]
   Dünya kralın gelişini
   Yıldızlar da ilan etti.</lyrics>
<key>D</key>
</song>