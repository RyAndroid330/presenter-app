<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>128</hymn_number>
<author>Hiltrud Ströhlein</author>
<key>G</key>
<lyrics>[V1]
.G            D
 Yaşam artık karanlık,
.D7            G
 Biz çok günah işledik.
.G     C        D  D7  G
 Tanrı'ya yaklaşamıyoruz.

[V2]
 İsa dünyaya geldi,
 Çarmıhta canını verdi,
 Kanını döktü bizim için.

[V3]
 Yeni yaşam verecek,
 Tertemiz hayat gerçek,
 Eğer O'nu kabul edersek.

[V4]
 Tanrı'ya yaklaşacak,
 Cennette bulunacak,
 Sonsuz yaşamı alacağız.

[V5]
 İsa'yla büyüyecek,
 O'na dua edecek,
 İncil'i okuyacağız.</lyrics>
<title>Yaşam Artık Karanlık TÇ128</title>
</song>