<?xml version="1.0" encoding="UTF-8"?><song><author>Cengiz</author>
<lyrics>[V1]
 // Her zaman Rab'be övgüler
 Sunacağım ben //

[V2]
 // Çünkü beni o kurtardı
 Günahım'dan zayıflığım'dan //

[V3]
 // Karar verdim adımlarıma
 Dikkat edeceğim ben //

[V4]
 // Ya Rab İsa'm bundan sonra
 Beni sen kullan Rabbim //

[V5]
 // Günahtan dünyadan uzak
 Tut beni yüce Rabbim //

[V6]
 /// Övguler sunacağım ben
 Her zaman sana Rabbim ///</lyrics>
<title>Her zaman Rabbe övguler</title>
</song>