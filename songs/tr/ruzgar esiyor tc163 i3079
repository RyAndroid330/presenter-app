<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
 (Konuşarak)
 // Rüzgar esiyor, vuvv, vuvv. //
 Hızlı esiyor, vuvv, vuvv, vuvv, vuvv.

[V2]
 // Fırtına kopuyor, vuvv, vuvv. //
 Kuvvetli artıyor, vuvv, vuvv, vuvv, vuvv.

[V3]
 Her şey uçuyor, vuvv, vuvv.
 Dalgalar yükseliyor, foşş, foşş.
 Herkes korkuyor. Uuu, uuu, uuu, uuu!</lyrics>
<title>Rüzgar Esiyor TÇ163</title>
<hymn_number>163</hymn_number>
<author>Hiltrud Ströhlein</author>
</song>