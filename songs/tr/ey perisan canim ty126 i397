<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<lyrics>[V1]
.   Em  B7    Em
 Ey perişan canım,
.         Am    B7
 Vazgeç dolaşmaktan!
.   Em          Am6  B7
 // Bu dünyanın çevresinde
.  Em    B7    Em
 Sana yoktur vatan. //

[V2]
.  Em      B7   Em
 İşte, Rab'bin evi!
.       Am    B7
 İşte, açık kapı!
.   Em             Am6   B7
 // Gir, ey canım, bu meskene!
.   Em     B7  Em
 Al sonsuz hayatı! //

[V3]
.   Em   B7   Em
 Or'da otur emin,
.       Am      B7
 Seni sever Rabbin.
.   Em         Am6   B7
 // Arzuların' eder tatmin,
.    Em    B7    Em
 Her şey olur senin. //

[V4]
.   Em  B7    Em
 Ey perişan canım,
.         Am    B7
 Vazgeç dolaşmaktan!
.   Em          Am6  B7
 // Bu dünyanın çevresinde
.  Em    B7     Em
 Sana yoktur vatan. //</lyrics>
<key>Em</key>
<title>Ey Perişan Canım TY126</title>
</song>