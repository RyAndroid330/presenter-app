<?xml version="1.0" encoding="UTF-8"?><song><author>Sherif Levit</author>
<lyrics>[V1]
 // Acılarında sıkıntılarımda
 Her zaman Rabbi ara
 İmanla yürü imanla yaşa
 Gerçeği yaz yüreğinin levhasına //
 // Rab İsa'nın ışığı görülsün hayatında //

[C1]
   // İbrahimin imanını davudun yüreğini
   Pavlusun işçiliğini İsa'nın sevgisi //
   İstiyorum
   // Seni hoşnut etmek için yarab //
   «. Neden üzgünsün, ey gönlüm,
   Neden içim huzursuz?
   Tanrı'ya umut bağla,
   İmanla yürü imanla yaşa
   // Rab İsa'nın ışığı görülsün hayatında //

[C2]
   // İbrahimin imanını davudun yüreğini
   Pavlusun işçiliğini İsa'nın sevgisi //</lyrics>
<title>İmanla yürü imanla yaşa</title>
</song>