<?xml version="1.0" encoding="UTF-8"?><song><author>Banu Çelik</author>
<title>Ayağım Kayıyor</title>
<key>Am</key>
<lyrics>[V1]
.Am        E               Am
 Ayağım kayıyor, dediğimde Ya Rab
.            E                   Am
 Tutarsın beni sen, sarsılmaz sevginle
.Dm        Am    Dm         Am
 Kaygılar içimi, sardığında birden
.            E               Am
 Şu garip gönlümü, avutursun yine

[C1]
.  Am             Dm                    C
   Lütuf üstüne lütuf, Sevgi üstüne sevgi
.               E                        Am
   Yürürüm yolunda, bir tek senin lütfunla
.                    Dm                 Am
   Yetmez tüm çabalarım, Ne gücüm ne bilgim
.                E                       Am
   Yürürüm yolunda, bir tek senin lütfunla

[V2]
.Am         E                Am
 Ayağım sürçerse, gücüm tükenirse
.              E              Am
 Korursun beni Rab merhametin ile;
.Dm     Am       Dm        Am
 Canımı ölümden, gözlerimi yaştan
.            E                     Am
 Kurtarırsın ya Rab, feryat ettiğimde</lyrics>
</song>