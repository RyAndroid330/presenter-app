<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>445</hymn_number>
<lyrics>[V1]
 Yollarını öğret,
 Gerçekte yürüyeyim.
 İsteğini göster,
 Sadık olayım.
 Arınmak tek isteğim,
 Hizmet etmek tek arzum!

[V2]
 Kalbimi lütfen tek kıl ki,
 Adından korkayım!
 Kalbimi lütfen tek kıl, Rab.
 Başka Tanrı,
 Başka sevgi,
 Senden başka Tanrı yok!</lyrics>
<title>Yollarını Öğret TY445</title>
</song>