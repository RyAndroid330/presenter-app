<?xml version="1.0" encoding="UTF-8"?><song><author>Aygün Çamsun, Gürkan Çamsun</author>
<hymn_number>479</hymn_number>
<title>Senin Tahtının Önünde Dururum TY479 RT111</title>
<key>Dm</key>
<lyrics>[V1]
.Dm         C    A         Dm
 Senin tahtının önünde dururum
.              C      A       Dm
 Ellerin şefkatle hep bana uzanır.

[C1]
.       C     Dm    C       Dm
   // Gece gündüz tapayım sana,
.    C     Dm     C          Dm
   Gece gündüz en Kutsal Yer'de. //

[V2]
.Dm         C      A        Dm
 Ve Sen çadırın' üstüme gerersin
.             C        A            Dm
 Kavuran sıcaklar, Rab beni hiç çarpmaz.

[V3]
.Dm          C      A         Dm
 Perde yırtıldı, yüzyüzeyiz artık
.                C     A           Dm
 En Kutsal Yer'deki, seninle birlikte.

[C2]
.       C     Dm    C       Dm
   // Gece gündüz tapayım sana,
.    C     Dm     C          Dm
   Gece gündüz en Kutsal Yer'de. //</lyrics>
</song>