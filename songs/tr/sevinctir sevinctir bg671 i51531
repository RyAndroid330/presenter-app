<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>671</hymn_number>
<lyrics>[V1]
 // Sevinçtir, sevinçtir,
 Sevinçtir Allahım. //
 // Onunla, onunla
 Seviniyor canım. //

[C1]
   // Aleluya, Aleluya,
   Aleluya sana. //
   // Bizden bir şey istemiyor,
   Sade günahımızı //

[C2]
   // Yıkasın, paklasın,
   O temiz kanıyla. //
   // Bizden bir şey istemiyor,
   Sade yüreyimizi //

[C3]
   // Yıkasın, paklasın,
   O temiz kanıyla. //
   // Bizden bir şey istemiyor,
   Sade inanalım. //

[C4]
   // İsaya, İsaya,
   Nurlu Rabbimize. //</lyrics>
<title>Sevinçtir, sevinçtir BG671</title>
</song>