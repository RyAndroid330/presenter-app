<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>542</hymn_number>
<title>Bütün dünyada insanlar BG542</title>
<lyrics>[V1]
 // Bütün dünyada insanlar,
 Allahı bekliyorlar.
 Allahı bekliyorlar,
 İman etsinler. //

[C1]
   Şükür, şükür ona,
   Şükür, şükür ona,
   Şükür, şükür Allaha,
   İsa Mesihe.

[V2]
 // İsa Mesih geldi,
 Onu oklan vurdular,
 Onu oklan vurdular,
 Kanını döktüler. //

[V3]
 // Lüzgyarlar esecek,
 İsa mesih gelecek,
 İnsanlar titreyecek,
 Dua edecek. //</lyrics>
</song>