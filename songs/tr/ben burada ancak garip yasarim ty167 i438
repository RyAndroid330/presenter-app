<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>167</hymn_number>
<lyrics>[V1]
 Ben burada ancak garip yaşarım,
 //  Göktedir benim vatanım.  //

[V2]
 Dünyayı harabe gibi görürüm,
 //  Göktedir benim vatanım.  //

[V3]
 Yurduma çabuk ulaşmak isterim,
 //  Evet, durmadan isterim.  //

[V4]
 Dünya denen çölde seyahatteyim,
 //  Gökte yurdumu bulayım.  //

[V5]
 Son boru sesiyle yüce düğüne
 //  Alınışımı beklerim.  //

[V6]
 Bir bakışla değiştirecek beni,
 //  Gökteki Rabbim, güveyim.  //

[V7]
 Dünyada çektiğim elem bitecek,
 //  Yurdumda rahat edeyim.  //

[V8]
 Tahtın önünde tüm mukaddeslerle
 //  Beyaz kaftanım olacak.  //

[V9]
 O güzel izzet tacını takayım,
 //  Yurdumda rahat edeyim.  //

[V10]
 Ta ki o gün son sevinçli düğünde
 //  Ebedi taçlar takayım.  //

[V11]
 İzzetimi Kralın önüne atıp
 //  O'na secde edeceğim.  //</lyrics>
<title>Ben Burada Ancak Garip Yaşarım TY167</title>
</song>