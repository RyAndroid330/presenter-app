<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[C1]
.  Em               D
    Sırtında kırbaç izleri,
.  C               Em
    Cennetin tek bileti
.  Em               Am
    Kaftan kırmızı, taç dikenli
.  B7     C         D       Em
    &quot;Alnından akan, suçumun bedeli.&quot;

[C2]
.  Am           C
    &quot;İhanetimin çivileri,
.  D                 Em
    Kutsal elleri deldi.
.  Am              C
    O gün çarmıhta üç kişi
.  D                  Em
    Suçumu biri üstlendi.&quot;

[C3]
.  Em            D
    O ölüler diyarına indi,
.  C               Em
    Yılanın başını orda ezdi.
.  Em             Am
    Üç gün geçti, kadınlar geldi
.  B7      C        D       Em
    &quot;Mezar boş İsa, ölümden dirildi.&quot;

[V1]
. Am         C          D         Em
 &quot;O Dirildi, O Dirildi, Ölümü ölümle yendi
.Am          C          B7        Em
  O Dirildi, O Dirildi, Ölümü ölümle yendi.
.Am                     B7
  Diriliş gücü üstüme indi!
.C                      Em
  Diriliş gücü üstüme indi!&quot;</lyrics>
<title>O Dirilidi!</title>
<author>Barış Örün</author>
</song>