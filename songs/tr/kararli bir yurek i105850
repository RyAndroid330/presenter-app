<?xml version="1.0" encoding="UTF-8"?><song><author>Gencebay</author>
<title>Kararlı bir yürek</title>
<lyrics>[V1]
 // Kararlı bir yürek bir kalp ver bana
 sana adanmış bir yaşam ver bana
 yolunda yürüyen senin izinde giden
 bir ruh sağla içimde Tanrım Rabbim //

[V2]
 // Rab bilirim ki senin sözün
 derin ve engin bir deniz gibidir
 senin sevgin eşsiz benzersizdir
 Sen kutsal kutsal kutsalsın Mesih // ..

[V3]
 // Görkemine yüceliğine bakarken
 övgü ve yücelik dökülsün dilimden
 kudret yücelik bereket ve hürmet
 sonsuzlara dek senindir Tanrım Rabbim //</lyrics>
</song>