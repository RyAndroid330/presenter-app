<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>446</hymn_number>
<author>Bünyamin Yasmin</author>
<lyrics>[C1]
   //  Lay la lay lay la lay...
   Gel Tapınalım!  //

[V1]
 Sıyrıl tüm keder ve derdinden,
 Ayır benliğimi senden,
 Yaklaş şimdi Rab'bin önüne,
 Şimdi tapınma zamanı!

[V2]
 Kaldır ellerini göklere,
 Yüce Olan'a izzet ver,
 Sevinçle ilahi söyle,
 Şimdi tapınma zamanı!

[V3]
 Rab'bin yarattığı gün, bugün,
 Dans et durma yerinde,
 &quot;Haleluya, Haleluya&quot; de,
 Şimdi tapınma zamanı!</lyrics>
<title>Lay La Lay Lay La Lay. TY446</title>
</song>