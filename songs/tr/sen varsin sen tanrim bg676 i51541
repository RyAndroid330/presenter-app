<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>676</hymn_number>
<lyrics>[V1]
 // Sen varsın, sen Tanrım,
 Şu yeryüzünde.
 Sen göktesin,
 sen yerde, a... a... a...
 Sen bütün dünyada. //

[C1]
   // Bizim için gerildin,
   Bizim için öldün.
   Al bizi yanına, a... a... a...
   Şükürler edelim sana. //

[C2]
   // Sana yalvarıyoz,
   Senden istiyoruz.
   Bizim bu zayıf
   duamızı, a... a... a...
   Kabul et, sen İsa. //</lyrics>
<title>Sen varsın, sen Tanrım BG676</title>
</song>