<?xml version="1.0" encoding="UTF-8"?><song><title>Tek Tanrı’ya İnanırız</title>
<key>D</key>
<lyrics>[V1]
.Em             D
 Tek Tanrı'ya inanırız,
.Em           D
 Evreni yaratana.
.Em               D
  Tek Oğlu da Rab İsadır,
.Em               D
 Kral doğan bakireden.
.G
 Çarmıha gerilip bizi
.Em             D
  Günahtan azat etti.
.G
  Ölümü yenip dirildi,
.Em          D
 Döndü Babasına.

[C1]
.     Em   D   Em          D
   // İsa, Rabbimiz, Rabbimiz!  //
.     G         Em        D
   //  İsa, Rabbimiz, Rabbimiz!  //
.             E
   Kralların Kralısın!
.             E
   Kralların Kralısın!

[V2]
.Em                D
  Tek Ruhunu göndermiştir.
.Em              D
 Halkına kuvvet veren.
.Em              D
  Hak sözünü doğrularken
.Em              D
  Dünyaya yollar bizi.
.G
 Gün gelir ki görkemiyle
.Em              D
  Yargı için dönecek.
.G
  O zaman herkes diz çöküp
.Em             D
 Ağzıyla ikrar etsin.</lyrics>
