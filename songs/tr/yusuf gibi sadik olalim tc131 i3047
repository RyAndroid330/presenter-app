<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[C1]
.  E B7  E
   Yusu__f gibi sadık olalım,
.  B7          E
   İyi günde, kötü günde,
.  B7          E
   Sevinçte, üzüntüde.
.  A      E    B7    E
   Her zaman, her zaman
.  B7                   E
   Tanrımız'a sadık olalım!
.  B7            E
   Kıskançlıkla kardeşleri
.  B7          E
   sattı onu yabancılara.
.  A     E  B7 E
   Yine de Yusuf,
.  B7                   E
   Tanrısı'na sadık kaldı.

[C2]
   Köle olarak çalıştı,
   Günaha ayartıldı.
   Yine de Yusuf,
   Tanrısı'na sadık kaldı.

[C3]
   Mısır halkını yönetti,
   Büyük bereket sağladı.
   Her zaman Yusuf,
   Tanrısı'na sadık kaldı.

[C4]
   Bir gün hapse atıldı,
   Orada da hizmet etti.
   Yine de Yusuf,
   Tanrısı'na sadık kaldı.</lyrics>
<title>Yusuf Gibi Sadık Olalım TÇ131</title>
<author>Hiltrud Ströhlein</author>
<hymn_number>131</hymn_number>
</song>