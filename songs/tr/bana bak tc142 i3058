<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.C                           G       C
  Bana bak, bana bak, neler yapabilirim:
.      G       C
 Alkışlayabilirim.
.    C      F     C
 // Alkış, alkış, alkışlayalım. //
.    G           C
 // Tanrı'ya şükredelim! //

[V2]
 Bana bak, bana bak, neler yapabilirim:
 Hızlı koşabilirim.
 // Hızlı, hızlı, hızlı koşalım! //
 // Tanrı'ya şükredelim! //

[V3]
 Bana bak, bana bak, neler yapabilirim:
 Yemek yiyebilirim.
 // Hapur, hapur, yemek yiyelim. //
 // Tanrı'ya şükredelim! //

[V4]
 Bana bak, bana bak, neler yapabilirim:
 Bir şey içebilirim.
 // Lıkır, lıkır, lıkır içelim! //
 // Tanrı'ya şükredelim! //

[V5]
 Bana bak, bana bak, neler yapabilirim:
 Zıp zıplayabilirim.
 // Zıp zıp zıp zıp zıp zıplayalım! //
 // Tanrı'ya şükredelim! //

[V6]
 Bana bak, bana bak, neler yapabilirim:
 Fır, fır dönebilirim.
 // Fır, fır, fır, fır, fır, fır dönelim! //
 // Tanrı'ya şükredelim! //

[V7]
 Bana bak, bana bak, neler yapabilirim:
 Eğilip kalkabilirim.
 // Eğilip, eğilip, eğilip kalkalım! //
 // Tanrı'ya şükredelim! //</lyrics>
<key>C</key>
<title>Bana Bak TÇ142</title>
<hymn_number>142</hymn_number>
<author>Hiltrud Ströhlein</author>
</song>