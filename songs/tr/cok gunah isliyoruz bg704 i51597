<?xml version="1.0" encoding="UTF-8"?><song><title>Çok günah işliyoruz BG704</title>
<lyrics>[C1]
   // Çok günah işliyoruz
   Sana, Rabbim, Allahım,
   Davet ediyoz seni
   Bizimle yaşayasan. //

[C2]
   Sensiz yaşamıyoruz
   Sensiz olamıyoruz.
   Sensiz duramıyoruz.
   Her vakıt bağırıyoruz.

[C3]
   // Rab ansızın gelecek,
   Yemişleri alacak.
   Kimin yemişi güzel,
   Onu kesin alacak. //

[C4]
   // Senin Rabbin o haçta,
   Senin ve benim için,
   Şükür olsun İsa'ya,
   Şanlar olsun adına. //

[C5]
   // Senin de kurtarıcın,
   Senin Tanrın o olsun.
   Her vakıt seni bekler,
   Seni kurtarmak ister. //</lyrics>
<hymn_number>704</hymn_number>
</song>