<?xml version="1.0" encoding="UTF-8"?><song><author>Eren Atik</author>
<key>Em</key>
<lyrics>[V1]
.Em                 G
 Kurtar Beni, Ey Tanrı
.D                Em
 Sular Boyuma Ulaştı.
.Am
 Batağa Gömülüyorum,
.Em
 Basacağım Bir Yer Yok
.  D
 Derin Suda Battım,
.   Em
 Sellere Kapıldım.
.C               D
 Tükendim Feryat Etmekten,
.C           Em
 Boğazım Kurudu
.Am              Em
 Gözlerimin Feri Sönüyor
.D           Em
 Tanrım'ı Beklemekten

[V2]
.Em                 G
 Kulak Ver Bana, Ya RAB,
.D                Em
 Yanıtla Beni, Tanrım
.Am
 Çünkü Mazlum Ve Yoksulum.
.Em             D
 Koru Canımı Çünkü Ben
.        Em
 Senin Sadık Kulunum.
.C                 D
 Kurtar Beni Ey Tanrı,
.C                Em
 Sana Güvenen Kulunu!
.Am                 Em
 Acı Bana Nolur, Ya Rab,
.D            Em
 Gün Boyu Yakarıyorum
.Am                  Em
 Sevindir Kulunu, Ya Rab,
.D           Em
 Duamı Yükseltiyorum</lyrics>
<title>Kurtar Beni Ey Tanrı</title>
</song>