<?xml version="1.0" encoding="UTF-8"?><song><title>Cennet Güvercini TY495 RT151</title>
<lyrics>[V1]
.    G      Em       C       D
 // Cennet güvercini dön, bana gel!
.G      Em       C      D
 Yüreğimden Seni söküp atan
.C     D        G      Em
 Sana acı veren günahımdan
.  C      Am       D
 Artık nefret ediyorum. //

[C1]
.           G       Em        C          D
   // Gel bana Rab İsa, kalbimi açtım Sana. //
.         G  Em     C      D
   // İsmine hamdederim, Baba. //
.        G
   Gel bana!</lyrics>
<key>G</key>
<author>Davut Yasmin</author>
<hymn_number>495</hymn_number>
</song>