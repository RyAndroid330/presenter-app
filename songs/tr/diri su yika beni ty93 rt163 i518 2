<?xml version="1.0" encoding="UTF-8"?><song><title>Diri Su Yıka Beni TY93 RT163</title>
<key>C</key>
<lyrics>[V1]
.C        G      Am
 Diri su, yıka beni,
.F        G   C  Em
 Pakla ve yenile.
.Dm       G        C        Am
 Tertemiz yıka, doldur gücünle,
.F        G      C
 Diri su, yıka beni.

[V2]
.C           G      Am
 Kutsal Ruh, koru beni,
.F      G        C  Em
 Beni yönelt İsa'ya.
.Dm     G         C        Am
 O'na tapayım, doldur gücünle,
.F           G      C
 Kutsal Ruh, koru beni.

[V3]
.C           G     Am
 İsam, Sen yönet beni,
.F      G       C  Em
 Yüreğimde taht kur.
.Dm         G         C        Am
 Coştur hamtlarla, doldur gücünle,
.F           G     C
 İsam, Sen yönet beni.</lyrics>
<author>Dougie Brown, D. Peacock</author>
<hymn_number>93</hymn_number>
</song>