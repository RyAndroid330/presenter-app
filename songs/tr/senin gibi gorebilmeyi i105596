<?xml version="1.0" encoding="UTF-8"?><song><title>Senin gibi görebilmeyi</title>
<lyrics>[V1]
 Senin gibi görebilmeyi
 Senin gibi duyabilmeyi
 // Senin gibi sevebilmeyi
 Ögret bana Rab Isam //

[V2]
 Tekrar:
 Duruşmda,bakışmada,soylediğim her sözde
 // Bulunduğum her yerde herkez görsün seni bende //

[V3]
 Ögret bana sabretmeyi
 Ögret bana afetmeyi
 // Ögret bana guzelliği
 Ögret bana Rab Isam //</lyrics>
</song>