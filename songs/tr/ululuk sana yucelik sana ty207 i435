<?xml version="1.0" encoding="UTF-8"?><song><author>Ali Yazar</author>
<hymn_number>207</hymn_number>
<lyrics>[V1]
 Ululuk sana, yücelik sana,
 Tanrı kuzusu, övgüler sana!
 Günahım için çarmıhta ölen,
 Tanrı kuzusu, şükürler sana!

[C1]
   Dirilişinle yengi kazanan,
   Tanrı sağında tahtta oturan,
   Beni doğruluk ile donatan,
   Rab İsa Mesih, şükürler sana!

[V2]
 Bana yüceden ruhunu veren,
 Bulutla bizi alacak olan,
 Bütün dünyaya barış getiren,
 Yüce hükümran, yücelik sana.</lyrics>
<title>Ululuk Sana, Yücelik Sana TY207</title>
</song>