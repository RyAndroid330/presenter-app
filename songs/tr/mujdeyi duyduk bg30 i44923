<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Müjdeyi duyduk Mesih'te doğduk
 Sevinçte coşarak yaşadık //

[C1]
   /// Kilise denendi tartışmalara düştü
   kıskançlık ve gurur aramıza girdi ///

[V2]
 // Sonradan duyduk ihtiyaç vardı
 Barıştık ve meyvalar verdik //

[B1]
   // Hamtlar olsun Rab İsa'ya çıkış
   yolu verdi bize kiliseyi yüceltti //</lyrics>
<title>Müjdeyi Duyduk BG30</title>
<hymn_number>30</hymn_number>
<author>İsko (Pomorie)</author>
</song>