<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Çok sevgi ver bana,
 Allahım, Rab İsa.
 Üzülmek istemyom
 bu dünyada. //

[C1]
   // Çıkar bizi, Allahım, sıkıntıdan.
   Kurtar bizi, Allahım, karanlıktan. //

[C2]
   // Çok hasta, ve düşkün,
   ve dertli biriydim.
   Sen beni buldun diye,
   sevinçliyim. //

[C3]
   // Gelirim dünyaya
   tezlerde yavrular..
   Sözümle davalacam
   ben herkesi. //

[C4]
   // Sözümü dinleyen
   herkesi seviyom,
   Cennette olacaklar
   hep benimle. //</lyrics>
<title>Çok sevgi ver bana BG705</title>
<hymn_number>705</hymn_number>
</song>