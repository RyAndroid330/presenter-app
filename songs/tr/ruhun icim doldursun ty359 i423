<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>359</hymn_number>
<title>Ruh'un İçim' Doldursun! TY359</title>
<lyrics>[V1]
.E
  Ruh'un içim' doldursun!
 Ruh'un içim' doldursun!
.      A
 Ayaklarım dans etsin,
.           F#m
 Yüreğim sevinsin,
.     A   F#       B7
 Ağzım sana övgü sunsun!

[V2]
.   E     B7
 Haydi, ileri!
.    E          A
 Orduların Rabbi ismiyle!
.     E            B7
 Çünkü Rab her düşmanı
.     E         B7
 Alt etti, alt etti.
.      E      B7
 Sevinelim, Rab'de!
.      E              A
 Güvenelim O'na, korkmayalım!
.   E     B7         E
 Haydi, ileri Rab isminde!

[V3]
 Ne yüce Tanrımız var!
.              B7
 Ne yüce Tanrımız var!
.E
  Melekler secde eder,
 Yer ve gök boyun eğer,
.          B7   E
 Ne yüce Tanrımız var!</lyrics>
<key>E</key>
</song>