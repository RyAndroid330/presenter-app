<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>123</hymn_number>
<author>Graham Kendrick</author>
<title>Tek Allah'a İnanırız TÇ123 TY371 RT126</title>
<lyrics>[V1]
.Em             D
 Tek Allah'a inanırız,
.Em            D
 evreni yaratana.
.Em                D
 Tek Oğlu da Rab İsadır,
. Em               D
 Kral doğan bakireden.

[V2]
. G              D
 Çarmıha gerilip bizi
.Em               D
 günahtan azat etti.
.G              D
 Ölümü yenip dirildi,
.Em           D
 döndü Babasına.

[C1]
.     Em    D   Em         D
   // İsa, Rabbimiz, Rabbimiz! //
.     G    D      Em         D
   // İsa, Rabbimiz, Rabbimiz! //
.                 E      D
   // Kralların Kralısın! //

[V3]
.Em                 D
 Tek Ruhunu göndermiştir.
.Em                D
 Halkına kuvvet veren.
.Em               D
 Hak sözünü doğrularken
.Em               D
 Dünyaya yollar bizi.

[V4]
.G                D
 Gün gelir ki görkemiyle
.Em              D
 Yargı için dönecek.
.G                  D
 O zaman herkes diz çöküp
.Em               D
 Ağzıyla ikrar etsin.</lyrics>
<key>G</key>
</song>