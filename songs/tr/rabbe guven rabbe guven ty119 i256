<?xml version="1.0" encoding="UTF-8"?><song><title>Rab'be Güven, Rab'be Güven TY119</title>
<lyrics>[V1]
 //  Rab'be güven, Rab'be güven,
 Rab'be güven, Rab'be güven.  //
 //  İnayeti ile beslen,
 İyiliklerini gönen.  //
 //  Rab'be güven, Rab'be güven.  //

[V2]
 //  Rab'be güven, Rab'be güven,
 Rab'be güven, Rab'be güven.  //
 //  Yollarını O'na bırak,
 Parlatacak o yolunu.  //
 //  Rab'be güven, Rab'be güven.  //</lyrics>
