<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>39</hymn_number>
<title>İsa Mesih indi dünya'ya BG39</title>
<lyrics>[V1]
 İsa Mesin indi dünya'ya
 bizim için kurban oldu
 // bizim için kanını döktü
 bizim için O öldü //

[V2]
 Bizim için O öldü
 bizim için kanını döktü
 // üç gün sonra O dirildi
 İsa Mesih Allahım //

[V3]
 Göksel Babam Sen yükseksin
 inanıyom İsa Mesih'e
 // herdayıma yardım ediyor
 benim güzel Allahım //

[V4]
 Gel İsa, gel yanıma
 ver iman Sen bana
 // seviyom Seni, seviyom
 canımdan daha vazla //

[V5]
 Her vakıt dua ediyom
 her vakıt Seni bekliyom
 // İsa Mesih gel yanıma
 İşit benim sözlerimi //
 İşit benim duamı</lyrics>
</song>