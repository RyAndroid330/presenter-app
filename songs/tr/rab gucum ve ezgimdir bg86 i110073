<?xml version="1.0" encoding="UTF-8"?><song><title>Rab Gücüm Ve Ezgimdir BG86</title>
<lyrics>[V1]
.   Am            Em
 // Dağında konut kurdu,
.Am                     Em
 Sular sağında, solunda duvar oldu.
.Dm
 Halkın Seni övgüyle anar,
 Rab gücüm ve ezgimdir. //

[C1]
   // Deniz yarıldı yollar açıldı,
   Halkın özgürlüğe kavuştu.
   Sağ elinle kurtuluş geldi,
   Adın sonsuza dek RAB'dir. //

[V2]
 // Güç ve zafer yüce RAB'bindir,
 Ezgiler sunun RAB'be.
 Çünkü yuceldikçe, yüceldi,
 Yuceldikçe, yüceldi. //</lyrics>
<key>Am</key>
<author>Musa Mesih Oğlu, Mustafa Abidov, Tahir Todorov</author>
<hymn_number>86</hymn_number>
</song>