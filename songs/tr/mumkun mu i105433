<?xml version="1.0" encoding="UTF-8"?><song><title>Mümkün mü?</title>
<lyrics>[V1]
 // Mümkün mü seni goremem ellerini tutup gozlerine bakamam //

[V2]
 // kokunu cekemem icime soyle bir nefes ta derinden //

[V3]
 // caresizim rab gucum kalmadi dayanacak //

[V4]
 // mumkunmu rab seni gormek
 mumkunmu rab dokunmak //

[V5]
 sarilmak kucaklamak
 yalnizligimla burdayim burada

[V6]
 // mumkun olan tek sey
 kalbimde olan sevgindir //</lyrics>
</song>