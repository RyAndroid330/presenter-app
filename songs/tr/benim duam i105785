<?xml version="1.0" encoding="UTF-8"?><song><author>David Stefanov</author>
<lyrics>[V1]
 // Benim duam yüce Babam sana
 Bizi almaya gelişine dek //

[V2]
 // Günahla , Dünyayla , Kendimle //

[V3]
 // Senin gücünle savaşmak istiyorum
.    
     Senin sabrın la dayanmak istiyorum
.    
     Senin sevginle sevmek istiyorum
.    
     Senin lütfü la alçalmak istiyorum
.    
     Senin sözünle beslenmek istiyorum
.    
     Senin ruhunla büyümek istiyorum //

[V4]
 İsa Mesih in isminle Amin.</lyrics>
<title>Benim duam</title>
</song>