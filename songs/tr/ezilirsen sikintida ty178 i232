<?xml version="1.0" encoding="UTF-8"?><song><author>Erol Özer</author>
<hymn_number>178</hymn_number>
<lyrics>[V1]
 Ezilirsen sıkıntıda,
 Her ümidin kaybolmuşsa,
 Müjde sana! Mesih geldi
 //  Bu karanlık dünyamıza.  //

[V2]
 Üzgün durma, kalk ayağa!
 Düşme ölüm korkusuna!
 Müjde sana! Mesih geldi
 //  Bu karanlık dünyamıza.  //

[V3]
 Günah yükü ezer seni,
 Kurtuluş var dinle beni!
 Müjde sana! Mesih geldi
 //  Bu karanlık dünyamıza.  //

[V4]
 Aydınlatmak ister seni,
 Vermek ister sevgisini.
 Müjde sana! Mesih geldi
 //  Bu karanlık dünyamıza.  //</lyrics>
<title>Ezilirsen Sıkıntıda TY178</title>
</song>