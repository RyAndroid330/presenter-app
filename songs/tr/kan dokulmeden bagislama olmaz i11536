<?xml version="1.0" encoding="UTF-8"?><song><title>Kan dökülmeden bağışlama olmaz</title>
<lyrics>[V1]
 // Kan dökülmeden bağışlama olmaz  //
 Ama şimdi ise, şimdi ise
 Mesih'in dökülen kanı sayesinde
 Günahtan arındık kanı sayesinde
 // Bağışlandık  //
 Kanı sayesinde
 // Kurtulduk  //
 Kanı sayesinde
 İbraniler, İbraniler 9:22</lyrics>
