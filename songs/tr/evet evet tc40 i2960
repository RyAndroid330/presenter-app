<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
 // Biri soruyor: &quot;Tanrı için imkansız olan var mı?&quot;
 Herkes bağırarak cevap veriyor: &quot;Hayır, yok!&quot; //

[V2]
.C      G     C         F
 Evet, evet, gerçekten yok!
.C     F    C        F     C
 Yok, yok, yok! Yok, yok, yok!
.F       C       G
 Rab her şeyi yapar.
.F     C      G
 Sözünde güç var.
.C        G      F     C
 Olmayan şeyler var olacak.
.        G    F        C
 Bütün yaratıklar şaşacak.
.F        C      G
 Tanrımız harikadır!
.F     C       G
 İmanımız O'ndadır.
.F        C    G
 Bir tek O'ndadır.</lyrics>
<title>Evet, Evet TÇ40</title>
<author>Hiltrud Ströhlein</author>
<hymn_number>40</hymn_number>
</song>