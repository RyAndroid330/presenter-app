<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>587</hymn_number>
<key>D</key>
<lyrics>[V1]
.Emin              D     Emin
 Ruhsal silahlarla kuşanalım,
.         D            Emin
 Çünkü Tanrı'nındır bu cenk.
.              D         Emin
 Şeytan bize asla yaklaşamaz,
.         D            Emin
 Çünkü Tanrı'nındır bu cenk.

[C1]
.            G  D   Emin G
   // Rab'be hürmet, övgü, kudret
.     D     Emin
   Ve güç olsun. //

[V2]
 Karanlık güç bizi yok edemez,
 Çünkü Tanrı'nındır bu cenk.
 Kuzu'nun kanıyla biz zaferliyiz,
 Çünkü Tanrı'nındır bu cenk.

[V3]
 Düşmandan biz asla korkmayalım,
 Çünkü Tanrı'nındır bu cenk.
 Rab İsa'nın gücüyle güçlenelim,
 Çünkü Tanrı'nındır bu cenk.</lyrics>
<title>Ruhsal Silahlarla Kuşanalım TY587</title>
</song>