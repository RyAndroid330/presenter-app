<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C                           C7
 Rab'be hamdedelim boru çalarak,
.F               Fm
 Hamdedelim O'na coşarak,
.C                        G    G7
 Zil ve tef çalıp dans ederek!
. C               C7
 Rab'be hamdedin sazla,
.F                Fm
 Rab'be hamdedin sözle,
.C      Am       Dm  G    C   F C G
 Nefesi olan herkes hamdetsin!

[V2]
.C               C7
 Haleluya, hamdedin!
.F         Fm
 Haleluya, hamdedin!
.C                       G     G7
 Nefesi olan herkes hamdetsin!
. C               C7
 Haleluya, hamdedin!
.F         Fm
 Haleluya, hamdedin!
.C      Am      Dm       C    F C
 Nefesi olan herkes hamdetsin!</lyrics>
<title>Rab'be Hamdedelim Boru Çalarak TY201 RT171</title>
<author>John Kennett</author>
<hymn_number>201</hymn_number>
</song>