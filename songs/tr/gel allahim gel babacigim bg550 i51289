<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Gel Allahım, gel Babacığım !
 Sen yıka beni kanıyla. //

[C1]
   // Ey Allahım, o Babacığım.
   Gayretlisin, çilelisin. //

[V2]
 // Sizi, yavrum, görüyorum,
 Sizi candan seviyorum. //

[V3]
 // Bahçemdeki güller gibi,
 Her gün sizi kokluyorum. //

[V4]
 // Sizin kalbiniz kapalı.
 Siz her vakıt dua yapın. //

[V5]
 // Bizi çamurdan çıkardın.
 Bizi sende temizledin. //</lyrics>
<title>Gel Allahım, gel Babacığım ! BG550</title>
