<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>38</hymn_number>
<author>Ali Yazar</author>
<lyrics>[V1]
.Am
 Ara bütün dünyayı,
.Em
 Gelmiş geçmiş zamanı,
.   G
 // Rastlamazsın bir yerde
.F
 Mesih'teki sevgiye. //

[C1]
   Hastayı, günahkârı
   Karanlıktan kurtardı.
   // Seni, beni, herkesi,
   Düşmanı da O sevdi. //

[C2]
   Gökten inen ekmeğim,
   Işığımdır, her şeyim!
   // Kötü günde Mesihim
   Dostumdur güvendiğim. //

[C3]
   Ne kadar övsem O'nu,
   Övgümün gelmez sonu!
   // Göreceğim ben O'nu
   Yüz yüze ebed boyu. //</lyrics>
<key>Am</key>
<title>Ara Bütün Dünyayı TY38</title>
</song>