<?xml version="1.0" encoding="UTF-8"?><song><author>Adrienne Neusch</author>
<hymn_number>643</hymn_number>
<key>G</key>
<lyrics>[V1]
.Em         Am  C          D
 Yaratan Tanrı, Yaşam Kaynağı
.Em           Am   C             D
 Görkemli Rab'bim, her şeyden üstün

[P1]
.  Bm           Em  Am       D
   Senin gibisi yok yeryüzünde
.  Bm       Em   Am       D
   Seni görelim, gel gücünle

[C1]
.     Em       Am        Bm         Em
   // Dünya dolsun senin görkemin ile
.  (Em)      Am       Bm         Em
   Adın yücelsin, egemenliğin gelsin //

[V2]
.Em         Am  C          D
 Sevgi Tanrısı, merhamet dolu
.Em          Am   C          D
 Sevecen Rab'bim, bize lütfeden

[B1]
.     Em       Am       Bm
   // Gökte olduğu gibi yeryüzünde de olsun
.  Em       Am       Bm
   Gökte olduğu gibi yeryüzünde de olsun //

[B2]
.  Em       Am      Bm
   Ruhunla doldur bizi
.  Em        Am      Bm
   Yetkinle meshet bizi
.  Em         Bm
   Görkemini göster</lyrics>
<title>Dünya Dolsun TY643 RT11</title>
</song>