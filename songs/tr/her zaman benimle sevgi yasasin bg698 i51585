<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Her zaman benimle, sevgi yaşasın
 İsa Mesih'le, kurtarıcımla. //

[C1]
   // Söyleyin ilahi, söyleyin İsa'ya.
   O çalışsın yüreklerimizde. //

[C2]
   // O geldi bu yere, sizi kurtarsın,
   Ve günahtan azat etsin. //

[C3]
   // Gelin sizler, büyükler, küçükler,
   Yüceltelim İsa'yı yüreyimizle. //

[C4]
   // Şükür İsa'ya, şükür Baba'ya.
   Tez geliyor o yeryüzüne. //</lyrics>
<title>Her zaman benimle, sevgi yaşasın BG698</title>
<hymn_number>698</hymn_number>
</song>