<?xml version="1.0" encoding="UTF-8"?><song><title>BETLEHEMDE DOGDU</title>
<lyrics>[V1]
 // Betlehem'de doğdu
 Kurtarıcı Rab İsa
 Meryem ananın kucağında
 Betlehem kutsal şehir
 Sessizliğe sarınmış
 Yoktu yer kutsal doğuşuna //

[V2]
 Göklerde yeni yıldız
 Parılıyor Betlehem'de
 Kurtarıcım doğdu
 Sevinç var yüreğimde
 Göklerde yeni yıldız
 Parılıyor Betlehem'de
 Kurtarıcım doğdu
 Sevinç var yüreğimde

[V3]
 // Çobanlar hayranlıkla
 Yıldızı izlediler
 Geldiler Rab'be tapındılar
 Betlehem kutsal şehir
 Rab uzatır sana el
 O'nun adı Emmanuel //</lyrics>
<author>Sherif Levit</author>
</song>