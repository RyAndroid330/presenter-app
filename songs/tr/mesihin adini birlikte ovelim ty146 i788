<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.  C         F              C
 Mesih'in adını birlikte övelim!
.       F        C       G7       C
 // Rab'be tapınalım, hakkını verelim! //

[V2]
 Sözünü tutalım, bu emanet bize,
 // Hiç olmasın ona ziyan ve ilave!  //

[V3]
 Mesih fikrimizde alsın birinci yer!
 // O her şeyden üstün, her durumda önder. //

[V4]
 Sevgide birleşmiş olalım büsbütün,
 // Dünya bizde Mesih sevgisini görsün.  //

[V5]
 Sevinçle dolalım, coşsun her birimiz!
 // Ruh'un şarabıyla çözülsün dilimiz!  //

[V6]
 Şeytan'ı birlikte yeneriz daima,
 // Ki onu yenemez mümin tek başına.  //

[V7]
 Dünyada kilise, dünyanın olmasın,
 // Tuz, ışık olalım, ortam bozulmasın!  //

[V8]
 İncil'i yayalım, kazanalım canlar!
 // Rab'de beslensinler, hoş karşılansınlar!  //

[V9]
 Kilise görkemde Mesih'le olacak,
 // Gelin ilelebet Güveye varacak!  //</lyrics>
<key>C</key>
<title>Mesih'in Adını Birlikte Övelim! TY146</title>
<hymn_number>146</hymn_number>
<author>Gloria Clarke, Graham Clarke</author>
</song>