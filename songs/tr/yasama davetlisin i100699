<?xml version="1.0" encoding="UTF-8"?><song><title>YAŞAMA DAVETLISIN</title>
<lyrics>[V1]
 // Yaşama yaşama Mesihte bol yaşama
 //  Davetlisin unutma Mesihle bol yaşama

[V2]
 // Sakın akılsız olma ve O yılana kanma
 //  Adem yaşayan candı ve kandı O yılana

[V3]
 // Sulara sulara gelin diri sulara
 //  Susayan gelsin içsin yaşam suyu bedava

[V4]
 // Yaşam gerçek yol benim gökten inen ekmeğim
 //  Bu ekmeği yiyene sonsuz yaşam verenim

[V5]
 // Hossanna hossanna Rabbimize hossana
 //  Susayan gelsin içsin yaşam suyu bedava

[V6]
 // Bedenimi yiyende ve kanımı içinde
 //  Yaşarım artık onda ve oda artık bende

[V7]
 // Yaşama yaşama Mesihte bol yaşama
 //  Davetlisin unutma Mesihle bol yaşama</lyrics>
<author>&quot;Edwin&quot; Corc Bahçecioğlu, Arapça'dan</author>
</song>