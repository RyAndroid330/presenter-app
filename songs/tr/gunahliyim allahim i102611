<?xml version="1.0" encoding="UTF-8"?><song><title>Günahlıyım Allah'ım</title>
<lyrics>[V1]
 // Günahlıyım Allah'ım
 yardım et sen bana
 İstersende gideyim
 Senin yolunda her daim //

[V2]
 // Toz Toprakım Önünde
 Yardım et Allah'ım //

[V3]
 İii-İsa İii-İsa İii-İsa
 Sensin hayatım
 İii-İsa İii-İsa İii-İsa
 Sensin Rab biziz

[V4]
 // Dönüyo ben sana
 Selametle ver bana
 Gel bana Allah'ım
 Beni sen affet //

[V5]
 // Az vakıt kaldı sana
 Sen gelesin Allah'ım
 Yalvarıyom ben sana
 Sen beni azırla //</lyrics>
</song>