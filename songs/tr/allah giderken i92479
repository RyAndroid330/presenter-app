<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ALLAH GİDERKEN GÖK YUZERİNE
 SÖZ VERDİ BİZE BEN YINE GELECEM
 O YALANCI DEİI BİR GUN GELECEK
 GÖK YUZERİNDE BİZİ BEKLEİCEK

[V2]
 İŞTE O GUN ELBET GELECEK
 İŞTE BEN GELDİM YAVRUM DİYECEK
 VERSENE ELİNİ ELİME DİYECEK
 HAZIR MISIN SEN BENİMLE DİYECEK

[V3]
 KUVET GELECEK YERE İNECEKA
 YERİN KULARINI DARMADAN EDECEK
 HER BİR KULARIMA KUVET GELMEYECEK
 HAZIR KULARIMA ONLAR GELECEK

[V4]
 HİÇ DARILMAYIR YAVRUM DİYECEK
 VAKIT YOK YAVRUM HİÇ BEKLEMEYCEK</lyrics>
<title>ALLAH GİDERKEN</title>
</song>