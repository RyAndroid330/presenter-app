<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>63</hymn_number>
<author>Mustafa Abidov</author>
<key>Am</key>
<lyrics>[V1]
.Am
 Uzakta değilsin
.                Dm
 Yakındasın Rab İsa
.E
 Seni çağırdım
.(E)               Am
 Benim yüreğime girdin
.Am                          Dm
 Beni sonsuz Sevgiyle Sen sevdin
.E                     Am
 Bana merhamet ettin Sen İsa

[C1]
.  E                  Am
   Ya Rab beni sevdin Sen
.  E                      Am
   Bütün gücümle Sana taparım
.  E                  Am
   Ya Rab beni sevdin Sen
.  E                           Am
   Bütün kalbimle ben Sana taparım

[V2]
.Am                            Dm
 Fakat Sen kurban benden istemedin
.E                         Am
 Senin istediğin alçakgönüllük
.Am                      Dm
 Beni sonsuz sevgiyle sevdin
.E                      Am
 Bana merhamet ettin Sen İsa

[V3]
.Am                             Dm
 Evindeyken dikkat ederim ben Rab
.E                             Am
 Ağızımdan çıkan övgüler hep Sana
.Am                              Dm
 Övgü ve yücelikle taparım ben Sana
.E                      Am
 Diz çökerim adına Rab İsa

[V4]
.Am                           Dm
 Adak kurban Sen benden istemedin
.E                           Am
 Senin istediğin pişman bi yürek
.Am                      Dm
 Beni sonsuz sevgiyle sevdin
.E                     Am
 Bana merhamet ettin Sen İsa</lyrics>
<title>Yakındasın Rab İsa BG63</title>
</song>