<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Tüm varlığımı dağatsam
 Yoksulları doyursam Allahım
 Sevgisizse yüreğim
 Deyersizdir emeğim

[V2]
 Gerçek sevgi övünmez
 Haksız işe sevinmez
 kızkançlık tanımaz
 çıkardığını aramaz, aramaz

[V3]
 Şimdi azdır bilgimiz
 birgün Rabbi görürüz Allahım
 İman, umut son bulur
 Sevgi ise hep kalır

[V4]
 Gerçek sevgi sabreder
 kötülüyü bağışlar
 tatlılıkla davranır
 zorluklara dayanır, dayanır</lyrics>
<title>Tüm varlığımı dağatsam BG24</title>
<hymn_number>24</hymn_number>
</song>