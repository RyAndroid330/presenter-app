<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>250</hymn_number>
<author>Ali Yazar</author>
<title>Ey Tanrım, Gökler Üstüne Yüksel! TY250</title>
<lyrics>[C1]
   Ey Tanrım, gökler üstüne yüksel!
   Görkemin yeryüzünü doldursun!

[V1]
 //  Uluslar arasında
 Sana şükür ederim!
 İnsanlar arasında
 Sana övgü sunarım!  //

[V2]
 //  Rab, senin inayetin
 Gökler kadar yüksektir.
 Ey Rab, senin gerçeğin
 Tüm evrenden aşkındır.  //</lyrics>
</song>