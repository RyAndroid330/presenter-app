<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>515</hymn_number>
<title>Secde Kılalım Ve Eğilelim; TY515</title>
<lyrics>[V1]
 Secde kılalım ve eğilelim;
 Bizi yaratan Rab'bin önünde diz çökelim;
 Secde kılalım ve eğilelim;
 Bizi yaratan Rab'bin önünde diz çökelim,
 Çünkü O Allahımızdır.
 Ve biz kendi otlağının kavmı
 Ve elinin koyunlarıyız
 Ve elinin koyunlarıyız.</lyrics>
</song>