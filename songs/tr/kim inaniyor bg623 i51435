<?xml version="1.0" encoding="UTF-8"?><song><title>Kim inanıyor BG623</title>
<lyrics>[V1]
 // Kim inanıyor
 İsa Mesihe
 Ölmeyecek,
 Yaşayacak. //

[V2]
 // Verin gidelim
 Onun izinden,
 Şükür edelim
 İsa Mesihe. //

[V3]
 // Yıka sen beni,
 Besle sen beni,
 Sula sen beni,
 Terk etme beni. //

[V4]
 // Yangın olcak,
 Ateş olacak,
 Bağırış olacak,
 Dünya yanacak. //

[V5]
 // Allah gelecek,
 Yere inecek,
 O beyenecek,
 Temizleyecek. //</lyrics>
<hymn_number>623</hymn_number>
</song>