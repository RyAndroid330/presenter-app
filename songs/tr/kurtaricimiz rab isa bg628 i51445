<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>628</hymn_number>
<lyrics>[C1]
   // Kurtarıcımız Rab İsa
   Elimden tutar beni.
   Bu günahtan uzak olsam,
   Şimdi senin elindeyim. //

[C2]
   // Beni ateşine atma.
   Beni yalnız sen brakma. //

[C3]
   // Şimdi senin ardındayım,
   Mutlu olayım. //

[C4]
   // Benim için, ey Allahım,
   Acı çektin, sen dayandın. //

[C5]
   // Ayrılamam senden artık,
   Şükürler olsun. //

[C6]
   // Benim için, ey Allahım,
   Acı çektin. sen dayandın. //

[C7]
   // Ölürüm, ayrılmam senden.
   Senin oldum ben. //</lyrics>
<title>Kurtarıcımız Rab İsa BG628</title>
</song>