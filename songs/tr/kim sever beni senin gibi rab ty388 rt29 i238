<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>388</hymn_number>
<author>Anna-Mari Kaskinen</author>
<key>G</key>
<lyrics>[V1]
.Em        D                Em
 Kim sever beni Senin gibi, Rab,
.             D          Em
 Kim canın' verir benim için.
.          D             Em
 Suçumun izleri avuçlarında,
.        D          Em
 Günahlarım bağışlandı.

[V2]
.Em          D                Em
 Kim duyar sesimi Senin gibi, Rab,
.             D          Em
 Kim siler benim gözyaşlarım'.
.          D               Em
 Ümidim Seninle, Senin elinde,
.           D           Em
 Özgürüm artık günahlardan.</lyrics>
<title>Kim Sever Beni Senin Gibi Rab TY388 RT29</title>
</song>