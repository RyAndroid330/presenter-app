<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>453</hymn_number>
<title>Büyük Tanrımız TY453</title>
<lyrics>[V1]
.Em                Cmaj7
 Büyük Tanrımız, Sana geliyoruz,
.Em               Cmaj7
 Yüce Tanrımız, Sana tapıyoruz.
.Bm                Em
 Tanımak istiyoruz gerçek özünü,
.Bm
 Ne denli geniş,
.  Em                      D
 Uzun, yüksek, derin olduğunu.

[C1]
.           G
   // Senin emsalsiz sevgin,
.       Em
   Düşündüğümden üstün,
.           C
   Daha çok anlamak isterim,
.        D
   Sende köklenmeliyim.
.        G
   Bütün aklım ve isteğim,
.       Em
   Sana doğru çevrilsin,
.      C
   Doluluğunu isterim,
.       D
   Seni tanımalıyım.  //
.          Em
   Yüce Rabbim!</lyrics>
<key>G</key>
</song>