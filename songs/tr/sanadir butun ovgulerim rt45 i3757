<?xml version="1.0" encoding="UTF-8"?><song><author>Özgür Tunç</author>
<hymn_number>45</hymn_number>
<title>Sanadır Bütün Övgülerim RT45</title>
<lyrics>[C1]
.     Em                  Am
   // Sanadır, bütün övgülerim.
.  (Am)
   Yürekten gelen sözlerim
.  C        D        Em
    Sanadır, sanadır ya Rab. //

[V1]
.Em
  Toza toprağa serildim
.Am
  İçim eriyor kederden
.C        D       Em
  Garibim bu dünyada.

[C2]
.     Em
   //  Ben sadakat yolunu seçtim
.  Am
    Hükümlerini uygun gördüm
.  C              D          Em
    Sözün uyarınca yaşam ver bana //

[C3]
.      Em
   // İçimden bir ses duydum
.  Am
    Yüzümü ara dedi bana
.  C       D           Em
    Ya Rab yüzünü arıyorum //</lyrics>
<key>G</key>
</song>