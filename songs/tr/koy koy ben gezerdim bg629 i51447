<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>629</hymn_number>
<lyrics>[V1]
 Köy köy ben gezerdim,
 Çareyi bulamadım.
 // İsa beni buldu,
 Derdime derman verdi. //

[C1]
   O İsa, sevgili dostumuz,
   O İsa, kuvvetli Rabbimiz,
   Gel doldur beni
   Senin kuvvetinle
   Gel doldur beni
   Senin sevincinle.
   Çok çeki geçirdim ben,
   Dermanı bulamadım.

[C2]
   // İsa beni buldu,
   Derdime derman verdi. //
   Gel Rabbim, gel Babam !
   Ellerine al beni !

[C3]
   // İsa doldur beni
   Senin kuvvetinle. //
   Ben çok günahlıydım,
   Hem de çok hasta idim.
   // İsa beni buldu,
   Ve kuvvetini verdi. //</lyrics>
<title>Köy köy ben gezerdim BG629</title>
</song>