<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>292</hymn_number>
<author>Ali Yazar</author>
<title>Senin İşin Görkemlidir TY292</title>
<lyrics>[V1]
 //  Senin işin görkemlidir,
 Hayranlığa yol açandır.  //
 Yolların hak ve gerçektir,
 Ulusların hükümranı.

[C1]
   Kutsal, kutsal, kutsal Tanrı!
   Evrensel ve egemen Rab,
   Ulusların hükümranı,
   Kutsal, kutsal, kutsal Tanrı!

[V2]
 //  Senin adından kim korkmaz,
 Kim yüceltmez Rab adını?  //
 Kutsal olan yalnız sensin,
 Evrensel ve egemensin!

[V3]
 //  Bütün uluslar gelecek,
 Eğilecekler önünde.  //
 Rab, sana tapınacaklar,
 Sana secde kılacaklar!</lyrics>
</song>