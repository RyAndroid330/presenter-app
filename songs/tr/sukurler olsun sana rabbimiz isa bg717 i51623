<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>717</hymn_number>
<title>Şükürler olsun sana, Rabbimiz İsa ! BG717</title>
<lyrics>[V1]
 // Şükürler olsun sana, Rabbimiz İsa ! //

[C1]
   // Şükürler, şükürler olsun sana,
   Rabbimiz İsa. //

[C2]
   // Ellerimi kaldırdım, senden isterim. //

[C3]
   // Gel, yavrum, benden iste, ben de verecem. //

[C4]
   // Üzgün durma, gel yavrum, kalbin soğumasın. //</lyrics>
</song>