<?xml version="1.0" encoding="UTF-8"?><song><title>İsa beni buldu BG593</title>
<lyrics>[V1]
 // İsa beni buldu,
 O beni kurtardı.
 Yanına gidecem,
 Onu görecem. //

[C1]
   // Bilirsin beni,
   Allahım,
   Neden hastayım.
   Yanıma gel, Allahım,
   Şifa verirsin. //

[V2]
 // İşit beni, Baba.
 Ben yalnız kaldım.
 Sana güveniyorum ben,
 Sensiz olamam. //

[V3]
 // Nereye gidecem
 İsa'yı övecem.
 Herkes duysun, öğrensin,
 Cennete gelsin. //</lyrics>
<hymn_number>593</hymn_number>
</song>