<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>501</hymn_number>
<lyrics>[V1]
 // Acıma sevinç katar İsa.
 Derdime derman verir Allah. //

[V2]
 // Uzaktan seyretme, kardeş,
 Al sonsuz hayatı, kardeş. //

[V3]
 // Bitki günü günahlılar
 doğru yoldan ayrılanlar, //

[V4]
 // doğrular Allahlan yaşar,
 Kötülerin yolu yok olur. //

[V5]
 // Bugün Allahın sözünü
 İman ile kabul edin. //

[V6]
 // Allahın diri sözüdür.
 Gece gündüz dua edin. //

[V7]
 // Ne kıymetli kutsal pınar,
 Orada benim Mesihim yaşar. //

[V8]
 // Bu sözlerden sevinç duyan
 Günahlarından kurtulur. //

[V9]
 // Kötülerle yürümeyin,
 Günah yolunda durmayьn, //

[V10]
 // Alaycılarla oturmayın,
 Allahın yolunda olun. //</lyrics>
<title>Acıma sevinç katar İsa BG501</title>
</song>