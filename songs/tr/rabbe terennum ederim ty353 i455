<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>353</hymn_number>
<title>Rab'be Terennüm Ederim TY353</title>
<lyrics>[V1]
 //  Rab'be terennüm ederim,
 Çünkü gayretle yükseldi,
 Düşmanları denize attı!  //

[V2]
 Rab kuvvetim ve mezmurumdur,
 O benim kurtuluşum oldu!
 Rab Allahım ve hamdedeceğim,
 Rab Allahım ve yükselteceğim!</lyrics>
</song>