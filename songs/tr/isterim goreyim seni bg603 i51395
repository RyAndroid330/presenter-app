<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>603</hymn_number>
<title>İsterim göreyim seni BG603</title>
<lyrics>[V1]
 İsterim göreyim seni,
 İsa Mesih, Rabbim.
 // Çekmişin gök perdesini,
 Göremem yüzünü. //

[V2]
 Göremem senin yüzünü
 İşittim sesini.
 // Benim aklım hep seninle.
 Yüreyim sevinçle. //

[V3]
 Sen her vakıt benimle ol.
 Yüreyimi doldur.
 // İmanımla gördüm Seni,
 Şifaladın beni. //

[V4]
 İnandım sana, Allahım.
 Yüzünü görmeden.
 // isterim, göreyim Seni,
 İsa Mesih, Rabbim. //
 aydınlık göklerde</lyrics>
</song>