<?xml version="1.0" encoding="UTF-8"?><song><author>Durmuş Tünel</author>
<lyrics>[V1]
 // Ben RAB'bin aşığıyım,
 Bir tek O'na taparım. //
 // Görmez gözüm dünyayı,
 Yalnız O'na bakarım. //

[V2]
 // Ben RAB'bin aşığıyım,
 Serveti ben neylerim. //
 // Sevgisini tatmışım,
 Candan da vazgeçerim. //

[V3]
 // Ben RAB'bin aşığıyım,
 Sanmayın ki yalnızım. //
 // Gündüz ve gecelerim,
 Rabbimle beraberim. //

[V4]
 // Ben RAB'bin aşığıyım,
 Yolundan şaşar mıyım? //
 // O elimden tuttu ya,
 Ölümü aşmaz mıyım? //</lyrics>
<title>Ben RAB'bin aşığıyım</title>
</song>