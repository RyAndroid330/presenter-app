<?xml version="1.0" encoding="UTF-8"?><song><author>MAHMUT KARDEŞ</author>
<hymn_number>614</hymn_number>
<lyrics>[V1]
 // Yüce Tanrım binlerce
 Şükürler edelim sana.
 Saa salim topladın bizi
 Senin tatlı sayana. //

[C1]
   // Orada beyaz evimiz,
   Orada bizim bahçemiz,
   Dön gel artık sen İsa,
   Teslim et bizi yanına. //

[C2]
   // Şükür, şükür Rab İsa'ya
   Sensin gözletleyen bizi,
   Kanınla yıka bizi,
   İmanla doldur bizi. //

[C3]
   // Şükür, şükür Rab İsa'ya
   Kanını döktü bize,
   Kanınla yıka bizi,
   İmanla doldur bizi. //</lyrics>
<title>Yüce Tanrım binlerce BG614</title>
</song>