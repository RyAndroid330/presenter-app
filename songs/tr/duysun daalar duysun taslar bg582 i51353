<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Duysun daalar, duysun taşlar.
 Seviyorum, içim yanar. //

[C1]
   Allahım benim,
   Allahım benim
   İyi Çobanım,
   Sevdiğim benim.

[C2]
   // Ben İsamı seveyim,
   Canımı vereyim.
   Yolundan gideyim,
   Ey İsam benim, //

[C3]
   // Kalbim yalnız sana tapar,
   Allahımı ben seveyim. //

[C4]
   // Ateş oldun, kalbimdesin.
   Sen söz oldun, dilimdesin. //

[C5]
   // Işık oldun, önümdesin,
   Allahımı ben seveyim. //</lyrics>
<title>Duysun daalar, duysun taşlar BG582</title>
<hymn_number>582</hymn_number>
</song>