<?xml version="1.0" encoding="UTF-8"?><song><title>Yücedir İsa'nın Adı; Secde Etsin Dünya! TY204</title>
<lyrics>[V1]
 Yücedir İsa'nın adı; secde etsin dünya!
 //  Ve: &quot;Her şeyin Rab'bi&quot; diye taç giydirsin O'na!  //

[V2]
 Günahkarlar diken tacı unutmasın asla!
 //  Alıp bütün taçlarını giydirsinler O'na!  //

[V3]
 Bu dünyadan her kurtulan, her taçlanan gökte
 //  Kendi tacını çıkarsın ve giydirsin Rab'be!  //

[V4]
 Baş melekler ve Kerubim katılsınlar bize!
 //  Gök ordusu ve Serafim taç giydirsin Rab'be!  //

[V5]
 Bütün evren, gök ve dünya, her yaratık ile
 //  Secde edip huzurunda taç giydirsin Rab'be!  //</lyrics>
<hymn_number>204</hymn_number>
</song>