<?xml version="1.0" encoding="UTF-8"?><song><author>Özgür Tunç</author>
<title>Senden Başkası Yok</title>
<lyrics>[V1]
.Em         D
 Yine bir günah içindeyim
.Am          C
 Yine düşmüş bir haldeyim
.Em            D
 Bir el ararım yerimden kalkmak için
.Am           C
 Seni düşünür bu düşmüş yüreğim

[V2]
.Em                  D
 Senden başkası yok, kurtaramaz benden beni
.Am                  C
 Günahım yükselirken değsin merhametin
.Em                   D
 Gelsin gelsin gelsin Ruhun bana gelsin
.Am             C
 Tutsun elimden kurtarsın benliğimden beni

[V3]
.Em         D        Am          C
 Rab yüzünü arıyorum gel Ruhunla gel Ruhunla</lyrics>
<key>Em</key>
</song>