<?xml version="1.0" encoding="UTF-8"?><song><author>Mustafa Abidov</author>
<hymn_number>52</hymn_number>
<title>Geri döndüm Ben BG52</title>
<key>Cm</key>
<lyrics>[V1]
.   Em                    Am
 // Babamdan ayrı bu dünyada
. C    D           Em
 Gezerdim karanlıkta
.Em                     Am
 Tanrıdan ayrı bu dünyada
. C       D      Em
 Ben mutlu olamadım //

[C1]
.     Em                       D
   // Geri döndüm, geri döndüm ben //
.  Am
   Kaybolan oğul gibi
.  Em
   Kaybolan oğul gibi
.  B                         Em (E)
   Babamın evine geri döndüm ben

[C2]
.  Am
   Kaybolan oğul gibi
.  Em
   Kaybolan oğul gibi
.  B                           Em
   Rabbimin evine geri döndüm ben

[V2]
.   Em                  Am
 // Dünya hep acı verdi bana
.C        D        Em
 Ama artık Seninleyim
.Em                   Am
 Rab İsa sevgin çok güzel
.C          D          E
 Senin varlığın yeter bana //</lyrics>
<aka>Kaybolan Oğul Gibi</aka>
</song>