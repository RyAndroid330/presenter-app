<?xml version="1.0" encoding="UTF-8"?><song><title>Rab Sen çok sevdin</title>
<key>Bm</key>
<lyrics>[V1]
.Bm                   F#              Em           F#
 Yaratılan hiç birşey Sensiz oluşmadı,var olmadı İsa,
.Bm             F#
 Yaşam Sendeydi,ışığın kendisiydin
.Em                    F#
 İnsan olup aramızda yaşadın.
.Em                   F#
 // Sen karanıkta parladın
.Em                  F#
 Ama biz Seni anlamadık. //

[C1]
.     Bm                 F#
   // Rab Sen dünyayı o kadar çok sevdin ki,
.  Em              F#
   Biricik Oğlunu bizlere verdin.
.  Bm                  F#
   Sana iman edenler sonsuzca kurtulacak,
.  Em                  F#         (Bm)
   Ebediyen Sana övgüler olsun.(İsa'm) //

[V2]
 Bizim uğrumuza dünyaya indin
 Ama biz seni tanımadık
 Günah içindeydik ,karanlıktaydık
 Ama sen bizleri aydınlattın
 // Uğrumuza feda oldun
 Bizleri kurtardın. //</lyrics>
<author>Mişel N. Samurkaş</author>
</song>