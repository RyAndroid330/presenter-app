<?xml version="1.0" encoding="UTF-8"?><song><title>Yıka beni isa</title>
<lyrics>[V1]
 // Allahım sana bağrıyom ben
 Allahım sana söylüyom ben
 Merhameti buldum sende
 Eşsiz sevgi ve sabır //
.    
     

[C1]
   // Yıka beni İsa suyunla Rab bim
   Yıka beni İsa kanınıla Rab bim
   Şükür edeyim ben sana
   Hamdedeyim İsa'ya //

[V2]
 // Allahım benim derdim çok
 Dermanımı kimse veren yok
 Yalvarıyom ben sana
 Yardımcı ol sen bana //

[V3]
 // Allahım nezaman gelecen sen
 Alasın beni bu dünyadan
 Götüresin cennetine
 Bende orda dinneneyim //</lyrics>
</song>