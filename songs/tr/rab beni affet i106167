<?xml version="1.0" encoding="UTF-8"?><song><author>Nisan Özlem Özyapıcı</author>
<title>Rab beni affet</title>
<lyrics>[V1]
.Em             Bm7
 // Rab ben kimim ki beni sevdin? //
.Am7                     B7
 // Senin sevgin kurtuluştur Rab'bim //
.C                  Em
 \\ Benim için öldün, Rab beni affet
.D                Am7
 Günahımı örttün, Rab beni affet \\ x2

[V2]
.Em             Bm7
 // Rab sen benim her şeyimsin //
.Am7                     B7
 // Senin sevgin kurtuluştur Rab'bim //
.C                  Em
 \\ Benim için öldün, Rab beni affet
.D               Am7
 Günahımı örttün kanınla, Rab beni affet \\ x2

[V3]
 /// Rab beni affet ///

[V4]
 /// Rab bana tövbe eden alçalmış bir yürek ver. ///</lyrics>
<key>Em</key>
</song>