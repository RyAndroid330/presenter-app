<?xml version="1.0" encoding="UTF-8"?><song><title>Bak Golgota'ya</title>
<lyrics>[V1]
 Bak Golgota'ya
 Ey Günahkar İnsan
 Orada Haç Üstünde
 Senin İçin Can Veren
 Bir Kurban Var

[V2]
 Bak Golgota'ya
 Ey günahkar insan
 Günahtan Arındıran
 Tanrıyla Barıştıran
 Bir Kurban Var

[V3]
 Bak Golgota'ya
 Ey günahkar insan
 Yüklerini Taşıyan
 Derdine Derman Olan
 Bir kurban var

[V4]
 Bak golgotaya
 Ey günahkar insan
 İsa dır Mesih olan
 Cennete ulaştıran
 Bir kurban var</lyrics>
<author>Kirkor Ağabaloğlu</author>
</song>