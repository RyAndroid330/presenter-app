<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>169</hymn_number>
<title>Sevgisi O'nun Ne Derin RT169</title>
<key>G</key>
<lyrics>[V1]
.G                C
 Sevgisi O'nun ne derin
.      G         D
 Ve şefkati sel gibi
.      G        C
 Tanrı kuzusu kanını
.    G    D       G
 Akıttı bizler için.

[V2]
.G                 D
 Kim anlar sevgisini?
.      C          G
 Kim bırakır övmeyi?
.     Em         C
 Asla unutulmayacak
.      G     D      G
 Sonsuzluklar boyunca

[V3]
.G                C
 Çarmıhta açıldı gökler
.      G          D
 Aktı Tanrı sevgisi
.     G         C
 Merhametini bizlere
.      G     D      G
 Döktü o bir sel gibi.

[V4]
.G               D
 Lütuf ve sevgisini
.      C             G
 Döktü güçle göklerden,
.       Em        C
 Göksel esenlik, adalet
.     G      D    G
 Öptü suçlu dünyayı.</lyrics>
</song>