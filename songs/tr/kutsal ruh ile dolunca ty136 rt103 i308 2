<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>136</hymn_number>
<author>Fred Hammond</author>
<title>Kutsal Ruh İle Dolunca TY136 RT103</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 //  Kutsal Ruh ile dolunca
.  B7            Em
 Davut gibi coşarım. //
.       Am        Em
 // Sevinirim, sevinirim!
.  B7            Em
 Davut gibi coşarım. //

[V2]
.   Em
 // Kutsal Ruh ile dolunca.
.    B7           Em
 Pavlus gibi işlerim. //
.       Am         Em
 // Çalışırım, çalışırım,
.   B7            Em
 Pavlus gibi işlerim. //

[V3]
.   Em
 //  Kutsal Ruh ile dolunca.
. B7           Em
 İsa gibi severim. //
.       Am      Em
 // Severim, severim,
. B7           Em
 İsa gibi severim. //</lyrics>
</song>