<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>599</hymn_number>
<author>Edip Avcıoğlu</author>
<title>Ben Layık Değildim, Rab Senin Sevgine TY599</title>
<key>C</key>
<lyrics>[V1]
.   Am             Dm                  Am
 // Ben layık değildim, Rab senin sevgine
.               G              Am
 Ama sen lütfedip kendine çektin. //

[V2]
 // Ellerimi sana ben açıyorum,
 Bağışla Rab İsa, senden diliyorum. //

[V3]
 // Dualarımı sana ben sunuyorum,
 Sen kabul et İsa'm, yalvarıyorum. //</lyrics>
</song>