<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ruhani hayat ver bize yaşayalım
 sende biz hep kalalım
 // hastayken düşkünken
 bizi hor görürken
 seni biz hep övelim //

[V2]
 Rabbim senin önünde duruyorum
 bütün kusurlarımla
 // eline beni al sen yıka pakla
 senin kutsal kanınla //

[V3]
 Müjde yayılsın bütün milletlere
 beni duacı sen yap
 // sana veriyorum kendimi Allahım
 beni kullan her zaman //</lyrics>
<title>Ruhani Hayat</title>
</song>