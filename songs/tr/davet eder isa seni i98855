<?xml version="1.0" encoding="UTF-8"?><song><title>Davet Eder İsa Seni</title>
<lyrics>[V1]
 // Davet eder Isa seni
 Bana getir dertlerini //
 // Gel ey yorgun argın bana
 Veririm ben rahat sana
 Rahat sana //

[V2]
 // Davet eder isa seni
 Gel ey susuz dinle beni //
 // Diri hayat suyu bende
 Şifan için gel iç sende
 Gel iç sende //

[V3]
 // İşte geldim günahlıydım
 İşte geldim affedildim //
 // işte geldim sevinç buldum
 işte geldim de kurtuldum
 De kurtuldum //

[V4]
 // Mutsuz idim koştum ona
 Yeni yürek verdi bana //
 // Sende aç kalbini ona
 Versin sonsuz hayat sana
 Hayat sana //</lyrics>
</song>