<?xml version="1.0" encoding="UTF-8"?><song><title>İsam! TY312</title>
<lyrics>[V1]
 //  Golgota'ya gelen ne güzel yoldur: İsam!  //
 //  O yolun yolcusu, ne güzel kuldur.  //
 //  O yolu bulanlar sevinçle coşar. İsam!  //
 //  Çevirmezsin sen geri, geleni sana.  //
 //  Canım feda olsun senin yoluna, İsam!  //
 //  Ol benimle daima, burada ve orada.  //
 //  Ömrünü verdin benim uğruma, İsam!  //
 //  Ben niye vermeyeyim kalbimi sana.  //
 //  Doldur Kutsal Ruhunla beni her zaman, İsam!  //
 //  Duysun ki her arayan Rabbimiz İsa!  //</lyrics>
<hymn_number>312</hymn_number>
</song>