<?xml version="1.0" encoding="UTF-8"?><song><author>Ahmed Muzafer</author>
<title>Ölene Kadar</title>
<lyrics>[V1]
 // Günyahlarimiz için o vuruldu
 Fesatlarımız için
 Onun yüzerime koydun //

[V2]
 Onu üvelim boynumuzun borcu
 Üvecem üvecem Ölene kadar

[C1]
   // Ölenekadar İsa'yı Seveceyim
   Ölene kadar Mesîh'i Allah Allah üveceim
   Ölene kadar Allahlan olacayim
   Ölene kadar Ölene kadar //

[V3]
 // Kaybolanı aradı
 Günyahları taşıdı
 Kendini Kurban adadı
 Yüce Allah'ın oğlu //

[V4]
 Onu üvelim Böyle bir Kralı
 Üvecem üvecem
 Ölene kadar</lyrics>
</song>