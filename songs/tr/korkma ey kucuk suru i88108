<?xml version="1.0" encoding="UTF-8"?><song><author>Adil Yaşar</author>
<lyrics>[V1]
 // Korkma Ey Küçük Sürü
 Ben Sizinle Birlikteyim //
 // Sona Kadar Dayanın
 Kurtuluş Günü çok Yakın //

[V2]
 // Yer ve Gökler Kalksa Bile
 Değişmeyendir Allahım
 Bir Nokta Bile Eksilmez Ebedidir Sözleri //

[V3]
 // Allahımın Sözleri Güvenilir ve Gerçektir //
 // Allahımın Vaatleri Güvenilir ve Gerçektir //</lyrics>
<title>korkma ey kücük sürü</title>
</song>