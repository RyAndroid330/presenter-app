<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>647</hymn_number>
<title>Nereye, nereye vurayım BG647</title>
<lyrics>[V1]
 Nereye, nereye vurayım,
 Şu kutsuz başımı ?
 // Nereye, nereye gideyim,
 Bu yalnızlık sardı beni ? //

[C1]
   Rabbim, Rabbim duruyor.
   Herkesi de bekliyor.
   // Gözyaşıyla aalıyor,
   'Gelin, gelin.' diyor. //

[C2]
   O Allahım, Rabbim,
   Neredesin, Mesih'im ?
   // Nasıl, nasıl bulayım
   Ben senin yolunu ? //

[C3]
   Nasıl, nasıl yapayım,
   Allahımı bulayım ?
   // Benim Allahım var,
   O beni yalnız brakmaz. //

[C4]
   Nasıl, nasıl rahat olayım,
   Vergimle ben bu dınyada ?
   // Nasıl, nasıl rahat olayım,
   Siz çeki çekerken. //

[C5]
   Gelin, gelin yavrular,
   Gelin, gelin kuzular.
   // Bu çekiler olmazsa,
   Bu yalnızlığı duymayın. //</lyrics>
</song>