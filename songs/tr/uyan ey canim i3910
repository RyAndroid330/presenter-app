<?xml version="1.0" encoding="UTF-8"?><song><title>Uyan Ey Canım</title>
<key>Em</key>
<lyrics>[V1]
.   Em             Am
 // Uyan ey canım, uyan ey canım
.B7                  Em
 Seheri ben uyandırayım. //

[V2]
.     Am               Em
 // Çünkü Sevgisi göklere erişir,
.  B7            Em     E
 Sadakati gökyüzüne ulaşır
. Am                     Em
 Yüceliğini göster göklerde Ey Tanrım.
.B7                     Em      E
 Görkemin bütün gökyüzünü kaplasın. //

[V3]
 Gökten gönderip beni kurtaracak,
 Sevgisin', Sadakatin' gösterecek.
 Benim için herşeyi yapan
 Yüce Tanrı'ma sesleniyorum.</lyrics>
<author>Mişel N. Samurkaş</author>
</song>