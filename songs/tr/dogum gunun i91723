<?xml version="1.0" encoding="UTF-8"?><song><author>Mustafa Abidov</author>
<title>Doğum Günün</title>
<lyrics>[V1]
.Em          C               D
 Doğum günün kutlu, mutlu olsun
.Em           C           D
 Rab hep yanında senin olsun
.Am
 Aileni ve seni korusun
.Bm          Em
 sonsuz boyunca/3

[V2]
.Em           C                D
 İyilik, sağılık dileriz biz sana
.Em        C         D
 Rable sen ol her zaman
.Am
 Yaşlandığında bile
.Bm
 Rab seni terk etmez
.Em
 dostum /3

[V3]
.Em          C              D
 İyi ki doğudun, iyi ki varsın
.Em                C    D  Em
 Rab seni bereketlesin dostum</lyrics>
<key>Em</key>
<aka>Rab Seni Terk Etmez</aka>
</song>