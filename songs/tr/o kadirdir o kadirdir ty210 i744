<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.       G        D7
 O kadirdir, O kadirdir,
.    G       C
 Rab İsam kadirdir.
.    G            D7        GCG
 Ben bilirim, Rab İsam kadirdir!

[V2]
.       G        D7
 O kadirdir, O kadirdir,
.    G       C
 Rab İsam kadirdir.
.    G         D7            GCG
 Her şeye kadirdir, benim Rabbim!

[V3]
 Hastaya şifa verir,
 Günahtan kurtarır,
 Yürütür kötürümü,
 Açar körün gözünü
 O Kadir'dir (2x)
 Rab İsa'm Kadir'dir
 Her şeye Kadir'dir
 Benim Rabbim</lyrics>
<key>G</key>
<title>O Kadirdir, O Kadirdir TY210</title>
<author>Paul E. Paino</author>
