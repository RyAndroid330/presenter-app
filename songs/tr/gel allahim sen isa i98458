<?xml version="1.0" encoding="UTF-8"?><song><author>Adil Yaşar</author>
<title>Gel Allahım sen isa</title>
<lyrics>[V1]
 // Gel Allahım sen Isa
 Gel sen yanıma
 Sana muhtacım
 Destek ol bana //

[V2]
 // Kutsal Ruhunla kuvvet ver bana
 Ben çok zayıfım Yardım et Bana //

[V3]
 // Benim için Allahım isa
 Tahtını sen braktın
 Kanınla Yıka beni
 Ey merhametli Isa //

[V4]
 // Hazırla beni Rabbim Isa
 Sana uygun Et
 Nurlu yüzünü
 Bende Göreyim //</lyrics>
</song>