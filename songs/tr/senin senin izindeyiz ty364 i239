<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>364</hymn_number>
<author>Faruk Peker</author>
<lyrics>[C1]
.     Dm           A     Dm
   // Senin, senin izindeyiz.
.                 A        Dm
   Kutsal, kutsal himayendeyiz.
.  Gm          A       Dm
   Biz seninle birlikteyiz,
.  A                Dm
   Huzur ve sevinçliyiz. //

[V1]
.                  Gm   A                Dm
 // Kimin zulmü ayırır, bizi senin sevginden?
.              Gm A              Dm
 Kim kötülük eder senin gözetiminde? //

[V2]
.                    Gm  A                 Dm
 // Ne ölüm ne de yaşam, ne kılıç ne de zaman
.           Gm  A           Dm
 Bizi ayıramaz, bizi koparamaz. //</lyrics>
<key>Dm</key>
<title>Senin, Senin İzindeyiz TY364</title>
</song>