<?xml version="1.0" encoding="UTF-8"?><song><title>Ey insanlar</title>
<lyrics>[V1]
 // Ey insanlar
 Tanrı sizi seviyor //

[V2]
 // Biz onun kuzularıyız
 Koyunlarıyız Çocuklarıyız //

[V3]
 Şükürler Şükürler İsa'ya
 Şükürler Şükürler Alla'ha

[V4]
 // Gelin Gelin Fakirler //

[V5]
 // İsa Bizi Çok Seviyor
 Cenneti verdi bize //

[V6]
 // Allahıma Şükürler //

[V7]
 // Tuttu beni elimden
 Yörüttü dar yolundan //</lyrics>
</song>