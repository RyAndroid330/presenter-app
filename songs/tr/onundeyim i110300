<?xml version="1.0" encoding="UTF-8"?><song><title>Önündeyim</title>
<lyrics>[V1]
.Bm                        A
  Bir gün tahtlar, krallıklar
.G               D
  Önünde duracaklar;
.Bm                   G
  Yarattığın tüm uluslar,
.A                  Bm
  Gelip diz çökecekler.

[C1]
.   Bm             G
   &quot;Önündeyim Rab, önünde;
.  A              Bm
   Varlığın şimdi bu yerde.
.  D              G
   Titrer bedenim Sen'inle;
.  A                Bm
   Tapınırım ruhta, gerçekte.&quot;

[V2]
.Bm                   A
  Bugün Çarmıha bakanlar,
.G              D
  Önünde arınırlar
.Bm                     G
  Ruhtan doğan tüm uluslar,
.A                 Bm
  Zaferini tadacaklar.

[B1]
.   Bm            G   A
   &quot;Gecikme sende gel önüne;
.  G                       D
   Eğil tapın diz çök bizimle...&quot;</lyrics>
<key>Bm</key>
<author>Barış Örün</author>
</song>