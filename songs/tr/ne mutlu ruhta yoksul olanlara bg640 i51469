<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ne mutlu ruhta yoksul olanlara, //
 // Göklerin egemenliyi onlarındır. //

[V2]
 // Ne mutlu, ne mutlu aalayanlara, //
 // Hepsi onlar teselli edilecekler. //

[V3]
 // Ne mutlu yumuşak huylu olanlara, //
 // Onlar yeryüzünü miras alacaklar. //

[V4]
 // Ne mutlu doğrulua acıkanlara, //
 // Çünkü onlar doyurulacaklar. //

[V5]
 // Ne mutlu merhametli olanlara, //
 // Onlara da merhamet edilecek. //

[V6]
 // Ne mutlu yüreyi temiz olanlara, //
 // Çünkü onlar Tanrı'yı görecekler. //

[V7]
 // Ne mutlu barışı getirenlere, //
 // Onlar Tanrı evlatları çarılacak. //

[V8]
 // Ne mutlu Tanrı için çeki çekenler, //
 // Göklerin egemenliği onlarındır. //</lyrics>
<title>Ne mutlu ruhta yoksul olanlara BG640</title>
