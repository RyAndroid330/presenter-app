<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am                   F              Am
 // Sonsuz, güçlü Tanrı, dünyaları yaratan, //
.Am      Em         Dm          Am
 Zayıflamaz, uyuklamaz, O yorulmaz,
.Am      Em          Dm           Am
 O yorulmaz, O yorulmaz, güçlü Tanrı.

[V2]
.   Am              F                 Am
 // Güçlü kişi bile yorgun ve argın olur, //
.Am      Em            Dm            Am
 Yiğit adam, hem zayıflar, hem de düşer,
.Am        Em           Dm           Am
 Hem zayıflar, hem de düşer, güçlü kişi.

[V3]
.   Am                F              Am
 // Rab'bi bekleyenin tazelenir kuvveti, //
.Am       Em           Dm          Am
 Kartal gibi, kanat gerip yükselir o,
.Am       Em          Dm           Am
 Yükselir o, yükselir o, kartal gibi.

[V4]
.   Am                 F                Am
 // Onlar seğirtirler, ama yorgun düşmezler, //
.Am       Em            Dm          Am
 Çünkü onlar Rab'bi bekler tüm yürekten,
.Am         Em             Dm            Am
 Rab'bi bekler, Rab'bi bekler, tüm yürekten.</lyrics>
<title>Sonsuz, Güçlü Tanrı TY257</title>
<author>Ali Yazar</author>
<hymn_number>257</hymn_number>
</song>