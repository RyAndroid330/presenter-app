<author>Paul Wilbur</author>
<lyrics>[V1]
.   Em                          D
 // En Kutsal Yer'e gitmek istiyorum,
.    C      D           Em
 Mesih'in kanıyla gidiyorum.
.Em                     D
 Ben, Ben olana tapmak için,
. C      D          Em
 Onur vermeye gidiyorum. //

[V2]
.   (Em)   G           D
 //  Ben Sana tapınıyorum,
.  Am          Em
 Sana tapınıyorum. //
.   (Em)           C
 //  Çünkü adın kutsaldır,
.   D       Em
 Kutsaldır İsam. //</lyrics>
<key>G</key>
<title>En kutsal yere gitmek istiyorum BG29 RT233</title>
</song>