<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<lyrics>[V1]
 Babam, Babam, Babacığım
 Yoktur dünyada rahatım
 // Dünya beni eziyor
 Kurtar beni Allahım //

[V2]
 Şeytan senin yaninda
 sen Değilsin farkinda
 // sen Düşünce gunaha
 o seviniyor tahtinda //

[V3]
 Çilenizi biliyorum
 Gücüne Güç Katacam
 // Bekle beni gelecem
 selameti verecem //

[V4]
 Saya sola bakinma
 dua edin Babaya
 // O verdi sizi bana
 davetlisiniz yanima //</lyrics>
<title>Babam, Babam, Babacığım BG22</title>
</song>