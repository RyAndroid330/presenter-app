<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>474</hymn_number>
<author>Juan Salinas, Marcos Witt</author>
<title>Kederimi Dansa Çevirdin TY474</title>
<lyrics>[V1]
.Em    C         D    Em
 // Kederimi dansa çevirdin.
.      C            D   Em
 Beni tam coşkuyla kuşattın. //

[V2]
.D  G           D
 Sana hamdedeceğim,
.       C      D         Em
 Övgüm Sensin, Övgüm Sensin.
.D   G             D
 Tek Sana dans ederim,
.       C                B7
 Övgüm Sensin, Övgüm Sensin.

[V3]
.Em          B7     Em
 // Oh Adonay, Oh Adonay!
.  C       D    Em
 Evrenin egemenisin,
. B7          Em
 Alemlerin Rabbi! //

[V4]
.    D               G
 // Gökler Seni anlatırlar,
.   D            G
 çocukların tapınırlar,
.  B7             Em
 Bütün harikalarınla,
.C   B7
 Adonay! //</lyrics>
<key>Em</key>
</song>