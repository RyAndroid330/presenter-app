<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.F        Bb              C C7
 Hiç bir serçe yere düşmez
.Bb           F                  C C7
 Gökteki Baban'ın haberi olmadan.
.F        Bb               C C7
 Hiç bir serçe yere düşmez.
.Bb           F                 C F
 Gökteki Baban'ın haberi olmadan.

[V2]
 // Siz kuşlardan değerlisiniz.
 Gökteki Babamız sizi çok sever. //

[V3]
 // Ayhan* asla yere düşmez
 Gökteki Baban'ın haberi olmadan. //

[V4]
 // Sen kuşlardan değerlisin,
 Gökteki Babamız seni çok sever. //</lyrics>
<key>F</key>
<title>Hiç Bir Serçe TÇ151</title>
<author>Geoffrey Harding</author>
