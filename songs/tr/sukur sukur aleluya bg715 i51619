<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Şükür, şükür, Aleluya,
   Güzel Allahımıza. //

[C2]
   // Kimsesiz kaldım,
   Ben bu dünyada,
   İsa'yı aradım,
   Benimle olsun. //

[C3]
   // Karanlık dünyada
   Günah işledim.
   Şimdi aydınlıkta,
   Kurtuluş buldum. //

[C4]
   // İsa Mesih, Rabbim,
   Ben senin yavrun.
   Sen beni aradın,
   Sen beni kurtardın. //</lyrics>
<title>Şükür, şükür, Aleluya BG715</title>
<hymn_number>715</hymn_number>
</song>