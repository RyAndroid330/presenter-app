<?xml version="1.0" encoding="UTF-8"?><song><title>Ya Rab Mübarek Kıl</title>
<lyrics>[V1]
 Ya Rab mübarek kıl
 Sınırım genişlet
 Elin benimle olsun
 Beni şerden korusun

[V2]
 Ya Rab merhamet et
 Yollarım genişlet
 Ruhun benimle olsun
 Beni şerden korusun</lyrics>
<author>Turgay Üçal, Turgay Üçal</author>
</song>