<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>500</hymn_number>
<lyrics>[V1]
 Acım, gamım, derdim çok oldu benim.
 // Nerelere gideyim, derman isteyim ? //

[V2]
 Yum sen gözlerini, kaldır ellerini.
 // Bağır, söyle derdini, işitecem. //

[V3]
 // Ben de çok seviniyom, hani benim oldunuz. //

[V4]
 // Her bir derdinize derman oluyorum. //

[V5]
 // Önüme gelen beni vurup dövdüler. //

[V6]
 // Önüme gelenlere boyun eydim ben. //
 // Böyle çile, yavrum, vermem ben size. //</lyrics>
<title>Acım, gamım, derdim çok oldu benim BG500</title>
</song>