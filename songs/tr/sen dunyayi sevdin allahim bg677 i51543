<?xml version="1.0" encoding="UTF-8"?><song><title>Sen dünyayı sevdin, Allahım BG677</title>
<lyrics>[V1]
 // Sen dünyayı sevdin, Allahım
 Biricik Oglunu verdin. //

[C1]
   // Gel Rabbim, gel İsa.
   Mubarekle sen bizi.
   Gel Rabbim, gel İsam.
   Mubarekle hepimizi. //

[C2]
   // Bir el sen de uzat, ya Rabbim.
   Mubarekle şimdi bizi. //

[C3]
   // Bizim için İsam öldün.
   Bizim için sen dirildin. //

[C4]
   // Al bizi İsa, senin yanına.
   seninle Olalım yukarda . //

[V2]
 // Şükür sana, İsa mesih ,
 benim Günahlarımı af ettin. //
 // Kurtuluşu bana verdin,
 İsmimi cennete yazdın. //</lyrics>
<hymn_number>677</hymn_number>
</song>