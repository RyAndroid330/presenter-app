<?xml version="1.0" encoding="UTF-8"?><song><title>Allahım Güçlüsün</title>
<lyrics>[V1]
 // Allahım Güçlüsün
 Övgüye Layık sın //

[V2]
 // Hamtların Rabbisin
 Her şeyden üstünsün
 Sen kadir tanrısın
 Işık sın Rab isa //

[V3]
 // Kudretisin sen Allahım
 Evrenin Kralısın //

[V4]
 // Gökte yerde bir tane sin
 Herşeyin hakimisin //

[V5]
 // Rab isa Allahım
 Temizle kalbimizi //

[V6]
 // Kuvvet ver sen bize
 Şeytani Ezelim
 Zaferler kazanalım
 Yüzünü görelim //</lyrics>
<author>Adil Yaşar</author>
</song>