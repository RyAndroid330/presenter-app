<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am       G        Am
 // Benim Tanrı'm diridir,
.Am        G         C  A
  Benim Tanrı'm hayatta.
.Dm
  Seslenirsem duyar,
.Am
  Beni yanıtlar,
.G      Em      Am
  Engel yok ki O'na. //

[V2]
.   Am
 //  O günahı yendi,
.Am
  Ölümü alt etti.
.Dm
  Zafer kazandı.
.G              Am
  Dirildi, dirildi. //

[V3]
.Am                           Dm       Am
 // İşte bu yüzden gece gündüz tapınsam azdır,
.Am                      Dm         Am
  Bundan böyle benim için her gün bayramdır.
.Dm                 G               Am
  Sevinirim, coşarım her zaman kutlarım,
.G/B C G         Em       Am
  Çünkü benim Tanrı'm diridir. //

[V4]
.   G         Em       Am
 //  Benim Tanrı'm diridir. //</lyrics>
<title>Benim Tanrı'm Diridir</title>
<author>Songül Duran</author>
</song>