<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>721</hymn_number>
<lyrics>[V1]
 // Yaşamak verdi İsa,
 Şükürler ettim ben ona.
 O kanıyla ödedi,
 Kendi temiz kanıyla. //

[C1]
   // Brakma, brakma beni sen,
   Seni seviyorum.
   Sensiz ben yaşayamam,
   Sensiz ben olamam. //

[V2]
 // Senin ellerinden
 Yaşıyoruz çok islya.
 Kalbimi sana verdim,
 Yaşamak hep buldum. //

[V3]
 // Allah gelecek,
 O bizi alacak,
 O bizi alacak,
 Bizimle olacak. //

[V4]
 // Ateş yanacak,
 Kim iman ederse
 Kim iman ederse,
 Rabbimle yaşayacak. //</lyrics>
<title>Yaşamak verdi İsa BG721</title>
</song>