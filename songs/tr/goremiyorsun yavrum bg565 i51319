<?xml version="1.0" encoding="UTF-8"?><song><title>Göremiyorsun, yavrum BG565</title>
<lyrics>[V1]
 // Göremiyorsun, yavrum,
 Senin yanlış işlerini. //
 // Aç gözünü, gör seni,
 Yargılama kimseleri. //

[C1]
   // Dön geri, gel beri. //
   // Ölümden kurtar seni. //

[V2]
 // Bir derede, köşede,
 Uraşırdın dertlerinle. //
 // Aldım seni dereden,
 Kurtardım dertlerinden. //

[V3]
 // Bakırdın etrafına,
 Koşan yok yardımına. //
 // Halin yok dayanmaya.
 Koştum sana yardıma. //

[V4]
 // Dooru, dooru söyleyin.
 Ben yalanı sevmeyim. //
 // Dooru yolumdan gidin,
 Dooru yanıma gelin. //</lyrics>
<hymn_number>565</hymn_number>
</song>