<?xml version="1.0" encoding="UTF-8"?><song><title>Sen açtın gözlerimizi, Allah BG673</title>
<lyrics>[V1]
 // Sen açtın gözlerimizi, Allah,
 Görelim dünyayı. //

[C1]
   Fakirlere, hasta olanlara,
   Rab İsam, sen geldin.
   Fakirlere, hasta olanlara,
   Rab İsam, sen verdin.

[C2]
   // Çok günahlı oluyoz, Allahım,
   Arındır sen bizi. //

[C3]
   // Bizim günahlarımızdan için,
   Mesihim, sen öldün. //

[C4]
   // Sen kurtardın bizi, ey Allahım,
   Karanlık dünyadan. //</lyrics>
<hymn_number>673</hymn_number>
</song>