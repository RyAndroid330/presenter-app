<?xml version="1.0" encoding="UTF-8"?><song><title>Kasırgaya Tutulmuş TY264</title>
<lyrics>[C1]
   //  Kasırgaya tutulmuş
   Ey teselli bulmamış,
   Gök yakutları ile
   Atılacak temelin.  //

[V1]
 //  Doğrulukla donanıp
 Korkun hiç olmayacak.  //
 //  Teselli olacaksın,
 Kurtuluş bulacaksın.  //

[V2]
 //  Dağlar yerinden kalkar,
 Tepeler de sarsılır.  //
 //  Benim tüm inayetim
 Üzerinden hiç kalkmaz.  //

[V3]
 //  Esenlik sundum sana,
 Verdiğim söz sarsılmaz.  //
 //  Sana merhamet ettim,
 İnayetimi döktüm.  //</lyrics>
<hymn_number>264</hymn_number>
<author>Ali Yazar</author>
</song>