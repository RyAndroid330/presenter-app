<?xml version="1.0" encoding="UTF-8"?><song><title>Gel Allah, sor bana BG549</title>
<lyrics>[V1]
 // Gel Allah, sor bana,
 Sen açasan kalbimi.
 Olamam sensiz, Allah,
 Böyle ben üzgünüm. //

[C1]
   // Hem ben yalnızdım,
   Hem çok hastaydım.
   Allahım beni buldu,
   Bana sabırlık verdi. //

[V2]
 // Benim yolum, yavrularım,
 Çok dardır, çok uzun.
 İsteyin size iman,
 İmanlı olasanız. //

[V3]
 // Siz, benim yavrularım,
 Size çok gülerler
 İsteyin siz Allahtan,
 Dayanabileseniz. //

[V4]
 // İnan olun, inan olun.
 Her vakıt duaya durun.
 Allah size gelecek,
 Cennete götürerecek. //</lyrics>
<hymn_number>549</hymn_number>
</song>