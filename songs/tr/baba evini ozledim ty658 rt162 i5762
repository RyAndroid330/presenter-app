<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>658</hymn_number>
<author>Banu Çelik</author>
<lyrics>[V1]
.Em     D      A    Em
 Avluların da olsaydım
.Em       D    A     Em
 Yanında Rab otursaydım
.    D      Em
 Yüzüne baksam
.     D      Em
 Sevgine doysam
.      D     A      Em
 // Baba evini özledim //

[V2]
.Em         D     A    Em
 Her gün canım seni özler
.Em      D     A      Em
 Geleceksin yolun gözler
.  D     Em       D      Em
 İçim çeker, yüreğim sızlar
.      D     A      Em
 // Baba evini özledim //

[V3]
.Em      D       A    Em
 Güneşimsin, kalkanımsın
.Em     D      A   Em
 Huzurumun kaynağısın
.    D     Em      D     Em
 Acılar biter, yaşlar diner
.      D     A      Em
 // Baba evini özledim //

[V4]
.Em      D    A     Em
 İsa'nın önünde dursam
.Em     D    A    Em
 Yaralarına dokunsam
.    D     Em       D     Em
 Ya Rab desem, hamtlar etsem
.      D     A      Em
 // Baba evini özledim //

[V5]
.Em      D    A     Em
 Gözlerimi kapadığımda,
.Em       D     A      Em
 Bu dünyadan ayrıldığımda
.     D      Em         D       Em
 Yanına gelirim, Kurtuldum bilirim
.      D     A      Em
 // Baba evini özledim //</lyrics>
<key>D</key>
<title>Baba Evini Özledim TY658 RT162</title>
</song>