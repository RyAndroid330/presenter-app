<?xml version="1.0" encoding="UTF-8"?><song><title>Isa geldi yanima</title>
<lyrics>[V1]
 // Isa geldi yanima
 Sonsuz hayat verdi bana //
 // Şükürler övgüler olsun sana //

[V2]
 // Hayatimi verdim sana
 Yaşamimi verdim sana //
 // Sen sahip cik bana ey alahim //

[V3]
 // Her derdime derman isa
 Her astaya şifa isa //
 // Duy benim duami ey alahim //</lyrics>
</song>