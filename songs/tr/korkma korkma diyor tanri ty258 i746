<?xml version="1.0" encoding="UTF-8"?><song><title>Korkma, Korkma Diyor Tanrı TY258</title>
<key>Em</key>
<lyrics>[C1]
.      Em                  F
   // Korkma, korkma diyor Tanrı,
.   Am                Em
   Ben seninle beraberim. //

[C2]
   // Etrafına hiç bakınma,
.   Am                   Em
   Çünkü senin Tanrın benim. //

[V1]
 // Pekiştireceğim seni,
 Sana yardım edeceğim. //
 // Adaletimin eliyle
 Sana destek olacağım. //</lyrics>
