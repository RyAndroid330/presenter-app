<?xml version="1.0" encoding="UTF-8"?><song><author>Murat Susmak, Benjamin Mclure</author>
<lyrics>[V1]
.Em   C       D
 Lütfunu dök bize,
.Em    C   D
 Ey Tanrı oğlu,
.Em    C    D
 Krallığına al,
.Em  C    D
 Kutsa bizi!

[V2]
.Em  C   D
 Evrenin Kralı,
.Em  C    D
 Günah kurbanı,
.Em  C   D
 Egemen Rab,
.Em  C   D
 Affet bizi!

[V3]
.   Em    C    G     D
 Ateşinle Yak, Yönet beni,
.   Em    C    G     D
 Ateşinle Yak, Sevginle.

[V4]
 Göksel evimde,
 Senin gölgende,
 Sonsuzluğunda,
 Yerimi aç!</lyrics>
