<?xml version="1.0" encoding="UTF-8"?><song><author>Selin Değer</author>
<hymn_number>216</hymn_number>
<lyrics>[V1]
.Am       E         Am
 İman ettim ben İsa'ya,
.Am         E         Am
 Huzur buldum en sonunda.
.Am                 E
 Sevgisini verdi bana,
.E                  Am
 Yaşam sundu insanlara.

[V2]
.   Am           Dm
 // Tanrım gel bana,
.      G          C
 Kalbimi açtım sana.
.   F          Dm
 Sonsuza dek inan,
.   E           Am
 Sevgim derin sana. //</lyrics>
<key>Am</key>
<title>İman Ettim Ben İsa'ya TY216</title>
</song>