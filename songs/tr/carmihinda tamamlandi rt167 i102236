<?xml version="1.0" encoding="UTF-8"?><song><author>Nigel Hendroff, Rich Thompson, Jonny Robinson</author>
<hymn_number>167</hymn_number>
<lyrics>[V1]
.D          G
 Çarmıhtaki seslenişi
.D        Bm    A
 Sevindiriyor bizi;
.D        G
 İsa bize umut verdi,
.D/F#m G        A     D
 &quot;İşim tamamlandı&quot; dedi.
.Bm          G
 Güneş karardığı zaman,
.D           A
 Yenilmiş görünsek de;
.Bm          G
 İsa'mız Şeytan'ı yendi;
.D/F#m G        A    D
 Çarmıhında tamamlandı.

[V2]
.D         G
 Laneti artık bozuldu,
.D         Bm   A
 Bedelimiz ödendi;
.D         G
 Bağışladı İsa bizi,
.D/F#m G        A     D
 Bize sevgiyle lütfetti.
.Bm          G
 İsa'nın doğruluğuyla
.D           A
 Yaklaşırız Baba'ya;
.Bm          G
 Suçumuz kalmadı artık,
.D/F#m G        A    D
 Çarmıhında tamamlandı.

[V3]
.   D         G
 // Ölüm rakibimiz iken
.D          Bm    A
 Korku bize sahipti;
.D         G
 Ölüp dirilen İsa'mız
.D/F#m  G       A    D
 Gerçek özgürlüğü verdi. //
.    D/F#m  G       A    D
 İsa gerçek özgürlüğü verdi!

[V4]
.Bm         G
 Özgürce sevip yaşamak,
.D           A
 Karanlıktan azade;
.Bm         G
 Ölüm ölü, Mesih diri,
.D/F#m G        A    D
 Çarmıhında tamamlandı.

[V5]
.Bm       G
 Ebedi sevince doğru,
.D          A
 Kurtarıcı Mesih'e;
.Bm        G
 Zaferiyle coşuyoruz,
.    D/F#m G        A    D
 /// Çarmıhında tamamlandı. ///</lyrics>
<key>D</key>
<aka>Çarmıhtaki seslenişi</aka>
<title>Çarmıhında tamamlandı RT167</title>
</song>