<?xml version="1.0" encoding="UTF-8"?><song><title>Ne kadar acı yaşlar döktüm BG639</title>
<lyrics>[V1]
 Ne kadar acı yaşlar döktüm,
 Seni, Allah, aradım.
 // Hep seni, Allah, merhametli
 Kıskançlıkla aradım. //

[V2]
 Niçin benim dualarıma
 Sen susarsın çok günler ?
 // Ya da istiyon imanımı benim
 Deneyesen, Allah, sen ? //

[V3]
 Kardaşımın günahlarını
 Candan af etmedim mi ?
 // Ya da senin temiz gönlünce,
 Bir günah mı işledim ? //

[V4]
 Az da olsa benim imanım,
 Daha dünyanın içinde.
 // Doldur beni imanınla sen,
 Hep sevgiyle doldur sen. //</lyrics>
<hymn_number>639</hymn_number>
</song>