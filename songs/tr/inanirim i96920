<?xml version="1.0" encoding="UTF-8"?><song><author>Reuben Morgan</author>
<title>İnanırım</title>
<aka>Kurtarıcım Yaşıyor!</aka>
<lyrics>[V1]
 Canımı kurtardığına
 Kanıyla aklandığıma
 İnanırım, inanırım.

[V2]
 Utancımı kaldırdığına,
 Adıyla şifa verdiğine
 İnanırım, inanırım.

[P1]
   Sevinçle coşarım,
   Çünkü Rab ölümü yendi!

[C1]
   // Kurtarıcım dirildi,
   Kurtarıcım yaşıyor! //

[B1]
   Yükümü kaldırır,
   Yüceltirsin beni,
   Dağlarda dans ederim
   Senin için Rab İsam</lyrics>
</song>