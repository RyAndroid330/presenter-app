<?xml version="1.0" encoding="UTF-8"?><song><title>Senden İhtiyacım Var İsa BG54</title>
<lyrics>[C1]
   Senden ihtiyacım var İsa
   Gelesin Rabbim şimdi
   Yüreklerimizi temizleyesin
   Senin kutsal kanınla

[C2]
   Sana barıyorum ya Rab İsa
   Bize Sen yardım et İsa
   Sonuna kadar dayanalım Rabbim
   Senin yolunda yürüyelim

[C3]
   Sana tapıyorum Seni seviyorum
   Senin adını İsa

[C4]
   Seni seviyorum Seni bekliyorum
   Senin adını İsa

[C5]
   Sana bağırıyorum Seni bekliyorum
   Senin adını İsa</lyrics>
<hymn_number>54</hymn_number>
</song>