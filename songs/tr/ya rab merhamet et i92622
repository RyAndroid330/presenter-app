<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ya Rab merhamet et,
 Sen bu insanlara,
 Kelam'ını gönder
 Seni arayanlara. //

[C1]
   // Gözleri var görmezler,
   Kulakları var işitmezler
   Tuz ve ışık yap bizi
   Gönder onlara.
   Karanlıkta yol bilmezler,
   Uzanan eli görmezler.
   Yüreklere sevgini dök,
   Göster onlara. //

[V2]
 // Gittikleri yollar,
 Senin yolun değil.
 Düşünceleri boş,
 Tanrısal değil. //</lyrics>
<title>Ya Rab merhamet et</title>
<author>Şaban Ok</author>
</song>