<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   D            Bm    G              A
 // كەل، ماعا باتاڭدى تۅگۉپ، كۉۉلۅپ جۉرۅك قىلدارىن
.D         Bm    G      A      D
 ىرايىمىڭا بۅلۅنۉپ، سەنئ داڭقتاپ ىردايىن. //

[C1]
.     D             Bm
   // جاردام بەرچى، اسقا۔تاشىم!
.   G            A
   تولتۇرۇپ ۅز كۉچۉڭۅ.
.       D         Bm
   مەنى قولدوپ، الىپ بارچى
.  G       A   D
   اسمانداعى ۉيۉمۅ. //

[V2]
.      D          Bm    G              A
 // وبونۇڭا مەنى سالىپ، ۅز تىلىڭدە سۉيلۅتكۉن
.D              Bm    G     A      D
 ەركىن بولوم، تامىر الىپ، نەگىزىنەن سۉيۉۉڭدۅن. //</lyrics>
<key>D</key>
<title>كەل، ماعا باتاڭدى تۅگۉپ ATT180</title>
<hymn_number>180</hymn_number>
</song>