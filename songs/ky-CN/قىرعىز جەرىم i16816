<?xml version="1.0" encoding="UTF-8"?><song><author>ائدى ازىزوۆا</author>
<lyrics>[V1]
.         Bm         A
 بىيىك توولور كۅك اسمانعا جەتكەنسىپ،
.          Em          G        Em F#
 قۇرچاپ تۇرات ىسىق ۔ كۅلدۇ ۔ بەرمەتتى،
.         Bm         A
 كۉندۉن نۇرۇ جەرگە التىن سەپكەنسئيت،
.          Em              G        Em F#
 قىرعىز جەرىم ەچ نەرسەگە تەڭەلگىس ، تەڭەلگىس.

[C1]
.             Bm
   // تەڭىرىم قولدو مەكەنىمدى
.              A
   تەڭىرىم قورگو مەنىن جەرىمدى،
.              Em
   بەرەكەندى بئزگە مول بەرىپ،
.             G              F#
   قوردۇقتان ساقتا مەنىن ەلىمدى. //

[V2]
 نارىن سۇۇسۇ باقىت۔تاالاي اققانداي
 تالاس جەرگە تەنىر بارقىن چاچقانداي
 وشتۇن تووسۇ جەر جۉزۉنۅ كۅرك بەردى،
 بىشكەك شاارىم ۔تااجى اسىل ۔تاشىنداي، تااجىداي.

[V3]
 قايدا جۉرسۅم سەنى ۇنۇتالبايمىن،
 بەيىش جەرىم ۇرماتتايمىن، ساقتايمىن،
 قىلىمدارعا سەنى داڭقتاپ، ىردايمىن،
 مەنىن ەلىم، سەن ۉچۉن سىيىنامىن، سىيىنامىن.

[B1]
.     Bm        A             Em
   تەڭئر، ساقتا ەلىمدى مەنىن جەرىمدى!
.      G            F#
   ارۇۇلا بئزدى، تەڭئر!
.    Bm            A             Em
   تەڭىر، ۇنۇتپا بئزدى قىرعىز جەرىمدى!
.     G            F#
   كۅتۅر بئزدى، تەڭئر!</lyrics>
<key>D</key>
<title>قىرعىز جەرىم</title>
</song>