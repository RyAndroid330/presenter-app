<?xml version="1.0" encoding="UTF-8"?><song><author>بۇرۇل شامىرقانوۆا, نۇرگۉل اسانباەۆا</author>
<hymn_number>126</hymn_number>
<lyrics>[V1]
.     C          F         G
 جاراتقان تەڭىرىم گۉلدۅگۅن جەرىمدى
.    F           G
 جامالى جايدارى مەيماندوس ەلىمدى
.   C             F
 جاشووعو كۉچ بەرىپ ار كۉندۉ جالعاعان
.   Dm            F        G
 جالپىبىز داڭقتايلى اسماندا تەڭىردى.

[C1]
.     C    G         F
   // قۇبانىپ تەڭىرگە، ىردايلى بئز بىرگە
.      Dm           G           (C)
   تىنچتىق ىرىس تىلەپ، ەلىمە، جەرىمە. //

[V2]
.    C          F        G
 باتاسى قۇدايدىن تۅگۉلگۅن ار ۉيگۅ
.    F          G
 ىنتىماق، سۉيۉۉدۅ قۇرالىپ ۉي۔بۉلۅ
.   C            F
 بئرىمدىك قالقىما، باقۇبات تۇرمۇشتۇ
.  Dm           F       G
 سىيىنىپ تەڭىردەن سۇرايلى كۉنۉگۅ.</lyrics>
<key>C</key>
<aka>داڭقتايلى تەڭىردى!</aka>
<title>جاراتقان تەڭىرىم گۉلدۅگۅن جەرىمدى ATT126</title>
</song>