<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>56</hymn_number>
<key>Em</key>
<lyrics>[V1]
.       Em
 ۅزۉڭ داڭقتاپ رۇحۇم تىنبايت،
.        D         Em
 جانىم سەنى ماقتاپ ىردايت.
.       Em
 كۉنۅۅكۅردۉ سۉيگۅن تەڭىر،
.      D           H
 ىرايىمىڭ قانداي قىمبات.

[C1]
.          Em
   // اجالدى جەڭۉۉچۉ،
.           C
   ەركىندىك بەرۉۉچۉ،
.            D
   قايرىمدۇۇ تەڭىر سەن،
.          H    (Em)
   چاقىرسا كەلۉۉچۉ. //

[V2]
 جاماندىقتان بئزدى ساقتاپ،
 كۉنۅۅلۅردۅن الدىڭ اقتاپ.
 ۉمۉت قىلعان قۇدايىم سەن،
 ىيسا تەڭىر، ساعا ىراحمات!</lyrics>
<title>ۅزۉڭ داڭقتاپ رۇحۇم تىنبايت РЫЖ56</title>
</song>