<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>29</hymn_number>
<lyrics>[V1]
.D         Bm        Em             D  A
 // القىش ساعا، القىش ساعا، القىش ساعا، پادىشا. //
.D          Bm     G           A
 // اتاق۔داڭققا بۅلۅنۉپ، قۇبات  مەنەن قۇرچالعان. //
.    D          G     Em      A
 // بئيلىگىڭ ۔ كۉچ۔قۇبات، ىرايىمىڭ ۔ اقىيقات. //
. D       G     A      D
 ساعا القىش جەردە جانا اسماندا.
.   G    A  Bm   G    A   D
 // سەن ۔ پادىشا، سەن ۔ پادىشا. //</lyrics>
<key>D</key>
<title>القىش ساعا پادىشا ATT29</title>
</song>