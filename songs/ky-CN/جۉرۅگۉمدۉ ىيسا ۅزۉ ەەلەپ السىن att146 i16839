<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>146</hymn_number>
<title>جۉرۅگۉمدۉ ىيسا ۅزۉ ەەلەپ السىن ATT146</title>
<lyrics>[V1]
. Bb
 جۉرۅگۉمدۉ ىيسا ۅزۉ ەەلەپ السىن
.Bb     Eb     F      Bb
 ويۇمدا سەزىمىمدە ال جاشاسىن
.Bb    Eb            F    Bb
 // انتكەنى قانچا ىزدەنىپ جۉرسۅم دا
. Eb    Bb
 تەڭىرىمدەي جۅلۅك تاياق تابالبادىم. //

[V2]
. Bb
 جارىق نۇرۇن ىيسا ۅزۉ الىپ كەلدى
. Bb      Eb        F    Bb
 كارا تۉندۉ سۅزۉ مەنەن جوك قىلىپ
.   Bb   Eb         F      Bb
 // كۉنۅۅلۅردۅن تازالادى ابئيىرىمدى
. Eb    Bb
 جانىن بەرىپ ىيىق قانىن اعازىپ. //

[V3]
. Bb
 مەن قىينالىپ تىنچتىق تاپپاي تۇرعان كەزدە
.Bb       Eb        F   Bb
 ۇققان ەلەم قۇبانىچتۇۇ كاباردى
.   Bb  Eb           F      Bb
 // سۉيۉنچۉنۉ قابىل الدىم شەكتەنبەستەن
. Eb    Bb
 تەڭىر مەنەن ۇلاي بەرەم ساپاردى. //</lyrics>
<key>Bb</key>
<aka>تەڭىر مەنەن ۇلاي بەرەم ساپاردى</aka>
</song>