<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>84</hymn_number>
<key>Bm</key>
<lyrics>[V1]
.Bm
 كۅكتۅگۉ اتا، تەڭىرسىڭ داڭقتۇۇ،
. G     D            A     D
 سەن سووروتۇۇچۇ، چىندىق رۇحۇ،
. Bm
 سەن قۇدۇرەتتۉۉ، ەڭ ۇلۇۇ قۇداي،
. G     D     A       D
 بئزدى ىيىقتا كۅزۉڭ الباي.

[V2]
 كۅكتۅگۉ اتا، باقىت بۇلاعى،
 ۇنۇتپا ساعا تايانعاندى.
 جاردى جۉرۅكتۅن سەن ورۇن الچى،
 بۅلۅپ باقىتقا، بەر باتاڭدى.

[V3]
 كۅكتۅگۉ اتا، كۉنۅۅدۅن ساقتا،
 ىيىق جاشايلى كۅز الدىڭدا.
 ىشئبىز مەنەن، ىرىبىز مەنەن
 سەنى داڭقتايلى ار ۇباقتا.</lyrics>
<title>كۅكتۅگۉ اتا، تەڭىرسىڭ داڭقتۇۇ РЫЖ315</title>
</song>