<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>185</hymn_number>
<key>D</key>
<lyrics>[V1]
.    D          F#m        G   A D
 كەلگىن، ىيىق رۇح كەلگىن، تولتۇرگۇن مەنى.
.      G         A      F#m      D
 مۇقتاجمىن مەن سۉيۉۉڭۅ سەنىن، ىرايىمىندى بەرگىن.
.     G          A         D
 // كەلگىن، تولتۇرعۇن ىيىق رۇح، كەلگىن. //

[C1]
.     Bm   F#m    G     D  G    D     A
   ماقتايم سەنى، ماقتايم سەنى، جاراتقان قۇدايىم.
.    Bm   F#m   G    D G     A    D
   كۉتۅم سەنى، كۉتۅم سەنى، ىيىق رۇح كەلگىن.
.     D            F#m        G  A  D
   كەلگىن، ىيىق رۇح، كەلگىن، كۉچ۔قۇبات بەرگىن.
.       G         A       F#m       D
   مەەرئمىڭ مەنەن بىزدى قاپتاپ، ىرايىم مەنەن ساقتاپ،
.      G           A        D
   // كەلگىن، ىيىق رۇح، كۉتۅبۉز، كەلگىن. //</lyrics>
<title>كەلگىن، ىيىق رۇح كەلگىن ATT185</title>
</song>