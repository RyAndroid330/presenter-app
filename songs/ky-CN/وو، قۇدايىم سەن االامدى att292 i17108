<?xml version="1.0" encoding="UTF-8"?><song><title>وو، قۇدايىم سەن االامدى ATT292</title>
<lyrics>[V1]
.    D    Em A7          D    Bm
 // وو، قۇدايىم، سەن االامدى جاراتتىڭ.
.       Em       A7      D
 سەن باردىق بۇلۇتتاردان جوعورۇسۇڭ. //
.      D          A         G           D
 // ساعا سىيىنام، ساعا سىيىنام، ساعا سىيىنام، قۇدايىم. //

[V2]
.D      Em  A7        D     Bm
 // وو، قۇدايىم، سەن االامدى جاراتتىڭ.
.       Em       A7      D
 سەن باردىق بۇلۇتتاردان جوعورۇسۇڭ. //
.      D          A          G           D
 // ساعا تابىنام،  ساعا تابىنام، ساعا تابىنام، قۇدايىم. //

[V3]
.D     Em  A7       D    Bm
 // وو قۇدايىم، بەكەم سەنىن ۇباداڭ،
.        Em        A7      D
 بەرگەن سۅزۉڭ ار ۇباقتا اتكارىلات. //
.      D          A          G           D
 // ساعا قايرىلام، ساعا قايرىلام، ساعا قايرىلام، قۇدايىم. //

[V4]
.D     Em  A7        D      Bm
 // وو قۇدايىم، سەندە چىندىق، اقىيقات
.      Em        A7          D
 ساعا ئشەنگەن ار بئر ادام قۇتقارىلات. //
.     D         A         G          D
 // ساعا ىشەنەم، ساعا ىشەنەم، ساعا ىشەنەم، قۇدايىم. //</lyrics>
<key>D</key>
