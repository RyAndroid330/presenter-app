<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Cm                  G  Cm
 ۇشۇل تويعو بەرسىن قۇداي باتاسىن،
. Bb               Eb
 چاقىرالى بۇل االامدىن اتاسىن.
. Cm                G  Cm
 كۇبانىپ دا، سۉيۉنۉپ دا توسولۇ،
.Bb              Eb
 ارابىزدا قايعى۔كاپا بولبوسۇن.
.   Fm         Bb      Eb
 // باقتىلۇۇ بولسۇن ۇۇل۔قىزى دەپ،
. Cm     Fm   G       Cm
 سىيىنالى بئزدىن ىيسا تەڭىرگە. //

[V2]
 قۇدايىمدىن ەركى مەنەن جۉرۉۉگۅ،
 تۉبۅلۉككۅ بىرگە ۅمۉر سۉرۉۉگۅ
 جاقىن بولۇپ، جاردام بەرسىن تەڭىرىم،
 جارىق قىلىپ اراسىندا ەلىمدىن.
 // باقتىلۇۇ بولسۇن ۇۇل۔قىزى دەپ،
 سۇرانالى بۉگۉن قۇدايدان بىرگە. //

[V3]
 تويۇڭارعا توي ۇلانسىن الدىدا،
 ورتوڭوردو بولسۇن سۉيۉۉ دايىما.
 كەلەچەكتە ەركى بولۇپ تەڭىردىن،
 ۇچۇپ چىقسىن قولۇڭاردان نارىستە.
 // ىيماندۇۇ بولسۇن ۇۇل۔قىزى دەپ،
 سىيىنالى بئزدىن ىيسا تەڭىرگە. //

[V4]
 ىشەنىمدۉۉ بئر۔بىرىڭە بولۇۇعا
 اقىل بەرسىن ۉي۔بۉلۅلۉك تۇرمۇشتا.
 زور سۉيۉۉڭدۉ باالاپ سەنىن، تەڭىرىم،
 جۉرسۉن الار ۅزۉڭدۉن اق جولۇڭدا.
 // ىيماندۇۇ بولۇپ بئزدىن ەكى جاش،
 ىنتىماقتۇۇ ۅمۉر سۉرسۉن دايىما. //</lyrics>
<key>Cm</key>
<title>ۇشۇل تويعو قۇداي بەرسىن باتاسىن ATT407</title>
<hymn_number>407</hymn_number>
</song>