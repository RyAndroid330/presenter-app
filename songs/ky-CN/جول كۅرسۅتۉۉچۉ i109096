<?xml version="1.0" encoding="UTF-8"?><song><author>سِنَكه</author>
<title>جول كۅرسۅتۉۉچۉ</title>
<key>C</key>
<lyrics>[V1]
.       C           G
 سەن مىندا، ارابىزداسىڭ،
.      Dsus       Em
 تابىنابىز، تابىنابىز.
.       C              G
 سەن مىندا، بىزگە جاقىنسىڭ،
.      Dsus       Em
 تابىنابىز، تابىنابىز.

[C1]
.  C
   جول كۅرسۅتۉۉچۉ،
   كەرەمەت ەەسى.
.  G
   سۅزۉنۅ تۇرعان،
.              Dsus
   قاراڭعىدا جارىق ۔ ەگەم،
.             Em
   مەنىن قۇدايىم

[V2]
.       C            G
 سەن مىندا، دىلىبىزدەسىڭ،
.      Dsus       Em
 تابىنابىز، تابىنابىز.
.       C          G
 سەن بئزدى ايىقتىراسىڭ،
.      Dsus       Em
 تابىنابىز، تابىنابىز.

[B1]
.  C
    كۅربۅسۅم دا ۔ سەن ىشتەپ جاتاسىڭ،
.  G
    سەزبەسەم دا ۔ سەن ىشتەپ جاتاسىڭ،
.  Dsus
    سەن ار دايىم مەنىن جانىمداسىن.
.  Em
    سەن ار دايىم مەنىن جانىمداسىن.</lyrics>
</song>