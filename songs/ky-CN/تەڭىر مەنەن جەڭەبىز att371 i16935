<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D          Bm
 // تەڭىر مەنەن جەڭەبىز،
. G           A
 جەڭىش بىزگە كەلدى قۇدايدان.
.        D          Bm
 دۇشماندىن كۉچتۅرۉن تەپسەلەيبىز،
.  G      A     D
 ىيسا تەڭئردىن اتىنان. //

[C1]
.     D       G
   // دۇشماندارىڭ قاچىپ كەتەت،
.   A               D
   ساعا ەچ كىم قارشىلىق قىلا البايت.
.   D              G
   شايتان بۇت الدىندا تەپسەلەت،
.    A           D
   ىيسا تەڭىردىن اتىنان. //

[V2]
.   D          Bm
 // جەڭىش ىرىن ىردايبىز،
. G        A
 كۇدايىبىزدى داڭازالاپ،
.      D          Bm
 ەلگە ەركىندىك جارىيالايبىز،
.  G      A     D
 ىيسا تەڭئردىن اتىنان. //</lyrics>
<title>تەڭىر مەنەن جەڭەبىز ATT371</title>
<hymn_number>371</hymn_number>
</song>