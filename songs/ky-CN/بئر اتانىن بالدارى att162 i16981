<?xml version="1.0" encoding="UTF-8"?><song><title>بئر اتانىن بالدارى ATT162</title>
<aka>ىشەنىمدىن اتاسى</aka>
<key>Bm</key>
<lyrics>[V1]
.Bm     Em     F#       Bm
 ىشەنىمدىن اتاسى، قۇدايىبىزدىن دوسۇ
.G       A        D B
 ىبرايىمدىن ۇرپاقتارىبىز
.Em       Bm        F#  Bm
 اسمانداعى جىلدىزدارداي جانابىز.

[C1]
.   B7      Em      A        D
   بئر اتانىن بالدارى، ىبرايىم ۇرپاقتارى
.   Em     Bm         B     B7
   كۇدايىبىزدى بئز چوعۇۇ داڭكتايبىز.
.   B7      Em      A        D
   بئر اتانىن بالدارى، ىبرايىم تۇقۇمدارى
.  Em      Bm       F#  Bm
   اتابىزدىن اتىن داڭازالايبىز.

[V2]
.Bm      Em     F#       Bm
 اتابىزدىن باتاسى، قۇدايدىن ۇباداسى
.G        A        D B
 ىبرايىمدىن تۇقۇمدارىبىز
. Em       Bm        F# Bm
 دەڭىز قۇمۇنداي بولۇپ كۅبۅيۅبۉز.

[V3]
. B   Em    A     D
 نا۔نا۔نا۔نا، نا۔نا۔نا۔نا
.Em       Bm        F#   Bm
 اسمانداعى جىلدىزدارداي جانابىز
. B   Em    A     D
 نا۔نا۔نا۔نا، نا۔نا۔نا۔نا
.Em      Bm         F#  Bm
 اتابىزدىن سۉيۉكتۉۉ بالدارىبىز.</lyrics>
<author>مئرلان ساعىنباەۆ</author>
<hymn_number>162</hymn_number>
</song>