<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>154</hymn_number>
<author>راحئل ىسىەۆا</author>
<lyrics>[V1]
.   C     Am       Dm          G
 // جۉرۅكتۅگۉ ويلورۇمدۇ، سوتتوي تۇرعان تىرۉۉ سۅزۉڭ.
. C       Am       Dm         G
 نئەتىمدى، جولدورۇمدۇ، كۅرۉپ تۇرعان ىيسا ۅزۉڭ. //

[V2]
.C            Am     Dm       G
 // القىش ساعا، قۇداي، اتا. القىش ساعا! //

[V3]
.   C     Am            Dm         G
 // جاشىرىلعان ەچ بئر جان جوق، تەڭئر، سەنىن بەت الدىڭدا.
.C      Am           Dm         G
 ىشئبىزگە، سۅزۉبۉزگۅ دا، جووپ بەرەبىز باردىعىنا. //</lyrics>
<key>C</key>
<title>جۉرۅكتۅگۉ ويلورۇمدۇ ATT154</title>
</song>