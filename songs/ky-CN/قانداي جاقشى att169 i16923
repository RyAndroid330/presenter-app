<?xml version="1.0" encoding="UTF-8"?><song><title>قانداي جاقشى ATT169</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm            Gm    A             Dm
 // قانداي جاقشى، قانداي سونۇن بئر تۇۇعاندار مەنەن بولعون //
. Dm   Gm    A               Dm
 كانداي جاقشى، قانداي جاقشى، قانداي سونۇن ۔
. Dm    Gm    A                Dm
 بئر تۇۇعاندار، بئر تۇۇعاندار مەنەن بولعون!

[V2]
.    Dm            Gm   A               Dm
 // ارۇندۇن ساقالىنداعى، قىمبات زايتۇن مايىنداي //
.Dm  Gm A             Dm
 ارۇندۇن، ارۇندۇن ساقالىنداعى
. Dm  Gm      A               Dm
 كىمبات زايتۇن، قىمبات زايتۇن مايىنداي.

[V3]
.    Dm             Gm     A              Dm
 // ەرموندۇن تووسۇنا تۉشكۅن، سەرگىتكەن شۉۉدۉرۉمدۅي //
.Dm   Gm   A             Dm
 ەرمون تووسۇ، ەرموندۇن تووسۇنا تۉشكۅن،
. Dm  Gm   A              Dm
 سەرگىتكەن، سەرگىتكەن شۉۉدۉرۉمدۅي.</lyrics>
<hymn_number>169</hymn_number>
</song>