<?xml version="1.0" encoding="UTF-8"?><song><title>كەلەمىن ساعا РЫЖ21</title>
<lyrics>[V1]
.    Am
 كەلەمىن ساعا،
.     Am
 داڭقتاپ سەنى.
.        F
 ىرايىمىڭ چەكسىز سەنىن،
.       G
 كۅرسۅتتۉڭ سۉيۉۉ كەنىن.

[C1]
.       C
   وو، سەن ۇلۇۇ!
.                Am
   سەن كەرەمەت، سەن ۇلۇۇ!
.                    F
   ساعا تەڭدەش ەچ كىم جوق!
.          G
   سەن كەرەمەت، سەن ۇلۇۇ!

[V2]
 ىر ىردايم ساعا،
 مەن قۇبانىپ.
 داڭازالايم ىسىمىڭدى،
 سۉيۉۉڭۅ مەن تاڭدانىپ.</lyrics>
<key>Am</key>
<author>ِڤَ-لِنَ هِللمَرك</author>
<hymn_number>21</hymn_number>
</song>