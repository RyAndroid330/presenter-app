<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 جۉرۅگۉمۅ سەنى چاقىرام
 جالعىز ساعا سىيىنام
 ۅمۉر سۇۇسۇن سەن بەردىڭ
 سەن سۉيۉۉ تەڭىر
 سەن سۉيۉۉ تەڭىر قۇدايىم

[C1]
   تابىنام
   تابىنام

[B1]
   ۅمۉر سۇۇسۇن ماعا تەڭىر
   سەن بەردىن، كەرەكسىڭ
   بولچۇ جانىمدا
   مەنى ىزدەپ جان دۉينۅمۅ
   سەن كەلدىڭ
   بەلەكسىڭ، سەن تەڭىر ماعا
   سەن چىندىق
   سەن تىنچتىق
   سەن ۅمۉرسۉڭ

[B2]
   ۅمۉر سۇۇ دايراسى
   بولدۇڭ سەن ىيسا ماعا
   جۉرۅكتۉن اچقىچى
   ەەسى سەن بولدۇڭ ىيسا</lyrics>
<title>تابىنام</title>
<author>بەقا نئيازوۆ</author>
</song>