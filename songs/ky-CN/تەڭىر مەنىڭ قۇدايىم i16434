<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 تەڭىر مەنىن قۇدايىم،
 باشپاانا قىلعان جايىم
 ىيسا تىرۉۉ قۇدايىم
 قۇتقاردى سەنىن قانىڭ
 ىيسا مەنىن تەڭىرىم
 اراچى بولۇپ كەلدىڭ
 داڭقتاپ سەنى ىردايمىن
 قۇرماندىعىڭدى الدىم

[C1]
   /// ىيسا تەڭىرىم ///
   اللىلۇييا

[V2]
 ىيسا تەڭىر ۔ قۇدايىم
 بەردىڭ بىزگە ىرايىم
 جاقىن بولۇپ سۅزۉڭۅ
 ىشەندىك بئز ۅزۉڭۅ
 چىندىعىڭدى ساقتايبىز
 تەڭىر سەنى ماقتايبىز
 ۅمۉر بويۇ القىشتاپ
 جالعىز ساعا ىردايبىز</lyrics>
<title>تەڭىر مەنىڭ قۇدايىم</title>
</song>