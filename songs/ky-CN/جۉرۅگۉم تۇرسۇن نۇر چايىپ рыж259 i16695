<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>259</hymn_number>
<lyrics>[V1]
.H                    F#
 جۉرۅگۉم تۇرسۇن نۇر چايىپ
.                  H
 ىيىعىم تەڭىر الدىندا،
. E                  F#
 كۉنۅۅنۉن بولبوي تۇتكۇنۇ،
.                  H
 جارىعى جانسىن دايىما.
. E
 ىيىعىم تەڭىر الدىندا
.                F#  H
 جارقىراپ جانسىن دايىما.

[V2]
 تەڭىرىم ىيسا الدىندا
 بار دىتىم بۇرۇپ تۇرايىن،
 اقىلدىن كەنچى قاتىلعان
 اسىل بئر سۅزۉن ۇعايىن.

[V3]
 جاراتقان ەگەم الدىندا
 جاشايىن ىيسا سىياقتۇۇ.
 ۅچۉربۅي ساقتاپ قالايىن
 تەڭىرىم بەرگەن چىراقتى.

[V4]
 تەڭىرىم ىيسا الدىندا
 داڭقتووعو تولسۇن جۉرۅگۉم.
 سۉيۉۉسۉن ايتىپ تەڭىردىن،
 ۅمۉرۉن ەلدىن تىلەيىن.</lyrics>
<key>B</key>
<title>جۉرۅگۉم تۇرسۇن نۇر چايىپ РЫЖ259</title>
</song>