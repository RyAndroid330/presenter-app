<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>224</hymn_number>
<author>سانجاربەك جاكەنوۆ</author>
<key>Bbm</key>
<lyrics>[V1]
. Bm             G
 كۇدايدىن بايلىقتارى ەبەگەيسىز،
.Em                F#
 اقىلماندىق بىلگىچتئگى نە بئر چەكسىز،
. Bm
 چىعارعان بۉتۉمدۅرۉ اڭداپ بۉتكۉس
. Em           F#
 كۇدايدىن ويلورۇنا اقىل جەتكىس.

[C1]
.  Bm               G
   انتكەنى بۉت باردىعى بئر قۇدايدان،
.  Em               F#
   ال ارقىلۇۇ، ال ۉچۉن جاراتىلعان.
.  Bm                 G
   ال بىرىنچى، ال اقىرقى، تەڭىرىبىز.
.   Em               F#
   داڭقتالسىن تۉبۅلۉككۅ قۇدايىبىز.
.  Bm             G
   قۇدايدىن اقىل۔ويۇن باربى بىلگەن؟
.   Em          F#
   كىمئسى ەگەبئزگە كەڭەش بەرگەن؟
.   Bm
   بئرۅۅڭۅر قارىز بەرىپ قۇدايىنا،
.  Em              F#
   ەگەبىزدىن بەرەسەسى باربى كىمگە؟</lyrics>
<title>قۇدايدىن بايلىقتارى ەبەگەيسىز ATT224</title>
</song>