<?xml version="1.0" encoding="UTF-8"?><song><author>دَِنَ بَلل</author>
<hymn_number>250</hymn_number>
<title>ماالىندا، ماالىندا ATT250 РЫЖ233</title>
<lyrics>[V1]
. C    G       C
 ماالىندا، ماالىندا،
.     Dm        G     C
 قۇداي بەرەت باردىعىن ساعا دا، (ماعا دا)
.      F        G        Em      Am
 // قايعىرعاندى سووروتۇپ، كەمچئلئگىڭ تولتۇرۇپ،
.     Dm        G       C
 قۇداي بەرەت باردىعىن ماالىندا. //

[V2]
. C    G       C
 ماالىندا، ماالىندا،
.     Dm       G      C
 قۇتقارىپ الدى تەڭىر مەنى دا، (سەنى دا)
.     F         G       Em        Am
 // تۉيشۉگۉمدۉ الپكەتىپ، جانىما تىنچتىق بەرىپ،
.      Dm           G     C
 بۉت كۉنۅۅمدۉ جۇۇپ كەتتى كانىنا. //

[V3]
. C    G       C
 ماالىندا، ماالىندا،
.     Dm         G         C
 باارى بولوت، مەن بىلەم، ماالىندا.
.      F        G        Em         Am
 // بەك ىشەنىم بەر ماعا. بەل بايلايم جالعىز ساعا.
.     Dm      G       C
 بۉت ۅمۉرۉم ۅزۉڭدۉن قولۇڭدا. //

[V4]
. C    G       C
 ماالىندا، ماالىندا،
.     Dm       G       C
 جاي تابامىن تەڭىردىن جانىندا.
.       F       G       Em    Am
 // بۇل دۉينۅدۅن بۅلۉنۉپ، جارىعىڭا بۅلۅنۉپ،
.    Dm        G       C
 تۉبۅلۉك جاشايم سەنىن الدىڭدا. //</lyrics>
<key>C</key>
</song>