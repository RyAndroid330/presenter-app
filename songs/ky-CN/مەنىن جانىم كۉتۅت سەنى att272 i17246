<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>272</hymn_number>
<key>Em</key>
<lyrics>[V1]
.   Em   Am        Em
 // مەنىن جانىم كۉتۅت سەنى،
.      C   D         Em
 سەن عانا تەڭىر مەنىن ۉمۉتۉم. //
.   Em  D      Em         C D G
 //  سەن مەنىن  قورعووچۇم ەچ كىمگە جەڭىلبەگەن.
. Em   D     Em         C   D  Em
 سەن مەنىن قورعووچۇم ەچ كىمگە جەڭىلبەگەن. //

[V2]
.   Em   Am         Em
 // سەنىن سۅزۉڭ جانگا داارى،
.      C   D         Em
 سەن عانا تەڭىر ايىقتىرۇۇچۇم. //
.   Em  D     Em        C  D G
 // سەن مەنىن ساقتووچۇم جانىما تىنچتىق بەرگەن.
. Em   D     Em        C    D    Em
 سەن مەنىن ساكتووچۇم جانىما تىنچتىق بەرگەن. //

[V3]
.    Em   Am        Em
 // سەنسىڭ مەنىن كۉچ قۇباتىم،
.      C   D          Em
 سەن عانا تەڭىر مەنىن تىرەگىم. //
.   Em  D    Em      C  D G
 // سەن مەنىن قۇدايىم تۉبۅلۉك ۅمۉر بەرگەن.
. Em   D    Em      C   D     Em
 سەن مەنىن كۇدايىم تۉبۅلۉك ۅمۉر بەرگەن. //</lyrics>
<title>مەنىن جانىم كۉتۅت سەنى ATT272</title>
</song>