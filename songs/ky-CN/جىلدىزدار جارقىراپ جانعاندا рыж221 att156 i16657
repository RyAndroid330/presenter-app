<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.     Cm      G       Cm
 جىلدىزدار جارقىراپ جانعاندا،
.      C7             Fm
 اي قالقىيت جىلدىزدۇۇ اسماندا.
.    Fm              Cm
 // تەڭىرىم سەن مەنى قۇتقاردىڭ، قۇتقاردىڭ
.     Fm   G     Cm
 جۉرۅكتۉ ۅزۉڭۅ اچقاندا. //

[V2]
.    Cm       G      Cm
 ۅمۉردۉن تابا الباي باعىتىن،
.    C7              Fm
 جولۇمدۇن بىلە الباي باعىتىن.
.     Fm             Cm
 // تۇمچۇعۇپ تۇڭعۇيۇق تۉبۉنۅ قالعاندا،
.    Fm     G       Cm
 تەڭئرىم سەن مەنى قۇتقاردىڭ. //

[V3]
.      Cm      G     Cm
 چىعا الباي كۉنۅۅنۉن تورۇنان،
.   C7             Fm
 اداشىپ جۉرگۅندۅ جولۇمدان.
.      Fm             Cm
 // جۉرۅكتۉ قايرادان جالعىزدىق باسقاندا،
.      Fm     G      Cm
 قۇتقاردىڭ جەتەلەپ قولۇمدان. //

[V4]
.    Cm      G    Cm
 ۅمۉردۉن قايگىسىن، ازابىن،
.    C7            Fm
 ۇنۇتتۇم كۉنۅۅنۉن مازاعىن.
.      Fm           Cm
 // قىينالعان جۉرۅككۅ قۇبانىچ تولتۇرۇپ،
.    Fm      G       Cm
 تەڭئرىم، كۉنۅۅدۅن قۇتقاردىڭ. //</lyrics>
<key>Cm</key>
<title>جىلدىزدار جارقىراپ جانعاندا РЫЖ221 ATT156</title>
<hymn_number>221</hymn_number>
<author>شыنتېمіروۋ ئەبіلخايыر</author>
</song>