<?xml version="1.0" encoding="UTF-8"?><song><title>قىمباتسىڭ سەن</title>
<lyrics>[V1]
.   Em           D
 // قىمباتسىڭ سەن ماعا ار دايىم،
.          B      Em     D     Em
 قىمباتسىڭ سەن، ار قاچان كۉتۅم سەنى.
.Em        D
 ىيسا، جۉرۅگۉم سەنى ەڭسەيت،
.    B    Em     D    Em
 سەن مەنەن بولوم تۉبۅلۉككۅ! //

[V2]
.            Em      Am
 // مەن ساعا ۅمۉرۉمدۉ ارنايم،
.    D    G
 ىيسا، سەن مەنى قولدونچۇ.
.        Em   D
 ار كۉندۅ سۅزۉڭۅ ۇمتۇلام،
.      B    Em    D   Em
 تەڭىرئم، ساعا ىشەنەمئن. //</lyrics>
<key>Em</key>
<author>ماييا راخىمگالىېۋا</author>
</song>