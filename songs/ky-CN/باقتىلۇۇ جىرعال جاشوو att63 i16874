<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>63</hymn_number>
<key>Em</key>
<lyrics>[V1]
.   Em        Am      B7              Em C
 // باقتىلۇۇ،  جىرعال جاشوو، جالعىز سەندەن كەلەرىن،
.          D       Em
 بىلبەدىم، تەڭىرىم، ىزدەدىم.
.         Am      B7            Em  C
 چىعۇۇ جولۇن كۅرسۅتتۉڭ، ۅمۉرۉمدۉ ۅزگۅرتتۉڭ،
.        B7       Em
 تايانىچىم، ىيىق كۇدايىم. //
.       G                D
 // ەگەدەرىم (ەگەدەرىم)، ەگەدەرىم!
.Am          B7      Em
 قۇدايدىن قۇرماندىق كوزۇسۇ!
.      G       D
 ەگەدەرىم، ەگەدەرىم،
.Am          B7      Em
 سورووتۇۇچۇم جالعىز ۅزۉڭسۉڭ. //</lyrics>
<title>باقتىلۇۇ جىرعال جاشوو ATT63</title>
</song>