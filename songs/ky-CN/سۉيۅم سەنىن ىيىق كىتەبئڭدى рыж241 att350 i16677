<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.Cm            G7  Cm
 سۉيۅم سەنىن ىيىق كئتەبئڭدى،
.Cm           G7   Cm
 ۇقمۇش سۅزدۅرۉڭدۉ وقۇۇنۇ.
.Cm       Fm       Cm
 // ماعا ايتقان قابارلارىڭدى
. Cm          G7 Cm
 سۉيۅمۉن قۇبانىپ ۇعۇۇنۇ. //

[V2]
 سۉيۅم ايقاش جىعاچىمدى الىپ،
 ارتىڭدان العا بارۇۇنۇ.
 // السىراعاندا جان قىينالىپ،
 سەندەن عانا تىنچتىق تابۇۇنۇ. //

[V3]
 سۉيۉپ تانداپ الدىڭ ۅزۉڭ مەنى،
 ادام بولۇپ جەرگە كەلگەنسىڭ.
 // سۉيۅمۉن دايىم مەن دا سەنى،
 مەن ۉچۉن ازاپ چەككەنسىڭ. //

[V4]
 قانتئپ تۇرام سۉيبۅي، سۉيۅم سەنى،
 ەڭ ۇلۇۇ سۉيۉۉنۉن اتاسىن.
 // سۉيۉۉ تارتۇۇلاپ، وو، قۇدايىم،
 ماعا دا بەرسىن باتاسىن. //</lyrics>
<title>سۉيۅم سەنىن ىيىق كىتەبئڭدى РЫЖ241 ATT350</title>
<hymn_number>241</hymn_number>
</song>