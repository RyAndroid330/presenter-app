<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>197</hymn_number>
<author>دۅۅلۅت ساعىنقۇلوۆ</author>
<key>C</key>
<lyrics>[V1]
. C                    Dm
 سۇروو ساعا: قايدان كەلدىڭ سەن؟
.G                    C
 ۇقچۇ، تۇۇعان، قايدا باراسىڭ؟
.C                   Dm
 ويلوندۇڭبۇ «نەگە جاشايم» دەپ،
. G                 C
 بۇعا جووپتۇ قايدان تاباسىڭ؟

[C1]
.  F         G        Em Am
   اسماندى دا، جەردى جاراتقان،
.   Dm     G         C  C7
   كۇدايىبىز تەڭىر بار ەكەن.
.  F        G        Em Am
   ادامداردى جەرگە تاراتقان،
.   Dm        G        C
   سۉيۉۉ بەرىپ، «اق جاشا» دەگەن.

[V2]
. C                  Dm
 شايتان دەگەن جالعانچى بولعون،
.G              C
 ازعىرىپتىر وبو ەنەنى.
.C                Dm
 اداشتىرعان ادامدى جولدون،
. G                  C
 بۇل چىندىقتى بئلىپ جۉر ەمى.

[V3]
.C                Dm
 ۇقپاي سۅزۉن قۇداي اتانىن،
. G                  C
 كۉنۅۅگۅ بئز باتىپ كەتكەنبىز.
. C               Dm
 كىينالابىز تارتىپ ازابىن،
. G                   C
 بئز توزوقتۇ قاراي كەتمەكپئز.

[V4]
.C                  Dm
 ۇلۇۇ قۇداي بئزدى سۉيگۅندۅن،
. G                  C
 جالعىز ۇۇلۇن جەرگە جئبەرگەن.
. C              Dm
 كۉنۅۅبۉزدۉ موينۇنا الىپ،
. G                  C
 جازالانعان، قايرا تئرىلگەن.

[V5]
. C                   Dm
 كۇداي ايتات: «ۇشۇل قۇرماندىق،
.G                     C
 ارىلتات» دەپ، «سەنى كۉنۅۅدۅن».
.C              Dm
 ىشەنىمىڭ سەنى كۇتقارات،
. G                 C
 كۉنۅۅڭ ۉچۉن ىيسا ۅزۉ ۅلگۅن.</lyrics>
<title>سۇروو ساعا: قايدان كەلدىڭ سەن؟ РЫЖ197 ATT345</title>
</song>