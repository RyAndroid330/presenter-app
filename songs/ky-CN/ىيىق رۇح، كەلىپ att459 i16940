<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>459</hymn_number>
<author>اپئزاحان قونقايتئەۆا</author>
<lyrics>[V1]
.Bbm           Ebm              Bbm
 ىيىق رۇح، كەلئپ، جارقىراپ، تولچۇ جۉرۅككۅ
.Bbm          Ebm             Bbm
 ىشەنىپ، ۇمتۇلالى الدىدا ماقسات۔تىلەككە.
.Ebm                    Bbm       Ebm
 // تولۇقشۇپ تولسۇن، تۅگۉلۉپ، تاشىپ دەڭىزدەي،
.Bbm         Ebm             Bbm
 قۇدايىم بەرگەن باتالار بئزدىن ۅمۉرگۅ. //

[V2]
.Bbm         Ebm           Bbm
 سەن بەردىڭ اتا، اشىعى مەنەن ۅمۉردۉ،
.Bbm           Ebm            Bbm
 كۉنۅۅدۅن، دارتتان ايىققان اچىك كۅڭۉلدۉ.
.   Ebm                Bbm       Ebm
 // قۇتقارىپ ۅزۉڭ، تۇتكۇندان الدىڭ بوشوتۇپ،
. Bbm           Ebm              Bbm
 داڭقتايمىن، ىرداپ، كەرەمەت قۇداي، تەڭىردى. //

[V3]
.Bbm       Ebm             Bbm
 اتابىز كۉتۅت، اسمانعا قولدۇ سۇنالى.
.Bbm         Ebm          Bbm
 تاڭدا دا كەچتە سىيىنىپ اعا تۇرالى.
.Ebm                  Bbm    Ebm
 // جاقىنداپ كەلدى، بۅلۅنۉپ نۇرعا، تەڭىرىم.
.Bbm            Ebm            Bbm
 چارچاباي، تولقۇپ، قۇدايدىن سۅزۉن ۇعالى. //

[V4]
.Bbm          Ebm           Bbm
 سەن بەردىڭ، اتا، اشىعى مەنەن ۅمۉردۉ،
.Bbm           Ebm            Bbm
 كۉنۅۅدۅن، دارتتان ايىققان اچىك كۅڭۉلدۉ.
.   Ebm               Bbm        Ebm
 // قۇتقارىپ ۅزۉڭ، تۇتقۇندان الدىڭ بوشوتۇپ،
. Bbm           Ebm              Bbm
 داڭقتايمىن، ىرداپ، كەرەمەت قۇداي، تەڭىردى. //</lyrics>
<key>Bbm</key>
