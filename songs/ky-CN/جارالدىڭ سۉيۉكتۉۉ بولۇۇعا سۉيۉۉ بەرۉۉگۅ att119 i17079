<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.      E       B       C#m
 // جارالدىڭ سۉيۉكتۉۉ بولۇۇعا، سۉيۉۉ ارنووعو.
.   A         E     F#m        B  (E)
 جاشووڭو بۇل سۉيۉۉ تولۇپ تۇرسۇن دايىما. //

[V2]
. E     B                C#m
 باشتالىشتا بۇل سۉيۉۉ قۇدايدان جارالعان.
.     A         E  F#m      B
 جەمىشتۉۉ بولسۇن دەدى، سەنى تەڭىرىم.
.E      B       C#m
 دۉينۅدۅ بولعونۇڭا بئز قۇبانابىز.
.    A         E    F#m  B    E
 قۇبانىچتى سۅز مەنەن، جەتكىرە البايبىز.

[V3]
.   E     B                C#m
 // سەن جارالدىڭ، سۉيۉكتۉۉ بولۇۇعا، سۉيۉۉ ارنووعو.
.A      E            F#m         B (E)
 ۇشۇل سۉيۉۉ دايىما، تولۇپ تۇرسۇن جاشووڭو. //</lyrics>
<title>جارالدىڭ سۉيۉكتۉۉ بولۇۇعا سۉيۉۉ بەرۉۉگۅ ATT119</title>
<hymn_number>119</hymn_number>
<author>مىنسوپ لى, Минсоп Ли</author>
</song>