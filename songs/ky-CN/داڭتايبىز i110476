<?xml version="1.0" encoding="UTF-8"?><song><tempo>147</tempo>
<author>جِرِمي رِددلِ</author>
<title>داڭتايبىز</title>
<time_sig>6/8</time_sig>
<lyrics>[V1]
.           Dmaj9
 قايعى تااجىسىن
.F#m7    E
 ۅزۉڭ كىيدىن.
.           Dmaj9
 سىزداتىپ دەنەڭ
.    F#m7     E
 مىڭ قامچى تىلدى.

[V2]
.            Dmaj9
 قادالعان قولدور،
.F#m7    E
 تەرەڭ جارالار.
.           Dmaj9
 اققان ايقاشتا،
.  F#m7   E
 قانىڭا قارايم!

[C1]
.     Dmaj9
   داڭتايبىز ماقتوو ىرداپ،
.      A
   باركتايبىز داڭازالاپ.
.    F#m7
   تاتىقتۇۇسۇڭ سەن!
.    Esus
   القىشتايمىن مەن!

[V3]
.           Dmaj9
 سەن جالعىز بەردىڭ،
.F#m7      E
 جانىڭدى ماعا.
.            Dmaj9
 ەركىندىك كەلدى،
. F#m7   E
 ۉرۅي شىلدىڭدان

[V4]
.          Dmaj9
 ادامزاتتى سەن،
.F#m7      E
 ازاپتا سۉيدۉڭ!
.           Dmaj9
 ۅز قانىڭ مەنەن،
.    F#m7   E
 ىيسا قۇتقاردىڭ!

[B1]
.        D
   شىلدىڭدى ايقاشتا
   ەگەم ىيسا جەڭدىڭ.
.    F#m7
   كۉنۅۅسۉز ۅزۉڭدۉ
   قۇرماندىققا بەردىڭ.
.     D
   ۅلۉمۉڭ دۇشماندى
   تالقالاپ جوق قىلدى
.    E4
   القىش

[B2]
.      D
   جارالار، ازاپ
   توقموق، شىلدىڭدار
.    F#m7
   تۅگۉلگۅن، قانىڭدان
   جۉرۅكتۅر تازارعان!
.     D
   چەكسىز سۉيۉڭ۔
   جەڭىشتىن ەەسى!
.   E4
   ىيسا!</lyrics>
<key>E</key>
</song>