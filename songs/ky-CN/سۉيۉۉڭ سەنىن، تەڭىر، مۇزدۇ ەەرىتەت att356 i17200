<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>356</hymn_number>
<author>ئا. ۋالېۋىچ, ئا. فېدوسېېۋا</author>
<title>سۉيۉۉڭ سەنىن، تەڭىر، مۇزدۇ ەەرىتەت ATT356</title>
<lyrics>[V1]
.        Em                  C
 سۉيۉۉڭ سەنىن،  تەڭىر، مۇزد(ۇ) ەەرىتەت.
.       D                     B7
 تۉشۉنۅت مەنى،  كەچىرەت، الدىعا جەتەلەيت.
.        Em              C
 سۉيۉۉڭ سەنىن،  تەڭىر، ۅمۉر بەرەت.
.       D                  B7
 ۅز جارىعىنا  چاقىرات، كۅككۅ كۅتۅرۅت!

[V2]
.         Em                  C
 باردىق  ئزدەگەندەر تابات، تىقىلداتقانعا اچىلات،
.          D                B7
 باردىق  سۇۇساعاندار ىچەت، ۅمۉرۉڭدۉن بۇلاعىنان.
.       Em                    C
 سۉيگۅن اتا،  سەن ىزدەيسىڭ، اداشقان ۅز بالدارىڭدى.
.       D                    B7
 كەچىرىپ،  سۉيۉپ كۉتۅسۉڭ، قايرىلىپ ۉيگۅ كەلگەنىن.

[V3]
.        Em                  C
 سۉيۉۉڭ سەنىن،  تەڭىر، مۇزد(ۇ) ەەرىتەت.
.        Em                 C
 سۉيۉۉڭ سەنىن،  تەڭىر، كۅككۅ كۅتۅرۅت.
.        Em              C
 سۉيۉۉڭ سەنىن،  تەڭىر، ۅمۉر بەرەت.</lyrics>
<key>Em</key>
</song>