<?xml version="1.0" encoding="UTF-8"?><song><title>ىيسا تەڭىرىم ATT447</title>
<lyrics>[V1]
.    Em          C
 // ىيسا تەڭىرىم، ىيسا تەڭىرىم،
.D               Em
 ىيسا تەڭىرسىڭ بۇل االامعا. //

[V2]
.C      D     Em
 انىن اتى باارىنان بىيىك،
.C       D     Em
 انىن تاقتى تۉبۅلۉك بەكەم،
.Cmaj7   D    G      Em
 انىن قانى شايتاندى جەڭدى،
.Cmaj7    Em     B7
 قۇتقارۇۇچۇم ىيسا تەڭىرىم.</lyrics>
<key>Em</key>
<hymn_number>447</hymn_number>
<author>رَمُن پِنك</author>
</song>