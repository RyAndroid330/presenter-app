<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>484</hymn_number>
<key>Am</key>
<lyrics>[V1]
.  Am
 ەمنە پايدا ماعا بايلىقتان،
.    E
 الىس كەتكەن اتاق۔داڭقتان،
.  Dm
 كۅڭۉل ەرگىتكەن مۇقام ىرلاردان،
.     E
 ىيسا مەنى مەنەن بولبوسو؟

[C1]
.     Am             Dm
   ىيساسىز دۉينۅ وقشوشوت چۅلگۅ،
.      G              C
   ىيساسىز ماڭىز جوق ۅمۉردۅ.
.       Dm         E
   سۇۇ بويۇندا ۅلۅمۉن سۇۇساپ،
.                   Am
   ىيسا مەنى مەنەن بولبوسو.

[V2]
.  Am
 ايىرما جوق قۇبانىپ جاتامبى،
.   E
 جە قايعىعا باتىپ تۇرامبى،
.   Dm
 ماانئسىز، ماڭىزسىز مۇنۇن باارى،
.     E
 ىيسا مەنى مەنەن بولبوسو.

[V3]
.  Am
 ىيساسىز جارىق كۉن۔قاراڭعى تۉن.
.  E
 ىيساسىز مەن بئر ۇۇچ توپۇراق.
.   Dm
 بۇل جاشوو كۅتۅرگۉس جۉك مەن ۉچۉن،
.     E
 ىيسا مەنى مەنەن بولبوسو.</lyrics>
<title>ەمنە پايدا ماعا بايلىقتان ATT484 РЫЖ258</title>
</song>