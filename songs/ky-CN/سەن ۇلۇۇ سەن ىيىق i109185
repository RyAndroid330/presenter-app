[C1]
.  Em       C        D     Em
    // سەن ۇلۇۇ، سەن ىيىق سەن //

[V2]
.   Em               C
 // ۅلۉمدۉن، ۅمۉر اچكىچى تەڭىر،
.D                Em
 كۉنۅۅدۅن قايتىپ، توبوو قىل ەلىم //</lyrics>
