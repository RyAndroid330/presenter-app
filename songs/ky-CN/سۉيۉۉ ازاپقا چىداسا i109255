<?xml version="1.0" encoding="UTF-8"?><song><author>هِللسُنگ وُرسهِپ</author>
<title>سۉيۉۉ ازاپقا چىداسا</title>
<key>F</key>
<lyrics>[V1]
.F         C  Dm     Bb
 سۉيۉۉ ازاپقا چىداسا،
.F         C   Dm          Bb
 قانداي باالۇۇ قانىڭ، ىيسا!
.F           C         Dm   Bb
 اسمان داڭقى جاپتى ۇياتتىمدى،
.F         C       Dm
 ۅلۉمدۅن سۉيۉۉڭ قۇتقاردى.

[P1]
.  Bb              C
    مەن ۉچۉن ازاپقا چىدادىڭ،
.  Bb          C          Am
    ايقاش جىعاچقا قادالدىڭ،
.  Bb            Dm     C
    ۅلۉمدۉ جەڭىپ داڭقتالدىڭ.

[C1]
.     F                C    Dm
   قانداي داڭقتۇۇ، تاڭ قالىچتۇۇ،
.    Bb   F     C  Dm
   جارااتتارىڭ، قۇتقارۇۇچۇ!
.       Am  Bb   C    Dm
   ۅمۉر ۉچۉن قۇن تۅلۅندۉ،
.      Bb  F        C
   ىرايىمعا مەن بۅلۅندۉم.

[V2]
.F             C    Dm     Bb
 ىيسا تئرىلدى، ۅلۉم جەڭىلدى،
.F              C   Dm    Bb
 جۉرۅككۅ قايرا ۉمۉت بەردى.
.F             C        Dm Bb
 قانىڭ مەنەن جەڭىپ توزوقتۇ،
.F         C       Dm
 ۇبادالارىڭ بوشوتتۇ.

[P2]
.  Bb             C
   ۅمۉر ارتىندا ەركىندىك،
.  Bb        C          Am
   كۉنۅۅ۔ۇياتتان ارىلدىق،
.  Bb            Dm     C
   مەن ۉچۉن باارىن سەن جەڭدىڭ.

[B1]
.  Bb
    ەركىندىكتى ىيسادان الدىم،
.  Dm
    قاراڭعىدا جارىقتى كۅردۉم.
.  F                       C
    اشىپ۔تاشقان ۅمۉر كەلگەن ۉچۉن،
   تاڭ قالام چىندىعىڭا.

[B2]
.  Bb       C   Dm
    ىرايىمىڭ الدىندا
.             Bb    F
   داڭقتايمىن قايرا۔قايرا،
.                C
   ىراازىمىن مەن ساعا.</lyrics>
</song>