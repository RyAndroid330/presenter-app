<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>178</hymn_number>
<key>Bm</key>
<lyrics>[V1]
.Hm                    Em        F#
 بۇل ۅمۉردۅن ۅتۅت ەكەن داانىشمان دا،
.F#                   Em    Hm
 ۅتۅت ەكەن اق ەلەچەك اپالار دا،
.H7                            Em
 دۉينۅنۉ بۉت تئتىرەتكەن پادىشا دا،
.Hm         Em          Hm
 ۅتۅت ەكەن اسىل، سۇلۇۇ، ارۇۇلار دا.

[C1]
.  Hm                       F#
   ەي ادامزات، كۅز جۉگۉرتچۉ ۅتكۅنگۅ.
.  Em            Hm          F#
   ۅلبۅي، تىرۉۉ، بۇل دۉينۅگۅ تۉركۉك بولعون،
.  F#               Hm
   ايتقىلا، اي، كىم بار؟

[V2]
 كۅرگۅن تۉشتۅي ۅتۅت چىعار الدىڭدان،
 ۅمۉر جالعان، انى ەچ كىم بىلە الباعان.
 بۇل ۅمۉردۉن چىن۔بىشىعىن، قۇپۇياسىن
 قانچا ىزدەپ، ەچ كىم انى تابا الباعان.

[V3]
 ۇققۇن بۉگۉن، ۇققۇن ۉنۉن جاراتقاندىن،
 ەگەدەرى باتقان كۉندۉن، اتقان تاڭدىن.
 پەندەلەرىم بارسىنچى دەپ بەيىش تۅرگۅ،
 سۉيگۅندۉكتۅن، بئز ۉچۉن ال تۅككۅن قانىن.

[V4]
 تۉبۅلۉككۅ بارار جولۇن كۅرسۅتۉپ،
 ىيسا تەڭىر جەرگە كەلگەن تۅرۅلۉپ.
 جاراتقاندىن الارىنان بەرەرى كۅپ،
 سەن دا العىن، تۇربا، دوسۇم كۅگۅرۉپ.</lyrics>
<title>بۇل ۅمۉردۅن ۅتۅت ەكەن داانىشمان دا РЫЖ178</title>
</song>