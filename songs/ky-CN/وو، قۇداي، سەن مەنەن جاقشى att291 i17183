<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am
 // وو، قۇداي، سەن(ى) مەنەن جاقشى!
.Dm
 وو، قۇداي، مەەرمانسىڭ!
.G                   C E
 وو، قۇداي، ساعا قايرىلامىن. //

[V2]
.   Am            Dm            Am
 // دىتىمدى بۇردۇم ساعا، ىرايىم قىلدىڭ ماعا،
. Dm           Am E       Am
 بوورۇكەر، مەەرىمدۉۉ، وو، قۇدايىم! //

[V3]
.   Am
 // وو، ىيسا، سەن(ى) مەنەن جاقشى!
.Dm
 وو، ىيسا، بوورۇكەرسىڭ!
.G                C E
 وو، ىيسا ساعا ىشەنەمىن! //

[V4]
.    Am                 Dm            Am
 // اسماندان جەرگە كەلدىڭ، تۉبۅلۉك ۅمۉر بەردىڭ.
. Dm             Am  E       Am
 كايرىمدۇۇ، كەچىرىم__دۇۇ، وو، تەنىرىم! //

[V5]
.    Am
 // ىيىق رۇح، سەن(ى) مەنەن جاقشى!
.Dm
 ىيىق رۇح، سووروتوسۇڭ!
.G                 C E
 ىيىق رۇح، سەنى چاقىرامىن! //

[V6]
. Am            Dm           Am
 تولولۇ بئز دايىما، سۉيۉۉڭۅ، اقىلىڭا.
. Dm           Am   E           Am
 كۉچتۅنۉپ، قۇباتتانىپ، جۉرۅلۉ شاتتىعىڭدا.</lyrics>
<key>Am</key>
<title>وو، قۇداي، سەن مەنەن جاقشى ATT291</title>
