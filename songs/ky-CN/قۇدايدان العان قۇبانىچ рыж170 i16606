<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>170</hymn_number>
<key>B</key>
<lyrics>[V1]
.H         F#      H
 قۇدايدان العان قۇبانىچ
.       E     F#    H
 تۇرسا ەكەن دايىم ۇلانىپ.
.H         F#       H
 قۇدايدىن بەرگەن سۉيۉۉسۉ
.H         F#       H
 ۅسسۅ ەكەن بىزدە چىڭالىپ.

[V2]
 قۇدايدىن ۇلۇۇ سۉيۉۉسۉ
 كۉنۅۅنۉن باارىن جااپ قويوت.
 جابىرقاپ تۇرعان ادامدىن
 جاشىرۇۇن سىرىن تااپ قويوت.

[V3]
 كۅپ جاندار كەلەت دۉينۅدۅن
 كۉنۅۅنۉن تارتىپ ازابىن.
 قۇبانىچ مەنەن قايتسا ەكەن،
 مەەرىمىن كۅرۉپ قۇدايدىن.</lyrics>
<title>قۇدايدان العان قۇبانىچ РЫЖ170</title>
</song>