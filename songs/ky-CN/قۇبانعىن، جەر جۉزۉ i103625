<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.     Am            Dm
 // قۇبانعىن، جەر جۉزۉ،
.    E                 Dm      Am
 قۇتكارۇۇچۇ تۅرۅلدۉ. قۇدايعا القىش! //
.              Em     G         C
 ال وورۇلاردى الدى، كۉنۅۅمدۉ كەچئردى.
.       Am         Dm               E        Am
 // ال جارىق ۉمۉت بەرىپ، قۇبانىچقا بئزدى تولتۇردۇ! //

[V2]
 // جار سالعىن، جەر جۉزۉ،
 جاراتقانعا شاتتانىپ، تەڭىرگە القىش! //
 سەنىن ۅمۉرۉڭ ۉچۉن ال ۅز جانىن بەردى.
 // جاشوونۇن دەمىن ۉيلۅپ، ىيىق رۇحقا بئزدى تولتۇردۇ. //

[V3]
 // جاندانسىن جەر جۉزۉ،
 سۉيۉۉسۉنۅ قۇبانىپ، ىيساعا القىش! //
 ال ىيىق قانى مەنەن ازعىرىقتى جەڭگەن.
 // جۉرۅككۅ وتۇ جانىپ، سۉيۉۉسۉنۅ بئزدى تولتۇردۇ. //</lyrics>
<key>Am</key>
<title>قۇبانعىن، جەر جۉزۉ</title>
</song>