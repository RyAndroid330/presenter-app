<author>فرِد هَممُند</author>
<title>جۉرۅگۉمۅ ىيىق رۇح ATT150</title>
<lyrics>[V1]
.     Em                B7 Em
 // جۉرۅگۉمۅ ىيىق رۇح تولۇپ تۇرعاندا،
.     B7       Em
 مەن ىردايمىن كۇدايعا. //
.        Am           Em
 // دۅۅت  پادىشاداي، دۅۅت پادىشاداي
.     B7        Em
 مەن ىردايمىن قۇدايعا. //

[V2]
.     Em                B7 Em
 // جۉرۅگۉمۅ ىيىق رۇح تولۇپ تۇرعاندا،
.     B7       Em
 مەن كۇبانام قۇدايعا. //
.       Am           Em
 // دۅۅت پادىشاداي، دۅۅت پادىشاداي
.     B7       Em
 مەن كۇبانام قۇدايعا. //

[V3]
.     Em                B7 Em
 // جۉرۅگۉمۅ ىيىق رۇح تولۇپ تۇرعاندا،
.    B7      Em
 سىيىنامىن قۇدايعا. //
.       Am           Em
 // دۅۅت پادىشاداي، دۅۅت پادىشاداي
.    B7      Em
 سىيىنامىن قۇدايعا. //</lyrics>
<key>Em</key>
</song>