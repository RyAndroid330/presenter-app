<?xml version="1.0" encoding="UTF-8"?><song><author>الماز ئسمايلوۆ, بۇرۇل شامىرقانوۆا</author>
<hymn_number>388</hymn_number>
<aka>سۉيۉۉ</aka>
<key>Am</key>
<lyrics>[V1]
.          Am            Dm
 // تەڭىرىم ۔ سۉيۉۉ، قۇدايىم ۔ سۉيۉۉ،
.          E           Am
 ەگەدەر ۔ سۉيۉۉ، ال بئز مەنەن. //

[V2]
.          Am           Dm
 كۅز ارتپايت سۉيۉۉ، بئر تۇۇعانىڭا،
.      G         C
 كۅتۅرۅت انىن السىزدىعىن دا.
.        Dm            C
 // انتكەنى قۇداي ۅزۉ ۔ «سۉيۉۉ» دەپ،
.      E           Am
 جازىلىپ تۇرات ىيىق جازۇۇدا. //

[V3]
.           Am            Dm
 // ىيىق رۇح ۔ سۉيۉۉ، ىيسا ۅزۉ ۔ سۉيۉۉ،
.         E            Am
 اتابىز ۔ سۉيۉۉ، ال بئز مەنەن. //

[V4]
.      Am           Dm
 چىنىعى سۉيۉۉ، قۇدايدان كەلەت،
.      G           C
 جاقىنىن سۉيگۅن ىيسانى بىلەت.
.        Dm           C
 // «بىرئڭدى بىرىڭ سۉيگۉلۅ» دەگەن،
.        E           Am
 تەڭىردىن سۅزۉن ال ساكتاپ جۉرۅت. //</lyrics>
<title>تەڭىرىم ۔ سۉيۉۉ ATT388</title>
</song>