<?xml version="1.0" encoding="UTF-8"?><song><title>اپپاق قار جاايت، تىنبايت ATT38</title>
<key>Eb</key>
<lyrics>[V1]
.Eb        Bb       Eb  Ab           Eb
 // اپپاق كار جاايت، تىنبايت، جىمجىرت بۉت ايلانا
.Bb     G7      Cm  Fm      Bb    Eb
 ىيسانىن تۇۇلعان كۉنۉن مايرامدايبىز قۇبانا. //

[V2]
.Eb       Bb      Eb  Ab        Eb
 // ەلگە تىنچتىق بەرۉۉگۅ جەرگە كەلدى قۇداي
. Bb     G7     Cm  Fm   Bb      Eb
 كۇبانعان جۉرۅكتۅردۅن جاڭىرا بەرسىن ىرلار. //

[V3]
.   Eb    Bb     Eb  Ab        Eb
 // سەن داعى شاشىلعىنىڭ شاشىل ىيسا تەڭىرگە
. Bb     G7   Cm Fm    Bb     Eb
 االامدىن پادىشاسى جانىڭا باقىت بەرەت. //</lyrics>
<hymn_number>38</hymn_number>
</song>