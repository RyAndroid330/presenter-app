<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>280</hymn_number>
<author>ماقسات سابىربەك ۇۇلۇ</author>
<key>G</key>
<lyrics>[V1]
.         G                    Em
 مىنا بۉگۉن بئز كەلدىك، تاازئم قىلىپ بئز كەلدىك،
.     C                 D
 جاراتقان ەگەمدىن، الدىنا كەلدىك.
.        G                Em
 جۉرۅگۉمدۅ سەن ۅزۉڭ، ويۇمدا سەن بئر ۅزۉڭ،
.      C                 D
 جاشوومدۇن ماڭىزى، جالعىز سەن ۅزۉڭ.

[P1]
.       Em            C
   سووروتۇۇچۇم سەن، قۇتقارۇۇچۇم سەن،
.      Am               D
   قۇباتىم، باقىتىم، جالعىز سەن.

[C1]
.    G        Em        C        D
   قۇبان، قۇبان ەلىم، ىممانۇەل بئزگە كەلدى.
.     G        Em          C        D
   قۇبان، قىرعىز ەلىم، قۇتكارۇۇچۇ بئزگە كەلدى.
.    G        Em        C        D
   قۇبان، قۇبان ەلىم، ىممانۇەل بئزگە كەلدى.

[P2]
.       Em          C
   بئر گانا ىيسا باارىنان قىمبات،
.        Am                D
   بۉت دۉينۅ، پەرىشتەلەر داڭقتاشات.

[B1]
.       Em         C (Em)
   //// ىممانۇەل بئزگە كەلدى. ////</lyrics>
<title>مىنا بۉگۉن بئز كەدىك ATT280</title>
</song>