<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>157</hymn_number>
<key>Am</key>
<lyrics>[V1]
.Am
 ىشەنەم ىيساعا،
.                   Dm
 ماقساتىم، جاشوومو جارىق.
.E
 ىشەنەم ىيساعا،
.                  Am
 ىسىم جوق ىيسادان ارتىق.
.A
 ىشەنەم سۉيۉۉگۅ
.                    Dm
 قۇدايدان ادامعا كەلگەن.
.F
 بىزدىن تەڭىر ىيسا
.                   E
 باارىنا كەچىرىم بەرگەن.

[C1]
.      F          G                C
   قۇبانىچىم، قۇبانىچىم، قۇدايىم، سەن،
.      F          G                  C A
   باقىتىم دا، باقىتىم دا، بئر ىيسا، سەن.
.          Dm         E
   كۉچۉم مەنىن، كۉچۉم مەنىن، تىرۉۉ
.   Am
   كۇداي، ۅزۉڭ،
.      Dm           E               Am
   قۇتكارعان دا، ساقتاعان دا ىيىق سۅزۉڭ.

[V2]
 ىشەنەم ىيساعا،
 ەسىمدە چاقىرعان ۉنۉ.
 ىشەنگەم ىيساعا
 ال رۇحۇنان بەرگەن كۉنۉ.
 ىشەنىپ قايرىلىپ،
 قۇدايعا دىلىمدەن ايتقام:
 جالعىز قۇدايىم، سەن
 ەكەنسىڭ چىنىعى سۉيۉۉ!

[V3]
 وشوندو جۉرۅگۉم
 قۇبانىچ رۇحۇنا تولعون.
 بۇل قانداي زور باقىت
 قۇداي مەنەن بىرگە بولعون.
 قاالارىم: ار بىرىڭ
 تاتىپ كۅر داامىن انىن.
 ۇقتابا كۉنۅۅنۉن قوينۇندا،
 ەرتەرەەك ويعون.</lyrics>
<title>ىشەنەم ىيساعا РЫЖ157</title>
</song>