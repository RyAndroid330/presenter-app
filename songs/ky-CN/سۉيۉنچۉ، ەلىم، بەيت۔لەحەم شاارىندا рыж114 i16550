<?xml version="1.0" encoding="UTF-8"?><song><key>F#</key>
<lyrics>[V1]
.C#                  G#         C#
 سۉيۉنچۉ، ەلىم، بەيت۔لەحەم شاارىندا،
. F#             C#   G#   C#
 كۇبانعىلا، تۅرۅلدۉ تەڭىر ىيسا.
.   F#                     G#
 ەمانۇەل ۔ قۇداي ۅزۉ بئز مەنەن،
. C#               F#   G#    C#
 كابىل ال، قۇتقارۇۇسۇن ساعا دەگەن.

[V2]
 قۇدايىم ىرايىمدۇۇ، قۇدۇرەتتۉۉ،
 ۇشۇنچالىق چەكسىز انىن سۉيۉۉسۉ.
 اتىن چاقىر، ۉنۉڭدۉ ۇعات سەنىن،
 ىيسا ايتقان: «جول، چىندىق، ۅمۉر مەنمىن».

[V3]
 تەڭىرىم، ىراازىمىن بەلەگىڭە،
 تۉبۅلۉك ۅمۉر بىزگە بەرگەنىڭە.
 بۉگۉن بئز تۇۇلعان كۉنۉڭ مايرامدايبىز،
 سەنى مەنەن قۇبانىپ، شاتتانابىز.</lyrics>
<title>سۉيۉنچۉ، ەلىم، بەيت۔لەحەم شاارىندا РЫЖ114</title>
<hymn_number>114</hymn_number>
</song>