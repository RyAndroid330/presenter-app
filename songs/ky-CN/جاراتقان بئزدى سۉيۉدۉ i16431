<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 جاراتقان بەرگەن سۉيۉۉدۅن
 جان۔دۉينۅم تولقۇندانات
 تاازئم قىلىپ ىرايىمىڭا
 كۅزۉمدۅن جاشىم تامات

[C1]
   // بۇل سۉيۉۉ تەڭىردەن كەلدى
   ەلىمە بەرگىن، ۔ دەدى
   االامدىن ەگەسى بئز ۉچۉن
   ۅزۉنۉن جانىن بەردى //

[V2]
 بۇل سۉيۉۉ تەڭىردەن كەلدى
 ەلىمە بەرگىن، ۔ دەدى
 االامدىن ەگەسى بئز ۉچۉن
 ۅزۉنۉن جانىن بەردى

[V3]
 تەڭىردىن ۇلۇۇ سۉيۉۉسۉنۅ
 جۉرۅكتۅن جارىق جانات
 العاندار ىيىق سۉيۉۉنۉ
 بئز مەنەن قۇبانىشات

[V4]
 بۇل سۉيۉۉ تەڭىردەن كەلدى
 ەلىمە بەرگىن، ۔ دەدى
 االامدىن ەگەسى بئز ۉچۉن
 ۅزۉنۉن جانىن بەردى</lyrics>
<title>جاراتقان بئزدى سۉيۉدۉ</title>
</song>