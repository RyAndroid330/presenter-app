<?xml version="1.0" encoding="UTF-8"?><song><author>كهرِس تُملِن, مَتت رِدمَن, جُنَس ميرِن, جِسسِ رِِڤِس</author>
<hymn_number>346</hymn_number>
<title>سۇۇنۇ شاراپقا ايلانتتىڭ ATT346</title>
<lyrics>[V1]
. Em     C         G
 سۇۇنۇ شاراپقا ايلانتتىڭ،
. Em     C          G
 سوقۇر كۅزدۅردۉ اچتىڭ ۔
.    Am           D
 ساعا تەڭدەش ەچ كىم جوق! (2ج)

[C1]
.     Em      C
   // تەڭىر ۇلۇۇسۇڭ، تەڭىر كۉچتۉۉسۉڭ،
.   G             D
   تەڭىر سەن جوعورۇسۇڭ باارىنان.
.  Em         C              G      D
   ايىقتىرۇۇچۇ، سەن بوشوتۇۇچۇ ۔ بئزدىن تەڭىر! //

[V2]
.   Em    C          G
 // جارىق قىلدىڭ قاراڭعىنى
. Em     C          G
 جاشووعو بىزدى تىرىلتتىڭ
.    Am           D
 ساعا تەڭدەش ەچ كىم جوق! //

[B1]
.     Em                C
   //  قۇداي بئز مەنەن بولسو، كىم بئزدى توقتوتوت؟
.   G                D            Em
   كۇداي بئز مەنەن بولسو، كىم قارشى چىعا الات؟! //</lyrics>
<key>G</key>
</song>