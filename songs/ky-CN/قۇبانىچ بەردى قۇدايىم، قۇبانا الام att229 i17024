<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>229</hymn_number>
<author>نارگىزا مارازىقوۆا</author>
<key>G</key>
<lyrics>[V1]
. G          C      D     G
 كۇدايسىز  دۉينۅدۅ مەن جاشاپ كەلگەم،
.G           C       D    G
 ۉمۉتسۉز،  باكتىسىز، جاپاا چەككەم.
. C      D     Em       D
 سۉيۉۉنۉن  ماڭىزىن ەچ بئلبەستەن،
. D                     G
 جۉرۅكتۅ  قۇبانىچ جوق ۅمۉر سۉرگۅم.

[V2]
.   G
 قۇبانىچ  بەردى قۇدايىم، قۇبان(ا) الام.
. G
 سۉيۉۉ  بەردى قۇدايىم، مەن سۉيۅ الام.
. C                        D
 باقىت  بەردى تەڭىرىم، باقتىلۇۇمۇن.
. D                           G
 راحاتتانىپ  بۇل جاشوودو، شاتتان(ا) الام.
. G
 تىنچتىق،  ۉمۉت ىيسا بەردى، قۇبانامىن،
.  G
 تۉبۅلۉك  ۅمۉر۔بەكەر  بەلەك اندان الدىم.
.C                      D
 ىشەنەم  قۇدايعا، ىيساعا ىشەنەم،
. D                        G
 مىنداي  بەكەم ىشەنىمدى تەڭئر بەرگەن.

[V3]
 «تىنچتىق قايدا؟» ۔ دەپ مەن ىزدەپ كەلدىم،
 بۇل جاشوودو شاتتانام دەپ ىشەنبەدىم.
 بئر كۉنۉ ىيسا كىردى جۉرۅگۉمۅ،
 جاشووم تولۇق ۅزگۅرۉلدۉ، انى سەزدىم.

[V4]
 قۇبانىچ الام قۇدايدان، قۇبان(ا) الام،
 سۉيۉۉ العام تەڭىردەن، مەن سۉيۅ الام.
 باقىت العام قۇدايدان، باقتىلۇۇمۇن،
 راحاتتانىپ بۇل جاشوودو، شاتتان(ا) الام.
 ۅچپۅس ۉمۉت، ىيسا بەردى، قۇبانامىن،
 تۉبۅلۉك ۅمۉر۔بەكەر بەلەك اندان الدىم.
 ىشەنەم قۇدايعا، ىيساعا ىشەنەم،
 مىنداي بەكەم ىشەنىمدى تەڭىر بەرگەن.</lyrics>
<aka>قۇدايسىز دۉينۅدۅ مەن جاشاپ كەلگەم</aka>
<title>قۇبانىچ بەردى قۇدايىم، قۇبانا الام ATT229</title>
</song>