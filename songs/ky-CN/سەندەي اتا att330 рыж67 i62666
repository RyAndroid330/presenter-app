<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>330</hymn_number>
<title>سەندەي اتا ATT330 РЫЖ67</title>
<aka>نەت تاقوعو وتتسا قاق تى</aka>
<key>Bm</key>
<lyrics>[V1]
.Bm    Em      F#      Bm
 سەندەي اتا بار بەكەن بۇل جەردە.
.         G    A       D
 جۉرۅسۉڭ سەن جانىمدا ار كەزدە.
.   Em      A         D      Bm
 // قاناتىڭا قالقالايسىڭ بۅپۅلۅپ،
.        Em         F#     Bm
 قورعوو چەبىم بولوسۇڭ سەن ار جەردە //

[C1]
.           Em    A     D  Bm
   // سەندەي اتا تابىلباس ماعا،
.        Em      F# Bm
   سەندەي اتا تابىلباس ماعا //

[V2]
 مەەرىمىڭە چۅمۉلۉپ مەن كەلەم
 ماعا دەگەن ىرايىمىڭ مول ەكەن،
 // اتا بولۇپ جۉرۅگۉمدۉ اچتىڭ سەن،
 تۉبۅلۉككۅ قۇچاعىڭا الدىڭ سەن //</lyrics>
</song>