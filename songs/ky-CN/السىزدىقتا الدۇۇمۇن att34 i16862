<?xml version="1.0" encoding="UTF-8"?><song><author>هِللسُنگ, رُِبِن مُرگَن</author>
<hymn_number>34</hymn_number>
<key>C</key>
<lyrics>[V1]
.     C  G     C      F           Am
 السىزدىقتا الدۇۇمۇن، جاردىلىقتا مەن بايمىن،
.      C   G   Am      Dm   G     C
 تەڭىر كۅزۉمدۉ اچتى، سۉيۉۉ مەنەن جاڭىرتتى.

[C1]
.   G      Am        F         C
   وساننا، وساننا، مەن ۉچۉن ىيسا كەلگەن،
.   G      Am        C    G    C
   وساننا، وساننا، ۅلۉپ قايرا تئرىلگەن.

[V2]
.    C    G    C       F        Am
 تەڭئرىم تۅگۉپ قانىن، مەن ۅلۉمدۅن ارىلدىم،
.     C   G    Am      Dm     G    C
 كۉنۅۅدۅن تازالانىپ، سوورونۇپ، تىنچتىق الدىم.

[C2]
.    G     Am        F        C
   وساننا، وساننا، مەن ۉچۉن ىيسا ۅلگۅن،
.    G     Am       C   G    C
   وساننا، وساننا، ىرايىم ماعا تۅككۅن.

[V3]
.    C     G   C       F       Am
 ۅمۉردۉن دايراسىنا، كىرىپ، جانىم تئرىلدى،
.    C    G     Am       Dm    G   C
 جۉرۅگۉمدۉ رۇح كاپتاپ، چەكسىز سۉيۉۉ بەرىلدى.</lyrics>
<title>السىزدىقتا الدۇۇمۇن ATT34</title>
</song>