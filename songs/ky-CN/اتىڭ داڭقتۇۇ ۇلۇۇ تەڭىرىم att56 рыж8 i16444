<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>56</hymn_number>
<title>اتىڭ داڭقتۇۇ ۇلۇۇ تەڭىرىم ATT56 РЫЖ8</title>
<lyrics>[V1]
.    Am           Dm     Am
 // اتىڭ داڭقتۇۇ ۇلۇۇ تەڭئرىم.
. Dm      Am
 تابىنىپ كەلەت سەنىن ەلىڭ. //

[C1]
.     F       G     F C
   سۉيۉۉسۉ مول باتاعا تولعون،
.   Dm          E
   بئزدىن قۇداي تەڭىر.
.  Dm                   E
   ادىلەتتۉۉ سوتتووچۇ، پادىشا.

[V2]
.    Am           Dm      Am
 // ىيسانىن چەكسىز زور سۉيۉۉسۉ،
.Dm     Am
 ۅلۉمدۅن ساقتايت كۉنۅۅكۅردۉ. //

[V3]
.    Am          Dm     Am
 // ماقتاسىن جەر جۉزۉ تەڭىردى،
. Dm     Am
 كۇتقارام دەپ چاقىرات سەنى. //</lyrics>
<key>Bm</key>
</song>