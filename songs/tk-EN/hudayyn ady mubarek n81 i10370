<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>81</hymn_number>
<lyrics>[V1]
 Hudaýyň Adyna şöhrat,
 Şöhrata we alkyşa
 Ol mynasyp.
 Mukaddesler ýaly
 elleri galdyryp,
 Aýdymda Onuň Adyn,
 Hudaýyň Adyn,
 Hudaýyň adyň
 alkyşlalyň.

[V2]
 Mynasyp,
 Ol mynasyp,
 Taňrylaň - Taňrysy,
 Ol mynasyp.
 Isa,
 Sen mynasyp,
 Taňrylaň - Taňrysy,
 alkyş Saňa.</lyrics>
<title>Hudaýyň ady mübärek N81</title>
</song>