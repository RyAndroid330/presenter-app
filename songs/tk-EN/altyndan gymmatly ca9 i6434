<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9</hymn_number>
<author>DSJ</author>
<key>Em</key>
<lyrics>[V1]
.Em       Am
 Meň üçin altyndan gymmat baha,
.C             D
 Göwherden hem gymmatdyr
.Em          Am
 Seň Görküň, Ýakutdan hem owadan,
.C                    D
 Rebbim meniň, Beýik Hudaýym.

[C1]
.  Am           Em
   Senden başga Halasgärim ýok,
.  D             G      E
   Senden başga umydym ýok,
.  Am           Em
   Senden başga Howandarym ýok,
.  D              Bm       Em
   Ýalňyz Taňrym, Beýik Hudaýym.</lyrics>
<title>Altyndan Gymmatly CA9</title>
</song>