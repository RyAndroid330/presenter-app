[C1]
.     G            A     D Bm
   // Täze dünýä, täze ömür,
.  Em        A            Bm
   Hakykat, hemişelik ömür,
.  G            A        D Bm
   Tükenmez bagt, guwanyş,
.     Em(Fm)    A          Bm
   // Başlanar Sen gelen güni.

[V2]
 Seniň Mähriň derýadeý çäksiz!
 Säherdendir Nurlaryň Seniň;
 // Ökünerin her güni ýaşap,
 Halas etgin halkymy meniň! //

[V3]
 Hudaýym geçir günämizi.
 Senden özge ýokdyr penamyz;
 // Hemmesinden Gudratlysyň Sen,
 Ýalňyz Sensiň söýenim meniň. //</lyrics>
