<?xml version="1.0" encoding="UTF-8"?><song><key>F</key>
<lyrics>[V1]
.F         C
 Geliň, şatlanyň
.F             C
 we nagmalar aýdyň,
.Dm      C          G    C7
 Beýtullahamda Çaga doguldy.
.F       Bb
 Ýörüň gideliň,
. Gm        C
 Oňa sežde edeliň,

[C1]
.  C  F
    Alkyşlalyň Adyny,
.              C7
   Alkyşlalyň Adyny,
.    Bb        C7 Bb
   Alkyşlalyň Ady-ny,
.   F  C7   F
   Isa Rebbimiz!

[V2]
.F      C        F
 Perişdeler şatlanyp
.F           C
 aýdymlar aýtsyn,
.Dm      C              G    C7
 Söýgide Gökler sežde etsin Oňa.
.F      Bb
 Hudaýa şöhrat,
.Gm        C
 Rebbimize şöhrat,</lyrics>
<title>Doglan Çaga N28</title>
<author>Wade, John Francis (circa 1710-1786), Hillsong Worship</author>
<hymn_number>28</hymn_number>
</song>