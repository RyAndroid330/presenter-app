<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>17</hymn_number>
<author>Melody Green</author>
<title>Bir Halasgär bardyr, Taňry Ogly Isa N17</title>
<lyrics>[V1]
.   C            F   C
 // Bir Halasgär bardyr
.G          C G
 Taňry Ogly Isa,
.C         F      C
 Gymmatly Taňry Guzysy,
.G         C
 Iň uly bolan. //

[C1]
.     C     F    C
   // Saňa şükür Atajan
.  G         C G
   Isaň gany üçin,
.  C          F     C
   Indi Seniň Ruhuň bilen
.  G         C
   dolanarys biz. //

[V2]
 // Isa Halasgärdir başga
 biri ýok,
 Hormatly Taňry Guzusy,
 el çekerin günäden. //
 Gaýtalama:</lyrics>
<key>D</key>
</song>