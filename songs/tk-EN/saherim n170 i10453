<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em
 Şäherim dagyň belentliginde dur,
.E              Am
 Jowzadyr, gar, aýazy gördi.
.Am                        Em
 Erbet ýel diwar berkligin synady,
.B7                   Em
 Ýykmagy, tozdurmagy isledi.
.Em
 Deňiziň gaharly beýik tolkuny,
.E                Am
 Şäheriň diwaryna ýetdi,
.Am                     Em
 Emma Dag has beýik - belentdi;
.B7                 Em
 Şäheri, suw basyp bilmedi.

[C1]
.     Em        Am
   // Şäherim - bu ruhum,
.  B7              Em
   Daşynda ynam - diwar.
.  Em           Am
   Meň Rebbim - meniň Dagym,
.  B7                 Em
   Meň Rebbim - meniň Gaýam! //

[V2]
 Megerem ýene birnäçe kyn günler,
 Şäherim mätäçligi çeker,
 Megerem erbet ýeller ýene geler,
 Öz gara işin etmek islär.
 Gorkmaryn, kellämi göge galdyryp,
 Bir zady dilegde sorajak:
 &quot;Goý meniň elmydam şäher, diwarym
 Gaýada berk ornaşyp dursun!&quot;</lyrics>
<title>Şäherim N170</title>
<hymn_number>170</hymn_number>
</song>