<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Reb meniň nurum,
 hem Halasgärim,
 Aýakda güýjüm,
 depämde täjim,
 Alnymda ýolum,
 arkada dagym,
 Sagymda örüm,
 solumda bagym.

[V2]
 Elimde hasam,
 Sen maňa hossar,
 Ters ýoly gysar,
 düz ýola gyssar,
 Ýokdan bar eden ne
 ajap Ussa.
 Şatlyk ber maňa,
 ýok bol gam-gussa.

[C1]
   Ýaşa, Rebbim,
   meniň kalbymda ýaşa,
   Senden dolup,
   aýdym ýürekden joşýar,
   Dostlar dogan bolýar,
   duşman ýaraşýar,
   Bu gün, Rebbim,
   Saňa halkyň garaşýar.</lyrics>
<title>Reb meniň nurum N136</title>
<hymn_number>136</hymn_number>
</song>