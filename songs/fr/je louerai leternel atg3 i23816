<?xml version="1.0" encoding="UTF-8"?><song><title>Je louerai l'Eternel ATG3</title>
<key>F</key>
<lyrics>[V1]
 Je louerai l'Eternel de tout mon cœur,
 Je raconterai toutes tes merveilles,
 Je chanterai ton nom.
 Je louerai l'Eternel de tout mon cœur,
 Je ferai de toi le sujet de ma joie,
 Alléluia !</lyrics>
<author>Claude Fraysse</author>
<hymn_number>3</hymn_number>
</song>