<?xml version="1.0" encoding="UTF-8"?><song><author>Ruben Saillens, imité de John Samuel Bewley Monsell, Mélodie autrichienne</author>
<hymn_number>159</hymn_number>
<title>J'ai faim, j'ai soif, Jésus AF159</title>
<key>Db</key>
<lyrics>[V1]
 J'ai faim, j'ai soif, Jésus ;
.    
     sois la manne pour moi !
 Eaux vives, jaillissez
.    
     du Rocher du Calvaire !

[V2]
 O Pain rompu pour nous,
.    
     que je vive de Toi !
 Je meurs, si tu ne viens
.    
     secourir ma misère !

[V3]
 Vendange que foula
.    
     le Vigneron divin,
 Enivre-moi d'amour,
.    
     d'espoir et de courage !

[V4]
 Ta chair, ton sang, Jésus,
.    
     sont le pain et le vin
 Qui seuls me soutiendront
.    
     jusqu'au bout du voyage !</lyrics>
</song>