<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am
 // Худо шундай деган,
.Dm
 Сендан асло айрилмайман,
.E                      Am E
 Сени асло ташлаб кетмайман. //

[C1]
.     Dm      E        Am
   // Ботир юрак билан сафарга чиқаман,
.  Dm          E
   Қўрқмайман, қўрқмайман.
.  Dm                E
   Худо чупонимдир, душманлар мени
.    Am Dm     E             Am
   Нима қилолади, нима қилолади? //</lyrics>
<key>Am</key>
<title>Худо шундай деган</title>
<author>Илияс Турсун</author>
<hymn_number>213</hymn_number>
</song>