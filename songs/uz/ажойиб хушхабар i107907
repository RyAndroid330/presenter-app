<?xml version="1.0" encoding="UTF-8"?><song><author>Мичаел В Смит</author>
<lyrics>[V1]
 АЖОЙИБ ҲУШХАБАР, ФАРИШТАЛАР КУЙЛАР
 ШУ ТУНДА, ЗУЛМАТДА, БУЮК СЕВГИ
 ТУҒИЛДИ,
 КУЙЛАНГЛАР,
 КУЙЛАНГ ҲАЛЕЛУЯ

[V2]
 АЖОЙИБ, АЖОЙИБ, ЕРГА КАЛОМ КЕЛДИ
 ОҲУРДА У ЁТАР, ҲАММА БИЛСИН
 ТУҒИЛДИ,
 КУЙЛАНГЛАР,
 КУЙЛАНГ ҲАЛЕЛУЯ

[V3]
 АЖОЙИБ, АЖОЙИБ, БУТУН БОРЛИҚ КУЙЛАНГ
 ТУҒИЛДИ ЭМАНУИЛ, ТУҒИЛДИ ШОХ
 НАЖОТКОР,
 О, ҲАЛЕЛУЯ
 О, ҲАЛЕЛУЯ
 АЖОЙИБ

[V4]
 ТУҒИЛДИ ЭМАНУИЛ, ТУҒИЛДИ ШОХ
 НАЖОТКОР,
 О, ҲАЛЕЛУЯ
 О, ҲАЛЕЛУЯ
 АЖОЙИБ</lyrics>
<title>АЖОЙИБ ХУШХАБАР</title>
</song>