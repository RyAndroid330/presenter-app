<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am        C          G  Am
 // Исо булутлардан келяпти!
.Am          C         G     Am
 Ҳар бир кўз Унга кўради, //

[C1]
.     Am          G
   // Унга найза санчганлар ҳам
.  Am         G
   Унга кўз тикади,
.  Am               G
   Дунёнинг жамики халқлари
.  C         G
   У туфайли йиғлайди. //</lyrics>
<key>Am</key>
<aka>Исо Булутлардан Келяпти</aka>
<title>Унга Кўз Тикан</title>
