<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26157</hymn_number>
<title>Муҳаббат</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 // Агар мен инсон ва малак тилларида
.                     Am
 Гапирсаму лек муҳаббатим бўлмаса
.B                                     Em
 Жаранглайдиган мис чолғу занг бўлиб қоламан //

[C1]
.           Am         D
   Муҳаббат сабрли кўнгилчандир
.           B                 Em
   Муҳаббат ҳасад қилмас кеккаймас
.           Am
   Муҳаббат бебошлик қилмас
.             G
   Худбинлик қилмас
.            Am          D
   Ҳар йўлда ишонч ҳосил қилар
.           B        Em
   Ва ҳар шароитда умид сақлар
.      Am      D      G
   Ҳар нарсага тоқат қилар

[V2]
 // Бутун сирлардан агар мен воқиф бўлсам
 Ва тоғларни кўчира олсам мен агар
 Мулкимни тақсимласам муҳаббатсиз ҳеч нарсамасман. //</lyrics>
</song>