<?xml version="1.0" encoding="UTF-8"?><song><key>Bm</key>
<lyrics>[V1]
.   Bm
 // Бир Сенга Тангримиз
.Em
 Илтижо айладик
.Bm    F#     G  F#
 Омонат фоний дунёда
.Bm                Em
 Муқаддас Раббимиз севгингга, раҳмингга
.Bm        F#  Bm
 Меҳрингга ҳамду сано. //

[C1]
.     G                   D
   // Қийналган чоғларда паноҳий мададкор
.  Em        G     D F#
   Нажоткор Сен Раббимиз
.  Bm                 Em
   Нажотли аҳдингга, севгингга, раҳмингга
.  Bm         F#    Bm
   Меҳрингга ҳамду сано //

[V2]
 // Меҳрибон Отамиз, осмонларда мавжуд
 Қудратли ғолибона
 Муқаддас Раббимиз севгингга, раҳмингга
 Меҳрингга ҳамду сано. //</lyrics>
<title>Бир Сенга Тангримиз W15</title>
<author>Һәмра ака</author>
<hymn_number>23</hymn_number>
</song>