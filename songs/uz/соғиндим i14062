<?xml version="1.0" encoding="UTF-8"?><song><title>Соғиндим</title>
<lyrics>[V1]
 // Кечаю кундуз Раббим
 Хаёлимдан сен чиқмайсан //
 // Қўлларимда сенинг каломинг
 Севиб севиб менга гапирасан //

[C1]
   /// Оҳ менинг Раббим
   Тангрим
   Сени жуда кўп соғиндим ///

[V2]
 // Каломларингни мен ўқиганда
 Юрак бағрим мени қувонар //
 // Бир хурсиниб қўйганимда
 Сени соғинганим сезилар //

[B1]
   // Осмонларга термулсам учгим келади
   Сени жамолинга
   Тўйгим келади //

[C2]
   // Оҳ менинг Раббим
   Тангрим
   Сени жуда кўп соғиндим //
   Соғиндим</lyrics>
</song>