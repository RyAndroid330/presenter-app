<?xml version="1.0" encoding="UTF-8"?><song><title>Дарахт кўркин йўқотар Q233</title>
<key>C</key>
<lyrics>[V1]
.   Am      C              G
 // Дарахт кўркин йўқотар баргсиз,
.Am        C       G
 Дарё дарё эмасдир сувсиз.
.Am       C           G
 Бу дунё ҳам қоронғу нурсиз,
.Am          C            G
 Мен ҳам ҳеч ким эмасман Сенсиз. //

[C1]
.     Dm        F           G        Am
   // Севишни ўргатдинг Сен менга, қалбимга,
.  Dm        F         G   Am
   Миннатдорман мен Сендан Исо. //

[V2]
 // Орзуларим армондир Сенсиз,
 Яхшилик ҳам ёмонлик Сенсиз.
 Бу дунё ҳам маъносиз Сенсиз,
 Мен ҳам ҳеч ким эмасман севгингсиз. //</lyrics>
<hymn_number>233</hymn_number>
</song>