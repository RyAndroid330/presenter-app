<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>135</hymn_number>
<title>Шукур, шукур, минг шукур Q135</title>
<key>E</key>
<lyrics>[V1]
.   E        F#m
 // Азиз халқини севган,
. C#m            F#m
 Тинчликни бизга берган //
.   A         Bm
 // Бизларни дуо қилган,
. C#          F#m
 Худога шукур минг шукур! //

[C1]
.     E            F#m
   // Шукур шукур минг шукур
.  C#m
   Худога шукур минг шукур! //

[V2]
 // У бизлар учун келди,
 Ҳамма одамни севди! //
 // Бизлар учун жон берди
 Худога шукур минг шукур! //

[V3]
 // Энди гуноҳ қилмаймиз
 Худойим билан яшаймиз! //
 // Қўшиқ айтиб куйлаймиз
 Худога шукур минг шукур! //

[V4]
 // Ўз халқининг чопони
 Берди бизга Исони! //
 // Олқишлайлик Худони
 Худога шукур минг шукур! //</lyrics>
<aka>Азиз халқини севган</aka>
</song>