<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>149</hymn_number>
<title>Исо Масиҳ Подшоҳимиз Q149</title>
<lyrics>[C1]
.     C                     F             C
   // Исо Масиҳ подшоҳимиз, Исо Масиҳ қудратимиз.
.  C             E        Am       Dm   C
   Исо Масиҳ шуҳратимиз, қурбонлигимиз омин. //

[V1]
.   C                           Dm                 G
 // Осмонда ёзилган исмларимиз, Парвардигорга ташаккур.
.G                  Dm   Am                 C
 Қувонамиз руҳимиз тоза, Парвардигорга ташаккур. //

[C2]
.     C                        F                     C
   // Исо Масиҳнинг муҳаббати, Исо Масиҳнинг куч-қуввати,
.  C                   E   Am     Dm    C
   Исо Масиҳ Муқаддас Руҳи юрагимизда омин. //

[V2]
.   C                            Dm                G
 // Осмонда мукофотимиз буюкдир, Парвардигорга ташаккур.
.G                    Dm    Am                 C
 Севинамиз, руҳимиз баланд, Парвардигорга ташаккур. //

[C3]
.     C                      F                C
   // Исо Масиҳдан ёруғлик, Исо Масиҳдан ғамхўрлик,
.  C                 E     Am     Dm   C
   Исо Масиҳдан ҳақиқатлик ҳаётимизда омин. //

[V3]
.   C                              Dm              G
 // Осмондан тинчлигимизни юборган, Парвардигорга ташаккур.
.G                  Dm     Am                 C
 Берилган Сенинг Ўғлингга, Парвардигорга ташаккур. //

[C4]
.     C                    F               C
   // Исо Масиҳ подшоҳимиз, Исо Масиҳ қудратимиз.
.  C               E     Am        Dm   C
   Исо Масиҳ шуҳратимиз, қурбонлигимиз омин. //</lyrics>
<key>C</key>
</song>