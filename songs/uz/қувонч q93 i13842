<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>93</hymn_number>
<title>Қувонч Q93</title>
<lyrics>[V1]
 // Худо берган севинч нури қалбимиздан сўнмасин, //
 // Худо бизни бошқаради, бизга ёрдам беради. //
 // Мусибатдан қутқаради, бизга қулоқ солади.2 //

[C1]
   //// Қувонч қувонч доим қувонч,
   Тинмай хурсанд бўлайлик.? ////

[V2]
 // Масиҳ изидан борайлик, Унга яқин бўлайлик. //
 // Оғир мушкул остида нобуд бўлиб кетмайлик. //

[V3]
 // Ҳаётбахш имон қувончи қуёшдек порлаб турсин. //
 // Худо бизларни севади,диллар хотиржам бўлсин. //</lyrics>
</song>