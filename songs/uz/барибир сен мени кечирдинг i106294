<?xml version="1.0" encoding="UTF-8"?><song><author>Тимўтий</author>
<title>Барибир Сен мени кечирдинг</title>
<lyrics>[V1]
 // Нега энди Раббим бошқасан
 Нолойиқман Севгинга Сенинг.
 Гуноҳ ботқоғига ботсам ҳам,
 Барибир Сен мени кечирдинг. //

[C1]
   // Нега мени Раббим кечирдинг?
   Ўтмиш ишларини ўчирдинг.
   Севгингга лойиқ бўлмасам ҳам,
   Барибир Сен мени кечирдинг. //

[V2]
 // Бўхтон, ёлғон тилим сўзлайди.
 Юрагимни нафрат қўзғайди.
 Жиркансам ҳам ҳатто ўзимдан,
 Барибир Сен мени кечирдинг / //</lyrics>
</song>