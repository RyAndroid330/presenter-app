<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<lyrics>[V1]
.   Fm         Bbm
 // Умрим узоқ бўлгай десанг,
.C#(Bbm)     Cm(C#)
 Яхши кунлар келгай десанг. //
.Cm         Fm
 Ҳаёт ширин бўлгай десанг,
.Ab         Bbm
 Ҳаёт ширин бўлгай десанг,
.   Cm           C#
 // Яхшилик қил, қил яхшилик.
.Bbm          Cm(Fm)
 Яхшилик қил, қил яхшилик. //

[V2]
.   Fm        Bbm
 // Ёмонларга ғашлик қилма,
.Fm          Bbm
 Бадкирдорга ҳавас қилма. //
.Bbm        C#
 Ёмонликни раво кўрма,
.Cm           Fm
 Яхшилик қил, қил яхшилик.

[B1]
.  Ab          Bbm
   Йўлларингни Худога топшир,
.  Cm           C#
   Бор кучингни Худога топшир.
.  Bbm          C#
   Бор кучингни Исога топшир,
.  Cm           Fm
   Яхшилик қил, қил яхшилик.

[V3]
.Fm         Bbm
 Яхши билан юрсанг яхши,
.Fm       Bbm
 Тинчгина яшасанг яхши.
. Fm         Bbm
 Худо билан бўлсанг, яхши
.Fm         Bbm
 Худо билан юрсанг яхши,
.   Bbm(Cm)      C#(Fm)
 // Яхшилик қил, қил яхшилик. //</lyrics>
<key>Fm</key>
<title>Яхшилик қил, қил яхшилик Q22</title>
</song>