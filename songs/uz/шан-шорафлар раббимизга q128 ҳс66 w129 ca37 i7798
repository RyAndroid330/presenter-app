<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   Em
 // Самовий Отамизга
.C
 Бўлсин доим шон
.F#
 Унинг меҳрибонлиги
.B7        Em
 Бизга бепоён! //

[C1]
.     G            D
   //  Шон-шарафлар Раббимизга!
.  Em       D    G
   Шон-шараф Худога!
.  G          D
   Муқаддас Руҳинг бизга,
.  C     Am      B   B7
   Ёр бўлсин эй, Оминг! //

[V2]
 // Халоскорим Сенга ҳам
 Бўлсин доим шон
 Фақат Сенда нажот топди
 Гуноҳкор инсон! //

[V3]
 // Муқаддас Руҳ Сенга ҳам
 Бўлсин доим шон
 Оғир ҳаёт йўлимизни
 Созлайсан оссон! //</lyrics>
<title>Шан-шорафлар Раббимизга Q128 ҲС66 W129 CA37</title>
