<?xml version="1.0" encoding="UTF-8"?><song><title>Куйлайман</title>
<key>Cm</key>
<lyrics>[V1]
.   Cm                        Bb
 // Дилдан ёзган қўшиғимни куйлайман Сенга Масиҳим,
.Ab                     Fm        Gm
 Нажот эшигин очганга, куйлайман Раббимизга.  //

[C1]
.     Eb                    Ab
   // Мени гуноҳим ювганга, куйлайман мен Унга,
.      Bb         Ab        Fm             Gm
   Мен учун азоб чекканга, куйлайман фақат Унга.  //
.  Ab             Bb    Cm
   Куйлайман, куйлайман.

[V2]
 // Раббим келишинг кутаман, булутлар узра келасан,
 Буюк шон-шуҳрат ила Раббимни мадҳ этаман.  //

[V3]
 // Бир куни бу бевафо дунёнинг умри ҳам сўниб қолар,
 Кўзимдаги ёшим тугаб, жаннат томон йўл оламан.  //</lyrics>
</song>