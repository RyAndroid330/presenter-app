<?xml version="1.0" encoding="UTF-8"?><song><author>Тимўтий</author>
<key>Em</key>
<lyrics>[V1]
.    Em
 // Қудратли Худони севаман.
. Am         Em
 Унга сано айтаман.
. Am          Em
 Тенгсиз буюк ишларини,
. D        Em
 Мадҳиялайман. //

[C1]
.     (Em) Am           Em
   // Биродар, опа-сингилларим,
.   D        Em
   Шодланиб куйланглар.
.   Am          Em
   Хурсанд бўлинглар доимо,
.   D        Em
   Худога ўйнанглар. //

[V2]
 // Унинг синови - марҳамат.
 Севгиси - иноят.
 Излаганга топилган,
 Йўлдир - Ҳақиқат //

[V3]
 // Буюкдир Унинг севгиси.
 Ҳис этиб ўйнайман.
 Ҳузурида абадий.
 Сано куйлайман. //</lyrics>
<title>Куйланглар ва ўйнанглар</title>
</song>