<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>118</hymn_number>
<title>Ғам аламли кунлар йўқолди Q118</title>
<lyrics>[V1]
.   Dm          C
 // Ғам аламли кунлар йўқолди,
.Gm                 Dm
 Озодликдан кўзлар ёшланди. //
.   Gm           C
 // Кўксим ичра кўнглим юмшалди, //
.   F                   Dm
 // Севди мени Худойим танлаб. //

[C1]
.  Gm                   F
   Куйланг, куйланг дўстларим,
.  Gm           C         F
   Нажоткорга куйланг дўстларим.
.  Gm                  F
   Куйланг, куйланг дўстларим,
.     F            C      Dm
   // Севди мени Худойим танлаб. //

[V2]
 // Сен билан менга дуо ёғилган,
 Жаннат эшиклари очилган. //
 // Кўксин ичра кўнглинг юмшалсин, //
 // Севди сени Худойим танлаб. //</lyrics>
<key>F</key>
<aka>Куйланг, куйланг дўстларим</aka>
</song>