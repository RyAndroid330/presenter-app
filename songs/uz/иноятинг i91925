<?xml version="1.0" encoding="UTF-8"?><song><title>Иноятинг</title>
<lyrics>[V1]
.Em              C
 // Иноятинг, марҳаматинг
.Am              D
 Доимо биз билан бўлсин.
.Em                C
 Иноятинг, меҳр-муҳаббатинг
.Am             D
 Доимо орамизда бўлсин. //

[C1]
.     Am           D
   // Бўлсин Сенинг севгинг,
.  Em             C
   Бўлсин Сенинг меҳринг.
.  Am              D
   Юрагимда ёнсин оловинг,
.  Em               C(D)
   Руҳимга келсин илҳоминг. //

[V2]
 // Нажоткорим Сенсан борим,
 Ўзингсан тирик ҳаёт тошим.
 Мени севдинг, курбон бўлдинг,
 Сенга бағишлайман ҳаётим. //</lyrics>
<key>Em</key>
<author>Собир Умуров</author>
</song>