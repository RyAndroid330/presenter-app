<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<author>Һәмра ака</author>
<title>Ватан, осмонда бордир ватан W23</title>
<aka>Ватан</aka>
<key>Dm</key>
<lyrics>[B1]
.  A              Dm   A     Bb   Am
   Осмонларда самовий бор мангу макон
.  A               Dm A   Bb   Am       Gm A
   Муқаддаслар ватани у гўзал, жаннат макон

[V1]
.   Dm                    Gm
 // Ватан, осмонда бордир ватан
.           Bb
 Бу дунёдан афзал
.             A
 Гўзал илоҳий макон //

[V2]
 // Эркин, ватанда ҳамма эркин
 Муҳаббат ва адолат
 Ҳақиқат тантанадир //

[V3]
 // Ватан, осмонда бордир ватан
 Ватанга етмоқ учун
 Бу зиндондан кетмоқ лозим //

[V4]
 // Хурсанд, ватанда ҳамма хурсанд
 Оҳу қилганлар йўқ ҳеч
 Чунки Худо бор жойдир //</lyrics>
</song>