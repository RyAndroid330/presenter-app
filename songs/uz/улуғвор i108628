<?xml version="1.0" encoding="UTF-8"?><song><author>Яşам Килисеси</author>
<title>УЛУҒВОР</title>
<lyrics>[V1]
 ТАХТИНГ ОЛДИДА СЕНИ КУТАМАН,
 ШУҲРАТИНГДА МЕН НИМА СЎЗЛАЙИН?
 АЙТАР СЎЗИМ ШУ: УЛУҒВОР!

[C1]
   ИСО БОКИРАДАН ТУҒИЛГАН,
   ИСО БУ ДУНЁНИ ЯРАТГАН,
   ИСО ҲАМ ТАНГРИ, ҲАМДА ИНСОН,
   УЛУҒВОР!

[C2]
   ИСО ҲЕЧ КИМ СЕНГА ЎХШАМАС,
   ИСО ҲОКИМИЯТЛИГИНГ БИТМАС,
   ИСО СЎЗЛАРИМ МЕНИНГ ЕТМАС,
   УЛУҒВОР!

[V2]
 СЕН МЕН БИЛАНСАН, МЕН УЯЛМАЙМАН
 УМРИМ БЎЙИЧА МИННАТДОР БЎЛАЙИН.
 БЎЛАЙИН МИННАТДОР, УЛУҒВОР</lyrics>
</song>