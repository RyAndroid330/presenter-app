<?xml version="1.0" encoding="UTF-8"?><song><title>Худойим Мени Топди (анъанавий)</title>
<lyrics>[V1]
 // Мен гуноҳни қаърида
 Савоб ишдан нарида //
 Адашгандим барида
 /// Худойим мени топди ///

[V2]
 // Дилдаги эзгу ишим
 Кимгадир керилишим //
 // Гуноҳ эди қилмишим
 Худойим мени топди //
 Худойим мени топди

[V3]
 // Ўз Ўғлини мен учун
 Қурбон қилди ўшал кун //
 // Гуноҳдан поклаб бутун
 Худойим мени топди //

[V4]
 // Хушхабар берди менга
 Барчамизга, ҳам сенга //
 Етказ ёш қари тенгга
 // Худойим мени топди //</lyrics>
<author>Равшан Ҳизиров</author>
</song>