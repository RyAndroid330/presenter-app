<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>76</hymn_number>
<title>Менга келган шубҳаларни Q76</title>
<key>Dm</key>
<lyrics>[V1]
.Dm           A                        Dm
 Менга келган шубҳаларни бартараф қил Худойим,
.   A              Dm          A        Dm
 // Аччиқлик самаралари дилда доғ қолдирмасин. //

[V2]
.A                                       Dm
 Фарзандингман бир зумга ҳам шубҳа мени эзмасин,
.   A                 Dm         A       Dm
 // Сенинг лашкаринг сафида фаол бўлиб юрайин. //

[V3]
.A              Dm     A          Dm
 Мадорсизлигим туфайли даф эт шубҳаларимни,
.    A              Dm           A             Dm
 /// Ўзинг келгин, жангга бошла, бер руҳий ғалабангни. ///</lyrics>
</song>