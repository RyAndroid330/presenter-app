<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Тангримизга шукр, Масиҳ Нажоткорга,
 Ҳамду сано шукр, бизнинг шоҳимизга.
 У қувонч ва ҳаёт, севги ва бахт берган,
 У бизни қутқарди гуноҳлардан. //

[C1]
   // Шон-шарафлар, раҳмат Сенга Масиҳ,
   Шон-шарафлар, Сен Худонинг Ўғли.
   Шон-шарафлар, Парвардигоримиз,
   Шон-шарафлар, Исо Масиҳ. //

[V2]
 // Тангримизга шукр, Масиҳ Нажоткорга,
 Ҳамду сано шукр, бизнинг шоҳимизга.
 У қувонч ва ҳаёт, севги ва бахт берган,
 У бизни қутқарди гуноҳлардан. //

[C2]
   // Муқаддасан Сен муқаддас Масих,
   Муқаддасан Сен Худонинг Ўғли.
   Муқаддасан Парвардигоримиз,
   Муқаддасан Исо Масиҳ. //</lyrics>
<title>Тангримизга шукур Q145 W134</title>
<hymn_number>145</hymn_number>
</song>