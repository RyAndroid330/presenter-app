<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Биродарлар келинглар,
 Қўлларни қўлга беринглар. //
 // Худони мадҳ этайлик эй,
 Исога сано айтайлик. //

[V2]
 // Энди бизлар озодмиз,
 Гуноҳлардан фориғмиз. //
 // Чалиб дутор торни биз эй,
 Худони мадҳ этайлик. //
 // Худони мадҳ этайлик эй,
 Исога сано айтайлик. //

[V3]
 // Келинглар ибодат қилайлик,
 Қалбларга имон тилайлик. //
 Исо билан бўлайлик,
 Худони мадҳ қилайлик.

[V4]
 // Исо танлади бизларни,
 Бизларнию сизларни. //
 Яшнатиб кўнгил созларни,
 Худони мадҳ этайлик.

[V5]
 Яшнатиб қаро кўзларни эй,
 Худони мадҳ қилайлик.
 // Очиб қаро кўзларни эй,
 Худони мадҳ қилайлик. //</lyrics>
<title>Биродарлар келинглар Q124</title>
<hymn_number>124</hymn_number>
</song>