<?xml version="1.0" encoding="UTF-8"?><song><title>Нажот галди</title>
<lyrics>[V1]
.   Cm       Fm           Ab       Gm     Cm
 // Осмондан нажот галди, Худодан хабар галди, //
.   Fm           Ab      Fm         Gm   Cm
 // Инсонларнинқ калбина ярқиллаган нур гелди. //

[C1]
.     Fm                   Ab      Gm     Cm
   // Озодлик йўлин берди, ёруғлик йўлин берди, //
.     Fm                   Ab         Gm
   // Инсонларнинқ калбина ярқиллаган нур гелди. //

[V2]
 // Нур зулматда порлади, зулмат қоплай олмади, //
 // Ҳар наинки от бўлсая Исо билан яралди. //

[V3]
 // Нур боринда юринглар, Унга хизмат этинглар, //
 // Севгисидан тотинглара, Руҳиндан руҳланинглар. //

[V4]
 // Яратганин номидан минг розиман Ўғлидан,
 Берган ёрқин йўлиндана, шодланаман кўнглимдан. //</lyrics>
<key>Cm</key>
</song>