<?xml version="1.0" encoding="UTF-8"?><song><title>Ҳаммадан Буюк Раббим</title>
<lyrics>[C1]
   // Ҳаммадан буюк Раббим Исодир
   Ҳар ишдан муҳим, улуғ Худодир //

[V1]
 // Сени танладим кечиб ўзимдан
 Сенга қарши бўлган қаро кўзлардан //

[V2]
 // Сен борсан, ҳақ Йўлим эй Нажоткорим
 Сенга ишонгайман, йўқ дўст-у ёрим //
 // Шайтон ҳужум қилмас кор қилмас сира
 Сендан воз кечмасман Сен энди жоним //

[V3]
 // Сенга ишонганим учун асрайсан
 Қўлимдан тутасан ташлаб қўймайсан //
 Сен содиқ Дўстимсан, Сен Вафодорим
 // Сени севиб адашмадим суянган тоғим //</lyrics>
</song>