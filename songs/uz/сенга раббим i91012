<author>Собир Умуров</author>
<lyrics>[V1]
.   Em         C  D     Em
 // Оловинг ёнсин юрагимда
.Em         C         D      Em
 Илик булмайин кайнок булай Сенга //

[C1]
.  C                D
   Сенга, Сенга Раббим
.   G             C
   Сенга, Сенга Раббим
.  Am               H7       Em E
   Сенга, Сенга Раббим богланайин
.  C                D
   Сенга, Сенга Раббим
.  G                C
   Сенга, Сенга Раббим
.  Am               H7      Em  E
   Сенга, Сенга Раббим богланайин

[V2]
.   Em             C  D    Em
 // Севгинг тугамасин юрагимда,
.Em         C      D     Em
 Раббим ухшайин севишда Сенга. //

[C2]
.  C                D
   Сенга, Сенга Раббим
.   G               C
   Сенга, Сенга Раббим
.  Am               H7   Em E
   Сенга, Сенга Раббим ухшайин
.  C                D
   Сенга, Сенга Раббим
.   G               C
   Сенга, Сенга Раббим
.  Am               H7     Em
   Сенга, Сенга Раббим ухшайин</lyrics>
<key>Em</key>
<aka>Оловинг Ёнсин Юрагимда</aka>
<title>Сенга Раббим</title>
</song>