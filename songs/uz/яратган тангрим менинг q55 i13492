<?xml version="1.0" encoding="UTF-8"?><song><title>Яратган Тангрим менинг Q55</title>
<key>Ebm</key>
<lyrics>[C1]
.     Abm
   // Яратган Тангрим менинг,
.  F#
   Борлиғинга минг шукур.
.  E
   Ҳар бир кунимда берган,
.  Ebm
   Ризқ-рўзинга минг шукур. //

[V1]
.   Abm      F#        Abm
 // Дардли кунларимда Сени,
.Abm          F#  Abm
 Мен чақирдим Худойим. //
.   Abm               F#
 // Дардимга бир даво бўлиб,
.E          C#m           Ebm
 Келганинга мингдан минг шукур. //

[C2]
   // Яратган Тангрим менинг,
   Борлиғинга минг шукур.
   Ҳар бир кунимда берган,
   Ризқ-рўзинга минг шукур. //

[V2]
 // Ҳақиқатни, Сени танимай,
 Мен дунёдан қидирдим. //
 // Ҳақиқатни менга тўлдириб,
 Берганинга мингдан минг шукур. //</lyrics>
<aka>Шукр</aka>
<hymn_number>55</hymn_number>
</song>