[V2]
 // Нечун, нечун келмайсиз,
 Нечун Худони билмайсиз? //
 // Шунчаликкам бепарвомисиз,
 Вақти келганда йиғлайсиз. //
 Йиғлайсиз.

[V3]
 // Эй одамлар билинглар,
 Худо қучоғига келинглар, //
 // Вақтида қилинглар тавбалар,
 Худо сизларни кечирар. //
 Кечирар.</lyrics>
