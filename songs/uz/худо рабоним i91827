<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22712</hymn_number>
<author>Собир Умуров</author>
<title>Худо Рабоним</title>
<lyrics>[V1]
.   Em          Am
 // Худо олдида менинг қалбим тинч
.H7            Em
 Фақат Ундадир менинг умидим
.Em            Am
 Ҳар дам Унга умид боғлайман
.H7           Em
 Унинг Олдида дилим очаман //

[C1]
.     Em             Am
   // Худодир менинг Паноҳим
.  H7              Em
   Худодир менинг Рабоним
.  Em              Am
   Худодир менинг Қўрғоним
.  H7              Em
   У билан яхшидир умрим //

[V2]
.   Em            Am
 // Худо олдида тинчлан қалбим
.H7            Em
 Удир Нажотим Удир Иззатим
.Em           Am
 Рабни куйла ғамни унутиб
.H7            Em
 Унга ишонгин Уни сен кутиб //</lyrics>
<key>Em</key>
</song>