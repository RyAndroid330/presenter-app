<?xml version="1.0" encoding="UTF-8"?><song><title>Дилларида Худо ўзбегим I</title>
<lyrics>[C1]
   // Дилларида Худо ўзбегим,
   Қўлларида Калом ўзбегим. //
   // Уйларида меҳмон ўзбегим,
   Тилларида Исо ўзбегим. //

[V1]
 // Имонлилар доим нурафшон,
 Имонсизлар қоқилар мудом. //
 // Имонда сиз турингиз бардам,
 Тилларида Худо ўзбегим. //

[C2]
   // Дилларида Худо ўзбегим,
   Қўлларида Калом ўзбегим. //
   // Уйларида меҳмон ўзбегим,
   Тилларида Исо ўзбегим. //

[V2]
 // Имонингиз бўлсин мустаҳкам,
 Шайтонларга йўл берманг ҳеч ҳам. //
 // Ибодатда турингиз бардам,
 Исо билан бўлган ўзбегим. //

[C3]
   // Дилларида Худо ўзбегим,
   Қўлларида Калом ўзбегим. //
   // Уйларида меҳмон ўзбегим,
   Тилларида Исо ўзбегим. //</lyrics>
</song>