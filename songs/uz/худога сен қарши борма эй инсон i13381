<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em                        F
 // Худога сен қарши борма эй инсон,
.F                   Dm        Em
 Худо сўзин эшитгин, эй қалби зиндон. //

[C1]
.     Am                  D        G
   // Яратганга сен қарши бориб эй инсон,
.  Am                D       G
   Ўзингга лаънатлар олма эй инсон.
.  C       Am      Dm       Em
   Ўзингга ёмонлик қилма эй инсон. //

[V2]
.   Em                     F
 // Тавба қилмовчи бу юрак билан,
.F                 Dm         Em
 Қаён кетмоқдасан, қай манзил томон. //

[C2]
.     G                       Am
   // Охиратда жавоб Ўзинг берурсан,
.  C                Dm      Em
   Дўзах азобларин унда кўрурсан. //

[V3]
.Em                   D      G
 Ҳали вақт бор сенда дарҳол ярашгин,

[C3]
.     C(Am)              D(Dm)   G(Em)
   // Ғийбату ёмонликдан юз угир инсон. //
.  Em                  D        G
   Ҳали вақт бор сенда дарҳол ярашгин,

[C4]
.     C          Am      D(Dm)   G(Em)
   // Қалбингга Масиҳни кирит эй инсон. //</lyrics>
<title>Худога сен қарши борма эй инсон</title>
</song>