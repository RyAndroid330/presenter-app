<?xml version="1.0" encoding="UTF-8"?><song><author>Наира Амиркханян</author>
<title>Ишлатгин мени Раб</title>
<lyrics>[V1]
.    Am7    Cmaj7
 Барҳаёт Нажоткор
.   Em           F
 Йўналтир Сен томон
.   Am7      Cmaj7
 Муқаддас Руҳинг-ла
.   Em        F
 Янгилагин мени

[V2]
.     Am7        Cmaj7
 Қўрқмайман, мен энди
.    Em         F
 Чунки Сен ёнимда
.    Am7       Cmaj7
 Тахтингда, пойингда
.   Em         F
 Қиларман илтижо

[C1]
.              F            G
   Ишлатгин мени Раб, борлиғим
.              Em          Am
   Сенга топшираман, ишлатгин!
.              F          G
   Ишлатгин мени Раб, ҳаётим
.                 C
   Топшираман Сенга Раббим!

[V3]
.    Am7       Cmaj7
 Шуҳратим, бойлигим
.    Em           F
 Сенга Раббим, олгин!
.   Am7        Cmaj7
 Мукофот, ютуқларим
.   Em       F
 Сени улағласин

[B1]
.  Am
   Оқладинг Сен, Оқладинг Сен
.            G
   Покман энди!
.   Dm
   Қутқардинг Сен, Қутқардинг Сен
.         Am       G
   Сеникиман! Эгамсан!
.  C
   Ажратолмас, айиролмас,
.             G
   Бизни ҳеч ким!
.       F
   Ошиқман Сенга Раббим,
.         Am G
   Сеникиман!</lyrics>
<key>G</key>
</song>