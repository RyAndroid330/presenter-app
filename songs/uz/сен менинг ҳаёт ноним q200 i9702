<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>200</hymn_number>
<title>Сен менинг ҳаёт ноним Q200</title>
<lyrics>[V1]
 // Сен менинг ҳаёт ноним,
 Меҳрибоним,Чўпоним. //
 // Сенда қувонди жоним, //
 // Меҳрибоним,Чўпоним. //
 Раҳмдил Отажоним.

[V2]
 // Жонажон деб айтдилар,
 Улуғвор деб айтдилар. //
 // Сени хочда қоқдилар, //
 // Меҳрибоним,Чўпоним. //
 Раҳмдил Отажоним.

[V3]
 // Ҳузуримга кел дединг,
 Болам бўлиб юр дединг. //
 // Сўзларимни бил дединг, //
 // Меҳрибоним,Чўпоним. //
 Раҳмдил Отажоним.</lyrics>
</song>