<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>135</hymn_number>
<title>Мадҳия Сенга ҲС53 CA39 W94 ҲСХМ113</title>
<aka>Ота, Севаман Сени</aka>
<lyrics>[V1]
.   D     G
 // Ота, севаман Сени //
.   Em            A
 // Сенга айтгим келади //
. G       D
 Севаман Сени!

[V2]
 // Исо, Севаман Сени //
 // Сенга айтгим келади //
 Севаман Сени!

[C1]
.  Bm       G     D         A
   Мадхия Сенга, Нажоткорим Худо
.  Bm     G    D          A
   Хамду Сано Қутқарувчим Исо!

[V3]
 // Муқаддас Рух, Севаман Сени //
 // Сенга айтгим келади //
 Севаман Сени!

[V4]
 // Ота севаман Сени. //
 // Исо севаман Сени. //
 // Муқаддас Руҳ севаман Сени. //</lyrics>
<key>D</key>
</song>