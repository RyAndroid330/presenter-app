<?xml version="1.0" encoding="UTF-8"?><song><author>Стеве МкФерсон, Джон Эззй, Даниел Грул</author>
<hymn_number>13816</hymn_number>
<title>Исо Сен менинг севгим ҲСХМ99</title>
<lyrics>[V1]
.   G        F#m     B7
 // Исо Сен менинг севгим,
.Em   C               D
 Исо қолдирмайман мен Сени.
.G              F#m      B7
 Зулматдан олиб чиқдинг мени,
.Em   Em7     C           D
 Таянчим менинг ва биламан энди. //

[C1]
.     G         F#m
   // Сенга мен муҳтожман,
.  Em  Em7        C        D
   Севаман Сени, қолдирма мени.
.  G        F#m     B7
   Нажоткор яқин дўстим,
.  Em   Em7       C           D
   Севаман Сени Раббим Исо Раббим. //

[B1]
.       Em/G D      C
   //// Улуғлайман Сени яна ва яна. ////</lyrics>
<key>Em</key>
</song>