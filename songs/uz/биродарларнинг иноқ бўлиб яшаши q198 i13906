<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Биродарларнинг иноқ бўлиб яшаши,
   Мана қандай яхши ва қандай соз. //

[V1]
 Бошга суртилган хушбўй ёғ кабидир у,
 Ва Ҳоруннинг соқолига оқиб тушган.
 Тун ёқасига оқиб тушган мойдек,
 Бошга суртилган хушбўй ёғ кабидир у.

[V2]
 // Сион тепаликларигача тушиб келган,
 Кўҳи Ҳермон шабнами кабидир у. //

[V3]
 // Зеро Сионда Худованд баракатни,
 Абадий ҳаётни амр этган. //</lyrics>
<title>Биродарларнинг иноқ бўлиб яшаши Q198</title>
<hymn_number>198</hymn_number>
</song>