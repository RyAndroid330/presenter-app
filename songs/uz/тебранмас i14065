<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Қуёш ёруғлик ой, юлдузлар қораяр
 Ёмғирли булутлар ўтиб кетар
 Лек Худонинг каломи ҳеч қачон тугамас
 Унга ишонганлар асло тебранмас //

[C1]
   // Тебранмас
   Асло тебранмас
   Тебранмас
   Асло йиқилмас //

[V2]
 // Худо ўғлини кўриб инсон қувонар
 Хатто юлдуз одам ҳам унга тиз чўкар
 Чунки у буюк Худо
 Ҳамма ундан қўрқар
 Ер юзида бутун жонзот унга тиз чўкар //

[C2]
   // Тиз чўкар ҳамма тиз чўкар
   Тиз чўкар ҳамма бош эгар //</lyrics>
<title>Тебранмас</title>
</song>