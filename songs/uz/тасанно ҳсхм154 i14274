<?xml version="1.0" encoding="UTF-8"?><song><author>Хиллсонг, Реубен Морган</author>
<hymn_number>154</hymn_number>
<lyrics>[V1]
.   C         G      C
 // Кучсизлар кучли бўлур,
.    F            Am
 Камбағаллар бой бўлур.
.C         G     C
 Ожизлар нурни кўрур.
.       G       C
 Худо севгиси шудир. //

[C1]
.  G           Am
   Тасанно, тасанно,
.  F           C
   Осмондаги Худога.
.  G           Am
   Тасанно, тасанно,
.  C          G  C
   Қутқарувчи Исога.

[V2]
 // Меҳрингга чўмдиргансан,
 Гуноҳдан оқлагансан.
 Мазмунли ҳаёт бериб,
 Қувончга тўлдиргансан. //</lyrics>
<key>C</key>
<title>Тасанно ҲСХМ154</title>
</song>