<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>49</hymn_number>
<author>Анвар Жўраев</author>
<key>Am</key>
<lyrics>[V1]
.      Am
 // Исо Масиҳ Токнинг Ўзидир,
.   Dm     (E)  Am
 Биз эса Унинг новдаси. //
.         Dm     E    Am
 // Парвардигор Боғбонимиз
.     Dm   E   Am
 Исо Масиҳ томиримиз
.      Dm         E      Am
 Ва Муқаддас Руҳ ҳаёт булоғимиздир. //</lyrics>
<title>Исо Масиҳ Токнинг Ўзидир W49</title>
</song>