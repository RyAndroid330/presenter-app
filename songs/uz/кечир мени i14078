<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<title>Кечир мени</title>
<lyrics>[V1]
 // Кечир мени, кечир мени
 Кечир мени гуноҳимни
 Шавқат қилиб, шавқат қилиб
 О Исо, оқлагин мени //

[C1]
   // Муқаддас қонинг билан
   Муқаддас қонинг билан ювгин //
   О Исо бошим эгаман
   Исо ҳаётим бераман
   // Исо сени севаман //

[V2]
 Кечир мени, кечир мени
 Кечир мени гуноҳимни
 Ювгин мени, оқла мени
 О Исо қўтқаргин мени
 Кечир мени, кечир мени
 Кечир мени гуноҳимни
 Покла мени, ювгин мени
 О Исо қўтқаргин мени

[C2]
   // Муқаддас қонинг билан
   Муқаддас қонинг билан ювгин //
   // О Исо бошим эгаман
   Исо ҳаётим бераман //
   // Исо сени севаман //
   // Муқаддас қонинг билан
   Муқаддас қонинг билан //</lyrics>
</song>