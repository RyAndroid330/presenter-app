<?xml version="1.0" encoding="UTF-8"?><song><author>Магул</author>
<hymn_number>90</hymn_number>
<title>Эй Худо муқадассан ҲС90 Q221</title>
<lyrics>[V1]
.Bm   Em    G    Bm
 Эй Худо муқаддассан,
.        Em  G Bm
 меҳрибонсан Исо

[C1]
.        D    Em     A       Bm
   // Муқаддасман, муқаддас бўл,
.         Em   F#        Bm
   Деган эдинг сўзингда Сен. //

[B1]
.          Em   F#      Bm
   Ёрдам бергин мен Сендек бўлай,
.             Em  F#    Bm
   Сендек мен ҳам меҳрибон бўлай

[C2]
.        D     Em     A      Bm
   // Муқаддасман, муқаддас бўл,
.          Em  F#       Bm
   Деган эдинг сўзингда Сен. //</lyrics>
<key>Bm</key>
</song>