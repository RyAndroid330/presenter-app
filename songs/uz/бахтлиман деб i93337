<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<key>Em</key>
<lyrics>[V1]
.    Em    Am    H     Em
 // Бахтлиман деб ҳаммаларни алдадим
.    C   Am   H    Em
 Лекин юрак ёлғонликдан чарчади
.   Am   D  G  Em
 Шунча яшаб мен Худони билмадим
.    C    Am   H     Em
 Чақирганда овозини эшитмадим //

[C1]
   // Қўлинг билан душманлардан сақладинг
   Қонинг билан гуноҳлардан покладинг
   Мени Сендай бошқа ҳеч ким севмайди
   Фақат Сен билан бўлишни истайман //

[V2]
 // Бу дунёда юрак тинчлик топмади
 Ер бойликлар мени бахтли қилмади
 Гуноҳларим ерга тошдай тортади
 Фақат Худо менга ёрдам беради //

[C2]
   // Қўлинг билан душманлардан сақладинг
   Қонинг билан гуноҳлардан покладинг
   Мени Сендай бошқа ҳеч ким севмайди
   Фақат Сен билан бўлишни истайман //
   // Мени Сендай бошқа ҳеч ким севмайди
   Фақат Сен билан бўлишни истайман //</lyrics>
<title>Бахтлиман деб</title>
</song>