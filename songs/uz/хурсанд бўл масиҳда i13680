<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>225</hymn_number>
<lyrics>[V1]
.   Ebm           B    Bbm Ebm
 // Хурсанд бўл Масиҳда ҳар доим,
.Abm       Bbm          Ebm
 Тоғдай муаммо турганда ҳам. //
.   F#           B      F#
 // Чунки тирик Сенинг Худойинг,
.Abm        Bbm      Ebm
 Сенда бор У берган ғалаба. //

[C1]
.                    B
   // Мен хурсанд бўламан,
.        C#      F#
   Мен хурсанд бўламан
.  Abm    C#    F#
   Бу Худонинг тилаги. //
.  Abm    C#    F#
   Бу Худонинг тилаги.

[V2]
.   F#                  C#
 // Қулоқ солма шайтон сўзига,
.Abm        C#        Ebm
 Шубҳаларга жой берма ҳеч ҳам
.F#              C#
 Ёлғоннинг отаси енгилган.
.Abm        C#         F#
 Имонингда тургин мустаҳкам. //

[C2]
.             B
   // Тургин имонингда,
.    C#    F#
   Тургин имонингда
.  Abm    C#    F#
   Чунки бу сенинг кучинг. //</lyrics>
<key>F#</key>
<aka>Хурсанд Бўл</aka>
<title>Хурсанд бўл Масиҳда</title>
</song>