<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em                     Bm
 // Интиларман Раббим Сен томонга доим
. C                   G
 Муқаддасимсан менинг Раббимсан менинг
. Em              Bm
 Самодаги порлоқ қуёшдан ҳам ёрқинроқ
. C                    G
 Сенинг севгинг нажот берар бизга //

[V2]
 // Саҳроимда менинг битмас булоғим
 Йўлларимдаги ўчмас бўлган чироғим
 Зулматларда нур Ўзинг тунларимда кун Ўзинг
 Раббимсан фақат Ўзинг, Исо улуғлайман! //

[V3]
 // Ўрнакдир менга Ўзинг Раббим ҳар айтган Сўзинг
 Кўрмоқ истайман Юзинг Муқаддасимсан
 Бу ўткинчи дунёда излаб яшайман Сени
 Топганим бу рўёда Ҳақиқатим Сен Ўзинг //</lyrics>
<key>Em</key>
<title>Юрак қўшиғи</title>
<author>Улуғбек Жўраев</author>
</song>