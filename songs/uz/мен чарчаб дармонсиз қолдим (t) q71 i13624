<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<title>Мен чарчаб дармонсиз қолдим (T) Q71</title>
<lyrics>[V1]
 // Мен чарчаб дармонсиз қолдим,
 Ё, Раббим сенга келдим! //
 // Ё, Раббим сенга келдим,
 Жонсиз руҳим қўллагин! //

[V2]
 // Дилимга тинчлик бергин,
 Меҳринг билан сақлагин! //
 // Ё, Раббим сенга келдим,
 Жонсиз руҳим қўллагин! //

[V3]
 // Бахтсиз дунёда яшаб,
 Ором қайерда, топмадим. //
 // Ё, Раббим сенга келдим,
 Жонсиз руҳим қўллагин! //

[V4]
 // Амрингни бажаришимга
 Йордам бер ҳаётимда! //
 Муҳаббат қанотларингда
 Оборасан Самога!
 // Ё, Раббим сенга келдим
 Жонсиз руҳим қўллагин! //
 // Жонсиз руҳим қўллагин! //</lyrics>
</song>