<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em               Am
 Эгамиз меҳрибон одилдир
.D         G
 Худойимиз раҳимдилдир
.C             Am
 Эгамиз содда инсонларни
.   H
 // Ҳимоя қилар //

[C1]
.  Em          Am
   Хаф-хатарда қолганингда
.      D        G
   /// Худо сен билан ///
.  C          Am
   Худо билан бўлганингда
.      H
   /// Жонинг хотиржам ///

[V2]
.Em            Am
 Эгам жонимни ўлимдан қутқарар
.D           G
 Қўзларимни ёш тўкишдан
.C          Am
 Оёқларимни қоқилишдан
.   H
 // Эгам қутқарар //</lyrics>
<key>Em</key>
<title>Худо Сен Билан</title>
<hymn_number>23183</hymn_number>
<author>Собир Умуров</author>
</song>