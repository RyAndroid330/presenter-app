<?xml version="1.0" encoding="UTF-8"?><song><title>Юрагинг Оч</title>
<lyrics>[V1]
 // Юрагинг оч Қувончга тўлсин
 Чунки Раббим сен билан //
 // Зулмат енга олмас сени
 Раббим нур сочди унда
 Хочда кўрсатиб севги изҳорин
 Нажот берди сену менга //
 Юрагинг оч Қувончга тўлсин
 Чунки Раббим сен билан</lyrics>
</song>