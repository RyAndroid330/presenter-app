<?xml version="1.0" encoding="UTF-8"?><song><author>Улуғбек Жўраев</author>
<lyrics>[C1]
   // Жоним ёлғиз Тангрида
   Ором топар
   Нажот Ундан келар
   Фақат У Қоям, Нажотим менинг
   Қалъам Удир
   Тебранмасман асло
   Жоним ёлғиз Тангрида
   Ором топар //

[V1]
 // Қалбим эрир ичимда
 У тегинса менга
 Кўзларим кўрмаса ҳам
 Борлигинг яқин менга
 Бир кун келасан шуҳрат-ла, булутларла
 Юрагим Сенга интиқ
 Кутяпман кел Раб Исо //</lyrics>
<title>Жоним ёлғиз Тангрида</title>
</song>