<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Қандайин рози этайин мен Сени Раббий?
 Бир куни охират эшик қоқади. //
 // Оч бугун қиёмат соатинг десанг о Раббий,
 Гуноҳкор бу қалбим қайга чопади? //

[V2]
 // Сўрамассан не единг,ичдинг,кийдинг
 Қай юртлар кездинг қанча дўстларинг? //
 // Дунёнинг шоҳимисан султони ким,
 Саройин,қасрию қизиқмас Эгам. //

[C1]
   // Қандайин рози этайин мен Сени Раббий?
   Бир куни охират эшик қоқади. //
   // Оч бугун қиёмат соатинг десанг о Раббий,
   Гуноҳкор қалбим қайга чопади? //

[V3]
 // О Раббий Ўзингсан бошпанам,қоям,
 Адолатда тенги йўқ солиҳ Эгам. //
 // Қутқарган бу руҳинг имлаб ўтмасин жон Раббий,
 Имконим бер Сенга қилайин хизмат. //</lyrics>
<title>Қандайин роз этай Q90</title>
