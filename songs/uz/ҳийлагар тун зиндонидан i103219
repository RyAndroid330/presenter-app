<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>282</hymn_number>
<key>G</key>
<lyrics>[V1]
.   G                        D       Bm
 // Ҳийлагар тун зиндонидан, озодлик равшанига
.Em            G            D
 Муқаддас Руҳ, бошла мени доим //

[C1]
.     Bm
   // Муқаддас Руҳ бу дунёдан
.  G             D
   Тор йўл билан мангу ҳаёт
.  Em          G            D
   Осмон томон бошла мени доим //

[V2]
.   G                   D          Bm
 // Дунё васваса синов, мукаммал имон таянч
.Em            G            D
 Камолот илоҳ, Каломида ҳикмат //</lyrics>
<title>Ҳийлагар тун зиндонидан</title>
</song>