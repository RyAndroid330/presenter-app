<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.   Cm        Fm
 // Осмондан нажот келди,
. Ab      Gm
 Худодан хабар келди.  //
.   Fm             Ab
 // Инсонларнинг калбина
.  Fm          Gm   Cm
 ярқираган нур келди.  //

[C1]
.     Fm
   // Озодлик йўлин берди,
.  Ab            Gm   Cm
   ёруғлик йўлин берди.  //
.     Fm
   // Инсонларнинг калбина
.  Ab            Gm  Cm
   ярқираган нур келди.  //

[V2]
 // Нур зулматда порлади,
 зулмат қоплай олмади.  //
 // Ҳар наинки от бўлсая
 Исо билан яралди.  //

[V3]
 // Нур боринда юринглар,
 Унга хизмат этинглар.  //
 // Севгисидан тотинглара
 руҳиндан руҳланинглар.  //

[V4]
 // Яратганнинг номидан
 мен розиман Ўғлидан,
 Берган ёрқин йўлидан
 шодланаман кўнглимдан.  //</lyrics>
<title>Осмондан нажот келди Q167</title>
<hymn_number>167</hymn_number>
</song>