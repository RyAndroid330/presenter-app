<?xml version="1.0" encoding="UTF-8"?><song><author>Малоҳат Пулатова</author>
<hymn_number>61</hymn_number>
<aka>Юрагим билан</aka>
<key>D</key>
<lyrics>[V1]
.   D                   A
 // Буюк тахтинг олдига келаман,
.Bm                     G  A
 Шуҳратингни ёғдиргин Худойим!
.D                   A
 Сенга, яқин бўлишни истайман,
.Bm                     G  A
 Шуҳратингни ёғдиргин Худойим! //

[C1]
.              D           A
   // Юрагим билан, Сенга ишонаман!
.           Em   G        Bm  A
   Юрагим билан, мен Сени севаман!
.           D            A
   Юрагим билан, Сенга интиламан!
.           Em   G        Bm   A
   Юрагим билан, мен Сени излайман! //</lyrics>
<title>Буюк тахтинг олдига келаман Q61</title>
</song>