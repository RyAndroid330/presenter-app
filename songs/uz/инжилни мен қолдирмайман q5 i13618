<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>5</hymn_number>
<aka>Абадий қолдирмайман Инжили Шарифни</aka>
<key>F#m</key>
<lyrics>[V1]
.   F#m    D            Em       F#m
 // Абадий қолдирмайман Инжил шарифни, //
.   Bm                   Em          F#m
 // Ундан халос бўлганман ташлаб гуноҳларимни. //

[C1]
.  Bm         A         G       Em         F#m
   Ҳеч қачон, ҳеч қачон Инжилни мен қолдирмайман.
.  Bm         A         G       Em         F#m
   Ҳеч қачон, ҳеч қачон Инжилни мен қолдирмайман.

[V2]
 // Мен васвасага тушсам У ёритар мени, //
 // Душманлар таҳдид қилса, ғолиб қилур мени. //

[V3]
 // Агар йўлда адашсам ҳаёт ўрмонида, //
 // Менга ёрдам беради, далда бериб йўлда. //

[V4]
 // Унга мен ишонганман, Унда бор чин ёруғ, //
 // Ундан ҳаёт топганман, оламда тенги йўқ. //</lyrics>
<title>Инжилни мен қолдирмайман Q5</title>
</song>