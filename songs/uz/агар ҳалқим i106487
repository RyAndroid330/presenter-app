<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Агар ҳалқим бўйнин эгиб
 Юзимни изласа,
 Агар ҳалқим бўйин эгиб
 Гуноҳлардан қайтса
 Осмондан эштиб, ва раҳм қилиб,
 Шифолайман ерини.
 Агар ҳалқим юзимни изласа. //

[C1]
   // Сен йўлимсан,
   Ҳақиқатим
   Ҳаётимнинг ёруғлиги. //
   // Муқаддас олов бизга келсин,
   Юракларни ёндир Худо.
   Муқаддас олов бизга келсин,
   Юракларни ёндир Худо. //

[V2]
 // Осмондаги Отамиз
 Номинг улуғлансин,
 Осмондаги Отамиз
 Сенинг шоҳлигинг келсин.
 Сенинг ироданг осмондагидек,
 Ерда ҳам бажо бўлсин.
 Барча хокимият ва куч-кудрат Сенда. // .
 Ёндир Худо...</lyrics>
<title>Агар ҳалқим</title>
<author>Ырысай Табышева</author>
</song>