<?xml version="1.0" encoding="UTF-8"?><song><title>Тунлари Q33</title>
<lyrics>[V1]
 // Тунлари осмонга термилиб,
 Масиҳни соғиниб йиғлайман. //
 // Гоҳида ўйласам азобин,
 Қоронғу дунёга сиғмайман. //

[C1]
   // Шу сабаб йиғлайман қон-қон,
   Осмон ҳам йиғлади ўша он. //
   Отам ҳам йиғлади ўша он.
   // Тикандан тож кийди, ким учун?
   Мен учун, Сен учун, Биз учун. //

[V2]
 // Хочда У жон берди, ким учун?
 Мен учун, Сен учун, Биз учун. //
 // Маъбадда пардалар йиртилди,
 Ер-юзи ларзага келтирди. //
 // Уч кунда Исони тирилтирди, кечирди.
 Гуноҳим кечир деб йиғлайман. //</lyrics>
<hymn_number>33</hymn_number>
</song>