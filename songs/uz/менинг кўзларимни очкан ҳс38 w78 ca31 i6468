<?xml version="1.0" encoding="UTF-8"?><song><aka>Исо - Жоним менинг</aka>
<lyrics>[V1]
.   Em
 // Менинг кўзларимни очган,
.                    Am
 Менга порлоқ нурин сочган,
.Am               C
 Ундан иблис ҳам қочган,
.C              B7
 Исо - Худонинг Ўғли. //

[C1]
.     Em       Am
   // Исо - жоним менинг,
.                G
   Исо - танам менинг,
.  C                Am
   Ҳаётим - Ноним менинг.
.  B7           Em
   Исо - жоним менинг. //

[V2]
 // Мени Ўз бағрига олган,
 Менга Муқаддас Руҳ берган,
 Мен билан абадий қолган,
 Исо - Худонинг Ўғли. //</lyrics>
<key>Em</key>
<title>Менинг кўзларимни очкан ҲС38 W78 CA31</title>
<hymn_number>38</hymn_number>
</song>