<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>207</hymn_number>
<title>Менга берган ҳаётинг учун ҲСХМ207 Q227</title>
<lyrics>[V1]
.   C#m                   F#m
 // Менга берган ҳаётинг учун,
.G#          G#7      C#m/G#
 Мен Сенга нима бера оламан?
.   C#m                  F#m
 Менга қилган ғамхўрлик учун,
.G#          G#7      C#m
 Мен Сенга нима қила оламан? //

[P1]
.     C#m      F#m
   // Фақат куйлайман мен Сени,
.         C#m
   Ва улуғлайман мен Сени,
.            G#         G#7     C#m/C#7
   Ва, раҳматлар мен Сенга айтаман! //

[C1]
.     C#m/C#7                      F#m
   //  Раҳмат Сенга - Ота, Ўғлинг учун!
.     B7                       E   C#m
   Раҳмат Сенга - Исо, қонинг учун!
.     A                           F#m
   Раҳмат - Муқаддас Руҳ, кучинг учун!
.     A               B7
   Раҳмат Сенга - Тангрим,
.            E         C#m
   Раҳмат Сенга - Тангрим! //</lyrics>
<key>E</key>
</song>