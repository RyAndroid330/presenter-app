<?xml version="1.0" encoding="UTF-8"?><song><title>Миннатдорман (анъанавий) Q125</title>
<lyrics>[V1]
 // Миннатдорман мени яратганингга,
 Қоронғуликлардан чақирганингга. //
 // Миннатдорман кучу қудратларингга,
 Улуғ сўзларингга, раҳматларингга. //

[C1]
   Оҳ Оллоҳим,Оллоҳим, азиз Оллоҳим,
   Оҳ Оллоҳим,Оллоҳим, улуғ Оллоҳим.

[V2]
 // Миннатдорман Сенинг улуғ севгингга,
 Миннатдорман Сенинг улуғ қонингга. //
 // Миннатдорман ҳаёт нафасинг учун,
 Мусибатли кунлар курашинг учун. //

[V3]
 // Миннатдорман осмондаги жаннатинг учун,
 Бир умрга абадий ҳаётинг учун. //
 // Миннатдорман мени яратганингга,
 Қоронғуликлардан чақирганингга. //</lyrics>
<hymn_number>125</hymn_number>
</song>