<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em                   C
 Осмонда фаришталар куйлар
.G                     D
 Ерда ҳам бутун жонзот куйлар

[B1]
.  Em
   Унинг буюклигини
.  C
   Унинг Шоҳлилигини
.  G
   Унинг Севгилигини
.  D
   Унинг Ҳақлилигини

[C1]
.  Em     C
   Ҳаллелуйя!
.  G      D
   Ҳаллелуйя!</lyrics>
<title>Осмонда Фаришталар Куйлар</title>
<author>Собир Умуров</author>
<hymn_number>16450</hymn_number>
</song>