<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D        G         A        D
 // Чўпонлар келмоқда, хабар бермоқда, //
.   D         G       A       D
 // Довуднинг шаҳрида Масиҳ туғилди. //

[C1]
.     G         D       G       D
   // Байтлаҳм шаҳрида, охурда ётади,
.    D         G         A      D
   Севининг, севининг Масиҳ туғилди. //

[V2]
 // Марямнинг, Юсуфнинг чексиз қувончи, //
 // Фаришталар осмонда куйлар қўшиқлар. //

[V3]
 // Айтинг бу хабарни бутун дунёга, //
 // Гуноҳни кечирган Қутқарувчимиз. //</lyrics>
<title>Чўпонлар келмоқда</title>
</song>