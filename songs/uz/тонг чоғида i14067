<?xml version="1.0" encoding="UTF-8"?><song><title>Тонг Чоғида</title>
<lyrics>[V1]
 // Тонг чоғида эрта туриб
 Тиз чўкаман мен уйимда
 Сенга боқиб ёлвораман
 Нажоткорим кел дея //

[C1]
   // Севаман Сени Исо
   Севаман Сени Худо //
   Муқаддас Рух севаман
   Сени Сени Сени
   // Севаман Сени Исо
   Севаман Сени Худо //
   Муқаддас Рух севаман Сени
   Муқаддас Рух севаман Сени

[V2]
 // Бош эгаман таъзим қиламан
 Тўккан қонинга покланаман
 Сенга боқиб ёлвораман
 Нажоткорим кел дея //

[V3]
 // Раббим сени соғинаман
 Нурли покли жамолингни
 Сенга боқиб ёлвораман
 Нажоткорим кел дея //</lyrics>
</song>