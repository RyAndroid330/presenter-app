<?xml version="1.0" encoding="UTF-8"?><song><author>Дон Моен, Паул Кыле</author>
<hymn_number>65</hymn_number>
<aka>Раббим Эгамизсан</aka>
<lyrics>[V1]
.G             Em   C
 Раббим (Исо) Эгамизсан,
.     Am     D
 бу ерга келгин,
.Em         Bm
 Бизнинг орамизга,
.C        Am         D
 бизнинг мақтовларни олгин!

[C1]
.  G      Em   C
   Сени улуғлаймиз,!
.       D   G  Em
   Сени улуғлаймиз,!
.  C     D   G  Em
   Сени улуғлаймиз,!
.           C          D   G
   Келгин Раббим (Исо) тахтингга!</lyrics>
<key>G</key>
<title>Исо Эгамизсан ҲС19 W32</title>
</song>