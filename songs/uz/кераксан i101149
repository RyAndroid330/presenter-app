<?xml version="1.0" encoding="UTF-8"?><song><title>Кераксан</title>
<lyrics>[V1]
 // Эшит мени дардимни
 Қулоқ тутгин оҳимга
 Нолаю фарёдимга Ота
 Фақат Сенсан суянганим ишонганим умидим
 Бордир мени ўтинчим Ота //

[C1]
   Кераксан Сен менга
   Кераксан Сен менга
   Дилимга дармонсан
   Сен Ота, Сен Ота

[V2]
 // Фиғоним изтиробим юрагим оғриганда
 Ягона юпатувчим Ота
 Кўз ёшларим артарсан
 Бағринга Сен босарсан
 Фақат Сен мен билансан Ота. //

[V3]
.Am Dm E Am F Am C E
 Аккорд</lyrics>
<key>Am</key>
<author>СалимаБукҳара</author>
</song>