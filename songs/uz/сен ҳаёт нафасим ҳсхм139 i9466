<?xml version="1.0" encoding="UTF-8"?><song><title>Сен Ҳаёт Нафасим ҲСХМ139</title>
<lyrics>[V1]
.   G        C       G
 //  Сен ҳаёт нафасим!
.        C       G
 Сен ҳаёт нафасим!
.  D      Em   C   D
 Сенинг севгинг яшар менда! //

[C1]
.     G D Em D    C  D
   // Сенга  ташна юрагим!
.    G D Em D     C  D
   Сенсиз нобуд юрагим! //

[V2]
 // Сен ҳар кунги ноним!
 Сен ҳар кунги ноним!
 Сенинг сўзинг яшар менда! //

[B1]
.      D        C/Asus/D
   ///  Ташно юрагим!
.  D        C/Asus/D
    Нобуд юрагим! ///</lyrics>
<key>G</key>
