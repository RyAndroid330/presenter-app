<?xml version="1.0" encoding="UTF-8"?><song><title>Эркин, эркин, мен эркин ҲС89</title>
<key>Am</key>
<lyrics>[V1]
.Am
 Эркин, эркин, мен эркин
.Dm                 Am
 Шайтоннинг қуллигидан
.E
 Берилган мен учун қурбонлик
.                    Am
 Эркин, эркин, мен эркин

[C1]
.     Dm
   // Халос, халос бўлганман
.  Am
   Қулликдан мен қутулганман
.  E
   Мен учун Тангри тўкди қонин //
.                     Am
   Эркин, эркин, мен эркин

[V2]
 Эркин, эркин, мен эркин
 Гуноҳнинг занжиридан
 Раб Исонинг қони билан
 Эркин, эркин, мен эркин</lyrics>
<hymn_number>89</hymn_number>
<author>Илияс Турсун</author>
</song>