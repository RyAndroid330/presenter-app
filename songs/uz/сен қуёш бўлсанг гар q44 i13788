<?xml version="1.0" encoding="UTF-8"?><song><title>Сен қуёш бўлсанг гар Q44</title>
<lyrics>[V1]
 // Сен қуёш бўлсанг агар, оламни ёритган.
 Сенга интилган ўзим Ман!
 Сен булоқ бўлсанг агар, оламни яшнатган.
 Сенга ташна кўнгил Ман! //

[C1]
   // Сен ва Мен Исо ажралмас дўстмиз,
   Менинг Раббим, Менинг Худойим! //

[V2]
 // Сен осмон бўлсанг агар,оламни қоплаган.
 Сенга порлаган юлдузман!
 Сен абадий Худосан, хаммага жон берган.
 Ишқингда юрган қулингман. //</lyrics>
<hymn_number>44</hymn_number>
</song>