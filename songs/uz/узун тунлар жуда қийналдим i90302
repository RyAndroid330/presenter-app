<?xml version="1.0" encoding="UTF-8"?><song><aka>Дардим тингла</aka>
<lyrics>[V1]
 // Узун тунлар жуда қийналдим
 Баъзида сендан тондим //
 // Фақат сенга сенга ишондим
 Раббим менинг дардим тингла //
 // Кўп ёғилди туҳмат тошлари
 Юзим ювди кўзим ёшлари //
 // Шунда билдим бағритошларни
 Раббим менинг дардим тингла //

[V2]
 Қийин кунлар, бу кунлар ўтар
 Ёмонликлар олислаб кетар
 // Ҳеч бўлмасин тана тошлари
 Энди оқмас кўзим ёшлари //
 Йўқолмасин топган имонлар
 Узиламасин аҳд-у паймонлар
 Яксон бўлсин уша шайтонлар
 // Раббим менинг дардим тингла //</lyrics>
<title>Узун тунлар жуда қийналдим</title>
</song>