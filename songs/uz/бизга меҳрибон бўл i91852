<?xml version="1.0" encoding="UTF-8"?><song><title>Бизга меҳрибон бўл</title>
<aka>Гўзаллигинг</aka>
<lyrics>[V1]
.   Em                Am
 // Бизга меҳрибон бўл, бўл Эй Худо
.B                 Em
 Бизни дуо қилгин Эй Эгам Худо
.Em                  Am
 Мунаввар Юзингни яна, яна бир бор
.B                   Em(B)
 Устимизга порлатгин Сен Раббим Исо //

[C1]
.     Em       Am
   // Гўзаллигинг буюклигинг
.  B              Em
   Ер юзига шодлик олиб келсин
.  Em         Am
   Гўзаллигинг юксаклигинг
.  B              Em(B)
   Бутун ер юзида намоён бўлсин //

[V2]
 // Ер юзи бўйлаб Сенинг Эй Эгам Худо
 Роҳинг маълум бўлсин Эй Раббим Исо
 Барча халқлар Сени севиб Сени билсин
 Сенинг нажотингга Эй Худо эришсин. //</lyrics>
<key>Em</key>
</song>