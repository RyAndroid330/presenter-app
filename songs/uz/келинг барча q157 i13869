<?xml version="1.0" encoding="UTF-8"?><song><title>Келинг барча Q157</title>
<lyrics>[V1]
 // Келинг барча инсонлар,
 Масиҳ сўзин эшитинг. //
 // Худо номин олқишлаб эй,
 Ҳамду сано билдиринг. //

[C1]
   // Осмонга йўл Масиҳдур,
   Ҳаёт берган Масиҳдур. //
   // Қувонч берган Масиҳдур,
   Жаннатга йўл Масиҳдур. //

[V2]
 // Мададкорим Худойим,
 Муқаддас қон тўкибсан. //
 // Олқиш сўзга лойиқсан,
 Бизлар учун ўлибсан. //

[V3]
 // Қурбон бўлиб ўлибсан,
 Гуноҳларни кўмибсан. //
 // Сўнг қайтадан тирилиб,
 Инсонга бахт берибсан. //</lyrics>
<hymn_number>157</hymn_number>
</song>