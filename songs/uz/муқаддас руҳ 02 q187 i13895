<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Муқаддас Руҳ юракларни нуринг билан ёритгин, //
 // Оламнинг зулматини Сен севгинг билан тўлдиргин. //

[C1]
   Улуғлаймиз, улуғлаймиз Раббимизни улуғлаймиз.
   Олқишлаймиз, олқишлаймиз Худовандни олқишлаймиз.
   Улуғлаймиз, улуғлаймиз Худовандни олқишлаймиз.

[V2]
 // Энди бизнинг дилимизда Ўзинг макон яратгин , //
 // Нурли олов бўлиб ёнгин қалбимизга жойлашгин. //

[V3]
 // Муқаддас Руҳ қудратингла содиқларга куч бергин, //
 // Жамоатинг тиклагин, ўзбек халқинг уйғотгин. //</lyrics>
<title>Муқаддас Руҳ 02 Q187</title>
