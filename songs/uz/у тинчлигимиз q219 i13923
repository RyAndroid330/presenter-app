<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>219</hymn_number>
<title>У тинчлигимиз Q219</title>
<key>Cm</key>
<lyrics>[C1]
.     Cm        Fm
   // У тинчлигимиз,
.  Cm        Fm
   У тинчлигимиз,
.  G                     Cm
   тўсиқ деворни қулатди Исо. //

[V1]
.   Eb             Fm
 // Унга беринг ташвишни,
.Eb            Cm
 ёрдам берар У сизга. //

[C2]
.     Cm        Fm
   // У тинчлигимиз,
.  Cm        Fm
   У тинчлигимиз,
.  G                     Cm
   тўсиқ деворни қулатди Исо. //

[C3]
   // У тинчлигимиз,
   У тинчлигимиз,
   касалларимизни олди Исо. //

[V2]
 // Унга беринг касалларни
 шифо берар У сизга. //

[C4]
   // У тинчлигимиз,
   У тинчлигимиз,
   касалларимизни олди Исо. //

[V3]
 // Унга беринг ҳаётингизни
 нажот берар У сизга. //

[C5]
   // У тинчлигимиз,
   У тинчлигимиз,
   тўсиқ деворни қулатди Исо. //</lyrics>
</song>