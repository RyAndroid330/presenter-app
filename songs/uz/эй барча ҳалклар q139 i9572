<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>139</hymn_number>
<author>Зафар</author>
<title>Эй барча ҳалклар Q139</title>
<lyrics>[V1]
.   F#m
 // Ей, барча халқлар,
. Bm         F#m  E      F#m
 Худовандни мадҳ қилинглар! //
.                E         F#m
 // Унга ҳамду - сано айтинглар
.B#m       F#m E F#m
 Эй, бутун миллатлар! //

[C1]
.     F#m             Bm
   // Ҳамдлар бўлсин! Ҳамдлар бўлсин!
.   F#m E     F#m
   Ҳамдлар бўлсин! //

[V2]
.   F#m                        E    F#m
 // Унинг бизга берган инояти беҳаддир! //
 // Абадийдур Худованднинг
.         E    F#m
 Вафосию ҳақиқати! //

[C2]
   // Ҳамдлар бўлсин! Ҳамдлар бўлсин!
   Ҳамдлар бўлсин! //
   Ҳамдлар бўлсин! Ҳамдлар бўлсин!</lyrics>
<key>F#m</key>
</song>