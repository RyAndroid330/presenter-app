<?xml version="1.0" encoding="UTF-8"?><song><title>Меҳрибонлик Тушар ҲСХМ110</title>
<key>Eb</key>
<lyrics>[V1]
.   Eb      Fm    Eb    Bb
 // Меҳрибонлик тушар, тушар,
.Eb      Fm      Eb     Bb
 Меҳрибонлик баҳорги ёмғирдай,
.Eb      Fm        Em    Bb  Eb  Fm Eb B
 Меҳрибонлик мени ўраб олади. //

[C1]
.     Eb         Fm         Bb
   // Ҳей хоу, меҳрибонлик билан,
.  Eb       Fm      Bb
   Ҳей хоу инояти билан,
.  Eb        Fm           Bb  Eb
   Ҳей хоу абадий рақсга тушаман. //
.      Eb      Fm     Bb   Eb
   /// Халелу-халелу, ҳаллелуя. ///</lyrics>
