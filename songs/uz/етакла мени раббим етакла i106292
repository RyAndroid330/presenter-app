<?xml version="1.0" encoding="UTF-8"?><song><author>Тимўтий</author>
<title>Етакла мени Раббим етакла</title>
<lyrics>[V1]
.Em D Am H7 Em
 -__
.D  H7 Em
 -__
 // Сен билан мен бўлишни жуда хоҳлайман.
 Ёқимли ҳар ўтган вақтим.
 Сўзларингни қалбимда мангу сақлайман.
 Фақат Исо Сен менга боқдинг. //

[C1]
   // Етакла, доим етакла.
   Ҳар куни Раббим етакла. //

[V2]
 // Дунё иши қоронғу ва қўрқинчли.
 Нуринг берар ёруғлик.
 Ҳар қадамда ўлим пойлар йўлимни.
 Ҳаёт Сенда Раббим мангулик. //</lyrics>
<key>Em</key>
</song>