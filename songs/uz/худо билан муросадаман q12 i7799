<?xml version="1.0" encoding="UTF-8"?><song><title>Худо билан муросадаман Q12</title>
<key>C#m</key>
<lyrics>[C1]
.     E               (G#)
   // Худо билан муросадаман
.  F#m(A)    B      E
   Жаннат эшиги очилган. //
.     A                      C#m
   // Қандай беҳад бойлигим бор
.  F#m        B       E
   Мақсадга эга бўлганман! //
.     A                    C#m
   // Менинг жоним ором топган
.  F#m         B       E
   Менга уни Раббим берган! //

[V1]
.   A
 // Менинг дилим қолмас хасратда
.               B
 Худога мен ишонаман! //
.   B
 // Менинг маконим самода
.                      E
 Бу дунёда мангу эллатдаман! //
.   B                   C#m
 // Менинг жоним ором топган
.F#m         B       E
 Менга уни Раббим берган! //

[V2]
.E                   G#
 Ноҳақликка курашиб турсам,
.A          B      E
 Ўзи менга ёрдам беради
.E
 Раббимнинг азиз иродаси
.A           B        E
 Доим менинг иродам бўлсин
.   E
 // Менинг жоним ором топган
.A          B       E
 Менга уни Раббим берган! //

[C2]
   // Худо билан муросадаман
   Жаннат эшиги очилган. //
   // Қандай беҳад бойлигим бор
   Мақсадга эга бўлганман! //</lyrics>
<hymn_number>12</hymn_number>
</song>