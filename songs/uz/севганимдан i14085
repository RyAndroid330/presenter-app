<?xml version="1.0" encoding="UTF-8"?><song><title>Севганимдан</title>
<lyrics>[V1]
 // Қарсак чаламан Раббимга қўшиқ айтаман
 Унинг номини тинмай шеърга битаман
 Шодланаман Раббимни улуғлаганимда
 Ўйнаб куламан Раббимни севганимдан //

[C1]
   // Севганимда унинг номини кўйлайман
   Севганимдан уни улуғлайман
   Севганимда унинг номини кўйлайман
   Севганимдан уни улуғлайман //

[V2]
 // Келинг дўстлар биргалашиб ўйнаб куйлайлик
 Қарсак чалиб ўйин кулгу ҳозир қилайлик
 Раббим мени севади сизни ҳам худди шундай
 Ўз қувончини беради сизга севганимдан //</lyrics>
</song>