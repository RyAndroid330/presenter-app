<?xml version="1.0" encoding="UTF-8"?><song><title>Ҳудованднинг Руҳи Q195</title>
<key>Bm</key>
<lyrics>[V1]
.   Bm                      Em
 // Худованднинг Руҳи Менга ёр,
.F#                      Bm
 У Мени муқаддас мойила мойлади.
.Bm                         Em
 Бечораларга мужда етказмоқ учун,
.F#                        Em
 Дилабгорларга шифо бермоқ учун,
.Em        F#      Bm
 Худованд мени юборди,
.Em       F#                Bm
 Худованд сизни (бизни) юборди. //

[V2]
.   Bm
 Асирга озод бўл деб,
.                       A      F#
 Басирга очилсин кўзинг демоқ учун
.F#              Bm
 Худованд мени юборди.
.   Bm
 Асирга озод бўл деб,
.                       A      F#
 Басирга очилсин кўзинг демоқ учун
.F#               Bm
 Худованд бизни юборди.

[V3]
.   Bm                        Em
 // Мазлумга эркинликни эълон этиб,
.F#                     Bm
 Марҳамат йили бўлсин демоқ учун. //
.Em       F#     Bm
 Худованд мени юборди.
.Em       F#       Bm
 Худованд бизни юборди.

[V4]
.   G          A    D     Em      A  F#
 // Сен ибтидо ва интиҳо, аввалию охири, //
.   G           A    D   Em        A       F#(Bm)
 // Бош ва сўнггидирсан, ёруғ тонг юлдузидирсан. //
.   Bm            G   A            F#
 // Руҳ ҳам келин ҳам кел деб чорлаяпти,
.Bm            G       D   F#
 Эшитган киши ҳам кел десин. //
.     Em         A     D      G
 //// Чанқаган келсин ҳаёт сувидан
.Em          F#    Bm
 Текин текин баҳра олсин. ////
.Em          F#    Bm
 // Текин текин баҳра олсин. //</lyrics>
