<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em             C
 // Меҳрибон мениг Чопаним,
.D         G
 Мени олға бошлагин,
.Am            Em
 Қандай гўззал яйлауларинг,
.C     D     Em
 Тўнуқ сувга опаргин! //
.   Em        D
 //  Ер юзида дўстим бўлгин,
.Am        G
 қўзиларни сақлагин,
.Am        Em
 Осмон нўрида ёндиргин,
.C   D     Em
 Адашқанни қайтаргин! //

[V2]
 // Берган ваъдангни бажаргин,
 Менга инойят бергин,
 Оғир йўл томом бўлганда,
 Жонимини қобул қилгин! //
 // Таёрлагин юрагимни,
 Амрингни бажоришка,
 Мен қаби имон топгандек,
 Чин қалбимдан севишка! //</lyrics>
<title>Меҳрибон Мениг Чопаним</title>
</song>