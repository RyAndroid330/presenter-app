<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>217</hymn_number>
<author>Зафар</author>
<lyrics>[V1]
.   Ab             Eb
 // Буюк бахт дунёга Худо назари,
.Db        Eb          Ab     Db Eb
 Олам олам тан олар унинг ҳақлигин.
.Ab                Eb
 Ҳар бир инсон Унга бағишлар қалбин,
.Db        Eb   Ab
 Мадҳ этар уни жаннат-ла замин. //

[C1]
.  Gb       Db    Dbm        Ab
   Берди У дунёга муҳаббатни ҳақиқатни,
.  Gb       Db     Dbm     Ab
   Ато этди башарга ватан ила миллатни.
.  Gb         Db   Dbm       Ab
   Унинг ишқи эрур илоҳий бир мўъжиза,
.  Gb       Db     Dbm       Ab
   Ҳақ ва гўзаллигин намоён этар бизга.

[V2]
 // Раббимиз буюк бахт дунёга буюк Халоскор,
 Жон борки Унинг бутун меҳрига мафтун.
 Довонлар, қир-адирлар шафақлар такрор,
 Куйлайди Худонинг севгисин мамнун. //</lyrics>
<key>Ab</key>
<title>Буюк бахт дунёга Оллох назари Q217</title>
</song>