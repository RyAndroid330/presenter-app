<?xml version="1.0" encoding="UTF-8"?><song><author>Ленны ЛеБланк</author>
<hymn_number>119</hymn_number>
<key>G</key>
<lyrics>[C1]
.     G   D          C
   // Сендан бошқаси йўқ,
.  C     G         Am      D
   Фақат Сен менга умид бердинг.
.  G      D       C
   Кўпдан бери қидириб билдим,
.  G        D              G
   Менда Раббимдан бошқаси йўқ. //

[V1]
.G        C          G    Em
 Меҳрибонлигинг ёҳуд дарёдай,
.Am          D     G
 Қалбимизга шифо берар.
.C               G       Em
 Фарзандларингга таскин берар,
.Am     C          D
 Раббимдан бошқаси йўқ.

[C2]
   /// Сендан бошқаси йўқ,
   Фақат Сен менга умид бердинг.
   Кўпдан бери қидириб билдим,
   Менда Раббимдан бошқаси йўқ. ///</lyrics>
<title>Сендан Бошқаси Йўқ W119</title>
</song>