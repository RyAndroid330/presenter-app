<?xml version="1.0" encoding="UTF-8"?><song><author>Малоҳат Пулатова</author>
<hymn_number>127</hymn_number>
<key>Db</key>
<lyrics>[V1]
.C              Em7
 Оловинг келсин менга,
. F7      G
 Оловинг келсин,
.C              Em7
 Оловинг билан бирга
. F7       G
 Мойланиш келсин,
.Dm7            Em
 Излайман ҳузурингни
.F7       Am7
 Муқаддас Худо
.Dm          G          Fm6/B
 Юрагимни очаман Сенга Исо.

[C1]
.     C7              Gm7
   // Сенинг оловингга муҳтожман,
.  C7             F7   B
   Оловингда ёнсин юрагим.
.  Am7                 D7
   Сенинг иродангни излайман,
.  Dm7                 G7  C
   Шундай яшаш менинг тилагим. //

[V2]
 Оловинг билан Раббим
 Поклагин қалбим
 Жасорат билан тўлдир
 Менинг юрагим
 Ҳузурингга келиб мен
 Жамолинг кўрай
 Ҳаётим Сенга Исо мен топширай.

[C2]
   // Сенинг оловингга муҳтожман,
   Оловингда ёнсин юрагим.
   Сенинг иродангни излайман,
   Шундай яшаш менинг тилагим. //

[B1]
.  F7
   Оловинг келсин
.  G7
   Ҳузуринг келсин
.  Am7
   Покланиш келсин
.  G7
   Шифоинг келсин
.  C7
   Жасорат келсин
.  G
   Руҳинг тўлдирсин
.  B           Am
   Шоҳлигинг келсин
.  G7
   Муқаддас Худо</lyrics>
<title>Оловинг Келсин</title>
</song>