<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   /// Чин кўнгилдан ёлвораяпман
   Менга жавоб бергин э Худованд ///
   Чин кўнгилдан ёлвораяпман
   Сенинг қонун-қоидаларинг сақлайман

[V1]
 // Сенга ёлвораяпман қўтқаргин мени
 Токи шаодадинга содиқ қолайин //
 // Саҳар чоғи тўриб нола-ю фиғон қиламан
 Сенинг сўзинга умид боғлайман //

[C2]
   // Чин кўнгилдан ёлвораяпман
   Менга жавоб бергин э Худованд
   Чин кўнгилдан ёлвораяпман
   Сенинг қонун-қоидаларинг сақлайман //

[V2]
 // Каломингни фикр қилиб тунни тонгга ўлайман
 Кўзларимга уйқу бермайман асло //
 // Иноят қилиб овозимни эшитгин ё Раббим
 Адолат қилиб менга жон бергин //

[C3]
   // Чин кўнгилдан ёлвораяпман
   Менга жавоб бергин э Худованд
   Чин кўнгилдан ёлвораяпман
   Сенинг қонун-қоидаларинг сақлайман //

[V3]
 // Фисқ фасот пайида бўлган бузуқ ниятлилар
 Қонунингда узоқлашиб менга яқинлашдилар //
 // Бироқ сен жуда яқинсан эй Худованд
 Барча амрларинг эса ҳақиқатдир //

[C4]
   Чин кўнгилдан ёлвораяпман
   Менга жавоб бергин э Худованд
   Ваҳийларинг азалий деб
   Мен сен уларни барқарор қилгансан
   Чин кўнгилдан ёлвораяпман
   Менга жавоб бергин э Худованд
   Чин кўнгилдан ёлвораяпман
   Сенинг қонун-қоидаларинг сақлайман
   Сенинг қонун-қоидаларинг сақлайман</lyrics>
<title>Чин Кўнгил</title>
</song>