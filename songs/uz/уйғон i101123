<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.  C           D
 Эрта тонгдан умид билан
.    Bm7         Em
 Худо Сенга биз қараймиз.
.C            D
 Туғирлаб биз юракларни
.Bm7      Em
 Ёнимизда Сен хардоим.

[V2]
.        C        D
 Оловинг билан хаётимни
.         Bm7     Em
 Севгинг билан ёритдинг Сен,
.   C            D
 Йулларимга Сен нур сочиб
.   D           Bm7
 Зулмат кетар шарафингдан.

[P1]
.     C
   // Хечкачон севгинг сенинг,
.  D
    сунмас ичимда менинг,
.  Bm7
   Шу севги-нури билан
.  Em
   Порлайсан хар куни Сен. //

[C1]
.        C
   // Сен мен билан-сан
.   D          Bm7
   мен билан сан
.          Em
   Юрагимда абадий //

[B1]
.      C       D       Bm7
   /// Абадий, Абадий, Абадий,
.  Em
    Севгингда ///
.  C      D       Bm7
   Абадий Абадий, Абадий
.  Em
    биламиз.</lyrics>
<title>Уйғон</title>
</song>