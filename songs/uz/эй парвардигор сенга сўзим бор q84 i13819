<?xml version="1.0" encoding="UTF-8"?><song><title>Эй Парвардигор Сенга сўзим бор Q84</title>
<lyrics>[V1]
 // Эй Парвардигор Сенга сўзим бор, //
 // Муқаддас номингга ҳамду санолар. //
 // Ижозат берсанг қулинг бўлсам Сени,
 Ер юзида маҳсулинг бўлсам Сени. //

[V2]
 // Эй Раббим Исо кел қалбимизга, //
 // Сен абадий ҳаёт бахш этдинг бизга. //
 // Ижозат берсанг қулинг бўлсам Сени,
 Ер юзида тимсолинг бўлсам Сени. //

[V3]
 // Муқаддас Руҳга тўлди бу бадан, //
 // Ўз қонинг ила мени олдинг зулмдан. //
 //// Ижозат берсанг қулинг бўлсам Сени,
 Ер юзида Ўз нуринг бўлсам Сани. ////</lyrics>
<hymn_number>84</hymn_number>
</song>