<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>81</hymn_number>
<lyrics>[C1]
.     F#                 Abm
   // Раббим жоним тайёр қилгин,
.  B        C#    F#
   Қулоқ ва кўзим очгин. //
.     F#
   // Каломинг билим эшитсин,
.  B       C#        F#
   Осмон ёруғин кўрсатгин. //
.     F#
   // Фаҳм-идрок жонимга бергин,
.  B         C#          F#
   Ҳаёт ғийбатларин йўқотгин. //
.     F#
   // Раббим жоним тайёр қилгин,
.  B        C#      F#
   Қулоқ ва кўзим очгин. //

[V1]
.B
 Ҳаётда кўп хато қиламиз.
.                C#m
 Зулмат орасинда юриб,
.B
 Одил бўлишга уринмаймиз.
.                 C#m
 Йовузликдан узоқлашиб
.C#m
 Раббим руҳинг билан ёритгин,
 Гуноҳлардан фориҳ қилгин.

[C2]
.     C#m(F#)             (B)
   // Раббим жоним тайёр қилгин,
.  C#(Abm)  (C#)   F#
   Қулоқ ва кўзим очгин. //

[B1]
.     F#
   // Сен ёруғликдан, ёруғликдан,
.  B        C#      F#
   Худонинг якка Ўғлисан //
.  F#
   Сенинг сўзинг эшитсам мен,
.  B        C#     F#
   Қалбим билан қувонаман.
.  F#               B
   Раббим мен билан доим бўлгин.
.  C#                 F#
   Ором бериб бахтиёр қилгин.

[C3]
.     F#
   // Раббим жоним тайёр қилгин,
.  B        C#     F#
   Қулоқ ва кўзим очгин. //
.     B        C#      F#
   // Қулоқ ва кўзим очгин! //</lyrics>
<key>F#</key>
<title>Раббим жоним тайёр қилгин Q81</title>
</song>