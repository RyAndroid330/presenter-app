<?xml version="1.0" encoding="UTF-8"?><song><title>Ешуа</title>
<lyrics>[V1]
.       Em
 Менинг севгилим
.        C
 Сенсан гўзалим
.        G      D
 Минглар ичра ягона

[C1]
.  C    D   Em  Bm
   Ешуа а - а - а
.    C  D   Em  Bm
   Ешуа а - а - а

[B1]
.      C
   Шуерда
.               C
   Сенинг шоҳлигинг!
.            D  Em
   Сенинг қудратинг!
.               Bm
   Абадийдир шуҳратинг! Омин!</lyrics>
<key>Em</key>
<author>Мичаел Коулианос, Джон Вилдс</author>
