<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Эгамизга ҳамду санолар бўлсин,
   Эгамизга ҳамду санолар бўлсин,
   Самоларда, фалаклардан,
   Унга ҳамду санолар бўлсин. //

[V1]
 // Эй Унинг фаришталари,
 Эгамизга ҳамду санолар бўлсин. //
 // Эй Унинг самовий лашкарлари,
 Эгамизга ҳамду санолар бўлсин. //

[V2]
 // Ҳамду сано айтинг йигит-қизлар,
 Ешу қари ҳаммангиз бирга, //
 // Мадҳия айтинг Раббимизга.
 Ёлғиз Унинг Номи юксакдир! //</lyrics>
<title>Эгамизга ҳамду санолар бўлсин</title>
<author>Собир Умуров</author>
</song>