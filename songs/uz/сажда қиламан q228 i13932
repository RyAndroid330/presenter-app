<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>228</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.   Dm                 C
 // Сажда қиламан Буюк Худо,
.Bb                    A
 Сени номингни улуғлаб доим. //

[C1]
.     F                       C
   // Бутун дунё халқлари шон-шараф айтар Сенга,
.  Bb                           A
   Минглар инсонлар келиб тавба қилар йўлингда. //

[B1]
.             Dm          C
   //// Ҳамду сано, ҳамду сано,
.  Bb                      A
   Ҳамдалар айтамиз Раббим Сенга. ////</lyrics>
<title>Сажда қиламан Q228</title>
</song>