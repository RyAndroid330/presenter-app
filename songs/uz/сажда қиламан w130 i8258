<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Сажда қиламан,
 Раббимиз Исо Сенга
 Муҳаббату қудратини
 Раҳматингни ўйласам. //

[C1]
   Сен улуғ, Сен улуғ ва Сен гўзал
   Дунёда тенгинг йўқ
   Рухланиб мен айтаман
   Сен улуғ, Сен улуғ ва Сен гўзал
   Азизим қутқарувчим
   Сен улуғ ва Сен гўзал</lyrics>
<title>Сажда қиламан W130</title>
<hymn_number>130</hymn_number>
<author>Эва-Лена Хеллмарк</author>
</song>