<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Раббим севгингнинг нури порлар,қоронғуликда порлар.
 Исо дунёнинг нури Сенсан,Масиҳим Узинг қудратлисан.

[C1]
   // Менга порла (Менга порла)
   Менга порла (Менга порла)
   Порла Масиҳ. //

[V2]
 // Дунё кўрсин ёруғ жамолинг,
 Менинг руҳим нурларга тўлди. //

[V3]
 // Бутун олам Сенинг муҳаббатинга тўлсин,
 Ўзинг оловингни юбор халқларга. //</lyrics>
<title>Раббим севгингни нури порлар Q68</title>
<hymn_number>68</hymn_number>
</song>