<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<hymn_number>23009</hymn_number>
<title>Эслагин Бизни</title>
<lyrics>[V1]
 // Нега Эй Худо
 Сен бизни рад этдинг, рад этдинг
 Нега Эй Худо
 Сен бизга қарши чқдинг, қарши чиқдинг //

[C1]
   // Ҳаётимизнинг Эгаси
   бўлганингни эслагин, эслагин
   Ўзинг бизни танлаганингни
   унутмагин, унутмагин Эгам //

[V2]
 // Нега Эй Худо
 Сени биз тополмай қолдик, тополмай қолдик
 Нега Эй Худо
 Сенсиз биз ҳузур ҳаловатни йўқотдик. //</lyrics>
</song>