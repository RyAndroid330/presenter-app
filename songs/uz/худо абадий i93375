<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<lyrics>[V1]
 // Йўлларимда тўлиб тош
 Йиғларман кўзларимда ёш //
 // О Раббим сенга дейман
 Сендан бошқа мени севадиган йўқ //
 // Сени деб яшайман
 Сени деб кўйлайман //

[V2]
 // Ҳамроҳимсан эй Раббим
 Доим сени ёнимда кўрдим //
 Сени улуғлайман
 Буюклигингни кўйлайман
 Сенга сажда қиламан Исо
 // Номингни тараннум этаман //
 Буюклигингни кўйлайман
 Муқаддас Худо Подшоҳ
 Сен борсан абадий
 Сен мен билан абадий
 Сен биз билан абадий</lyrics>
<title>Худо Абадий</title>
</song>