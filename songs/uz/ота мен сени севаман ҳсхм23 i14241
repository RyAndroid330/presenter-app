<?xml version="1.0" encoding="UTF-8"?><song><title>Ота Мен Сени Севаман ҲСХМ23</title>
<key>G</key>
<lyrics>[V1]
.   G        C      G(D)
 // Ота мен Сени севаман, //
.G         C  Em
 Ота мен Сени жуда севаман,
.Am       D      G
 Ота мен Сени севаман.

[V2]
.   G        C     G(D)
 // Исо мен Сени севаман, //
.G        C   Em
 Исо мен Сени жуда севаман,
.Am       D      G
 Исо мен Сени севаман.

[V3]
.   G                 C       G(D)
 // Муқаддас Руҳ, мен Сени севаман, //
.G                  C    Em
 Муқаддас Руҳ, мен Сени жуда севаман,
.Am                 D      G
 Муқаддас Руҳ, мен Сени севаман.

[V4]
 // Отам мени севади, //
 Отам мени жуда севади,
 Отам мени севади.

[V5]
 // Исо мени севади, //
 Исо мени жуда севади,
 Исо мени севади.

[V6]
 // Муқаддас Руҳ мени севади, //
 Муқаддас Руҳ мени жуда севади,
 Муқаддас Руҳ мени севади.

[V7]
 // Ота раҳмат Ўғлинг учун, //
 Ота раҳмат азиз Ўғлинг учун.
 Ота раҳмат Ўғлинг учун.

[V8]
 // Исо раҳмат қонинг учун, //
 Исо раҳмат азиз қонинг учун.
 Исо раҳмат қонинг учун.

[V9]
 // Муқаддас Руҳ раҳмат далданг учун, //
 Муқаддас Руҳ раҳмат кучли далданг учун.
 Муқаддас Руҳ раҳмат далданг учун.</lyrics>
<hymn_number>23</hymn_number>
</song>