<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>152</hymn_number>
<title>Раббим Исо мен учун</title>
<key>G</key>
<lyrics>[V1]
.G           C
 Раббим Исо мен учун,
.G           D
 хочга михланганда.
.G             C
 Дунёнинг гуноҳин олиб,
.G          D G
 жазоланган эди.

[C1]
.  G        C
   Раб Исо, Раб Исо,
.  G           D
   менинг гуноҳим учун
.  G         C
   Асил қонини тўкиб,
.  G          D G
   гуноҳимни олган.</lyrics>
</song>