<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Шаҳримни марҳаматла эй Эгам Худо,
 Юртимни уйғонтиргин эй Раббим Исо. //

[C1]
   /// Муқаддас Руҳ ҳузуринг келсин, ///
   // Ҳар бир ерда марҳамат иноятинг бўлсин. //

[V2]
 // Доира чалиб, рақс ила ҳамду сано айтинг,
 Торли асбоб най чалиб Унга ҳамду сано куйланг. //

[V3]
 // Эгангни олқишлагинэй азиз инсон,
 Сени ташлаб қўймайди эганг ҳеч қачон. //</lyrics>
<title>Шаҳримни Мархаматла</title>
<author>Собир Умуров</author>
</song>