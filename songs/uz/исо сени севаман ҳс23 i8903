<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<lyrics>[V1]
 // Исо Сени севаман //
 Фақат Сени севаман,
 Ва Сенга мен ўзимни бағишлайман.
 Исо Сени севаман

[V2]
 // Исо Сен ажойибсан! //
 Исмингни такрорлайман,
 Улуғлайман ва мадҳлайман мен Сени!
 Исо Сен ажойибсан!</lyrics>
<title>Исо Сени севаман ҲС23</title>
</song>