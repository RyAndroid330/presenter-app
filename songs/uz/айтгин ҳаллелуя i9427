<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<title>Айтгин Ҳаллелуя</title>
<aka>Сен кўз ёш тўкмагин</aka>
<key>Am</key>
<lyrics>[V1]
.   Am                  G
 //  Сен кўз ёшлар тўкмагин,
.Am                 Em
 Умидинг, Худода бўлсин! //
.   Am              G
 // Кундан-кун улғайиб,
.Am                  Em
 Нигоҳинг, Худода бўлсин! //

[C1]
.  Am          Em
   Айтгин Ҳаллелуя!
.  Am C         G
   Айтгин Ҳаллелуя!
.  Am           Em
   Куйлагин Ҳаллелуя!
.  Am    C        G
   Куйлагин Ҳаллелуя!

[V2]
 // Мен билган Худо - севги!
 Кўз ёшларни артгувчи! //
 // Ёмғир ёғиб келади,
 Осмондан келар, тўлиб севги! //

[C2]
   Айтаман Ҳаллелуя!
   Айтаман Ҳаллелуя!
   Куйлайман Ҳаллелуя!
   Куйлайман Ҳаллелуя!</lyrics>
</song>