<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<lyrics>[V1]
.    Em       A             C          D
 // Муқаддас улуғворликка бурканган Эгамизга
.     Em       A             C          D
 Эй замин аҳли титраб туринг Унинг олдида
 Муқаддас улуғворликка бурканган Эгамизга
 Айтингки Эгамиз Шоҳ элатларнинг орасида //

[C1]
.     Em    A       C    D
   // Эгамиз Шоҳдир Эгамиз
   Унга биз сажда қиламиз
   Эгамиз Шоҳдир Эгамиз
   Унинг Номини биз куйлаймиз //

[V2]
 // Муқаддас либосларда сажда қилиб Эгамизга
 Назрлар олиб киринг Унинг муқаддас ҳовлисига
 Муқаддас либосларда сажда қилиб Эгамизга
 Куйлангки Эгамиз Шоҳ кўтариб қўлларни баландга //</lyrics>
<key>Em</key>
<title>Исроилнинг Худоси</title>
</song>