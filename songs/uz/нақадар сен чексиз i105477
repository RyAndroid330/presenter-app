<?xml version="1.0" encoding="UTF-8"?><song><title>НАҚАДАР СЕН ЧЕКСИЗ</title>
<lyrics>[V1]
 ЧУҚУР ДЕНГИЗЛАР, ЧЕКСИЗ КОИНОТ ҲАМ
 СЕНИНГ МЕҲРИНГНИ БУЛАР АНГЛАТОЛМАС.
 ҚОЧАРДИМ ЎЗИМДАН, ОҒРИҚДАН
 ЎША ВАҚТ ҲАЁТИНГ БЕРГАНДИНГ.

[P1]
   КЕЧИРИМ ҲАМ СЎРАМАГАНДИМ,
   СЕН ЭСА СЕВДИНГ.

[C1]
   НАҚАДАР СЕН ЧЕКСИЗ,
   ҚАНЧАЛАР ЧЕКСИЗ СЕВГИНГ СЕНИНГ,
   КЕЧИРДИНГ СЕН БИЗНИ.
   НАҚАДАР СЕН БУЮК,
   МАРҲАМАТИНГ ЁҒДИРДИНГ БИЗГА,
   НАҚАДАР СЕН БУЮК.

[V2]
 СЕНГА НАЗАРИМ, ЗУЛМАТ ЎҒИРЛАРКАН,
 АММО ХУДОЙИМ, СЕН СОДИҚ ҚОЛАРСАН
 ЖОЙ БЕРДИНГ МЕНГА ЯЙЛОВЛАРДАН
 ЭНДИ МЕН ЁНИНГДА, МАНГУМАН.

[P2]
   МАРҲАМАТИНГНИ БИЛМАГАНМАН,
   СЕН ЭСА ЙЎЛ БЕРДИНГ</lyrics>
</song>