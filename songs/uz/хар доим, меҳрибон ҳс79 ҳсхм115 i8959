<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D          A
 // Хар доим, меҳрибон
. Em      G
 Бепоён, хайрихох
.        A
 Худойим Сен менга //

[C1]
.  D               Bm
   Севаман Раббим Сени мен,
.  Em         G           A
   Чунки Сен Ўзинг аввал мени севдинг.
.   D            Bm
   Сўзингни юбординг менга,
.  Em         G          A
   Нажотли аҳдинг учун шукур Сенга!

[V2]
.   D        A
 // Ер жаҳон ва осмон
. Em    G                       A
 Бепоён шодлидир муқаддас номингга //</lyrics>
<title>Хар доим, меҳрибон ҲС79 ҲСХМ115</title>
<author>Һәмра ака</author>
<hymn_number>276</hymn_number>
</song>