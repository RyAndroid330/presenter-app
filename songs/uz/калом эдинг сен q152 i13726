<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>152</hymn_number>
<aka>Парвардигор оламни яратганида</aka>
<lyrics>[V1]
.Em                 C      Em
 Парвардигор оламни яратганида,
.G        Am     Dm      Em
 Ер узра қуёшни порлатганида.
.Am                  Dm      Am
 Бўлдиё заминга зиё таратганида.
.F              G              Em
 У буюрган ўша сўз Калом эдинг Сен.

[C1]
.     Em          Am   D            G
   // Калом эдинг Сен, Калом эдинг Сен,
.  C          F       Dm         Em
   У буюрган ўша сўз Калом эдинг Сен. //

[V2]
.    G                       Am
 // Дунёга гуноҳ кириб адашганида,
.C        Am         D       G
 Инсонлар бойлик дея талашганида. //
.Am                  C       Am
 Ҳақиқат ёлғон билан алмашганида,
.Em      Am    G    C      D     Em
 Худо юборган Нажоткор Исо эдинг Сен!

[C2]
   // Исо эдинг Сен, Исо эдинг Сен,
   Худо юборган Нажоткор Исо эдинг Сен! //

[V3]
.   Em                 G
 // Илоҳий нур порлар сирли кўзида,
.C              F   Dm       Em
 Бир дунё маъно бор айтган сўзида. //
.C                  Am    G
 Одамга ёт хислат бордир Ўзида,
.C                 Dm         E
 Инсон қиёфасидаги Худо эдинг Сен!

[C3]
   // Худо эдинг Сен, Худо эдинг Сен,
   Инсон қиёфасидаги Худо эдинг Сен! //</lyrics>
<key>C</key>
<title>Калом эдинг Сен Q152</title>
</song>