<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Болта урар илдизга
 Гуноҳ яратган доғи //
 // Оғир кечар ёлғизга
 Синов ойнаси чоғи //

[V2]
 // Берар ишора-имо,
 Чорлар севги ўчоғи! //
 // Очиқ бўлар доимо.
 Отанг қалби, қучоғи! //

[V3]
 Тўла Худонинг уйи
 Унинг азиз боласига.
 // Ака-ука, опа-сингил,
 Далда, заиф ноласига. //

[V4]
 Ёлғизликка кўнмагин!
 Сени оиланг кутмоқда.
 // Ёнгин, ёнгин сўнмагин!
 Умринг сувдек ўтмоқда. //</lyrics>
<aka>Болта урар илдизига гуноҳ</aka>
<title>Ота Худо оиласи</title>
</song>