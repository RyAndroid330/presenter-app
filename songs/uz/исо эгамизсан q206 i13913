<?xml version="1.0" encoding="UTF-8"?><song><title>Исо Эгамизсан Q206</title>
<lyrics>[V1]
.   Bbm Ab        C#        Bbm
 // Исо Эгамизсан бу ерга келгин,
.Bbm  Ab       C#             Bbm
 Бизнинг орамизда мақтовларни олгин. //

[C1]
.     Eb        Ab     Ab        Eb
   // Сени улуғлаймиз, Сени улуғлаймиз,
.  Fm      Ab          Ab           Eb
   Сени улуғлаймиз, келгин Исо тахтингга. //

[V2]
 // Исо Нажоткоримиз бу ерга келгин,
 Бизнинг орамизда мақтовларни олгин. //

[V3]
 // Исо Шифокоримиз бу ерга келгин,
 Бизнинг орамизда мақтовларни олгин. //

[V4]
 // Исо умидворимиз бу ерга келгин,
 Бизнинг орамизда мақтовларни олгин. //</lyrics>
