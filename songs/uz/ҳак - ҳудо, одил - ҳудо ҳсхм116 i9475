<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>116</hymn_number>
<key>D</key>
<lyrics>[V1]
.   D            A
 // Ҳақ - Худо, Одил - Худо,
.Bm         F#m
 дунёни севган Худо!
.G         D
 Ер юзин, Ўзи билан,
.Em          A
 НураФшон қилган Худо! //

[C1]
.     D              A
   // Меҳрибон, сирдошимсан,
.       Bm      F#m
   Муқаддас йўлдошимсан,
.     G      D  Em    A
   Ягона таянчимсан менинг! //

[V2]
 // Эзгулигка тўлгансан,
 Шафқатинг кўрсатгансан,
 Ваъда берган сўзингга,
 Доим содиқ бўлгансан! //</lyrics>
<title>Ҳак - Ҳудо, Одил - Ҳудо ҲСХМ116</title>
</song>