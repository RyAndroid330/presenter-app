<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em
 // Биз учун бир ўлиб тирилган
.Em                 Am
 Гуноҳлар қон билан ювилган
. Am
 Фарзандлар янгидан туғилган
. C                    B7
 Танланган фарзандлар оқланган //

[C1]
.     Em
   // Сўрайман Худодан сўрайман
.   Em                 Am
   Дунёнинг тинчлигин сўрайман
.   Am
   Сўрайман Исодан сўрайман
.    C       B7      Am
   Худонинг Севгисин сўрайман //

[V2]
 Дунёнинг нелигин англадим
 Биргина Худони танладим
 Онамнинг қалбидек меҳрли
 Исонинг Каломин танладим</lyrics>
<key>Em</key>
<title>Сўрайман Худодан</title>
<author>Собир Умуров</author>
<hymn_number>23105</hymn_number>
</song>