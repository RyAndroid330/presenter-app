<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>164</hymn_number>
<title>Самовий тахтини қолдириб</title>
<lyrics>[V1]
.   Am
 // Самовий тахтини қолдириб
.G           Am
 Дунёмизга келди Исо Ихтиёридан кечиб
.D            Em
 Хизматкор бўлди Исо //

[C1]
.     Em
   // Исо мен учун қурбон
.  Am
   Исо мен учун қурбон бўлди
.  Am
   Гуноҳларим туфайли
.  D         Em
   Хочда У азоб чекди //

[V2]
.   Am
 // Мен қилган гуноҳларим
.G          Am
 Жуда жуда кўп эди Масиҳим барибир
.D             Em
 Улардан мени оқлади //</lyrics>
<key>Am</key>
</song>