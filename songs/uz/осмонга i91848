<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Gm      Eb  F     Gm
 // Осмонга кўзларинг тикгин
.Gm     Eb  F    Gm
 У ерда Раббимиз кутар
.Gm    Eb     F     Gm
 Исони эслаб келгин дўстим
.Gm    Eb       F     Gm
 Шунда қалбинг тинчлик топар. //

[C1]
.     Gm      Eb   F
   // Фақат Унинг ёнига
.  Gm        Eb      F
   Юрагингни очгин Масиҳга
.  Gm      Eb    F
   Фақат Унинг сўзига
.  Em        Eb        F
   Ишониб маҳкам тур имонда. //

[V2]
 // Қўрқмагин қийинчиликдан
 Ўзи Раббим Сен билан
 Юз ўгирмагин Исодан
 Шунда бахтли бўла оласан. //</lyrics>
<key>Gm</key>
<title>Осмонга</title>
<author>Собир Умуров</author>
</song>