<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Талпинар кийик ирмоқ сувига.
 Жоним ташна тирик Худога. //
 // Хамду сано айтиб куйлашни.
 Хузурингда хоҳлар абадий. //

[V2]
 // Тушкинликга жоним тушмоқда.
 Зулмат, тунлар келиб -кетмоқда. //
 Доим менга доим умид берасан.
 Сенга ибодатим етмоқда.

[V3]
 // Дунё билмас, кўрмас нурингни.
 Хақоратлаб мазах қиларлар. //
 // Жоним умид боғлар Исога.
 Унда нажотлигин биларлар. //</lyrics>
<title>Сенга талпинар</title>
<author>Тимўтий</author>
</song>