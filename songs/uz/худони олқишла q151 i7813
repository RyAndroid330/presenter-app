<?xml version="1.0" encoding="UTF-8"?><song><title>Худони олқишла Q151</title>
<key>E</key>
<lyrics>[C1]
.     E        B        E
   // Ё менинг жоним ҳардам
.  B        A
   Худони олқишла
.  B                 E
   Ё менинг жоним ҳардам! //

[V1]
.   E(B)
 // Эй, бутун баданим,
.      (E)
 унинг пок номига! //
.B
 Ҳамиша шукур айтиб,
.A
 Уни мақтаб тур!

[V2]
.   E(B)
 // Биргина қурбон билан мудамо
.   A     B      E
 Биргина қурбон билан! //
.   E(B)       (E)
 // Исо мени муқаддас қилиб қолдирди! //
.E             A      B     E
 Худойим мени ҳамиша комил қилди!

[V3]
.   E
 // Ўзининг қони билан,
.        A
 У мени қутқарди
.B             E
 Ўзининг қони билан! //
.    E(B)
 // Ундан узоқ эдим
. (E)
 Ҳукм қилинган эдим, //
.E               A      B      E
 Мен энди Нажоткоримга келиб қолдим!</lyrics>
<hymn_number>151</hymn_number>
</song>