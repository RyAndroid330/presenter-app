<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<hymn_number>22713</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.   Dm              G
 // Исонинг олдига бир талай
.A                  A#    A
 Чўлоқ, кўр, майиб, соқовлар
.Dm            G
 Ва бошқа кўп хасталарни
.A           A#  A
 Олиб келди одамлар //

[C1]
.     Dm                 G
   // Соқовларнинг гапирганини
.  A               A#     A
   Майибларнинг соғайганини
.  Dm                G
   Чўлоқларнинг юрганини
.  A                   A#   A
   Кўрларнинг кўзи очилганини //
.      Dm                          G A    A# A
   /// Буни ҳалқ кўриб ҳайратда қолди ///

[B1]
.  Dm   G   A          A#  A
   Худодан шифо топганлар__
.  Dm   G  A    A# A
   Худони олқишланг
.  Dm   G  A           A# A
   Худодан нажод топганлар
.  Dm   G  A    A#  A
   Худони улуғланг__</lyrics>
<title>Шифо</title>
</song>