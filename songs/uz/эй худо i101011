<?xml version="1.0" encoding="UTF-8"?><song><author>ҚУРБОН МУКУМОВ</author>
<title>Эй Худо</title>
<lyrics>[V1]
 // Эй Худо
 Менга иноят қилиб
 Меҳрибонлик кўрсатгин
 Чексиз раҳм-шавқатинг тўфайли
 Қонунсизлик ишимдан кечиб юборгин //

[C1]
   Қилмишимдан қонунсизлик деб тан оламан
   Қилган гуноҳим кўз - унгимдадур
   Бу гуноҳларим бу гуноҳларим
   Бу хатоларим

[V2]
 // Мен сенга фақат сенга қарши гунох қилдим
 Сенинг кўз олдингда ёмонлик қилдим
 Сен эса сўзингда доим барҳақсан
 Ҳукм қилганингда фақат одилсан //

[C2]
   // Қилмишимдан қонунсизлик деб тан оламан
   Қилган гуноҳим кўз - унгимдадур
   Бу гуноҳларим бу гуноҳларим
   Бу хатоларим бу хатоларим //</lyrics>
</song>