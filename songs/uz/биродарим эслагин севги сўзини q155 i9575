<?xml version="1.0" encoding="UTF-8"?><song><aka>Меҳрингга шон-шараф</aka>
<lyrics>[V1]
.   C#                   A#m
 // Биродарим эслагин севги сўзини
.F#                 D#m    C#
 Дилинг билан англагин сўзнинг сирини! //

[C1]
.     C#             D#m    C#
   // Муҳаббат қўшиғи осмонга чиқсинки
.  D#m          F#
   Раббимга шон, Раббимга шон
.  G#           C#
   Меҳрингга шон-шараф! //

[V2]
 // Халоскорда дунёга муҳаббат келди
 Ёш оқизган инсонга ором келтирди! //

[C2]
   // Муҳаббат инсонга, бахтлик берди жонга
   Раббимга шон, Раббимга шон
   Меҳрингга шон-шараф! //

[V3]
 // Гўзал қувончга тўлган Муҳаббат сўзин
 Дилга ёқимли бўлган Худо сўзлари! //

[C3]
   // Раббим муҳаббати руҳни уйғотади
   Раббимга шон, Раббимга шон
   Меҳрингга шон-шараф! //
.     G#           C#
   // Меҳрингга шон-шараф! //</lyrics>
<key>F#</key>
<title>Биродарим эслагин севги сўзини Q155</title>
<hymn_number>155</hymn_number>
</song>