<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>19</hymn_number>
<lyrics>[C1]
   // Орқага чекинмайман. //
   // Ланнатни кўчасининг,
   шаробин ичолмайман. //

[V1]
 Раббим келгин бағринга ол,
 Мен Сени кутаяпман.
 Мен Сенинг фарзандингман,
 Мен Сенинг дилбандингман.

[V2]
 // Дардларим дуосига,
 Армонларим нолиган. //
 // Ноҳақлик гирдобида,
 Солиҳанг қон йиғлагаг. //
 // Кел, Раббий қўлингни чўз,
 Узоқдаман инграган. //

[V3]
 // Эшит менинг оҳим,
 Қулоқсизнинг саводин. //
 // Ич-этим ебон ҳар дам,
 Саҳродан ўтаяпман. //
 // Қалбимга тирик гўшт берар,
 Ўтмишдан кечаяпман. //
 // Мен сени излаяпман. //

[V4]
 Жафолик Худойим менинг,
 Ноласин чидолмайман.
 // Юракинам ёнимда бўл,
 Мен сенсиз яшай олмайман //
 // Нолай-у фарёдимни,
 Мен сенсиз йеча олмайман //

[V5]
 Раббим келгин бағринга ол,
 Мен Сени кутаяпман.
 // Мен Сенинг фарзандингман,
 Мен Сенинг дилбандингман. //
 Мен Сенинг дилбандингман!</lyrics>
<title>Оркага чекинмайман Q19</title>
</song>