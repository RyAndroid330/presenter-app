<?xml version="1.0" encoding="UTF-8"?><song><author>Ковчег церковь Днепропетровск</author>
<hymn_number>25503</hymn_number>
<title>Лойикдир Номинг</title>
<key>E</key>
<lyrics>[V1]
.E        B
 Сен хочимни олдинг,
.          E
 Ва Сен ўлдинг,
.      A      B
 'Озод бўлиб яша' деб,
.E      B
 Ҳаётим Сеники,
.         E     A     B
 Ва ҳар доим иноятингни куйлай.

[C1]
.                A      B
   // Лойикдир Номинг, Исо
.             E
   Мақтовга лойиқ
.             C#m
   Лойиқдир Номинг //

[V2]
.E       B
 Иснодим ювилди,
.         E        A        B
 Завқланяпман шубҳасиз Севгингдан мен
.E     B
 Иноятнинг мени
.        E      A        B
 Тўлдиряпти у ҳакида куйлай доим

[C2]
   // Лойиқдир Номинг Исо,
   Мақтовга лойиқ,
   Лойиқдир Номинг, //

[B1]
.    A
   Осмонларда юксалгансан,
.      F#m
   Буюклигинг шу ерда
.    C#m
   Ёлғиз Сен мақтовга лойиқ
.      B             E
   Буюксан ҳамма Номдан

[C3]
   // Лойиқдир Номинг Исо,
   Мақтовга лойиқ
   Лойиқдир Номинг. //</lyrics>
</song>