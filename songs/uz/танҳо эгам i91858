<?xml version="1.0" encoding="UTF-8"?><song><title>Танҳо Эгам</title>
<key>F#m</key>
<lyrics>[C1]
.  F#m                D
   Эгам Сенга бўлсин ҳамдлар
.         E            C#m
   Эгам Сенга бўлсин олқишлар
.  F#m              D
   Эгам Сенга тазим қилай
.          F             C#m
   Лойиқдирсан фақат танҳо Эгам

[V1]
.F#m
