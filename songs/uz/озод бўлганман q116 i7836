<?xml version="1.0" encoding="UTF-8"?><song><title>Озод бўлганман Q116</title>
<key>Fm</key>
<lyrics>[C1]
.     Fm          Bbm
   // Озод, озод, бўлганман
.  Fm         Bbm
   Гуноҳнинг занжириндан
.  Fm            Bbm
   Халос, халос, бўлганман
.  Fm(C#)   (Eb)  Bbm(Fm)
   Шайтоннинг қулигиндан! //

[V1]
.   Ab               Bbm
 // Қулликдан қутилганман, //
.   Ab            Bbm
 // Исонинг қони билан, //
.   Ab              Bbm
 // Юракдан шод бўлганман, //
.   Ab             Bbm
 // Худонинг Ўғли билан! //

[V2]
 // Иброҳимни бой қилди! //
 // Ёқубни дуо қилди! //
 // Юсуфни подшоҳ қилди! //
 // Бизларни озод қилди! //
 // Юсуфни подшоҳ қилди! //
 // Бизларни озод қилди! //

[V3]
 // Осмонга етиб борди, //
 // Азизларнинг дуоси! //
 // Муқаддас Руҳ юборди, //
 // Юракларнинг шифоси! //

[V4]
 // Осмон-у ер ҳам йўқ бўлар, //
 // Биргина севги қолар! //
 // Исо олдинда халқлар, //
 // Бир кун келиб йиқилар! //</lyrics>
<hymn_number>116</hymn_number>
</song>