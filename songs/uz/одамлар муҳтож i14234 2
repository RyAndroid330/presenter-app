<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>123</hymn_number>
<author>Нелсон Грег, Филип Мчугх</author>
<lyrics>[V1]
.C#            Ab  F# C#           Ab
 Ҳар кун инсон кўзида маъносиз кун кўраман,
.Fm        Bbm           B           Ab
 Мавҳумлик кунлар кутар, рангсиз хаёллар.
.C#            Ab  F#  C#       Bbm
 Оғриқ, қўрқув юракда, аламли севинч,
.F#m              C#    Ebm   Ab
 Ким улар қалбин билар, фақат Исо.

[C1]
.  C#       F#     C#       F#
   Одамлар муҳтож, Худога муҳтож,
.  F          Bbm       F#   Ab
   Мазмунсиз бўлса ҳаёт, Исо нажот.
.  C#        F#     C#     F#
   Одамлар муҳтож, Худога муҳтож,
.  F            Bbm       Ebm Ab    C#
   Ҳамма келсин ҳузурига, одамлар муҳтож.</lyrics>
<key>F#</key>
<title>Одамлар Муҳтож</title>
</song>