<?xml version="1.0" encoding="UTF-8"?><song><aka>Қўшнилар тўйлар қилиб</aka>
<lyrics>[V1]
 // Қўшниларим тўйлар қилиб
 Айтмасалар майлига //
 // Дўстим деб юрганларим
 Юзимга урсалар майлига //

[V2]
 // Қариндошлар қарамасдан
 Юз ўгирсалар майлига //
 // Иззатимни тупроқларга
 Қорсалар ҳам майлига //

[V3]
 Маҳаллада қўшнилар
 Гап қилсалар майлига
 Динин сотган деб мени
 Тош отсалар майлига

[V4]
 Раббим Ўзи келиб
 Бир кун олиб кетади
 Самовий жаннатидан
 Яхши жойлар беради</lyrics>
<title>Худо учун майлига</title>
</song>