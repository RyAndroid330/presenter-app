<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>137</hymn_number>
<lyrics>[C1]
.     F#m        E
   // Осий эдим, ювдинг мани,
.  F#m         E
   гуноҳларим қувдинг мани. //
.     A(D)      (C#)
   // Эл ичида суйдинг мани //
.        E               F#m
   Парвардигорим, Парвардигорим.

[V1]
.   A            B          D   E      F#m
 // Қудратингдин йўқдин яна бор айлагайсан,
.A            B            D    E     F#m
 Гуноҳ қилсам кенг жаҳонни тор айлагайсан. //
.   A              E       C#m           F#m
 // Тавба қилмас осийларни хор айлагайсан эй, //
.E          F#m
 Зор айлагайсан.

[C2]
   // Осий эдим, ювдинг мани,
   гуноҳларим қувдинг мани. //
   // Эл ичида суйдинг мани //
   Парвардигорим, Парвардигорим.

[V2]
 // Мана энди кеч бўлсада келдим қошингга,
 Раҳм айладинг кўздан оққан аччиқ ёшимга. //
 // Бу не бахтки қўлинг қўйдинг ғамли бошимга, //
 Ғамли бошимга.

[V3]
 // То тирикман мадҳингни мен куйлаб ўтарман,
 Хушхабаринг элинг ичра баён этарман. //
 Куни келса шоҳлигингга мен ҳам кетарман,
 Куни келса ҳузурингга // бир кун борарман. //</lyrics>
<key>F#m</key>
<title>Осий эдим суйдим мени Q137</title>
</song>