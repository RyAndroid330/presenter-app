<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>27</hymn_number>
<title>Исонинг севгиси севгиси</title>
<lyrics>[V1]
.E
 Исонинг севгиси, севгиси
.A
 Гуллаб очилди
.    E
 Исони учратганимда
.B7    E
 Исонинг севгиси

[V2]
 Исонинг тинчлиги...

[V3]
 Исонинг қувончи...

[V4]
 Исонинг умиди...

[V5]
. E
 Мендаги ташвишлар, ташвишлар
.A
 Йўқолиб кетди
.        E
 Исони учратганимда
.B7         E
 Мендаги ташвишлар

[V6]
 Мендаги қайғулар...</lyrics>
<key>E</key>
</song>