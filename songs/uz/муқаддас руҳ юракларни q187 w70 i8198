<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>187</hymn_number>
<title>Муқаддас Руҳ юракларни Q187 W70</title>
<lyrics>[V1]
 // Муқаддас Руҳ юракларни
 Нуринг билан ёритгин. //
 // Оламнинг зулматини Сен
 Севгин билан тўлдиргин. //

[V2]
 // Энди бизнинг дилимизда
 Ўзинг макон яратгин,
 Нурли олов бўлиб ёнгин
 Қалбимизга жойлашгин! //

[V3]
 // Муқаддас Руҳ қудратингла
 Содиқларга куч бергин
 Жамоатингни тиклагин
 Ўзбек халқин уйғотгин! //</lyrics>
</song>