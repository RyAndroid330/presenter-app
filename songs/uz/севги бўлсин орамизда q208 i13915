<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>208</hymn_number>
<key>F</key>
<lyrics>[V1]
.   Am            C         C            Dm
 // Севги бўлсин орамизда, порласин бахт кўзимизда.
.Dm               Bb                      Am
 Худони халқимиз севсин, қўрқув ва оғриқ йўқолсин. //

[C1]
.     F                         C                Dm
   // Мен қалбим ила куйлайман, ҳамду сано ҳамду сано,
.  Dm              Bb                      Am
   Эгам Худони куйлайман, ҳамду сано ҳамду сано. //

[V2]
 // Сен ёрдам бер тушунишга, керакмиз бир-биримизга,
 Севги бўлсин орамизда, Сенинг нуринг йўлимизда. //

[V3]
 // Тиз чўкиб дилимизда юракларни очайлик,
 Худодан қувват олиб, шайтонга қарши турайлик. //

[V4]
 // Келинг, келинг биродарлар ҳаммамиз бирга бўлайлик,
 Ҳаммамиз бирга сўрайлик, баробар кўкка борайлик. //</lyrics>
<aka>Севинчим Исо Масиҳ</aka>
<title>Севги Бўлсин Орамизда Q208</title>
</song>