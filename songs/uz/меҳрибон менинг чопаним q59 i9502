<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Меҳрибон менинг чўпоним,
 Мени олға бошлагин. //
 // Қандай гўзал яйловларинг,
 Тиниқ сувга оборгин. //

[C1]
   // Менинг Раббим, Менинг Раббим
   Мен учун Сен қон тўкдинг. //

[V2]
 // Ёр юзида дўстим бўлгин,
 Қўзиларни сақлагин. //
 // Осмон нури ила ёритгин,
 Адашганни қайтаргин. //

[V3]
 // Берган ваъдангни бажаргин,
 Менга иноят бергин. //
 // Оғир йўл тамом бўлганда,
 Жонимни қабул қилгин. //

[V4]
 // Тайёрлагин юрагимни
 Амрингни бажаришга. //
 // Мен каби иймон топганни
 Чин қалбимдан севишга. //</lyrics>
<title>Меҳрибон Менинг Чопаним Q59</title>
<hymn_number>59</hymn_number>
</song>