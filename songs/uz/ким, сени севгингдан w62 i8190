<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>62</hymn_number>
<lyrics>[V1]
 // Ким, Сени севгингдан,
 Мени жудо қилар экан // /
 Қайғуми, сиқилишми,
 Қувғинми, очликми,
 Яланғочликми, хавф-хатарми
 ёки қиличми?

[V2]
 /// На ўлим ва на ҳаёт, на фаришталар
 Ва на жин-ажиналар,
 На ҳозирги ва на келгуси,
 Ҳамда на яратилган бошқа бирон мавжудод
 Раббимиз севгисидан жудо қилишга қодир эмас ///
 Раббимиз Исо севгисидан
 Жудо қилолмас</lyrics>
<title>Ким, Сени севгингдан W62</title>
</song>