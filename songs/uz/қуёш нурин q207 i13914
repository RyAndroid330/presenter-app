<?xml version="1.0" encoding="UTF-8"?><song><title>Қуёш нурин Q207</title>
<key>Em</key>
<lyrics>[V1]
.   Em                G      Am
 // Қуёш нурин сахий сочар юртимга,
.Em         G      D     Em
 Худовандимнинг бу марҳамати. //
.   Em              G       Am
 // Дарахтлар мева тугар мавсумида,
.Em         G       D    Em
 Худовандимнинг бу марҳамати. //

[C1]
.     Am            Em      Am            Em
   // Соғлик берар танамга, бардам қилар руҳимни,
.  Am           Em         D        Em
   Мени севган Худовандга жонимни бераман. //

[V2]
.Em                    G     Am
 Маконида тинчлик абад ҳукм сурар,
.Em         D    G            Em
 Солиҳлари Унга фақат хизмат қилар.
.G                            Am
 Юрагимга Ўзи фақат тинчлик берар,
.Am                         Em
 Иноятим берганига мен ҳам бераман,
.Am                         D     Em
 Ўзим боримдан бир қисмини Унга бераман.

[V3]
.Em             G             Am
 Ҳаёт маконимга У ҳам уруғ сочар,
.Em         D        G      Em
 Парваришда Ўзи доим бирга бўлар.
.G                             Am
 Ҳосил пайтта мени кутиб четта турар,
.G                 Em      Am
 Иноятим берганига мен ҳам бераман,
.G                         B    Em
 Ўзим боримдан бир қисмини Унга бераман.

[B1]
.     Em                       Am
   // Қуёш нурин сахий сочар юртимга,
.  G                      Em
   Худовандимнинг бу марҳамати. //
.     Em                       Am
   // Дарахтлар мева тугар мавсумида,
.  G                      Em
   Худовандимнинг бу марҳамати. //</lyrics>
<hymn_number>207</hymn_number>
</song>