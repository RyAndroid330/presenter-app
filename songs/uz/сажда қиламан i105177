<?xml version="1.0" encoding="UTF-8"?><song><title>Сажда қиламан</title>
<lyrics>[V1]
 // Сажда қиламан.
 Сенга тиз чукиб
 О буюк Раббим
 О буюк Раббим //

[C1]
   Барча олқишга,
   барча мақтовга.
   // Фақат Сен Раббим //
   лойиқсан.

[V2]
 // Сажда қиламан
 Бошимни эгиб.
 О буюк Раббим
 О буюк Раббим //

[C2]
   Барча олқишга,
   барча мақтовга.
   // Фақат Сен Раббим //
   лойиқсан.

[B1]
   // Қўлларимни, кўтариб баланд.
   Сажда қиламан
   Сажда қиламан //</lyrics>
</song>