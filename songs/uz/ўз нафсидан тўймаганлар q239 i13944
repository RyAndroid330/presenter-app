<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>239</hymn_number>
<key>Cm</key>
<lyrics>[V1]
.Cm
 Ўз нафсидан тўймаганлар бахтсизларни излайдилар,
.   Fm                      Cm
 // Лабин тишла кўзин қиса, тул аёлни излайдилар. //
.Cm
 Бир оёғин гўр судраган, Худо қолиб ёр излаган,
.   Fm                   Cm
 // Кечалари нафс йўлида шаъмлар ёқиб ёр излаган. //

[C1]
.  Cm                    Fm           Cm
   Қўлларида шаробу май, зино айлаб кўзлари тўймас.
.     Fm                   Cm        G      Cm
   // Тилларида Худо деган тул аёлни авраб тўймас. //
.  Cm
   Бу кун Раббий таниб билган солиҳасин тинч қўй шайтон,
.     Fm                     Cm
   // Фарёдларин Худо эшитар беваларни тинч қўй шайтон. //
.  Cm
   Ўз нафсидан тўймаганлар бахтсизларни излайдилар,
.     Fm                      Cm
   // Лабин тишла кўзин қиса, тул аёлни излайдилар. //</lyrics>
<title>Ўз нафсидан тўймаганлар Q239</title>
</song>