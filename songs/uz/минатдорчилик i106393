<?xml version="1.0" encoding="UTF-8"?><song><tempo>78 бпм</tempo>
<author>Брандон Лаке, Бенджамин Хастингс, Данте Бове</author>
<title>МИНАТДОРЧИЛИК</title>
<lyrics>[V1]
.G
 ТАЪРИФЛАШ УЧУН
.      Em
 ТИЛИМ ХАМ ОЖИЗ,
.   D
 ЯГОНА СЎЗИМ
.      C
 МИНАТДОРЧИЛИК!

[V2]
.      G
 СЕНИ УЛУҒЛАЙ,
.     Em
 САНОЛАРИМДА!
.       D
 ЛЕК САНО ТУГАР
.    C        D
 СЕН ЭСА МАНГУ!

[C1]
.       G
   ҚЎЛЛАРИМ УЗАТИБ
.                    D
   УЛУҒЛАЙМАН МЕН СЕНИ
.  D
