<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Худонинг каломида бор икки амр: //
 // Ягона Худойингни, Ягона Худойингни,
 Бутун қалбинг, бутун жонинг,
 Бутун ақлинг ва кучинг билан севгин! //

[V2]
 // Ўзингни севгандек ўзгани севгин! //
 // Ягона Худойингни, Ягона Худойингни,
 Бутун қалбинг, бутун жонинг,
 Бутун ақлинг ва кучинг билан севгин! //

[V3]
 // Ўзгани ҳукм қилма бўлмайсан маҳкум! //
 // Ягона Худойингни, Ягона Худойингни,
 Бутун қалбинг, бутун жонинг,
 Бутун ақлинг ва кучинг билан севгин! //

[V4]
 // Солиҳлик йўлидан юр бўлмайсан нобуд! //
 // Ягона Худо сени, Ягона Худо сени,
 Бутун ҳаётингда, тутган ҳаёлингда,
 Жаннат маконида қолдирмас ёлғиз! //

[V5]
 // Каломни эшитганмас бажарган солиҳ! //
 // Ягона Худойингни, Ягона Худойингни,
 Бутун қалбинг, бутун жонинг,
 Бутун ақлинг ва кучинг билан севгин! //</lyrics>
