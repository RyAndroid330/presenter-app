<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>52</hymn_number>
<title>Ким Белимга Камарни Боғлар W52</title>
<lyrics>[V1]
.    E           B7         E  C#m
 //  Ким белимга камарни боғлар,
.E           B7        E  C#m
 Ким менга ғалаба келтирар?  //
.    A      B7        E  C#m
 //  Фақат Уни улуғлайман,
.F#m    B7          E
 Фақат Уни юксалтираман!  //

[C1]
.      E    A      B7        C#m
   //   Мен Сени тараннум этаман,
.    A B7         E  C#m
   Биродарларим билан.
.  A   B7   E       C#m
   Юк- сал- ти- ра- ман,
.    F#m    B7      E
   Сенинг Номинг Раббим.
.        C#m    F#m    B7      E
   О, Раббим, Сенинг Номинг Раббим!  //</lyrics>
<key>E</key>
</song>