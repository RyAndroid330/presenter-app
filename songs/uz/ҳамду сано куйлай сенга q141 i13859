<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>141</hymn_number>
<title>Ҳамду сано куйлай Сенга Q141</title>
<lyrics>[V1]
.Ab                      C#   Ab
 Ҳамду сано куйлай Сенга Масиҳим,
.C#           Ab        C#   Ab
 Дил тўрида сақлай Сени Масиҳим.

[C1]
.     C#            Eb             Ab
   // Менга берган хушкаломинг қўлимда,
.  Eb        C#         Eb  Ab
   Элу юртга сўйлай уни Масиҳим. //

[V2]
 Йиқилганни турғизувчи Масиҳим,
 Тоза юрак яратувчи Масиҳим.

[C2]
   // Гуноҳкорни гуноҳдан озод этиб,
   Ўз жонини қурбон қилган Масиҳим. //

[V3]
 Ҳамду сано куйлай Сенга Масиҳим,
 Дил тўрида сақлай Сени Масиҳим.

[C3]
   // Менга берган хушкаломинг қўлимда,
   Элу юртга сўйлай уни Масиҳим. //</lyrics>
<key>Ab</key>
</song>