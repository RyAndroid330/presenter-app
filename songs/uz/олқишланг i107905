<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.   C
 //  Олқишланг, олқишланг
.Am
 Қалб эшигин очинг ланг.
.Dm
 Кириб келсин Раббимиз
.G
 Фақат У билан яшанг! //

[C1]
   // Олқишланг, олқишланг
   Кўкни тутсин мадҳингиз.
   Имон билан тузилган
   Сизнинг янги ахдингиз. //
   //// Олқишланг ////

[V2]
 // Олқишланг, олқишланг
 Мақтов айтинг бетиним
 Чунки Нажоткор келди
 У билан бахтли куним //</lyrics>
<title>Олқишланг</title>
<author>Равшан Хизиров, Бауржон Пўлатов</author>
</song>