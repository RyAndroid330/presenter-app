<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>117</hymn_number>
<title>Инсон қалби Q117</title>
<lyrics>[V1]
.   Dm           Gm   Dm
 // Инсон қалби поралидур,
.Gm     Bb    Gm    Dm
 Сенсиз яшай билмам Исо,
.Dm           Gm  Dm
 Бу ҳаётим азобдадир,
.Gm     Bb    Gm    Dm
 Сенсиз яшай билмам Исо. //
.   Dm Gm   Dm     Gm
 // Эй ёра, йўқдир чора,
.Gm     Bb   Gm     A
 Сенсиз яшай билмам Исо, //

[C1]
.  D           Gm   D
   Мўъжизалар яратганга,
.  Gm            Bb  A
   Шукур айтинг Масиҳга.
.  D          Gm  D
   Муқаддас жамоатида
.  Gm         Bb   A
   Топажаксиз Хушхабар.
.     Dm Gm    Dm    Gm
   // Эй ёра, йўқдир чора,
.  Gm      Bb   Gm    A
   Сенсиз яшай билмам Исо. //

[V2]
 // Инсон қалби нурни кўрди,
 Сенсиз яшай билмам Исо,
 Бу нурингни Сенда кўрди,
 Сенсиз яшай билмам Исо. //
 // Эй ёра, йўқдир чора,
 Сенсиз яшай билмам Исо. //</lyrics>
<key>Dm</key>
</song>