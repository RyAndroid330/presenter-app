<?xml version="1.0" encoding="UTF-8"?><song><title>Осмонга йўл Масиҳдур</title>
<lyrics>[C1]
.  Abm
   Осмонга йўл Масиҳдур,
.       C#m        F#
   Ҳаёт берган Масиҳдур.
.         B          E
   Қувонч берган Масиҳдур,
.              F#(C#m) Ab (Ebm)
   // Жаннатга йўл Масиҳдур. //

[V1]
.   Eb             Abm
 // Келинг барча инсонлар,
.(E)   B         F#
 Масиҳ сўзин эшитинглар. //
.     Abm      E
 Худо номин олқишлаб,
.         F#(C#m) Abm (Ebm)
 // Ҳамду сано билдиринглар. //

[C2]
   Осмонга йўл Масиҳдур,
   Ҳаёт берган Масиҳдур.
   Қувонч берган Масиҳдур,
   // Жаннатга йўл Масиҳдур. //

[V2]
.   Ebm          F#
 // Мададкорим Худойим,
.B        C#m      F#
 Муқаддас қон тўкибсан. //
.C#
 Олқиш сўзга лойиқсан,
.   Abm    C#       F#
 // Қурбон бўлиб ўлибсан. //
.Abm
 Қурбон бўлиб ўлибсан,
.C#         F#
 Гуноҳларни кўмибсан.
.Abm
 Сўнг қайтадан тирилиб,
.           F#       Abm
 // Инсонга бахт берибсан. //</lyrics>
<key>B</key>
</song>