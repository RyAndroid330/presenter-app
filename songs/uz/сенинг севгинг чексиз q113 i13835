<?xml version="1.0" encoding="UTF-8"?><song><title>Сенинг севгинг чексиз Q113</title>
<lyrics>[V1]
.   A              B        F#m      C#m
 // Сенинг севгинг чексиз, ўзгармас мутлақ,
.        A         B    A         C#m
 Сенинг сабринг чексиз,шифобахш булоқ. //

[C1]
.      C#m              F#m         C#m
   /// Сен каби бўлишга интилар ҳар дил,
.  F#m                 A        E
   Оҳ бунча ягонасан, дурдонам Тангрим. ///

[V2]
 // Ҳаётимда сабоқ,қалбимга чироқ,
 Бу севгинг хосиятин,сирларин ўргат. //</lyrics>
<key>E</key>
<hymn_number>113</hymn_number>
</song>