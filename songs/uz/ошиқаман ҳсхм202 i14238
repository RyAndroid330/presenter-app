<?xml version="1.0" encoding="UTF-8"?><song><key>Bbm</key>
<lyrics>[V1]
.Bbm
 Ошиқаман Сенинг уйингга,
.Fm                   Ebm
 Ҳузурингни излайман тинмай.
.   Ebm          Ab      C#
 // Ёққим келур Сенинг дилингга,
.Ebm           Fm      Bbm
 Сажда қилгум келур тўхтамай. //

[C1]
.     Bbm    Ebm
   // Бутун онгим билан,
.  Ab     C#
   Бутун жоним билан,
.  Bbm        Ebm   F       Bbm
   Ва юрагим билан севаман Сени. //

[V2]
 Ором берур менга ҳузуринг,
 Суҳбат қилганимда Сен билан.
 // Етакласин Муқаддас Руҳинг,
 Ҳаётимнинг маъноси Сенсан. //</lyrics>
<title>Ошиқаман ҲСХМ202</title>
<author>Малоҳат Пулатова</author>
<hymn_number>147</hymn_number>
</song>