<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.    Am
 // Сенинг Севгинг бетакрор
.Dm
 Ҳаётимда Сенсан бор
.Am
 Севгинг ила мавжудман
.Dm
 Буни айтаман такрор! //

[C1]
.   Am
   Сен Севгисан Раббоним
.   Dm
   Сен Севги меҳрибоним
.   Am
   Дунёда севги йўқдир
.    Em
   Ягона Севгим, борим

[V2]
 Сенинг севгинг таратай
 Ишда севгинг кўрсатай
 Севги эканлигингни
 Барчага аён этай</lyrics>
<title>Сен Севгисан Раббоним</title>
<author>Улуғбек Жўраев</author>
</song>