<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<author>Һәмра ака</author>
<title>Бор Парвардигор Худо CA23 W25 Q214</title>
<lyrics>[V1]
.   Am                F
 // Дунё бошдан оёқ нодонлашиб,
.Em                  G
 Яратгувчи Эга йўқ деса, //
.   Am                F
 // Бор Парвардигор Худо!
.C                      G F G
 Осмонларда мангу мавжуд бор! //  .

[V2]
 // Гуноҳкор инсон гуноҳнинг илигидан
 Озод бўлмоқ чора йўқ деса, //
 // Бор Парвардигор Худо
 Кўкдан ерга келган Нажоткор! //

[V3]
 // Ишончи йўқ банда жафога дуч келиб
 Ноумид ҳеч амал йўқ деса //
 // Бор Парвардигор Худо
 Қутқарувчи Исо Масиҳ бор! //

[B1]
   Бор Парвардигор Худо
   Осмонларда мангу мавжуд бор!
   Бор Парвардигор Худо
   Кўкдан ерга келган Нажоткор!
   Бор Парвардигор Худо
   Қутқарувчи Исо Масиҳ бор!</lyrics>
<key>Am</key>
<aka>Дунё бошдан оёқ нодонлашиб</aka>
</song>