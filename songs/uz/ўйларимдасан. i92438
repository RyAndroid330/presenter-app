<?xml version="1.0" encoding="UTF-8"?><song><aka>Отган Тонглардай</aka>
<lyrics>[V1]
 // Отган тонглардай нурлар таратдинг
 Юракда янги юрак яратдинг //

[C1]
   // Ўйларимдасан, куйларимдасан
   Юрагимдасан Исо, севаман Сени //

[V2]
 // Биламан Сени азалдан борсан
 Буюкдир севгинг, ҳаммага ёрсан //

[V3]
 // Сен Йўл, Ҳақиқат ва Ҳаётдирсан
 Қалбим тубида бир баётдирсан //

[V4]
 // Кутаман Сени ваъда бергансан
 Ваъдангга кўра қайтиб келарсан //</lyrics>
<title>Ўйларимдасан.</title>
</song>