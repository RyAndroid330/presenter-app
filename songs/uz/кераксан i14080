<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Эрта тонгдан сени учратмоқчиман
 Жамолинг нурини мен кўрмоқчиман
 Бу дунё ташвишларини унутмоқчиман
 Сени паноҳингда яшашни истайман //

[C1]
   // О Сен кераксан менга Раббим
   О сенсиз яшолмайман Тангрим //
   // Шунинг учун бўлгин Раббим яқин
   Ҳаётимда бўлгин сен паноҳим //

[V2]
 // Қаерга бораман ахир сен ҳақиқат йўлсан
 Сенсиз ҳаётимни таъсаввур қилолмайман
 Чунки сендан келар нажот мен томон
 Сен билан юрагим шодликка тўлар ҳамон //</lyrics>
<title>Кераксан</title>
<author>Собир Умуров</author>
</song>