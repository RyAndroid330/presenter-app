<?xml version="1.0" encoding="UTF-8"?><song><aka>Муқаддас Раббим</aka>
<lyrics>[V1]
.   Am                G       Am
 // Муқаддас Раббим, Сенга интилдим,
.G                   C
 Чунки Сен дилларга ором. //

[C1]
.     Am      Dm        F    G
   // Сенинг бағрингда ором топаман,
.  C         Dm        Am
   Менинг дилим ором топади. //

[V2]
 // Биламан Сенда абадий қувонч,
 Ва улуғ муҳаббат Сенда. //

[V3]
 // Ва энди ҳеч ким мендан ололмас,
 Сен менга берган шодликни. //

[V4]
 // Ва қачон келса қазо соатим,
 Оласан мени Ўзингга. //</lyrics>
<key>C</key>
<title>Муқаддас Раббим, Сенга интилдим W79 Q47</title>
<hymn_number>112</hymn_number>
</song>