<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<lyrics>[V1]
 // Юрагим интилар
 севгинга талпинар
 Сен эса келасан ёнимга
 Юрагим интилар
 севгинга талпинар
 Сен эса келасан ёнимга //

[C1]
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Севгинга тўламан
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Сен билан бўламан

[V2]
 // Бу дунё ташвишдан
 Шошилади қаерга
 Мен эса келаман ёнинга //

[C2]
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Севгинга тўламан
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Сен билан бўламан

[B1]
   // Сен билан //
   Сен билан, Исо
   Фақат сен билан Раббим
   /// Сени деб ///
   Фақат сени деб
   /// Сени деб ///

[C3]
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Севгинга тўламан
   Муқаддас Худо Муқаддас Худо
   Сени мен кўраман
   Сен билан бўламан Исо</lyrics>
<title>Мукаддас Худо</title>
</song>