<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.    D                    G
 // Денгиздаги бир кема каби,
.A            A7       D
 Бир тану бир жон бўлайлик.
.D                   G
 Ҳақ Раббоним бошимизда,
.A            A7     D
 Биз бир маҳалла бўлайлик. //

[C1]
.     D     G         A
   //  Худойимиз муқаддас,
.          F#m         Bm
   Сен ҳам бўлгин муқаддас.
.      Em                    A
   Нурафшон (Қадрдон) Ўзбекистон,
.       D             D7
   Муқаддас бўл, муқаддас! //

[V2]
 // Меҳру мурувват шиоримиз,
 Солиҳ меҳрибон бўлайлик.
 Раббий бўлсин паноҳимиз,
 Хур Ўзбекистон бўлайлик! //

[B1]
   Эй, муқаддас маҳаллам
   Муқаддас бўл, муқаддас!</lyrics>
<title>Денгиздаги бир кема каби W26</title>
<author>Зафар</author>
<hymn_number>26</hymn_number>
</song>