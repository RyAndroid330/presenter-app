<?xml version="1.0" encoding="UTF-8"?><song><title>Ўғил қизим бардам бўл</title>
<lyrics>[V1]
 // Ўғил, қизим бардам бўл
 Калом ўқиб доно бўл //
 // Тилингдан тушмасин Исо
 Борлиқни яратган Худо //

[C1]
   Ўғил, қизим бардам бўл
   Калом ўқиб доно бўл

[V2]
 // Яратганнинг олдига
 Покдил бўлиб борайлик //
 // Муқаддас Руҳни берди
 Ҳамду сано айтайлик //

[V3]
 // Яратганку Ўзимизни
 Ҳам ризқ-рўзимизни //
 // Тобе қилиб борлиқни
 Порлатган қуёшини //</lyrics>
</song>