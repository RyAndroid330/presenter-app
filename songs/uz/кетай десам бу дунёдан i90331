<?xml version="1.0" encoding="UTF-8"?><song><title>Кетай десам бу дунёдан</title>
<lyrics>[V1]
.   Db               F#               (Db)
 // Кетай дўстлар бу дунёдан Отажонимни соғиндим. //
.   Db         F#      Ab         F#    Db
 // Манинг учун жонин берган Исо раббимни соғиндим. //

[V2]
 // Омон бор деб дуо қилган бизни севиб ўғлин берган //
 // Ўз руҳини бизга берган Отажонимни соғиндим //
 Отажонимни соғиндим

[V3]
.   Db                Ebm     F#        Db
 // Фарзандим деб қўлга олган адашганда йўлга солган //
.F#                 Ebm    Ab      Db
 Қўзичоқ деб исмим қўйган чўпонимни соғиндим
.   Db              F#
 // Бир иймонга эга бўлган қадрдондан азиз бўлган //
.   Db               F#        Ab     Db
 // Хайрлашиб йиғлаб кетган Азизларимни соғиндим //
.Ebm    Ab     Db
 Азизларимни соғиндим</lyrics>
