<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>277</hymn_number>
<author>Эддие Эспиноса</author>
<title>Раббим, о Раббим CA21 ҲС78</title>
<aka>Мени Ўзгартир</aka>
<lyrics>[V1]
.   D         Em  A         D
 // Ҳақиқат билан мени ўзгартир,
.Bm         Em   A         D
 Сендек бўлайин, мени ўзгартир! //

[C1]
.  F#      Bm     G     A     D
   Сен Кулолимсан, мен эса лойман,
.  F#  F#7/Bm    G         A
   Ясаб ўзгартир, ибодатим шу!

[V2]
.D         Em A           D  Bm
 Ҳақиқат билан, мени ўзгартир,
.Bm         Em   A         D
 Сендек бўлайин, мени ўзгартир!

[C2]
.  G  A     F#m Bm
   Раббим, о Раббим!
.       Em      A Asus D7    B7
   қилай чин дилдан Сенга таъзим!
.  G  A     F#m Bm
   Раббим, о Раббим!
.       Em      A            D
   қилай чин дилдан Сенга таъзим!

[V3]
.D6 D4 A  G         A7
  У сизни бутун мухаббати,
.    D          Bm
 ила тўла қамраб олсин!
.     Em         A
 Бутун севгисини бериб,
.   D     Bm      D7
 юракка шодлик солсин!
.D6 D4 A  G         A7
  У сизни бутун мухаббати,
.    D          Bm
 ила тўла қамраб олсин!
.     Em         A
 Бутун севгисини бериб,
.       D    Bm      D7
 қалбларга қувонч солсин!</lyrics>
<key>D</key>
</song>