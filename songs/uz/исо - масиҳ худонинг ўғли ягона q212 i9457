<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em       D          Em
 // Исо Масиҳ, Худонинг Ўғли ягона!
.Em        D             Em
 Исо Масиҳ, Худонинг қурбони! //

[C1]
.     Em       Am         D7
   // Ташаккур айтамиз Сенга - Худойим,
.  G    Em
   Раббимиз!
.  Em         Am            B7
   Фақат - Сенга, биз кўйлаймиз!
.  B7         Em/E
   Фақат - Сенга
.  E7         Am           D7         G       Em
   Фақат - Сенда, нажот топдим, ҳа Азизим, Раббим!
.  Em    Am         B7             Em
   Ҳаётимни бағишлайман фақат - Сенга! //</lyrics>
<title>Исо - Масиҳ Худонинг Ўғли ягона Q212</title>
<hymn_number>212</hymn_number>
</song>