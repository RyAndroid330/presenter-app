<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.     F     C    Am    F
   // Ботир бўл, кучли бўл!
.         C       F      G
   Чунки, Худованд сен биландир! //

[V1]
.   F       G      Am
 // Мен ҳеч қўрқмайман,
. F      G     Am
 Умидсиз бўлмайман.
.F           G      C     Am
 Чунки, мен юраман имон билан,
.F          G        C     Am
 Келинг ва юринглар имон билан! //

[V2]
 // Биз ҳеч қўрқмаймиз,
 Умидсиз бўлмаймиз.
 Чунки биз юрамиз имон билан,
 Келинг ва юринглар имон билан! //
 Чунки Худованд биз биландир!</lyrics>
<key>C</key>
<aka>Мен ҳеч қўрқмайман</aka>
<title>Ботир бўл, Кучли бўл W16</title>
<hymn_number>16</hymn_number>
<author>Моррис Чапман</author>
</song>