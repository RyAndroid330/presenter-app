<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Йиғлама эй аёл йиғлама, сен учун Масиҳ ўлган, //
 // Ва қайтадан тирилиб, сен учун ҳаёт берган. //

[V2]
 // Йиғлама ҳеч йиғлама сен учун Масиҳ келган, //
 // Хўрланма хоп юрагинг ҳаётинг тугалмаган. //

[V3]
 // Кел энди Раббимизнинг фарзанди дилбанди бўл, //
 // Шаҳаншоҳ султонининг руҳоний маликаси. //

[V4]
 // Қалбингда Раббий яшар,бағрингга қувонч келар, //
 // Ҳижронли тунларингда Раббий ёнингда бўлар. //</lyrics>
<title>Йиғлама эй аёл йиғлама Q186</title>
<hymn_number>186</hymn_number>
</song>