<?xml version="1.0" encoding="UTF-8"?><song><aka>Исонинг азоблари</aka>
<lyrics>[C1]
.  G                          D
   Ана эшитилди, Гетсимания боғида.
.     G
   // Гуноҳкор бўлган, мен учун нолиган,
.  Am          G
   Раббимнинг овози! //

[V1]
.   G              Am
 // Эй, Ота мумкин бўлса,
.Am      D        G
 Бу заққум коса менинг! //
.   G
 // Ёнимдан ўтиб кетсин деб,
.       Am                G
 Менинг Раббим дуо қилиб турди! //

[V2]
 // Лек мен истагандек эмас,
 Сен истагандек, //
 // Бўлсин Отам деб, Масиҳим
 Менинг Раббим дуо қилиб турди. //

[V3]
 // Жон ўлим олдидалигини
 Сезиб қийналиб, //
 // Уч марта ерга йиқилиб,
 Менинг Раббим дуо қилиб турди! //</lyrics>
<key>G</key>
<title>Ана эшитилди</title>
</song>