<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[V1]
.   Gm         Cm
 // Осмондан нажот келди,
.Eb       Dm     Gm
 Худодан хабар келди. //
.   Gm           Cm
 // Инсонларнинг қалбига
.Eb        Dm     Gm
 Ялтираган руҳ берди. //

[C1]
.     Gm         Cm
   // Озодлик йўлин берди,
.  Eb       Dm     Gm
   Ёруғлик йўлин берди. //

[V2]
.   Cm
 // Нур зулматда порлади,
.Eb            Dm  Gm
 Зулмат қоплай олмади. //
.   Gm           Cm
 // Неки яралган булса
.Eb        Dm  Gm
 Исо билан яралди. //

[V3]
.   Cm
 // Нур борида юринглар,
.Eb          Dm    Gm
 Унга хизмат қилинглар. //
.   Gm          Cm
 // Севгисидан тотинглар,
.Eb          Dm   Gm
 Руҳидан руҳланинглар. //

[V4]
.   Cm
 // Яртганнинг одамидан,
.Eb           Dm    Gm
 Минг розиман Ўглингдан, //
.   Gm           Cm
 // Берган ёруғ йўлингдан,
.Eb         Dm     Gm
 Шодланаман кўнглимдан. //</lyrics>
<title>Осмондан нажот келди</title>
</song>