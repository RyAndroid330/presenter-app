<?xml version="1.0" encoding="UTF-8"?><song><author>Френч, ункновн</author>
<lyrics>[V1]
 КЕЛГИН КЕЛГИН ИММАНУЭЛ
 ҚУЛЛИК ЗАНЖИРЛАРИДАН ОЗОД ҚИЛ
 ХУДО ЎҒЛИ КЕЛГУНИЧА
 ЁЛҒИЗ ВА ҚУВҒИНДАГИ ҲАЛҚИНГ

[C1]
   ШОДЛАН, ШОДЛАН! ИММАНУЭЛ
   КЕЛАР СЕНГА ХУДО ТАНЛАГАН ЭЛ

[V2]
 КЕЛГИН ХУДОНИНГ ҚУДРАТЛИ КУЧИ
 ЯКСОН БЎЛСИН ИБЛИС КИШАНЛАРИ
 ҚУТҚАР АЗОБЛАРДАН БИЗНИ
 БЕРГИН ЎЗ ҲАЛҚИНГА ҒАЛАБАНГНИ

[V3]
 КЕЛГИН ХУДОНИНГ МУҚАДДАС НУРИ
 УЙҒОТ ҒАФЛАТ УЙҚУСИДАН БИЗНИ
 КЕТСИН ЗУЛМАТ БУЛУТЛАРИ
 КЕТСИН БУ ЕРДАН ЎЛИМ СОЯСИ

[V4]
 КЕЛГИН, КЕЛГИН ДОВУДНИНГ КАЛИТИ
 ОЧГИН ОСМОН УЙИНГ ДАРВОЗАСИН
 ЎЗИНГ ТОМОН БОШЛА БИЗНИ
 АСРА ДОИМ ЙЎЛЛАРИМИЗНИ

[V5]
 КЕЛГИН ҚУДРАТЛИ ХУДО АДОНАЙ
 МУҚАДДАС МАСКАНИНГДИР ТОҒ СИНАЙ
 БЕРДИНГ ҲАЛҚИНГГА ҚОНУНЛАРИНГ
 ЮБОР ЭНДИ БУЮК МАРҲАМАТИНГ

[C2]
   ШОДЛАН, ШОДЛАН! ИММАНУЭЛ
   КЕЛДИ СЕНГА ХУДО ТАНЛАГАН ЭЛ</lyrics>
<title>Келгин Иммануел</title>
</song>