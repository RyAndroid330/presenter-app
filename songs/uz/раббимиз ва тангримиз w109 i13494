<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>109</hymn_number>
<title>Раббимиз ва Тангримиз W109</title>
<aka>Бор бўлган</aka>
<key>B</key>
<lyrics>[V1]
.   Abm          E
 // Раббимиз ва Тангримиз,
.F#         Ebm
 Қудратга лойиқсан.
.E       C#m
 Ҳаммага қодир Худо,
.Ebm          Abm
 Ҳурматга лойиқсан. //

[C1]
.     Abm
   // Бор бўлган
.  E     F#   Ebm Abm
   Ҳозир ҳам, бор бўлган
.  E     F#   Ebm Abm
   Ҳозир ҳам, бор бўлган
.          F#
   Бор бўлгайсан. //

[V2]
 // Ҳаммани Сен яратдинг,
 Ироданг билан.
 Йўқдан бор пайдо қилдинг,
 Сўзинг билан. //

[C2]
.     Abm
   // Бор бўлган
.  E     F#   Ebm Abm
   Ҳозир ҳам, бор бўлган
.  E     F#   Ebm Abm
   Ҳозир ҳам, бор бўлган
.          F#
   Бор бўлгайсан. //

[B1]
.  Abm     E     F#  Ebm
   Шон-шуҳрат ва куч-қудрат,
.         F#
   Бор бўлгайсан.</lyrics>
</song>