<?xml version="1.0" encoding="UTF-8"?><song><title>Ёш ва қари Q222 W28 ҲС13</title>
<key>C</key>
<lyrics>[V1]
.   C
 // Ёш ва қари, яқин ва нари бўлганлар
.       G                  C
 Шукур қилайлик, хурсанд бўлайлик //

[C1]
.     F
   // Худойим Сенга раҳмат айтамиз
.          G (C)
   Шукурга лойиқсан //

[V2]
 // Шимол ва шарқда, жануб ва ғарбда турганлар
 Шукур қилайлик, хурсанд бўлайлик //

[V3]
 // Ўзбек ва руслар ва барча халқлар Худога
 Шукур қилайлик, хурсанд бўлайлик //

[V4]
 // Ориқ ва семиз, пакана новча ҳаммамиз
 Шукур қилайлик, хурсанд бўлайлик. //</lyrics>
<author>Илияс Турсун</author>
<hymn_number>222</hymn_number>
</song>