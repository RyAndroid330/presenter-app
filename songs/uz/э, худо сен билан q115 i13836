<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Эй Худо Сен билан турмушим обод,
 Эй Худо Сен билан дилларимиз шод. //
 // Эй Худо Ўзингсан дардларга шифо,
 Сенсиз билмасмиз ҳаёт не асло. //

[C1]
   /// Эй Худо ///  Ўзингсан улуғсан эй Худо.
   /// Эй Худо ///  Сени севдим доимо эй Худо.

[V2]
 // Эй Худо юракни Ўзинг давола,
 Эй Худо қулингга бергин кучингни. //
 // Эй Худо нурингни Ўзинг тўлдириб,
 Бу ёруғ дунёга кўрсат кучингни. //

[V3]
 // Эй Худо беморга бергин кучингни,
 Эй Худо номингни улуғлайлик биз. //
 // Эй Худо доимо ёд этиб Сени,
 Худосиз турмушни кўрмайлик асло. //</lyrics>
<aka>Эй Ҳудо Сен билан (2)</aka>
<title>Э, Худо Сен билан Q115</title>
<hymn_number>115</hymn_number>
</song>