<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>51</hymn_number>
<lyrics>[V1]
 // Ўзбекистон Худо сўзин эшит,
 Ўзбекистон Унга қара. //

[C1]
   // Исо йўлдир, У ҳақиқат,
   Исо ҳаётдур, оламга бугун. //

[V2]
 // Унинг олдида ҳар бир жон тиз чўксин,
 Исо ҳамма учун Раббий. //

[V3]
 // Бутун халқлар учун фақат битта йўл бор,
 фақат битта Исо Масиҳ, //

[V4]
 // Ўзбекистон Худо сўзин эшит,
 Ўзбекистон Унга қара. //</lyrics>
<aka>Ўзбекистон</aka>
<title>Исо йўлдир, У ҳақиқат Q154</title>
</song>