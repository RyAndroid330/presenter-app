<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Хаёлимдасан юрагимдасан
   Сени севаман Исо
   Қалбан интилиб Сени соғиниб
   Яшаяпман (кутаяпман) мен //

[V1]
 Бу дунёнинг дастидан
 Юрак тўла жароҳат
 Орзу эмас армон кўп
 Кўзда тўла ёшлар

[V2]
 Азоблардан қийналиб
 Дардим ошкора этиб
 Армонларга тополмай ечим
 Келдим ҳузурингга Раббим

[C2]
   // Хаёлимдасан юрагимдасан
   Сени севаман Исо
   Қалбан интилиб Сени соғиниб
   Яшаяпман (кутаяпман) мен //

[B1]
   Сен менинг Нажоткорим
   Сен менинг Юпатувчим
   Кўз ёшларим артгувчим
   Қалбга тинчлик бергувчим
   Умидимсан Раббим

[C3]
   // Хаёлимдасан юрагимдасан
   Сени севаман Исо
   Қалбан интилиб Сени соғиниб
   Яшаяпман (кутаяпман) мен //</lyrics>
<title>Хаёлимдасан юрагимдасан</title>
<author>Улуғбек Жўраев</author>
</song>