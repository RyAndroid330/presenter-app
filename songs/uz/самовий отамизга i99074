<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Самовий Отамизга
 Бўлсин доим шон
 Унинг меҳрибонлиги
 Бизга бепоён! //

[C1]
   // Шон-шарафлар Раббимизга!
   Ҳамдо сано Худога!
   Муқаддас Руҳинг бизга,
   Ёр бўлсин эй, Оминг! //

[V2]
 // Халоскорим Сенга ҳам
 Бўлсин доим шон
 Фақат Сенда нажот топди
 Гуноҳкор инсон! //

[V3]
 // Муқаддас Руҳ Сенга ҳам
 Бўлсин доим шон
 Оғир ҳаёт йўлимизни
 Созлайсан оссон! //</lyrics>
<title>Самовий Отамизга</title>
</song>