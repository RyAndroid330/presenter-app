<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Хохламайди тун кундуз бўлишга
 Истамайди ой қуёш бўлишга //
 // Келмайди инсон Худо ёнига
 Негаки инсон аср гуноҳга //

[C1]
   // Сен мен келдик Худога
   Нега бу дунё бош эгамас унга
   Сен мен келдик Худога
   Нега бу дунё бош эгамас унга //

[V2]
 // Хохламайди ва ортга қолишга
 Истамайди бахт хазон бўлишга //
 /// Ҳар неки бўлар Худо қўлида
 Гар шошмаса инсон қолади азобга ///

[C2]
   /// Сен мен келдик Худога
   Нега бу дунё бош эгамас унга ///
   Сен мен келдик Худога
   Энди дунё керакмикан кимга</lyrics>
<title>Хохламайди</title>
</song>