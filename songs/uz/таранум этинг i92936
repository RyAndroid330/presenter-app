<?xml version="1.0" encoding="UTF-8"?><song><title>Таранум Этинг</title>
<lyrics>[V1]
 // Эгамизга шукур айтинг
 Унга сажда қилинг
 Таранум қилиб уни
 Ҳамду Сано ила қўшиқ айтинг //

[C1]
   // Муқаддас номи ила
   Муқаддас номи ила
   Эгамиз билан фахрланинг //

[V2]
 // Қудратли Эгамизга
 Юракдан сажда қилинг
 Унинг хузурида
 Бўлишга интилинг //

[C2]
   ️ // Муқаддас номи ила
   Муқаддас номи ил
   Эгамиз билан фахрланинг️ //

[B1]
   Юракдан унга кўйланг, кўйланг
   Юракдан унга сажда қилинг сажда қилинг
   Эгамиз лойиқдир шон шухратлага
   Унинг номини таранум этинг
   Таранум Таранум Таранум
   Этинг уни Ҳаллелуя</lyrics>
<author>Собир Умуров</author>
</song>