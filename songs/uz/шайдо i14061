<?xml version="1.0" encoding="UTF-8"?><song><title>Шайдо</title>
<lyrics>[C1]
   // Бўлдим сенга мен шайдо
   Ҳеч бўлгим келмас сендан жудо //
   // Раббим йўқлаб топдинг мени
   Ғариб ҳолимда севдинг мени //
   // Бўлдим сенга мен шайдо
   Ҳеч бўлгим келмас сендан жудо //

[V1]
 // Чанг устимни қоқдинг
 Юзимни ювиб арттинг //
 // Бағрингга босиб йиғладинг
 Боламсан деб мени севдинг //
 // Бўлдим сенга мен шайдо
 Ҳеч бўлгим келмас сендан жудо //
 // Раббим йўқлаб топдинг
 Ғариб ҳолимда севдинг //
 // Бўлдим сенга мен шайдо
 Ҳеч бўлгим келмас сендан жудо //

[V2]
 // Югураман ҳурсанд бўлиб
 Дўстларимга сени айтиб //
 // Бор эканку азиз Отам
 Кенг оламни бунёд этган //
 // Бўлдим сенга мен шайдо
 Ҳеч бўлгим келмас сендан жудо //
 // Раббим йўқлаб топдинг мени
 Ғариб ҳолимда севдинг мени //
 // Бўлдим сенга мен шайдо
 Ҳеч бўлгим келмас сендан жудо //</lyrics>
</song>