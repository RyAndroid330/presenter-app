<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<title>ЙЎЛЛАР</title>
<key>Em</key>
<lyrics>[V1]
.   Em D Em
 // ҲАМРОҲИМСАН ЭЙ РАББИМ,
.Em D Em
 ЁНИМДА ЮРГИН ДЕДИМ. //
.   GD
 // УЗУН ОППОҚ КИЙИМИНГДАН,
.Em D Em
 УШЛАБ СЕНДАН АЙРИЛМАЙ ДЕДИМ. //

[C1]
.     Em D
   // ОҲ ЙЎЛЛАР, ЙЎЛЛАР, ЙЎЛЛАР,
.  Em D
   ЕНДИ СЕНДАН КИМ ҚЎРҚАР. //
.     GD
   // РАББИМ ЁНИМДА МЕНИНГ //
.     Em D
   // ЕНДИ ЙЎЛЛАР ЁРИШАР,
.  Em D
   РАББИМ МЕНИ БОШҚАРАР, //
.  Em D Em
   РАББИМ МЕНИ БОШҚАРАР.
   РАББИМ, РАББИМ, ЖОН РАББИМ

[V2]
 // СЕН ЯХШИСАН ЖОН РАББИМ,
 КЎЗ ҚУЛОҚСАН МЕНГА ТАНГРИМ. //
 // ШИРИН МАЙИН ОВОЗИНГДАН,
 АТРОФИНГДА ЎЙНАБ КУЛДИМ. //</lyrics>
<aka>Ҳамроҳимсан Раббим</aka>
</song>