<?xml version="1.0" encoding="UTF-8"?><song><aka>Исо Масиҳ қутқарган</aka>
<key>D</key>
<lyrics>[V1]
.   D                        Bm
 // Исо Масиҳ қутқарган, гуноҳдан озод қилган,
.G                          A
 Олқишлаймиз биз Сени, Худо Ўғли аталган. //

[C1]
.     D                          Bm
   // Олқишлаймиз биз Сени, бир, икки ва минг марта,
.  G                         A
   Қутқарувчи Эгамиз тахтинг олдида туриб. //

[V2]
 // Олқиш, мақтов Раббимизга, Қутқарувчи Эгамизга,
 Бизларни қувонтирган, Худо фарзанди қилган. //</lyrics>
<title>Олқишлаймиз Q129</title>
<hymn_number>129</hymn_number>
</song>