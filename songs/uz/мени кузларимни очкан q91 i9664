<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Gm
 // Мени кўзларимни очган,
.Bb
 Менга порлоқ нурин сочган.
.Cm
 Ундан иблис ҳам қочган,
.Cm            Gm
 Исо Худонинг Ўғли. //

[C1]
.          Gm      Cm
   // Исо жоним менинг,
.       D       Gm
   Исо таним менинг,
.  Dm               Gm
   Ҳаётим, Ноним менинг. //

[V2]
 // Мени Ўз бағрига олган,
 Менга Муқаддас Руҳини юборган.
 Мен билан абадий қолган,
 Исо Худонинг Ўғли. //

[C2]
   // Исо жоним менинг,
   Исо таним менинг,
   Ҳаётим, Ноним менинг. //</lyrics>
<key>Gm</key>
<title>Мени кузларимни очкан Q91</title>
<hymn_number>91</hymn_number>
</song>