<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>19</hymn_number>
<lyrics>[V1]
.   D             G      D
 // Бизнинг осмондаги Отамиз
.          A    D
 Сенинг номинг улуғ! //
.   D            G
 // Осмонда бўлгани каби
.D           A     D
 Ерда ҳам номинг улуғ! //

[C1]
.     D               G
   // Ҳамдлар бўлсин, ҳамдлар бўлсин
.  D               A D
   Ҳамдлар бўлсин Отага! //

[V2]
.   D           G      D
 // Бизга гуноҳ қилганларни
.            G  D
 Биз кечириб юрамиз //
.   D               G          D
 // Сен ҳам бизнинг гуноҳларимизни
.     A     D
 Кечиргин Ота //

[V3]
.   D           G            D
 // Ризқ-рўзимизни кунда берган
.         G   D
 Отамиз муқаддас //
.   D            G
 // Кучу қудрат, шону шуҳрат
.D            A  D
 Салтанат Сеникидир! //</lyrics>
<key>D</key>
<title>Бизнинг осмондаги Отамиз</title>
</song>