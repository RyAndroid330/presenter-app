<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<lyrics>[V1]
 // Агар биз Масиҳ билан бирга ўлган бўлсак
 У билан бирга ҳам яшаймиз
 Агар қийинчиликларга чидасак
 У билан бирга ҳукмронлик қиламиз //

[P1]
   Бордию уни рад этсак
   У ҳам бизни рад этади
   Содиқ бўлмасак ҳам Масиҳ
   Содиқ бўлиб қолаверади

[C1]
   // Эгамиз билади
   Эгамиз севади
   Эгамиз кутади
   Ўзиникиларни билади //</lyrics>
<title>Раббим Билади</title>
</song>