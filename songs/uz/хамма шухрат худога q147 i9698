<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>147</hymn_number>
<title>Хамма шухрат Худога Q147</title>
<lyrics>[V1]
.   Am           Em
 // Ҳамма шуҳрат Худога, //
.   G                     D          Em
 // Қалбим ва жоним билан Худони севаман. //
.   Am           Em
 // Ҳамма шуҳрат Худога. //

[C1]
.     Am                 Em
   // Исо олқишларимизни олгин, //
.     G                    D       Em
   // Гуноҳларни кечирди, Муқаддас Руҳин берди. //
.     Am                 Em
   // Исо олқишларимизни олгин. //

[V2]
.   Em(G)   A       Bm(C)(Bm)Em
 // Тасалли берувчи Муқаддас Руҳ, //
.   G(C)    (Bm)      Am(Em)
 // Юрагимизда туриб бизни бошқаради. //
.   G        Em(Am) G(C)C(Bm)Em
 // Тасалли берувчи Муқаддас Руҳ. //

[C2]
.     Am
   // Исо олқишларимизни олгин, //
.     G                   C  Bm    Em
   // Гуноҳларни кечирди, Муқаддас Руҳин берди. //
.     G                  C Bm Em
   // Исо олқишларимизни олгин. //</lyrics>
<key>Am</key>
</song>