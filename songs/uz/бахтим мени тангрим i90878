<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<title>Бахтим мени Тангрим</title>
<key>Em</key>
<lyrics>[V1]
.      Em          Am
 // Бахтим мени Тангрим
. H       Em
 Севаман Сени
. Em
 Билгин Раббим
. Am   H              Em
 Ҳеч кимга бермайман Сени //
.     Em                Am
 // Излаб топганим Сен ўзинг
. D         G
 Мен учун бебаҳо
. C            Am
 Билгин Раббим ҳамиша
.H             Em
 Сен юрагимда танҳо //

[C1]
.      C     D   G    D  C D    Em
   // Танҳо бебахҳо, танҳо бебахҳо //

[V2]
 // Хафа қилардим Сени
 Мен Раббим тинмай
 Ҳатто боқмай кетардим
 Азобинг билмай //
 // Мени севган Сен ўзинг
 Билмабман эй Худо
 Кечиргин мени Раббим
 Жоним Сенга фидо //</lyrics>
</song>