<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23010</hymn_number>
<author>Собир Умуров</author>
<title>Бизнинг Худо</title>
<lyrics>[C1]
.      Am           G
   /// Бизнинг Худо муқадддас ///
.      Am          G
   /// Худойимиз муқаддас ///

[V1]
.Am                G
 Осмон узра бизга қарагин
.Am            G
 Қўлинг билан бизга тегин
.Am        G
 Ва Сенинг фаришталаринг
.C                      E
 Ер юзига тинчлик олиб келсин

[C2]
.      Am        G
   /// Буюк Раббимиз ///
.      Am        G
   /// Буюк Худованд ///

[V2]
 Келсин ҳақиқат Ҳукминг Сенинг
 Ҳаётимиз қўлингда
 Ер юзи бўйлаб Сенинг
 Абадий Номинг Улуғлансин

[C3]
   /// Бизнинг Худо кучли
   Худойимиз кучли ///</lyrics>
<key>Am</key>
</song>