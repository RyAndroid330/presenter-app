<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>70</hymn_number>
<key>G</key>
<lyrics>[V1]
.   G                C      D
 // Сенга ҳамду сано куйлайман,
.           G      Em
 Сенга куйлайман Раббим.
.      C
 Чунки Сен буюк
.    D       G    C    G
 улуғлансин номинг. //

[V2]
 // Номингни улуғлайман, Раббим
 Улуғлайман Раббим
 Чунки Сен буюк улуғлансин Номинг //

[C1]
.     G            C
   // Ажойибсан Худойим,
.  D              G
   Сен гўзалсан Худойим,
.  Em          C
   Ажойибсан Худойим,
.  D               G   C    G
   Ҳамду сано куйлайман. //

[V3]
.    G         C
 // Исонинг буюклиги,
.D           G
 тугамасдир чиройи,
.Em            C
 Қалбимизнинг тубида
.D             G   C G
 юлдуз каби порлайди. //</lyrics>
<title>Сенга Ҳамду Сано Куйлайман ҲСХМ70</title>
</song>