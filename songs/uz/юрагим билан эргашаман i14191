<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13</hymn_number>
<aka>Бер Тоза Муқаддас Эҳтиросни</aka>
<lyrics>[V1]
.   C                    Am   Em
 // Бер тоза, муқаддас эҳтиросни,
.F          Dm         G
 Бер менга ажойиб бир фикрни.
.C                      Am       Em
 Бер ҳаётимга интилиш, умид бир мақсад,
.F        G         C
 Юрагим билан эргашаман. //

[C1]
.  C        F        G
   Юрагим билан эргашаман,
.  Am        F       G
   Ҳақиқатингга яқинлашиб.
.       Am         Em
   Бу дунё ёвуз ва бўш,
.          Am        D
   Раббим Сенинг олдингда.
.            F             G        Am(C)
   // Бер қўлингни мен ортингдан бораман. //</lyrics>
<key>C</key>
<title>Юрагим билан эргашаман</title>
</song>