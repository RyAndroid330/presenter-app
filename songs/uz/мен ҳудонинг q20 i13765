<?xml version="1.0" encoding="UTF-8"?><song><title>Мен Ҳудонинг Q20</title>
<lyrics>[C1]
   //// Мен Худонинг фарзандиман! ////
   Осмондан туғилдим бугун.
   Мен Худонинг фарзандиман!

[V1]
 // Узоқ узоқ йўллар кечдим. //
 // Дунёнинг заҳарини ичдим. //
 // Охири Инжилни очдим.
 Танладим янги ахдни мен. //

[V2]
 // Исо менга бўлди ҳамроҳ. //
 // У билан яшайман узоқ. //
 // Қалбимдадур Муқаддас Руҳ,
 Худованднинг маъбадиман. //

[V3]
 // Худовандга содиқ қолай, //
 // Тоза пок муқаддас бўлай. //
 // Раббим куч бер асраб қолай,
 Бу абадий ҳаётни мен. //</lyrics>
<hymn_number>20</hymn_number>
</song>