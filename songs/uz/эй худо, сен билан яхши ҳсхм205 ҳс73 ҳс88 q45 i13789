<?xml version="1.0" encoding="UTF-8"?><song><title>Эй Худо, Сен билан Яхши ҲСХМ205 ҲС73 ҲС88 Q45</title>
<lyrics>[V1]
.    Am
 // Эй Худо, Сен билан яхши,
.Dm
 Эй Худо, Сен меҳрибон.
.G                   Am    E
 Эй Худо, ташнаман ҳузурингга. //

[C1]
.     F                Am
   // Илтижо қилдим Сенга,
.  F                  Am
   Яқинлашдинг Сен менга,
.  F            Am  G    F   E
   Ожиз руҳимни Сен кўтардинг. //

[V2]
 // Худо шундай деган,
 Сендан асло айрилмайман,
 Сени асло ташлаб кетмайман. //

[C2]
   // Ботир юрак билан сафарга чиқаман,
   Қўрқмайман, қўрқмайман.
   Худо ёрдамимдир, душманлар мени
   Нима қилолади, нима қилолади? //</lyrics>
<key>Am</key>
<hymn_number>241</hymn_number>
<author>Илияс Турсун</author>
</song>