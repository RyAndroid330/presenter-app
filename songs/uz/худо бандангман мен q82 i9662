<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>82</hymn_number>
<aka>Гуноҳларимни кечир</aka>
<key>Gm</key>
<lyrics>[V1]
.   Gm            Eb
 // Гуноҳларимни кечир,
.Cm            Gm
 Гуноҳларимни кўтар. //
.   Cm                 Bb
 // Эй Худо бандангман мен,
.Eb            D    Gm
 Эй Худо қавмингман мен. //

[C1]
.  Cm             Bb
   Гуноҳларимни кечир,
.  Eb       D     Gm
   Гуноҳларимни кўтар.

[V2]
.   Cm                    Bb
 // Юрак касал, қалбим ногирон,
.Cm     F      Bb
 Ором бергил интизордирман. //
.   Cm                     Bb
 // Шифобахш Руҳ ҳамроҳим бўлсин,
.Eb           D          Gm
 Энди бу қалб шодликка тўлсин. //

[C2]
.  Cm       F     Bb
   Гуноҳларимни кечир,
.  Eb       D     Gm
   Гуноҳларимни кўтар.

[V3]
.   Gm
 // Изладим кўп бормисан Ўзинг?
.Cm           F        Bb
 Изладим кўп гапиргил сўзинг //
.   Cm                     Bb
 // Энди билдим бордирсан Ўзинг,
.Eb          D          Gm
 Энди билдим гапирдинг сўзинг. //

[C3]
.     Cm       F    Bb
   // Гуноҳларимни кечир,
.  Eb      D     Gm
   гуноҳларимни кўтар. //
.     Bb      D     Gm
   // Гуноҳларимни кўтар. //</lyrics>
<title>Худо бандангман мен Q82</title>
</song>