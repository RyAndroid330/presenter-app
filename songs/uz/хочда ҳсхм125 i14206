<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>125</hymn_number>
<key>D</key>
<lyrics>[V1]
.   D         A     Em          A
 // Хочда, хочда у ерда мен ўлганман,
.     D        A     Em   A   D
 Бу севги қалбимда дарёдай оқади. //

[C1]
.        Bm      F#m
   Ҳаёт берди У менга,
.          G     F#m
   қувват берди руҳимга,
.        G       F#m
   Умид берди ҳаётимга,
.   G       A
   Ҳаётим Сеники.

[V2]
 // Хочда, хочда у ерда мен ўлганман,
 Бу севги қалбимда дарёдай оқади. //

[C2]
.        Bm           F#m
   Шон-шуҳратинг мен билан,
.         G        F#m
   Куч-қудратинг қалбимда,
.        G       F#m
   Марҳаматинг ҳаётимда,
.   G       A
   Ҳаётим Сеники.</lyrics>
<title>Хочда ҲСХМ125</title>
</song>