<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>178</hymn_number>
<author>Новое Поколение (г. Рига, Лавия), Оскар Спрогис</author>
<tempo>124</tempo>
<key>Bbm</key>
<lyrics>[V1]
.C#                Ab     Bbm     F#
 Худо берган қурбонлик қутқарди оловдан,
.C#             Ab       Bbm             F#
 Исонинг яраларидан тузалдим бунга шубҳа йўқ.
.C#             Ab       Bbm     F#
 Исонинг қони билан оқландим гуноҳдан,
.C#              Ab      Bbm          F#
 Исонинг ўлими билан берилган абадий ҳаёт.

[C1]
.  C#                   Ab
   Улуғлагин менинг қалбим
.       Bbm       F#
   Раббимни, Раббимни,
.  C#
   Ва менинг бутун
.        Ab        Bbm        F#
   борлиғим улуғла Нажоткорни.
.  C#                   Ab      Bbm        F3
   Улуғлагин менинг қалбим Раббимни, улуғлагин Раббимни,
.  C#                Ab          Bbm
   Ва унутмагин сен учун қилган ишларини.

[B1]
.     C#              Ab
   // Ишонаман қурбонлигингга
.                 Bbm            F#
   Ва муқаддас қонингга, абадий ҳаётга,
.  C#                Ab         Bbm F# (Ab)
   Менинг номим ҳаёт китобида ёзилганига. //</lyrics>
<title>Худо Берган Қурбонлик ҲСХМ178</title>
<time_sig>4/4</time_sig>
</song>