<?xml version="1.0" encoding="UTF-8"?><song><title>Ким Сенга тенг CA7 W53 ҲС29 ҲСХМ199</title>
<aka>Барҳаёт Отамиз</aka>
<lyrics>[V1]
.   Am             Dm     Am
 // Ким Сенга тенг келади Ота,
.Bb        Gm        Am
 Коинотда тенги йўқ Сенга. //
.   Dm         Am           Bb    F
 // Куйлайман Сенга, осмон Худосига,
.Gm          Am
 Барҳаёт Отамизга. //

[V2]
 // Ким Сенга тенг келади Исо,
 Нажот берган Худо қўзиси. //
 // Сен улуғлангансан, исминг Сени юксалган,
 Ҳаммадан ҳам улуғсан. //

[V3]
 // Ким Сенга тенг Муқаддас Руҳим,
 Юпатувчи, азиз меҳрибон. //
 /// Биз билан йўлга туш, жаннат томон кўрсат йўл,
 Жаннатга олиб бор. ///</lyrics>
<key>F</key>
<hymn_number>7</hymn_number>
</song>