<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Бошқаси керакмас, бошқаси
 Бу Раббимнинг улуғ туҳфаси, //
 // Бу йўл тартиб интизом йўли
 Ҳам имтиҳон, интиқо йўли. //
 Бошқаси керакмас, бошқаси
 Бу Раббимнинг улуғ туҳфаси!

[V2]
 // Бошқа йўлни танламаймиз,
 Танимаймиз, тан олмаймиз. //
 // Аҳдимиз шу жиддий, қатъий,
 Биз Раббий фарзандлари. //

[C1]
   Бошқаси керакмас, бошқаси
   Бу Раббимнинг улуғ туҳфаси!
   Бу йўл тартиб интизом йўли
   Ҳам имтиҳон, интиқо йўли.

[V3]
 // Қаранг, қандай ажойиб,
 Бир мамлакат бўлганмиз.
 Ким ўзбегу, қозоқ, рус,
 Тил топишиб қолганмиз. //

[V4]
 // Бизнинг тош юрагимиз
 Ҳалимдай юмшоқ қилган, //
 // Мағрурлик ва худбинлик,
 Биздан йироқлаб қолган. //</lyrics>
<title>Бошқаси керакмас Q29</title>
<hymn_number>29</hymn_number>
</song>