<?xml version="1.0" encoding="UTF-8"?><song><title>Мен Ернинг Тузиман</title>
<lyrics>[V1]
.Em     D      C
 Мен ернинг тузиман
.Am     D     Em
 Мен дунёнинг нуриман

[C1]
.  Em         D
   Сўзларим тамли
.  C         D      Em
   Юришим нурли менинг

[V2]
.Em     D        C
 Сиз ернинг тузисиз
.Am     D       Em
 Сиз дунёнинг нурисиз

[C2]
.  Em        D
   Сўзларис тамли
.  Am        D       Em
   Юришисиз нурли бўлсин

[V3]
.Em      D      Em
 Биз ернинг тузимиз
.Am    D      Em
 Биз дунёнинг нуримиз

[C3]
.  Em       D
   Сўзларис тамли
.  Am        D       Em
   Юришисиз нурли бўлсин</lyrics>
<key>Em</key>
<author>Собир Умуров</author>
<hymn_number>23136</hymn_number>
</song>