<?xml version="1.0" encoding="UTF-8"?><song><title>Сени Келишингни</title>
<lyrics>[V1]
 // Отажоним Меҳрибоним
 Туну кунда сени ўйлайман
 Севгинг битиб шеърлар ёзиб
 Ич-ичимдан тўлиб-тошаман //

[C1]
   // Сени келишингни
   Сени келишингни
   Сени келишингни
   Интиқ кўтаман //

[V2]
 // Ёзай десам севгиси олов
 Сўзин оҳиста сен бўздинг осмон
 Марҳамати абадий чексиз
 Яшолмасман мен ҳеч усиз //

[B1]
   // Ҳар бир дилларга беради ором
   Унинг Каломи бизларга дармон
   Севаман сени дейди у ҳамон
   Бизларга бергандир чексиз бир имон //</lyrics>
<author>Собир</author>
</song>