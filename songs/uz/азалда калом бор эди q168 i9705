<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>168</hymn_number>
<aka>Борлиқ У орқали бор бўлган</aka>
<key>F#</key>
<lyrics>[V1]
.   F#               Ebm
 // Азалда Калом бор эди,
.B           C#      F#
 Калом Худо ҳузурида эди. //
.F#         Ebm
 Калом Худо эди,
.B          C#     F#
 Азалданоқ Худода эди.
.F#               Ebm
 Азалда Калом бор эди,
.B           C#       F#
 Калом Худо ҳузурида эди.

[V2]
.    F#                  Abm
 // Борлиқ У орқали бор бўлган,
.B         C#              F#
 Усиз ҳеч нарса бор бўлган эмас. //
.F#               Abm
 Неки бор бўлган бўлса,
.B         C#    F#
 У орқали бор бўлган.
.F#               Ebm
 Азалда Калом бор эди,
.B           C#      F#
 Калом Худо ҳузурида эди.

[V3]
.F#            Ebm
 Унда ҳаёт бор эди,
.B         C#        F#
 Ҳаёт инсонлар нури эди.
.F#              Ebm
 Нур зулматда порлайди,
.B            C#          F#
 Зулмат эса нурни қоплай олмади.
.F#                     Ab
 Калом инсон қиёфасига кирди,
.B        C#     F#
 Биз аро маскан қилди.

[C1]
.     F#               Ebm
   // Азалда Калом бор эди,
.    B           C#      F#
   Калом Худо ҳузурида эди. //
.     B           C#      F#
   // Калом Худо ҳузурида эди. //</lyrics>
<title>Азалда Калом бор эди Q168</title>
</song>