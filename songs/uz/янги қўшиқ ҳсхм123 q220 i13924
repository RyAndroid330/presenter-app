<?xml version="1.0" encoding="UTF-8"?><song><author>Малоҳат Пулатова</author>
<hymn_number>123</hymn_number>
<title>Янги Қўшиқ ҲСХМ123 Q220</title>
<lyrics>[V1]
.   C                    Am
 // Янги қўшиқ куйлайман Сенга Исо,
.F                 G
 Чунки Сени жуда севаман.
.C                     Am
 Сенга куйлаш жонга тегмайди асло,
.F      G           C
 Чунки Сен мени оқлагансан. //

[C1]
.     Dm             Am     F  G   C
   // Ҳаётимда Сен ягонасан Раббим Исо,
.  Dm             Am        F  G   C
   Мен учун доим парвонасан Раббим Исо.
.  Dm                     Am     F  G   C
   Сенинг исминг мен учун қалқон Раббим Исо,
.  Dm                 Am      F      G
   Сен орқали очиқдир осмон, раҳмат Сенга Исо. //

[V2]
 // Янги ҳаёт беради сенга Исо,
 Чунки сени жуда севади.
 Гуноҳингни кечиради У танҳо,
 Тавба қилсанг сенга келади. //</lyrics>
<key>C</key>
<aka>Янги қўшиқ кўйлайман Сенга - Исо</aka>
</song>