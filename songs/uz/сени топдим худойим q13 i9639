<?xml version="1.0" encoding="UTF-8"?><song><aka>Эй, Дўстларим</aka>
<lyrics>[V1]
 // Эй, дўстларим мен дунёдан,
 Паноҳимни топганман. //
 // Қалбимга тинчлик берган,
 Подшоҳимни топганман. //
 // Кеча-кундуз уйимда,
 Доим менинг ўйимда. //
 // Ишлаб юрсам ишимда,
 Мадоримни топганман. //

[C1]
   Излаб-излаб ҳақиқатни,
   Мен дунёда сарсон бўлдим.
   Қалбим қийнаган саволга,
   Жавобимни топганман!

[V2]
 // Дунё тўлса уйимга,
 Кўнглим сира тўлмади. //
 // Сени топиб Худойим,
 Кўнглим тўлди Паноҳим. //
 // Кўнглим топди Паноҳим! //</lyrics>
<title>Сени топдим Худойим Q13</title>
<hymn_number>13</hymn_number>
</song>