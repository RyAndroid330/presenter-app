<?xml version="1.0" encoding="UTF-8"?><song><title>Бошларим силади Раббим Q56</title>
<aka>Аламларим</aka>
<lyrics>[V1]
 // Аламларим кўпдур бир жаҳон,
 Мени эзиб юборган шайтон. //
 // Муқаддасдур Ўзинг тўккан Қон,
 Аламимни олиб бер Отажон! //

[V2]
 // Менинг каби йиғлаганлар кўп,
 Жигар бағрим тиғлаганлар кўп. //
 // Қасос ўтила ёнганлар кўп,
 Аламимни олиб бер Отажон! //

[V3]
 // Ўчира олай шайтон ўтини,
 Фош қилайин маҳлуқ бетини. //
 // Қурита олай унинг зотини,
 Аламимни олиб бер Отажон! //

[V4]
 // Оёқ ости бўлганда қадрим,
 Тилка пора бўлганда қалбим. //
 // Ҳаётдан сўнганда умидим,
 Бошларимни силади Раббим. //
 Тамом тугаб битганда сабрим,
 // Бошларимни силади Раббим. //</lyrics>
<hymn_number>56</hymn_number>
</song>