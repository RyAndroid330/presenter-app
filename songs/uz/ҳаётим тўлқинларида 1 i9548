<?xml version="1.0" encoding="UTF-8"?><song><key>Bm</key>
<lyrics>[C1]
.     F#m
   // Ибодатим, ибодатим,
.  G         Em    F#m
   Худодан берилгансан. //
.     Bm              F#m
   // Ҳаётим тўлқинларида,
.  G          Em    F#m
   Мен сенга суянганман. //

[V1]
.F#m
 Худойим сен биласан,
.F#              Bm
 Жоним жуда қийналган,
.Bm                    F#m
 Дармонсизман ерга йиқилдим.
.    G         Em
 // Ёрдам бер менга, //
.G             F#m
 Ҳаёт ташвишларида.

[C2]
   // Ибодатим, ибодатим,
   Худодан берилгансан. //
   // Ҳаётим тўлқинларида,
   Мен сенга суянганман. //

[V2]
.F#m
 Худойим осон ҳаётни,
.F#            Bm
 Умримда истамайман.
.F#m
 Майли йўлингда қайғурсам,
.G         Em    F#m
 Изингдан чекинмайман.

[C3]
   Ибодатим, ибодатим,
   Худодан берилгансан.
   // Ҳаётим ташвишларида,
   Мен сенга суянганман! //
   // Мен сенга суянганман! //</lyrics>
<aka>Ибодатим, ибодатим</aka>
<title>Ҳаётим тўлқинларида 1</title>
</song>