<?xml version="1.0" encoding="UTF-8"?><song><title>Жаннат ҲС14 Q188 W83</title>
<key>D</key>
<lyrics>[V1]
.   D           A          Bm           F#m
 // Мен осмонни ўйлаганда, ердан кетгим келади,
.G          Bb     D           A      D
 Фақатгина жаннат томон тезроқ етгим келади. //

[C1]
.     G         A             F#m          Bm
   // Оҳ у ерда қандай роҳат, кулгу қувонч ҳамиша,
.  Em       A      D             A
   Абадият эшигига тезроқ етгим келади. //

[V2]
 // Исо Ўзи кутиб олар фаришталар бирликда,
 Кел ўғлим деб, кел қизим деб таклиф қилар жаннатга. //

[V3]
 // У осмонда фақат қувонч, Исо билан бирликда
 Кел қувон дер, кел яйра дер, таклиф қилар жаннатга/ //</lyrics>
<aka>Мен осмонни ўйлаганда</aka>
<hymn_number>14</hymn_number>
</song>