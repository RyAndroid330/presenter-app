<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16</hymn_number>
<title>Худованд бизни кутмоқда</title>
<aka>Биз ўйнаймиз, куйлаймиз</aka>
<lyrics>[V1]
.   D         G        A
 // Биз ўйнаймиз, куйлаймиз,
.D        G      A
 Номингни улуғлаймиз,
.    G           Bm
 Исо билан бизни никоҳ кутмоқда,
.G       A     D
 У билан бахтиёрмиз. //

[C1]
.  D             G               A
   Ҳаллелуя буюк Худованд бизни кутмоқда,
.  D             G                 Bm  A  D
   Ҳаллелуя буюк Худованд бизнинг ҳукмдоримиз.
.  D             G             A
   Ҳаллелуя буюк Худованд жуда хурсандмиз,
.  D             G                 Bm A    D
   Ҳаллелуя буюк Худованд гуноҳдан қутилганмиз .</lyrics>
<key>D</key>
</song>