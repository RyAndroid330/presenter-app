<?xml version="1.0" encoding="UTF-8"?><song><title>Ким Мени</title>
<key>Am</key>
<lyrics>[V1]
.   Am             F
 // Ким мени қувончимни
.Em              Am
 Мендан олиб қўяр экан
.Am           F
 Ахир Худонинг ўзи
.Em             Am
 Мени ўғлим деб айтган //

[C1]
.     C            G
   // Гар менинг ҳаётимга
.  F            Am
   Қийинчликлар келса
.  Am                 F
   Мен ҳеч бундан қўрқмайман
.   Em            Am
   Ахир Худо мен билан //

[V2]
 // Ким сенинг қувончингни
 Сендан олиб қўяр экан
 Ахир Худонинг ўзи
 Сени қизим деб айтган //

[C2]
   // Гар сенинг ҳаётинга
   Қийинчликлар келса
   Сен ҳеч бундан қўрқмагин
   Ахир Худо сен билан //

[V3]
 // Ким бизнинг қувончимизни
 Биздан олиб қўяр экан
 Ахир Худонинг ўзи
 Бизни фарзандим деб айтган //

[C3]
   // Агар жуда кўп тила
   Сен ҳаётингдан топсанг
   Билгин байрам бўлади
   Мен билан кўйласанг //</lyrics>
</song>