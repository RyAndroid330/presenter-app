<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>176</hymn_number>
<lyrics>[V1]
.   Dm                          A
 // Шодлан халқим диёрингга нур тушди,
.Gm                  A      Dm
 Арши аъло Ўзи берди Қутқарувчи. //
.   Dm                        Gm
 // Чўпонларга келганидек Хушхабар,
.A                            Dm
 Қоронғу қалбингга, сенга ҳам келди. //

[C1]
.     Dm               C       F
   // Юракни оч Унинг Хушхабарига,
.  Dm                   C           F
   Осмонларни тўлдириб,фаришталар келди. //

[V2]
.   Dm                          A
 // Юракларга малҳам суриб қони билан,
.Gm                       A    Dm
 Гуноҳлардан озод қилгани Исо келди. //

[V3]
.   Dm                            A
 // Ҳамдлар бўлсин Ота Худо Масиҳга,
.Gm                        A    Dm
 Гуноҳ учун қурбон бўлгани Исо келди. //
.Dm                      A
 Ҳамдлар бўлсин Ота Худо Масиҳга,
.    Gm                       A    Dm
 /// Бизга ҳаёт тақдим этгани Исо келди. ///</lyrics>
<key>Dm</key>
<title>Шодлан ҳалқим диёрингга Q176</title>
</song>