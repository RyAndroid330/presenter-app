<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>144</hymn_number>
<title>Ҳаёт шошар қайгадир елиб Q144</title>
<lyrics>[C1]
.     Gm            Eb
   // Сендан бошқа Нажоткорим йўқ,
.  F             Bb
   Сендан бошқа Мададкорим йўқ.
.  Eb           Cm
   Сендан бошқа Умидворим йўқ
.  Dm           Bb  Cm     Dm
   Сендан бошқа Халоскорим йўқ! //

[V1]
.Gm          Eb
 Ҳаёт шошар қайгадур елиб,
.F          Dm
 Одам оғли нажот кутиб,
.Eb               Cm
 Бир кун минг кун каби ўтиб
.   Dm          Bb(Cm)  Gm
 // Яратганни излаб ўйланиб! //

[V2]
.   F         Dm
 // Бағрингда ўсдим улғайдим,
.Gm         Cm    (Dm) (Gm)
 Лекин Сени эшита олмадим! //
.Gm
 Бахтимга бор экансан Раббим
.   F(Eb)        Bb(Cm)    Dm
 // Мени Ўзинг бағрингга олдинг! //

[V3]
.   Bb        Dm
 // Яратганга келсин одамзод,
.Cm           F
 Ҳаёт кўрсин билсин одамзод! //
.Gm             Eb
 Минг шукурлар десин одамзод
.F              Bb
 Сендан бошқа Нажоткорим йўқ
.Eb            Cm        D
 Сендан бошқа ададкорим йўқ!</lyrics>
<key>Gm</key>
<aka>Сендан бошқа Нажоткорим йўқ, Нажоткорим</aka>
</song>