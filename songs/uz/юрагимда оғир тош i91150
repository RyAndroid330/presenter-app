<?xml version="1.0" encoding="UTF-8"?><song><author>Равшан Ҳизиров</author>
<lyrics>[V1]
 // Юрагимда оғир тош
 Эзар бағрим, йўқ бардош
 Қўзларимдан оқиб ёш
 Раббим Сизни излайман... //

[V2]
 // Кулар кўзим ёлғончи
 Шодон сўзим ёлғончи //
 Қалбимда бир &quot;талончи&quot;
 /// Раббим Сизни излайман... ///

[V3]
 Юким оғир елкамда
 Доим у кам, бу камда
 Яшайман доим ғамда
 // Раббим Сизни излайман... //

[V4]
 // Келинг ҳаётимга Сиз
 Ҳар бир баётимга Сиз //
 Ожизман энди Сизсиз
 Раббим Сизни излайман...

[V5]
 Ҳақиқат Сизда Раббим
 Йўл, Ҳаёт Сизда Раббим
 // Ҳамдлар куйлайди қалбим
 Раббим Сизни излайман... //</lyrics>
<aka>Раббим Сизни Излайман (анъанавий)</aka>
<title>Юрагимда Оғир Тош</title>
</song>