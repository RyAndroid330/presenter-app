<?xml version="1.0" encoding="UTF-8"?><song><author>Адриенне Неусч</author>
<title>СЕНИ КУТАМАН</title>
<lyrics>[V1]
.Am            Dm
 СЕНИ КУТАМАН, СЕНДА КЎЗЛАРИМ,
.F           G       Am
 ҲУЗУРИНГ ЖУДА ҚУМСАДИМ.
.Am            Dm
 СЕН БЎЛГАН ЕРДА, МЕН ҲАМ БЎЛАЙИН,
.F          G        Am
 ҲУЗУРИНГ ЖУДА ҚУМСАДИМ.

[C1]
.  C                  Dm
   СЕН БИЛАН БИРОЗ ҚОЛАЙИН,
.  F        G       C  G
   МЕНИ ТЎЙДИРУВЧИ РАБ.
.  Am                 Dm
   ҲУЗУРИНГГА МЕН ЧАНҚОҚМАН,
.  F       G     Am
   СЕНГА ТЎЯЙИН, ИСО.

[V2]
.Am           Dm
 МУҚАДДАС ЖОЙДА СЕНГА БОҚАМАН,
.F            G      Am
 ШУҲРАТИНГНИ КЎРИШ УЧУН.
.Am          Dm
 ИЧИМДАН ИСТАБ, ЖОНИМ ИЗЛАЙДИ,
.F           G       Dm
 ҲУЗУРИНГ ЖУДА ҚУМСАДИМ.

[C2]
   СЕН БИЛАН БИРОЗ ҚОЛАЙИН,
   МЕНИ ТЎЙДИРУВЧИ РАБ.
   ҲУЗУРИНГГА МЕН ЧАНҚОҚМАН,
   СЕНГА ТЎЯЙИН, ИСО.</lyrics>
<key>Am</key>
</song>