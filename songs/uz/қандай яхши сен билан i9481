<?xml version="1.0" encoding="UTF-8"?><song><title>Қандай Яхши Сен Билан</title>
<lyrics>[V1]
.    Gm           Eb
 //   Қандай яхши, Сен билан,
.F             Bb
 Сен билан - Хўдо!
.Cm           Eb
 Қандай яхши, Сен билан,
.F            D7
 Сен билан - Исо!
.Gm           Eb
 Қандай яхши, Сен билан,
.   F        Bb
 О. Мўқаддас Рўх,
.Cm
 Сендан, дойим,
.Eb             D7
 менинг кўнглим тоқ!  //

[C1]
.           Gm           Eb
   Сенинг қувончинг, бор менда,
.      F          Bb
   бор менда, бор менда!
.            Cm
   Сенинг севгинг,
.       Eb          D7
   таролмағда хаётимда!
.           Gm        Eb
   Сенинг Сўзинг, бор менда,
.      F          Bb
   бор менда, бор менда!
.           Cm
   Сенинг ахдинг,
.       Eb         D7
   бор ўмир, юрагимда!

[V2]
 //  Мададкорим Ўзингсан,
 Ўзингсан Хўдо!
 Нажоткорим Ўзингсан,
 Ўзингсан Исо!
 Юпатувчим Ўзингсан,
 о, Мўқаддас Рўх!
 Сендан, дойим,
 менинг кўнглим тоқ!  //</lyrics>
<key>Bb</key>
</song>