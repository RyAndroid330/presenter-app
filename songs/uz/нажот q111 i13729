<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>111</hymn_number>
<title>Нажот Q111</title>
<aka>Танга ором</aka>
<lyrics>[V1]
.   Am
 // Танга ором бердинг,
.C           D    G
 Дилга илҳом бердинг. //
.   G
 // Осмонларда нур бўлиб,
.C                Am
 Сен менга нажот бердинг
.C           D    G
 Сен менга нажот бердинг. //

[V2]
 // Олган эдинг қалбимни,
 Кўрган эдинг ўзимни. //
 // Жаннатинга йўл бериб,
 Тутқаздинг каломингни
 Тутқаздинг каломингни. //

[V3]
 // Билмас эдим Ўзингни,
 Кўрмас эдим нурингни. //
 // Неча йиллар адашиб,
 Топдим энди Ўзингни
 Топдим энди Ўзингни. //</lyrics>
<key>G</key>
</song>