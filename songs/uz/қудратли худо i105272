<?xml version="1.0" encoding="UTF-8"?><song><author>Шане&amp;Шане</author>
<title>ҚУДРАТЛИ ХУДО</title>
<lyrics>[V1]
 КЕЛИНГ ҲАЛҚЛАР,
 КЎРИНГ ХУДО ИШЛАРИН, У БУЮК
 КАМОН, ЎҚНИ ПАРЧАЛАБ,
 ЖАНГЛАРНИ У ТЎҲТАТАР
 ОҲ ИСРОИЛ ҚОДИР ХУДОСИ
 СЕН БИЗ ТОМОНДА
 БУЮК ХУДО БИЛАН ОЛҒА БОРАМИЗ ИЙМОНДА

[C1]
   ХУДОВАНД БИЗ БИЛАН
   ОЛОВДА БИЗ БИЛАН
   БЎРОНДА БИЗ БИЛАН
   ПАНОҲИМИЗ У
   У ОЛИБ ЎТАР
   ОҒИР ЖАНГЛАР УЗРА
   БИЗ БИЛАН ҲАР ЕРДА
   ҚУДРАТЛИ ХУДО

[V2]
 ЁҚУБ ХУДОСИ ҚУДРАТЛИ,
 ЛАРЗА ОВОЗИДА
 БОРЛИҚ ТАЪЗИМ ЭТАР,
 ТОҒЛАР ҚОЛАР СУВ ОСТИДА
 У ОДАМЗОД НИЯТЛАРИН БИЛИБ
 САБР ЭТАР
 МАҒРУР ТОҒЛАР ТИТРАБ,
 РАББИМ СЕНГА ТАЪЗИМ
 ҚИЛАР
 МАҒРУР ТОҒЛАР ТИТРАБ, РАББИМ СЕНГА ТАЪЗИМ ҚИЛАР

[B1]
   ДЕНГИЗ ТОШИБ, БЎРОН КЕЛСА
   УЛАРНИ СЕН ТИНЧЛАТАРСАН
   ЮРАГИМНИ СЕН САҚЛАЙСАН
   ОСТИН-УСТУН БЎЛСА ЕРЛАР
   ШОВҚИН КЎТАРСА БУ ҲАЛҚЛАР
   ХУДО ҲАММАСИНИ УШЛАР</lyrics>
</song>