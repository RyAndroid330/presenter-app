<hymn_number>206</hymn_number>
<title>Гўлиёт жангга чиқса ҲСХМ206 CA38 ҲС11 W24</title>
<key>Am</key>
<lyrics>[V1]
.   Am
 // Гўлиёт жангга чиқса,
.     Dm    Em  G      Am
 Довуд ундан хеч қўрқмади //
.   C          Am
 // Худонинг Номи билан уни,
.Dm   E           G         Am
 Битта тош билан уни йўқ қилди! //

[V2]
 // Шайтон қарши чиқса, бизлар
 ундан хеч қўрқмаймиз //
 // Исонинг Номи билан уни
 Факат сўз билан уни хайдаймиз! //</lyrics>
</song>