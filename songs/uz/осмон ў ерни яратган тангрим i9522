<?xml version="1.0" encoding="UTF-8"?><song><title>Осмон ў ерни яратган Тангрим</title>
<lyrics>[V1]
.   Em
 // Осмон-у ерни яратган Тангрим!
.Am
 Ой-у қуёшни қаратган Тангрим!
.F              Dm            Em
 Барча жонзотни яйратган Тангрим! //

[C1]
.     Em
   // Сен ягона олқишларга муносиб,
.  Am
   Бутун руҳингни ерни босиб,
.  F              Dm            Em
   Нопок инсонлар жамолингдан қочиб! //

[C2]
   // Бутун борлиқни яратган Аллоҳим!
   Сен ва менинг ахд-у қарорим!
   Сўнмас юракларда баҳорим! //

[V2]
 // Ёр-у осмонни ёритган Аллоҳим! !
 Ўз жонидан кечган Исойим!
 Тахт-у муродига йетган Худойим! //

[C3]
   // Бутун борлиқни яратган Аллоҳим! !
   Сен ва менинг ахд-у қарорим!
   Сўнмас юракларда баҳорим! //</lyrics>
<key>Em</key>
</song>