<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   B              E         B       F#
 // Шод ҳуррамлик кайфиятда эркинлигингда,
.B               E           F#      B
 Миннатдордорман чин дилдан Нажоткоримга. //

[C1]
.  B         G#m     E         B
   Қўшиқ айтайлик, қувнаб куйлайлик,
.  B             E     B   F#     B
   Раббимизнинг олдида хурсанд бўлайлик.
.  B         G#m    E       B
   Масиҳ муҳаббат, бахту саодат,
.  B             E      B   F#     B
   Муқаддас Руҳ кучида хурсанд бўлайлик.

[V2]
 // Шон шараф зўр янграсин ва олқиш зиёда,
 Миннатдордорман чин дилдан Нажоткоримга. //

[V3]
 // Еру осмон куйласин биз билан бирга,
 Ҳамду сано олқишлар доим Худога. //</lyrics>
<key>B</key>
<title>Шод ҳуррамлик Q97 ҲС84</title>
<author>Һәмра ака</author>
