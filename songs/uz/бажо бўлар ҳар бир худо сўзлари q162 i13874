<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>162</hymn_number>
<aka>Калом келди Инсон қиёфасида</aka>
<key>Em</key>
<lyrics>[V1]
.   Bm                       Ebm
 // Бажо бўлар ҳар бир Худо сўзлари,
.B                 Bm
 Келиб қолар Худо айтган кунлари.
.Bm                         Ebm
 Келгин дейди Худо ҳар бир инсонга,
.B                      Bm
 Қолиб кетма ёлғончи бу дунёда. //

[C1]
.     Bm                Ebm
   // Калом келди инсон қиёфасида,
.  Ab                     C#
   Келди мену сен учун бу дунёга.
.  F#                       B
   Оч юрагинг, қабул қилгин Исони,
.  Abm                       B
   Сен бахтлисан, бахтиёрсан эй инсон. //

[V2]
 // Келиб қолса ўша кунлар ногаҳон,
 Тайёр тургин, ҳушёр бўлиб эй инсон.
 Олиб кетар танланган Ўз халқини,
 Қувонч, кулги, тинчлик бўлган самога. //</lyrics>
<title>Бажо бўлар ҳар бир Худо сўзлари Q162</title>
</song>