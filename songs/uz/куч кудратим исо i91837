<?xml version="1.0" encoding="UTF-8"?><song><title>Куч Кудратим Исо</title>
<key>Bm</key>
<lyrics>[V1]
.   Hm
 // Агар ухлаб қолган бўлсанг
.F#
 Исо сени сени уйғотади
.G
 Агар ҳолдан тойган бўлсанг
.F#
 Исо сенга сенга ёрдам беради //

[C1]
.     Hm
   // Куч-қудратим Исо де
.  F#
   Менинг оромим Исо де
.  Hm
   Ҳар қандай тўсиқларни
.  F#
   Исо билан енгаман де //

[V2]
.Hm
 Агар тоғдек муаммо бўлса ҳам
.F#
 Агар яқинларинг юз ўгирса ҳам
.G
 Агар сенга оғир ботса ҳам
.F#
 Не бўлса ҳам Масиҳда бахт топасан</lyrics>
<hymn_number>23003</hymn_number>
<author>Собир Умуров</author>
</song>