<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em                                           B
 // Мумтоз халқингни боқиш учун самодан тушдинг Ўзинг,
.B                                  Em
 Гуноҳкор қўзиларга қўйчивон бўлиб келдинг. //

[C1]
.     Em                                    Am
   // Кимнинг чечан забонию кимнинг бахтиёр оғзи?
.  Am                     B            Em
   Сўзлаверар, олар экан бизнинг иқболимизни? //

[V2]
 // Хақ подшоҳлик нима бўбди ахир унда куч йўқми?
 Ҳоли бўламиз офатдан Раббимиз Исо билан. //

[V3]
 // Бизни хасталик қийнаса ҳеч ким шифо беролмас,
 Раббимиздан ўзга ҳеч ким жонга нажот беролмас. //</lyrics>
<title>Мумтоз Q64</title>
<hymn_number>64</hymn_number>
</song>