<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>134</hymn_number>
<title>Раббим Сени олқишлашни истайман Q134</title>
<aka>Куйлайман Сенга ҳамду сано</aka>
<lyrics>[V1]
.   Em                       B
 // Раббим Сени олқишлашни истайман,
.Am        B       Em
 Ва Сендан миннатдорман.
.Em                      B
 Биргина Сен менинг умидимсан,
.Am        B       Em
 Мен Сенга хизматкорман. //

[C1]
.     Em               Am
   // Куйлайман Сенга ҳамду сано,
.  D                 G
   Куйлайман Сенга Масиҳим.
.  C                      Am
   Чунки Сен қийналдинг бегуноҳ,
.  B                  Em
   Яратувчи Сени севдим эй. //

[V2]
.   Em                       B
 // Қачон мен йўлларимда йиқилсам,
.Am        B       Em
 Кўрдим Сени куйишингни.
.Em                  B
 Қачон нола билан интилсам
.Am         B      Em
 Мен Сендан миннатдорман. //

[V3]
.   Em              B
 // Масиҳим мен билмабман,
.Am        B       Em
 Қандай Сен меҳрибонсан.
.Em                  B
 Сен бир дақиқада кечирасан,
.Am        B    Em
 Ва юракни нурлайсан. //</lyrics>
<key>Em</key>
</song>