<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>381</hymn_number>
<author>Eliza Edmunds Hewitt, William James Kirkpatrick</author>
<lyrics>[V1]
 Minut, Jeesus,
 säilytä päivittäin
 armossa vaan,
 armossa vaan.
 Murhe, pelko
 haihtuu
 pois syömmestäin
 armosi kautta vaan.

[C1]
   Kätke, oi Jeesus,
   päivittäin
   Golgatan virtaan
   hetkittäin.
   Voiman taisteluun
   yksin saan
   armosi kautta vaan.

[V2]
 Pakopaikka varma
 on syntisen
 armossa vaan,
 armossa vaan.
 Onni, autuus,
 pelastus ihmisen
 armosi kautta vaan.

[V3]
 Auta, että uskossa
 kasvaisin
 armossa vaan,
 armossa vaan.
 Lohdun saan mä
 tuntoni tuskihin
 armosi kautta vaan.

[V4]
 Rauha varma mulla
 on sielussain
 armossa vaan,
 armossa vaan.
 Ilon suuren
 lahjana
 myöskin sain
 armosi kautta vaan.</lyrics>
<title>Minut, Jeesus, säilytä</title>
</song>