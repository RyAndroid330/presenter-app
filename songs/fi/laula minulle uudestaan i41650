<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10</hymn_number>
<author>Philip Paul Bliss, Philip Paul Bliss</author>
<title>Laula minulle uudestaan</title>
<lyrics>[V1]
 Laula minulle
 uudestaan
 elämän Sana kallis.
 Ohjeet antavi
 yksin vaan
 elämän Sana kallis.
 Tietä mulle
 se näyttää,
 kaikki puutteeni
 täyttää.

[C1]
   Ihmeellinen,
   voimallinen
   elämän Sana kallis!
   Ihmeellinen,
   voimallinen
   elämän Sana kallis!

[V2]
 Jeesus tullut
 on maailmaan,
 elämän Sana kallis.
 Synnin voittaa
 Hän voimallaan,
 elämän Sana kallis.
 Lohdun antaa
 Hän vaivaan,
 ohjaa kotihin
 taivaan.</lyrics>
</song>