<?xml version="1.0" encoding="UTF-8"?><song><author>Lina Sandell-Berg, Lilli, s. Thuneberg Leinberg</author>
<hymn_number>32</hymn_number>
<lyrics>[V1]
 Juhla on rauhainen
 lähestynyt.
 Jeesus on seimehen
 nyt syntynyt
 valkeutta luomahan
 suo se mun rintahan
 kahleista kuoleman
 vapahtaen.

[V2]
 Suo yhä runsaammin
 aarteitasi.
 Elämän murheisiin
 tuo ilosi.
 Suo, että nähdä saan
 apusi ainiaan,
 luoksesi tulla saan
 kiittäen Sua.

[V3]
 Ahdistus, minkä soit,
 poistukohon.
 Myötäsi armon toit.
 Kallis se on.
 Kylmän Sä lämmität,
 mielemme elvytät,
 kiitosta herätät.
 Rauhasi suo.</lyrics>
<title>Juhla on rauhainen</title>
</song>