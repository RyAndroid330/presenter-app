<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 &quot;Rakkaus ihmeellinen!&quot;
 Siinäpä aihe on,
 &quot;Rakkaus taivaallinen!&quot;
 sydämen laulelon.
 Enkelten sanoma kaikui:
 &quot;Vapahtajanne nyt saapui,
 kunnia Herran
 ja maahan rauha myös
 taivaallinen.&quot;

[C1]
   Ihmeinen, ihmeinen,
   ihmeinen rakkaus
   taivaallinen.

[V2]
 &quot;Rakkaus ihmeellinen!&quot;
 Vaikka sä harhailet,
 &quot;Rakkaus taivaallinen!&quot;
 ääntänsä vältä et.
 Elämän lähteelle riennä,
 ristiltä kuohuu se vielä.
 Tyydykkeen löydät
 sä siellä.
 Rakkaus taivaallinen!</lyrics>
<title>Rakkaus ihmeellinen</title>
<hymn_number>73</hymn_number>
<author>J. M. Driver, J. Driver</author>
</song>