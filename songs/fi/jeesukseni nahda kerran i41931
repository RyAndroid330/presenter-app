<?xml version="1.0" encoding="UTF-8"?><song><title>Jeesukseni nähdä kerran</title>
<lyrics>[V1]
 Jeesukseni
 nähdä kerran
 kasvoista
 saan kasvoihin.
 Kuljen vielä
 hetken verran,
 sitten pääsen
 kotihin.

[C1]
   Kasvotusten
   kirkkauttaan
   kohta saan
   mä katsella,
   voittajana
   Hänen kanssaan
   ikuisesti taivaassa.

[V2]
 Täällä maassa
 ahdistusten
 joskus usko
 heikkenee.
 Maahan kaipaan
 lupausten,
 jossa Jeesus
 hallitsee.</lyrics>
<hymn_number>610</hymn_number>
<author>Carrie Ellis Breck, Grant C Tullar</author>
</song>