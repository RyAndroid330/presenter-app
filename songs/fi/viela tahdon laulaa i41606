<?xml version="1.0" encoding="UTF-8"?><song><author>Tuntematon, Tuntematon</author>
<hymn_number>108</hymn_number>
<lyrics>[V1]
 Vielä tahdon laulaa
 työstä Golgatan,
 siellä Jeesus minut pelasti.
 Tähteni Hän vaipui
 tuskiin kuoleman,
 kalliin verensä kun vuodatti.
 Etikkaa vain janoonsa sai Hän.
 Kuinka kärsitkään,
 Uhrikaritsa!
 Siellä annoit mulle
 uuden elämän,
 kuoloon kun kävit Golgatalla.

[C1]
   Uudestaan, uudestaan
   Jeesuksesta mä
   laulaa nyt saan.
   Golgatasta laulu soi,
   rauhan sydämeeni toi,
   kun Hän tähteni
   astui kuolemaan.

[V2]
 Vielä tahdon
 laulaa sydämestänsä,
 johon keihäs lyötiin tähteni.
 Piikkikruunu painoi
 pyhää päätänsä,
 kun Hän puolestani rukoili.
 Näin Hän kuoloon
 kävi voittaen,
 siksi laulaa nyt
 kiitostansa saan.
 Laulan voimasta
 tuon ikirakkauden,
 joka Jeesuksen vei kuolemaan.</lyrics>
<title>Vielä tahdon laulaa</title>
</song>