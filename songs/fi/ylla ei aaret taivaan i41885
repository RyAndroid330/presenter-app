<?xml version="1.0" encoding="UTF-8"?><song><author>Augusta Charlotta Lönborg, Julius Dahlof</author>
<hymn_number>508</hymn_number>
<lyrics>[V1]
 Yllä ei ääret taivaan,
 aurinko, tähtitie
 korkeutehen, minne
 vain rukous, huokaus vie.
 Tomusta maan jo henki
 siipensä kohottaa,
 kotihin Isän pyrkii,
 sen portille kolkuttaa.

[V2]
 Ahdas on
 mailman laajuus,
 ystävä avuton.
 Taivaassa levon löytää
 voi sielusi rauhaton.
 Väistyvi vaikein vaiva,
 Herrasi lohdun tuo,
 kautta jos rukoussillan
 sun tiesi käy Luojan luo.</lyrics>
<title>Yllä ei ääret taivaan</title>
</song>