<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Jouluyö! Juhlayö!
 Päättynyt kaikk'
 on työ.
 Kaks vain valveill'
 on puolisoa
 lapsen herttaisen
 nukkuessa,
 /: seimikätkyessään.:/

[V2]
 Jouluyö! Juhlayö!
 Paimenill' yksin työ
 enkel taivaasta
 ilmoitti heill':
 suuri koittanut
 riemu on teill'!
 /: Kristus
 syntynyt on!:/</lyrics>
<title>Jouluyö, juhlayö</title>
<author>Joseph Franz Mohr, Franz Xavier Gruber</author>
<hymn_number>39</hymn_number>
</song>