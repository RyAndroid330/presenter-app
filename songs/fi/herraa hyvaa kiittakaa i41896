<?xml version="1.0" encoding="UTF-8"?><song><title>Herraa hyvää kiittäkää</title>
<lyrics>[V1]
 Herraa hyvää
 kiittäkää,
 iloiten ylistäkää,
 luodut kaikki
 laulakaa
 Luojan
 suurta kunniaa!

[V2]
 Pyhät, suuret,
 korkeat
 työnsä on
 ja oikeat,
 suuri herrautensa
 maassa on
 ja taivaassa.

[V3]
 Kiitos
 Jumalallemme
 soikoon
 sydämestämme
 virsin, lauluin,
 psalttarein,
 harpuin, huiluin,
 kantelein.</lyrics>
<hymn_number>524</hymn_number>
<author>Jesper Swedberg, Heinrich Albert</author>
</song>