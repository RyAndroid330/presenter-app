<?xml version="1.0" encoding="UTF-8"?><song><title>Yhtehenkö tulla saamme</title>
<lyrics>[V1]
 Yhtehenkö
 tulla saamme
 tuolla puolen Jordanin
 pelastettuin
 joukkoon suureen,
 ikirauhan majoihin?

[C1]
   Yhtehen, yhtehen
   pääsemmekö
   vielä kerran
   tuolla puolen
   Jordanvirran,
   miss' on rauha
   iäinen?

[V2]
 Halki myrskyn
 pauhun kerran
 saavutaanko
 valkamaan?
 Lasketaanko
 ankkurimme
 rauhan rantaan
 uuden maan?

[V3]
 Kohdataanko
 kaupungissa
 elonvirran varrella?
 Se on meille
 valmistettu
 jaspiksesta, kullasta.</lyrics>
<hymn_number>641</hymn_number>
<author>Horace Lorenzo Hastings, Olli Vuorinen-Berg, Elihu Rice</author>
</song>