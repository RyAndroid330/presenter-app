<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<author>Charles Price Jones, Charles Price Jones</author>
<title>Jeesus, vanhurskauteni</title>
<lyrics>[V1]
 Jeesus,
 vanhurskauteni.
 Tiedän sen,
 uskon sen.
 Vaihteluissa
 aikojen
 Hän on kaikkeni.

[C1]
   Vanhurskaus,
   voimani,
   pyhitys
   ja rauhani.
   Armosta sain
   kaiken sen,
   onnen, autuuden.

[V2]
 Jeesus kuoli
 tähteni.
 Tiedän sen,
 uskon sen.
 Kuljen ristiin
 turvaten.
 Hän on kaikkeni.

[V3]
 Veri tunnon
 puhdisti.
 Tiedän sen,
 uskon sen.
 Haavoissaan
 saan lääkkehen.
 Hän on kaikkeni.</lyrics>
</song>