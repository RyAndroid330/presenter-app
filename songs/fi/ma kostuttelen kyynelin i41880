<?xml version="1.0" encoding="UTF-8"?><song><author>Jooseppi Mustakallio, Mikael Nyberg</author>
<hymn_number>494</hymn_number>
<lyrics>[V1]
 Mä kostuttelen
 kyynelin
 Jeesuksen
 ristin juurta,
 en jaksa
 kantaa kauemmin
 synteini
 kuormaa suurta.

[V2]
 Mä lasken
 ristin juurehen
 sen taakan
 tuskinensa,
 mä lasken
 ristin verehen
 sydämen
 saastoinensa.

[V3]
 Se veren voima
 kirvoittaa
 pois taakan
 raskahimman,
 se ristin veri
 puhdistaa
 myös minut,
 saastaisimman.</lyrics>
<title>Mä kostuttelen kyynelin</title>
</song>