<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>422</hymn_number>
<author>Eliza Edmunds Hewitt, Hilma Katariina Charlotta Suomalainen, John Robson Sweney</author>
<lyrics>[V1]
 Päivä kirkas
 loistaa sielussain.
 Pimeys on
 hälvennyt.
 Maa ja taivas
 hymyileepi vain.
 Valonain on
 Jeesus nyt.

[C1]
   Loistaa päivä,
   kevätpäivä,
   elon hetket
   kaikki kirkastaa.
   Jeesukseen kun
   silmäin katselee,
   sieluni Hän valaisee.

[V2]
 Kiitoslaulu soipi
 sielussain.
 Herralle se
 kajahtaa.
 Säveleitä sydän
 uhkuu ain,
 kiitosvirttä
 riemuisaa.

[V3]
 Kevät armas
 ompi sielussain:
 Jeesus luonain
 asustaa.
 Laulu kaikuu
 sydäntarhassain,
 kukat armon
 kukoistaa.</lyrics>
<title>Päivä kirkas</title>
</song>