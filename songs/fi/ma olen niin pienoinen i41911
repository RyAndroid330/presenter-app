<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>554</hymn_number>
<author>Ingeborg Hellen, Mikael Nyberg</author>
<lyrics>[V1]
 Mä olen niin
 pienoinen,
 pienoinen aivan,
 Sä suuri
 ja voimakas
 Isäni taivaan,
 Isäni taivaan.

[V2]
 En suotta
 saa peljätä,
 murhetta kantaa,
 kun sen, minkä
 tarvitsen,
 Isäni antaa,
 Isäni antaa.

[V3]
 Kun voimani
 uupuvat,
 käsilläs kannat,
 ja syntini
 armostas
 anteeksi annat,
 anteeksi annat.</lyrics>
<title>Mä olen niin pienoinen</title>
</song>