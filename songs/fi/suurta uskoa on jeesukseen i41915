<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>569</hymn_number>
<author>Andrew L . Skoog, Andrew L. Skoog</author>
<lyrics>[V1]
 Suurta uskoa on
 Jeesukseen jo nuorena,
 kevätpäivinä jo
 lapsuuden,
 ennen kuin on sydän
 epäuskon valtaama,
 maistaa tosirauhaa
 Jeesuksen.

[C1]
   Suurta uskoa on
   Jeesukseen jo nuorena,
   Hänen askeleissaan
   käydä vain.
   Vuotten vieriessä
   kaikki muu
   on muuttuva.
   Ilo Jeesuksessa
   kestää ain.

[V2]
 Suurta totella on
 Jeesusta jo nuorena,
 ennen kuin on
 sydän saastunut,
 antaa Jeesukselle
 elämänsä uhrina,
 ennen kuin on
 tunto paatunut.</lyrics>
<title>Suurta uskoa on Jeesukseen</title>
</song>