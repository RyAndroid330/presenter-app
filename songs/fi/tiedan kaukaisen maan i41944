<?xml version="1.0" encoding="UTF-8"?><song><title>Tiedän kaukaisen maan</title>
<lyrics>[V1]
 Tiedän kaukaisen maan,
 jonne käydä mä saan.
 Sinne uskossa
 nyt katselen.
 Poissa sieltä on yö,
 tuska, vaiva ja työ,
 ei vanheta suojissa sen.

[C1]
   Rauha ihmeellinen
   maassa kirkkauden,
   ei myrskyjen
   pauhina soi.
   Siellä tyyntä on ain,
   riemu vallitsee vain,
   eikä aurinko laskea voi.

[V2]
 Valo ihmeellinen
 loistaa taivaallinen
 yllä kaupungin
 tuon kultaisen.
 Siellä kantelon saan,
 osan myös autuaan;
 ei vanheta suojissa sen.</lyrics>
<hymn_number>638</hymn_number>
<author>Mrs. F. A. F. White, Mark M. Jones</author>
</song>