<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>198</hymn_number>
<author>Eric Mauritz Bergquist, Aina G. Johansson, Eric Mauritz Bergquist</author>
<lyrics>[V1]
 Oi, armon
 ihmettä Jumalan:
 saat olla
 lähetti Karitsan,
 kiiruhtaa kuolevaan
 maailmaan
 kylvämään suurta
 rakkauttaan.

[C1]
   Käy, oi kylväjä, käy!
   Käy, oi kylväjä, käy
   siementä hyvää
   kylvämään.
   Käy, oi kylväjä, käy!

[V2]
 Jos näyttää tie
 joskus synkältä,
 on Herran
 lupaus pysyvä:
 kädellään Hän
 sua johdattaa,
 tien kolkkoon
 korpeen valmistaa.

[V3]
 Jos ensimmäisnä
 et seisokaan,
 niin hiljaisuudessa
 toimi vaan.
 Herra, mi salattuun
 katsoo ain,
 uskollisuutta
 vaatii vain.

[V4]
 Jos niin kuin Ruut
 halpa lienetkin,
 sä riennä kentälle
 kuitenkin.
 Voit löytää
 jäljelle jäänehen
 Herralle kalliin
 tähkäsen.

[V5]
 Ei pelkkä puhe,
 ei laulukaan
 saa yksin synnistä
 nousemaan,
 vaan myöskin
 Herrassa vaellus
 on monen sielun
 pelastus.</lyrics>
<title>Oi, armon ihmettä</title>
</song>