<?xml version="1.0" encoding="UTF-8"?><song><title>Vuosi vanha vaipui hautaan</title>
<lyrics>[V1]
 Vuosi vanha
 vaipui hautaan
 riemuineen ja murheineen.
 Ihmismieli puhkee nöyrään
 rukoukseen, kiitokseen.
 Oi, jos vuosi alkava
 oisi Luojan siunaama,
 Luojan siunaama.

[V2]
 Oi, jos koittais päivä uusi
 sydämeen nyt jokaiseen,
 uusi toivo orastaisi,
 syttyis usko Jeesukseen.
 Silloin vuosi alkava
 oisi Luojan siunaama,
 Luojan siunaama.</lyrics>
<hymn_number>581</hymn_number>
<author>Tuntematon, Mikael Nyberg</author>
</song>