<?xml version="1.0" encoding="UTF-8"?><song><author>Eden Reeder Latta, Henry Southwick Perkins</author>
<hymn_number>106</hymn_number>
<lyrics>[V1]
 Verilähde siunausten
 maailmalle nyt auki on,
 uhri kallis tuo Jeesuksen,
 joka meille toi sovinnon.
 Eksyin kerran kauaksi pois,
 tuskaa tunsin sielussani,
 vaan kun veri
 puhdisti mun,
 niin sain lunta
 valkeemmaksi.

[C1]
   Jeesus puhdistaa,
   Jeesus puhdistaa.
   Oi, kun Jeesus
   puhdistaa mun,
   niin saan lunta
   valkeemmaksi.</lyrics>
<title>Verilähde siunausten</title>
</song>