<?xml version="1.0" encoding="UTF-8"?><song><author>Daniel Webster Whittle, James McGrahan</author>
<hymn_number>236</hymn_number>
<lyrics>[V1]
 Jumalan virta nyt kuohuu
 armoa janooville.
 Niin Herran lupaus kuuluu
 kaikille kaipaaville.

[C1]
   Virrat, virrat ne armon
   autuutta, lohtua tuo.
   Runsaammin suo niiden tulla
   jokaisen lapsesi luo.

[V2]
 Jumalan virta nyt tulvii
 taivaasta, oi, Jumalan,
 kunnes jo korpikin kukkii
 kauniina kuin morsian.

[V3]
 Jumalan virta nyt kuohuu
 Henkeä, elämääkin.
 Esteet sen voimasta kaatuu,
 herättää kuollehetkin.

[V4]
 Jumalan virta nyt kuohuu
 vyöryen ylitse maan.
 Sen, mitä kansoilta puuttuu,
 virta tää tuo tullessaan.</lyrics>
<title>Jumalan virta</title>
</song>