<?xml version="1.0" encoding="UTF-8"?><song><author>Tuntematon, Tuntematon</author>
<hymn_number>302</hymn_number>
<title>Syntien orjana</title>
<lyrics>[V1]
 Syntien orjana
 kulkiessain
 kahleita himojen
 kannoin.
 Jeesus mun
 syntisen vapautti,
 Hänelle syömmeni
 annoin.

[C1]
   Vapaa, ostettu oon,
   Jeesus mun
   syntini kantoi.
   Vapaa, onnellinen,
   Hän mulle
   Henkensä antoi.

[V2]
 Ennen mä teillä
 sain epäilyjen
 tuskani yksin
 vain kantaa.
 Jeesuksen luona
 nyt turvani on,
 Hän mulle
 armonsa antaa.</lyrics>
</song>