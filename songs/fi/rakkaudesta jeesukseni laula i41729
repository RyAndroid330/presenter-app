<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>165</hymn_number>
<author>Eliza Edmunds Hewitt, Emely D. Wilson</author>
<lyrics>[V1]
 Rakkaudesta
 Jeesukseni laula,
 laula laupeudestaan.
 Asunnon on
 valmistanut
 Herra meille
 taivaassaan.

[C1]
   Kun me
   kohtaamme kerran,
   mikä riemu silloin
   täyttää taivaan, maan.
   Kun me Jeesuksen
   näämme,
   ei juhla
   pääty milloinkaan.

[V2]
 Usein täällä
 korpiretkellämme
 taivas peittyy
 pilvihin,
 mutta taiston
 päättyessä
 lepoon saamme
 Saalemiin.

[V3]
 Loppuun asti kaikki
 taistelkaamme
 Häntä riemuin
 palvellen.
 Palkka suuri
 taivahassa
 ompi luona
 Jeesuksen.</lyrics>
<title>Rakkaudesta Jeesukseni laula</title>
</song>