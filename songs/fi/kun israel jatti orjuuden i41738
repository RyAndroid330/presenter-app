<?xml version="1.0" encoding="UTF-8"?><song><author>Harry J. Zelley, Henry L. Gilmour</author>
<hymn_number>181</hymn_number>
<title>Kun Israel jätti orjuuden</title>
<lyrics>[V1]
 Kun Israel
 jätti orjuuden
 ja saapui
 meren luo,
 niin Herran
 sanan voimasta
 jo väistyi
 vedet nuo.

[C1]
   Siis eespäin
   Kristuksen käsky on,
   vaikka aallot
   pauhailee.
   Yhä eespäin vaan
   käymme voimassaan.
   Hän meret halkaisee.

[V2]
 Kun synnin
 laineet uhkaavat
 löi eessäin
 vaahtopäin,
 niin Jeesus
 kuuli huutoni
 ja auttoi
 eteenpäin.

[V3]
 Kun murheen
 virta tielleni
 toi tuskaa
 tullessaan,
 niin silloin
 Herra armoinen
 mua riensi
 auttamaan.</lyrics>
</song>