<?xml version="1.0" encoding="UTF-8"?><song><title>Kaiken matkaa Jeesus johdattaa</title>
<lyrics>[V1]
 Kaiken matkaa
 Jeesus johdattaa,
 &quot;Kiitos oi!
 Kiitos oi!&quot;
 Taivaan mannaa
 nälkään tarjoaa.
 &quot;Kiitos, kiitos oi!&quot;

[C1]
   Päivin, öin
   minä laulelen
   kiitosvirttä
   Jeesuksen.
   Se laulu sielussa
   soi, se soi!
   &quot;Kiitos, kiitos oi!&quot;

[V2]
 Jeesus-nimi
 kaiken lahjoittaa,
 &quot;Kiitos oi!
 Kiitos oi!&quot;
 Pöydässään mua
 paikka odottaa.
 &quot;Kiitos, kiitos oi!&quot;

[V3]
 Eihän Jeesus
 hylkää milloinkaan,
 &quot;Kiitos oi!
 Kiitos oi!&quot;
 Kiusoissakin
 auttaa omiaan.
 &quot;Kiitos, kiitos oi!&quot;

[V4]
 Maailmasta
 Hän mun pelasti,
 &quot;Kiitos oi!
 Kiitos oi!&quot;
 Valtakuntaansa
 mun lunasti.
 &quot;Kiitos, kiitos oi!&quot;</lyrics>
<hymn_number>519</hymn_number>
<author>Charles Homer Gabriel, Charles Homer Gabriel</author>
</song>