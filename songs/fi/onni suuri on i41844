<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>412</hymn_number>
<author>Elisha Albright Hoffman, Anthony Johnson Showalter</author>
<title>Onni suuri on</title>
<lyrics>[V1]
 Onni suuri on,
 riemu verraton,
 kun mua Herran
 käsi johdattaa.
 Rauhan taivahan
 silloin omistan,
 kun mua Herran
 käsi johdattaa.

[C1]
   Luotan, luotan:
   taistoissa
   Herra vahvistaa.
   Voitan, voitan,
   kun mua
   Herran käsi
   johdattaa.

[V2]
 Tieni valkenee,
 taivas selkenee,
 kun mua Herran
 käsi johdattaa.
 Voiman heikko
 saa täällä vaeltaa,
 kun vain Herran
 käsi johdattaa.</lyrics>
</song>