<?xml version="1.0" encoding="UTF-8"?><song><author>Simo Oskari Korpela, Martti Mikael Hela</author>
<hymn_number>560</hymn_number>
<lyrics>[V1]
 Herran taistohon
 rohkeaan
 sä vihkiös nuoruusaikas!
 Tässä intosi paikallaan
 ja hyödyksi laulu raikas.
 Säilyy voimat nuoruuden
 kun ne antaa uhraten
 kunniaksi Herran,
 kunniaksi Herran!

[V2]
 Joukoin käykäämme
 suljetuin
 ja silmämme
 lippuun luoden,
 toisen innosta innostuin
 ja heikoille
 voimaa suoden!
 Yhdess' ollen muinoinkin
 voitot suuret saatihin
 kunniaksi Herran,
 kunniaksi Herran!

[V3]
 Voittolippumme risti on,
 ja Jeesus on
 Kuninkaamme.
 Hän vie joukkonsa
 voittohon
 ja Hältä me
 kruunun saamme.
 Seuratkaamme Häntä vaan
 elämään ja kuolemaan
 kunniaksi Herran,
 kunniaksi Herran!</lyrics>
<title>Herran taistohon</title>
</song>