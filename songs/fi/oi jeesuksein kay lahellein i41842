<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Oi Jeesuksein,
 käy lähellein,
 taivuta tahtoos
 sydämein!
 Alkaissa päivän,
 yön saapuessa,
 oi Jeesuksein,
 käy lähellein.</lyrics>
<title>Oi Jeesuksein, käy lähellein</title>
<author>Lina Sandell-Berg, Saksalainen</author>
<hymn_number>410</hymn_number>
</song>