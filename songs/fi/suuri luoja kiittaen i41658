<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<author>Ignaz Franz, Aina G. Johansson, Saksalais-Itävaltalainen</author>
<lyrics>[V1]
 Suuri Luoja, kiittäen
 astumme nyt etehesi
 maa ja taivas
 kaikkineen
 ilmoittaa Sun
 viisauttasi.
 Suuri olet voimassa,
 suuri rakkaudessa.

[V2]
 Luomakunta ihmeinen
 kunniata Sulle kantaa.
 Enkeljoukot riemuiten
 ylistyksen aina antaa
 &quot;Pyhä, Pyhä&quot;, laulaen,
 edessäsi nöyrtyen.

[V3]
 Pyhä Herra Jumala,
 maan ja taivaan
 suuri Luoja,
 hädässämme auttaja,
 armon, rauhan,
 turvan tuoja,
 Sulle kiitosuhriksi
 antaudumme iäksi.

[V4]
 Kohta, Isä taivahan,
 kiitostasi kaikki kielet
 laulaa yli maailman.
 Laulaa suuret
 sekä pienet
 Sulle, Poika Jumalan,
 ylistyksen, kunnian.</lyrics>
<title>Suuri Luoja, kiittäen</title>
</song>