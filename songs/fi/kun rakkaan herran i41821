<?xml version="1.0" encoding="UTF-8"?><song><title>Kun rakkaan Herran</title>
<lyrics>[V1]
 Kun rakkaan
 Herran Jeesuksen
 uskossa nähdä saan,
 mä silloin muuta toivo en
 kuin olla luonaan vaan.
 Hän kärsi
 eestäin kuoleman,
 mä siksi Häntä rakastan.
 Nyt annan ruumiin,
 sielunkin
 mä haltuun Mestarin.</lyrics>
<author>Brita Hedvig Knös, Ruotsalainen kansansävelmä kansansävelmä</author>
<hymn_number>365</hymn_number>
</song>