<?xml version="1.0" encoding="UTF-8"?><song><author>Adelaide Addison Pollard, George C Stebbins</author>
<hymn_number>466</hymn_number>
<lyrics>[V1]
 Tahtosi, Herra,
 tapahtukoon.
 Kädessäs, Jeesus,
 savea oon.
 Aivan kuin tahdot
 muovaile mua.
 Nöyränä, hiljaa
 ootan mä Sua.

[V2]
 Tahtosi, Herra,
 tapahtukoon.
 Syömmeni tutki,
 eessäsi oon.
 Irroita täysin
 kahleista maan,
 alttiina auta
 Sua seuraamaan.

[V3]
 Tahtosi, Herra,
 tapahtukoon.
 Voimia anna,
 väsynyt oon.
 Valta ja voima
 Sulla on vain.
 Paranna, auta,
 Vapahtajain.</lyrics>
<title>Tahtosi, Herra, tapahtukoon</title>
</song>