<?xml version="1.0" encoding="UTF-8"?><song><author>Ivan Stepanovits Prohanov, Venäläinen</author>
<hymn_number>92</hymn_number>
<lyrics>[V1]
 Käy, veljeni,
 Golgatalle.
 Oi, siellä on
 Messias Vapahtaja,
 tuo syyllisten
 ainoa Armahtaja
 sinun eestäsi
 ristillenaulittuna.
 Nöyrtyen rukoile.

[V2]
 Käy, veljeni,
 Golgatalle.
 Hän kärsii ja
 nääntyvi kuumeisena.
 Vain etikkaa saapi
 Hän janohonsa,
 joka elämän veden
 toi lahjanansa.
 Nöyrtyen rukoile.

[V3]
 Käy, veljeni,
 Golgatalle.
 Saat kuulla sä
 kuinka Hän rukoilevi:
 &quot;Oi,miksi mun
 hylkäsit, Jumalani?&quot;
 Tämän kaiken Hän
 kantanut on tähtesi.
 Nöyrtyen rukoile.

[V4]
 Käy, veljeni,
 Golgatalle.
 Sun eestäsi Jeesus
 on runneltuna.
 Hän rukoilee puolesta
 vainoojainsa:
 &quot;Isä, suo heille
 anteeksi rikoksensa.&quot;
 Nöyrtyen rukoile.</lyrics>
<title>Käy, veljeni Golgatalle</title>
</song>