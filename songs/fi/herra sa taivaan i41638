<?xml version="1.0" encoding="UTF-8"?><song><author>Tuntematon, Carl Erik Sjögren</author>
<hymn_number>474</hymn_number>
<lyrics>[V1]
 Herra Sä taivaan,
 sieluni
 Sua odottaa.
 Suo apu vaivaan,
 vain Sinä
 voit lohduttaa.

[V2]
 Matkalla näännyn,
 voimani
 uupuvat mun.
 Puoleesi käännyn,
 suo mulle
 voimasi Sun.

[V3]
 Armoa anna
 kulkea ristisi tie.
 Nosta ja kanna,
 voitosta
 voittohon vie.

[V4]
 Kanssani kulje,
 johdata
 matkalla maan.
 Suojaasi sulje,
 siinä mä
 riemuita saan.</lyrics>
<title>Herra Sä taivaan</title>
</song>