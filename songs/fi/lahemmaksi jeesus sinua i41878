<?xml version="1.0" encoding="UTF-8"?><song><title>Lähemmäksi, Jeesus, Sinua</title>
<lyrics>[V1]
 Lähemmäksi,
 Jeesus, Sinua,
 lähemmäksi
 vedä minua.
 Armostasi
 päivä päivältä
 elämä saa
 merkityksensä.

[V2]
 Lähemmäksi,
 vaikka joutuisin
 taisteluun ja
 alle ristinkin.
 Silloin sidot
 minut itseesi
 irrottaen
 kaikki kahleeni.</lyrics>
<hymn_number>490</hymn_number>
<author>Lina Sandell-Berg, Oscar Ahnfelt</author>
</song>