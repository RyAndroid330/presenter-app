<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>481</hymn_number>
<author>Frances Crosby-van Alstyne, William Howard Doane</author>
<lyrics>[V1]
 Jeesus, ristin juurella
 suo mun pysytellä,
 terveysvirran äärellä,
 elon lähtehellä.

[C1]
   Risti vain, risti vain,
   olkoon kunniani,
   kunnes taivaan rannalla
   nautin autuuttasi.

[V2]
 Ihme: ristin juurella
 armo synnin voitti!
 Sieluhuni ristiltä
 aamutähti koitti.

[V3]
 Ristihin, oi Karitsa,
 kiinnä katseheni.
 Jeesus, ristis varjossa
 johda askeleni.</lyrics>
<title>Jeesus, ristin juurella</title>
</song>