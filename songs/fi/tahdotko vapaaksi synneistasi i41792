<?xml version="1.0" encoding="UTF-8"?><song><author>Lewis E. Jones, Lewis E. Jones</author>
<hymn_number>303</hymn_number>
<lyrics>[V1]
 Tahdotko vapaaksi
 synneistäsi?
 Oi, veressä vain
 voima on ain!
 Tullos, niin rauhan
 saat sieluhusi,
 kun puhdistus
 veressä on.

[C1]
   Voittovoima,
   voima ihmeinen
   veressä Jeesuksen.
   Voittovoima,
   voima voitokas
   Vapahtajan
   haavoissa vain.

[V2]
 Tahdotko voiton
 sä himoistasi?
 Oi, veressä vain
 voima on ain!
 Golgatan veri
 luo puhtahaksi,
 ja varjelus
 veressä on.</lyrics>
<title>Tahdotko vapaaksi synneistäsi</title>
</song>