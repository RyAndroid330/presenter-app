<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>186</hymn_number>
<author>Anders Carl Rutström, Saksalainen kansansävelmä</author>
<title>Käy, armahtaja laupias</title>
<lyrics>[V1]
 Käy, Armahtaja laupias,
 kuin paimen
 lammaslaumaan,
 ja väsyneet vie
 meidät taas
 haavoissas
 virvoittaumaan.
 Vie laaksoihin
 luo lähteiden,
 ja henki yksimielinen
 suo joukkoon uskovaisten.</lyrics>
</song>