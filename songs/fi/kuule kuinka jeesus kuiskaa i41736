<?xml version="1.0" encoding="UTF-8"?><song><author>E. W. Blandly, John Samuel Norris</author>
<hymn_number>178</hymn_number>
<lyrics>[V1]
 Kuule, kuinka
 Jeesus kuiskaa,
 kuule, kuinka
 Jeesus kuiskaa,
 kuule, kuinka
 Jeesus kuiskaa:
 &quot;Ota ristisi ja
 seuraa minua.&quot;

[C1]
   Askeleissas
   tahdon käydä,
   askeleissas
   tahdon käydä,
   askeleissas
   tahdon käydä.
   Koko tien Sua,
   Jeesus, seuraan vain.

[V2]
 &quot;Getsemaneen
 tie se johtaa,
 Getsemaneen
 tie se johtaa,
 Getsemaneen
 tie se johtaa.
 Rohkenetko
 sinne seurata?&quot;

[V3]
 &quot;Juotko kärsimysten
 maljan?
 Juotko kärsimysten
 maljan?
 Juotko kärsimysten
 maljan?
 Sinun tähtesi
 join maljan sen.&quot;</lyrics>
<title>Kuule, kuinka Jeesus kuiskaa</title>
</song>