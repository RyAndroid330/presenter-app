<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>244</hymn_number>
<author>Tuntematon, Tuntematon</author>
<lyrics>[V1]
 Kun vailla
 rauhaa harhailin
 ja tuska sielussain,
 niin epätoivoon
 polttavaan
 mä avun
 kuulla sain:

[C1]
   Riittää
   voima verensä,
   riittää
   voima verensä,
   riittää
   voima verensä.
   Syvä armonmerensä.

[V2]
 Nuo viisi
 haavaa Jeesuksen
 ja synkkä
 ristinpuu,
 ne tuovat
 armovirtansa
 ja siinä puhdistuu.

[V3]
 Mä vaikka huono
 olen vain
 ja kurja syntinen,
 sain ilon,
 rauhan sydämeen
 armosta Jeesuksen.</lyrics>
<title>Kun vailla rauhaa harhailin</title>
</song>