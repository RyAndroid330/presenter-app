<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7</hymn_number>
<author>Jens Nicolai Ludvig Schjörring, H. S. Thompson</author>
<title>Armo Jumalan</title>
<lyrics>[V1]
 Armo Jumalan
 lailla kirkkahan
 lähteen puuhtaan
 kuohuilee.
 Syvyydessä sen
 armolähtehen
 elon helmi
 hohtelee.

[V2]
 Armo Jumalan
 levon suloisan
 sydämehen
 aina suo.
 Jeesus-nimessä
 onnen löydät sä.
 Taivahan se
 myötään tuo.</lyrics>
</song>