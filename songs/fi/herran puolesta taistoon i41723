<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>154</hymn_number>
<author>William Fisk Sherwin, William Fisk Sherwin</author>
<lyrics>[V1]
 Herran puolesta
 taistoon kiiruhda.
 Seuraa Kristusta
 ainiaan.
 Sana aseemme,
 henki voimamme.
 Eespäin luottaen
 ain Jumalaan!

[C1]
   Veljet, siskot,
   taisteluun nyt käykää,
   tunnussanaksenne
   ottakaa:
   ylös, eespäin
   riemumielin käykää!
   Kristus itse
   meitä johdattaa.

[V2]
 Rohkeasti vaan
 luota Jumalaan.
 Hän vie ainiaan
 voittoon näin.
 Kun Hän johdattaa,
 kotiin kuljettaa,
 risti nostakaa
 ja eteenpäin.</lyrics>
<title>Herran puolesta taistoon</title>
</song>