<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>418</hymn_number>
<author>Ida Castalia Lönnbeck, Hjalmar Gustaf Braxén</author>
<lyrics>[V1]
 Olet mun.
 Sun ostin kerran
 elämään ja
 autuuteen.
 Rakkahasti ääni
 Herran vakuuttaa
 näin omilleen.

[V2]
 Kuinka kauhistaa
 siis voisi
 elon tuska,
 kuolokaan?
 Pitkä, raskas tie
 jos oisi,
 lohdun saan
 mä seurassaan.

[V3]
 Olet mun.
 Oi armo suuri,
 lapsi oon
 mä Jumalan.
 Sanansa on
 linna, muuri,
 tahdossaan
 kun vaellan.

[V4]
 Pojan kautta
 syntisille
 taivaan aarteet
 tarjotaan.
 Tietä, rauhaa
 etsiville
 armo Herran
 annetaan.</lyrics>
<title>Olet mun</title>
</song>