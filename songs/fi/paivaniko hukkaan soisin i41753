<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>207</hymn_number>
<author>Charles Carrol Luther, George C Stebbins</author>
<lyrics>[V1]
 Päivänikö
 hukkaan soisin
 mennä ilman
 hedelmää?
 Käteni vain
 tyhjät toisin,
 kun jo ilta
 yllättää?

[C1]
   Kristikansa,
   työhön, työhön,
   kun on vielä
   valoisaa.
   Kohta vaihtuu
   päivä yöhön,
   sieluja nyt
   voittakaa!

[V2]
 Jeesus auttaa,
 Jeesus kantaa
 kuolemasta
 vapahtain.
 Vähän vain voin
 Hälle antaa,
 vaikka itse
 paljon sain.</lyrics>
<title>Päivänikö hukkaan soisin</title>
</song>