<?xml version="1.0" encoding="UTF-8"?><song><author>Nils Frykman, James McGrahan</author>
<hymn_number>613</hymn_number>
<title>Öiset varjot hiljaa väistyy</title>
<lyrics>[V1]
 Öiset varjot
 hiljaa väistyy,
 aamutähti loistelee,
 aurinko jo
 kohta nousee,
 ikipäivä valkenee.

[C1]
   Herra saapuu,
   Herra saapuu!
   Päättyy taistelut
   nää maiset.
   Kruunu kirkas
   morsiolla,
   häät jo alkaa
   taivaiset.

[V2]
 Oi, mi riemu
 taivaan täyttää
 lunastettuin tullessa
 maisen matkan
 taisteluista
 voittovirren soidessa!</lyrics>
</song>