<?xml version="1.0" encoding="UTF-8"?><song><title>Kun joulu valkeneepi</title>
<lyrics>[V1]
 Kun joulu
 valkeneepi,
 luo seimen
 rientää saan.
 /: Siell' Jeesus
 lepäileepi nyt
 olkivuoteellaan.:/

[V2]
 Sä Poikas,
 Herra, sallit
 lapseksi syntyä.
 /: Siis lapsuus-
 vuodet kalliit
 myös Sulle
 annan mä.:/</lyrics>
<hymn_number>31</hymn_number>
<author>Abel Burckhart, Saksalainen</author>
</song>