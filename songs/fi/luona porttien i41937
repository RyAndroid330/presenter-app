<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>621</hymn_number>
<author>Katharine E. Purvis, James Milton Black</author>
<lyrics>[V1]
 Luona porttien
 joukko enkelten
 pelastettuin tullessa!
 Päässä matkan maan
 kruunu annetaan
 pelastettuin tullessa.

[C1]
   Pelastettuin tullessa,
   pelastettuin tullessa
   riemulaulelot soivat
   halki taivasten,
   pelastettuin tullessa.

[V2]
 Siellä uskovat
 jälleen kohtaavat
 pelastettuin tullessa.
 Valkojoukon nään
 palmut käsissään
 pelastettuin tullessa.

[V3]
 Siellä laulu soi
 ylistystä, oi,
 pelastettuin tullessa,
 tuskan ahjosta
 koetuksista
 pelastettuin tullessa.</lyrics>
<title>Luona porttien</title>
</song>