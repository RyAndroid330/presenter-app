<?xml version="1.0" encoding="UTF-8"?><song><title>Ah, etten mitään oisi</title>
<lyrics>[V1]
 Ah, etten mitään oisi,
 tyhjä, murrettu astia vaan,
 pantu Mestarin
 jalkain juureen
 korjaustansa vartoamaan;
 tyhjä, Hän että voi täyttää,
 kun työtänsä
 käyn tekemään,
 niin murrettu,
 että voi käyttää
 mua syntistä etsimään.

[V2]
 Ah, etten mitään oisi,
 yksin Herraani tottelisin,
 ovenvartijan lailla valppaan
 Hänen käskynsä täyttelisin;
 kanteleen
 sointuna helkkäin,
 kun Taitajan tahto on niin,
 tai vaieten,
 kunnes mun jälleen
 saa sointuihin taivaisiin.</lyrics>
<hymn_number>321</hymn_number>
<author>Georgiana M. Taylor, Tuntematon</author>
</song>