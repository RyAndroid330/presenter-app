<?xml version="1.0" encoding="UTF-8"?><song><title>Jeesuksen nyt Jordanille</title>
<lyrics>[V1]
 Jeesuksen nyt
 Jordanille
 nähdään menevän,
 /: kastetta näin
 Johanneksen
 siellä pyytävän.:/

[V2]
 Näin Hän kaiken
 vanhurskauden
 siellä täyttävi,
 /: tällä
 esimerkillänsä
 tietä näyttävi.:/

[V3]
 Jeesus Johanneksen
 kanssa
 astui Jordaniin.
 /: Pyhä Henki
 Hänen päälleen
 silloin laskettiin.:/

[V4]
 Jeesus käski
 oppilaansa
 kaikkeen
 maailmaan
 /: saarnaamaan
 vain sanaa Herran,
 sitten kastamaan.:/

[V5]
 Tämän käskyn
 saatuansa
 Herraan uskovat
 /: kaikkialla
 saarnasivat
 ja myös
 kastoivat.:/

[V6]
 Herran
 kastekäsky vielä
 ompi voimassaan.
 /: Ken vain uskoo
 Jeesuksehen,
 hänet kastetaan.:/</lyrics>
<author>Tuntematon, Tuntematon</author>
<hymn_number>177</hymn_number>
</song>