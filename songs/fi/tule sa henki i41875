<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>485</hymn_number>
<author>Magnetius Maurus Hrabanus, Louis Lambillotte</author>
<lyrics>[V1]
 Tule, Sä Henki,
 Puolustaja,
 sydämen
 rauhan antaja.
 Voimalla täytä,
 tulellasi
 /: Sinua kaipaava
 kansasi.:/

[V2]
 Lohduttaja,
 Sua rukoilemme,
 lahjaasi suurta
 anomme.
 Henkesi liekki,
 rakkautesi,
 /: voitelu uusi
 suo työhösi.:/</lyrics>
<title>Tule, Sä Henki</title>
</song>