<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>191</hymn_number>
<author>Sabine Baring-Gould, Tekla Renfors, Sir Arthur Seymor Sullivan</author>
<title>Eespäin, Herran kansa</title>
<lyrics>[V1]
 Eespäin, Herran kansa,
 pyhään taistohon,
 ristin lipun alla
 aina voittohon!
 Kristus, kuninkaamme
 meitä johdattaa.
 Voittovoiman yksin
 Hän vain lahjoittaa.

[C1]
   Eespäin, Herran kansa,
   pyhään taistohon,
   ristin lipun alla,
   aina voittohon!

[V2]
 Vihollisten joukot
 Jeesus karkottaa.
 Ei siis
 taiston kuumuus
 saa sua kauhistaa.
 Pimeyden voimat
 laulun kuullessaan
 vapisevat; siispä
 laulakaamme vaan.</lyrics>
</song>