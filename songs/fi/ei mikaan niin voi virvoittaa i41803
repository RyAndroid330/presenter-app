<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>327</hymn_number>
<author>Lars Thorstensson Nyberg, Elias Lagus, Bartholomeus Gesius</author>
<lyrics>[V1]
 Ei mikään niin
 voi virvoittaa,
 en muusta
 iloani saa,
 ei autuutta
 saa suurempaa
 kuin minkä
 Jeesus lahjoittaa.

[V2]
 En lepoa
 mä löytänyt,
 en muusta
 mistään tyyntynyt,
 ennen kuin
 löysin aartehen,
 Ystävän, Herran
 Jeesuksen.

[V3]
 Muu vaivoissa
 ei lohduta,
 ei auta kuolon
 tuskissa,
 ei päästä
 alta murheitten
 kuin läsnäolo
 Jeesuksen.

[V4]
 Ainoa
 anteeksantamus,
 ainoa synnin
 sovitus
 ja ainoa tie
 armohon
 Jeesuksen risti
 yksin on.

[V5]
 On ainut
 neuvo huonolle,
 on ainut
 turva heikolle
 ja ainut
 meillä puolustus
 Jeesuksen
 esirukous.

[V6]
 Ainoa tosi viisaus
 ja ainoa
 vanhurskaus,
 ainoa puhdas
 pyhitys
 on Vapahtajan
 yhteys.</lyrics>
<title>Ei mikään niin voi virvoittaa</title>
</song>