<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>334</hymn_number>
<author>Simo Oskari Korpela, Martti Mikael Hela</author>
<lyrics>[V1]
 Jeesuksesta laulan,
 Jeesuksesta vaan,
 /: jolta synnit
 suuret anteeks
 sain ja saan.:/

[V2]
 Hän mun
 syyni suuret
 poisti verellään,
 /: otti synnin
 orjan armoon,
 elämään.:/

[V3]
 Katkoi verkot
 valheen,
 kahleet kuoleman,
 /: vangin vapautti,
 laps oon
 Jumalan.:/

[V4]
 Lapsi oma Herran,
 taivaan kuninkaan,
 /: kruunun perin
 kerran,
 valtakunnan saan.:/</lyrics>
<title>Jeesuksesta laulan</title>
</song>