<?xml version="1.0" encoding="UTF-8"?><song><author>Tekla Renfors, Kaarlo Waismaa</author>
<hymn_number>472</hymn_number>
<title>Ensin tyhjennä</title>
<lyrics>[V1]
 Ensin tyhjennä,
 Herra, sieluni,
 tomuun taivuta
 oma voimani:
 sitten korota
 ylös luoksesi.

[V2]
 Ensin nöyryytä
 ylpeys, sisuni,
 kaikki kuoleta
 kerskaus lihani;
 sitten ylennä,
 anna armosi.

[V3]
 Ensin kurita,
 Isä, lastasi,
 lyö ja haavoita
 parahakseni;
 sitten paranna,
 sido terveeksi.

[V4]
 Ensin verellä
 pese syntini,
 sydän puhdista
 lumivalkeeksi;
 sitten aseta
 mailman suolaksi.

[V5]
 Ensin ahjossa
 hio henkeni,
 usko vahvista,
 täytä maljani;
 sitten kirkasta
 nimes kauttani.

[V6]
 Ensin vuodata
 rakkaus työhösi,
 vaikka itkulla
 kylvö kävisi;
 sitten kotona
 näytä lyhteeni.</lyrics>
</song>