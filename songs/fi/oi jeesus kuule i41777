<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Oi Jeesus,
 kuule huutoain
 ja auta kurjaa
 sieluain.
 Sä armostasi
 minut vain
 nyt ota tällaisnaan.

[C1]
   Oi, ota tällaisnaan.
   Oi, ota tällaisnaan.
   Sä, Jeesus,
   kuolit tähteni;
   siis ota tällaisnaan.

[V2]
 Oon rikollinen,
 avuton.
 Sun veressäsi
 voima on.
 Nyt turvaan
 Herran armohon;
 oi, ota tällaisnaan.</lyrics>
<title>Oi Jeesus, kuule</title>
<author>Eliza H. Hamilton, Ira David Sankey</author>
<hymn_number>273</hymn_number>
</song>