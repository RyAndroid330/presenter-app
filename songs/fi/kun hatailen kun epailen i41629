<?xml version="1.0" encoding="UTF-8"?><song><author>Tuntematon, Suomalainen kansansävelmä</author>
<hymn_number>357</hymn_number>
<lyrics>[V1]
 Kun hätäilen,
 kun epäilen,
 kun olen tuskissain,
 mä käännyn
 Herran puolehen,
 Hän on mun auttajain.
 Hän kuulee rukoukseni
 ja rientää auttamaan.
 Ja vaikka apu viipyisi,
 se saapuu aikanaan.</lyrics>
<title>Kun hätäilen, kun epäilen</title>
</song>