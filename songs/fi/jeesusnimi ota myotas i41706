<?xml version="1.0" encoding="UTF-8"?><song><author>Lydia Baxter, Olli Vuorinen-Berg, William Howard Doane</author>
<hymn_number>57</hymn_number>
<lyrics>[V1]
 Jeesus-nimi
 ota myötäs,
 murheen laakson
 matkamies.
 Tee sen turvissa
 sä työtäs,
 ohjatkoon se
 kaikki ties.

[C1]
   Taivas, maa,
   iloitkaa!
   Nimi Jeesus
   toivon toi.
   Taivas, maa,
   iloitkaa!
   Nimi Jeesus
   toivon toi.

[V2]
 Jeesus-nimi
 kilven lailla
 synnin liekit
 sammuttaa.
 Siitä kiusausten
 mailla
 heikot avun,
 turvan saa.

[V3]
 Jeesus-nimi
 ilon antaa
 synnin orjan
 rintahan,
 elon purtemme
 se kantaa
 suojaan
 rauhan valkaman.</lyrics>
<title>Jeesus-nimi ota myötäs</title>
</song>