<?xml version="1.0" encoding="UTF-8"?><song><author>Eliza Edmunds Hewitt, John Robson Sweney</author>
<hymn_number>476</hymn_number>
<lyrics>[V1]
 Herrani tahdon
 nähdä vain,
 katsella yksin
 Jeesustain,
 vaipua ristin
 juurehen
 nöyränä Häntä
 palvoen.

[C1]
   Vain Jeesukseen
   luotan,
   vain Jeesukseen
   luotan.
   Ristillä kuoli eestäni,
   sovitti kaikki
   syntini.

[V2]
 Jälkiä seuraan
 Jeesuksen
 oppien tietä
 pyhyyden.
 Henkensä minut
 ohjatkoon
 Herrani kaikkeen
 aarteistoon.

[V3]
 Täydemmin Hänen
 sanansa
 sieluni saakoon
 vallata
 käskynsä että
 pienenkin
 uskollisesti
 täyttäisin.</lyrics>
<title>Herrani tahdon nähdä vain</title>
</song>