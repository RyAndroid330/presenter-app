<?xml version="1.0" encoding="UTF-8"?><song><author>John Foote, John Foote</author>
<hymn_number>297</hymn_number>
<lyrics>[V1]
 Ristillä kuoli
 Vapahtaja,
 syntisten
 suuri armahtaja.
 Verensä voima
 turvani on,
 poissa on uhka
 lain tuomion.

[C1]
   Veri vain Jeesuksen
   turva on ikuinen.
   Veri vain Jeesuksen
   voitonmerkki
   on ihmeellinen.

[V2]
 Kurjimman Kristus
 voi pelastaa.
 Minkä Hän lupaa
 sen vahvistaa.
 Verensä voima
 turvani on,
 poissa on uhka
 lain tuomion.

[V3]
 Päivä kun kerran
 koittava on,
 Herralta silloin
 saat palkinnon.
 Verensä voima
 turvani on,
 poissa on uhka
 lain tuomion.</lyrics>
<title>Ristillä kuoli Vapahtaja</title>
</song>