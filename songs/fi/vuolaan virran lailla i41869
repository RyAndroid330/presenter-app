<?xml version="1.0" encoding="UTF-8"?><song><author>Frances Ridley Havergal, James Mountain</author>
<hymn_number>469</hymn_number>
<lyrics>[V1]
 Vuolaan virran lailla
 Herran rauha tuo
 taivaan korkeudesta
 siunauksen suo.
 Täynnä, tulviessaan
 yli äyräitten
 kirkkaana se virtaa
 aina syveten.

[C1]
   Rauhan suuren antaa,
   syvän, runsahan.
   Jeesukselta saan
   sen ottaa vastahan.

[V2]
 Isän hellään hoivaan,
 varjoon taivaiseen
 kätketty saan olla,
 käteen suojaiseen.
 Lapsenansa aina
 levon luonaan saan.
 Huolet eivät paina
 Hänen omiaan.</lyrics>
<title>Vuolaan virran lailla</title>
</song>