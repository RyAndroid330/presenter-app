<?xml version="1.0" encoding="UTF-8"?><song><title>Suo Hengen tulla</title>
<lyrics>[V1]
 Suo Hengen tulla
 päällemme, kuin ennen
 Sun oppilaasi
 saivat salissaan.
 /: Sen saman taivaallisen
 Pyhän Hengen
 suo myöskin meille
 luoda valoaan.:/

[V2]
 Suo Hengen tulla
 päällemme, kuin ennen
 soit kerran
 saarnatessa Pietarin.
 /: Suo sanan voiman
 poistaa usva öinen,
 luo valo kärsivihin
 sydämiin.:/

[V3]
 Suo Hengen tulla
 päällemme kuin ennen,
 kun sielut suurin
 joukoin pelastui.
 /: Sä pue meidät
 voimaan
 Pyhän Hengen.
 Sen kautta ennen
 sana kirkastui.:/

[V4]
 Suo Hengen tulla
 päällemme kuin ennen.
 Se kuolleet nosti,
 sairaat paransi.
 /: Sä meille annoit
 Hengen lupauksen.
 Siis rukoilemme:
 anna voimasi.:/</lyrics>
<author>Karl Gustaf Sjölin, A. A. Holmgrén, Karl Gustaf Sjölin</author>
<hymn_number>144</hymn_number>
</song>