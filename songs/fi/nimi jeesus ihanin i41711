<?xml version="1.0" encoding="UTF-8"?><song><author>John T. Klementz, H. P. Danks</author>
<hymn_number>67</hymn_number>
<lyrics>[V1]
 Nimi Jeesus
 ihanin ja rakkain,
 suurin taivaassa
 ja päällä maan.
 Nimi Jeesus,
 lahja taivaan,
 kiitoslaulut saa
 se sointumaan.

[C1]
   Nimi suloinen,
   nimi ihmeinen
   synnin vallan
   aina voittaa voi.
   Yksin Jeesus,
   kallis Jeesus,
   ikiautuuden
   Hän meille toi.

[V2]
 Nimi Jeesus voiman
 suuren antaa.
 Nimet toiset
 kaikki varjoon jää.
 Nimi Jeesus,
 lahja taivaan,
 enkelitkin
 Häntä ylistää.

[V3]
 Kuinka suuri
 onkaan nimi Jeesus.
 Sepä täyttää
 taivaat taivahain.
 Nimi Jeesus,
 lahja taivaan,
 soikoon yli
 laaksoin, kukkulain.</lyrics>
<title>Nimi Jeesus ihanin</title>
</song>