<?xml version="1.0" encoding="UTF-8"?><song><author>Johan Melcher Öjerholm, Johan Melcher Öjerholm</author>
<hymn_number>189</hymn_number>
<title>Eespäin, Herran joukko</title>
<lyrics>[V1]
 Eespäin, Herran joukko,
 käy taistelohon.
 Eespäin riennä riemuiten.
 Voitto Sun on.
 Jeesus, meidän päämies,
 on voittamaton.
 Eespäin siis
 riennä taistohon.

[C1]
   Tulkaa, tule sinäkin!
   Käy nyt Herran riveihin.
   Usko, valvo rukoillen.
   Tee työtä
   Herran Jeesuksen.

[V2]
 Aallot pauhaa,
 myrsky lyö voimallinen,
 mutta lippu liehuvi
 uskovien
 siksi, kunnes
 voitamme vihollsen.
 Silloin on
 valta Jeesuksen.</lyrics>
</song>