<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Riennä riemuin
 eespäin vaan
 tietä Jumalasi,
 /: joskin löydät
 määrämaan
 vasta
 kuollessasi.:/

[V2]
 Ällös pelkää
 yötä maan;
 taivaan
 tähdet loistaa.
 /: Luota Herraan
 Jumalaan,
 Hän voi
 varjot poistaa.:/</lyrics>
<title>Riennä riemuin eespäin</title>
<hymn_number>433</hymn_number>
<author>Pekka Juhani Hannikainen, Pekka (Pietari) Juhani Hannikainen</author>
</song>