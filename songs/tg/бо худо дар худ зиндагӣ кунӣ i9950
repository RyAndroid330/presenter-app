<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>57</hymn_number>
<title>Бо Худо дар худ зиндагӣ кунӣ</title>
<lyrics>[V1]
.Am                       Dm
 Бо Худо дар худ зиндагӣ кунӣ
.                    Am
 Чизе нест беҳтару азизтар

[C1]
.     A                     Dm
   // Маро ёд деҳ Худованди ҷонам
.  Am
   Меҳратро ба қадраш бидонам //

[V2]
 Баҳри Ту наҷот диҳанда зиям
 Дар боқеъи умре, ки дорам

[C2]
   // Ба қимати озоди, ки додӣ
   Рӯз ба рӯз бештар ман бирасам //

[V3]
 Маро ёд деҳ дӯст дорам душманам
 Ки аз рости руй мегардонад

[C3]
   // Маро ёд деҳ наҷоткори ҷонам
   То Туро бештар ман шиносам //</lyrics>
<key>Dm</key>
</song>