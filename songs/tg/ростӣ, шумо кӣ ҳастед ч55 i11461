<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>55</hymn_number>
<key>D</key>
<lyrics>[V1]
.D      G    A     D
 Ростӣ, шумо кӣ ҳастед,
.             A     D
 Ки ин қадар хушбахтед?
.    G          A      D
 //  Хандону бо ҳам дӯстед,
.A    G    D    A
 Механдеду мерақсед?  //

[V2]
 Моён масеҳӣ ҳастем,
 Исоро мепарастем.
 //  Падари мо аст Худо,
 Ту ҳам биё ҷамъи мо!  //

[V3]
 Чӣ китобе мехонед,
 Эҳтиёташ мекунед?
 //  Чӣ чизе аз он дидед,
 Ки дил ба он додаед?  //

[V4]
 Роҳу расми зиндагӣ,
 Чораи дармондагӣ
 //  Дар Инҷил мо меёбем,
 Ту ҳам биё, бихонем.  //</lyrics>
<title>Ростӣ, шумо кӣ ҳастед Ч55</title>
</song>