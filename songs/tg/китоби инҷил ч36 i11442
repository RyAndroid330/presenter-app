<?xml version="1.0" encoding="UTF-8"?><song><title>Китоби Инҷил Ч36</title>
<key>F</key>
<lyrics>[V1]
.    F
 //  Китоби Инҷил
.C7
 Ба ман роҳнамо,
 Мехонамаш ман
.F
 Бо дуо.  //

[C1]
.             C7
   Азоб кашид Исоям.
.               F
   Хунашро рехт барои ман.
.              C7
   Ҳеҷ фаромӯш намекунам,
.               F
   Наҷот бахшид барои ман.
.             C7
   Шодиро дод бар дилам,
.             F
   Фарзанди Худо ҳастам.

[V2]
 //  Китоби Инҷил -
 Каломи Худо,
 Мехонамаш ман
 Доимо.  //</lyrics>
<hymn_number>36</hymn_number>
</song>