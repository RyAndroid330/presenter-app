<?xml version="1.0" encoding="UTF-8"?><song><title>Бо Ту роҳ равам</title>
<key>Cm</key>
<lyrics>[V1]
.   Cm                  Fm
 // Хоҳам ҳар рӯз бо Ту роҳ равам,
.Gm        Cm
 Садоятро бишнавам!
.Ab             D
 Муждаи хуши наҷотатро,
.G         Cm
 Хамаҷо расонам! //

[C1]
.     C                  Fm
   // Султани қалбам Туй Исо,
.  Bb          Eb
   Меҳри Ту беҳамто!
.  Ab                   D
   Хоҳам ҳар рӯз бо Ту роҳ равам,
.  G          Cm
   Садоятро бишнавам! //

[V2]
 // Чун ирадаатро наҷуям,
 Бубахш маре Масеҳам!
 Хоҳам сӯят шитобон давам,
 Бо Ту роҳ равам! //</lyrics>
</song>