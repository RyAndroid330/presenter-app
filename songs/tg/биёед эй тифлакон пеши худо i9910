<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>96</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.   Dm                C     Dm
 // Биёед эй тифлакон пеши Худо //
.   Gm         F              E      Dm
 // Дуо кунед, дуо кунед, дуо кунед, дуо //

[V2]
 // Барои Падари худ дуо кунед //
 // Суруди нав бисароед ба номи Худо //

[V3]
 // Барои модари худ дуо кунед //
 // Ки азоб кашидааст ӯ аз барои шумо //

[V4]
 // Ба Худованди худ бовар кунед //
 // То, ки хубие шавад роҳнамои шумо //</lyrics>
<title>Биёед эй тифлакон пеши Худо</title>
</song>