<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>97</hymn_number>
<lyrics>[C1]
   // Беҳтарини китобҳо
   Муҳимтарини дунё //

[V1]
 // Худо дар он мегӯяд
 Ки оштиро дӯст дорад //
 Беҳтарини китобҳо
 Муҳимтарини дунё

[C2]
   // Дар ҳақи Довуд, Мусо
   Пайғамбарони Худо //

[V2]
 // Дар он хонем аз Масеҳо
 Ба наздаш шитоб ҳоло //
 Дар ҳақи Довуд, Мусо
 Пайғамбарони Худо

[C3]
   // Нақл шуда аз Исо
   Ӯро фиристод Худо //

[V3]
 // Беморонро дод шифо
 Мурд зинда шуд баҳри мо //
 // Нақл шуда аз Исо
 Ӯро фиристод Худо //

[C4]
   // Нақл шуда аз Исо
   Ӯро фиристод Худо //</lyrics>
<title>Беҳтарини китобҳо</title>
</song>