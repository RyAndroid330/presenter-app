<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<author>аттрибутед то Садху Сундар Сингх, Фолк Мелоды</author>
<title>Аз пайаш равам СЧҲ34</title>
<lyrics>[V1]
 /// Ман тазмим гирифтам,
 аз пайаш равам, ///
 Аз пайи Исо ҳар рӯза.

[V2]
 /// Гарчи аз пайаш,
 наравад касе, ///
 Аз пайаш равам ҳар рӯза.

[V3]
 /// Пушт бар ҷаҳону
 рӯям бар салиб, ///
 Аз пайаш равам ҳар рӯза.</lyrics>
</song>