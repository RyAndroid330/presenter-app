<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Каф бизанед шоди кунед
 Масеҳи мо Худои мо //
 // Суриди ҳало ҳало кунед
 Домиди мо Худои мо //

[C1]
   // Аруси мо калисо, Аруси мо калисо
   Калисое Худо, Калисое Худо //

[V2]
 // Суриди ҳало ҳало меояд
 Пуршаҳроми меояд //
 // Муборак аст касе ки
 Ба номи Худо меояд //

[V3]
 // Хурду калон пиру ҷавон
 Бихонанд ҳалелуё //
 // Исои мо дар байни мо
 Ба номи Худо меояд //

[V4]
 // Эй қавми Ӯ шодӣ кунед
 Ба миёни мо миояд //
 // Исои мо дар байни мо
 Ба номи Худо меояд //</lyrics>
<title>Аруси Исо Калисо</title>
</song>