<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12</hymn_number>
<title>Бархез, бархез Ч12</title>
<lyrics>[C1]
.  A          D                A
   Бархез, бархез, эй дӯст, ба-ро!
.                  D
   Бархез, бархез, паси Масеҳ биё!

[V1]
.    D                   G
 //  Омад Худованд назди мо,
 Сӯи осмон кушодааст роҳ.  //

[V2]
 //  Исо гуфтааст: Ман ҳастам роҳ.
 Ба Суханаш бовар намо.  //

[V3]
 //  Дӯстам, нагард дур аз Худо,
 Дилатро бидеҳ ба Исо.  //

[V4]
 //  Ҳамвор мекунад Ӯ роҳро.
 Мерезонад баракатро.  //</lyrics>
<key>D</key>
</song>