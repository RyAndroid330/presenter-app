<?xml version="1.0" encoding="UTF-8"?><song><title>Худо мо шукр мегуем</title>
<lyrics>[V1]
 /// Худо мо шукр мегуем ///
 Зи меҳру лутфат Омин

[V2]
 /// Худо Ту баракат деҳ ///
 Нонеро, ки додӣ Омин

[V3]
 /// Ҳалелуёҳ ҳамд гуед ///
 Павардигоро Омин Омин</lyrics>
<hymn_number>55</hymn_number>
</song>