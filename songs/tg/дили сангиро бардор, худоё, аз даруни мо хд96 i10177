<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>96</hymn_number>
<title>Дили сангиро бардор, Худоё, аз даруни мо Хд96</title>
<key>D</key>
<lyrics>[C1]
.                  G          Em    A    D
   Дили сангиро бардор, Худоё, аз даруни мо.
.                    G        A               D
   Дили гӯштиро деҳ, Худованд, бар тибқи ваъдаҳо.
.                G          Em   A     D
   Пурии Рӯҳи Қуддусат хоҳем андаруни худ.
.                  G          Em     A         D
   Тасаллию қувват бахшой моро зи файзат, эй Худо.

[V1]
.   D                  C            D
 // Дили тоза деҳ моро, тасаллӣ, зафар бахшо.
.         G      A            D
 Ҳидояту таълимро зи Рӯҳат хоҳем ҳар ҷо. //

[V2]
 // Шери сибти Яҳудо, ғолиб гаштӣ бар дунё.
 Пуршукӯҳу ҷалолӣ, Ту ҳастӣ умеди мо. //</lyrics>
</song>