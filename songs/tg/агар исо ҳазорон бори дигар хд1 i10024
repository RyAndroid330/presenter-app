<?xml version="1.0" encoding="UTF-8"?><song><title>Агар Исо ҳазорон бори дигар Хд1</title>
<key>Cm</key>
<lyrics>[V1]
.Cm       Fm             Cm
 Агар Исо ҳазорон бори дигар
.           Db              Cm
 Ба дунё зиндагонӣ гирад аз сар,
.             Fm             Cm
 Кунад равшан зи нав дунёи моро,
.            Fm             Cm
 Шифо бахшад ҳама дардҳои моро,

[C1]
.                 Fm               Cm
   // Вале дар қалби мо ворид нагардад,
.           Db             Cm
   Умеди мо саросар ҳеҷ гардад. //

[V2]
.Cm       Fm             Cm
 Агар Исо ҳазорон бори дигар
.           Db              Cm
 Ба дунё зиндагонӣ гирад аз сар,
.             Fm              Cm
 Ба худ хонад ҳама заҳматкашонро,
.            Fm             Cm
 Бибахшад зиндагонӣ мурдагонро,

[C2]
.                 Fm               Cm
   // Вале дар қалби мо ворид нагардад,
.           Db             Cm
   Умеди мо саросар ҳеҷ гардад. //

[V3]
.Cm       Fm             Cm
 Агар Исо ҳазорон бори дигар
.           Db              Cm
 Ба дунё зиндагонӣ гирад аз сар,
.         Fm              Cm
 Намоёнад ба инсон роҳу чора,
.           Fm              Cm
 Шавад маслубу бархезад дубора,

[C3]
.                 Fm               Cm
   // Вале дар қалби мо ворид нагардад,
.           Db             Cm
   Умеди мо саросар ҳеҷ гардад. //</lyrics>
<hymn_number>1</hymn_number>
</song>