<?xml version="1.0" encoding="UTF-8"?><song><title>Эй Худои нозанин СЧҲ105</title>
<lyrics>[V1]
.D
 Эй Худои нозанин,
.Hm
 эй ҷаҳонро офарин
.   G          Em
 // Шукри Туро гӯем
.A        D
 дар рӯи замин //

[C1]
.     G     D    G   D   G     D
   // Зебоӣ Ту, яктоӣ Ту, бо моӣ Ту
.     Em       D
   Эй Худо, эй Худо //

[V2]
 Ту чашмаи оби ҳаёт,
 Баҳрам Ту овардӣ наҷот
 // Туро доим мепарастам,
 дар ёдат хурсанд ҳастам //</lyrics>
<key>D</key>
<hymn_number>105</hymn_number>
</song>