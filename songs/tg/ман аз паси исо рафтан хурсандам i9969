<?xml version="1.0" encoding="UTF-8"?><song><author>аттрибутед то Садху Сундар Сингх, Фолк Мелоды</author>
<hymn_number>38</hymn_number>
<title>Ман аз паси Исо рафтан хурсандам</title>
<key>A</key>
<lyrics>[V1]
.   A
 // Ман аз паси Исо рафтан хурсандам //
.             D                A
 (Ман аз паси Исо рафтан хурсандам
.    
     Ман аз паси Исо рафтан хурсандам)
.              E      A
 Аз ин роҳ бар намегардам

[V2]
 // Ёфт намешавад ҳеҷ пеш гирие //
 Ки маро боз мегардонад

[V3]
 // На бар ин дунё, балки бар салиб //
 Менигарам пеш меравам</lyrics>
</song>