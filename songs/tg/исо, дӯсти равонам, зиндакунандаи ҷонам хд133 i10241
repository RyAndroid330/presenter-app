<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>133</hymn_number>
<key>F</key>
<lyrics>[V1]
.   Dm            Gm      C            F
 //  Исо, дӯсти равонам, зиндакунандаи ҷонам!
. B                 Gm   A              Dm
 Ғайр аз Ту дар ду олам набвад паноҳи ҷонам. //
.            Gm     C              F     B
 // Гар аз кашокаши даҳр доим дар имтиҳонам,
.        Gm      A                  Dm
 Бо номи қуддуси Ту худро аз он раҳонам. //

[V2]
 // Бар баҳри зиндагонӣ ором чу киштироне.
 Оромам, гарчи ояд тӯфони ногаҳонӣ. //
 // Шодам аз он ки дорам ҳамчун Ту пуштибоне.
 Донам, ки Ту саломат бар бандарам расонӣ. //

[V3]
 // Эй Чашмаи ҷалолат, в-эй Манбаи адолат,
 Бар даргаҳат надорам ҷуз тавбаву хиҷолат. //
 // Овора банда будам, гумгашта дар ҷаҳолат.
 Лекин маро зи раҳмат бираҳондӣ аз залолат. //</lyrics>
<title>Исо, дӯсти равонам, зиндакунандаи ҷонам! Хд133</title>
</song>