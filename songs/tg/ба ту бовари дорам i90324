<?xml version="1.0" encoding="UTF-8"?><song><author>Фарангис Улунд</author>
<key>Cm</key>
<lyrics>[V1]
.   Cm
 // Ба ту бовари дорам
.     Gm(Bb)
 Дар канори Ту ҳастам
.   Ab
 Танҳо дар ҳузури Ту
.     Bb
 Руҳбаланду хурсандам //

[V2]
.   Cm
 // Бигзор вуҷуди ман
.     Bb
 Туро мадҳ бикунад
.   Ab
 Бигзор дилу ҷони ман
.     Bb
 Туро беҳад дӯст дорад //

[C1]
.             Cm(Ebm)       Bb(D)
   //// Худои ман Шоҳи Шоҳон Ту
.          Ab(B)          Bb(D)
   Тасалоҳи дилам мепарастам Туро ////

[B1]
.          Ebm
   // Ту бузург тавоно
   Беҳамтову пурқуддрат
.        Db
   Худои ман
.       B       Db
   Ту бузурги тавонои //
.    Ebm
   Худо</lyrics>
<title>Ба ту бовари дорам</title>
</song>