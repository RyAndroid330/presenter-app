<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // О Худойи офарида
 Меҳрибони маҳд гӯем //

[V2]
 // Дар дили мо ҳаст меҳри Ту
 Дар забони маҳд гӯем //

[V3]
 // Гудакона дӯст медори
 Мо ҳамма дар назди ту //

[V4]
 // Васият карда месароям
 Ту бузурги, эй Худо //

[V5]
 // Ту шоҳи мо, эй Худо //</lyrics>
<title>Эслагин севги со'зини</title>
</song>