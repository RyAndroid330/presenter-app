<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10</hymn_number>
<lyrics>[C1]
   // Шоди намо бо Худованд
   Ки Исо аст дилу ҷон //

[V1]
 Ин замину дарёҳо
 Аз они Ӯст бачаҳо
 Шоди намоед бо Худованди Исо
 Ту бузург ҳастӣ Худованди Исо
 Худои Падар фиристода Туро</lyrics>
<title>Шоди намо бо Худованд</title>
</song>