<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>65</hymn_number>
<title>Исо кудаконро чун маро дӯст дорад</title>
<key>F#</key>
<lyrics>[V1]
.   F#                 C#
 // Исо кӯдаконро чун маро дӯст дорад //
.C#        F#           G#      C#
 Кӯдаконро чун маро дар даст мегирифт
.F#                 C#
 Исо кӯдаконро чун маро дӯст дорад

[V2]
 // Исо кӯдаконро чун туро дӯст дорад //
 Кӯдаконро чун туро дар даст мегирифт
 Исо кӯдаконро чун туро дӯст дорад

[V3]
 // Калонҳоро мисли шуморо дӯст дорад //
 Чун шуморо, калонҳоро баракат медод
 Калонҳоро мисли шуморо дӯст дорад</lyrics>
</song>