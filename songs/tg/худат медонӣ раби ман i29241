<?xml version="1.0" encoding="UTF-8"?><song><title>Худат медонӣ Раби ман</title>
<key>E</key>
<lyrics>[C1]
.     E                       A
   // Худат медонӣ Раби ман, худат медонӣ //
.     E                       A
   // Ошиқат ҳастам Раби ман, ошиқат ҳастам //
.     A           B             E
   // Оям ба суят Сарварам маро наронӣ //

