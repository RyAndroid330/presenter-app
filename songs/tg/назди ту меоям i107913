<?xml version="1.0" encoding="UTF-8"?><song><title>НАЗДИ ТУ МЕОЯМ</title>
<lyrics>[V1]
 // Ҷлолат медиҳем, ҳамдат гуэм
 Оем дастҳо барафрозем, дар васфат бисароэм //

[C1]
   Чи аҷби, корҳои Ту аҷб аст
   Дар тамоми замин Исо, шистаи ҳамди
   Кист мисли Ту, монанди Ту еу Исо
   Беназиру неҳамто Исо
   Шоистаи ҳамди

[V2]
 // Назди Ту меоям бо тарона
 Муӣзаҳоят бисёр аст ва муҳаббатат бузург //

[V3]
 // О Ту бузург, Ту зебоиву бузург
 Мисли Ту дигаре нест //</lyrics>
<author>Эва-Лена Хеллмарк</author>
</song>