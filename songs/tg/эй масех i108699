<?xml version="1.0" encoding="UTF-8"?><song><author>Собир Умуров</author>
<lyrics>[V1]
 // Эй Масех нури жахон
 Ту хасти Шохи Султон
 Ба ту бовари дорам
 Куддуси Худойи Калом //

[C1]
   // Худойиман Падарам
   Туро ман мепарастам
   Сарчашмаи хурсанди
   Ту доди ба ин хаётам //

[B1]
   // Руҳи Куддус Пуштибони
   Тасаллохи жонам Ту
   Дар ин бевафо дуне
   Чашмаи соф хаётам Ту //</lyrics>
<title>Эй Масех</title>
</song>