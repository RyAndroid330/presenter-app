<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G       D         G
 Эй Шоҳи шоҳони ҷаҳон,
.        D           G
 Эй Нури чашми ақлу ҷон!
.     C         G
 //  Бар тахти дил султон Туӣ,
.       D           G
 Исо - Худовандам Туӣ.  //
.G        D       G
 Эй Нури чашми ошиқон,
.G      D           G
 Эй Холиқи кавну макон!
.    C      G
 //  Эй Ромиши ороми ҷон,
.      D            G
 Исо - Худовандам Туӣ!  //

[V2]
 Мусо ба фармони Ту шуд
 Солики саҳрои наҷот,
 //  Довуд ба дил иқрор кард,
 Исо - Худовандам Туӣ!  //
 Ҳамчун баҳор андар чаман,
 Ҳам рӯҳу ҳам райҳон Туӣ!
 //  Шабнам Туӣ, насрин Туӣ,
 Исо - Худовандам Туӣ!  //

[V3]
 Дар ҷисми мо чун ҷон Туӣ,
 Дар ҷонҳо ҷонон Туӣ!
 //  Сурат Туӣ, маъно Туӣ,
 Исо - Худовандам Туӣ!  //
 Ту ҷисмро ҷон медиҳӣ,
 Чашму аёнро медиҳӣ.
 //  Ҷонро Ту сомон медиҳӣ,
 Исо - Худовандам Туӣ!  //

[V4]
 Ҷӯён будам ман солҳо,
 Ҳам дар замин, ҳам дар само.
 //  Чун боз кардам дидаро
 Дидам - Худовандам Туӣ!  //
 Ҳам Ҳайю ҳам Боқӣ Туӣ,
 Ҳам Соқии мардум Туӣ!
 //  Ҳам манну ҳам Нони ҳаёт,
 Исо - Худовандам Туӣ!  //

[V5]
 Зиндагии ҷовид Туӣ,
 Раҳмати бекарон Туӣ!
 //  Ташнаи файзи Ту манам,
 Исо - Худовандам Туӣ!  //
 Ошиқи бӯи Ту манам,
 Пайрави роҳи Ту манам.
 //  Ҳодию Султонам Туӣ,
 Исо - Худовандам Туӣ!  //

[V6]
 Фатҳу футӯҳи ман Туӣ,
 Киштии Нӯҳи ман Туӣ!
 //  Шуста ба хуни Ту манам,
 Исо - Худовандам Туӣ!  //
 Шодии рӯҳи ман Туӣ,
 Роҳати ҷони ман Туӣ!
 //  Кист ҳарифи меҳри Ту?
 Исо - Худовандам Туӣ!  //</lyrics>
<aka>Мусо ба фармони Ту шуд</aka>
<title>Эй Шоҳи шоҳони ҷаҳон Хд98</title>
<hymn_number>98</hymn_number>
</song>