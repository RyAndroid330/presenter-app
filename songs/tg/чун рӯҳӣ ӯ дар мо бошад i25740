 // Шунавем, шунавем шунавем монанди Самуил //

[V4]
 // Чун Рӯҳӣ ӯ дар мо бошад,
 Эътиқод монанди Аюб //
 // Эътиқод, эътиқод эътиқод монанди Аюб //

[V5]
 // Чун Рӯҳӣ ӯ дар мо бошад,
