<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>25</hymn_number>
<key>F</key>
<lyrics>[V1]
.        F                      C(F)
 //  Дар шаб кӣ назди охур омадааст?
 (Чӯпонон)  //
.    Bb
 Чӯпонон назди охур,
.    F
 Омаданд дар шаби нур
.     C                F
 Дили ҳама аз хурсандӣ пур.

[V2]
 //  Ситораро кӣ дар шарқ дидааст?
 (Маҷусон)  //
 Маҷусон диданд онро,
 Рафтанд назди Исо,
 Бо тӯҳфа парастиданд Ӯро.

[V3]
 //  Худо киро даъват мекунад?
 (Ҳамаро)  //
 Биёед назди Исо.
 Бинед Писари Худо,
 Танҳо Ӯст Наҷоткори дунё.</lyrics>
<title>Дар шаб кӣ назди охур омадааст? Ч25</title>
</song>