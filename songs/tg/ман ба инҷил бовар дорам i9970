<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>37</hymn_number>
<title>Ман ба инҷил бовар дорам</title>
<key>F#</key>
<lyrics>[V1]
.    C#
 /// Ман ба инҷил ///
.  G#    C#
 Бовар дорам

[V2]
 /// Чун, ки Худо худаш ///
 Чунин мегуяд

[V3]
 /// Ин ҳақиқат аст ///
 Барои мо</lyrics>
</song>