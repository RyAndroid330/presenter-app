<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  F#            Bbm  D#m
   Эй тозадилон, шод бошед,
.  C#        F#
   Масеҳ бо мост!
.  F#                Bbm  D#m
   Гулчанбари осмон, шод бошед,
.  C#       F#
   Худо бо мост!

[V1]
.   F#             B      F#
 // Шод бошед, чун Ӯ роҳнамост,
.    G#m       C#         F#
     Шод бошед, Ӯ наҷоти мост. //
.        G#m       C#      F#    D#m
 // Хурсанду шод бошед, хурсанду шод,
.             G#m     C#        F#
     Чун бар осмон Ӯ моро роҳнамост. //

[V2]
.   F#          B      F#
 // Шод бошед, эй покдилон,
.    G#m        C#      F#
     Шод бошед, эй мискинон, //
.        G#m    C#  F# D#m
 // Чун шумоён, чун шумоён,
.        G#m     C#          F#
     Маҳбуби Худованд шудаед шумоён. //</lyrics>
