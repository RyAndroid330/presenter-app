<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>88</hymn_number>
<lyrics>[V1]
.    Hm                 Em
 //  Дар шаби тори зулмонӣ
.F#               Hm
  Фариштагони нуронӣ
.        H7          Em
 Зоҳир шуданд ба чӯпонон:
.F#                Hm
  Шод бошед, шод бошед,
.F#                Hm
  Шод бошед, шод бошед,  //

[C1]
   Бандгардон:
.                   F#
   Зеро Наҷоткори ҷаҳон
.                     Hm
   Зоҳир шуд бар оламиён.
.                   F#
   Дар парпече печонда,
.                Hm
   Дар охуре хобида.
.                 F#
   Наҷоткори оламиён
.                   Hm
   Омад акнун ба ҷаҳон.
.                     A
   Номи Худоро ҷалол бод,
.                     G
   То абад Ӯ муборак бод.
.                    F#
   Ба диданаш бишитобед,
.                   Hm
   Шод бошед, шод бошед,
.  F#                 Hm
    Шод бошед, шод бошед.

[V2]
 //  Масеҳ Исо аз осмон
 Омада акнун ба ҷаҳон.
 Зону занед, ҳамдаш кунед,
 Шод бошед, шод бошед,
 Шод бошед, шод бошед,  //</lyrics>
<key>Bm</key>
<title>Дар шаби тори зулмонӣ Хд88</title>
</song>