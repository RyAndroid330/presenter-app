<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>751</hymn_number>
<title>Барух ха-ба</title>
<key>Cm</key>
<lyrics>[V1]
.Cm          Fm
 Барух ха-ба б'Шем Адонай
.Ab Bb Cm
 Аллелуйя,
.Cm          Fm
 Барух ха-ба б'Шем Адонай
.Ab Bb Cm
 Аллелуйя.

[C1]
.  F            Cm
   Барух ха-ба б'Шем Адонай
.  F     Cm      Ab  Bb Cm
   Барух ха-ба б'Шем Адонай
.  Ab Bb Cm
   Аллелуйя!

[V2]
.Cm           Fm
 Благославен тот кто грядет
.Ab Bb   Cm
 Во имя Господа
.Cm           Fm
 Благославен тот кто грядет
.Ab Bb  Cm
 Во имя Господа

[C2]
.  F     Cm
   Благославен
.  F              Cm
   Грядущий во имя Господа
.  F     Cm
   Благославен
.  F          Ab  Bb Cm
   Грядущий во имя Господа
.  Ab Bb Cm
   Аллелуйя!</lyrics>
<aka>Барух ха-ба б'Шем Адонай</aka>
</song>