<?xml version="1.0" encoding="UTF-8"?><song><author>Егор и Наталия Лансере</author>
<hymn_number>2063</hymn_number>
<title>Шалом</title>
<lyrics>[V1]
.   E      B     E                A
 // К праведным и сокрушенным сердцам
.E       B    E
 Милость Его вовек!
.E         B      E      A
 К ищущим благоволенья Отца -
.E       B   E
 Милость Его вовек! //

[C1]
.     E       A     E
   // Любовь Христа вовеки
.  E      A          B
   Для любящих Божий Дом!
.  E       A    E
   Небес открыты двери,
.  E       B        E
   Он нам говорит : «Шалом!» //</lyrics>
<key>E</key>
</song>