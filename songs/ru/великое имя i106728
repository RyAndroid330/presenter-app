<?xml version="1.0" encoding="UTF-8"?><song><author>Тимўтий</author>
<title>Великое имя</title>
<lyrics>[V1]
 // Я знаю одно имя.
 Величайшее из всех имен //
 // Горы, скалы Ему подчиняются.
 Ветры и гроза, и шторм тоже //

[C1]
   // Это имя
   Иисус! //
   Имя Иисус, Имя Иисус
   Великое имя, Великое имя
   Имя Иисус, Имя Иисус
   Велико Оно

[V2]
 // Я знаю одно имя.
 Величайшее из всех имен //
 // Вся душа Тому, поклоняется.
 Даже демоны склоняются //</lyrics>
</song>