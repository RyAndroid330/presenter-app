<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[C1]
.  E
   Я ИДУ ПУТЁМ ГОСПОДА,
.  A                     B
   СЕРДЦЕМ ВОЗЛЮБИЛ Я ПУТЬ ЕГО.
.  E
   Я ИДУ ПУТЁМ ГОСПОДА,
.  A                    B
   РАДОСТЬ НАПОЛНЯЕТ СЕРДЦЕ МОЁ.

[V1]
.A           B
 ОН БЛАГОСЛОВИЛ МЕНЯ,
.E           C#m
 И Я ТАК СЧАСТЛИВ,
.A              B
 СВОЕЙ РУКОЙ ПОВЁЛ МЕНЯ,
.E        C#m
 ХРИСТУ ХВАЛА!
.A                         B
 ХВАЛА ЕМУ ПУСТЬ БУДЕТ ВСЕГДА,
.E                         C#m
 ХВАЛА ЕМУ ПУСТЬ БУДЕТ ВСЕГДА,
.A             B           E
 ДА СЛАВИТ ГОСПОДА МОЯ ДУША.

[B1]
.  A                 B
   ПУСТЬ НЕ ЛЕГКИЙ ЭТОТ ПУТЬ,
.  E              C#m
   НО С БОГОМ Я ДОЙДУ,
.  A             B
   МРАК СГУЩАЕТСЯ ВОКРУГ,
.  E                 C#m
   ТЬМА ЖДЁТ, ЧТО УПАДУ,
.  A                 B
   НО РУКИ К НЕБУ ПОДНИМУ,
.  E               C#m
   СЕРДЦЕ К БОГУ ОБРАЩУ
.  A             B
   И УВИЖУ ЯРКИЙ СВЕТ,
.  E              E
   РАЗГОНЯЮЩИЙ ТЬМУ.</lyrics>
<title>Я иду путем Господа</title>
<hymn_number>6437</hymn_number>
</song>