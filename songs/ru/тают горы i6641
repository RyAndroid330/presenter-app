<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2260</hymn_number>
<author>Валерий Короп</author>
<title>Тают горы!</title>
<lyrics>[V1]
.      Am          D
 // В Твоем Святом присутствии!
.Hm7                Em
 В Твоем Святом присутствии!
.Am              Hm
 В Твоем Святом присутствии!
.     Em
 Тают горы! //

[C1]
.  Am        D
   Горы проблем, горы греха,
.  Hm7         Em
   Горы беды и неудачи!
.  Am             Hm
   В Твоем Святом присутствии
.       Em
   тают горы!

[B1]
.  Am         D
   Мне хорошо в доме Твоём!
.  Hm7          Em
   Мне хорошо с Тобой вдвоём!
.  Am         Hm
   Мне хорошо Иисус в доме Твоём!</lyrics>
<key>D</key>
<aka>В Твоем Святом присутствии</aka>
</song>