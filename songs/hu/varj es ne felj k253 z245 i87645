<?xml version="1.0" encoding="UTF-8"?><song><title>Várj és ne félj K253 Z245</title>
<key>Em</key>
<lyrics>[V1]
.Em         C        Am6    H7
 Várj és ne félj, az Úr jön már!
.Em   D     G        Am  H7  Em
 Várj és ne félj, hű szívvel várj!

[V2]
.Em           C         Am6    H7
 Wait for the Lord, His day is near.
.Em   D       G          Am     H7   Em
 Wait for the Lord: keep watch, take heart.</lyrics>
<tempo>48</tempo>
<author>J. Berthier</author>
<hymn_number>253</hymn_number>
</song>