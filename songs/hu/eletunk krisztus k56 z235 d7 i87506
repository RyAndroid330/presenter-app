<?xml version="1.0" encoding="UTF-8"?><song><author>Varga Attila</author>
<hymn_number>56</hymn_number>
<lyrics>[V1]
.G       C        D  G
 Életünk Krisztus élete,
.G          C    D      G
 életünk az Atya szeretete,
.C  D              G    H7 Em
 életünk az Egyház Szentlelke,
.Am       F            D   D7
 életünk, életünk Krisztus.

[C1]
.  G  C         D        G
   Életünk Krisztus, alleluja.
.  G  C           A          D
   Életünk el van rejtve Őbenne.
.  G  C         D        E
   Életünk Krisztus, alleluja,
.  Am D         G
   életünk Krisztus.</lyrics>
<key>G</key>
<title>Életünk Krisztus K56 Z235 D7</title>
</song>