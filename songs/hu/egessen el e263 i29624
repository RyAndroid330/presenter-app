<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>263</hymn_number>
<lyrics>[C1]
   Égessen el, égessen el
   a Te szent tüzed engem,
   égessen el!

[V1]
 Igéid tüze lelkem mélyén ég.
 Égess ki szennyet, hozd el a mennyet!

[V2]
 Akaratod tüze csontjaimban ég.
 Lángoló Szellem, eméssz meg engem!</lyrics>
<title>Égessen el E263</title>
</song>