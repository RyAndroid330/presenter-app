<?xml version="1.0" encoding="UTF-8"?><song><author>Hajnal Péter, Nagy Lajos</author>
<key>D</key>
<lyrics>[V1]
.   D               G            D
 // Titok és ajándék Jézus szent teste:
.D              G A      D
 Erő és kegyelem fehérbe rejtve! //

[C1]
.  G                   D    A              D
   Megerősít és megszentel, Betölt szeretettel,
.  A     G   A      D   A      G    D
   Békéjével áraszt el, Az Atyához emel.

[V2]
 // Titok és ajándék Jézus szent vére:
 Béke és szeretet kehelybe rejtve. //

[C2]
   Megtisztít és megszentel, Betölt kegyelemmel,
   Békéjével áraszt el, Az Atyához emel.</lyrics>
<title>Titok és ajándék</title>
</song>