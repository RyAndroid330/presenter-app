<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>27</hymn_number>
<title>Eljegyezlek magamnak E27</title>
<lyrics>[V1]
.    Hm           A       G               D
 Eljegyezlek magamnak igazsággal, szeretettel,
.    Hm          A      G               D
 eljegyezlek örökre irgalommal, kegyelemmel.

[V2]
.    G                F#m    (Hm)
 Eljegyezlek magamnak hittel,
.      G      (A)        D
 igen, hittel  jegyezlek el!
.   Hm               A
 És megismered a te Urad,
.G                D
 megismered Istenedet!</lyrics>
<key>Bm</key>
</song>