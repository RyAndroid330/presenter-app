<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>219</hymn_number>
<author>Jean-Marc Morin, Pierre Mugnier, Viviane Mugnier</author>
<title>Szentlélek, jöjj, lobogó Láng Z219 E23 K1</title>
<lyrics>[C1]
.  Em                       D
   Szentlélek, jöjj, lobogó Láng,
.  D                 Hm      Em
   Szentlélek, jöjj, a világ vár,
.  Em                        D
   Szentlélek, jöjj, viharos Szél,
.  D     Hm    Em
   jöjj, áradj szét!

[V1]
.Em                 D
 Jöjj el, élő vízforrás,
.D               Hm    Em
 jöjj, a szívünk Téged vár,
.Em                         D
 jöjj, ki fényt adsz lelkünknek,
.D         Hm     Em
 jöjj, úgy várunk Rád!

[V2]
 Jöjj, igazság forrása,
 jöjj, imádunk mindnyájan,
 jöjj, reményünk éleszd fel,
 Jöjj kegyelmeddel!

[V3]
 Jöjj, a néped gyűjtsd egybe,
 jöjj, az alvót ébreszd fel,
 jöjj, a bűntől tisztíts meg,
 bátoríts minket!</lyrics>
<key>Em</key>
</song>