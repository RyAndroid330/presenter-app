<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<presentation>C V1 C V2 C V3 C</presentation>
<lyrics>[C1]
.  Em             Hm
   Jézus vár terád, lelkét küldi hozzád,
.  C                D                  Em
   mert közel jön ő, irgalmas Üdvözítő!

[V1]
.Am          D       Hm           C
 Jöjjetek hozzá, kik szomjazzátok őt,
.Am         C                    H7
 Belsejéből élő víz forrása fakad!

[V2]
.Am          D       Hm        C
 Jöjjetek hozzá, kik megfáradtatok,
.Am          C                   H7
 Megkönnyíti Jézus nehéz terhetek!

[V3]
.Am          D      Hm     C
 Jöjjetek hozzá, ti alázatosak,
.Am            C                   H7
 Nektek akarja adni dicső országát!</lyrics>
<key>Em</key>
<title>Jézus vár terád K104 SK94</title>
</song>