<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>6</hymn_number>
<title>Az Úrnak szüksége van rád E6 K131 Z426</title>
<key>D</key>
<lyrics>[V1]
.   D                  A
 Az Úrnak szüksége van rád,
.      G                 D   A
 oly nagyon szüksége van rád.

[C1]
.  D7             G
   Fontosabb vagy te, mint az égbolt,
.                 D
   fontosabb vagy te, mint a föld,
.                 A
   fontosabb vagy te, mint a tenger,
.                     D  D7
   nagyon fontos vagy te!

[V2]
 Az Úrnak szüksége van rám...

[C2]
   Fontosabb vagyok, mint...

[V3]
 Az Úrnak szüksége van ránk...

[C3]
   Fontosabb vagyunk, mint...</lyrics>
</song>