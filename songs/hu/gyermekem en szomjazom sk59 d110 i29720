<?xml version="1.0" encoding="UTF-8"?><song><title>Gyermekem, én szomjazom SK59 D110</title>
<key>D</key>
<lyrics>[C1]
.     D             C
   // Gyermekem, én szomjazom,
.  C        G       D
   vágyom a szíved után. //

[V1]
.C             D         Em        A
 Maradj mindig énbennem, nézd szívemet!
.C             D         Em       A  A4 A
 Maradj mindig énbennem, lásd hűségem!__

[V2]
.C             D         Em     A
 Maradj mindig énbennem, békére lelsz!
.C             D         Em           A  A4 A
 Maradj mindig énbennem, igaz lesz életed!__

[V3]
 Maradj mindig énbennem, figyeld igémet!
 Maradj mindig énbennem, szeresd testvéred!

[V4]
 Ne aggódj és ne félj már, bízz énbennem!
 Felüdítem lelkedet, add át életed!</lyrics>
<presentation>C V1 C V2 C V3 C V4 C</presentation>
<hymn_number>59</hymn_number>
</song>