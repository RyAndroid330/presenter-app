<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>74</hymn_number>
<presentation>V1 V2 V3</presentation>
<title>Irgalmazz, Uram, irgalmazz SK74</title>
<key>A</key>
<lyrics>[V1]
.A          D         A
 Irgalmazz, Uram irgalmazz!
.A                 E
 Uram, irgalmazz nekem!
.A               D
 Tenger a bűnöm, jöjj, segíts,
.A             E
 erős kezeddel ments meg!
.A          E         A
 Irgalmazz, irgalmazz nekem!

[V2]
 Kegyelmezz, Krisztus kegyelmezz!
 Krisztus, kegyelmezz nekem!
 Ha bármit tettem ellened
 bocsásd meg, kérlek!
 Kegyelmezz, kegyelmezz nekem!

[V3]
 Irgalmazz, Uram irgalmazz!
 Uram, irgalmazz nekem!
 Elestem, de felállok
 és indulok Feléd!
 Irgalmazz, irgalmazz nekem!</lyrics>
</song>