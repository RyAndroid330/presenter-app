<?xml version="1.0" encoding="UTF-8"?><song><title>Kenyeret és bort</title>
<key>Bm</key>
<lyrics>[V1]
.Hm               G          D
 Kenyeret és bort hoztunk neked!
.Hm                G          D
 Szívünk melegével legyen a tied!

[C1]
.     G          D      A          Hm
   // Fogadd el, Urunk, ezt a kenyeret,
.       G           D     A  D
   hogy legyen a te szent tested! //

[V2]
 Kenyeret és bort hoztunk neked!
 Szívünk melegével legyen a tied!

[C2]
   // Fogadd el a borral ezt a kelyhet,
   hogy legyen a te szent véred! //

[V3]
 Kenyeret és bort hoztunk neked!
 Szívünk melegével legyen a tied!</lyrics>
<author>Sillye Jenő</author>
</song>