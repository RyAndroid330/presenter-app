<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>83</hymn_number>
<title>Hogy a Jézus nevére E83</title>
<key>Em</key>
<lyrics>[V1]
.                  Em                    D
 // Hogy a Jézus nevére minden térd meghajoljon
.        Cmaj7     H7                 Em
 mennyeieké, földieké és föld alatt valóké! //

[C1]
.        C            D            G              Em
   // És minden nyelv vallja, hogy Jézus Krisztus Úr
.     C         H7       Em
   az Atyaisten dicsőségére! //</lyrics>
