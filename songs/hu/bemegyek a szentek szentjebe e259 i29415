<?xml version="1.0" encoding="UTF-8"?><song><title>Bemegyek a Szentek Szentjébe E259</title>
<lyrics>[V1]
.Em                      D
 Bemegyek a Szentek Szentjébe,
.Am         D            Em
 bemegyek a Bárány vérén át.
.Em                     D
 Bemegyek, csak Téged dicsérlek,
.Am             D        Em
 bemegyek, hogy hódoljak Neked.

[C1]
.        G     D    Am    Em
   Uram, dicsérlek, dicsérlek,
.        G     D    Am    Em
   Uram, dicsérlek, dicsérlek,
.               C      D     Em
   Neved áldom, szent, szent Uram,
.               C      D     Em
   Neved áldom, szent, szent Uram!</lyrics>
<key>Em</key>
<hymn_number>259</hymn_number>
</song>