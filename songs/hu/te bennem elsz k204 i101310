<?xml version="1.0" encoding="UTF-8"?><song><title>Te bennem élsz K204</title>
<key>E</key>
<lyrics>[V1]
.   E               A
 Te bennem élsz, én benned élek
.Am           E
 Tiéd e test, tiéd e lélek,
.H7               A
 Enyém e perc, az örök élet,
.          E        H7     E    H7
 Te bennem élsz, te bennem élsz.

[V2]
.E                 A
 Mária tette, hogy tiéd lettem,
.Am             E
 Örök szándékod teljesítettem,
.H7               A
 Meghalván benned újra születtem,
.          E        H      E        H7     A    E
 Te bennem élsz, te bennem élsz, te bennem élsz.</lyrics>
<hymn_number>204</hymn_number>
<author>Dax, Dienes Valéria</author>
</song>