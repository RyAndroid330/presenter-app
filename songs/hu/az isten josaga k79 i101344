<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>79</hymn_number>
<author>Dax</author>
<title>Az Isten jósága K79</title>
<key>D</key>
<lyrics>[V1]
.D          Gm6/Bb     D   Gm6/Bb
 Drága a te kegyelmed Uram.
.D         Gmaj7/H    Em  A7
 Menedéket nálad találtam.
.   G          A        D
 // Házad javaiból jóllakom,
.       Gm6/Bb      D   Gm6/Bb
 örömöd forrását ihatom. //

[V2]
 Tenálad van az élet forrása,
 a te fényed az ember lámpása.
 // Jóságod tartsa meg,
 kik tisztelnek téged, őrizd meg! //

[C1]
.         A                    D        D7
   // Istenem, Istenem! Itt az egész életem.
.    G               A           D
   A világot is csak tebenned és veled érthetem. //
.      A                    D         Gm6/Bb Gmaj7/H Em Gm6/D D
   Istenem, Istenem! Itt az egész életem.</lyrics>
</song>