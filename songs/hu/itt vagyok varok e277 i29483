<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>277</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em           A
  Itt vagyok, várok,
.  D             G
 maradj, Uram, velem,
.Em           A        D
  itt vagyok, vágyom Reád!

[V2]
.Em         A
  Szerelmed elrejt,
.D             G
 térdre kényszerít,
.Em      A            D
  amikor köztünk megjelensz.

[C1]
.  D          G        Em      Asus4 A
    Te élj bennem, uralkodj szívemben,
.  D         G      Em        D     A   D
    hadd érezzem erődet, mely szárnyra emel!</lyrics>
<title>Itt vagyok, várok E277</title>
</song>