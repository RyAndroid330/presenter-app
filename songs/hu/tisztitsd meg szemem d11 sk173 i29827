<?xml version="1.0" encoding="UTF-8"?><song><author>Sillye Jenő</author>
<hymn_number>11</hymn_number>
<title>Tisztítsd meg szemem D11 SK173</title>
<aka>Mentsd meg a lelkem</aka>
<key>Dm</key>
<lyrics>[V1]
.Dm                               Bb     Dm
 Tisztítsd meg szemem, hogy Téged lásson!
.Dm                              Gm     Gm6 Dm
 Tisztítsd meg fülem, hogy Téged halljon!___
.   C7          F            Gm
 // Nyisd meg a szívem, hogy befogadjon! //
.C7          F
 Nyisd meg a szívem!

[V2]
.Dm                          Bb   Dm
 Vidd a lábaim, hogy Hozzád érjek!
.Dm                     Gm    Gm6 Dm
 Emeld két karom, ha átölellek!___
.   C7           F            Gm
 // Mentsd meg a lelkem, hogy Benned éljek! //
.C7           F
 Mentsd meg a lelkem!</lyrics>
</song>