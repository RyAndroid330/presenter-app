<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>110</hymn_number>
<presentation>V1 C V2 C V3 C V4 C</presentation>
<title>Mária, igaz leány SK110</title>
<key>Gm</key>
<lyrics>[C1]
.     Gm        Dm    Gm
   // Alleluja, alleluja! //

[V1]
.Gm
 Mária, igaz leány!
.Gm                   Dm      Gm
 Ne félj, nézd, Rád tekint az Úr!
.Gm
 Téged hív, hogy légy az anyja Fiának!

[V2]
.Gm
 Mária, áldott Anya,
.Gm                Dm    Gm
 Isten reád Lelkét árasztja!
.Gm
 Boldog vagy, mert hittél az Ő szavának!

[V3]
.Gm
 Mária, szent Szűzanya!
.Gm                  Dm   Gm
 Asszony nincs nálad áldottabb!
.Gm
 És áldott Jézus, akit a világra szültél.

[V4]
.Gm
 Mária, édesanya!
.Gm                    Dm    Gm
 Jézus Krisztust méhed hordozta!
.Gm
 Várva-várjuk áldott Fiadat, Jézust!</lyrics>
</song>