<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>227</hymn_number>
<author>Somogyi István</author>
<title>Uram, Tehozzád futok Z227 E30 K353 D15</title>
<key>Em</key>
<lyrics>[V1]
.      Em         D
 Uram, Tehozzád futok,
.    Hm7          Em
 élő vízre szomjazom,
.     C              D      Em
 közelséged, ó, mily jó énnekem.
.        Em           D
 Kérlek, ne menj el tőlem,
.        Hm7        Em
 légy mindig segítségem,
.      C        D        Em
 úgy kívánlak Téged, Istenem!

[C1]
.           G             D
   Én pedig szüntelen remélek,
.        Hm           Em
   egyre jobban dicsérlek,
.        C            F#ø     Hsus4 H
   ajkam beszéli a Te igazságodat.
.         G             D
   Hadd legyen most a dalom
.       Hm          Em
   jó illat oltárodon,
.         C           D        Em
   nagyon szeretlek Téged, Jézusom!

[C2]
   Befejezés:
.         C           D           C           D
   Nagyon szeretlek téged, nagyon szeretlek téged!
.         C           D        Em
   Nagyon szeretlek téged, Jézusom!</lyrics>
</song>