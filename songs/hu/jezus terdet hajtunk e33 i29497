<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>33</hymn_number>
<key>G</key>
<lyrics>[V1]
.G             Em7
 Jézus, térdet hajtunk,
.C             G
 Te vagy a Királyunk,
.Em7          Hm7
 énekünk magasba emel,
.C          Am7      D
 foglald el királyi trónod!

[V2]
.G           D/F#    Em
 Úgy várunk, jöjj, Tiéd a trón,
.C           D     G    D/F# Em7  Em/D
 úgy várunk, jöjj, Tiéd a    trón,
.C           D       H    Em
 úgy várunk, jöjj, Tiéd a trón,
.         Am7       D     G
 jöjj, Úr Jézus, Te légy Urunk!

[V3]
 Jézus, térdet hajtok,
 Te vagy a Királyom,
 énekem magasba emel,
 foglald el szívemnek trónját!

[V4]
 Úgy várlak, jöjj, Tiéd szívem,
 úgy várlak, jöjj, Tiéd szívem,
 úgy várlak, jöjj, Tiéd szívem,
 jöjj, Úr Jézus, Te légy az életem!</lyrics>
<title>Jézus, térdet hajtunk E33</title>
</song>