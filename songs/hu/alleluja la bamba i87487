<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  G                 C
   Alleluja-sabalaba labamba,
.  G                 D
   Alleluja-sabalaba labamba,
.  G                 C
   Alleluja-sabalaba labamba,
.  G     D G
   Amen, amen!

[V1]
 // Jézus meghalt, de feltámadt! //  Amen, amen!

[V2]
 // Elküldte nekünk a Szentlelket! //  Amen, amen!

[V3]
 Aki nekem szolgál, engem kövessen,
 És ahol én vagyok, ott lesz ő velem!
 Aki nekem szolgál, engem kövessen!
 Amen, amen!

[V4]
 // Szeressétek egymást, ez az új parancs! //
 Amen, amen!

[V5]
 // Örvendezzünk, gyere, te is énekelj! //
 Amen, amen!

[V6]
 Gyere, gyere, hétvégézzünk, úgy bizony!
 Hozz magaddal még egy embert minimum!
 Gyere, gyere, hétvégézzünk, úgy bizony!
 Amen, amen!</lyrics>
<key>G</key>
<title>Alleluja La Bamba</title>
<author>Sztakovics János</author>
</song>