<?xml version="1.0" encoding="UTF-8"?><song><title>Jöjj, Szentlélek, újíts meg E195</title>
<lyrics>[V1]
 Jöjj, Szentlélek, újíts meg engem,
 tölts be erőddel, töltsd be szükségem!

[V2]
 Te teszel csak teljessé, hitben járó felnőtté,
 jöjj, Szentlélek, újíts meg engem!</lyrics>
<hymn_number>195</hymn_number>
</song>