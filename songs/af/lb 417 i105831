<?xml version="1.0" encoding="UTF-8"?><song><title>LB 417</title>
<aka>JESUS, ONS EER U</aka>
<lyrics>[V1]
.  D
 Jesus, ons eer U,
.Em    G    A
 opgestane Heer.
.D             Bm F#m
 Lewensvors en koning,
.Em     A    D
 U het triomfeer!

[P1]
.  D            Em Bm
   Hoe was U verne-der,
.  Em          F#
   hoe het U gely;
.  Bm           E
   hoe is U verheerlik!
.  D       E      A
   U voer heerskappy.

[C1]
.  D
   Jesus, ons eer U,
.  Em   G     A
   opgestane Heer.
.  D             Bm
   Lewensvors en Koning,
.  Em      A    D
   U het triomfeer

[V2]
.D
 Jesus, ons eer U,
.Em   G     A
 opgestane Heer
.D          Bm  F#m
 omdat U oorwin het,
.Em       A    D
 sal ons triomfeer!

[P2]
.  D             Em Bm
   Hoe was ons gebon-de,
.  Em              F#
   hoe was ons verkneg.
.  Bm           E
   U bevry tot lewe,
.  D         E       A
   baan vir ons die weg.

[C2]
.  D
   Jesus, ons eer U,
.  Em    G    A
   opgestane Heer,
.  D              Bm
   nou het ons 'n toekoms:
.  Em   A       D
   lewe by ons Heer!</lyrics>
<key>D</key>
</song>