<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C                            G   C
 Lofsing die Heer, buig voor Hom neer;
.   F       G      C
 bewys aan Hom die eer.
.      C
 Laat elke mond Hom loof en prys
.   C
 en Hom erken as Heer
.    G
 en Hom erken as Heer
.    C       F     C  G   C
 en Hom, ja Hom erken as Heer.

[V2]
.C                        G   C
 Lof aan die Heer, verheerlik Hom;
.      F        G      C
 wees vrolik, juig en sing.
.C
 Laat al wat leef Hom dank en prys,
.C
 aan Hom die hulde bring,
.     G
 aan Hom die hulde bring,
.     C       F       C  G   C
 aan Hom, aan Hom die hulde bring.

[V3]
. C                       G   C
 Lofprys die Heer, besing sy Naam -
.    F     G       C
 sy hele skepping juig.
.      C
 Laat almal saam Hom eer betoon
.     C
 en voor hul koning buig,
.    G
 en voor hul koning buig,
.    C.        F      C  G    C
 en voor, ja voor hul koning buig.</lyrics>
<aka>LB 201</aka>
<title>Lofsing die Heer, buig voor Hom neer</title>
</song>