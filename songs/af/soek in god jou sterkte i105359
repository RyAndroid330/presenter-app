<?xml version="1.0" encoding="UTF-8"?><song><title>Soek in God jou sterkte</title>
<aka>LB 513</aka>
<lyrics>[V1]
. C               G
 Soek in God jou sterkte;
.Gsus            C
 kry by Hom jou krag;
.            Am  G
 met sy wapenrusting
.D7               G
 klee Hy ons met mag.

[P1]
.  G7            C
   Nie teen medemense
.                  F
   is ons worstelstryd,
.                    F
   maar ons veg teen Satan
.          Dm         G
   en sy sluwe listigheid.

[C1]
.  C              G
   Hy stuur bose magte
.                C
   in die wêreld in,
.               G   C
   maar met God se wapens
.  Dm       G      C
   kan ons hul oorwin.

[V2]
.C                 G
 Waarheid en Gods vryspraak
.G7              C
 hou ons op ons pos,
.                   Am   G
 dan klink bly die boodskap
.D7               G
 dat die Heer verlos.

[P2]
.                  C
   Ons geloofsvertroue
.                   F
   is 'n skild wat keer -
.                   F
   daarmee kan ons elke brandpyl
.  Dm            G / G7
   van die Bose weer.

[C2]
.  C               G
   Ons bly van verlossing
.  G7           C
   altyddeur bewus
.              G   C
   en met God se swaard,
.      Dm      G    C
   sy woorde, toegerus.

[V3]
.C               G
 Doen dit alles biddend,
.G7                 C
 soos die Gees ons lei.
.                Am  G
 Laat ons altyd waaksaam
.D7         G
 en gelowig bly!

[P3]
.  G7            C
   Almal wat bly volhou,
.  C               F
   saam bly bid en werk
.                 F
   deel in die geheim van
.         Dm            G
   God se koninkryk en kerk.

[C3]
.  C               G
   Hy maak ons vrymoedig,
.   G7             C
   swakkes gee Hy krag -
.           G   C
   met sy wapenrusting
.  Dm       G       C
   klee Hy ons met mag!</lyrics>
<key>C</key>
</song>