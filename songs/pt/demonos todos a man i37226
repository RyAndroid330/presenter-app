<?xml version="1.0" encoding="UTF-8"?><song><presentation>C V1 C V2 C</presentation>
<lyrics>[C1]
   ¡Démonos todos a man!,
   ¡Démonos todos a man!;
   Irmáns, irmáns,
   ¡Démonos todos aman!

[V1]
 Unha man para-o camiño,
 Unha man para-axudar,
 Unha man para quen chora,
 Unha man para perdoar.

[V2]
 Unha man para-o cansado,
 Unha man para soster,
 Unha man para quen chega,
 Unha man para querer.</lyrics>
<title>Demonos todos a man</title>
</song>