<?xml version="1.0" encoding="UTF-8"?><song><title>Hosana nas alturas</title>
<aka>Te exaltamos Senhor</aka>
<lyrics>[V1]
 Hosana, Hosana, Hosana nas alturas!
 Hosana, Hosana, Hosana nas alturas!
 Te exaltamos, Senhor,
 com coração de louvor,
 Sê exaltado, Deus meu,
 Hosana nas alturas!</lyrics>
<author>Carl Tuttle</author>
</song>