<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Am                 Dm
 خۇدا ھوزۇرىغا كېلەيلۇق
.Am                Dm
 شات۔خورامغا چۆمەيلۇق.
.   Am          Bb
 // رەببىمىزنىڭ الدىدا
.Gm           Am
 ەركىن ئازادە وينايلۇق. //

[C1]
.     C
   // ئەيسا ئاسمانغا يول ئاچتى
.  E7         Am
   قەلبىمىزگە نۇر چاچتى. //
.     Am        Dm
   // ھاياتىمىز خۇرسەنلىك،
.  E7        Am
   دىلىمىز بەخىت قۇچتى. //

[C2]
.     C
   // رەببىم ساڭا تەشەككۈر
.  E7         Am
   ېيتىمىز دايىم شۈكۈر. //
.     Am          Dm
   // ئەيسا نامىڭ تارقالسۇن
.  E7           Am
   اسمانۇ يەرگە مەشھۈر. //</lyrics>
<key>Am</key>
<title>دىلىمىز بەخىت قۇچتى И51 Мн76</title>
<author>قۇددۇس ئاكا</author>
<hymn_number>51</hymn_number>
</song>