<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>157</hymn_number>
<author>ئەيسا جامائەت</author>
<title>نىجاتكارىم، پەرۋەردىگارىم Мн157</title>
<lyrics>[V1]
.   Dm          Gm
 // نىجاتكارىم، پەرۋەردىگارىم
.Dm                 Gm
 قۇتقازغۇچۇم، يورۇق يۋلتۇزۇم.
.   C             F
 سەندۇر بەخىت، سەندۇر ئۆمۈر،
.    Gm             A
 يۈرىگىمنىڭ سەن نۇرىسەن. //

[C1]
.     Gm            B    F
   // ئەركىندۇرمەن، اتا، سېنىڭ بىلەن،
.  Gm            A  Dm
   ازات بولدى جېنىم روھىڭ بىلەن.
.  Gm          A         Dm/B
   سېنىڭ يولۇڭ بىلەن يۈرىمەن،
.  Gm          A           Dm
   باشقۇر مېنى ۆزەڭ، روھىڭ بىلەن. //

[V2]
.   Dm           Gm
 // ئىززىتىمسەن، سۆيگۈنىمسەن،
.Dm               Gm
 ھەمكارىمسەن، پادىشاھىمسەن.
.C                   F
 سەندۇر ۔ خۇدا، ياراتقۇچىمسەن،
.      Gm              A
 پۈتۈن قەلبىمنىڭ ئېگىسىسەن. //</lyrics>
<key>F</key>
</song>