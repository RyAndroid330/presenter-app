<?xml version="1.0" encoding="UTF-8"?><song><title>قەلبىمنى خۇدا! Мн113</title>
<key>Am</key>
<lyrics>[V1]
.   C          Dm
 // قەلبىمنى خۇدا
.G           C
 ھەققانىي قىلغىن.
.Am          Dm
 ۆزگەرتكىن مېنى
.G           C
 ھەققانىي بولاي. //

[C1]
.  E7        Am
   سەن ئۇستازىمسەن
.  G           C
   مەن شاگىرتىڭمەن.
.  E7       Am
   ھەر كۈنى ساڭا
.  D          G
   ىبادەت قىلىمەن.</lyrics>
<hymn_number>113</hymn_number>
<author>ِددِِ ِسپِنُسَ</author>
</song>