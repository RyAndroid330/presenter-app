<?xml version="1.0" encoding="UTF-8"?><song><title>غولىيات جەڭگە چىقسا М124 И50 Мн74</title>
<lyrics>[V1]
.   Am
 // غولىيات جەڭگە چىقسا
.      Dm      Em     Am
 داۋۇت ۇنىڭدىن قورقمايدۇ. //
.   C          Am
 //  خۇدانىڭ نامى بىلەن ئۇنى
.        Dm          Em  Am
 بىر تال تاش بىلەنلا يېڭىدۇ. //

[V2]
 // شەيتان قارشى چىقسا
 بىزلەر ئۇنىڭدىن قورقمايمىز. //
 // ئەيسانىڭ نامى بىلەن ئۇنى
 پەقەت سۆز بىلەنلا قوغلايمىز. //

[V3]
 غولىيات جەڭگە چىقسا
 داۋۇت ئۇنىڭدىن قورقمايدۇ.
 شەيتان قارشى چىقسا
 بىزلەر ئۇنىڭدىن قورقمايمىز.
 // ئەيسانىڭ نامى بىلەن ئۇنى
 پەقەت سۆز بىلەنلا قوغلايمىز. //</lyrics>
<key>C</key>
<aka>خۇدانىڭ نامى بىلەن</aka>
<hymn_number>124</hymn_number>
<author>ھەمرا ئاكا</author>
</song>