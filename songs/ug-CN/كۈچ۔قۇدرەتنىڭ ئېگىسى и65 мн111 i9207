<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em            B
 // ئەڭ كىچىكتىن بىر ئەۋلات
 ئەڭ ئاجىزىڭدىن
.Am            Em
 كۈچلۈك خەلىق كېلىپ چىقار
.B             Em
 دېگەندىڭ رەببىم. //

[C1]
.     G             Am
   // ساڭا شۆھرەت ساڭا ھۆرمەت
.    Em         B
   قىلغان ۋەدەڭگە
.  Am          Em
   قۇدرىتىڭنى كۆرسەتكەيسەن
.  B            Em
   بۈگۈن بىزلەردە. //

[V2]
 // بۇ ئىشلارنى تېزلىتىپ
 ئىلگىرى سۈرۈپ
 ئۆز ۋاقتىدا ئورۇنلايمەن
 دېگەن سۆزۈڭدە. //</lyrics>
<aka>ئەڭ كىچىكتىن بىر ئەۋلات</aka>
<title>كۈچ۔قۇدرەتنىڭ ئېگىسى И65 Мн111</title>
<author>قۇددۇس ئاكا, يەشايا 60:22</author>
