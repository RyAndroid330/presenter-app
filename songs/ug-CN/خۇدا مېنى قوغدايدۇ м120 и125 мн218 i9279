<hymn_number>120</hymn_number>
<title>خۇدا مېنى قوغدايدۇ М120 И125 Мн218</title>
<key>C</key>
<lyrics>[C1]
.     Am
   // نەدىن كېلەر، ياردەم دەپ
.  G            Am
   مەن تاغلارغا قارايمەن
.  Am            Dm
   ياردەم كېلەر خۇدادىن
.  E           Am
   اسمان يەرنى ياراتقان. //

[V1]
.   Am
 // بەخىتسىز بولۇشۇمغا
.F            Am
 خۇدا ھېچ يول قويمايدۇ //
.   Am         Dm
 // قوغدىغۇچىم سەگەك بولۇپ
.E          Am
 ۇنى غەپلەت باسمايدۇ. //

[V2]
.   Am
 // خۇدا مېنى قوغدايدۇ
.F            Am
 اپتاپتىن ھەم ساقلايدۇ //
.    Am          Dm
 // كۈندۈزى كۈن، كېچىسى ئاي
.E           Am
 ماڭا زىيان قىلمايدۇ //

[V3]
.   Am
 // قەيەرلەردە يۈرسەممۇ
.F          Am
 خۇدا مەڭگۈ قوغدايدۇ //
.     Am        Dm
 // يامانلىقتىن قۇتقۇزۇپ
.E         Am
 ھاياتىمنى ساقلايدۇ. //</lyrics>
</song>