<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>127</hymn_number>
<author>نۇرىك ئاكا</author>
<title>مەن گۇناھكار Мн127</title>
<key>G</key>
<lyrics>[V1]
.   Em          D
 // ئۆزەمگە قارىسام
.C              D
 شۇنچىلىك ئۇيۋلىمەن
.Em              D
 مەن سېنىڭ ئالدىڭدا
.C       D      Em
 ۆزەم تۇرالمايمەن //

[C1]
.  G       D    Am       G
   ئەي خۇدايىم، مەن گۇناھكار،
.  G       D  Am    D
   ماڭا رەھىم قىلغايسەن.
.  G           D  Am      Em
   چۈشكەن روھۇمنى سەن كۆتىرىپ
.       C     D        Em
   ھاياتلىققا تۇرغۇزغايسەن.

[B1]
.  Em
   رەببىم مېنىڭدە
.  Em          G
   رەببىم مېنىڭدە
.  Em          D
   رەببىم مېنىڭدە
.             Bm
   تەخت قۇرغايسەن.
.  Em
   رەببىم مېنىڭدە
.  Em          G
   رەببىم مېنىڭدە
.          D
   رەببىم مېنى
.  Bm       Em
   تۇرغۇزغايسەن.</lyrics>
</song>