<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>220</hymn_number>
<author>شەرگىيە</author>
<title>خۇدانىڭ ئوغلى Мн220 И131</title>
<lyrics>[V1]
.     Am                        G
 // خۇدانىڭ ئوغلى ۔ ئەيسا مەسىخ،
.  F           G         Am
 ئۇ قۇتقۇزغۇچى ۔ ئۇ رەبدۇر.
.       Am               G
 ئۇ مۇھەببەت ۋە ئۇ ھايات،
.  F        G         Am
 شان۔شەرەپلەر ساڭا رەببىم. //

[C1]
.         Am                         G
   // مەدھىيەم ساڭا، شان۔شۆھرەت ساڭا،
.   F                    G Am
   سۆيىمەن سېنى مەن رەببىم.
.      Am                  G
   مىنەندارمەن مۇقەددەس رەببىم،
.    F                  G     Am
   سېنىڭ مۇھەببىتىڭ ئۈچۈن. //

[V2]
 // ئەيسا مەسىھ رەبلەر رەببى،
 شاھلار شاھى نىجاتكارىم
 نامىڭ ئۇلۇغ ۋە مۇقەددەستۇر
 ھەم ھۆرمەتلەر ساڭا رەببىم! //</lyrics>
<key>C</key>
</song>