<?xml version="1.0" encoding="UTF-8"?><song><author>قۇددۇس ئاكا</author>
<hymn_number>30</hymn_number>
<key>Am</key>
<lyrics>[V1]
.Am
 ئەي ئادەملەر، ئويغىنىڭلار،
.Dm                 Am
 خۇش۔خەۋەرنى ئاڭلاپ قېلىڭلار.
.   Dm                    Am
 // بىزلەر ئۈچۈن قۇربان بولغان
.E                  Am
 رەب ئەيسانى مەدھىيىلەڭلار. //

[C1]
.  Dm             Am
   كۆيۈمچان مەدەتكارىم،
.  Am    E         Am
   پانايىمسەن جان سۆيەر.
.     Dm                 Am
   // مەڭگۈلۈككە ھايات بەرگەن
.  Am    E        Am
   قۇتقازغۇچى مەسىھسەن. //

[V2]
 ئەي ئادەملەر، ئويغىنىڭلار،
 ھەقىقەتنى بىلىپ قېلىڭلار.
 // مەسىھ بىلەن بىرگە بولۇپ،
 تەشنالىققا پېتىپ قېلىڭلار. //</lyrics>
<title>ئەي ئادەملەر ئويغىنىڭلار М30 И9 Мн13</title>
</song>