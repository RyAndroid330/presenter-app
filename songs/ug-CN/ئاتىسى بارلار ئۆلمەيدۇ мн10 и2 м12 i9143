<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   C
 // ئاتىسى بارلار ئۆلمەيدۇ،
.                 Dm
 ئاتىسى بارلار ياشايدۇ.
.                G
 مېنىڭ ئاتام بىر خۇدا،
.                C
 روھۇم مەڭگۈ ياشايدۇ. (2ق) //

[C1]
   قايتارمىسى:
.  C                Am
   مېنىڭ ئۇيغۇر خەلقىمنىڭ
.  F     G       C
   اتىسى خۇدا بولغاي.
.  Am               Dm
   اتىسى بارلار ئۆلمەيدۇ
.  G              C
   ۇيغۇرۇم ئامان بولغاي.

[V2]
.                      C
 // كەلگىن ئۇيغۇرۇم، كەلگىن
.                  Dm
 قۇللۇقتىن ئازاد بولغىن.
.                   G
 ئەيسا رەبنى رەببىم دەپ
.               C
 ئۆلمىگىن ھايات بولغىن.(2ق) //</lyrics>
<key>C</key>
<title>ئاتىسى بارلار ئۆلمەيدۇ Мн10 И2 М12</title>
