<hymn_number>67</hymn_number>
<key>Am</key>
<lyrics>[V1]
.   Am7
 // شۈكرى دېمەسمەن دۇنىيا
.Dm
 گۇناغا پاتقان دۇنىيا
.E7
 دۇنىيا، ئېزىققان دۇنىيا
.           Am
 توۋا قىل، قۇتۇل دۇنىيا. //

[C1]
.     Am
   // كەلمەس ئىدى رەببىمىز
.  Dm
   سېنى مېنى سۆيمىسە
.  E7
   ۆلمەس ئىدى رەببىمىز
.              Am
   بۇ دۇنىياغا كۆيمىسە. //

[V2]
 // ئەيسا كەلسە دۇنىياغا
 دۇنىيا رەبنى تونىمىدى
 ئېزىققانلار شەيتانغا
 رەبنى دارغا مىقلىدى. //

[V3]
 // ئەيسا بىزنى سۆيىدۇ
 ئەيسا بىزگە كۆيىدۇ
 قۇتۇل دۇنىيا، قۇتۇل دۇنىيا
 ئەيسا قايتىپ كېلىدۇ. //</lyrics>
<title>قۇتۇل دۇنىيا М67 И64 Мн117</title>
</song>