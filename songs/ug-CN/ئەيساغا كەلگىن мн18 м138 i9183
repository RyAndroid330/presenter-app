<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>18</hymn_number>
<author>قۇددۇس ئاكا</author>
<lyrics>[V1]
.Am
 ئەيسانىڭ يولى تار يولدۇر
.Dm
 ھەقىقەت يولدۇر.
.E
 جەنەتكە ئاپىرىدىغان
.Am
 ەڭ توغرا يولدۇر.

[C1]
   // كىم ئىشەنسە ئەيساغا
   قەلبى پاك بولۇر.
   گۇناھلىرى كەچۈرۈلۈپ
   مۇقەددەس بولۇر. //

[V2]
 ئەيساغا ئەگەشكەنلەر
 بەخىتلىك بولۇر.
 يامانلىقلار ئۈستىدىن
 غالىبىيەت قازىنار.

[V3]
 ئەگەر بىلسەڭ، ئەي ئىنسان،
 ئەيساغا كەلگىن.
 خۇدا بىلەن يارىشىپ
 مەڭگۈ ياشىقىن.</lyrics>
<key>Am</key>
<title>ئەيساغا كەلگىن Мн18 М138</title>
</song>