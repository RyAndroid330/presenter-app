<?xml version="1.0" encoding="UTF-8"?><song><title>خۇدانىڭ ئىجادىتى Мн219</title>
<lyrics>[V1]
 // ياراتتىڭ ئەي خۇدا
 بىزنى ئۆزەڭگە ئوخشاش //
 // بەخىتلىك بىز ھەر دايىم
 رەببىمىز يار بولغاچ //

[V2]
 // ئايلىناركەن يەر شارى
 قۇدرەتلىك قولۇڭدا
 مەدەتكار بول ئەي رەببىم
 خەتەر كۆپتۇر يولۇمدا //

[V3]
 // كېچە كۈندۈز ئايلىنار
 رەت تەرتىبىمنى تاشلىماي //
 // مەدەت بەرگىن رەب ئەيسا
 ئاي قۇياشتەك نۇر چاچار //
 ئاي قۇياشتەك نۇر چاچار</lyrics>
<hymn_number>219</hymn_number>
</song>