<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26</hymn_number>
<author>ھەمرا ئاكا</author>
<lyrics>[V1]
.Am
 كېلىڭلار مەسىھىي جامائەت،
.        E
 ئەسلەيلى رەبنى.
.Dm
 ياد ئېتىپ دەرقەمدە
.E               Am E
 ەسلەيلى رەببىمىزنى.

[V2]
.Am
 چۈنكى ئۇ بىز ئۈچۈن ئۆزىنى
.       E
 ئەيلىدى قۇربان.
. Dm               E
 بىز ئۈچۈن ئۆلدى ۋە تىرىلدى
.        Am  E
 مەڭگۈ ھايات.

[C1]
.  Dm           Am
   ياد ئېتەيلى، قېرىنداشلار،
.  Dm     E         Am
   ەيسانىڭ مۇقەددەس قېنىنى.
.  Dm          Am
   ياد ئېتەيلى قېرىنداشلار
.  Dm       E        Am
   مەسىھنىڭ مۇقەددەس تېنىنى

[C2]
.  Dm          Am
   قەدىرلەيلى، قېرىنداشلار
.  Dm      E         Am
   قوزىنىڭ قۇرۋانلىق قېنىنى
.  Dm          Am
   قەدىرلەيلى، قېرىنداشلار،
.  Dm      E         Am
   قوزىنىڭ قۇرۋانلىق تېنىنى.</lyrics>
<key>Am</key>
<title>ئەسلەيلى رەبنى М26 И16 Мн52</title>
</song>