<?xml version="1.0" encoding="UTF-8"?><song><title>زۇلمەتنى يورۇتقۇچى И54 Мн86</title>
<lyrics>[V1]
.A               Cm#
 كەلدىڭ ئەيسا بۇ دۇنىياغا
.Bm              E
 زۇلمەتنى يورۇتۇشقا
.A            Cm#
 جېنىڭنى پىدا ەيلەپ
.Bm              E
 گۇنانى يوق قىلىشقا!

[C1]
.  A       Cm#
   ئاپىرىن ساڭا ۔ ئەيسا
.  Bm              E
   خۇدانىڭ پاك قوزىسى
.  A        Cm#
   تەشەككۈر ساڭا ۔ ئەيسا
.  Bm              E
   زۇلمەتنى يورۇتقۇچى!
   يورۇتقۇچى!

[V2]
.A           Cm#
 ئەيسا سەن يورۇق يۋلتۇز
.Bm              E
 ەيسا سەن پارلاق نۇر
.A          Cm#
 يورۇسۇن شۇ نۇرىڭدا
.Bm              E
 اسمانۇ ۋە يەر۔جاھان!</lyrics>
<key>A</key>
<hymn_number>54</hymn_number>
<author>قۇددۇس ئاكا</author>
</song>