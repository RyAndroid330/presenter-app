<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>195</hymn_number>
<author>ھەمرا ئاكا</author>
<lyrics>[V1]
.   Am   (Dm/A) Am        C
 // سېنىڭ نامىڭ مەن ئۈچۈن ەزىزدۇر،
.Am  (Dm/A)  E7
 مۇقەددەس رەببىم!
.Am   (Dm/A)          G
 سېنىڭ نامىڭ ماختاشقا ەرزىيدۇ،
.Dm   E7    Am   C   E7
 مۇقەددەس رەببىم! //

[C1]
.     E7
   // رەببىم ئەيسا ۔ ساڭا ھەمدۇسانا!
.  Am/E
   رەببىم ئەيسا ۔ ساڭا تەسسەننا، ئاپىرىن!
.  E7
   رەببىم ئەيسا، ساڭا ھەمدۇسانا!
.  Am
   شان۔شەرەپ! (2ق) //</lyrics>
<key>C</key>
<title>سېنىڭ نامىڭ مەن ئۈچۈن ئەزىزدۇر Мн195</title>
</song>