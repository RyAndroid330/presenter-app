<?xml version="1.0" encoding="UTF-8"?><song><title>دۇئا Мн78</title>
<lyrics>[V1]
 // ئەي ئاسماندىكى ئاتىمىز
 مۇقەددەس بولغاي سېنىڭ نامىڭ //
 // پۈتۈن ئەلگە تارقالسۇن رەببىم
 سېنىڭ ئۇلۇغ شەرەپ۔شانىڭ //
 پۈتۈن ئەلگە تارقالسۇن رەببىم
 سېنىڭ ئۇلۇغ شەرەپ۔شانىڭ

[V2]
 // رەببىم ئەيسا ئۇلۇغدۇر نامىڭ
 بىزلەر ئۈچۈن تۆكۈلدى قېنىڭ //
 شۇندىن بېرى مەنسۈپ مەن ساڭا
 مېنىڭ بۇ تېنىم
 شۇندىن بېرى مەنسۈپ ساڭا
 مېنىڭ بۇ تېنىم

[V3]
 ئىشلەت مېنى خالايمەن
 خىزمەت قىلىشنى
 سېنىڭ ئۈچۈن رىيازەت چېكىپ
 قۇربان بېرىشنى
 ئۇلۇغ خۇدا پاك بولۇشنى
 خالايمەن دايىم
 ناپاك ياشاش ئەمەس
 مېنىڭ ئۆمۈرلۈك غايەم
 مېنىڭ ئۆمۈرلۈك غايەم
 ئۆمۈرلۈك غايەم</lyrics>
<hymn_number>78</hymn_number>
</song>