<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>78</hymn_number>
<author>ئالمابۇۋى</author>
<title>مەڭگۈ ھايات М78 И81 Мн132</title>
<key>G</key>
<lyrics>[V1]
.   Em
 // ئاسماندىكى ئاتامدىن
.D           Em
 بىزگە كەلدى ساداقەت //
.   Em          Am
 // گۇناھلاردىن ازات قىلىپ
.D           Em
 ھايات بەردى تاەبەت //

[C1]
.     Em    Am    D      G    Em
   // مەڭگۈ ھايات، مەڭگۈ ھايات
.            Am       D
   تەغدىم قىلدى بىزگە اتام
.          Em
   مەڭگۈ ھايات //

[V2]
 // مېھرىبانلىقىڭ چەكسىز
 ئۇنتۇمايمىز مەڭگۈگە //
 // ئېغىر ھايات يولۇمنى
 ئازاد قىلدىڭ مەڭگۈگە //

[V3]
 // مۇقەددەس روھىڭ ئۇلۇغ
 قايغۇ كەلسە بېشىمغا //
 // نىجاتكارىمىز ئەيسا
 دايىم بىللە قېشىمدا //</lyrics>
</song>