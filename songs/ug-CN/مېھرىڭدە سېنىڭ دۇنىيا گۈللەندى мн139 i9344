<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   Gm              C
 // مېھرىڭدە سېنىڭ دۇنىيا گۈللەندى
.F                      B
 مېھرىڭدە سېنىڭ ھاياتىم ۆزگەردى
.Gm                     A
 مېھرىڭ سېنىڭ گۇناھدىن قۇتقازدى
.    B       A       Dm
 ئىلتىجا قىلدىم ھوزۇرىڭنى //

[C1]
.         Gm     C       Am   Dm
   // سەن قۇتقازدىڭ ھەم پاكلىدىڭ،
.  Gm       Am       Dm
   ازات قىلدىڭ گۇناھدىن. //

[B1]
.     Gm       Dm
   // تەشەككۈر ساڭا! //</lyrics>
<aka>ھاياتىم ئۆزگەردى</aka>
<title>مېھرىڭدە سېنىڭ دۇنىيا گۈللەندى Мн139</title>
<hymn_number>139</hymn_number>
<author>سېرگېي دانىلьچېنكو (سېرژ دانى)</author>
</song>