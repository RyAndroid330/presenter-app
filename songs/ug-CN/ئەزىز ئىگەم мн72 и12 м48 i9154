<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>72</hymn_number>
<author>ھېمىدەم ھەدە, قۇددۇس ئاكا</author>
<title>ئەزىز ئىگەم Мн72 И12 М48</title>
<aka>گۈل بوستاندىن</aka>
<key>Am</key>
<lyrics>[V1]
.   Am
 // گۈل بوستاندىن قەلبىمدە ماكان قۇردۇڭ سەن
.G                         C      E7
 اجىز بەندەڭ خۇرسەن بولدۇم اندىن مەن. //
.   Dm                     Am
 // ئەزىز ئىگەم سېنىڭ ئاتا مېھرىڭنى
.E                         Am   A7        Am
 سۆز يەتكۈزۈپ ئېيتالمايمەن ھەرگىز مەن. //

[V2]
 // باغۇ۔بوستان خۇش پۇراقتۇر ھوزۇرۇڭ
 يېقىملىقتۇر مەدەت بېرەر ئاۋازىڭ. //
 // مۇقەددەستۇر، ھېكىمەتتۇر سۆزلىرىڭ
 گويا چەكسىز مېھرىباندۇر كۆزلىرىڭ. //

[V3]
 // ئەزىز ئىگەم سېنىڭ چەكسىز قەلبىڭنى
 بۇ دۇنىيادا كىملەر بىلۇر مېھرىڭنى. //
 // سەن تاللىغان بەندەڭ بىلۇر رەھمىڭنى
 مۇقەددەسلىك سېنىڭ ئەيسا سۆيگۈڭنى. //</lyrics>
</song>