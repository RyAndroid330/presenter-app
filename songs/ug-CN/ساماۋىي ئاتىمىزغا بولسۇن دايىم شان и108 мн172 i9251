<?xml version="1.0" encoding="UTF-8"?><song><title>ساماۋىي ئاتىمىزغا بولسۇن دايىم شان И108 Мн172</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 // ساماۋىي ئاتىمىزغا
.Сmaj7
 بولسۇن دايىم شان
.F#
 ۇنىڭ مېھرىبانلىقى
. B7       Em
 بىزگە بېپايان. //

[C1]
.  G            F
   شان۔شەرەپلەر رەببمىزگە
.  C         D   C
   شان۔شەرەپ خۇداغا
.  G          F
   مۇقەددەس روھۇڭ بىزلەرگە
.  C             B7
   يار بولسۇن، ئامىن!

[V2]
 // نىجاتكارىم ساڭا
 ھەم بولسۇن دايىم شان
 پەقەت سەندە نىجات تاپتى
 گۇناھكار ئىنسان. //

[V3]
 // مۇقەددەس روھ ھەم ساڭا
 بولسۇن دايىم شان
 ئېغىر ھايات يولۇمىزنى
 قىلىسەن ئاسان! //</lyrics>
