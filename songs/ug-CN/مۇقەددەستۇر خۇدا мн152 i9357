<?xml version="1.0" encoding="UTF-8"?><song><author>جِسُس كُلتُرِ</author>
<hymn_number>152</hymn_number>
<lyrics>[V1]
.   Dm                     Gm
 // يالغۇز ئاۋاز ياڭرار مەندە!
.         F             A Asus
 ئېيتار ناخشام، پەقەت ساڭا! //

[C1]
.     Dm        Gm
   //  مۇقەددەس! مۇقەددەس!
.  F        A     Asus
    مۇقەددەستۇر خۇدا!
.  Dm        Gm
    مۇقەددەس! مۇقەددەس!
.  F        A     Asus
    پەرۋەردىگار خۇدا! //

[B1]
.     Dm          Gm             F         A Asus
   //  ساڭا تەڭداش يوقتۇر، ئەي خۇدا! پاك خۇدا!
.  Dm        Gm             F        A Asus
    چۇنكى مۇقەددەستۇر سەن خۇدا! پاك خۇدا! //</lyrics>
<key>Dm</key>
<title>مۇقەددەستۇر خۇدا! Мн152</title>
</song>