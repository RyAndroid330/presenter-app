<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 تۇغۇلدۇڭ ئەيسا رەب
 بولسۇن مۇبارەك
 تۇغۇلدۇڭ ئەيسا رەب
 بولسۇن مۇبارەك
 كۈيلەيمىز نامىڭنى
 تۇغۇلغان كۈنىڭگە
 بولسۇن مۇبارەك

[V2]
 // ئەيسا دېگەن نامىڭغا
 بولسۇن شان۔شەرەپ
 ئۇلۇغلۇق ساڭىلا
 مەنسۈپتۇر ئەبەد //

[V3]
 // ناخشا ئېيتىپ، ئۇسسۇل ئويناپ
 كۈيلەيمىز سېنى
 تۇغۇلغان كۈنىڭگە
 بولسۇن مۇبارەك //

[V4]
 // تۇغۇلغان كۈنىڭگە
 بولسۇن مۇبارەك //</lyrics>
