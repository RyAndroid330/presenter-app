<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<key>G</key>
<lyrics>[V1]
.   G
 //  بىز كەلدۇق مانا،
.      D          G
 ئىسمىڭنى ماختاشقا!
.          C                  D
 سەن ۔ رەب، يەر۔يۈزى ۋە ئاسماندا!
.     G              D        Em
 ناخشىمىز ساڭا، مەدھىيىەلەر ساڭا،
.          C           D      G
 سەن ۔ رەب، يەر۔يۈزى ۋە ئاسماندا! //

[C1]
.     G               Em
   //  قوللىرىمىزنى كۆتىرىپ،
.         C            D
   مەدھىيىلەيمىز بىز سېنى!
.          G               Em
   سەن ۔ مۇقەددەم، سەن ۔ خاتىمە،
.        C         D
   يەر۔يۈزىنىڭ خۇدايى! (2ق) //
.               C        D         G/Em
   // سەن ۔ رەب، يەر۔يۈزى ۋە ئاسماندا! //</lyrics>
<title>بىز كەلدۇق مانا Мн59</title>
</song>