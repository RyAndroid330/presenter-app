<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D      A           Bm
 // سىز خۇدانىڭ بەرگەن سوغىسى
.    G                  A
 رەببىم سىزنى بەرىكەتلىسۇن.
.D        A         Bm
 سىز ئارقىلىق ئۇيغۇرلار قۇتۇلسۇن
. G    A           D
 رەببىمىز ئۇلۇغلانسۇن. //

[V2]
 // خۇدايىمىز كۆيۈمچان ئاتىمىز
 ھازىر بىزنىڭ ئارىمىزدا، (ئارىمىزدا)!
 ئۇنىڭ مۇقەددەس روھى ئارقىلىق
 قېرىندىشىم دەيمەن سىزنى. //</lyrics>
<title>سىز خۇدانىڭ بەرگەن سوغىسى Мн196 М111</title>
<hymn_number>196</hymn_number>
</song>