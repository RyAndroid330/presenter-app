<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ئۇلۇغ خۇدا كۈيلەيمەن سېنى
 قۇدرىتىڭ بىلەن ياراتتىڭ مېنى
 // ساڭىلا مەنسۈپ ھەمدۇسانالەر
 ئىلتىجا قىلىپ قىلغان دۇالار //

[V2]
 گۇناھىم كۆپتۇر كەچۈرگىن خۇدا
 ئىللىق مېھرىڭدىن قىلمىقىن جۇدا
 // كۆرسەتكىن ماڭا توغرا يولۇڭنى
 قۇتقۇزغىن مەندەك ئاجىز قۇللۇڭنى //

[V3]
 ساقلىقىن مېنى رەزىل شەيتاندىن
 زۇلمەت قاراڭغۇ مۈشكۈل زىنداندىن
 ئېرىشتۈر مېنى مېھرى۔شەپقەتكە
 // نايىل قىل مېنى ئەھلى جەننەتكە //</lyrics>
<title>كۈيلەيمەن سېنى Мн110</title>
<hymn_number>110</hymn_number>
</song>