<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm
 // خۇدايىم ئۇلۇغتۇر،
.Bb
 خۇدا مېھرىباندۇر،
.Gm           A7  Dm/A7
 خۇدا تامامەن ادىلدۇر،
.Dm                  Gm       A7
 خۇدا ھەممىنى كۆرىدۇ ۋە ئاڭلايدۇ. //

[C1]
.  Gm            C
   ھەمدۇسانا، ھەمدۇسانا
.       F        Bb
   نامىڭغا، نامىڭغا،
.    Gm             A7
   قوبۇل قىلدىم ھاياتلىقنى،
.       Dm      D7
   ئۆزەڭنى مەڭگۈگە.
.     Gm             C
   مەدھىيىلەيمەن، مەدھىيىلەيمەن،
.      F          Bb
   بىر سېنى، خۇدايىم،
.  Gm        A7         Dm/D7
   مۇبارەكتۇرسەن يالغۇز ۆزەڭ.

[V2]
.   Dm
 // خۇدا مۇقەددەستۇر،
.Bb
 خۇدا قۇدرەتلىكتۇر،
.Gm         A7       Dm/A7
 خۇدا مېھىر۔شەپقەتلىكتۇر،
.Dm                  Gm       A7
 خۇدا ھەممىنى بىلىدۇ ەمەل قىلىدۇ. //</lyrics>
<key>F</key>
<title>خۇدايىم ئۇلۇغتۇر Мн216</title>
<author>ئەيسا جامائەت</author>
<hymn_number>216</hymn_number>
</song>