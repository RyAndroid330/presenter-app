<?xml version="1.0" encoding="UTF-8"?><song><title>ئەيسا پادىشا سەن М20 И31 Мн37</title>
<lyrics>[V1]
.G        Em
 ئەيسا، پادىشا سەن،
.C         D
 ھوقۇق سېنىڭكىدۇر.
.Em          Bm
 بۇ يەردە ئارىمىزدا سەن،
.C       Am      D
 مەدھىيىلەيمىز نامىڭنى

[C1]
.  Em      Bm     Em
   ئورۇن ئالغىن قەلبىمىزدە.
.  C      D        G    Em
   شان۔شەرەپلەر بولسۇن ساڭىلا
.  C      D    G        Em
   يەر۔يۈزىدە نامىڭ ئۇلۇق بولسۇن،
.         C         D     G
   كەل رەب ئەيسا، تەخت قۇر بىزدە.</lyrics>
<key>G</key>
<hymn_number>20</hymn_number>
<author>دُن مُِن, پَُل كيلِ</author>
</song>