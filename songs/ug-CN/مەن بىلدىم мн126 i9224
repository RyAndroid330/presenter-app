<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<author>مارۇپژان ياكۇپ ئوغلى</author>
<title>مەن بىلدىم Мн126</title>
<lyrics>[V1]
.        Bm           G
 مەن بىلدىم، خۇدا باركەن،
.        A7           F7#
 مەن بىلدىم، ئەيسا ھەقكەن.
.         Bm            G
 يەتتە كۈندە، بەخىت تاپتىم،
.          A7           F7#
 ئازاد بولدۇم، ئېغىر يۈكتىن.

[C1]
.     G
   // سەن مۇكەممەل //
.     A7
   // سەن مۇقەددەس //
.  F7#           Bm/A
   سەن مۇھەببەت، ەيسا
.     G
   // سەن مۇكەممەل //
.     A7
   // سەن مۇقەددەس //
.  F7#           Bm   G A7 F#7
   سەن مۇھەببەت، ەيسا.

[V2]
 سەن بىلەن كۈچۈم باردۇر،
 سەن بىلەن بەخىت ياردۇر.
 سەن بىلەن كۆڭلۈم توقتۇر،
 ئەژرىڭدە روھۇم پاكتۇر.
 خۇدا!

[C2]
.         Bm/G/A7/F#7/Bm
   رەببىم ەيسا!</lyrics>
<key>D</key>
</song>