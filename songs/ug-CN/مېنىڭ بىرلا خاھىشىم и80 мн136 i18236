<?xml version="1.0" encoding="UTF-8"?><song><author>هِللسُنگ, رُِبِن مُرگَن</author>
<hymn_number>80</hymn_number>
<copyright>١٩٩٥ هِللسُنگ پُبلِسهِنگ</copyright>
<key>G</key>
<lyrics>[V1]
.G              Em
 مېنىڭ بىرلا خاھىشىم
.     C  Am   D
 نامىڭنى كۆتىرىش.
.Em               G
 چىن قەلبىمدىن رەببىم
.        Am D
 ئۇلۇغلايمەن.

[V2]
.G            Em
 بارلىق مېنىڭ ۋۇجۇدۇم
.    C  Am    D
 مەدھىيە ساڭا.
.Em          G
 سۆيگۈ ئىزھارىم
.       Am D
 بىر ساڭا.

[C1]
   قايتارمىسى:
.  G             D
   قەلبىم ھاياتىمنى
.                Em
   بىر ساڭا بېغىشلايمەن.
.        C     D    G
   سەن ئۈچۈن ياشايمەن
.                 D
   ھەر بىر قەدىمىمدە
.                  Em
   بىرگە بولغۇم كېلىدۇ
.     C          D          G
   پەقەت ئىرادەڭ بولغاي مەندە.</lyrics>
<title>مېنىڭ بىرلا خاھىشىم И80 Мн136</title>
</song>