<?xml version="1.0" encoding="UTF-8"?><song><title>مەدھىيە И76 Мн121</title>
<key>Am</key>
<lyrics>[V1]
.   Am               Dm
 // بېشىمنى ئاسمانغا كۆتۈرۈپ
.G                   C
 سېنىڭ ئۇلۇغ نامىڭنى مەدھىيلەيمەن
.F                     Dm
 ساڭا شۈكۈرلەر ئېيتىپ، ەي خۇدا
.E
 سېنىڭ ئۇلۇغ نامىڭنى كۆتۈرىمەن! //

[C1]
.     Am       G
   // مەدھىيە، مەدھىيە!
.           Am
   مەدھىيە، مەدھىيە!
.               Dm
   مەدھىيە، ئەي خۇدا!
.  E                  (Am 2қ)
   سېنىڭ ئۇلۇغ نامىڭغا مەدھىيە! //

[V2]
 // قەلبىمنى مەن ساڭا تاپشۇرۇپ
 سېنىڭ ئۇلۇغ نامىڭنى مەدھىيلەيمەن
 شان۔شەرەپلەر ئېيتىپ مەن ساڭا
 سېنىڭ ئۇلۇغ نامىڭنى كۆتۈرىمەن. //</lyrics>
<author>شەرگىيە, زۇلفىرا</author>
