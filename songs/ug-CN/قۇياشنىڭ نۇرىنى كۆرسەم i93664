<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // قاراڭغۇ ھوجىرەمدىن
 دالاغا چىقسام
 قۇياشنىڭ نۇرىنى كۆرسەم //

[C1]
   // ھەقىقەتنىڭ ھۆرلۈكنىڭ
   ھوزۇرىنى سۈرسەڭ //
   ئو۔ئو۔ئو

[V2]
 // پاسىختىن يامانلىقتىن
 خالى بولسام
 بىلىكنى ھېكمەتنى بىلسەم //

[C2]
   چىن بەخىتنىڭ ئىچىدە
   ياشنىسام كۈلسەم
   ئو۔ئو۔ئو</lyrics>
<title>قۇياشنىڭ نۇرىنى كۆرسەم</title>
</song>