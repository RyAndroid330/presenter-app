<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>61</hymn_number>
<author>قۇددۇس ئاكا</author>
<title>كەلگىن مۇھەببەت М61 И62</title>
<key>C</key>
<lyrics>[V1]
.    Am
 //  مۇھەببەتنىڭ ئۆزىغۇ سەن
.C
 يورۇقلۇقنىڭ نۇرىغۇ سەن (2ق)  //
.    Dm
 //  ئىنسانلارغا يول كۆرسەتكەن
.Am           (E7 Am)
 مەڭگۈ ھايات يولىغۇ سەن (2ق)  //

[C1]
   قايتارمىسى:
.  Dm          Am   C           Am
   كەلگىن مۇھەببەت، چەكسىز مۇھەببەت
.  G            C          E
   ئاتام خۇدادا مەڭگۈ مۇھەببەت
.  Dm         Am     C         Am
   سازلارنى چېلىپ، ئۇسسۇل ئوينايلى
.  G          C  E7         Am
   ياشنا مۇھەببەت ئەبەدىل-ئەبەد

[V2]
 //  ئۇسىغاننىڭ بۇلىقى سەن
 تېنىگەننىڭ چىرىقى سەن (2ق)  //
 //  ئېزىلگەنگە بەخىت بېرىپ
 مۇھەببەتكە تولتىرىسەن (2ق)  //</lyrics>
</song>