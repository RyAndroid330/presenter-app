<?xml version="1.0" encoding="UTF-8"?><song><title>ئىككى دۇنىيا М53 И56 Мн89</title>
<key>Dm</key>
<lyrics>[V1]
.   Am                             E
 // ئىككى دۇنىيا بار ئېكەندۇر ئەزەلدىن،
.                   Am       A7
 باقى يۋرتقا مەن قارايمەن تويماستىن. //

[C1]
.  A7                 Dm
   بەش كۈنلۈك بۇ ئالەمدە
.               Am
   ژىغا۔زېرە كۆپتۇر
.                 E
   مېلىكە بۇ ئالەمدە
   خۇدانى بىلگەن جان
.  A7    Dm       Am
   قانداق بەخىتلىكتۇر

[C2]
.  A7                 Dm
   بەش كۈنلۈك بۇ ئالەمدە
.                  Am
   قايغۇ۔ھەسرەت كۆپتۇر
.                   E
   ھەم پانىي بۇ ئالەمدە
   خۇدانى سۆيگەن جان
.  A7    Dm       Am
   شۇنداق بەخىتلىكتۇر

[V2]
.Am                                       E
 بۇ ئالەمدە، ئۆمرۈمنىڭ تېڭى كەتتى سېنى بىلمەي
.                                                  Am
 بۇ ئالەمدە، كۆزۈمنىڭ يېشى بىر يەرگە يەتتى سېنى بىلمەي.</lyrics>
<hymn_number>53</hymn_number>
<author>ھېمىدەم ھەدە</author>
</song>