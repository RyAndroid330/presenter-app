<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>81</hymn_number>
<author>قۇددۇس ئاكا, خەلىق ناخشىسى</author>
<lyrics>[V1]
.   Dm               Gm
 // رەببىم ئەيسا، مىڭ رەخمەت
.Dm             A
 ماڭا تەلىم بېرىسەن //
.   Dm                Am
 // پاك قەلبىمگە، مۇقەددەس //
.   F          Gm
 // ئۇرۇغىنى تېرىسەن //

[C1]
.     Dm
   // رەببىم ئەيسا، مىڭ رەخمەت
.   F
   مىڭ رەخمەت
.  A                 Dm
   ماڭا تەلىم بېرىسەن //

[V2]
 // رەببىم ئەيسا، مىڭ رەخمەت
 ساڭا قەدەم تاشلىدىم //
 // ئازاد قىلدىڭ گۇناھدىن //
 // يېڭى ئۆمۈر باشلىدىم //

[V3]
 // قاراڭغۇدا يۈرەتتىم
 يول تاپالماي تېنەپ مەن //
 // خۇش خەۋىرىڭ كەلدىغۇ //
 // قاراڭغۇنى يېڭىپ مەن //

[V4]
 // رەببىم ئەيسا، مىڭ رەخمەت
 سەندىن تەلىم ئالىمەن //
 // ئازاد بولسۇن خەلقىم دەپ //
 // دايىم دۇئا قىلىمەن. //</lyrics>
<key>Dm</key>
<title>مىڭ رەخمەت М81 И83 Мн142</title>
</song>