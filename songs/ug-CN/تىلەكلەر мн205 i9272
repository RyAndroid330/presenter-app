<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>205</hymn_number>
<lyrics>[V1]
 // تىلەيمەن دوستلار
 سىلەرگە شاتلىق
 شاتلىق ئىچىدە
 ساقلانسۇن پاكلىق //

[V2]
 // رەب ئەيسادىن تىلەيمەن دوستلار
 قېرىنداشلار بىر تەن بولۇڭلار //
 // يامانلىقتىن ژىرگىنىپ ژىراق
 ياخشى ئىشتا بولسۇن قولۇڭلار //

[V3]
 // رەب ئەيسادىن تىلەيمەن دوستلار
 باشقىلارغا ياردەم قىلىڭلار //
 // رەقىپ ئەمەس دۈشمەنلىرىڭلار
 مېھرى بېرىپ دوست دەپ بىلىڭلار //

[V4]
 // تىلەيمەن دوستلار
 خوشال ياشاڭلار //
 // خۇدانىڭ ئىللىق ئۇچقۇنلىرىدىن
 توپ۔توپ بولۇپ گۈلخان ياساڭلار //
 توپ۔توپ بولۇپ گۈلخان ياساڭلار</lyrics>
<title>تىلەكلەر Мн205</title>
</song>