<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // رەببىم ئەيسا رەببىم ئۆزۈڭ
 ئۇلۇغدۇرسەن بىزلەر ئۈچۈن //
 // ئېيتىمىز ساڭا ھەمدۇسانا
 شان۔شەرەپلەر بولسۇن ساڭا //

[V2]
 // رەببىم ئەيسا بىزلەرنى سەن
 قىلدىڭ قوبۇل رەببىم ئۆزۈڭ
 گۇناھىمىزغا بولدۇڭ قۇربانلىق
 مۇقەددەس ئوغۇل رەببىم ئەيسا //

[V3]
 // رەببىم ئۆزۈڭ رەببىم ئەيسا
 شان۔شەرەپلەر بولسۇن ساڭا //
 شان۔شەرەپلەر بولسۇن ساڭا</lyrics>
<title>رەببىم ئەيسا رەببىم ئۆزۈڭ Мн165</title>
<hymn_number>165</hymn_number>
</song>