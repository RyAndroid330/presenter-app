<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ئۇلۇغ خۇدا سۆيىمىز سېنى
 ئۇلۇغلايدۇ ھەر دايىم ئۆيۈمىز سېنى
 ئۇلۇغ خۇدا سەن بىزگە مېھرىبان

[V2]
 // بۇ ئالەمدە، ئۇ ئالەمدە يوقتۇر پەقەت
 سەندىن ئۆزگە ھېچ بىر قەدىردان //

[V3]
 ئۇلۇغلىقىڭ چەكسىزدۇر، شەپقىتىڭ ھەم
 // قوغدىقىن بىزنى، ئەي ئۇلۇغ خۇدا
 ئاجىز ئېكەن ئىنسان تېنىدە //
 نامىڭ ئۇلۇغتۇر سېنىڭ ئەي خۇدا
 // ئىللىق مېھرىڭدىن ئىللىقىن بىزنى //</lyrics>
<title>ئۇلۇغ خۇدا سۆيىمىز سېنى Мн208</title>
<hymn_number>208</hymn_number>
</song>