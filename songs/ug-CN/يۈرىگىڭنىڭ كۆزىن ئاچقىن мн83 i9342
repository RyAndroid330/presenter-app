<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Cm         Fm
 يۈرىگىڭنىڭ كۆزىن ئاچقىن
.Bb           Eb
 بۈگۈن سۆزلەر ۇ ساڭا
.Cm        Fm
 قەلبىڭنى، ھاياتىڭنى
.Gm        Cm
 ەيساغا ئاتا

[P1]
.     Ab           Bb
   // كۆڭۈل ئاغرىق ۆتۈپ كەتسۇن
.  Eb       F
   ادالىتىڭنى تاشلا
.  Ab         Bb
   موشۇ كۈننى مەسىھ بىلەن
.  Gm          Cm
   يېڭىدىن باشلا //

[C1]
.     Cm         Ab
   // كۈچ بەرسۇن ھەر بىر سۆزۈڭ
.  Bb       Eb
   اژىز ژانغا
.  Cm         Fm
   مەسىھ سېنى تاللىۋالغان
.  Bb        Cm
   ۆز ھوزۇرىغا //

[V2]
.Ab          Fm
 گۇناھ ئۈچۈن ەيسا قېنى
.Gm          Cm
 چېدىر بولۇپ يېپىلغان
.Cm             Fm
 يېڭى ئادەم سەن مۇقەددەس
.Bb         Cm
 ھەم پاكلانغان

[P2]
.     Ab           Bb
   // سەن مۇقەددەس يەر۔يۈزىدىن
.  Eb        F
   چاقىرىلىپ ېلىنغان
.  Ab         Bb
   مەسىھنىڭ مۇھەببىتىدىن
.  Gm           Cm
   بەھىرمان بولغان //</lyrics>
<key>Eb</key>
<title>يۈرىگىڭنىڭ كۆزىن ئاچقىن Мн83</title>
<author>راخىلь ыسыېۋا</author>
<hymn_number>83</hymn_number>
</song>