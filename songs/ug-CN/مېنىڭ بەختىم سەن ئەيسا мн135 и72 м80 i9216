<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>135</hymn_number>
<author>قۇددۇس ئاكا</author>
<title>مېنىڭ بەختىم سەن ئەيسا Мн135 И72 М80</title>
<key>G</key>
<lyrics>[V1]
.   Em                  D
 // سەندىن تاپتىم بەختىمنى
.Bm                Em
 نۇرغا چۆمدۈم قۇياشتەك
.Em              D
 ساڭا ئەيسا تەلپۈنىمەن
.Bm             Em
 بۆشۈكتىكى بوۋاقتەك //

[C1]
.  Am          Em
   بەخىت بەرگەن بىر ئۆزەڭ
.     Am        Em            Am D G
   // ھايات يولى بىر ئۆزەڭ //
.  Am        Em
   ساڭا تەشنا يۈرىگىم
.     Am          Em        D   Bm Em
   // مېنىڭ بەختىم سەن ئەيسا //

[V2]
.   Em              D
 // سېنىڭ ئۈچۈن سوقىدۇ
.Bm              Em
 ىنسانلارنىڭ يۈرىگى
.Em                 D
 ارام، بەخىت، جەننەتنىڭ
.Bm              Em
 بىر ئۆزەڭغۇ كۆرۈگى. //</lyrics>
</song>