<?xml version="1.0" encoding="UTF-8"?><song><title>پەرۋەردىگار Мн161 И93 М94</title>
<key>Em</key>
<lyrics>[V1]
.Em          Am
 بەخىت ھايات بىر سەن ئېكەن
.B7              Em
 ادىشىپ يۈرگەن ئېدىم
.C         Bm           Em
 ويلىمىغان بىر يول باشلىدىم
.Em          Am
 تايانچىم بولدى بىر دوست
.B7              Em
 ھاياتىمنى ئۆزگەرتىپ
.C           Bm          Em
 ۋاپادار، ئۆزگەرمەس، مۇقەددەس

[C1]
.          G            D
   پەرۋەردىگار، پەرۋەردىگار
.  Am         Bm         Em
   خۇدانىڭ قۇرۋانلىق قوزىسى
.          G            D
   پەرۋەردىگار، پەرۋەردىگار
.  Am         Bm          Em
    ئاسماندىن كەلگەن نىجاتكار.</lyrics>
<hymn_number>161</hymn_number>
<author>تاش ئاكا</author>
</song>