<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>90</hymn_number>
<author>ھەمرا ئاكا</author>
<key>G</key>
<lyrics>[V1]
.   G                       D        Bm
 // ھەلىگەر تۈن ۔ زىندانىدىن، ئازادلىق روشەنىگە،
.Em          G             D
 مۇقەددەس روھ باشلا مېنى دايىم. //

[C1]
.     Bm
   // مۇقەددەس روھ بۇ پانىيدىن،
.  G            D
   تار يول بىلەن مەڭگۈ ھايات
.  Em         G             D
   اسمان تامان باشلا مېنى دايىم. //

[V2]
 // دۇنىيا ۋەس۔ۋەسە سىناق، مۇكەممەل ئىمان تايانچ
 كامالەت ئىلاھ، كامالىدا ھېكمەت //</lyrics>
<title>ھەلىگەر تۈن زىندانىدىن М90 И135 Мн238</title>
</song>