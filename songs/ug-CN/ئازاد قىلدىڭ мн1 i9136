<?xml version="1.0" encoding="UTF-8"?><song><title>ئازاد قىلدىڭ Мн1</title>
<lyrics>[V1]
.   Bm          A           F#      Bm
 // خۇدا ئىرادەڭنى چۈشەردىڭ سەن بىزلەرگە
.Bm               A       G       F#
 خۇدا مۇقەددەس روھۇڭنى بىزگە ئەۋەتتىڭ //

[C1]
.      G              A          F#          Bm
   // بىزنى ئازاد قىلدىڭ گۇناھلاردىن، ئەي رەببىم.
.           G          A        F#           Bm
   رەببىم ئەيسا، پاكلىدىڭ قەلبىمىزنى، ئەي رەببىم. //

[V2]
.   Bm               A        F#        Bm
 // سەن ئۇلۇغ سەن ھەممىدىن ئۇلۇق، ئەي مەسىھ
. Bm                A          G         F#
 سەن بىزنى ئازاد قىلدىڭ گۇناھلاردىن، ئەي رەببىم. //</lyrics>
<key>Bm</key>
<author>مەرۈپژان ياقۇپ ئوغلى</author>
<hymn_number>1</hymn_number>
</song>