<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm                     Gm
 //  ماڭا بەرگەن ھاياتىڭ ئۈچۈن،
.A          Asus   Dm     Bb/A
 مەن ساڭا نېمە بېرەلەيمەن؟!
.Dm                        Gm
 ماڭا قىلغان غەمقورلۇغۇڭ ئۈچۈن،
.A           Asus    Dm
 مەن ساڭا، نېمە قىلالەيمەن؟! //

[P1]
.     Dm        Gm
   //  پەقەت كۈيلەيمەن مەن سېنى،
.           Dm
   ھەم ئۇلۇغلايمەن مەن سېنى،
.      A          Asus      Dm/D7
   تەشەكۈر، مەن ساڭا ، ئېيتىمەن! //

[C1]
.     D7                           Gm
   // رەخمەت ساڭا ۔ ئاتا، ئوغلۇڭ ئۈچۈن!
.     C7                        F  A
   رەخمەت ساڭا ۔ ئەيسا، قېنىڭ ئۈچۈن!
.    Bb                         Gm
   رەخمەت مۇقاددەس روھ، كۈچۈڭ ئۈچۈن!
.     Bb           C
   رەخمەت ساڭا، رەببىم!
.           F      D7   (Dm)
   رەخمات ساڭا، رەببىم!  //</lyrics>
<key>F</key>
<title>ماڭا بەرگەن ھاياتىڭ ئۈچۈن Мн119</title>
<hymn_number>119</hymn_number>
</song>