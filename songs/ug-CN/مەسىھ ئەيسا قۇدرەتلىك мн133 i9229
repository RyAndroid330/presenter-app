<?xml version="1.0" encoding="UTF-8"?><song><title>مەسىھ ئەيسا قۇدرەتلىك Мн133</title>
<lyrics>[V1]
.   C
 // مەسىھ ئەيسا قۇدرەتلىك،
.F            C
 ھەيۋەتلىك ۋە شۆھرەتلىك.
.F         G           C
 غالىبىيەت قازانغان جەڭچى ئۇ. //

[C1]
.     F           G
   // چاپراسقا مىقلانغاندا ئۇ،
.  C           Am
   شەيتاننى يەڭدى،
.  F            G           C
   دۈشمەن تامام شەرمەندە بولدى. //

[V2]
 // رەببىم ئەيسا قۇدرەتلىك،
 ھەيۋەتلىك ۋە شۆھرەتلىك،
 غالىبىيەت قازانغان جەڭچى ئۇ. //

[C2]
   // ئۆلۈمدىن تىرىلگەندە ئۇ،
   ئۆلۈمنى يەڭدى،
   ئۆلۈممۇ ھەم شەرمەندە بولدى. //

[V3]
 ئاپىرىن ساڭا ئەيسا،
 قۇتقۇزغۇچى رەب ئەيسا،
 غالىبىيەت قازانغان جەڭچى رەب.
 ئاپىرىن ساڭا ئەيسا،
 ھەق ۋە ئادىل پادىشا،
 غالىبىيەت قازانغان جەڭچى رەب.

[C3]
.     F           G
   // دۇنىياغا كەلگەندە ئۇ،
.  C           Am
   دۇنىيانى يەڭدى.
.  F           G        C
   دۇنىيامۇ شەرمەندە بولدى. //</lyrics>
<key>C</key>
<author>ھەمرا ئاكا</author>
<hymn_number>133</hymn_number>
</song>