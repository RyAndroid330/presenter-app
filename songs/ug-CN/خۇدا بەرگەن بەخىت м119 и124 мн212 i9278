<?xml version="1.0" encoding="UTF-8"?><song><author>قۇددۇس ئاكا</author>
<hymn_number>119</hymn_number>
<lyrics>[V1]
.   C       G                    C
 // ئوغۇللار رەب بەرگەن نەسىلدۇر،
.C          Am          G
 قىزمۇ خۇدا بەرگەن بەخىتتۇر. //
.   C           Am            Dm
 // كىم ئىشەنسە خۇدا ئوغلى ئەيساغا،
.G                   C
 اسمان ئىشەنگەننىڭ تەختىدۇر. //

[C1]
.     C           G             C
   // كېلىڭ ئوغۇل۔قىزلار كېلىڭلار.
.  Am           H          G
   دۇتار۔تەمبۈر چېلىپ كېلىڭلار. //
.      Gm           Am           Dm
   // رەببىمىز ھەم بەختىمىز ۔ ئەيسا ئۈچۈن،
.   G                               C
   گۆزەل قىزلار ئۇسسۇل ئويناپ كېلىڭلار. //

[V2]
.   C         G                C
 // تەبىەتنى گۆزەل قىلىپ ياراتقان،
.C          Am              G
 ىنسانلارنى مۇھەببەتكە ئۈگەتكەن. //
.   C          Am             Dm
 // گۇناھكارنى قۇتۇلسۇن دەپ خۇدايىم،
.G                      C
 ۆز ئوغلىنى بۇ دۇنىياغا ەۋەتكەن. //</lyrics>
<key>C</key>
<title>خۇدا بەرگەن بەخىت М119 И124 Мн212</title>
</song>