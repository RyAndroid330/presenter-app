<?xml version="1.0" encoding="UTF-8"?><song><title>خۇداغا تايانغان Мн213</title>
<key>C</key>
<lyrics>[V1]
.   Dm           G
 // خۇداغا تايانغان خەلىقلەر
.C         Dm
 مەڭگۈ ژىقىلماس
.Dm           G
 ۇلار خۇددى سىون تېغىدەك
.C          Dm
 مۇستەھكەم تۇرار //

[C1]
.           Dm          G
   // ئۇ قانداق قوغدىسا ىېرۇسالىمنى
.  C                 Dm
   ۇ ھەم شۇنداق قوغدار ئۆز خەلقىنى
.    Dm       G
   بارچە خەلىق ئېيتار شۇڭا
.  C         Dm
   مەڭگۇ ھەمدۇسانا //</lyrics>
<hymn_number>213</hymn_number>
</song>