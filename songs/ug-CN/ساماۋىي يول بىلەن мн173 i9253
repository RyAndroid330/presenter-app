<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>173</hymn_number>
<author>ھەمرا ئاكا</author>
<title>ساماۋىي يول بىلەن Мн173</title>
<key>Em</key>
<lyrics>[V1]
.Em                D                 C
 ساماۋىي يول بىلەن مۇقەددەس روھ ئارقىلىق
.Bm             Am   C              B
 دۇنىياغا كەلدى ەيسا، قۇتقۇزغۇچى مەسىھ
.Em              D                   C
 ۇ ھەقتە قېدىمىي پەيغەمبەرلەر ئېيتقاندەك،
.Bm            Am   C                  B
 بەيتلەھەمدە تۇغۇلدى، ئىپپەتلىك پاك قىزدىن

[C1]
.     Am                     Em
   // ئەي، دۇنىياغا مەسىھ كەلدى
.                 D
   خۇدانىڭ ئەۋەتكىنى
.                   Em  E7
   قۇتقۇزغۇچىمىز كەلدى__
.  Am                    Em
   ەي، گۇناھكار ئىنسانلارنى
.                  D
   مۇقەددەس خۇدا بىلەن
.                  Em
   ياراشتۇرغۇچى كەلدى
.  E7             Am
   ېغىلدا۔ئوقۇردا تۇغۇلۇپ،
.                    B7
   ئالەمنىڭ رەببى كەلدى //
   (رەبلەرنىڭ رەببى كەلدى)

[V2]
 خۇدانىڭ گۇناھكار ئىنسانغا كەچۈرۈم بېرىش
 مەخسىتىنى ئەمەلگە ئاشۇرغۇچى كەلدى
 مۇقەددەس گۇناھسىز مەسىھ ئەيسا بىز ئۈچۈن
 چاپراستا قۇربان بولدى گۇناھلار ژۇيۋلدى

[C2]
   ئەي، بېگۇنا مەسىھ ئۆلدى،
   گۇناھكارلار ئورنىدا
   قۇربانلىق بولۇپ ئۆلدى.
   ئەي قۇربانسىز كەچۈرۈم يوق،
   گۇناھنى ژۇيار قۇربان قان،
   مۇقەددەس قۇربان قان.
   ئەيسادىن ئاققان قاننىڭ
   ھەققىگە بىز ئاقلاندۇق

[C3]
   ئەي، ئەيسادىن ئاققان قاننىڭ
   ھېساۋىغا ئاقلاندۇق
   جازادىن قۇتقۇزۇلدۇق.
   ئەي، ئەيسا ئۆز قېنى بىلەن
   بىزلەرنى سېتىۋالدى
   قانۇننىڭ لەنىتىدىن،
   گۇناھدىن ھەم دوزاقتىن
   قۇتقۇزغۇچىدۇر ئەيسا

[C4]
   ئەي، ئىشىنىڭلار ئۇنىڭغا
   خۇدا ئەۋەتكەن ۋەكىل ئۇ
   خۇدانىڭ مۇھەببىتى
   ئەي ئىشىنىڭلار ئەيساغا
   خۇدادىن كەلگەن مەسىھ ئۇ
   خۇدانىڭ مەخپىرىتى
   ئىنسانلارغا ئەۋەتكەن
   خۇدانىڭ ئىلتىپاتى</lyrics>
</song>