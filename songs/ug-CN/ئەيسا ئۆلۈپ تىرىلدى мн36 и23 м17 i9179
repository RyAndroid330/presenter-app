<?xml version="1.0" encoding="UTF-8"?><song><title>ئەيسا ئۆلۈپ تىرىلدى Мн36 И23 М17</title>
<key>D</key>
<lyrics>[V1]
.   D           A        Bm    F#m
 // ئەيسا ئۆلۈپ تىرىلدى، ھەمدۇسانا.
.G        D       C      A
 قېرى ئىلان يەنچىلدى، ھەمدۇسانا.
.D          A      Bm     F#m
 غالىپ چىقتى رەببىمىز، ھەمدۇسانا.
.G      D         C      A
 تەنتەنە، خۇرسەن بىز، ھەمدۇسانا. //

[C1]
.     D A Bm  F#m
   // ھەمدۇسانا،
.  G  D C  A
   ھەمدۇسانا. //

[V2]
 // يېڭى ھايات باشلاندى، ھەمدۇسانا
 ئاقلاندى ئۈمۈتىمىز، ھەمدۇسانا.
 يېقىنلاشتى رەببىمىز، ھەمدۇسانا.
 تەنتەنە، خۇرسەن بىز، ھەمدۇسانا //</lyrics>
<hymn_number>36</hymn_number>
<author>ئېركіنبېك ئاغا</author>
</song>