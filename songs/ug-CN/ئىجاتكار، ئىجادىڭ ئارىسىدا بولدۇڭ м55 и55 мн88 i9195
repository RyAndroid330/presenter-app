<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em            Bm              F#
 ئىجاتكار، ئىجادىڭ ئارىسىدا بولدۇڭ،
.             G
 سەزمىدى بەزەنلەر،
.Em         Bm                   F#
 قانچە مۆجىزىلەر كۆرسەتكەن بولساڭمۇ،
.             Bm
 بىلمىدى ئادەملەر.

[V2]
.   Em          Bm               F#
 // بارچە ھەمدۇسانا سەن ئۈچۈن ئىلاھىم،
.            G
 ئاپىرىن كامالەت،
.Em            Bm               F#
 كەچۈرگىن بىزلەرنى توۋۋا ئەستايىدىل،
.           Bm  F#
 ئەپسۇس كەچ نادامەت. //

[C1]
.  Bm         Em          Bm      G F#m
   ئەيسا رەب، اپىرىن ساڭا شان۔شەرەپ،
.  Em                            Bm  F#
   بىزلەر ئۈچۈن پاك قېنىڭ قۇربان ەتكەن
.  Bm       Em            Bm      G F#m
   مۇھەببەت، ئاپىرىن ساڭا شان۔شەرەپ،
.  Em                         Bm  F#
   بىزلەر ئۈچۈن ئازاپ۔ئوقۇبەت چەككەن.

[V3]
.Bm      Em             Bm     G F#m
 خۇدايىم، ئېگىدارىم سەن ھەر دايىم،
.Em                           Bm F#
 سەن بار ئۈچۈن، خاتىرجەملىكتە مەن.
.Bm       Em             Bm   G F#m
 اجىز مەن، ئۆزەڭ بىلىسەن خۇدايىم،
.Em                   Bm  F#
 ەگەشتىم يېتىلە ئۆزەڭ سەن.

[P1]
.     Bm            Em
   // ئاپىرىن خۇدا، شۈكرى ئىگەم،
.  F#
   شۈكرى ئىگەم مېنىڭ //

[C2]
.     Bm
   // مەدھىيە ئالقىشلار بولسۇن
.  Em       F#
   بىر ساڭا رەببىمىز.
.  Bm         Em         F#
   شان۔شەرەپ، ھەمدۇسانا، اپىرىن
.  Bm
   مەدھىيە ئالقىشلار بولسۇن
.  Em       F#
   بىر ساڭا نىجاتكارىمىز
.  Bm         Em         F#
   شان۔شەرەپ، ھەمدۇسانا، اپىرىن. //</lyrics>
<key>Bm</key>
