<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // ئەيسا مەسىھ نىجاتكار
 بولغىن ماڭا مەدەتكار
 كۈيلەي سېنىڭ نامىڭنى
 ناخشا ئېيتىپ چېلىپ ساز. //

[C1]
   // تىرىك خۇدا سەن ئۆزۈڭ
   مۇقەددەستۇر ھەم سۆزۈڭ. //

[V2]
 قۇتقۇزدۇڭ سەن ئەي خۇدا
 بىز گۇناھكار بەندەڭنى.
 ئادىل بولغاچ سەن خۇدا
 ئۇنىتمىدىڭ ۋەدەڭنى.

[V3]
 قۇتقۇزدۇڭ سەن ئەي خۇدا
 بىز گۇناھكار بەندەڭنى.
 ئادىل بولغاچ سەن خۇدا
 ئەسكە ئېلىپ ئەھدەڭنى.</lyrics>
<title>ئەيسا مەسىھ نىجاتكار Мн23</title>
<hymn_number>23</hymn_number>
</song>