<?xml version="1.0" encoding="UTF-8"?><song><title>كايىناتنى ياراتقان Мн97</title>
<lyrics>[V1]
 كاىنات يارتقان
 // يگانە ئۇلۇغ خۇدا //
 خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا

[V2]
 بۇ ئالەمگە مۇساپىر مەن
 // ئۇ ئالەمدىن قىلما جۇدا //
 خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا

[V3]
 بۇ دۇنىيا تۈگەيدىكەن
 // ئاخىرى ئۆلۈم بىلەن //
 خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا

[V4]
 ئۇ ئالەم مەڭگۈلۈكتۇر
 // ئەي خۇدا سېنىڭ بىلەن //
 // خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا //

[V5]
 بۇ دۇنىيادا ساقلىقىن
 // شەيتاننىڭ سىناقىدىن //
 خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا

[V6]
 ئۇ دۇنىيادا ئازاد قىل
 // ئۆلۈمنىڭ ئازاۋىدىن //
 خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا

[V7]
 ئۇ دۇنىيادا ئازاد قىل
 // ئۆلۈمنىڭ ئازاۋىدىن //
 // خۇدا ئۇلۇغدۇرسەن ئەي ئۇلۇغ خۇدا //</lyrics>
<hymn_number>97</hymn_number>
</song>