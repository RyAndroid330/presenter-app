<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 خۇدا دەيمەن، خۇدا دەيمەن
 // خۇدا سېنى ئۇلۇغلايمەن //
 // خۇدا ھوزۇرىدىن كەلگەن
 رەببىمنى ئۇلۇغلايمەن //

[V2]
 خۇدا دەيمەن، خۇدا دەيمەن
 خۇدا سېنى ئۇلۇغلايمەن
 // خۇدا ئالدىڭدا گۇناھكار
 ئاژىز قۇلۇڭ بەندەڭمەن //

[V3]
 خۇدا دەيمەن، خۇدا دەيمەن
 خۇدا سېنى ئۇلۇغلايمەن
 // گۇناھىمغا توۋۋا قىپ
 نىجاتلىق تاپاي دەيمەن //

[V4]
 ياراتقان ئىگەم قوينىغا
 ئۆزەمنى ئاتاي دەيمەن
 خۇدا ئۈچۈن جېنىمنى
 // قوش قوللاپ تۇتاي دەيمەن //</lyrics>
<aka>خۇدا سېنى ئۇلۇغلايمەن</aka>
<title>خۇدا دەيمەن Мн223</title>
<hymn_number>223</hymn_number>
</song>