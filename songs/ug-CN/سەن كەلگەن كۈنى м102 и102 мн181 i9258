<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.Cm                     Fm
 بۇ دۇنىيا بەشكۈنلۈك ئۆمۈر،
.Bb                         Cm
 ھەممە يالغان، ھەممە ئۆتكۈنچى.
.   Cm                    Fm
 // دۇنىيادىكى ھەممە نەرسىلەر،
.G                         Cm
 توزۇپ كېتەر سەن كەلگەن كۈنى. //

[C1]
.     Ab           Bb      Gm Cm
   // يېڭى دۇنىيا، يېڭى ئۈمۈت،
.  Fm      Bb          Cm
   ھەقىقەت مەڭگۈلۈك ئۆمۈر.
.  Ab      Bb       Gm Cm
   تۈگىمەس بەخىت۔ساادەت
.  Fm       Bb           Cm
   باشلىنار سەن كەلگەن كۈنى. //
.  G                      Cm
   باشلىنار سەن كەلگەن كۈنى.

[V2]
 سېنىڭ مېھرىڭ دەرىيادەك چەكسىز،
 قۇياشتىن مول نۇرلىرىڭ سېنىڭ.
 // ئۆتۈنىمەن نۇرىڭنى چېچىپ،
 قۇتقۇزۋال خەلقىمنى مېنىڭ. //

[V3]
 خۇدايىم كەچۈر گۇناھكارمىز
 سەندىن باشقا يوق پانايىمىز.
 // ھەممىسىدىن قۇدرەتلىك ئۆزەڭ
 يالغۇز ساڭىلا سىقىنىمىز. //</lyrics>
<title>سەن كەلگەن كۈنى М102 И102 Мн181</title>
<hymn_number>102</hymn_number>
<author>گۇلمىرا (مويناق), رۇستام</author>
</song>