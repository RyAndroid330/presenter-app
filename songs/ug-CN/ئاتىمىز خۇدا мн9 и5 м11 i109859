<?xml version="1.0" encoding="UTF-8"?><song><title>ئاتىمىز خۇدا Мн9 И5 М11</title>
<key>C</key>
<lyrics>[V1]
.C       F         Am          G/B
 ئەگەر ماڭسام ئۆلۈمگە يېقىن مەن
.C        F         Am
 قورقمايمەن ھېچ يامانلىقتىن.
.   Dm      Am       G
 // چۈنكى سەن رەببىم مېنىڭ بىلەن
.F      G         C
 ھاياتلىق يولۇم سەن ئىگەم //

[C1]
   قايتارمىسى:
.     Am        G    F            C
   // ئاتىمىز خۇدا، رەببىم سەن ئەيسا،
.  Dm       Am G/B C
   تېچلىقىم مۇقەددەس روھ. //</lyrics>
<hymn_number>9</hymn_number>
<author>تاش ئاكا</author>
</song>