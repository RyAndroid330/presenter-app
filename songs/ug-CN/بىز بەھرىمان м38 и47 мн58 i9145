<?xml version="1.0" encoding="UTF-8"?><song><title>بىز بەھرىمان М38 И47 Мн58</title>
<key>F</key>
<lyrics>[V1]
.Bb       F             C   Dm
 بىز بەھرىمان، غالىبانە شادىمان،
.Am        C                    Bb     F
 نىجاتلىققا ئېرىشكەن پاك ئىمان، شاد ئىنسان.
.Bb      F             C   Dm
 بىز بېگۇمان، خالىسانە شادىمان،
.Am         C                  Bb     F  (C-Dm)
 چۈنكى مەسىھ بىز ئۈچۈن كاپالەت ھەق قۇرۋان.

[V2]
.   Am         C                  Bb  F
 // ئالقىشلايلى مۇقەددەس نىجاتكار نامىنى،
.Am         C       Bb      Dm
 رەببىمىزگە ۋاپادار بېپايان شاد
.Am          C                 Bb  F
 خۇدا ئاچقان مەخپىرەت نىجاتلىق يولىنى،
.Am       C          Bb      Dm
 توسالمايدۇ ھەسەتخور، ھېلىگەر ياۋ. //</lyrics>
<author>ھەمرا ئاكا</author>
<hymn_number>38</hymn_number>
</song>