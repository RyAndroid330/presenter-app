<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>24</hymn_number>
<lyrics>[V1]
 // مەسىھ بولۇپ دۇنىياغا كەلدىڭ سەن رەببىم //
 // شۇنىڭ ئۈچۈن ھەر دايىم شاتلىقتا قەلبىم //

[V2]
 // بۇ دۇنىياغا نۇر بولۇپ كەلدىڭ سەن رەببىم
 شۇ نۇرۇڭنىڭ مېھرى بىلەن بولدۇم مەن ئەركىن //

[C1]
   كەلدى مانا ئەي رەببىم
   شۇ قۇتلۇق كۈنۈڭ
   ئۇلۇغلۇق، شان۔شەرەپ پەقەتلا سېنىڭ
   ناخشا ئېيتىپ ئۇسسۇل ئويناپ
   كۈيلەيمىز سېنى
   مۇبارەك ئەي رەببىم، تۇغۇلغان كۈنۈڭ
   ناخشا ئېيتىپ ئۇسسۇل ئويناپ
   كۈيلەيمىز سېنى
   // مۇبارەك ئەي رەببىم، تۇغۇلغان كۈنىڭ //</lyrics>
<title>ئەيسا مەسىھنىڭ تۇغۇلغان كۈنى Мн24</title>
</song>