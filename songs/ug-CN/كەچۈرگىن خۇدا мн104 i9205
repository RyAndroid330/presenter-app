<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<title>كەچۈرگىن خۇدا Мн104</title>
<lyrics>[V1]
 // كەچۈرگىن خۇدا
 كەچۈرگىن مېنى
 گۇناھ ئۆتكۈزدۈم
 تونۇماي سېنى //

[V2]
 // ئۆرتىنەر قەلبىم
 شۇڭا ئازاپتا
 كۆيەرمەنمۇ دەپ
 ئەمدى دوزاقتا //

[V3]
 // شۈكرى رەب ئەيسا
 قۇتقۇزدۇڭ مېنى
 كۈيلەيمەن ئەمدى
 گۆزەل نامىڭنى //

[V4]
 // شۈكرى ئەي خۇدا
 كۈيلەيمەن سېنى
 غەلپەت قوينىدىن
 قۇتقۇزدۇڭ مېنى //</lyrics>
</song>