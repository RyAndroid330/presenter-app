<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>100</hymn_number>
<author>قۇددۇس ئاكا</author>
<lyrics>[V1]
.Am         Dm
 رەببىمىزنى مەدھىيلەپ
.E          Am
 ېگىز كۆككە قارايمەن
.Am         Dm
 قۇتقازغۇچى ەيسادىن
.G           C
 مەن كەچۈرۈم سورايمەن

[C1]
.     Am            Dm
   // كەلگىن ئەيسا، كەلگەيسەن
.  E          Am
   يەر۔يۈزىگە كەلگەيسەن
.  F            Dm
   پۈتكۈل جاھان كۆرسۇن سېنى
.  E          Am
   قۇدرىتىڭدە كەلگەيسەن //
.  Am            Dm
   پۈتكۈل جاھان كۆرسۇن سېنى
.  E          Am
   قۇدرىتىڭدە كەلگەيسەن

[V2]
 رەببىم مېنى كەچۈرگىن
 قۇربانلىق قېنىڭ بىلەن
 يېڭىلىقىن قەلبىمنى
 مۇقەددەس روھىڭ بىلەن

[V3]
 بىز ئۈچۈن سەن ئۆلدۈڭغۇ
 ئۈچ كۈن ياتتىڭ مازاردا
 ئۈچ كۈن يېتىپ تىرىلىپ،
 كەتتىڭ تىرىك ئاسمانغا</lyrics>
<key>Am</key>
<title>كەلگىن ئەيسا Мн100 И59 М59</title>
</song>