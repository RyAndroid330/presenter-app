<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm                            Cm  Dm
 // ئەيسانىڭ مۇقەددەس قېنى، ھايات بۇلۇغى
.Dm         Gm       Cm      Dm
 تەنگە داۋا بەرگۈچى، شىپالىق مەنبەسى //
.   Dm                   Gm
 // ئەيسا ھايات بەرگۈچى، ەيسا داۋالىغۇچى
.Dm                 Cm                Dm
 يوقتۇر ھېچ بىر ئۇنىڭدەك قەلبنى ساقايتقۇچى! //

[V2]
 // ئەيسادىن ئاققان قاننى قوبۇل قىلايلى
 ئۇنىڭ تىلىنغان تېنىنى ئەسلەپ ئۆتەيلى //
 // بىرگە جەم بولايلى، رەببىمىزنى ئەسلەيلى
 ئۇنىڭ قۇربانلىق قېنىغا پاكلىقتا بىز كېلەيلى! //</lyrics>
<key>Bb</key>
<title>ئەيسانىڭ قۇربانلىق قېنى И38 Мн34</title>
<author>قۇددۇس ئاكا</author>
