<?xml version="1.0" encoding="UTF-8"?><song><title>ئەيسا دوستۇم М35 И37 Мн19</title>
<key>Dm</key>
<lyrics>[V1]
.Dm               A
 ئەيسا مېنىڭ مەڭگۈ دوستۇم
.Gm             Dm
 خۇدا بىلەن ياراشتۇرغان.
.   Dm            Gm
 // تېنەپ يۈرگەن مەن ئۈچۈن
.A                 Dm
 ەيسا دوستۇم ئىشىك اچقان. //

[C1]
.  Gm
   ئەيسا بىزگە ئىشىك ئاچتى،
.     Dm(A)                Dm
   // كەلگىن دوستۇم، قۇتۇل دوستۇم. //
.  Gm
   بۇ دۇنىيا باقى ئەمەس،
.     Dm(A)                Dm
   // كەلگىن دوستۇم، ئىشەن دوستۇم. //

[V2]
 بەزى ئادەم ئىشەنمەستىن
 گۇناھلارغا پېتىپ يۈرەر.
 // ئەيسا دوستۇم قولىنى سۇنسا،
 قولىنى بەرمەي قېچىپ يۈرەر. //

[V3]
 بېباھا قېنى بىلەن
 ئەيسا دوستۇم ھايات بەردى.
 // ئۆلۈم يولىدىن قۇتقۇزۇپ
 ياشىسۇن دەپ ئۆمۈر بەردى. //</lyrics>
<author>قۇددۇس ئاكا</author>
<hymn_number>35</hymn_number>
</song>