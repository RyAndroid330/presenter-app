<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 ئەيسا مەسىھ ھاياتتۇر مەڭگۈ
 ئۆلۈم ئۇنى قۇل قىلالمايدۇ
 // رەزىل شەيتان ھەرگىزمۇ
 خۇدا بىلەن تەڭ تۇرالمايدۇ //

[V2]
 // چۈنكى خۇدا ئادىلدۇر ئۇلۇغدۇر ھامان
 رەزىلدۇر شەيتاننىڭ سۈيقەستى يامان //

[V3]
 پاك بولغىن گۇناھسىز خۇددى كەپتەردەك
 سەگەك بول ھوشىيار خۇددى يىلاندەك
 // ھاياتىڭنى ئاتىقىن ئۇلۇغ خۇداغا
 يالغۇز قالسۇن رەزىل شەيتان خۇددى تىكەندەك //
 يالغۇز قالسۇن رەزىل شەيتان خۇددى تىكەندەك</lyrics>
<title>ئەيسا مەسىھ ھاياتتۇر Мн29</title>
<hymn_number>29</hymn_number>
</song>