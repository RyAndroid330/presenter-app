<?xml version="1.0" encoding="UTF-8"?><song><author>قۇددۇس ئاكا</author>
<hymn_number>11</hymn_number>
<lyrics>[V1]
.Dm           Gm
 ئەيسا قايتىپ كەلگەندە
.Dm           A
 پۈتكۈل ئالەم كۆرىدۇ
.Dm       Gm
 بۇلۇتلار ارا نۇر چېچىپ
.C         F
 شۆھرىتىگە بۆلەيدۇ!

[P1]
.  F            Gm
   يېڭى ئاسمان، يېڭى يەر
.  C          F
   ھەممە يېڭى بولىدۇ
.                     Gm
   // ھوزۇرىغا باشلاپ ۇ
.  A           Dm
   مەڭگۈ بىرگە بولىدۇ! //

[C1]
.  Dm           Gm
   ياشنا، ياشنا ەي۔ئەيسا
.  A              Dm
   ىززەت ئېھتىرام ساڭا
.  Dm            Gm
   ياشنا، ياشنا، ەي۔ئەيسا
.  A              Dm
   مەڭگۈلۈككە سەن باشلا!

[V2]
 ئەيسا نامىڭ ئۇلۇغتۇر
 سۆزۈڭ ئۆتكۈر قىلىچتۇر
 نامىڭنى ئېشىتكەندە
 شەيتان قورقۇپ قاچادۇر!

[P2]
   ئەيسا رەببىم ھاياتسەن
   دايىم مەندە ياشايسەن
   // مەدەت بېرىپ جېنىمغا
   ھاياجانلىق بېرىسەن! //</lyrics>
<key>Dm</key>
<title>ئەيسا رەببىم ھاياتسەن И11 Мн38</title>
</song>