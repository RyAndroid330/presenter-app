<?xml version="1.0" encoding="UTF-8"?><song><aka>رەببىم ئەيسا، ھەمدۇسانا!</aka>
<key>Em</key>
<lyrics>[V1]
.Em
 رەببىم ئەيسا،
.     Am
 ھەمدۇسانا ساڭا،
.     Em
 ھەمدۇسانا.
.Em
 رەببىم ئەيسا،
.      Am
 مىننەتدارمەن سەندىن،
.      Em
 مىننەتدارمەن.

[C1]
.          Am
   // قەدىردانىم ساماۋىي
.       Em
   نىجاتكارىم ساماۋىي
.       B7                        Em
   يېتەكچىم سەن مۇقەددەس مېنىڭ رەببىم
.       Am                   Em
   ئۆزەڭ ئۈلگە نامۇنە، سۆزىڭ ھېكمەت نامۇنە
.        B7                   Em
   ھايات تەرىزىڭ بىزلەرگە نامۇنە. //</lyrics>
<title>قەدىردانىم ساماۋىي Мн112 И99 М66</title>
<hymn_number>112</hymn_number>
<author>ھەمرا ئاكا</author>
</song>