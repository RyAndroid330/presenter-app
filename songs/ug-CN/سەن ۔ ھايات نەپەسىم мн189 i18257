<?xml version="1.0" encoding="UTF-8"?><song><title>سەن ۔ ھايات نەپەسىم Мн189</title>
<lyrics>[V1]
.   G            C7      G
 //  سەن ۔ ھايات نەپەسىم!
.G           C7      G
 سەن ۔ ھايات نەپەسىم!
.  D7   Em  C      D
 مۇھەببىتىڭ ياشار مەندە! //

[C1]
.       G/D/Em     C    D
   // ساڭا تەشنا يۈرىگىم!
.     G/D/Em      C    D
   سەنسىز نابۇد يۈرىگىم! //

[V2]
 // سەن ۔ كۈندىلىك نېنىم!
 سەن ۔ كۈندىلىك نېنىم!
 سېنىڭ سۆزۈڭ يۈرىگىمدە! //

[B1]
.        D        C     D
   /// ...تەشنا يۈرىگىم!
.    D        C     D
   ...نابۇد يۈرىگىم! ///</lyrics>
<key>G</key>
