<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm                   C
 // مەسىھ بىزنى ئاسمانغا ېلىپ كېتىدۇ،
.C                 Dm
 اسمانغا ئېلىپ كېتىدۇ //

[C1]
.     F             Gm
   // پەرۋەردىگارغا شۈكۈر ئېيتىڭلار!
.  C         F
   ۇ مېھرىباندۇر!
.  F                   Gm
   ىلاھلارنىڭ ئىلاھىغا شۈكۈر ئېيتىڭلار!
.  Bb              C          Dm
   ۇنىڭ مۇھەببىتى مەڭگۈلۈكتۇر!!! //

[B1]
.     Dm          G
   // ئەيسا مەسىھ يار بولسۇن
.  Dm           G
   يامان روھلار يوقالسۇن!!! //
.  Dm
   ېېېېي</lyrics>
