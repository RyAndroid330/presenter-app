<?xml version="1.0" encoding="UTF-8"?><song><title>رەبنى تونۇڭلار Мн170 И94 М100</title>
<key>F</key>
<lyrics>[V1]
.   Dm         F      Gm      Dm
 // بۇ ئالەمگە ەيسانىڭ كېلىشىنى
.F          Gm          Am      Dm
 بۇرۇنتىنلا پەيغەمبەرلەر ئېيتىپ كەلگەندى //
.   Dm           Fm                Gm
 // يامان يولدىن يېنىڭلار رەبنى تونۇڭلار
.C                Dm   Am          Dm
 دېگەن ئىدى سۆزلىرىدە شۇ پەيغەمبەرلەر //

[C1]
.     Dm     F        F        Gm
   // شۇ پەيغەمبەرلەر، شۇ پەيغەمبەرلەر،
.  Am          Dm
   شۇ پەيغەمبەرلەر //

[V2]
 // خۇدا ئۆزى ئىنسان بولۇپ يەرگە كەلسىمۇ
 تونۇمىدى لېكىن ئۇنى نادان ئىنسانلار //
 // خۇدا يولى مەن بولىمەن ئەگەشكىن دېسىمۇ
 خىلاپلىق قىلدىڭ خۇداغا دەپ قاقتى نادانلار //

[C2]
   // قاقتى نادانلار، قاقتى نادانلار، قاقتى نادانلار //

[V3]
 // خۇدا يولى ئەيسادۇر ئۇ پاك يولدۇر
 خۇدا بىلەن ياراشتۇرغان ھەم ھەق يولدۇر //
 // ھايات يولى ئەيسادۇر، رەبنىڭ ئۆزىدۇر
 جەننەت يولى ئەيسادۇر، ئۇ مۇقەددەستۇر //

[C3]
   // ئۇ مۇقەددەستۇر، ئۇ مۇقەددەستۇر، ئۇ مۇقەددەستۇر //</lyrics>
<author>قۇدرەت ئاكا</author>
<hymn_number>170</hymn_number>
</song>