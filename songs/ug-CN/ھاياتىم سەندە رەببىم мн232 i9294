<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>232</hymn_number>
<author>شەرگىيە</author>
<lyrics>[V1]
.   Am          Gm    Am
 // ھاياتىم سەندە رەببىم
.Am           Gm    Am
 قۇدرىتىم سەندە رەببىم
.Gm         Bb
 ۈمۈتىم سەندە رەببىم
.Gm           Am
 سەندە رەببىم ەيسا //

[C1]
.  Am           Gm   Am
   ئالقىشلايمەن سېنى رەب
.  Am           Gm   Am
   ھۆرمەتلەيمەن ەيسا رەب
.     Gm          Bb
   // ھاياتىم قۇدرىتىم
.  Gm         Am
   ۈمۈتىم سەندە رەب //
.  Am           Gm   Am
   مەدھىيلەيمەن سېنى رەب

[V2]
 // شىپالىقىم سەندە رەب
 قۇتقۇزغۇچۇم سەندە رەب
 بايلىقىم سەندە رەب
 سەندە رەببىم ئەيسا //

[V3]
 // خوشاللىقىم سەندە رەب
 ئارمانلىرىم سەندە رەب
 مۇھەببىتىم سەندە رەب
 سەندە رەببىم ئەيسا //</lyrics>
<key>C</key>
<title>ھاياتىم سەندە رەببىم Мн232</title>
</song>