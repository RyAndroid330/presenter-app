<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.              C  F            C
 // مەن ھالسىراپ جېنىم قىينالغاندا
.       C     F         G
 تىنچسىزلىنىپ ژۈرىگىم قايغۇرسا
.        F    G         C
 ئۈن چىقارماي يالغۇز سېنى كۈتىمەن
.        C   G          C
 كېلەر دەپ سېنى رەببىم يېنىمغا //

[C1]
.         F     G         C
   كۆتەردىڭ سەن شۇڭا ئېگىزلىكتە مەن
.        Am       G         C
   كۆتەردىڭ سەن ئۆتتۈم دېڭىزلاردىن
.       F  G         C
   كۈچلۈكمەن سېنىڭ قولۇڭدا رەب
.       C         G         C
   كۆتەردىڭ سەن، سەندە غەيرەتلىك مەن

[V2]
 // بۇ ھاياتتا بىز قىينالماي قالمايمىز
 تىنچسىزلىنىپ يۈرەكلەر سالىدۇ
 سەن كەلگەندە مۆژۈزەڭگە تولىمەن
 كۆز ئالدىمغا ئاسمىنىڭ تارتىلۇر //</lyrics>
<title>كۆتۈردۈڭ سەن Мн108</title>
<hymn_number>108</hymn_number>
</song>