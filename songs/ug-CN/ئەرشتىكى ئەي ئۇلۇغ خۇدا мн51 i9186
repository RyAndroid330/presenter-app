<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>51</hymn_number>
<lyrics>[V1]
 ئەرشتىكى ئەي ئۇلۇغ خۇدا
 مەن دېدىم سېنى
 ئاژىز بەندەڭ مەن
 كەچۈرگىن مېنى

[V2]
 // سەندىن باشقا يوقتۇر پاناھىم
 ئۇلۇغلايمەن ھەر دايىم سېنى //
 // سايدا ئۆسكەن يالغۇز دەرەق مەن
 ماڭا ئۆزەڭ پەرۋىش قىلغايسەن //

[V3]
 // ئەسكى چاغلار چىقسا مېنىڭدىن
 ئۇنى دەرھال جۇدا قىلغايسەن //
 ئۇلۇغ خۇدا سەن ئەپۇ قىلغۇچى
 // مەۋجۇديىتىڭ ھازىرمۇ مەۋجۇت
 ۋە مەڭگۈ مەۋجۇت بولغۇچى //
 ۋە مەڭگۈ مەۋجۇت بولغۇچى</lyrics>
<title>ئەرشتىكى ئەي ئۇلۇغ خۇدا Мн51</title>
</song>