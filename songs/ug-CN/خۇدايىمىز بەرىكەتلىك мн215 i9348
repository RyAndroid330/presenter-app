<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>215</hymn_number>
<author>نوۋوې پوكولېنىې تسېركوۋь گ. رىگا</author>
<title>خۇدايىمىز بەرىكەتلىك Мн215</title>
<lyrics>[C1]
.     D   A    Hm    G
   // خۇدايىمىز بەرىكەتلىك،
.  D      A     G
   خۇدا رەھىمدىلدۇر
.  D  A    Hm    G
   ۇنىڭ قولىدا ھەممە
.  D        A      G
   اسماندا، يەر۔يۈزىدە //

[V1]
.Hm         G            Em          A
 خۇدايىم مېنىڭ ئۆزىدەك قىلىپ مېنى ياراتتى
.Hm                G            Em    A
 خۇدايىم مېنىڭ ھەممىنى يارىتىپ بىزگە بەردى

[B1]
.  D
   خوشال قىلار ئۇ مېنى
.  Hm
   ھەيران قىلار ئۇ مېنى
.  G                        A
   ھەر كۇنى رەببىم مۆجۇزە يارىتىپ

[P1]
.  D
   سۆيەر ئۇ ھەممىنى
.  Hm
   سۆيەر ئۇ سېنىمۇ
.  G
   يول ئاچتى ھەممىگە
.  A
   گۇنادىن باشقىغا</lyrics>
<key>D</key>
</song>