<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hledám Tvoji tvář, Pane můj,
 hledám Tvoji tvář každý den.
 Po Tobě touží duše má,
 očekávám slovo Tvé.

[C1]
   Chci jít za Tebou, Ježíši,
   cestou Tvou,
   chci jít za Tebou, Ježíši.

[C2]
   Chci jít za Tebou, Ježíši,
   cestou Tvou,
   chci jít za Tebou, Ježíši,
   za Tebou.

[B1]
   Za Tebou, Pane můj,
   chci jít každý den,
   za Tebou, Pane můj,
   chci jít.</lyrics>
<title>Hledám Tvoji tvář ZM52</title>
<hymn_number>52</hymn_number>
<author>Martina Střítecká</author>
<tempo>Středně</tempo>
</song>