<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<presentation>V1 V2 V3 V4</presentation>
<lyrics>[V1]
 1. // Byl jsi tam, když byl Pán můj křižován? //
 Já jsem tam stál a hřích mne tížil
 mocí temnou, temnou, temnou.
 Pro můj hřích byl Pán Ježíš křižován.

[V2]
 2. // Byl jsi tam, když slib lotru dával Pán? //
 Já jsem tam stál a hřích mne tížil
 mocí temnou, temnou, temnou.
 Slibem tím těší i mne stále Pán.

[V3]
 3. // Byl jsi tam, když se v hrůze třásla zem? //
 Já jsem tam stál a hřích mne tížil
 mocí temnou, temnou, temnou.
 Vinou mou se tam v hrůze třásla zem.

[V4]
 4. // Byl jsi tam, když jej kladli v hrobu stín? //
 Já jsem tam stál a hřích mne tížil
 mocí temnou, temnou, temnou.
 Z lásky k nám vstoupil Ježíš v hrobu stín.</lyrics>
<title>Byl jsi tam? ZH59</title>
</song>