<?xml version="1.0" encoding="UTF-8"?><song><title>Slavme Pána s radostí ZH40</title>
<lyrics>[V1]
 1. Slavme Pána s radostí,
 zpívejme mu s vděčností.

[C1]
   Ref.: Nabízí nám milost svou,
   věrnou, jistou, trvalou.

[V2]
 2. Stvořil zemi slovem svým,
 tvůrčím slovem všemocným.

[V3]
 3. Štědře dlaň svou otvírá,
 všechno živé v péči má.

[V4]
 4. Proto tedy z radosti
 slavme Pána s vděčností.

[C2]
   Ref.: Nabízí nám milost svou,
   věrnou, jistou, trvalou.</lyrics>
<hymn_number>40</hymn_number>
<presentation>V1 C V2 C V3 C V4 C1</presentation>
</song>