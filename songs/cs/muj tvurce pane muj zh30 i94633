<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>30</hymn_number>
<presentation>V1 V2 V3</presentation>
<lyrics>[V1]
 1. Můj Tvůrce, Pane můj,
 co mám, je darem Tvým.
 // V mém životě mne posiluj
 a buď vždy Vůdcem mým. //

[V2]
 2. Jsem dílo rukou tvých,
 vždy v péči své mne máš,
 // Ty slyšíš prosby dítek svých
 a rád jim pomáháš. //

[V3]
 3. Nech mocně milost svou
 i ve mně působit,
 // mně Ducha dej, ať za Tebou
 v Tvé síle mohu jít. //</lyrics>
<title>Můj Tvůrce, Pane můj ZH30</title>
</song>