<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>83</hymn_number>
<tempo>Středně</tempo>
<lyrics>[V1]
 Hoden je Beránek, nejvyšší slávy
 On nás vykoupil, svou krví

[C1]
   Jenom Ty jsi na věky Král
   Jenom Tobě, patří sláva, Pane náš

[C2]
   Budem jásat nad Tvým vítězstvím,
   prapory pozdvihnem, ve jménu svého Boha</lyrics>
<title>Hoden je Beránek ZM83</title>
</song>