<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>91</hymn_number>
<author>Petr Zika</author>
<title>Buď touhou mého srdce ZM91</title>
<lyrics>[V1]
 Buď touhou mého srdce
 a žádostí mé duše,
 naplň můj život.

[C1]
   Ježíši, buď touhou mého srdce,
   Ježíši, jen Ty uhasíš mou žízeň,
   jedině Ty.</lyrics>
</song>