<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>75</hymn_number>
<author>Jana Brůžková</author>
<tempo>Pomalu</tempo>
<lyrics>[V1]
 Dáváš mi lásku vzácnou,
 dáváš mi přátelství,
 vždyť mám teď touhu jasnou
 jít na Tvé nádvoří.

[C1]
   Chválit Tvé svaté jméno,
   přebývat v Tvých hlubinách,
   v srdci mít lásku Tvou,
   jenom s ní žít</lyrics>
<title>Dáváš mi lásku vzácnou ZM75</title>
</song>