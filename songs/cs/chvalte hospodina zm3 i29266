<?xml version="1.0" encoding="UTF-8"?><song><title>Chvalte Hospodina ZM3</title>
<lyrics>[V1]
 Chvalte Hospodina,
 všichni národové,
 velebte Ho
 všichni lidé.

[C1]
   Neboť je rozšířená
   nad námi milost Jeho
   a pravda jeho navěky.
   Haleluja!</lyrics>
<tempo>Středně</tempo>
<hymn_number>3</hymn_number>
</song>