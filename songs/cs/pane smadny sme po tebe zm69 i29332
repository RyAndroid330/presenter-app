<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>69</hymn_number>
<title>Pane smädný sme po Tebe ZM69</title>
<lyrics>[V1]
 [: Pane smädný
 sme po Tebe,
 Pane smädný
 sme po Tebe :]

[V2]
 [: Nech táto oslava
 naplní ulice,
 chceme tancovať
 z lásky ku Tebe :]

[V3]
 [: A všetko čo mám
 dám na oltár,
 svoj život nesiem
 pred Tvoju tvár :]</lyrics>
</song>