<?xml version="1.0" encoding="UTF-8"?><song><title>Pane my ti děkujeme</title>
<key>Dm</key>
<lyrics>[V1]
. Dm
 Pane, my Ti děkujeme
.               Am         Dm
 za to, cos pro nás udělal.
.Dm
 Pane, my Ti děkujeme
.           Am                Dm
 za všechno to, co jsi nám dal

[C1]
.          F             C
   Díky za život, za lásku,
.          Dm                    Am
   díky za vítězství, za svobodu,
.         F         C               Dm
   za evangelium, za moc ke spasení.
.          F                  C
   Díky za Tvůj dokonalý plán,
.         Dm                  Am
   díky za slávu, již vyléváš,
.          Dm             Am                  Dm
   díky za volnou cestu do nebe pro národ náš.</lyrics>
<author>Kateřina Heroldová Grossová</author>
</song>