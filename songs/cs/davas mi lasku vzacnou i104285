<?xml version="1.0" encoding="UTF-8"?><song><author>Jana Brůžková</author>
<title>Dávaš mi lásku vzácnou</title>
<key>G</key>
<lyrics>[V1]
.G        D/F#  Em
 Dáváš mi lásku vzácnou,
.C                   D
 dáváš mi přátelství,
.G             D/F#  Em
 vždyť mám teď touhu jasnou
.C                  D
 jít na Tvé nádvoří.

[C1]
.                    G
   Chválit Tvé svaté jméno,
.  D/F#             Em
   přebývat v Tvých hlubinách,
.              C          Am
   v srdci mít lásku Tvou,
.             D
   jenom s ní žít</lyrics>
</song>