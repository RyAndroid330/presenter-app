<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hospodin kraluje,
 oděl se důstojností,
 oděl se Hospodin,
 mocí se opásal.

[V2]
 Pevně je založen svět,
 nic s ním neotřese,
 Tvůj trůn pevně stojí odedávna
 Ty jsi od věčnosti.

[C1]
   Zvedají řeky, Hospodine,
   zvedají řeky svůj hlas.
   zvedám i já, Hospodine,
   zvedám i já svůj hlas.</lyrics>
<title>Hospodin kraluje ZM93</title>
<hymn_number>93</hymn_number>
<author>Jiřina Marková</author>
<tempo>Pomalu</tempo>
</song>