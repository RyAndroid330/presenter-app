<?xml version="1.0" encoding="UTF-8"?><song><title>Pane buď vítaný ZM70</title>
<lyrics>[V1]
 Pane buď vítaný, v tomto chráme Ťa vítam,
 si tu Pánom.
 V našej chvále máš trón, Pane medzi nami bývaj -
 ruky dvíhame, srdcia dávame,
 Tebe klaniame sa, Ježiš bývaj v nás.</lyrics>
<hymn_number>70</hymn_number>
</song>