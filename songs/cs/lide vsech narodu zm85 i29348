<?xml version="1.0" encoding="UTF-8"?><song><title>Lidé všech národů ZM85</title>
<lyrics>[V1]
 Lidé všech národů
 tleskejte v dlaně
 hlaholte Bohu
 plesejte zvučně

[V2]
 Hospodin nejvyšší
 vzbuzuje bázeň
 On je Král veliký
 nad celou zemí.

[V3]
 On je Král veliký
 nad celou zemí,
 On je Král veliký
 nad celou zemí</lyrics>
<author>Karel Řežábek</author>
<hymn_number>85</hymn_number>
</song>