<?xml version="1.0" encoding="UTF-8"?><song><title>Ať jméno Ježíš zazní všem ZH84</title>
<lyrics>[V1]
 1. Ať jméno Ježíš zazní všem,
 ať zvučí do všech stran,
 // jej zdobí slávy diadém,
 vždyť Kristus Bůh je, Pán //

[V2]
 2. On z hříchu lidi vykoupil,
 byl pro nás křižován,
 // svou milostí nás zachránil,
 a proto náš je Pán //

[V3]
 3. Kéž každý národ na zemi
 zná Boží lásky plán,
 // ať oslaví jej písněmi
 a zpívá: Bůh je Pán //

[V4]
 4. Kéž brzy všichni vejdeme
 v ten Jeho věčný stan,
 // u nohou Krista padneme,
 vždyť On je Bůh a Pán //</lyrics>
<presentation>V1 V2 V3 V4</presentation>
<hymn_number>84</hymn_number>
</song>