<?xml version="1.0" encoding="UTF-8"?><song><title>Ježíši, můj Pane ZM88</title>
<lyrics>[V1]
 Ježíši, můj Pane,
 Ty jsi králů Král,
 Tys za mne život svůj dal.

[C1]
   Velebíme Tvoje svaté jméno,
   Ty jsi Bůh náš a Pán.</lyrics>
<hymn_number>88</hymn_number>
<author>Jan Hanning, Klára Valentová</author>
</song>