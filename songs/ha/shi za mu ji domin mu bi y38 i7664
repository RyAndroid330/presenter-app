<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>38</hymn_number>
<author>Sankey, Ira David (1840-1908), Cushing, William Orcutt (1823-1902)</author>
<title>Shi Za Mu Ji Domin Mu Bi Y38</title>
<lyrics>[V1]
 Shi za mu ji domin mu bi
 Hanyar da za ta gun Allah.
 Yesu Mai Ceton duniya duk
 Shi ne zai kai mu gun Allah.</lyrics>
</song>