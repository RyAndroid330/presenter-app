<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<title>Da Rai, da Rai, Mai Ceto Yana da Rai Y21</title>
<lyrics>[V1]
 Da rai, da rai, Mai Ceto yana da rai,
 Tare da ni ya kan tafi
 A duniyan nan lalle.
 Da rai, da rai, Mai Ceto ya fito Kabari.
 Labarin nan ya tabbata,
 Yesu 'na nan a zuciyata</lyrics>
</song>