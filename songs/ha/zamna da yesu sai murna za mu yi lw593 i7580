<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>593</hymn_number>
<title>Zamna da Yesu, Sai Murna Za Mu Yi LW593</title>
<lyrics>[V1]
 Zamna da Yesu, sai murna za mu yi
 A cikin gidansa
 Zamna da Yesu har abada.
 Yesu ya wanke ni, daga zunubi
 Zan yi godiya, zan bi shi kullum
 Har ran da za ya zo
 Ya kai ni gidan can
 Mu zamna tare...har abada.</lyrics>
</song>