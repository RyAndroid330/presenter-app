<?xml version="1.0" encoding="UTF-8"?><song><title>Wa Ke Wajen Allah, Wa Zai Bauta Shi LW534</title>
<lyrics>[V1]
 Wa ke wajen Allah, wa zai bauta shi,
 Wa zai taimake shi, shaida ƙamnarsa?
 Wa zai bar bin duniya, duka da tsohon rai?
 Wa ke wajen Allah, wa zai ci gaba?
 Muna wajen Allah, muna ƙamnarshi!
 Muna wajen Allah, mu na Allah ne!</lyrics>
<hymn_number>534</hymn_number>
</song>