<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1)Daga ina ne cetona zai zo
 Daga Ubangiji sarki mai daraja
 Daga Ubangiji babban marayu
 Cetona zai zo.

[V2]
 2) Daga El-shaddai wato Allah mai iko duka
 Jehovah Rapha Allah mai warkasuwa
 Jehovah Jire Allah mai tanadawa
 Cetona zai zo.

[V3]
 3) Daga El-Elyon wato Allah Maɗaukaki
 Jehovah Nisi Allah ne tutata
 Jehovah Ra'ah Allah Makiyayi
 Cetona zai zo.

[V4]
 4)Daga Adonai wato Allah Ubangiji
 Jehovah Shalom Allah ne salamata
 Jehovah Saba'oh Allah mai runduna
 Cetona zai zo

[V5]
 5)Daga El-Hai wato Allah ne rayayye
 Jehovah Mekoddishkem Allah Mai Tsarkakewa
 Jehovah Shammah Allah yana nan
 Cetona zai zo.</lyrics>
<title>Daga Ina Ne Cetona Zai Zo LW398</title>
<hymn_number>398</hymn_number>
</song>