<?xml version="1.0" encoding="UTF-8"?><song><title>Duba, Duba, A Ҡofar Zuciya LW405</title>
<lyrics>[V1]
 Duba, duba, a ƙofar zuciya,
 Yesu 'na nan, ji!
 Yana ƙwanƙwassawa.
 In ka ji muryarsa,
 Ka buɗe kofa kuwa,
 Zai shiga dai, ya ba ka rai,
 Ku zamna tare, har abada.</lyrics>
<hymn_number>405</hymn_number>
</song>