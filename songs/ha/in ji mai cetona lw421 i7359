<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>421</hymn_number>
<title>In Ji Mai Cetona LW421</title>
<lyrics>[V1]
 1) In ji Mai Cetona
 Kai ba ka iya ba
 Ni kaɗai Mai Cetonka
 Zan biya laifinka.

[V2]
 KORUS
 Shi ya biya duk
 Ni mai bashi ne
 Shi ya zubda jininsa
 Ya wanke zuciyata.

[V3]
 2) Jinin Ubangijina
 Jininsa ne kaɗai
 Ya wanke zuciyata
 Ya biya bashina.
 Korus

[V4]
 3) Ikon Yesu shi kaɗai
 Zai sake halina
 Ni ban iya kome ba
 Shi kaɗai Mai bada rai.
 Korus

[V5]
 4) Ran da zai dawo dai
 Zan tsaya gabansa
 Ba zan ji tsoro ba
 Don ya biya laifina.
 Korus</lyrics>
</song>