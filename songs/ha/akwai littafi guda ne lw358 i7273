<?xml version="1.0" encoding="UTF-8"?><song><title>Akwai Littafi Guda Ne LW358</title>
<lyrics>[V1]
 Akwai littafi guda ne
 Ke shaida kamnar Allah
 Akwai hanya guda kaɗai
 Ga Ubangijinmu.
 [ Littafi Mai Tsarki,
 Shi ne maganar Allah.
 Yesus shi kaɗai ne
 Hanya ga sama. ] 2x</lyrics>
<hymn_number>358</hymn_number>
</song>