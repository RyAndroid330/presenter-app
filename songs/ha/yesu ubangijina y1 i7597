<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1</hymn_number>
<author>Paul Baloche, Hastings, Thomas (1784-1872), Toplady, Augustus Montague (1740-1778)</author>
<lyrics>[V1]
 Yesu, Ubangijina,
 Kai Mai Iko duka ne,
 Sai ka ba ni nasara
 Cikin dukan jaraba.
 Sai ka ji addu'ata,
 Yesu, Ubangijina</lyrics>
<title>Yesu, Ubangijina Y1</title>
</song>