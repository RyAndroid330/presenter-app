<?xml version="1.0" encoding="UTF-8"?><song><author>Hatton, John (1710-1793), Watts, Isaac (1674-1748)</author>
<hymn_number>46</hymn_number>
<lyrics>[V1]
 1) Ya Yesu, Ubangijinmu,
 Wurinka muka zo yanzu.
 Kai ne mai sanin cutarmu,
 Kai ne mai ikon warkarwa.

[V2]
 2) Zunubanmu dayawa ne,
 Har ba mai ikon ƙirgawa,
 Sai kai kaɗai, Mai Cetonmu,
 Ya Yesu Ubangijinmu.

[V3]
 3) Ya Makiyayin Isra'ila,
 Kiyaye mu da ikonka,
 Domin mu shaida ƙaunarka,
 Tun daga yau har abada</lyrics>
<title>Ya Yesu, Ubangijinmu LW46</title>
</song>