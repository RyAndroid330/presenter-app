<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1) Nan gabas dubu suna ta mutuwa
 Ba su da maganar rai
 Nan yamma dubu suna ta kira
 Na mu da maganar rai.

[V2]
 KORUS
 Nan gabas, da yamma, arewa da gusum
 Mu tafi, mu tafi da maganar Allah
 Mu tafi, mu tafi, suna jiranmu can
 Mu tafi, mu tafi, don su sami tsira.

[V3]
 2) Arewa kuma dubu ke jira
 Ba su da sanin ceto
 Nan gusum suna ta biɗa
 Biɗan salamar Allah.
 Korus

[V4]
 3) Ga tafiyar dangi cikin wuta
 Ҡarƙarshin shari'a
 Fushin Allah bisansu zamne
 Muna da ƙofar rai.
 Korus</lyrics>
<title>Nan Gabas Dubu Suna Ta Mutuwa LW496</title>
<hymn_number>496</hymn_number>
</song>