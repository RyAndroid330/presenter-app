<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>261</hymn_number>
<lyrics>[V1]
 1) Zo, ku ji umarnin Yesu, (3x)
 Sai mutane duk su ji.

[V2]
 KORUS
 Yesu za ya taimake mu, (3x)
 Har mutane duk su ji.

[V3]
 2) Za mu yi bangaskiya, (3x)
 Har mutane duk su ji.
 Korus

[V4]
 3) Za mu je kowane gida, (3x)
 Har mutane duk su ji.
 Korus

[V5]
 4) Za mu ba da labari, (3x)
 Har mutane duk su ji.
 Korus

[V6]
 5) Za mu shaida wa yara, (3x)
 Har mutane duk su ji.
 Korus

[V7]
 6) Za mu yi musu addu'a, (3x)
 Har mutane duk su ji.
 Korus

[V8]
 7) Za mu hau cikin dutse, (3x)
 Har mutane duk su ji.
 Korus

[V9]
 8) Za mu daure shan wuya, (3x)
 Har mutane duk su ji.
 Korus

[V10]
 9) Za mu komo da murna, (3x)
 In mutane duk sun ji.
 Korus</lyrics>
<title>Zo, Ku Ji Umarnin Yesu LW261</title>
</song>