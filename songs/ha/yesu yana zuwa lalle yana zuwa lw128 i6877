<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>128</hymn_number>
<author>Thompson, Will Lamartine (1847-1909)</author>
<lyrics>[V1]
 1) Yesu yana zuwa, lalle yana zuwa,
 Yesu yana zuwa duniyan nan.
 Za ya tara Masu Binsa daga ko'ina,
 Ku yi shiri domin zuwansa.

[V2]
 KORUS
 Ku yi shiri, ku yi shiri!
 Ku yi shiri domin zuwansa
 Ku yi shiri, ku yi shiri
 Domin zuwansa.

[V3]
 2) Masu Binsa duka, Masu Binsa duka,
 Waɗanda su ke da shirinsu,
 Za a kai su Sama tare da Ubangiji
 Ku yi shiri domin zuwansa.
 Korus

[V4]
 3) Sai ku bar yin laifi, ku bar yin laifi,
 Sai ku bar yin laifi, Masu Bi.
 Babu sauran daman tuba ran da za ya zo,
 Ku yi shiri domin zuwansa.
 Korus

[V5]
 4) Sai mu yi addu'a, mu yi addu'a,
 Sai mu yi addu'a, Masu Bi,
 Don mu tarbe shi da murna ran da za ya zo,
 Mu yi shiri domin zuwansa.
 Korus

[V6]
 5) Sai mu yi ta aiki, mu yi ta aiki,
 Sai mu yi ta aiki, Masu Bi,
 Don mu kawo mutane dayawa gun Yesu
 Mu yi shiri domin zuwansa.
 Korus</lyrics>
<title>Yesu Yana Zuwa, Lalle Yana Zuwa LW128</title>
</song>