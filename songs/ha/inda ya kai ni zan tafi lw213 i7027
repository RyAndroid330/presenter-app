<?xml version="1.0" encoding="UTF-8"?><song><title>Inda Ya Kai Ni, Zan Tafi LW213</title>
<lyrics>[V1]
 1) Inda ya kai ni, zan tafi,
 Gama na saba binsa nan,
 Kuma na tuna, domina
 Yesu ya tafi Kalfari.

[V2]
 KORUS
 Za ya bishe ni ko'ina,
 Za ya bishe ni koyaushe,
 Ina tafiya tare da shi,
 Gama na tuna da Kalfari.

[V3]
 2) Jawabi nasa na ke bi,
 Muna tarayya, ni da shi,
 Daɗin nufinsa na ke ji,
 Gama na tuna da Kalfari.
 Korus

[V4]
 3) Inda ya kai ni, zan tafi,
 Tare da Yesu Mai Ceto,
 Gama na sani, domina
 Yesu ya tafi Kalfari.
 Korus</lyrics>
<hymn_number>213</hymn_number>
</song>