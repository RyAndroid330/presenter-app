<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ти възлюби мен
 толкоз много че
 даде своя Син единствен //

[C1]
   // Бях в тъмнина
   и в греха стоях
   заради мене Ти пострада //

[V2]
 // Ти отне от мен
 всеки грях за да съм
 спасен от съд Господи //

[C2]
   // Там на кръста Ти
   всичко победи
   и сега си жив Исусе //

[C3]
   // Бях в тъмнина
   и в греха стоях
   заради мене Ти пострада //</lyrics>
<title>Ти възлюби мен</title>
</song>