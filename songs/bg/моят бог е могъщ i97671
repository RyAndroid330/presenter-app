<?xml version="1.0" encoding="UTF-8"?><song><title>МОЯТ БОГ Е МОГЪЩ</title>
<lyrics>[V1]
 МОЯТ БОГ Е МОГЪЩ

[V2]
 МОЯТ БОГ Е МОГЪЩ
 ВСИЧКИ НУЖДИ
 МОИ СНАБДЯВА
 ОТ БОГАТСТВОТО СИ
