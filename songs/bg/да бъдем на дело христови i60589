<?xml version="1.0" encoding="UTF-8"?><song><title>Да бъдем на дело Христови</title>
<lyrics>[V1]
 //// Да не бъдем на име християни,
 а да бъдем на дело Христови.
 Този свят е лъжлив и измамлив
 гледа всички верни да заблуди. ////

[V2]
 // От грях и завист да се отделим,
 с всяка злоба с добра да победим.
 И нека правда и благодат,
 вярност и милоств нас да блести //</lyrics>
</song>