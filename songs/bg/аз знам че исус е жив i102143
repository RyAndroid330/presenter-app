<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Аз знам че Исус е жив
 Иде спасение то ми //

[C1]
   // Исус е жив, жив е той
   Където и дае //
   // Очите Ми ще видят
   Лицето на Исус //

[V2]
 // Само със кръвта на Исус
 Ще Се спасим от греха //

[V3]
 // Има една отворена врата
 За Теб и за мен //</lyrics>
<title>Аз Знам Че Исус Е Жив</title>
</song>