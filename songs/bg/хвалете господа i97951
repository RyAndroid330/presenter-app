<?xml version="1.0" encoding="UTF-8"?><song><title>ХВАЛЕТЕ ГОСПОДА</title>
<lyrics>[V1]
 ХВАЛЕТЕ ГОСПОДА

[V2]
 ХВАЛЕТЕ ГОСПОДА
 ОТ НЕБЕСАТА,
 ХВАЛЕТЕ ГОСПОДА
 ВЪВ ВИСИНИТЕ,

[V3]
 ХВАЛЕТЕ ГО ВСИЧКИ АНГЕЛИ.
 ХВАЛЕТЕ ГО
