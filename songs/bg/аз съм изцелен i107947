<?xml version="1.0" encoding="UTF-8"?><song><title>Аз съм изцелен</title>
<lyrics>[V1]
 АЗ СЪМ ИЗЦЕЛЕН

[V2]
 // Аз съм изцелен и освободен
 в кръвта на Иисус
 и чрез неговите рани //

[V3]
 ПРИПЕВ:
 // Има сила в устата на човека
 Има сила в кръвта на Агнето
 призови го чакай го и той ще дойде //

[V4]
 // Благодат и мир да умножи
 в нашите сърца да живее Иисус //</lyrics>
</song>