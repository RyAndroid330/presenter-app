<?xml version="1.0" encoding="UTF-8"?><song><title>ДЕТЕ РОДИ СЕ ДНЕС</title>
<lyrics>[V1]
 ДЕТЕ РОДИ СЕ ДНЕС

[V2]
 verse1
 ДЕТЕ РОДИ СЕ ДНЕС ЗА НАС, / 2
 ДНЕС СЛАВАТА НА БОГ,
 ДАДЕ ЖИВОТ ЗА ЦЕЛИЯ СВЯТ

[V3]
 chorus1
 О, ИСУС РОДЕН Е В ТОЗ ДЕН,
 СВЕТИ И НОСИ СПАСЕНИЕ
 О, ИСУС РОДЕН Е В ТОЗ ДЕН,
 ЦАР Е НАД ВСИЧКО И ГОСПОД

[V4]
 verse2
 БОГ ПРАТИ СВОЯ СИН ЕДИН, / 2
 ЕТО ПОДАРЪК ЗА НАС
 С ЛЮБОВ ОТ ОТЦА,
 ЗА ВСЕКИ ЧОВЕК

[V5]
 chorus2
 О, ИСУС РОДЕН Е В ТОЗ ДЕН,
 НЕБЕСНО ДЕТЕ НА ЗЕМЯТА
 О, ИСУС РОДЕН Е В ТОЗ ДЕН,
 ЦАР Е НАД ВСИЧКО И ГОСПОД

[V6]
 verse3
 ДНЕС РАДВАМЕ СЕ В ТОЗИ ДЕН, / 2
 ДНЕС СВЕТЛИНАТА ОТ НЕГО
 НИ ИЗПЪЛВА СЪС ПОЧИТ
 И НОСИ НИ МИР

[V7]
 chorus
 О ИСУС РОДЕН Е В ТОЗ ДЕН,
 НЕБЕСНО ДЕТЕ НА ЗЕМЯТА
 О ИСУС РОДЕН Е В ТОЗ ДЕН,
 ЦАР Е НАД ВСИЧКО И ГОСПОД

[V8]
 ДЕТЕ РОДИ СЕ ДНЕС ЗА НАС
 ТОЙ Е ЦАР,
 ТОЙ Е БОГ,
 ТОЙ Е ЖИВ,
 ДНЕС НА РОЖДЕСТВО.</lyrics>
</song>