<?xml version="1.0" encoding="UTF-8"?><song><title>НЕЖНО ТИ МИНАВАШ</title>
<lyrics>[V1]
 НЕЖНО ТИ МИНАВАШ

[V2]
 НЕЖНО ТИ МИНАВАШ
 ПОКРАЙ МЕН,
 ЧУВСТВАМ ТЕ СЕГА ДО МЕН.
 НЕЖНО ГАЛИШ МЕ С РЪКА,
 ТИ РАЗТАПЯШ МОЯТА ДУША.

[V3]
 ИСУСЕ, ИСУСЕ,
 ДЕН И НОЩ СИ ТИ ДО МЕН.
 КАК ДА ТИ СЕ ОТПЛАТЯ -
 ОСВЕН ЖИВОТА СИ
 ДА ТИ ДАРЯ.

[V4]
 СЛЪНЦЕ СИ В ЖИВОТА МИ,
 ТИ ОГРЯВАШ ПЪТИЩАТА МИ.
 СЛЪНЦЕ СИ В ЖИВОТА МИ,
 БЕЗ ТЕБ НЕ МОГА, ГОСПОДИ!</lyrics>
</song>