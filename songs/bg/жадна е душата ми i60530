<?xml version="1.0" encoding="UTF-8"?><song><title>Жадна е душата ми</title>
<key>Gm</key>
<lyrics>[V1]
.   Gm           G#
 // Избави ме от тъмнината
.Cm            Bb    Gm
 Постави ме на светлина
.Eb                G#
 Огря в мен душата мрачна
.Bb          Fm             Gm
 Ти Боже Мой изтрий сълзите ми //

[V2]
.   Cm                             G#
 // Жадна е душата ми, жадна е за Теб
.Bb              Fm         Gm
  При тихи води сега Ти Ме води
.Cm                         G#
  Освети душата ми помажи сърцето ми
.Bb               Fm     Eb
  Ти Си Пастир на живота ми //

[V3]
 // Изля Ти в мене духът си святий
 Постави ме на светлина
 Жадува в мене душата жадна
 За Теб Исусе за Твоята Любов //</lyrics>
</song>