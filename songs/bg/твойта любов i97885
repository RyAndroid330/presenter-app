<?xml version="1.0" encoding="UTF-8"?><song><title>ТВОЙТА ЛЮБОВ</title>
<lyrics>[V1]
 ТВОЙТА ЛЮБОВ

[V2]
 ТВОЙТА ЛЮБОВ
 Е ВИНАГИ ТУК ДО МЕН,
 ВЕЛИКА Е - АЗ ЗНАМ, ТЪЙ ЦЕННА Е!
 КАКВО ДА ТИ ДАМ, НЕ ЗНАМ,
 В МЕН ВСИЧКО Е ОТ ТЕБ.
 ЕДИНСТВЕНО ОТ ЛЮБОВ НУЖДАЯ СЕ!

[V3]
 ТИ СИ МОЙ БОГ,
 ТИ СИ МОЙ ЦАР!
 И МОЙТО СЪРЦЕ
 ТЕ ХВАЛИ СЕГА!

[V4]
 И ПЕЯ ЗА ТЕБ,
 ЗА ВСИЧКИТЕ ЧУДЕСА,
 И АЗ ТЕ ОБИЧАМ - ЗНАЕШ ТОВА
 ИСУС, ИСУС!</lyrics>
</song>