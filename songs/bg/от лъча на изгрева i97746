<?xml version="1.0" encoding="UTF-8"?><song><title>ОТ ЛЪЧА НА ИЗГРЕВА</title>
<lyrics>[V1]
 ОТ ЛЪЧА НА ИЗГРЕВА

[V2]
 ОТ ЛЪЧА НА ИЗГРЕВА,
 ДО ЛЪЧА НА ЗАЛЕЗА
 ИМЕТО НА БОГА Е
 ДОСТОЙНО ЗА ХВАЛА
 ВЕСЕЛИ СЕ НЕБЕ, РАДВАЙ СЕ ЗЕМЯ
 И ВСИЧКО ЩО ДИША
 НЕКА ХВАЛИ ГОСПОДА

[V3]
 ИЗДИГАМ КЪМ ТЕБ СЪРЦЕ
 ИЗДИГАМ КЪМ ТЕБ ДУШАТА СИ
 ИЗДИГАМ КЪМ ТЕБ РЪЦЕ
 ПОКЛАНЯМ СЕ!</lyrics>
</song>