<?xml version="1.0" encoding="UTF-8"?><song><title>Обичам Те, Желая Те</title>
<aka>О, Исусе</aka>
<key>Dm</key>
<lyrics>[V1]
.   Dm              C
 // О, Исусе, Татко мой
.Bb              A
 Ти - прекрасен, аз съм Твой. //
.   Dm        Bb    C
 // Обичам Те, желая Те
.F     Bb       A
 От сърце търся Те. //

[V2]
 // Искам с Тебе да живея
 Да те хваля и да пея. //

[V3]
 // Любовта Ти е огромна
 Тя омразата изгонва. //</lyrics>
</song>