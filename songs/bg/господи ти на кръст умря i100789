<?xml version="1.0" encoding="UTF-8"?><song><aka>Песен На Спасението</aka>
<lyrics>[V1]
 // Господи Ти на кръст умря
 възкръстна и спаси света
 мойте грехове прости
 Спасител мой Приятел Си //

[C1]
   // Нов живот аз имам днес
   Със Теб Исус за винаги //

[V2]
 Нов живот аз имам днес
 Със Теб Исус за винаги
 Нов живот аз имам днес
 Спасение в Теб Исус сега и винаги</lyrics>
<title>Господи Ти На Кръст Умря</title>
</song>