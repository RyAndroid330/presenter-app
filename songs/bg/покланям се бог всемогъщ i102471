<?xml version="1.0" encoding="UTF-8"?><song><author>Дон Моен</author>
<title>ПОКЛАНЯМ СЕ БОГ ВСЕМОГЪЩ</title>
<lyrics>[V1]
 ПОКЛАНЯМ СЕ БОГ ВСЕМОГЪЩ

[V2]
 Покланям се,
 Бог Всемогъщ,
 несравним си Ти!

[V3]
 Покланям се,
 о, Княз на мир,
 искам вечно
 да съм с Теб!

[V4]
 Аз хваля Те, Ти си
 мойта праведност!</lyrics>
<aka>ПОКЛАНЯМ СЕ, ПОКЛАНЯМ СЕ СПАСИТЕЛЮ</aka>
</song>