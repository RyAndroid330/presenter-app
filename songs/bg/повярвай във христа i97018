<?xml version="1.0" encoding="UTF-8"?><song><title>ПОВЯРВАЙ ВЪВ ХРИСТА</title>
<key>F</key>
<lyrics>[V1]
 ПОВЯРВАЙ ВЪВ ХРИСТА

[V2]
.F        Gm      C
 ПОВЯРВАЙ ВЪВ ХРИСТА,
.C7        B    F
 ПРЕДАЙ СЪРЦЕТО СИ.
.        Gm
 ТОЙ Е ДОШЪЛ ЗА ТЕБ,
.C           F
 ЗА ДА ТЕ СПАСИ.

[V3]
.F        Gm        C
 ЗНАЙ ИМА МИЛОСТ ЗА ТЕБ
.C7         B      F
 ПРИ КРЪСТА НА ХРИСТА!
.            Gm
 НЕ ОТЛАГАЙ, НО СЕГА
.C              F
 ЗА ПРОШКА СЕ МОЛИ!

[V4]
.F           Gm       C
 ЗНАЙ ТОЙ ЗА ТЕБ ОТ ЛЮБОВ
.C7       B    F
 ДОЙДЕ НА ТОЗИ СВЯТ,
.                 Gm
 ЗА ДА ЖИВЕЕШ ВЪВ ВЕЧНОСТТА -
.C              F
 ЗА ТЕБЕ ТОЙ ДОЙДЕ!

[V5]
.F       Gm     C
 МОЛИ СЕ НА ХРИСТА,
.C7        B    F
 ПРЕДАЙ СЪРЦЕТО СИ.
.        Gm
 ТОЙ Е ДОШЪЛ ЗА ТЕБ,
.C           F
 ЗА ДА ТЕ СПАСИ.</lyrics>
</song>