<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 НЕЩО ДА ТИ ДАМ

[V2]
 ТАЗИ ВЕЧЕР ИСКАМ
 НЕЩО ДА ТИ ДАМ,
 НО КАКВО ДА БЪДЕ
 АЗ НЕ ЗНАМ.
 ВСИЧКО ЩО Е В МЕНЕ,
 ВСИЧКО НА СВЕТА,
 ЧУДЕСАТА НА НЕБЕТО
 ТВОИ СА.

[V3]
 ТИ ДОЙДЕ И ДАДЕ
 СЪРЦЕТО СИ.
 ТИ ДОЙДЕ И ДАДЕ
 ДОРИ ЖИВОТА СИ.
 ТИ ДОЙДЕ И ДАДЕ
 НОВ ЖИВОТ ЗА ВСЕКИ,
 ТИ ДОЙДЕ И ДАДЕ
 СЪРЦЕТО СИ.

[V4]
 СЛОВОТО ТИ УЧИ
 ДА БЪДЕМ КАТО ТЕБ,
 В НАЙ-МАЛКОТО
 ДА БЪДЕМ ВЕРНИ,
 СЛУГИ С ЛЮБОВ
 НА ВСЕКИ ЧОВЕК.
 ТАЗИ ВЕЧЕР ИСКАМ
 НЕЩО ДА ТИ ДАМ,
 НО КАКВО ДА БЪДЕ
 ВЕЧЕ ЗНАМ.

[V5]
 АЗ ЩЕ ДОЙДА И ЩЕ ТИ ДАМ
 СЪРЦЕТО СИ,
 АЗ ЩЕ ДОЙДА И ЩЕ ТИ ДАМ
 ДОРИ ЖИВОТА СИ,
 АЗ ЩЕ ДОЙДА
 И ЩЕ ПРЕКАРАМ
 ВЕЧНОСТТА СЪС ТЕБЕ
 АЗ ЩЕ ДОЙДА И ЩЕ ТИ ДАМ
 СЪРЦЕТО СИ.</lyrics>
<title>НЕЩО ДА ТИ ДАМ</title>
</song>