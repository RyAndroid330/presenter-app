<?xml version="1.0" encoding="UTF-8"?><song><title>КАК ТЕ ОБИЧАМ</title>
<lyrics>[V1]
 КАК ТЕ ОБИЧАМ

[V2]
 КАК ТЕ ОБИЧАМ,
 ТИ СИ МОЙ БОГ,
 ТИ СИ ЕДИНСТВЕН.
 КАК ТЕ ОБИЧАМ,
 ТИ СИ ЕДИНСТВЕН ЗА МЕН.

[V3]
 БЯХ ИЗГУБЕН -
 ПОКАЗА МИ ПЪТ,
 ЗАЩОТО СИ ПЪТЯ.
 БЯХ ИЗГУБЕН,
 НО ТИ МИ ПОКАЗА ПЪТ.

[V4]
 БЯХ ИЗМАМЕН -
 НО ТИ МИ РАЗКРИ
 ИСТИНА ЧУДНА.
 БЯХ ИЗМАМЕН,
 НО ИСТИНА ТИ СИ ЗА МЕН.

[V5]
 АЗ УМИРАХ - НО ДАДЕ ЖИВОТ,
 И ТИ СИ ЖИВОТА.
 АЗ УМИРАХ,
 НО ТИ МИ ДАРИ ЖИВОТ.</lyrics>
</song>