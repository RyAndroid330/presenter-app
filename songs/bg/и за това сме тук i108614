<?xml version="1.0" encoding="UTF-8"?><song><title>И за това сме тук</title>
<aka>ИДВАМЕ ПРИ ТЕБЕ С ПЕСЕН, ЗАТОВА СМЕ ТУК</aka>
<lyrics>[V1]
 ИДВАМЕ ПРИ ТЕБЕ С ПЕСЕН

[V2]
 ИДВАМЕ ПРИ ТЕБЕ С ПЕСЕН,
 ИДВАМЕ ПРИ ТЕБЕ С ХВАЛА,
 С БЛАГОДАРНОСТ ИДВАМЕ,
 НИЕ ЩЕ ПРАЗНУВАМЕ.

[V3]
 С НАС Е И НЕБЕТО,
 СИЛАТА Е ТУК
 И С ВИК: &quot;АЛЕЛУЯ&quot;
 ВЕЛИЧАЕМ И ХВАЛИМ ТЕБ СЕГА.

[V4]
 САМО ТИ ДОСТОЕН СИ
 ЗА ПОЧИТ И ХВАЛА.
 ТЕБЕ ХВАЛИМ, ИСУС
 И ЗАТОВА СМЕ ТУК.
 ВСИЧКО ВЪТРЕ В МЕНЕ
 СЕ СТРЕМИ КЪМ ТЕБ,
 КЪМ СИЛА, ВЕЛИЧИЕ,
 МИЛОСТ, БЛАГОДАТ.

[V5]
 ИМА ПЕСНИ, ТАНЦИ
 И ВЕСЕЛИЕ.
 ТИ НИ ДАДЕ СВОБОДА,
 ПЪЛНИ СМЕ С ХВАЛЕНИЕ.</lyrics>
