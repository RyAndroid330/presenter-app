<?xml version="1.0" encoding="UTF-8"?><song><aka>Кат Давид</aka>
<lyrics>[V1]
 // Щом Духъ на Бога е във сърцето ми,
 Аз ще пея кат Давид. //
 // Аз ще пея, Аз ще пея,
 Аз ще пея кат Давид! //

[V2]
 // Щом Духъ на Бога е във сърцето ми,
 Аз ще пляскам кат Давид. //
 // Аз ще пляскам, Аз ще пляскам ,
 Аз ще пляскам кат Давид. //

[V3]
 // Щом Духъ на Бога е във сърцето ми,
 Ще се моля кат Давид. //
 // Ще се моля, ще се моля,
 Ще се моля кат Давид. //

[V4]
 // Щом Духъ на Бога е във сърцето ми,
 Хваля Бога кат Давид. //
 // Хваля Бога, хваля Бога,
 Хваля Бога кат Давид. //

[V5]
 // Щом Духъ на Бога е във сърцето ми,
 Ще се радвам кат Давид. //
 // Ще се радвам, ще се радвам,
 Ще се радвам кат Давид. //</lyrics>
<title>Щом Духът на Бога в Сърцето ми</title>
</song>