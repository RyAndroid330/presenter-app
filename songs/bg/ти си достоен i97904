<?xml version="1.0" encoding="UTF-8"?><song><title>ТИ СИ ДОСТОЕН</title>
<lyrics>[V1]
 ТИ СИ ДОСТОЕН

[V2]
 ТИ СИ ДОСТОЕН,
 ТИ СИ ДОСТОЕН,
 ТИ СИ ДОСТОЕН, ГОСПОДИ!
 ДА ПРИЕМЕШ СЛАВА,
 СЛАВА И ПОЧИТ,
 СЛАВА, И ПОЧИТ, И ВЛАСТ!

[V3]
 ЗАЩОТО СЪЗДАЛ СИ
 ТИ ВСИЧКИ ТВОРЕНИЯ -
 ВСИЧКО СЪЗДАЛ СИ ЗА ТЕБ!
 ЗА ТВОЯ СЛАВА
 ТИ НИ СЪЗДАДЕ.
 ТИ СИ ДОСТОЕН И СВЯТ!</lyrics>
</song>