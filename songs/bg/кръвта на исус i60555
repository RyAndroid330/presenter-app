<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Кръвта на Исус е върху мен,
 и в този час аз съм простен. //

[C1]
   // Благословен съм, изцерен съм
   от Кръвта На Исус.
   Измит съм, освободен съм
   от Кръвта на Исус. //

[V2]
 // Ридай и търси Божията кръв,
 Защото ценна е за теб. //

[C2]
   Ще бъдеш благословен, изцерен.
   Измит, освободен от кръвта на Исус.</lyrics>
<title>Кръвта На Исус</title>
</song>