<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7013</hymn_number>
<lyrics>[V1]
 Аз имам радост

[V2]
.        D/G
 Аз имам радост! (2)
.   D
 От Божия трон се излива
.     A
 жива вода във мен.

[V3]
 Аз имам радост! (2)
.      D
 Записано,
.     A            D
 моето име е записано,
.         A        D
 там на небето е за писано,
.          A             G;D
 в книгата на живот. Алилуя!</lyrics>
<key>D</key>
<title>Аз имам радост</title>
</song>