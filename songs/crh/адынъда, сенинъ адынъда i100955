<?xml version="1.0" encoding="UTF-8"?><song><title>Адынъда, Сенинъ адынъда</title>
<key>Am</key>
<lyrics>[V1]
.   Am       (Dm)     Am
 //  Адынъда, Сенинъ адынъда
