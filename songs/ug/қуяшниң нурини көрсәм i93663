<?xml version="1.0" encoding="UTF-8"?><song><title>Қуяшниң нурини көрсәм</title>
<lyrics>[V1]
 // Қараңғу һоҗирәмдин
 Далаға чиқсам
 Қуяшниң нурини көрсәм //

[C1]
   // Һәқиқәтниң һөрлүкниң
   Һозурини сүрсәң //
   О-о-о

[V2]
 // Пасихтин яманлиқтин
 Хали болсам
 Биликни һекмәтни билсәм //

[C2]
   Чин бәхитниң ичидә
   Яшнисам күлсәм
   О-о-о</lyrics>
</song>