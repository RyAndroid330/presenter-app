<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>32</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em              D
 Әй Ата, мәдһийәм Саңа
.            C
 Тәхтиңниң алдида
 Шүкүрләр ейтип
.D         B
 Улуқлаймән Сени.

[V2]
.Em              D
 Әйса қиммәтлик Сән маңа
.                 C
 Саңа тәңдаш һеч ким йоқ
.C          D
 Пәқәт Сән лайиқсән
.B          Em
 Сән лайиқсән мәдһийәмгә.

[C1]
.     Em Am     D     G  Em
   // Апирин Саңа! Апирин Саңа!
.  Em     Am
   Апирин Саңа!
.  B      Em
   Рәббим Әйса! //

[B1]
.         Am    D
   // Сөйимән Сени,
.     G     C
   Сөйимән Сени
.      Am    B
   Сөйимән Сени,
.         Em
   Рәббим Әйса! //

[B2]
   Мәдһийәм Саңа,
   Мәдһийәм Саңа
   Мәдһийәм Саңа
   Рәббим Әйса!</lyrics>
<title>Әй Ата М32 И35 Мн15</title>
</song>