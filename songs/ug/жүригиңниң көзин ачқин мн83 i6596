<?xml version="1.0" encoding="UTF-8"?><song><title>Жүригиңниң көзин ачқин Мн83</title>
<lyrics>[V1]
.Cm         Fm
 Жүригиңниң көзин ачқин
.Bb           Eb
 Бүгүн сөзләр У саңа
.Cm        Fm
 Қәлбиңни, һаятиңни
.Gm       Cm
 Әйсаға ата

[P1]
.     Ab          Bb
   // Көңүл ағриқ өтүп кәтсун
.  Eb       F
   Адалитиңни ташла
.  Ab         Bb
   Мошу күнни Мәсиһ билән
.  Gm          Cm
   Йеңидин башла //

[C1]
.     Cm         Ab
   // Күч бәрсун һәр бир сөзүң
.  Bb       Eb
   Ажиз жанға
.  Cm         Fm
   Мәсиһ сени талливалған
.  Bb        Cm
   Өз һозуриға //

[V2]
.Ab        Fm
 Гуна үчүн Әйса қени
.Gm          Cm
 Чедир болуп йепилған
.Cm            Fm
 Йеңи адәм сән муқәддәс
.Bb         Cm
 Һәм пакланған

[P2]
.     Ab           Bb
   // Сән муқәддәс йәр-йүзидин
.  Eb        F
   Чақирилип елинған
.  Ab         Bb
   Мәсиһниң муһәббитидин
.  Gm           Cm
   Бәһирман болған //</lyrics>
<key>Eb</key>
<hymn_number>83</hymn_number>
<author>Рахиль Ысыева</author>
</song>