<hymn_number>189</hymn_number>
<title>Сән - һаят нәпәсим Мн189</title>
<key>G</key>
<lyrics>[V1]
.   G           C7      G
 //  Сән - һаят нәпәсим!
.G          C7      G
 Сән - һаят нәпәсим!
.  D7   Em  C     D
 Муһәббитиң яшар мәндә! //

[C1]
.       G/D/Em     C    D
   // Саңа тәшна жүригим!
.     G/D/Em      C    D
   Сәнсиз набуд жүригим! //

[V2]
 // Сән - күндилик неним!
 Сән - күндилик неним!
 Сениң сөзүң жүригимдә! //

[B1]
.        D        C     D
   /// ...тәшна жүригим!
.    D        C     D
   ...набуд жүригим! ///</lyrics>
</song>