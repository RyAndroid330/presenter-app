<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<title>Кәчүргин Худа Мн104</title>
<lyrics>[V1]
 // Кәчүргин Худа
 Кәчүргин мени
 Гуна өткүздүм
 Тонумай Сени //

[V2]
 // Өртинәр қәлбим
 Шуңа азапта
 Көйәрмәнму дәп
 Әнди дозақта //

[V3]
 // Шүкри Рәб Әйса
 Қутқуздуң мени
 Күйләймән әнди
 Гөзәл намиңни //

[V4]
 // Шүкри әй Худа
 Күйләймән Сени
 Ғәлпәт қойнидин
 Қутқуздуң мени //</lyrics>
</song>