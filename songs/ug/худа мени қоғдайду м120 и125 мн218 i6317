<lyrics>[C1]
.     Am
   // Нәдин келәр, ярдәм дәп
.  G            Am
   Мән тағларға қараймән
.  Am           Dm
   Ярдәм келәр Худадин
.  E           Am
   Асман йәрни яратқан. //

[V1]
.   Am
 // Бәхитсиз болушумға
.F            Am
 Худа һеч йол қоймайду //
.   Am         Dm
 // Қоғдиғучим сәгәк болуп
.E          Am
 Уни ғәпләт басмайду. //

[V2]
.   Am
 // Худа мени қоғдайду
.F            Am
 Аптаптин һәм сақлайду //
.    Am          Dm
 // Күндүзи күн, кечиси ай
.E          Am
 Маңа зиян қилмайду //

[V3]
.   Am
 // Қәйәрләрдә жүрсәмму
.F          Am
 Худа мәңгү қоғдайду //
.    Am        Dm
 // Яманлиқтин қутқузуп
.E        Am
 Һаятимни сақлайду. //</lyrics>
