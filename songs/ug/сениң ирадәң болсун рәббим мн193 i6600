<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>193</hymn_number>
<title>Сениң ирадәң болсун Рәббим Мн193</title>
<key>F</key>
<lyrics>[V1]
.Dm             Bb
 Сениң ирадәң болсун Рәббим
.   Gm           A     Asus
 Паклиғин мени Өз қениң билән
.Dm               Bb
 Шәрәпликтурсән Муқәддәс Худа
.   Gm           A     Asus
 Паклиғин мени Өз Сөзүң билән

[C1]
.     D7       Gm      C7
   // Сән болмисаң адишимән
.          F      A      Bb
   Пәрвәрдигар йол көрсәткин
.         Gm          A
   Таянчим Сән Нижаткарим
.  Asus    Dm
   Муқәддәс Сән //

[B1]
.     Dm  Bb                    F Gm Dm
   //  Паклиғин мени қениң билән
.  Dm/Bb                           F Gm Dm
    Муқәддәс Сөзүң мәндә болғай //

[B2]
.     Dm      C   Bb         F/Dm
   //  Пәрвәрдигар мени пакла
.  Dm      C  Bb             F
   Қудритиңдә кәлгин маңа //</lyrics>
</song>