<?xml version="1.0" encoding="UTF-8"?><song><author>Қуддус ака</author>
<hymn_number>35</hymn_number>
<title>Әйса достум М35 И37 Мн19</title>
<lyrics>[V1]
.Dm              A
 Әйса мениң мәңгү Достум
.Gm            Dm
 Худа билән яраштурған.
.   Dm            Gm
 // Тенәп жүргән мән үчүн
.A                Dm
 Әйса достум ишик ачқан. //

[C1]
.  Gm
   Әйса бизгә ишик ачти,
.     Dm(A)                Dm
   // Кәлгин достум, қутул достум. //
.  Gm
   Бу дуния бақи әмәс,
.     Dm(A)               Dm
   // Кәлгин достум, ишән достум. //

[V2]
 Бәзи адәм ишәнмәстин
 Гуналарға петип жүрәр.
 // Әйса достум қолини сунса,
 Қолини бәрмәй қечип жүрәр. //

[V3]
 Бебаһа қени билән
 Әйса достум һаят бәрди.
 // Өлүм йолидин қутқузуп
 Яшисун дәп өмүр бәрди. //</lyrics>
<key>Dm</key>
</song>