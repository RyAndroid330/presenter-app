<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>216</hymn_number>
<author>Әйса җамаәт</author>
<lyrics>[V1]
.   Dm
 // Худайим улуқтур,
.Bb
 Худа меһривандур,
.Gm           A7  Dm/A7
 Худа тамамән адилдур,
.Dm                  Gm      A7
 Худа һәммини көриду вә аңлайду. //

[C1]
.  Gm            C
   Һәмдусана, һәмдусана
.       F        Bb
   Намиңға, Намиңға,
.    Gm            A7
   Қобул қилдим һаятлиқни,
.      Dm      D7
   Өзәңни мәңгүгә.
.     Gm             C
   Мәдһийиләймән, мәдһийиләймән,
.      F          Bb
   Бир Сени, Худайим,
.  Gm        A7        Dm/D7
   Мубарәктурсән Ялғуз Өзәң.

[V2]
.   Dm
 // Худа муқәддәстур,
.Bb
 Худа қудрәтликтур,
.Gm         A7       Dm/A7
 Худа меһир-шәпқәтликтур,
.Dm                  Gm       A7
 Худа һәммини билиду әмәл қилиду. //</lyrics>
<key>F</key>
<title>Худайим улуқтур Мн216</title>
</song>