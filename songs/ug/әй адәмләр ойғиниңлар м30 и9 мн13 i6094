<?xml version="1.0" encoding="UTF-8"?><song><author>Қуддус ака</author>
<hymn_number>30</hymn_number>
<key>Am</key>
<lyrics>[V1]
.Am
 Әй адәмләр, ойғиниңлар,
.Dm                Am
 Хуш-хәвәрни аңлап қелиңлар.
.   Dm                   Am
 // Бизләр үчүн қурван болған
.E                 Am
 Рәб Әйсани мәдһийиләңлар. //

[C1]
.  Dm             Am
   Көйүмчан мәдәткарим,
.  Am    E         Am
   Панайимсән җан сөйәр.
.     Dm                Am
   // Мәңгүлүккә һаят бәргән
.  Am    E        Am
   Қутқазғучи Мәсиһсән. //

[V2]
 Әй адәмләр, ойғиниңлар,
 Һәқиқәтни билип қелиңлар.
 // Мәсиһ билән биргә болуп,
 Тәшналиққа петип қелиңлар. //</lyrics>
<title>Әй адәмләр ойғиниңлар М30 И9 Мн13</title>
</song>