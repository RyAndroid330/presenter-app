<?xml version="1.0" encoding="UTF-8"?><song><author>Қуддус ака</author>
<hymn_number>67</hymn_number>
<lyrics>[V1]
.   Am7
 // Шүкри демәсмән дуния
.Dm
 Гунаға патқан дуния
.E7
 Дуния, езиққан дуния
.           Am
 Това қил, қутул дуния. //

[C1]
.     Am
   // Кәлмәс еди Рәббимиз
.  Dm
   Сени мени сөймисә
.  E7
   Өлмәс еди Рәббимиз
.             Am
   Бу дунияға көймисә. //

[V2]
 // Әйса кәлсә дунияға
 Дуния Рәбни тонимиди
 Езиққанлар шәйтанға
 Рәбни дарға миқлиди. //

[V3]
 // Әйса бизни сөйиду
 Әйса бизгә көйиду
 Қутул дуния, қутул дуния
 Әйса қайтип келиду. //</lyrics>
<key>Am</key>
<title>Қутул дуния М67 И64 Мн117</title>
</song>