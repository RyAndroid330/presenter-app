<?xml version="1.0" encoding="UTF-8"?><song><aka>Башқа қайғу чүшкәндә</aka>
<lyrics>[V1]
.   D
 // Башқа қайғу чүшкәндә
.D               Em
 Рәббим Сени яд әткәй
.Em             A
 У муқәддәс җайидин
.A                 D
 Мәдәт берип яр болғай //

[C1]
.     D            Bm
   // Сениң бәргән қурванлиғиң
.  Bm          G
   Худани рази қилғай
.  G           Em
   Сениң тәшна қәлбиңгә
.  A                D
   Нурлирини яғдурғай //
.     G          D
   // Нурлирини, Нурлирини,
.  Em      A      D
   Нурлирини яғдурғай. //

[V2]
.   D
 // Ниҗатлиққа еришип
.D                  Em
 Мән шатлиққа тоймаймән
.Em            A
 Худайимиз намиға
.A                D
 Шан-шәрәпләр ейтимән //</lyrics>
<key>D</key>
<title>Рәббим Сени яд әткәй Мн166 И96 М97</title>
<author>Қуддус ака</author>
<hymn_number>166</hymn_number>
</song>