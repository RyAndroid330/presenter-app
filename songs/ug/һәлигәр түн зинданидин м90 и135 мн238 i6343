<lyrics>[V1]
.   G                       D       Bm
 // Һәлигәр түн - зинданидин, азатлиқ рошәнигә,
.Em          G             D
 Муқәддәс Роһ башла мени дайим. //

[C1]
.     Bm
   // Муқәддәс Роһ бу панийдин,
.  G            D
   Тар йол билән мәңгү һаят
.  Em         G             D
   Асман таман башла мени дайим. //

[V2]
 // Дуния вәс-вәсә синақ, мукәммәл иман таянч
 Камаләт Илаһ, камалида һекмәт //</lyrics>
<title>Һәлигәр түн зинданидин М90 И135 Мн238</title>
</song>