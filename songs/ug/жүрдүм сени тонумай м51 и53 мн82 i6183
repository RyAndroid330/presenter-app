<?xml version="1.0" encoding="UTF-8"?><song><author>Қуддус ака</author>
<hymn_number>51</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.Dm        A
 Гуна қилип жүрдүм мән
.A         Dm
 Худа Сени тонумай
.D          A
 Хаталаштим талай мән
.A           Dm
 Көп нәрсини чүшәнмәй

[V2]
 Жүрдүм Сени тонумай
 Әгишип мән шәйтанни
 Қапқан қоюп жиқитти
 Талай қетим оңдурмай

[C1]
.     Dm          Gm
   // Әйса чүштүң қәлбимгә
.  Gm        Dm
   Жүригимни ойғитип
.  Dm         Gm
   Мәңгү һаят йолиға
.  A          Dm
   Ишик ачтиң йорутуп //

[V3]
 Тонуп әнди Сени мән
 Бәхтим гүлдәк ечилди
 Унтуп мән өткәнни
 Интилимән илгири

[V4]
 Ғәм-қайғиму йоқ әнди
 Гунайимму жуюлди
 Яратқучим алдида
 Әйивимму йоқ әнди</lyrics>
<title>Жүрдүм Сени тонумай М51 И53 Мн82</title>
</song>