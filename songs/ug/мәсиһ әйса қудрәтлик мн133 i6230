<hymn_number>133</hymn_number>
<key>C</key>
<lyrics>[V1]
.   C
 // Мәсиһ Әйса қудрәтлик,
.F            C
 Һәйвәтлик вә шөһрәтлик.
.F         G           C
 Ғалибийәт қазанған Җәңчи У. //

[C1]
.     F           G
   // Чапрасқа миқланғанда У,
.  C           Am
   Шәйтанни йәңди,
.  F            G           C
   Дүшмән тамам шәрмәндә болди. //

[V2]
 // Рәббим Әйса қудрәтлик,
 Һәйвәтлик вә шөһрәтлик,
 Ғалибийәт қазанған Җәңчи У. //

[C2]
   // Өлүмдин тирилгәндә У,
   Өлүмни йәңди,
   Өлүмму һәм шәрмәндә болди. //

[V3]
 Апирин Саңа Әйса,
 Қутқазғучи Рәб Әйса,
 Ғалибийәт қазанған Җәңчи Рәб.
 Апирин Саңа Әйса,
 Һәқ вә адил Падиша,
 Ғалибийәт қазанған Җәңчи Рәб.

[C3]
.     F          G
   // Дунияға кәлгәндә У,
.  C          Am
   Дунияни йәңди.
.  F          G        C
   Дунияму шәрмәндә болди. //</lyrics>
<title>Мәсиһ Әйса қудрәтлик Мн133</title>
</song>