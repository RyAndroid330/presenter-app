<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>78</hymn_number>
<author>Алмабуви</author>
<key>G</key>
<lyrics>[V1]
.   Em
 // Асмандики Атамдин
.D           Em
 Бизгә кәлди садақәт //
.   Em         Am
 // Гуналардин азат қилип
.D          Em
 Һаят бәрди таәбәт //

[C1]
.     Em    Am   D      G   Em
   // Мәңгү һаят, Мәңгү һаят
.            Am       D
   Тәғдим қилди бизгә Атам
.          Em
   Мәңгү һаят //

[V2]
 // Меһриванлиғиң чәксиз
 Унтумаймиз мәңгүгә //
 // Еғир һаят йолумни
 Азат қилдиң мәңгүгә //

[V3]
 // Муқәддәс Роһиң Улуқ
 Қайғу кәлсә бешимға //
 // Ниҗаткаримиз Әйса
 Дайим биллә қешимда //</lyrics>
<title>Мәңгү һаят М78 И81 Мн132</title>
</song>