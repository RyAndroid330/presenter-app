<?xml version="1.0" encoding="UTF-8"?><song><author>Гулмира (Мойнақ), Рустам</author>
<hymn_number>102</hymn_number>
<title>Сән кәлгән күни М102 И102 Мн181</title>
<key>Cm</key>
<lyrics>[V1]
.Cm                   Fm
 Бу дуния бәшкүнлүк өмүр,
.Bb                       Cm
 Һәммә ялған, һәммә өткүнчи.
.   Cm                   Fm
 // Дуниядики һәммә нәрсиләр,
.G                         Cm
 Тозуп кетәр Сән кәлгән күни. //

[C1]
.     Ab          Bb     Gm Cm
   // Йеңи дуния, йеңи үмүт,
.  Fm      Bb         Cm
   Һәқиқәт мәңгүлүк өмүр.
.  Ab      Bb       Gm Cm
   Түгимәс бәхит-саадәт
.  Fm       Bb           Cm
   Башлинар Сән кәлгән күни. //
.  G                      Cm
   Башлинар Сән кәлгән күни.

[V2]
 Сениң меһриң дәриядәк чәксиз,
 Қуяштин мол нурлириң Сениң.
 // Өтүнимән нуриңни чечип,
 Қутқузвал хәлқимни мениң. //

[V3]
 Худайим кәчүр гунакармиз
 Сәндин башқа йоқ панайимиз.
 // Һәммисидин қудрәтлик Өзәң
 Ялғуз Саңила сиғинимиз. //</lyrics>
</song>