<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10</hymn_number>
<title>Ата сөйимән Сени М10 Мн8</title>
<key>D</key>
<lyrics>[V1]
.   D       G
 // Ата, сөйимән Сени. //
.   Em        A
 // Саңа ейтқум келиду, //
.   G        D
 сөйимән Сени.

[V2]
.   D        G
 // Әйса, сөйимән Сени. //
.   Em        A
 // Саңа ейтқум келиду, //
.   G        D
 сөйимән Сени.

[C1]
.      Bm   G
   Мәдһийә Саңа,
.     D        A
   Ниҗаткарим, Худа!
.      Bm  G
   Һәмдусана,
.         D       A
   Қутқазғучим, Әйса!

[V3]
.   D               G
 // Муқәддәс Роһ, сөйимән Сени. //
.   Em        A
 // Саңа ейтқум келиду, //
.   G        D
 сөйимән Сени.</lyrics>
</song>