<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em
 // Самавий Атимизға
.Сmaj7
 Болсун дайим шан
.F#
 Униң меһриванлиғи
. B7       Em
 Бизгә бепаян. //

[C1]
.  G            F
   Шан-шәрәпләр Рәббмизгә
.  C         D   C
   Шан-шәрәп Худаға
.  G          F
   Муқәддәс Роһуң бизләргә
.  C           B7
   Яр болсун, амин!

[V2]
 // Ниҗаткарим Саңа
 Һәм болсун дайим шан
 Пәқәт Сәндә ниҗат тапти
 Гунакар инсан. //

[V3]
 // Муқәддәс Роһ һәм Саңа
 Болсун дайим шан
 Еғир һаят йолумизни
 Қилисән асан! //</lyrics>
<key>Em</key>
<title>Самавий Атимизға болсун дайим шан И108 Мн172</title>
