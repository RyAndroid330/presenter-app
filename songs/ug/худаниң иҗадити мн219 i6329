<?xml version="1.0" encoding="UTF-8"?><song><title>Худаниң иҗадити Мн219</title>
<lyrics>[V1]
 // Яраттиң әй Худа
 Бизни Өзәңгә охшаш //
 // Бәхитлик биз һәр дайим
 Рәббимиз яр болғач //

[V2]
 // Айлинаркән йәр шари
 Қудрәтлик қолуңда
 Мәдәткар бол әй Рәббим
 Хәтәр көптур йолумда //

[V3]
 // Кечә күндүз айлинар
 Рәт тәртибимни ташлимай //
 // Мәдәт бәргин Рәб Әйса
 Ай қуяштәк нур чачар //
 Ай қуяштәк нур чачар</lyrics>
<hymn_number>219</hymn_number>
</song>