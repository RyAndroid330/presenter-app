<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>170</hymn_number>
<author>Қудрәт ака</author>
<key>F</key>
<lyrics>[V1]
.   Dm        F      Gm      Dm
 // Бу аләмгә Әйсаниң келишини
.F          Gm          Am     Dm
 Бурунтинла пәйғәмбәрләр ейтип кәлгәнди //
.   Dm          Fm                Gm
 // Яман йолдин йениңлар Рәбни тонуңлар
.C               Dm   Am          Dm
 Дегән еди сөзлиридә шу пәйғәмбәрләр //

[C1]
.     Dm     F        F        Gm
   // Шу пәйғәмбәрләр, шу пәйғәмбәрләр,
.  Am          Dm
   Шу пәйғәмбәрләр //

[V2]
 // Худа Өзи инсан болуп йәргә кәлсиму
 Тонумиди лекин Уни надан инсанлар //
 // Худа йоли Мән болимән әгәшкин десиму
 Хилаплиқ қилдиң Худаға дәп қақти наданлар //

[C2]
   // Қақти наданлар, қақти наданлар, қақти наданлар //

[V3]
 // Худа йоли Әйсадур У пак йолдур
 Худа билән яраштурған һәм һәқ йолдур //
 // Һаят йоли Әйсадур, Рәбниң Өзидур
 Җәннәт йоли Әйсадур, У Муқәддәстур //

[C3]
   // У Муқәддәстур, у Муқәддәстур, у Муқәддәстур //</lyrics>
<title>Рәбни тонуңлар Мн170 И94 М100</title>
</song>