<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D               Bm
 // Саңа ибадәт қилимән
.G    Em   A
 О улуқ Худа.
.       D    Bm
 Аманлиқниң егиси Сән
.G    Em    A
 Намиңни көтиримән. //

[C1]
.     G         D/Bm
   // Мәдһийиләймән
.            Em      A
   Аләмдә тәңдишиң йоқ.
.  D               Bm
   Саңа ибадәт қилимән,
.  G    A       D
   Сени сөйимән. //</lyrics>
<title>Саңа ибадәт қилимән М139 И100 Мн174</title>
