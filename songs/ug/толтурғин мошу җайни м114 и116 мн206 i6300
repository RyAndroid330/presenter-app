<?xml version="1.0" encoding="UTF-8"?><song><title>Толтурғин мошу җайни М114 И116 Мн206</title>
<key>C</key>
<lyrics>[V1]
.   C     G          Am
 // Толтурғин мошу җайни,
.        F           F
 Өз Роһуңға, Өз Роһуңға! //

[C1]
.     F          G       C
   // Мәдһийиләймән мән Сени
.  F       G             Em Am
   Намиңни улуқлап көтиримән
.  F          G    Am
   Падишайим кәлгин
.  Em               Am
   Мәдһийә тәхтидә олтарғин
.  F            G        C
   Толтурғайсән мошу җайни
.          C
   Өз Роһуңға //

[V2]
 // Толтурғин мениң қәлбимни
 Өз Роһуңға, Өз Роһуңға! //

[C2]
.   F         G       C
   Мәдһийиләймән мән Сени
.  F       G             Em Am
   Намиңни улуқлап көтиримән
.  F          G    Am
   Падишайим кәлгин
.  Em               Am
   Мәдһийә тәхтидә олтарғин
.  F            G           C
   Толтурғайсән мениң қәлбимни
.          C
   Өз Роһуңға</lyrics>
<author>Сергей Минеев</author>
<hymn_number>114</hymn_number>
</song>