<?xml version="1.0" encoding="UTF-8"?><song><title>Худа бәргән бәхит М119 И124 Мн212</title>
<lyrics>[V1]
.   C      G                    C
 // Оғуллар Рәб бәргән нәсилдур,
.C          Am          G
 Қизму Худа бәргән бәхиттур. //
.   C          Am          Dm
 // Ким ишәнсә Худа Оғли Әйсаға,
.G                  C
 Асман ишәнгәнниң тәхтидур. //

[C1]
.     C          G             C
   // Келиң оғул-қизлар келиңлар.
.  Am           H          G
   Дутар-тәмбүр челип келиңлар. //
.      Gm           Am          Dm
   // Рәббимиз һәм бәхтимиз - Әйса үчүн,
.   G                             C
   Гөзәл қизлар уссул ойнап келиңлар. //

[V2]
.   C         G               C
 // Тәбиәтни гөзәл қилип яратқан,
.C          Am             G
 Инсанларни муһәббәткә үгәткән. //
.   C         Am             Dm
 // Гунакарни қутулсун дәп Худайим,
.G                    C
 Өз Оғлини бу дунияға әвәткән. //</lyrics>
