<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>179</hymn_number>
<author>Мирбахит Ака</author>
<title>Сән Егәм Машиях Мн179</title>
<key>Bb</key>
<lyrics>[V1]
.Gm                      Cm
 Мән Саңа ейтай, мениң Егәм.
.F                      B/D
 Сенила махтай Рәббим Сени.
.Gm                      Cm
 Сән кәл дедиң мени йениңға.
.F                       B/D
 Мән шунчилик хошалмән Саңа.

[P1]
.     Gm                 Cm
   // Немә маңа шунчилик байлиқ?
.  F                   B/D/Gm
   Нечун маңа нурғун күмүч?
.  Gm                   Cm
   Нечун ясинип меңишлирим?
.  A                   D
   Әгәр жүригимдә болмисаң! //

[C1]
.     Gm
   // Һәммә йәрдә,
.          Eb
   вә асманда,
.  Bb               F
   Бирла Сән Егәм Машиях! //</lyrics>
</song>