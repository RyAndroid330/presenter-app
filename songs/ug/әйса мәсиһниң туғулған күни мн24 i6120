<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>24</hymn_number>
<lyrics>[V1]
 // Мәсиһ болуп дунияға кәлдиң Сән Рәббим //
 // Шуниң үчүн һәр дайим шатлиқта қәлбим //

[V2]
 // Бу дунияға нур болуп кәлдиң Сән Рәббим
 Шу нуруңниң меһри билән болдум мән әркин //

[C1]
   Кәлди мана әй Рәббим
   Шу қутлуқ күнүң
   Улуқлуқ, шан-шәрәп пәқәтла Сениң
   Нахша ейтип уссул ойнап
   Күйләймиз Сени
   Мубарәк әй Рәббим, туғулған күнүң
   Нахша ейтип уссул ойнап
   Күйләймиз Сени
   // Мубарәк әй Рәббим, туғулған күниң //</lyrics>
<title>Әйса Мәсиһниң туғулған күни Мн24</title>
</song>