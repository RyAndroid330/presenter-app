<?xml version="1.0" encoding="UTF-8"?><song><title>Тиләкләр Мн205</title>
<lyrics>[V1]
 // Тиләймән достлар
 Силәргә шатлиқ
 Шатлиқ ичидә
 Сақлансун паклиқ //

[V2]
 // Рәб Әйсадин тиләймән достлар
 Қериндашлар бир тән болуңлар //
 // Яманлиқтин жиргинип жирақ
 Яхши ишта болсун қолуңлар //

[V3]
 // Рәб Әйсадин тиләймән достлар
 Башқиларға ярдәм қилиңлар //
 // Рәқип әмәс дүшмәнлириңлар
 Меһри берип дост дәп билиңлар //

[V4]
 // Тиләймән достлар
 Хошал яшаңлар //
 // Худаниң иллиқ учқунлиридин
 Топ-топ болуп гүлхан ясаңлар //
 Топ-топ болуп гүлхан ясаңлар</lyrics>
<hymn_number>205</hymn_number>
</song>