<?xml version="1.0" encoding="UTF-8"?><song><title>Nima deysan Rabbing kelganda Q213 W115</title>
<key>F#</key>
<lyrics>[V1]
.    D#m
 //  Rabbimiz tezda kelar,
.B
 Seni qandayin topar?
.C#        Bb        D#m
 Behuda oʻtmasmi hayoting?
.D#m
 Tashvishlar girdobida
.B
 Foniy taraddudlarda,
.C#          Bb            D#m
 Nima deysan Rabbing kelganda?  //

[C1]
.      G#m
   //   Oʻzgalarga hakamsan
.  C#7
   Aybini ham koʻrasan,
.  F#          Bb            D#m D#7
   Biroq oʻz aybingni koʻrmaysan!
.  G#m
   Qandayligin bilasan
.  C#7
   Lekin oʻzing qandaysan?
.  F#            Bb         D#m
   Koʻrsa diling gunohga botgan.  //

[V2]
 //  Oʻzgalarni koʻrasan
 Gunohga oʻzing qulsan
 Bu xaqda hech oʻylab koʻrmaysan
 Yiqilganni koʻrasan
 Oʻylarin ham bilasan
 Biroq oʻzing toʻyib ketyapsan!  //

[V3]
 //  Xudo taxti yoniga
 Gunohingla borasan
 Xudo sendan soʻramas
 Oʻzgalarning gunohin
 Oʻzing uchun javob berasan
 Qanday hayot kechding?! -deb soʻrar.  //</lyrics>
<hymn_number>213</hymn_number>
</song>