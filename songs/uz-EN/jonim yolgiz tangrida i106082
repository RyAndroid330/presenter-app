<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Jonim yolgʻiz Tangrida
   Orom topar
   Najot Undan kelar
   Faqat U Qoyam, Najotim mening
   Qalʼam Udir
   Tebranmasman aslo
   Jonim yolgʻiz Tangrida
   Orom topar //

[V1]
 // Qalbim erir ichimda
 U teginsa menga
 Koʻzlarim koʻrmasa ham
 Borliging yaqin menga
 Bir kun kelasan shuhrat-la, bulutlarla
 Yuragim Senga intiq
 Kutyapman kel Rab Iso //</lyrics>
<title>Jonim yolgʻiz Tangrida</title>
<author>Ulugʻbek Joʻrayev</author>
</song>