<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<author>Lenny LeBlanc</author>
<key>G</key>
<lyrics>[C1]
.     G   D           C
   // Sendan boshqasi yoʻq,
.  C     G         Am      D
   Faqat Sen menga umid berding.
.  G       D       C
   Koʻpdan beri qidirib bildim,
.  G        D               G
   Menda Rabbimdan boshqasi yoʻq. //

[V1]
.G        C           G     Em
 Mehribonliging yohud daryoday,
.Am           D     G
 Qalbimizga shifo berar.
.C               G       Em
 Farzandlaringga taskin berar,
.Am     C           D
 Rabbimdan boshqasi yoʻq.

[C2]
   /// Sendan boshqasi yoʻq,
   Faqat Sen menga umid berding.
   Koʻpdan beri qidirib bildim,
   Menda Rabbimdan boshqasi yoʻq. ///</lyrics>
<title>Sendan Boshqasi Yoʻq W119</title>
</song>