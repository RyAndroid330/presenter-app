<?xml version="1.0" encoding="UTF-8"?><song><author>Sinach</author>
<hymn_number>30512</hymn_number>
<key>A</key>
<lyrics>[V1]
.       A             E
 Buyuk Rab, Sen oramizda,
.        B         C#m
 Ulugʻlayman, ulugʻlayman.
.   A         E
 Qudratli, bunyodkor Xudo,
.      B       C#m
 Ulugʻlayman, ulugʻlayman.

[C1]
.     A
   // Sen Yoʻlsan, Moʻjizakorsan
.  E
   Soʻzingda sodiq,
.            B
   Zulmat ichra Nur Rabbim,
.          C#m
   Buyuk Xudosan! //

[V2]
.       A       E
 Shu yerda, oʻzgartir meni,
.      B       C#m
 Ulugʻlayman, ulugʻlayman
.       A               E
 Shu yerda, qalbim shifola,
.     B        C#m
 Ulugʻlayman, ulugʻlayman

[V3]
.       A       E
 Shu yerda, Hayot beruvchi,
.     B        C#m
 Ulugʻlayman, ulugʻlayman
.    A        E
 Shu erda, Shifo beruvchi,
.     B        C#m
 Ulugʻlayman, ulugʻlayman

[B1]
.  A
   Hatto koʻrmasam ham Seni
.  E
   Hatto sezmasam ham Seni
.  B
   Yonimdasan, yonimdasan Rabbim
.  C#m
   Shu yerdasan, Shu yerdasan Rabbim!
.  A
   Hatto koʻrmasam ham Seni
.  E
   Hatto sezmasam ham Seni
.  B
   Yonimdasan, yonimdasan Rabbim
.  C#m
   Toʻxtamaysan, Toʻxtamaysan Rabbim!</lyrics>
<title>Sen Yoʻlsan</title>
</song>