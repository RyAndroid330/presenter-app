<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Nega Ey Xudo
 Sen bizni rad etding, rad etding
 Nega Ey Xudo
 Sen bizga qarshi chqding, qarshi chiqding //

[C1]
   // Hayotimizning Egasi
   boʻlganingni eslagin, eslagin
   Oʻzing bizni tanlaganingni
   unutmagin, unutmagin Egam //

[V2]
 // Nega Ey Xudo
 Seni biz topolmay qoldik, topolmay qoldik
 Nega Ey Xudo
 Sensiz biz huzur halovatni yoʻqotdik. //</lyrics>
<title>Eslagin Bizni</title>
<author>Sobir Umurov</author>
<hymn_number>23009</hymn_number>
</song>