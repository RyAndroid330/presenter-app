<?xml version="1.0" encoding="UTF-8"?><song><author>Ulugʻbek Joʻrayev</author>
<key>C</key>
<lyrics>[V1]
.C
 Jaranglaydi tengsiz Mukaddas Noming
.F                            G
 Erdan koʻkka qadar ulugʻvorliging
.C                                Am
 Barcha borliq, hatto farishtalar ham
.F                          G
 Boshin egar faqat Sening huzuringda

[C1]
.  G   C                 Am
   Buyuksan barcha buyuklardan
.  F                     G
   Ulugʻvordir muqaddas Sening Noming
.         C                 Am
   Otamizning buyuk Inoyatisan
.  F                           G/C
   Senda topar barcha inson najotni

[V2]
 Qalb osmonida porlagan quyosh kabi
 Nurin sochar birgina Sening Isming
 Tilimdan qoʻymasman Seni aslo
 Najotkor Rabbim deya Seni Iso</lyrics>
<title>Jaranglaydi tengsiz Muqaddas Noming</title>
</song>