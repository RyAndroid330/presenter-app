<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>208</hymn_number>
<title>Sevgi Boʻlsin Oramizda Q208</title>
<key>F</key>
<lyrics>[V1]
.   Am             C         C            Dm
 // Sevgi boʻlsin oramizda, porlasin baxt koʻzimizda.
.Dm               Bb                        Am
 Xudoni xalqimiz sevsin, qoʻrquv va ogʻriq yoʻqolsin. //

[C1]
.     F                         C                Dm
   // Men qalbim ila kuylayman, hamdu sano hamdu sano,
.  Dm              Bb                      Am
   Egam Xudoni kuylayman, hamdu sano hamdu sano. //

[V2]
 // Sen yordam ber tushunishga, kerakmiz bir-birimizga,
 Sevgi boʻlsin oramizda, Sening nuring yoʻlimizda. //

[V3]
 // Tiz choʻkib dilimizda yuraklarni ochaylik,
 Xudodan quvvat olib, shaytonga qarshi turaylik. //

[V4]
 // Keling, keling birodarlar hammamiz birga boʻlaylik,
 Hammamiz birga soʻraylik, barobar koʻkka boraylik. //</lyrics>
<aka>Sevinchim Iso Masih</aka>
</song>