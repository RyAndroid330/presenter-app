<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Isroilning Xudosi</title>
<lyrics>[V1]
.    Em       A              C          D
 // Muqaddas ulugʻvorlikka burkangan Egamizga
.     Em       A             C          D
 Ey zamin ahli titrab turing Uning oldida
 Muqaddas ulugʻvorlikka burkangan Egamizga
 Aytingki Egamiz Shoh elatlarning orasida //

[C1]
.     Em    A        C    D
   // Egamiz Shohdir Egamiz
   Unga biz sajda qilamiz
   Egamiz Shohdir Egamiz
   Uning Nomini biz kuylaymiz //

[V2]
 // Muqaddas liboslarda sajda qilib Egamizga
 Nazrlar olib kiring Uning muqaddas hovlisiga
 Muqaddas liboslarda sajda qilib Egamizga
 Kuylangki Egamiz Shoh koʻtarib qoʻllarni balandga //</lyrics>
<key>Em</key>
</song>