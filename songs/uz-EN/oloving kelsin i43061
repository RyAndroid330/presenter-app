<?xml version="1.0" encoding="UTF-8"?><song><author>Malohat Pulatova</author>
<hymn_number>127</hymn_number>
<title>Oloving Kelsin</title>
<lyrics>[V1]
.C              Em7
 Oloving kelsin menga,
. F7      G
 Oloving kelsin,
.C              Em7
 Oloving bilan birga
. F7        G
 Moylanish kelsin,
.Dm7            Em
 Izlayman huzuringni
.F7       Am7
 Muqaddas Xudo
.Dm            G          Fm6/B
 Yuragimni ochaman Senga Iso.

[C1]
.     C7              Gm7
   // Sening olovingga muhtojman,
.  C7              F7    B
   Olovingda yonsin yuragim.
.  Am7                 D7
   Sening irodangni izlayman,
.  Dm7                     G7  C
   Shunday yashash mening tilagim. //

[V2]
 Oloving bilan Rabbim
 Poklagin qalbim
 Jasorat bilan toʻldir
 Mening yuragim
 Huzuringga kelib men
 Jamoling koʻray
 Hayotim Senga Iso men topshiray.

[C2]
   // Sening olovingga muhtojman,
   Olovingda yonsin yuragim.
   Sening irodangni izlayman,
   Shunday yashash mening tilagim. //

[B1]
.  F7
   Oloving kelsin
.  G7
   Huzuring kelsin
.  Am7
   Poklanish kelsin
.  G7
   Shifoing kelsin
.  C7
   Jasorat kelsin
.  G
   Ruhing toʻldirsin
.  B            Am
   Shohliging kelsin
.  G7
   Muqaddas Xudo</lyrics>
<key>Db</key>
</song>