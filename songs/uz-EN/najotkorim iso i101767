<?xml version="1.0" encoding="UTF-8"?><song><author>Baurjon Poʻlatov</author>
<title>Najotkorim Iso</title>
<key>Am</key>
<lyrics>[V1]
.   Am               E    Am
 Podsholarning Podshohi Iso
.     A7                 Dm
 Qutqaruvchim gunohdan Iso
.       Dm                   Am
 // Kelishingni intizor bilan,
.Am              E   Am\A7
 Najotkorim kutaman Iso //

[V2]
 Yoʻlimga chiroqdir Kaloming
 Asaldir ogʻzimga lazzatli
 // Har bir soʻzing taʼsirli, jonli,
 Sen Yoʻl, Haqiqat, Hayotdirsan //

[V3]
 Xochdagi qoning, yaralaring,
 Laʼnatdan ozod etar - kuchdir.
 // Azoblaring tortgan biz uchun,
 Buyuk sevgingning isboti Iso //</lyrics>
</song>