<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Masih Xudoning Oʻgʻli</title>
<key>Em</key>
<lyrics>[V1]
.Em      C         G
 Xochga bordi biz uchun
. G     D          Em
 Qonun toʻkdi biz uchun
.Em     C         G
 Azoblandi biz uchun
.G      D       Em
 Bizni sevuvchi Iso

[V2]
.Em     C      G
 Iso sevadi bizni
.G      D        Em
 Erga keldi osmondan
.Em       C      G
 Oʻlib yana tirilib,
.G     D       Em
 Qutqardi va gunohdan

[C1]
.  Em     C     G     D     Em
   Iso Masih Xudoning Oʻgʻli
.  Em     C      G       D    Em
   Buyuk sevgisi bizni qutqardi
.  Em      C     G       D   Em
   Yaralaridan xochdagi Uning
.  Em      C     G      D    Em
   Shifolanar barcha kasallar

[V3]
 Taqillatar yurakning
 Eshigini muloyim
 Ochsang kirar xursandlik
 Qut-baraka har doim

[V4]
 Yigʻlaganlar quvonar
 Charchaganlar kuch olar
 Abadiy hayot berib
 Hayotingni oʻzgartar</lyrics>
<author>Baurjan Poʻlatov</author>
</song>