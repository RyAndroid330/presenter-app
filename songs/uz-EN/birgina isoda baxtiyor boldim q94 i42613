<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>94</hymn_number>
<title>Birgina Isoda baxtiyor boʻldim Q94</title>
<key>F#m</key>
<lyrics>[V1]
.   F#m                    D
 // Birgina Isoda baxtiyor boʻldim,
.Bm      Em              F#m
 Birgina Isoda jonga dam oldim. //
.   A                     Bm
 // U doʻstimga men dil sirlarim ochdim,
.            D        Em    F#m
 Eng yaxshi doʻstimni Unda topdim. //

[C1]
.     F#m                      Bm
   // Qanday baxtiyorman doʻst boʻlib Unga,
.  D            Em                F#m
   Soʻzlab berolmaydi ogʻzim hech kimga. //
.     Bm
   // Birgina dilim Unda quvonadi,
.  D          Em               F#m
   Bu doʻstim bilan hech xatar boʻlmaydi. //

[V2]
 // Bu doʻstim bilan sevgida yashayaman,
 U meni xalos qildi gunohlardan. //
 // Muhabbatini isbot etdi xochda,
 Eng yaxshi doʻstimni topdim Unda. //

[V3]
 Men bilan U doʻstlik ittifoq tuzgan,
 Yoshligimdan yetaklab qoʻli bilan.
 /// Baxt oʻlkasiga meni olib boradi,
 Abadiy jonim Unda quvonadi. ///</lyrics>
<aka>Qanday baxtiyorman</aka>
</song>