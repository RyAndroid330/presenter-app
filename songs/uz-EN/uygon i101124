<?xml version="1.0" encoding="UTF-8"?><song><title>Uygʻon</title>
<key>Em</key>
<lyrics>[V1]
.  C           D
 Erta tongdan umid bilan
.    Bm7         Em
 Xudo Senga biz qaraymiz.
.C             D
 Tugʻirlab biz yuraklarni
.Bm7       Em
 Yonimizda Sen xardoim.

[V2]
.        C         D
 Oloving bilan xayotimni
.         Bm7      Em
 Sevging bilan yoritding Sen,
.   C            D
 Yullarimga Sen nur sochib
.   D            Bm7
 Zulmat ketar sharafingdan.

[P1]
.     C
   // Xechkachon sevging sening,
.  D
    sunmas ichimda mening,
.  Bm7
   Shu sevgi-nuri bilan
.  Em
   Porlaysan xar kuni Sen. //

[C1]
.        C
   // Sen men bilan-san
.   D          Bm7
   men bilan san
.           Em
   Yuragimda abadiy //

[B1]
.      C       D       Bm7
   /// Abadiy, Abadiy, Abadiy,
.  Em
    Sevgingda ///
.  C      D       Bm7
   Abadiy Abadiy, Abadiy
.  Em
    bilamiz.</lyrics>
</song>