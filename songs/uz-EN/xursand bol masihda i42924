<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>225</hymn_number>
<title>Xursand boʻl Masihda</title>
<aka>Xursand Boʻl</aka>
<lyrics>[V1]
.   Ebm            B    Bbm Ebm
 // Xursand boʻl Masihda har doim,
.Abm        Bbm          Ebm
 Togʻday muammo turganda ham. //
.   F#            B      F#
 // Chunki tirik Sening Xudoying,
.Abm        Bbm       Ebm
 Senda bor U bergan gʻalaba. //

[C1]
.                     B
   // Men xursand boʻlaman,
.        C#       F#
   Men xursand boʻlaman
.  Abm    C#    F#
   Bu Xudoning tilagi. //
.  Abm    C#    F#
   Bu Xudoning tilagi.

[V2]
.   F#                   C#
 // Quloq solma shayton soʻziga,
.Abm         C#        Ebm
 Shubhalarga joy berma hech ham
.F#                C#
 Yolgʻonning otasi engilgan.
.Abm        C#         F#
 Imoningda turgin mustahkam. //

[C2]
.             B
   // Turgin imoningda,
.    C#    F#
   Turgin imoningda
.  Abm     C#    F#
   Chunki bu sening kuching. //</lyrics>
<key>F#</key>
</song>