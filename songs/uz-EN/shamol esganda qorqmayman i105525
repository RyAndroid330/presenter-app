<?xml version="1.0" encoding="UTF-8"?><song><title>Shamol esganda qoĘ»rqmayman</title>
<aka>Men, men, men, qoĘ»rqmayman</aka>
<lyrics>[V1]
 Shamol esganda qoĘ»rqmayman,
 qoĘ»rqmayman, qoĘ»rqmayman,
 ToĘ»fon koĘ»tarilganida qoĘ»rqmayman,
 men, men, men, qoĘ»rqmayman.
 Shamol yaratgan Xudoyim,
 ToĘ»fon yaratgan Xudoyim.
 Rabbim ichimda boĘ»lgani chun,
 Men, men, men, qoĘ»rqmayman.

[V2]
 YomgĘ»ir yoqqanda qoĘ»rqmayman,
 qoĘ»rqmayman, qoĘ»rqmayman,
 Chaqmoq chaqqanda qoĘ»rqmayman,
 men, men, men, qoĘ»rqmayman.
 YomgĘ»ir yaratgan Xudoyim,
 Chaqmoq yaratgan Xudoyim.
 Rabbim ichimda boĘ»lgani chun,
 Men, men, men, qoĘ»rqmayman.</lyrics>
</song>