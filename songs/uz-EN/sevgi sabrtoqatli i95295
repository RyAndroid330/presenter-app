<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em           Am
 Sevgi sabr-toqatli
.Dm            Em
 Sevgi erur mehribon
.Em           Am
 Sevgi emas hasadli
.Dm            Em
 Kekkaymaydi hech qachon

[V2]
 Sevgi hech maqtanmaydi
 Kekni hech saqlamaydi
 Odobsizlik qilmaydi
 Xudbinlik ne bilmaydi

[C1]
.  Em           Am
   Sevgi umid saqlaydi
.   Dm               Em
   Ishonchni yoʻqotmaydi
.   Em              Am
   Achchiq qilish bilmaydi
.   Dm             Em
   Aslo ado boʻlmaydi</lyrics>
<key>Em</key>
<title>Sevgi Sabr-Toqatli</title>
<author>Ulugʻbek Joʻrayev</author>
</song>