<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.D          G     C      G
 Ertalabki tongda Iso tirildi,

[C1]
.     C          G       D     G
   // Olqishlang bolalar osmon shohini. //

[V2]
 Endi U oʻlmaydi gunohlar uchun,

[C2]
   // Xochda oʻlim koʻrib,najot berdi U. //

[V3]
 Gunohni yengdi U, quvonch keltirdi,

[C3]
   // Olqishlang bolalar osmon shohini. //</lyrics>
<title>Ertalabki tongda Iso tirildi</title>
</song>