<?xml version="1.0" encoding="UTF-8"?><song><title>Ota Men Seni Sevaman ҲСХМ23</title>
<key>G</key>
<lyrics>[V1]
.   G        C      G(D)
 // Ota men Seni sevaman, //
.G         C  Em
 Ota men Seni juda sevaman,
.Am       D      G
 Ota men Seni sevaman.

[V2]
.   G        C     G(D)
 // Iso men Seni sevaman, //
.G        C   Em
 Iso men Seni juda sevaman,
.Am       D      G
 Iso men Seni sevaman.

[V3]
.   G                 C       G(D)
 // Muqaddas Ruh, men Seni sevaman, //
.G                  C    Em
 Muqaddas Ruh, men Seni juda sevaman,
.Am                 D      G
 Muqaddas Ruh, men Seni sevaman.

[V4]
 // Otam meni sevadi, //
 Otam meni juda sevadi,
 Otam meni sevadi.

[V5]
 // Iso meni sevadi, //
 Iso meni juda sevadi,
 Iso meni sevadi.

[V6]
 // Muqaddas Ruh meni sevadi, //
 Muqaddas Ruh meni juda sevadi,
 Muqaddas Ruh meni sevadi.

[V7]
 // Ota rahmat Oʻgʻling uchun, //
 Ota rahmat aziz Oʻgʻling uchun.
 Ota rahmat Oʻgʻling uchun.

[V8]
 // Iso rahmat qoning uchun, //
 Iso rahmat aziz qoning uchun.
 Iso rahmat qoning uchun.

[V9]
 // Muqaddas Ruh rahmat daldang uchun, //
 Muqaddas Ruh rahmat kuchli daldang uchun.
 Muqaddas Ruh rahmat daldang uchun.</lyrics>
<hymn_number>23</hymn_number>
</song>