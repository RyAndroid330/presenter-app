<?xml version="1.0" encoding="UTF-8"?><song><title>Yahshilik qil</title>
<lyrics>[V1]
.   Em         Am
 // Umrim uzoq boʻlgay desang,
.Bm              C      D   Em
 Yaxshi kunlar kelgay desang, //

[C1]
.     Em           Am
   // Hayot shirin boʻlgay desang,
.      C              B         Em
       Yaxshilik qil, qil yaxshilik.
.  C              B
   Yaxshilik qil, qil yaxshilik //

[V2]
.   Em(Bm)     (Am)
 // Yomonlarga gʻashlik qilma,
.Am(G)        B(A)
 Badkirdorga havas qilma, //

[C2]
.     Em          Am
   // Yomonlikni ravo koʻrma, //
.     C              B         Em
   // Yaxshilik qil, qil yaxshilik. //

[V3]
 // Yoʻllaringni Xudoga topshir,
 Mol-mulkingni Xudoga topshir. //

[C3]
   // Bor gunohni Isoga topshir,
   Yaxshilik qil, qil yaxshilik. //

[V4]
 // Yaxshi bilan yursang, yaxshi.
 Tinchgina yashasang, yaxshi. //
 // Xudo bilan boʻlsang, yaxshi. //

[C4]
   // Xudo bilan yursang, yaxshi.
   Yaxshilik qil, qil yaxshilik. //</lyrics>
<key>Em</key>
</song>