<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>194</hymn_number>
<title>U ibtido va intiho, avvaliyu oxiri Q194</title>
<lyrics>[V1]
.   Dm                      Gm
 // Xudovandning Ruhi Menga yor,
.Gm                       Dm
 U Meni muqaddas moyila moyladi.
.Dm                      Gm
 Bechoralarga mujda yetkazmoq uchun,
.C                   Dm
 Dilabgorlarga shifo bermoq uchun,
.A                  Dm
 Xudovand Meni yubordi,
.A                  Dm
 Xudovand bizni yubordi. //

[C1]
.  Dm       F          Gm         A
   U ibtido va intiho, avvaliyu oxiri,
.  Bb                F             C
   Ruh ham kelin ham kel deb chorlamoqda,
.  F                        Dm
   Eshitgan kishi ham kel desin.
.  Bb                Gm
   Chanqagan kelsin xohlagan tekin
.  C                   Am
   Hayot suvidan bahra olsin.

[V2]
 // Xudovandning Ruhi Menga yor.
 U Meni muqaddas moyila moyladi.
 Bechoralarga mujda yetkazmoq uchun,
 Dilabgorlarga shifo bermoq uchun,
 Xudovand Meni yubordi,
 Xudovand bizni yubordi. //</lyrics>
<key>Dm</key>
<aka>Hudovandning Ruhi</aka>
</song>