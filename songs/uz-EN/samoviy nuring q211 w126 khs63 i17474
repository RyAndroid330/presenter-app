<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>182</hymn_number>
<author>Iliyas Tursun, Ablәһәt aka</author>
<title>Samoviy nuring Q211 W126 ҲС63</title>
<key>Em</key>
<lyrics>[V1]
.Em              Cmaj7
 Sen quyosh, haqiqat Sening himmating
.D               Bm
 Sevgi va shafqatdan ayon qimmating!
.Em              Cmaj7
 Tuganmas, tengdoshsiz, cheksiz qudrating,
.D             Bm
 Mangulik hayotda bayon xislating

[V2]
.Em               Cmaj7
 Soʻzlaring qalbimga toʻkilgan ancha,
.D                 Bm
 Men Sening kuchingdan yetilgan gʻuncha!
.Em             Cmaj7
 Boyligim, borligʻim Sening yoʻlingda,
.D              Bm
 Senga xos hurmatim umrim boʻyicha

[C1]
.   Em  G          D
   Samoviy nuring tushdi qadamimga
.  Am    Em          C            D    Em
   Yoʻl ochib zulmatdan, hayot baxtimga
.  Em   G            D
   Ey Xudo, olqishim oshdi falakdan
.  Am    Em         C            D   Em
   Chunki Sen oʻtirding hayot taxtimga</lyrics>
<aka>Sen Quyosh, Haqiqat</aka>
</song>