<?xml version="1.0" encoding="UTF-8"?><song><key>B</key>
<lyrics>[V1]
.   B               E          B       F#
 // Shod hurramlik kayfiyatda erkinligingda,
.B               E            F#      B
 Minnatdordorman chin dildan Najotkorimga. //

[C1]
.  B           G#m     E         B
   Qoʻshiq aytaylik, quvnab kuylaylik,
.  B             E     B   F#      B
   Rabbimizning oldida xursand boʻlaylik.
.  B         G#m    E       B
   Masih muhabbat, baxtu saodat,
.  B             E       B   F#      B
   Muqaddas Ruh kuchida xursand boʻlaylik.

[V2]
 // Shon sharaf zoʻr yangrasin va olqish ziyoda,
 Minnatdordorman chin dildan Najotkorimga. //

[V3]
 // Yeru osmon kuylasin biz bilan birga,
 Hamdu sano olqishlar doim Xudoga. //</lyrics>
<title>Shod hurramlik Q97 ҲС84</title>
<author>Һәmra aka</author>
<hymn_number>97</hymn_number>
</song>