<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C
 Pul bilan borolmaymiz,
.G
 Xudoning dunyosiga.
.C
 Kuch bilan borolmaymiz,
.G              C
 Xudoning dunyosiga.

[C1]
.  F          C         D     G
   Yangitdan tugʻilsak, borolamiz.
.  F                  C
   Faqat iymon bilan borolamiz,
.  G           C
   Xudoning dunyosiga.

[V2]
 Omad bilan borolmaymiz,
 Xudoning dunyosiga.
 Bilim bilan borolmaymiz,
 Xudoning dunyosiga.</lyrics>
<title>Pul bilan borolmaymiz</title>
<hymn_number>45</hymn_number>
</song>