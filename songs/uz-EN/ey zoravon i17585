<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   Am                   G
 // Ey, zoʻravon nechun, yovuzliging bilan maqtanib?
.Am                              G
 Tangir inoyyati, menga doim yor deb yurasan? //
 Hoy hiylagar, niyati buzuq
 Keskir ustaradekdir tiling!
 Sen yaxshilikdan koʻra yomonlikni
 Haqiqatdan koʻra yolgʻonni ortiq sevasan

[V2]
 Ey sen, makrli til
 Qingʻir maqsadlarni ortiq sevasan
 Tangri Oʻzi seni abadiy halok qiladi
 // Seni chodiringdan quvib chiqaradi
 Tiriklar diyoridan ildizingni quritib tashlaydi //

[V3]
 Solihlar buni koʻrib qoʻrqadilar
 Uning ustidan kulib deydilar
 Qarang, Xudoni tayanchim deb bilmagan
 Davlati koʻpligiga eʼtiqod qoʻyib
 // Boyligiga ishongan odamning oqibati shu! //</lyrics>
<title>Ey Zoʻravon</title>
</song>