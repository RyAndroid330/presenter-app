<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>83</hymn_number>
<title>Kim Sen bilan teng kelar</title>
<key>G</key>
<lyrics>[V1]
.G        D           Em
 Kim Sen bilan teng kelar
.C             G         D
 Sen yuragimga tegib oʻtding.
.G    D           C              G
 Bu dunyoni qanchalar izlamay Rabbim
.D                  G
 Sen goʻzalsan hammadan

[C1]
.  C         D      G        Em
   Sening sevging oqar daryoday,
.  Am7    D      G
   Va shifong Sening.
.  C7       D           G          Em
   Farzandlaring azoblarda Senga kelar,
.  Am      C            D
   Kim Sen bilan teng kelar.</lyrics>
</song>