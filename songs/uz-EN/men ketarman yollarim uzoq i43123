<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
.Dm                     Eb
 Men ketarman yoʻllarim uzoq,
.Cm                    F
 Yuraklarda qolurmikan dogʻ.

[C1]
.     Eb              F
   // Olis-olis samo ortida,
.  Cm                    Dm
   Tangri kutar jannat yurtida. //

[V2]
 Doʻst yorlar qilmang yuz afsus,
 Olloh bilan umrniku siz.

[C2]
   // Tangri qolib sizlarga madad,
   Men qilarman har kun ibodat. //

[V3]
 Qutuldi deb dunyo tashvishdan,
 Mushkulotli yengil bir ishdan.

[C3]
   // Olloh aytsa bir kun kelib man,
   Yoningizda men ham tururman. //</lyrics>
<title>Men ketarman yoʻllarim uzoq</title>
</song>