<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>28</hymn_number>
<lyrics>[V1]
.E           G#m     A               E
 Tuproqdan odamni yaratib dimogʻiga hayot
. E        F#m    B
 nafasi puflagan Xudo.
.E             G#m    A
 Biz uchun Oʻgʻlini dunyoga yuborgan,
.E            B       E
 Sevgi Xudosi men sevaman.

[C1]
.       E         G#m       A    E
   Men Xudo suratida yaratilgan bandaman,
.            A         B
   Vujudimni Senga beraman.
.         E         G#m      A            E
   Hech qachon hayotimda Sendan tonmayman Iso,
.        E     B      E
   Rabbimga sodiq qolaman.

[V2]
 Goʻlgota xochida toʻkkan qoni ila,
 abadiy hayot bergan Iso.
 Endi men Sen uchun butun hayotim yoʻlida,
 faqat Seni sevaman.</lyrics>
<key>E</key>
<title>Tuproqdan Odamni ҲСХМ28</title>
</song>