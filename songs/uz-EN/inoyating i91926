<?xml version="1.0" encoding="UTF-8"?><song><title>Inoyating</title>
<lyrics>[V1]
.Em               C
 // Inoyating, marhamating
.Am              D
 Doimo biz bilan boʻlsin.
.Em                 C
 Inoyating, mehr-muhabbating
.Am             D
 Doimo oramizda boʻlsin. //

[C1]
.     Am            D
   // Boʻlsin Sening sevging,
.  Em              C
   Boʻlsin Sening mehring.
.  Am                D
   Yuragimda yonsin oloving,
.  Em               C(D)
   Ruhimga kelsin ilhoming. //

[V2]
 // Najotkorim Sensan borim,
 Oʻzingsan tirik hayot toshim.
 Meni sevding, kurbon boʻlding,
 Senga bagʻishlayman hayotim. //</lyrics>
<key>Em</key>
<author>Sobir Umurov</author>
</song>