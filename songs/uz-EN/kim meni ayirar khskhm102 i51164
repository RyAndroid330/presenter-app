<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13819</hymn_number>
<title>Kim Meni Ayirar ҲСХМ102</title>
<key>D</key>
<lyrics>[V1]
.D           F#m
 Kim meni ayirar,
.        G           A
 Sevgingdan mening Rabbim,
.D           F#m
 Kim meni ayirar,
.       G             Asus4 A
 Sening sevgingdan Rabbim.

[C1]
.  Hm        F#m
   Oʻlim bas kelmas,
.  Hm           F#m
   Qoʻrquv dahshat solmas,
.          G           E           Asus4 A
   Hech qanday kuch va Farishtalar ayirmas.
.  Hm       F#m
   Qorongʻu kunlar
.  Hm        F#m
   Va na tashvishlar,
.          G             E
   Xech qanday baland pastliklar,

[B1]
.  A             F#
   Va butun erdagi tirik jonlar,
.        G          A           D       Hm
   Buyuk sevgingni mendan tortib olmas, Rabbim,
.       G           A           D
   Buyuk sevgingdan meni mahrum qilmas.</lyrics>
</song>