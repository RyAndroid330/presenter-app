<?xml version="1.0" encoding="UTF-8"?><song><title>Tong otib Q42</title>
<key>F</key>
<lyrics>[V1]
.Dm              Bb
 Tong otib, kun botmoqda,
.C                   Dm
 Rabbiy kelarkin qay chogʻ?
.Dm         Bb
 Bogʻlari hosilga kon,
.C                    Dm
 Tashrif aylarkin qay chogʻ?

[C1]
.     Gm           F
   // Guldastalar poyana,
.  Gm              F
   Qushlar kuylar madhiya.
.  Gm              Bb    C
   Barcha qoʻshiq, kuy Senga,
.  Bb       C      Dm
   Bulbul sayrar Samoda. //

[V2]
 Qir parda, qizil lola,
 Chuchmoma, moychechaklar,
 Toʻplanishib raqs tushar,
 Sano ayta olqishlar.

[C2]
   // Bir kun kimga gʻalaba,
   Kim ortdana, kim yonda.
   Rabbim kelar bir kuni,
   Bardosh tilab har kimga. //</lyrics>
<hymn_number>42</hymn_number>
</song>