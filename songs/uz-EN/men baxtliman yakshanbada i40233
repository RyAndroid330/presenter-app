<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G               Am
 Men baxtliman yakshanbada,
.D
 Dushanbada, seshanbada,
.                   G
 Chorshanbada, payshanbada,
.G                     Am
 Men baxtliman juma, shanbada,
.       D                G
 Chunki Iso mening zoʻr doʻstim.

[V2]
 Kalom oʻqi yakshanbada,
 Dushanbada, seshanbada,
 Chorshanbada, payshanbada,
 Kalom oʻqi juma, shanbada,
 Xudo soʻzin qadrlagin.

[V3]
 Ibodat qil yakshanbada,
 Dushanbada, seshanbada,
 Chorshanbada, payshanbada,
 Ibodat qil juma, shanbada,
 Eshitadi Xudo ibodatingni.</lyrics>
<title>Men baxtliman yakshanbada</title>
</song>