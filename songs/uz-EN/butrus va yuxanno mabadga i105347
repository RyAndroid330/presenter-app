<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>28</hymn_number>
<title>Butrus va Yuxanno maʼbadga</title>
<lyrics>[V1]
.C  C7     A  F  C
 Butrus va Yuxanno maʼbadga borganida
.  C7      F     C  G7    C
 SHu yerda oʻtirgan shol tilanchilik qilyapti

[C1]
.     C(G7)    G7 (F  -   G7)
   // U yuryapti, yuguryapti xamdu sano aytdi //
.    C    C7   F
   Nosiralik Isoning nomi bilan
.     C  G7  C
   Oʻrnidan turib yuryapti.

[V2]
 Menda oltin va kumush yoʻq
 Menda borini senga beraman
 Nosiralik Isoning nomi bilan
 Oʻrningdan turib yurgin</lyrics>
<key>C</key>
</song>