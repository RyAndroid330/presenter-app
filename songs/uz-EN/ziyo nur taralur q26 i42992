<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26</hymn_number>
<title>Ziyo nur taralur Q26</title>
<key>Am</key>
<lyrics>[V1]
.Am         C      Dm           Am
 Ziyo nur taralur, Sen tashrif etsang.
.Am         C      Dm         Am
 Umid uchqunlaydi, Sen kulib boqsang.

[C1]
.     Dm                Am       G
   // Toxir-u Zuhrolar koʻngil ololmas,
.  G                  C             E
   Faqat Sen yoqasan, chin soʻzim, bilsang. //

[V2]
 Iqbolim porlar-mu, ne ojiz bir hol,
 Zabonsiz yuragim urar bemalol.

[C2]
   // Ayriliq savdosi mehmondir banda,
   Butkul qalbim beray, beray Oʻzingga. //</lyrics>
</song>