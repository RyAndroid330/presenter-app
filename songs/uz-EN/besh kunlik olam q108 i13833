<?xml version="1.0" encoding="UTF-8"?><song><aka>Ikki dunyo</aka>
<key>Ebm</key>
<lyrics>[V1]
.   Am                          E
 // Ikki dunyo bor yekandir azaldan,
.                   Am        A7
 Bokiy yurtga men karayman tuymasdan. //

[C1]
.  A7                Dm                 Am
   Besh kunlik bu olamda yigi zorlar kupdir,
.               E                     A7    Dm     Am
   Bevafo bu olamda Xudoni bilgan jon kanday baxtlidir.

[V2]
 Bu olamda umrimni yarimi utdi Seni bilmay,
 Bu olamda uzimni yoshi bir yerga yetdi Seni bilmay.

[C2]
   Besh kunlik bu olamda kaygu xasrat kupdir,
   Va lekin bu olamda Xudoni bilgan jon kanday baxtlidir.

[B1]
   Ikkinchi matnli versiya

[V3]
.   Ebm
 // Ikki dunyo,
.            Abm
 bor ekandur azaldan!
.Abm
 Baxtli hayot,
.B                 Ebm
 men qarayman bilmasdan! //

[C3]
.     Ebm                 Abm
   // Besh kunlik - bu olamda,
.  C#                  F#
   Koʻp tashvishlar koʻpdur.
.  B               Abm
   Men uchun - bu olamda
.  Bb
   Xudoni sevgandan,
.  Ebm
   Oʻzga baxt yoʻqdur! //

[V4]
 // Bu olamda umrimning yarmi oʻtdi
 Seni bilmay,
 Bu olamda koʻzimning yoshi bir yerga yetdi
 Seni bilmay. //

[V5]
 Bu besh kunlik tashvishlar
 Oʻtar - ketar doʻstim
 Yodingda tut Yaratganni
 Unutma doʻstim!
 Bu besh kunlik tashvishlar ham
 Oʻtar - ketar doʻstim
 Yaratganni yodingda tut
 Unutma doʻstim!

[C4]
   //// Besh kunlik - bu olamda,
   Koʻp tashvishlar koʻpdur.
   Men uchun - bu olamda
   Xudoni sevgandan,
   Oʻzga baxt yoʻqdur! ////
   Xudoni sevgandan,
   Oʻzga baxt yoʻqdur!</lyrics>
<title>Besh kunlik olam Q108</title>
<hymn_number>108</hymn_number>
<author>Һemidәm һәdә</author>
</song>