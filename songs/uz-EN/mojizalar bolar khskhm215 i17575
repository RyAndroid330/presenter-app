<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>215</hymn_number>
<lyrics>[V1]
.Em                D
 Rabbim bizni yaratdi
.B7           Em
 Qalbimizga imon soldi
.C         G            Am          B7
 Yaratish uchun har bir odam yaratilgan
.  Em           D
 Toqqa buyurtirgin
.    B7         Em
 Dengizning tubiga qula
.  C        G            Am         D
 Nimaiki desang bajo boʻlgay faqat ishon

[C1]
.  G               D
   Moʻjizalar boʻlar faqat ishon
.  Em      Bm    C      Dsus4  D
   Umidingni amalga oshirar Xudo
.  G                D
   Orzuingni topshir faqat ishon
.  Em       Bm    C        Am      D     Em
   Oʻshanda Rab ham eshik ochar Moʻjizalar uchun

[V2]
.Em              D
 Dahshat qoplaganda
.   B7        Em
 va sinovlar ezganida
.  C       G              Am        B7
 Umidimiz uchib ketar qushlardek samoga
.    Em        D
 Lek men ishonaman
.    B7           Em
 Rabbiy quvvatlab U aytgan
.  C          G            Am         D
 U meni qoldirmas va tark etmas faqat ishon

[B1]
.    C              D   G
   Orzuingni mahkam tut va Yasha
.         C                            G
   Taslim boʻlma gʻolib chiq bari oldinda
.      C
   Kulfat toʻsatdan kelsa gar
.     G
   Rabbiy doim yoʻling ochar
.        C
   Sen tirik soʻzla eshitgin
.      D
   Togʻlar ham qulaydi</lyrics>
<key>Em</key>
<title>Moʻjizalar Boʻlar ҲСХМ215</title>
</song>