<?xml version="1.0" encoding="UTF-8"?><song><title>Sen Uchun</title>
<key>Em</key>
<lyrics>[V1]
.Em                 Bm
 Yomgʻir yoqqanda osmonga qarayman
.C                   D
 Balki bu Rabbim deb xayol qilaman
.Em                Bm
 Gumbirlar chaqmoq qoʻrqib ketaman
.C                    D
 Balki bu Rabbim deb Uni kutaman

[P1]
.  Am                   Em
   Agar inson bilsa edi Uning qaygʻurishini
.  F#                     H
   Biz uchun jonini fido qilganligini

[C1]
.  Em                  Bm
   Sen uchun jon fido qilgan
.  C                      D
   Sen uchun Oʻz hayotini bergan
.  Em                      Bm
   Lekin inson Uni bir zum sevmadi
.  C                            D
   Xochga mixlab Xudo oʻgʻlini qiynashdi

[V2]
.Em              Bm
 Kim kimni aldar kim kimni urar
.C                              D
 Hatto qarindoshlar ham bir biriga qarshi turar
.Em                   Bm
 Dunyoda sevgi tugar inson Xudoni unutar
.C                       D
 Hatto yosh bolalar ham gunohni oʻrgatib qoʻyar

[P2]
.  Em                    Bm
   Xudo buni oʻrgatmadi bizga sevgini oʻrgatdi
.  C                     D
   Hammani Xudo gunohdan asrab yangi hayotga undadi</lyrics>
<hymn_number>23415</hymn_number>
<author>Sobir Umurov</author>
</song>