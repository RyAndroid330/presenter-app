<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Xizirov</author>
<lyrics>[V1]
 Rabbim kelgay
 Samolarda
 Farishtalar
 Ziyolarda.
 Ummatlari
 Kecha-kunduz
 Qoʻli ochiq
 Duolarda
 // Rabbim kelar
 Samolarda! //

[V2]
 Yoʻqlar bugun
 Birodarim.
 Birodarim
 Duru-zarim
 Masih amri
 Sizu bizga
 Sevgin dedi
 Ochib bagʻrin!
 // Rabbim kelar
 Samolarda! //

[V3]
 Eng goʻzal dam
 Bular bu kun
 Farishtalar
 Toʻlar bu kun.
 Osmon uzra
 Bulutlarda
 Soʻnggi soat
 Va soʻnggi tun
 // Rabbim kelar
 Samolarda! //

[V4]
 // Tiz choʻkadi
 Xar tirik jon
 Tiz choʻqadi
 Tirik imon. //
 Afsuslardan
 Titrar xatto
 Qoʻldan ketib
 Soʻnggi imkon.
 // Rabbim kelar
 Samolarda! //</lyrics>
<title>Rabbim kelar</title>
</song>