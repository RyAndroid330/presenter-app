<?xml version="1.0" encoding="UTF-8"?><song><title>Buyuksan CA19</title>
<aka>Buyuksan hamma buyuklardan</aka>
<key>Bb</key>
<lyrics>[V1]
.Bb        Eb    F        Bb
 Buyuksan hamma buyuklardan,
.Bb       Eb         F          Bb
 Buyuksan bor hamma mavjudotlardan
.Bb        Gm  Gm7            Eb Bb
 Buyuksan hamma dono insonlardan,
.Cm         Eb               F
 Azaldan bor boʻlgan buyuk SHoh!

[V2]
.Bb        Eb    F          Bb
 Buyuksan hamma bor taxtlardan,
.Bb       Eb         F         Bb
 Buyuksan inson koʻrgan moʻjizadan,
.Bb        Gm  Gm7             Eb Bb
 Buyuksan hamma dunyo boyligidan,
.Cm           Eb         D D7
 Tenging yoʻqdir Sevgi Xudosi!

[C1]
.  Bb   Eb    F             Bb
   Xochga mihlanib xor boʻlgan,
.  Bb  Eb     F             Bb
   Otasi rad etib voz kechgan,
.  Bb  Gm     Gm7         Eb Bb
   Atirgulday loyga toptalgan,
.  Bb       Cm           Eb/FF7   Bb
   Aybim olding, sevib meni, buyuksan!

[C2]
.  Bb  Eb    F             Bb
   Xochga mihlanib xor boʻlgan,
.  Bb  Eb     F             Bb
   Otasi rad etib voz kechgan,
.     Bb  Gm     Gm7         Eb Bb
   // Atirgulday loyga toptalgan,
.  Bb       Cm           Eb/FF7   Bb
    Aybim olding, sevib meni, Buyuksan! //</lyrics>
<hymn_number>19</hymn_number>
<author>Lenny LeBlanc, Paul Baloche</author>
</song>