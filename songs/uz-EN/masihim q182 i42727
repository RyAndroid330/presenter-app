<?xml version="1.0" encoding="UTF-8"?><song><title>Masihim Q182</title>
<aka>Ey insonlar oching koʻzni, Nur boʻling</aka>
<lyrics>[V1]
.   Cm       Fm  Bbm    Cm     Cm    Fm   Bbm   Eb
 // Ey insonlar oching koʻzni, Masih ozod qildi bizni,
.Eb                    A     Abm   Bbm   Cm
 U keldiyu yer yuziga, ochib ketdi ruhiy koʻzni. //
.   Fm                     Bbm         Eb
 // Masih kelib yer yuziga ochib berdi jannat yoʻlin,
.Bbm                 Ab      Bbm   Cm
 U nochoru ezilganga uzatadi ikki qoʻlin. //

[C1]
.     Fm                     Eb
   // Masihimni kirgizinglar ezilgan u buzuq qalbga,
.  Ab          C#             Bbm     C#      Ab     C
   Hamdu sano ayting doʻstlar gʻolib boʻlgan bizning Rabga. //

[V2]
.   Cm              Bbm    Cm   Cm      Ab   Bbm     Cm
 // Keling barcha oʻgʻil qizlar,dunyoda nur boʻling sizlar,
.Eb           C#                       Bbm  Cm
 Xushxabarni aytib elga, doim nurda yuringizlar. //</lyrics>
<key>Cm</key>
<hymn_number>182</hymn_number>
</song>