<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>250</hymn_number>
<lyrics>[V1]
.Eb                 Bb
 Qanday osmonga men bora olaman?
.Bb                    Eb
 Velosipedga men minib olaman.
.   Ab             Eb       Cm
 // Ot aravani men topib olaman.
.Bb                  Eb
 Qanday osmonga men bora olaman? //

[V2]
 Bunga samolyot menga kerak boʻladi.
 Yoki katta kema olib boradi.
 // Mashina bilan yo raketa bilan
 Qanday osmonga men bora olaman? //

[V3]
 Gunohim qoldirib, kechirim soʻrayman.
 Shunda men osmonga bora olaman.
 // Ishonib Iso Masih Rabbimizga,
 Abadiy osmonda men boʻlaman. //</lyrics>
<key>Eb</key>
<title>Qanday Osmonga men bora olaman Q250</title>
</song>