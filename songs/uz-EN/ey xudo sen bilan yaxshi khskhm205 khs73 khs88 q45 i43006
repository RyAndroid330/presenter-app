<?xml version="1.0" encoding="UTF-8"?><song><author>Iliyas Tursun</author>
<hymn_number>241</hymn_number>
<key>Am</key>
<lyrics>[V1]
.    Am
 // Ey Xudo, Sen bilan yaxshi,
.Dm
 Ey Xudo, Sen mehribon.
.G                    Am    E
 Ey Xudo, tashnaman huzuringga. //

[C1]
.     F                Am
   // Iltijo qildim Senga,
.  F                    Am
   Yaqinlashding Sen menga,
.  F            Am  G     F   E
   Ojiz ruhimni Sen koʻtarding. //

[V2]
 // Xudo shunday degan,
 Sendan aslo ayrilmayman,
 Seni aslo tashlab ketmayman. //

[C2]
   // Botir yurak bilan safarga chiqaman,
   Qoʻrqmayman, qoʻrqmayman.
   Xudo yordamimdir, dushmanlar meni
   Nima qiloladi, nima qiloladi? //</lyrics>
<title>Ey Xudo, Sen bilan Yaxshi ҲСХМ205 ҲС73 ҲС88 Q45</title>
</song>