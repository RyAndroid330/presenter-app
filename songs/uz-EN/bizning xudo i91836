<?xml version="1.0" encoding="UTF-8"?><song><title>Bizning Xudo</title>
<key>Am</key>
<lyrics>[C1]
.      Am           G
   /// Bizning Xudo muqadddas ///
.      Am          G
   /// Xudoyimiz muqaddas ///

[V1]
.Am                G
 Osmon uzra bizga qaragin
.Am             G
 Qoʻling bilan bizga tegin
.Am        G
 Va Sening farishtalaring
.C                        E
 Er yuziga tinchlik olib kelsin

[C2]
.      Am         G
   /// Buyuk Rabbimiz ///
.      Am         G
   /// Buyuk Xudovand ///

[V2]
 Kelsin haqiqat Hukming Sening
 Hayotimiz qoʻlingda
 Yer yuzi boʻylab Sening
 Abadiy Noming Ulugʻlansin

[C3]
   /// Bizning Xudo kuchli
   Xudoyimiz kuchli ///</lyrics>
<hymn_number>23010</hymn_number>
<author>Sobir Umurov</author>
</song>