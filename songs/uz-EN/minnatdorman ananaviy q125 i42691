<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>125</hymn_number>
<lyrics>[V1]
 // Minnatdorman meni yaratganingga,
 Qorongʻuliklardan chaqirganingga. //
 // Minnatdorman kuchu qudratlaringga,
 Ulugʻ soʻzlaringga, rahmatlaringga. //

[C1]
   Oh Ollohim,Ollohim, aziz Ollohim,
   Oh Ollohim,Ollohim, ulugʻ Ollohim.

[V2]
 // Minnatdorman Sening ulugʻ sevgingga,
 Minnatdorman Sening ulugʻ qoningga. //
 // Minnatdorman hayot nafasing uchun,
 Musibatli kunlar kurashing uchun. //

[V3]
 // Minnatdorman osmondagi jannating uchun,
 Bir umrga abadiy hayoting uchun. //
 // Minnatdorman meni yaratganingga,
 Qorongʻuliklardan chaqirganingga. //</lyrics>
<title>Minnatdorman (anʼanaviy) Q125</title>
</song>