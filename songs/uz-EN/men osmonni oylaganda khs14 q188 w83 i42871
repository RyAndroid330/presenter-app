<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>14</hymn_number>
<aka>Jannat</aka>
<key>D</key>
<lyrics>[V1]
.   D           A           Bm           F#m
 // Men osmonni oʻylaganda, erdan ketgim keladi,
.G          Bb     D           A      D
 Faqatgina jannat tomon tezroq etgim keladi. //

[C1]
.     G          A             F#m           Bm
   // Oh u yerda qanday rohat, kulgu quvonch hamisha,
.  Em        A       D              A
   Abadiyat eshigiga tezroq yetgim keladi. //

[V2]
 // Iso Oʻzi kutib olar farishtalar birlikda,
 Kel oʻgʻlim deb, kel qizim deb taklif qilar jannatga. //

[V3]
 // U osmonda faqat quvonch, Iso bilan birlikda
 Kel quvon der, kel yayra der, taklif qilar jannatga/ //</lyrics>
<title>Men osmonni oʻylaganda ҲС14 Q188 W83</title>
</song>