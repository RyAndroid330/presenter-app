<?xml version="1.0" encoding="UTF-8"?><song><title>Bir marta Q6</title>
<aka>Xudodan qaytma</aka>
<lyrics>[V1]
 // Bir marta ziyoni koʻrsang,
 Samoviy lazzatdan olsang, //
 Xudo Ruhidan ruhlansang,
 Imondan qaytma ey doʻstim!
 Xudodan qaytma, qaytma.
 Xudo Ruhidan ruhlansang,
 Xudodan qaytma, qaytma.
 Imondan qaytma, qaytma.

[V2]
 // Kelajak olam qudrating
 Ochiq koʻrgan insonlar. //
 Agar Xudodan qaytsalar,
 // Hayoti imkonsiz boʻlar. //
 Imondan qaytma ey doʻstim!
 Xudodan qaytma, qaytma!

[V3]
 // Xudo adolatsiz emas,
 Muhabbatingni unutmas. //
 Agar orqaga qaytmasak,
 Aslo bizni tashlab ketmas.
 Xudo bizni tashlab ketmas.
 Imondan qaytma ey, doʻstim!
 Xudodan qaytma, qaytma!

[V4]
 // Yana biroz, birozdan keyin
 Iso Masih kelar, kechikmas. //
 Agar imondan qaytmasak,
 // Xudo bizni kutib olar. //
 Imondan qaytma ey, doʻstim!
 // Xudodan qaytma, qaytma! //</lyrics>
<hymn_number>6</hymn_number>
</song>