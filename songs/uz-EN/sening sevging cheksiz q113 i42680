<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>113</hymn_number>
<key>E</key>
<lyrics>[V1]
.   A              B          F#m      C#m
 // Sening sevging cheksiz, oʻzgarmas mutlaq,
.        A          B     A          C#m
 Sening sabring cheksiz,shifobaxsh buloq. //

[C1]
.      C#m                F#m         C#m
   /// Sen kabi boʻlishga intilar har dil,
.  F#m                   A        E
   Oh buncha yagonasan, durdonam Tangrim. ///

[V2]
 // Hayotimda saboq,qalbimga chiroq,
 Bu sevging xosiyatin,sirlarin oʻrgat. //</lyrics>
<title>Sening sevging cheksiz Q113</title>
</song>