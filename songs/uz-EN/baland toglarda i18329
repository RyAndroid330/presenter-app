<?xml version="1.0" encoding="UTF-8"?><song><title>Baland togʻlarda</title>
<aka>Men kichkina qoʻzichoqman</aka>
<lyrics>[V1]
.Gm         Cm
 Baland togʻlarda
.F           Gm
 Choʻponim ketyapti,
.Cm        Gm
 Qoʻylarni tor yoʻldan
.D
 Olib boryapti.

[C1]
.         Gm
   // Men kichkina qoʻzichoqman,
.  F         Gm
   Ergashdim Unga.
.  Cm             Gm
   Tor soʻqmoqdan borib
.  D           Gm
   Quddus shahriga. //

[V2]
 Mehribon Choʻponim
 Sevadi kamtarni.
 Faqat yoqtirmaydi
 U magʻrurlarni.

[V3]
 Men Yoʻl va Haqiqat,
 Yorugʻlik Unda.
 Orqamdan borgin sen
 Aytadi menga.</lyrics>
<key>Gm</key>
<author>Neizvestnyy</author>
</song>