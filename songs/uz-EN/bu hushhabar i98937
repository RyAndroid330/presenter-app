<?xml version="1.0" encoding="UTF-8"?><song><title>Bu Hushhabar</title>
<time_sig>Style: 140 Tempo 100</time_sig>
<key>A</key>
<lyrics>[V1]
.A          E      D         A
 Bu hushhabar! Masih tugʻildi!
.       D         A        F#m   E A
 Kuylashar farishtalar: &quot;Ajoyib habar!&quot;
.  A        E       D         A
 Ajoyib tunda, suruvin qoʻriqlab,
.      D          A        F#m    E A
 Mehribon choʻponlar eshitdi hushhabar.

[C1]
.       A     E       D     A
   Bu hushhabar! Bu hushhabar!
.    D         A       F#m      E A
   Bu kun tugʻildi bizning Shohimiz!

[V2]
 Shu kun osmonda porlagan yulduzni
 Koʻrishdi uzokdan uch donishmandlar.
 Ajoyib nur Yerga taraldi,
 Tunu kun porlab Najotga yoʻl koʻrsatdi.

[C2]
.         A    E        D    A
   Bu hushhabar! Bu hushhabar!
.    D         A       F#m      E A
   Bu kun tugʻildi bizning Shohimiz!</lyrics>
<author>Davies Gilbert, Sir John Stainer</author>
</song>