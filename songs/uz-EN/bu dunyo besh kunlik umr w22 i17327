<?xml version="1.0" encoding="UTF-8"?><song><author>Gulmira (Moynaқ), Rustam</author>
<hymn_number>22</hymn_number>
<title>Bu dunyo besh kunlik umr W22</title>
<key>Bm</key>
<lyrics>[V1]
.Bm                   Em
 Bu dunyo besh kunlik umr
.A                       Bm
 Bari yolgʻon bari oʻtkinchi
.Bm                    Em
 Dunyodagi, hamma narsa
.Fm                   Bm
 Tugaydi Sen kelgan kuni

[C1]
.  G              A     D Bm
   Yangi dunyo yangi umr
.  Em      A          Bm
   Haqiqat mangulik umr
.  G             A      D Bm
   Tugamas baxtu quvonch
.  Fm                       Bm
   Boshlanar Sen kelgan kuning

[V2]
 Sening mehring daryoday cheksiz
 Quyoshday moʻl nurlaring Sening
 Oʻtinaman nuringni soch
 Qutqarib ol halqim menin

[V3]
 Xudoyim kechir gunohimiz
 Sendan oʻzga yoʻq panohimiz
 Hammasiga qodir Oʻzingsan
 Yolgʻiz Senga sigʻinamiz</lyrics>
</song>