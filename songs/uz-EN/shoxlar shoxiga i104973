<?xml version="1.0" encoding="UTF-8"?><song><title>Shoxlar Shoxiga</title>
<lyrics>[V1]
.D      Bm7        G
 Zulmat ichiga burkanib,
.     A        D
 no umid kutardik
.      Bm7           G
 Sen osmondan bizga kelgach,
.      A              D
 Mehr koʻzlaring koʻrdik
.       Bm7         G
 Paygʻomlar amalga oshdi,
.        A             D
 boikra qizga Soʻz keldi
.          Bm7            G
 Cheksiz shon-shuhrat tahtidan,
.    A          D
 oramizga U keldi

[C1]
.  D         G
   Otamizni ulugʻlang
.  Bm7           Asus4  A
   Oʻgʻil shuxratin kuylang
.   D            G
   Muqaddas Ruh, Uch birlik
.   Bm7     G                A   D
   Madhlar boʻlsin Shoxlar SHoxiga

[V2]
.       Bm             G
 Oshkor qilib Sen shohliging,
.       A             D
 yoʻqolganga yoʻl ochding
.    Bm          G
 Ijodingni qutqarish chun,
.        A             D
 hochdan ham Sen qaytmading
.    Bm7          G
 Azoblardan oʻta turib,
.       A            D
 bizlar haqda oʻylarding
.     Bm           G
 Bilarding bu Najotimiz,
.     A            D
 Iso biz uchun oʻlding

[V3]
.       Bm7         G
 Tong sahar tirilganingda,
.        A           D
 borliq jim kutib turdi
.     Bm7             G
 Qabr tosh joydan siljidi,
.      A           D
 Qoʻzi oʻlimni yengdi
.     Bm7             G
 Va oʻlganlar tirildilar,
.       A          D
 farishtalar hayratda
.       Bm7            G
 Barcha qaytib kelgan jonlar,
.    A             D
 Ota bilan birlashdi

[V4]
.   Bm7            G
 Jamoat barpo boʻldi,
.      A            D
 Muqaddas olov tushdi
.     Bm7          G
 Endi Injil hushhabari,
.       A            D
 jim turmaydi, kutmaydi
.     Bm7        G
 Qoni va nomi bilan,
.     A          D
 Unda men ozoddirman
.      Bm7      G
 Masih Sevgisi uchun,
.      A           D
 endi men tirikdirman!!!</lyrics>
<key>D</key>
<author>Hillsong Worship</author>
</song>