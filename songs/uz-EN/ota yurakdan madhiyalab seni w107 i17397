<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ota yurakdan, madhiyalab Seni
 Yoʻlga termilib Seni kutaman
 Mehringa tashna boʻldim intizor
 Kelgin qoshimga quyosh nuridek.

[C1]
   // Hamdu sano soz yangrasin Senga
   Koʻngillar qonsin, bagʻishlab Senga //

[V2]
 Ozgan bolangman qildim pushaymon
 Oʻksinib Ota yondim men Senga
 Kechirgin Ota gunohlarimni
 Boʻlay men endi huzuringda</lyrics>
<title>Ota yurakdan, madhiyalab Seni W107</title>
<hymn_number>107</hymn_number>
<author>Қuddus aka, Khәliқ nakhshisi</author>
</song>