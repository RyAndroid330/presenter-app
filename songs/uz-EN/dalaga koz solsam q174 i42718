<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>174</hymn_number>
<lyrics>[V1]
.Gm                  F
 Dalaga koʻz solsam, oʻtmishni oʻylasam,
.Gm           F         Cm          D
 Necha kunlik umrim bor, soni yoʻq sanasam.

[C1]
.     Gm                 F
   // Yurakda maza yoʻq, hayotda qaygʻu koʻp,
.  Gm          F         Cm      D
   Tinchlikni topolmay yurakka mador yoʻq. //

[V2]
 Yaratguchi Otam, dunyoni gullatgan,
 Olamning Egasi qutqargin azobdan.

[V3]
 Xudoyim eshitdi, gunohim kechirdi,
 Gunohkor men uchun Oʻz Oʻgʻlin yubordi.

[V4]
 Gunohdan qutqargan, biz uchun qiynalgan,
 Ishondim Isoga, U kelgan Xudodan.

[C2]
   // Bu qanday quvonchki, bu qanday tinchlik?!
   Orom topildi yuragim quvondi. //</lyrics>
<key>Gm</key>
<title>Dalaga koʻz solsam Q174</title>
</song>