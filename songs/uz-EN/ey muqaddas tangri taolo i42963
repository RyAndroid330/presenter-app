<?xml version="1.0" encoding="UTF-8"?><song><title>Ey, muqaddas Tangri taolo!</title>
<lyrics>[V1]
.Bbm                 Ebm
 Ey, muqaddas Tangri taolo!
.B           Abm   Bbm
 Boshim uzra panoh Sen.
.F#          F    Ebm
 Har qadamim nazaringdadur,
.B            Abm  Bbm
 Qilmishimdan ogoh Sen.

[C1]
.     Ebm
   // Soʻqir boʻlgan qalb koʻzlarim,
.  F#         Ab    C#
   Oʻzing ochding Masihim!
.  Bbm        Ebm
   Kechirimli parvardigor,
.  B           Abm    Bbm
   Ruhimga kel hamroh Sen. //

[V2]
.Bbm            Ab
 Najot berding, Menga kel Sen.
.C#          Ebm Ab C#
 Edim osiy gumroh Men,
.F#            F
 Meni shuncha, aziz etding.
.C#               Ebm Ab C#
 Garchi Men kim, tuproq Men.

[C2]
.     Ebm
   // Qalbimga boʻlding Shohanshoh.
.  F#        Ab     C#
   Sensan Mening Masihim!
.  Bbm          Ebm
   Jon-u tanim kuylar Seni,
.  B               Abm  Bbm
   Qoʻlda gʻijjak segoh Men. //

[V3]
.Bbm         C#
 Borar joyim aytding behisht,
.Abm           C#
 Eng muqaddas dargoh Sen.
.C#             Abm
 Mehr-u shavqat faqat Senda,
.Ebm         B Abm Bbm
 Inson sevar Olloh Sen!

[C3]
.     Bbm(Ebm)
   // Hayotimda porloq quyosh,
.  F#       Ab    C#
   Sensan oʻzing Masihim!
.  Bbm          Ebm
   Bor vujudim Senga fido,
.  B           Abm   Bbm
   Nola qilgum devon Men. //

[V4]
.Bbm                  Ebm
 Ey, muqaddas Tangri taollo!
.B            Abm  Bbm
 Boshim uzra panoh Sen.
.F#            F      Ebm
 Har qadamim nazaringdadur,
.B            Abm  Bbm
 Qilmishimdan ogoh Sen.
.Ebm
 Soʻqir boʻlgan qalb koʻzlarim,
.F#         Ab     C#
 Oʻzing ochding Masihim!
.   Bbm              Ebm
 // Kechirimli parvardigor,
.B            Abm   Bbm
 Ruhimga kel hamroh Sen. //</lyrics>
