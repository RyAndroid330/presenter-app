<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>100</hymn_number>
<title>Uyga ketiyapman ҲСХМ214</title>
<aka>Meni Oʻylab</aka>
<key>G</key>
<lyrics>[C1]
.     Em      Am           B7
   // Meni oʻylab, meni oʻylab,
.         Em  D       C
   azoblardan Sen bording!
.          Am          B7         Em   Em7
   Meni oʻylab, azoblardan yigʻlarding!
.  Em      Am   D        B7
   Meni oʻylab, meni oʻylab,
.            Em          C
   Sen Oʻzingdan ham kechding!
.      Am           B7         Em   Em7
   Yuragimda doim yashaysan Rabbim!  //

[V1]
.Em             D            C
 Qanoti singan, bir qush misoli,
.Em               D          G
 Visolingga qarab uchaman Rabbim!
.      Am              B7           Em D C
 // Loyiq boʻlmasam ham buyuk sevgingga,
.        Am             B7          Em
 Bagʻringni keng ochib, kelarsan menga! //

[V2]
 Yuragimdan Seni sevmagan edim,
 Qoqilib yurarman, xatto hozir ham!
 // Sevaman Azizim, Jigarim deya,
 Bagʻringga bosarsan, meni koʻtarib! //

[V3]
 Bu hayot ham tushday, oʻtib ketadi,
 Bor boʻlgandirman, buning farqi yoʻq!
 // Uygʻonib bulardan, qaytarman uyga,
 Bagʻringni keng ochib, kelarsan menga! //

[V4]
 Borligʻim bilan, men Seni kuylayman!
 Buyuklarning Buyugisan Sen Rabbim!
 // Ulugʻlayman Seni vujudim bilan,
 Hayotimni Senga topshirdim Rabbim! //

[B1]
   Najotkorim! Qurbonligim!
   Hayot bergan bulogʻim!
   Yuragimda sevgi toshib oqmoqda!
   Hayot berding, tinchlik berding,
   Koʻz yoshlarimni ham artding,
   /// Yuragimda doim yashaysan Rabbim! ///</lyrics>
</song>