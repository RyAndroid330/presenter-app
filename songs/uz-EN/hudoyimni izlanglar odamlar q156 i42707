<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>156</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em         C         Am             B
 Xudoyimni izlanglar, yigʻlab kuyib izlanglar,
.Em          C        Am          B
 Vaqt borida odamlar, kech-kunduz izlanglar.

[C1]
.     Em            D        C          B
   // Qish vaqtida, bahorda, Xudoyimni izlanglar. //

[V2]
.Em          C          Am           B
 Har qayerda izlanglar, har bir odam izlanglar,
.Em             C      Am           B
 Najot bir kun topasiz va osmonga yetarli.
.B         B7
 Quvonchga siz toʻlasiz.

[C2]
.     Em         D         C          B
   // Non qanday izlanilsa,Xudoyimni izlanglar. //
.  Em
   Odamlar!</lyrics>
<title>Hudoyimni izlanglar odamlar Q156</title>
</song>