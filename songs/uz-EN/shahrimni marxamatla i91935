<?xml version="1.0" encoding="UTF-8"?><song><title>Shahrimni Marxamatla</title>
<lyrics>[V1]
 // Shahrimni marhamatla ey Egam Xudo,
 Yurtimni uygʻontirgin ey Rabbim Iso. //

[C1]
   /// Muqaddas Ruh huzuring kelsin, ///
   // Har bir yerda marhamat inoyating boʻlsin. //

[V2]
 // Doira chalib, raqs ila hamdu sano ayting,
 Torli asbob nay chalib Unga hamdu sano kuylang. //

[V3]
 // Egangni olqishlaginey aziz inson,
 Seni tashlab qoʻymaydi egang hech qachon. //</lyrics>
<author>Sobir Umurov</author>
</song>