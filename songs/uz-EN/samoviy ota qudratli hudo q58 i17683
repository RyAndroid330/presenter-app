<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<key>Fm</key>
<lyrics>[V1]
.Fm
 Samoviy Ota qudratli Xudo,
.Fm
 Najotkorimiz olamning Shohi.

[C1]
.     Bbm                 Fm
   // Sen abadiy barhayot va donosan,
.  F#                  Fm
   Biz bilan boʻlgin yoritgin bizni. //

[V2]
.Fm          Ab
 Samoviy Ota baxtlik bulogʻi,
.Bbm            Ab
 Qoldirma bizni hayot bergin.

[C2]
.     Fm                  Ab       Bbm
   // Solihlik ber Oʻzing Shohimiz boʻlgin,
.  C#              Ebm   Fm
   Dilga donolik qudrat solgin. //

[V3]
.   C#          Ab
 // Samoviy Ota bizga najot ber,
.Bbm             Eb      Ab
 Xotirjamlik va solihlik ber. //

[C3]
.     Bbm                     Fm
   // Quvnoq qoʻshiqlar bilan dilni toʻldir,
.  C#            Ebm     Fm
   Inoyat bilan bardam qilgin. //

[V4]
.Fm
 Samoviy Ota qudratli Xudo,
.Fm
 Najotkorimiz olamning Shohi.

[C4]
.     Bbm                 Fm
   // Sen abadiy barhayot va donosan,
.  C#                Ebm      Fm
   Biz bilan boʻlgin yoritgin bizni. //
.     Fm         Bbm    C#       Ebm Fm
   // Biz bilan boʻlgin yoritgin bizni. //</lyrics>
<title>Samoviy Ota qudratli Hudo Q58</title>
</song>