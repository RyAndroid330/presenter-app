<?xml version="1.0" encoding="UTF-8"?><song><author>Hillsong</author>
<hymn_number>42</hymn_number>
<title>Iso Xudo Oʻgʻli</title>
<lyrics>[V1]
.D    G      A    D
 Yonimda boʻlgin doim,
.D     G   A      D
 Sen nurim va hayotim.
.D           A       D
 Yoʻlimni Oʻzing boshqar,
.D         A       D
 Xudovand Sen Choʻponim.

[C1]
.  D     G      A         Bm
   Najotkorim shuhratli Rabbim,
.         G     Em      A
   Xaloskorim yashar qalbimda doim.
.          G      A        Bm
   Shohligingni olding Sen to abad,
.     Em   Bm(D)
   // Iso Xudo Oʻgʻli. //

[V2]
 Havodek zarur menga,
 Umidim faqat Senda
 Osmonda malaklar kuylar,
 Shon-shuhrat va kuch Senga

[C2]
.  D G    A  D    G    A    D
   Iso, o Iso Xudoning Qoʻzisi -x4
   Muqaddas Xudo Qoʻzisi</lyrics>
<key>D</key>
<aka>Yonimda boʻlgin doim</aka>
</song>