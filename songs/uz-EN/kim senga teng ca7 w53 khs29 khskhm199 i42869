<?xml version="1.0" encoding="UTF-8"?><song><title>Kim Senga teng CA7 W53 ҲС29 ҲСХМ199</title>
<aka>Barhayot Otamiz</aka>
<key>F</key>
<lyrics>[V1]
.   Am             Dm     Am
 // Kim Senga teng keladi Ota,
.Bb        Gm         Am
 Koinotda tengi yoʻq Senga. //
.   Dm         Am           Bb    F
 // Kuylayman Senga, osmon Xudosiga,
.Gm           Am
 Barhayot Otamizga. //

[V2]
 // Kim Senga teng keladi Iso,
 Najot bergan Xudo qoʻzisi. //
 // Sen ulugʻlangansan, isming Seni yuksalgan,
 Hammadan ham ulugʻsan. //

[V3]
 // Kim Senga teng Muqaddas Ruhim,
 Yupatuvchi, aziz mehribon. //
 /// Biz bilan yoʻlga tush, jannat tomon koʻrsat yoʻl,
 Jannatga olib bor. ///</lyrics>
<hymn_number>7</hymn_number>
</song>