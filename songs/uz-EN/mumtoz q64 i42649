<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>64</hymn_number>
<title>Mumtoz Q64</title>
<lyrics>[V1]
.   Em                                               B
 // Mumtoz xalqingni boqish uchun samodan tushding Oʻzing,
.B                                      Em
 Gunohkor qoʻzilarga qoʻychivon boʻlib kelding. //

[C1]
.     Em                                        Am
   // Kimning chechan zaboniyu kimning baxtiyor ogʻzi?
.  Am                      B            Em
   Soʻzlaverar, olar ekan bizning iqbolimizni? //

[V2]
 // Xaq podshohlik nima boʻbdi axir unda kuch yoʻqmi?
 Holi boʻlamiz ofatdan Rabbimiz Iso bilan. //

[V3]
 // Bizni xastalik qiynasa hech kim shifo berolmas,
 Rabbimizdan oʻzga hech kim jonga najot berolmas. //</lyrics>
<key>Em</key>
</song>