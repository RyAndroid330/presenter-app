<?xml version="1.0" encoding="UTF-8"?><song><title>Hamdu Sano 5</title>
<lyrics>[V1]
 // Muqaddas Ruh yuraklarni
 Nuring bilan yoritgin, //
 // Olamning zulmatini Sen,
 Sevging bilan toʻldirgin. //

[C1]
   Ulugʻlaymiz, ulugʻlaymiz, Rabbimizni ulugʻlaymiz.
   Olqishlaymiz, olqishlaymiz, Xudovandni olqishlaymiz.
   Ulugʻlaymiz, ulugʻlaymiz, Xudovandni olqishlaymiz.

[V2]
 // Endi bizning dilimizda
 Oʻzing makon yaratgin. //
 // Nurli olov boʻlib yongin,
 Qalbimizga joylashgin. //

[V3]
 // Muqaddas Ruh qudrating ila
 Sodiqlarga kuch bergin. //
 // Jamoating tiklagin,
 Oʻzbek xalqin koʻtargin. //</lyrics>
</song>