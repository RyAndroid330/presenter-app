<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Barakaot</title>
<aka>Agar uyni Xudovand qurmasa</aka>
<key>Ab</key>
<lyrics>[C1]
.     Ab       Fm       Db        Eb
   // Agar uyni Xudovand, Xudovand qurmasa
.  Ab         Fm      Db        Eb
   Quruvchilar bekorga, bekorga ishlaydilar //

[V1]
.   Db                   Eb
 // Agar shaharni Xudovand qoʻriqlamasa
.Db            Eb
 Qorovul bekorga bedor qoladi //

[B1]
.       Ab      Eb   Fm
   ////  Bekorga sizlar sahar turib
.         Db     Eb
   Tungi uyqudan qolasizlar ////

[V2]
.   Db               Eb
 // Bekorga gʻam-gʻussa nonini yeysizlar
.      Db
 Mana, Xudoning mahbubiga
.Eb
 Uyqu nasib etar //

[C2]
.       Ab
   //// Har bir baraka,
.  Fm
   Har bir baraka,
.  Db            Eb
   Har bir baraka Xudodan ////</lyrics>
</song>