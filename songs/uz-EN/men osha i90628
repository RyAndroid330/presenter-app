<?xml version="1.0" encoding="UTF-8"?><song><aka>Kel, Men hayot Noni</aka>
<lyrics>[V1]
.C              Em
 Kel, Men hayot Noni
.F                G
 Abadiy hayotning bulogʻi
.C                 Em
 Kel, Men haqiqat imon Yoʻliman
.       F                         G
 Men bilan qoqilmassan yoʻlingda aslo

[C1]
.  C                     Em
   Men Oʻsha senga hayot ulashgan
.  F                          G
   Xochda Oʻz jonin senga qurbon qilgan
.  C                      Em
   Men Oʻsha unutma hech Meni bolajon
.  F                            G
   Imonda qol, imoning boʻlsin Menga qurbon

[V2]
.C            Em
 Men Xudovandning Nuriman
.F                        G
 Inson qalbin oʻzgartirguvchi Kalom
.                           Em
 Men Oʻsha shaytonni yengib magʻlub qilgan
.      F                      G
 Va senga abadiy hayotni bergan</lyrics>
<key>C</key>
<title>Men Oʻsha</title>
</song>