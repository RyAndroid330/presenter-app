<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>65</hymn_number>
<title>Sulh beruvchi mening Rabbim Q65</title>
<key>F</key>
<lyrics>[V1]
.Dm                           Gm              C
 Sulh beruvchi Mening Rabbim, ezgulik qilding Menga.
.F              Gm         Bb       Am      Dm
 Tabibimsan, shifolantir, sevging cheki qayerda?
.   Dm                          Gm              C
 // Men ham Senga dushman edim, tob bermasdan qonunga,
.F             Gm          Bb        Am       Dm
 Shunday boʻlsa-da, Sen oʻzing najot berdng jonimga. //

[V2]
.Dm          G        Bb    C
 Men Sendan yiroqda edim, gunohli hayot chekib.
.Dm           G       Bb     C
 Fahsh botqogʻiga botgandim, erda noumid qolib.
.   F                             Gm        C
 // Menga Sening rahming kelib, oʻlimdan tiriltirding,
.F            Gm           Bb     Am       Dm
 Tinmay madh eturman Seni, yoyib Seni shuhrating. //

[C1]
.  Dm
   Masihim ozod qilgan deb,umidim-la bardamman.
.  C                     Bb                A
   Meni oʻlim uyqusidan, uygʻotgani uchun hursandman.
.  Dm
   Unga Mening sevgim yongan, yarashdim Rabbim bilan.
.  C                      Bb              Dm
   Zero xochdagi qoni-la, U menga najot bergan.

[V3]
.   Bb                       Gm
 // Ikkilanmay izlaringdan shubhasiz yurgim kelur, //
.F        Gm          Bb         A      Dm
 Gunohkor olam ahliga najoting eltgim kelur.
.   Bb                      Gm
 // Yurakka tasalli berib, ruhimni quvontirar.
. F            Gm          Bb        A     Dm
 Tanamni ham bardam qilib, yovuzlikdan qaytarar. //

[V4]
.   Dm                     Gm
 // Sulh beruvchi Mening Rabbim, ezgulik qilding Menga.
. F               Gm         Bb     A     Dm
 Tabibimsan, shifolantir, sevging cheki qaerda? //
.   Bb        A     Dm
 // Sevging cheki qaerda? //</lyrics>
</song>