<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Men charchab darmonsiz qoldim,
 Yo, Rabbim senga keldim! //
 // Yo, Rabbim senga keldim,
 Jonsiz ruhim qoʻllagin! //

[V2]
 // Dilimga tinchlik bergin,
 Mehring bilan saqlagin! //
 // Yo, Rabbim senga keldim,
 Jonsiz ruhim qoʻllagin! //

[V3]
 // Baxtsiz dunyoda yashab,
 Orom qayerda, topmadim. //
 // Yo, Rabbim senga keldim,
 Jonsiz ruhim qoʻllagin! //

[V4]
 // Amringni bajarishimga
 Yordam ber hayotimda! //
 Muhabbat qanotlaringda
 Oborasan Samoga!
 // Yo, Rabbim senga keldim
 Jonsiz ruhim qoʻllagin! //
 // Jonsiz ruhim qoʻllagin! //</lyrics>
<title>Men charchab darmonsiz qoldim (T) Q71</title>
<hymn_number>71</hymn_number>
</song>