<?xml version="1.0" encoding="UTF-8"?><song><author>Timoʻtiy, Ester</author>
<title>Nomingni tinmay ulugʻlarman</title>
<lyrics>[V1]
.Am      G      Dm    Am
 Bogʻim meva bermasa ham
.Am       G       Dm    Am
 Qoʻramda mol boʻlmasa ham
.   Am      G       Dm       Am
 // Moddiy boyligim boʻlmasa ham
.Am        G      Dm      Am
 Nomingni tinmay ulugʻlarman //

[C1]
.    Dm          Am
   CHunki yagona Panohim Oʻzing
.    Dm            Am
   CHunki hayotim mazmuni Oʻzing
.   G           E       Am
   Mening boyligim ham Sen Oʻzing
.  G             E        Am
   Mening borligʻim Rabbim Oʻzing

[V2]
 Tushkunlikka tushganda ham
 Gʻamu qaygʻuga botganda ham
 // Shodlikdan asar boʻlmasa ham
 Nomingni tinmay ulugʻlarman //

[V3]
 Yaqinimlarim hiyonat qilsalar ham
 Dushmanlarim mazah qilsalar ham
 // Yaqin deganim tonib ketsa ham
 Nomingni tinmay ulugʻlarman //</lyrics>
<key>Am</key>
</song>