<?xml version="1.0" encoding="UTF-8"?><song><author>Abduhalimov Ulugʻbek</author>
<title>Men dedim Sen</title>
<aka>Alamlarda xasratlarda qolganimda</aka>
<key>Bb</key>
<lyrics>[V1]
.   Gm                F      Eb                    Gm
 // Alamlarda, hasratlarda qolganda men dedim Sen, Sen,
.F                   Eb                           Gm
 Bu vujudim xoʻrliklardan tolganda men dedim Sen, Sen. //
.      Cm            F       Bb
 // Ey Tangri Taolo qalbimga oro
.Cm        F               Gm
 Men Seningman, Seningman mudom. //

[V2]
.   Gm                   Cm          F          Bb
 // Johillarning jazosin olganda men dedim Sen, Sen,
.Gm                     Cm        F          Bb
 Munofiqlar orasinda qolganda men dedim Sen, Sen. //
.   Cm             F      Bb
 // Tangri Taolo qalbimga oro
.Eb              F         Gm
 Men Seningman, Seningman mudom. //

[B1]
.     Gm                  F        Bb   Gm
   // Nechalar ketdilar, Seni rad etdilar,
.  Eb                     F        Gm
   Gʻazabda yondilar va Sendan tondilar. //
.  Eb               Cm             Gm
   Najoting bebaho, men uchun Sen daho,
.  Cm                  F            Bb
   Men bugun shodman, borurman Sen tomon.
.     Cm             F      Bb
   // Tangri Taolo qalbimga oro
.  Eb              F          Gm
   Men Seningman, Seningman mudom. //
.     Eb              F         Gm
   // Men Seningman, Seningman mudom. //</lyrics>
</song>