<?xml version="1.0" encoding="UTF-8"?><song><aka>Xuzuringga egiltirdim jahon</aka>
<lyrics>[V1]
.   Am                      C
 // Xuzuringga egiltirdim jahon,
.       G
 Men tezroq intilib shoshilaman
.      Dm
 Kecha-kunduz boʻlib Nigorom,
.       F                 G
 Men yoʻlinga intizor boʻldim! //

[C1]
.     G             C
   // Lekin shodlik toʻla koʻzlaring,
.          Am
   Qalbim ila his etdim shu on!
.            F                Dm
   Tabassum etibli nurli yuzlaring,
.     F                 G
   Otalikning mehridan ishon! //

[V2]
 Sevging ila Rabbim
 Meni Oʻz yoningga chorlagin
 Xizmatim qilib Senga
 Chorlayin men yoshlarni!

[C2]
   //// Lekin shodlik toʻla koʻzlaring
   Qalbim ila his etdim shu on
   Tabassum etibli nurli yuzlaring
   Otalikning mehridan ishon! ////
.  G  Am
   OTAJON!</lyrics>
<key>C</key>
<title>Lekin shodlik toʻlo koʻzlaring</title>
</song>