<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[C1]
.     Dm         Gm
   // Rab mening choʻponimdir
.  C                Dm
   Hech kimdan qoʻrqmayman
.  Dm            Gm       C         Dm
   Yashil chamanliklarga yetaklab boradi! //

[V1]
.   Dm             Gm
 // Meni sokin suvlarga olib borar,
.C          F
 Jonimga tetiklik kiritar
.Bb      Gm
 Adolat yoʻliga
.  A       Dm
 Boshlaydi meni! //

[V2]
.   Dm               Gm
 // Dahshatdan qoʻrqmayman men
.C               F
 Chunki Sen men bilansan
.Bb         Gm
 Rabbim dargohida men
.A           Dm
 Hamisha qolaman! //</lyrics>
<title>Rabb, mening Chopanimdur, xechkimdan qurqmayman</title>
</song>