<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>245</hymn_number>
<title>Eshiklar boshlaring koʻtar</title>
<key>G</key>
<lyrics>[V1]
.     G          D       C
 Eshiklar boshlaring koʻtar
.     G       D     G
 Koʻtarilsin abadiy eshiklar
.      C  G     B7/F#    Em
 Ulugʻvor Shohimiz kirishi uchun
.      C        D   G
 Ulugʻvor Shohimiz kirib kelar
.      D/F#    Em    C
 Ulugʻvor Shoh kim ekan?
.G          D
 Kuchli va qudratli Rabbimiz
.G   B7       C  A     C
 Jangda qudratli Rabbimiz
.D         G
 Olqishla, buyuk Shohimizni
.G   D     Em        C   G    Dsus4  D
 Shohga shon-sharaf, Shohga shon-sharaf
.G    D     C    A   C
 Rabbimiz ulugʻ Podshohdir
.D         G
 Olqishla, buyuk Shohimizni</lyrics>
</song>