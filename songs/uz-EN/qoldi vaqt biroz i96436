<?xml version="1.0" encoding="UTF-8"?><song><author>Ulugʻbek Joʻrayev</author>
<title>Qoldi Vaqt Biroz</title>
<lyrics>[V1]
.   Em                    Am
 // Koʻtarilish yaqin qolganda
. Bm                 Em
 Rabbiy buni esga solganda
. Em              Am
 Xudo huzuriga borganda
. Bm                    Em
 Nima deysiz bir oʻylab koʻring //

[C1]
.       Em                 Am
   // YOdda tuting vaqt juda ham oz
.   Bm                    Em
   Hushyor boʻling, qoldi vaqt biroz //

[V2]
 Qanday hayot kechirayapsiz
 Kimga qanday yordam beryapsiz
 Imonni qanday qoʻllayapsiz
 Bu haqida bir oʻylab koʻring

[C2]
   // Yodda tuting vaqt juda ham oz
   Hushyor boʻling, qoldi vaqt biroz //

[V3]
 Vaqt juda oz qoldi yaqin oxirat
 Vaqtingiz borida soʻzlang haqiqat
 Xudo Nomin ulugʻlang abad
 Buni doimo siz yodda tuting

[C3]
   // Yodda tuting vaqt juda ham oz
   Hushyor boʻling, qoldi vaqt biroz //</lyrics>
<key>Em</key>
</song>