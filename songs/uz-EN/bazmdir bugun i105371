<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Xizirov, Bauirjan Pulatov</author>
<title>Bazmdir bugun</title>
<lyrics>[V1]
.Am    Dm    Am
 Osmon Shohligida
.F   G     C
 Bazmdir bugun
.Dm     G      C
 Mening qalbim toʻla
.Dm   E   Am
 Nazmdir bugun
.Am   Dm    Am
 Gunohkorni izlab
.F     G   C
 Topdi Rabbimiz
.Dm    G    C
 Hamdu sano aytibyo
.Dm     E  Am
 Yayrar qalbimiz

[C1]
.  F     G      C
   Xudoning Shohligi
.  Dm    E   C
   Keldi bir qalbga
   Shodlik olib keldi
   Millionlab labga.
   Najotkor Isoga
   Shon-sharaflar boʻlsin!
   Otamiz dargohi
   Hamdlarga toʻlsin!

[V2]
 Bugun lang ochiqdir
 Najot eshigi
 Najotkor qoʻlida
 Dunyo beshigi
 Biz bugun Xushxabar
 Yetkazuvchimiz
 Xudoning sevikli
 Oʻgʻil-qizimiz

[C2]
   Qimmatbaho qondir
   Rabbim toʻlovi
   Faqat Unga boʻlsin
   Qalbim maqtovi
   Qancha ulugʻlasam
   Shunchalar kamdir
   Sizsiz mening Rabbim
   Koʻzlarim namdir

[V3]
 Bugun yuragimni
 Taxti Sizniki
 Dunyo anglamagan
 Baxti bizniki
 Osmon Shohligida
 Har kuni bazm
 Qalbim maqtovlaridan
 Tuzmoqda Nazm.</lyrics>
<key>Am</key>
</song>