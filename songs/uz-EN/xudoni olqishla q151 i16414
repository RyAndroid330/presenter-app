<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>151</hymn_number>
<key>E</key>
<lyrics>[C1]
.     E         B        E
   // Yo mening jonim hardam
.  B        A
   Xudoni olqishla
.  B                  E
   Yo mening jonim hardam! //

[V1]
.   E(B)
 // Ey, butun badanim,
.      (E)
 uning pok nomiga! //
.B
 Hamisha shukur aytib,
.A
 Uni maqtab tur!

[V2]
.   E(B)
 // Birgina qurbon bilan mudamo
.   A     B      E
 Birgina qurbon bilan! //
.   E(B)       (E)
 // Iso meni muqaddas qilib qoldirdi! //
.E             A       B     E
 Xudoyim meni hamisha komil qildi!

[V3]
.   E
 // Oʻzining qoni bilan,
.        A
 U meni qutqardi
.B              E
 Oʻzining qoni bilan! //
.    E(B)
 // Undan uzoq edim
. (E)
 Hukm qilingan edim, //
.E               A      B      E
 Men endi Najotkorimga kelib qoldim!</lyrics>
<title>Xudoni olqishla Q151</title>
</song>