<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>106</hymn_number>
<key>Db</key>
<lyrics>[V1]
.   C#           Ebm Ab         C#
 // Oʻlgan edim tiriltirdi, Masihim!
.C#                  Ebm  Ab    C#
 Koʻr koʻzimni ochib qoʻydi, Masihim! //
.   C#           F#            C#
 // Sevgi bilan totib bagʻriga oldi.
.F#                   F#    Ab   C#
 Masih uchun men yana qayta tirildim! //

[V2]
.C#           Bbm  Ebm  Ab  C#
 Kelar meni Najotkorim, Masihim!
.C#          Ebm   Ab     C#
 Uni nomi ulugʻlansin yurtimda.
.   C#             F#              C#
 // Muhabbat ber, Sevgi bergin, Masihim!
.F#                    F#   Ab  C#
 Najot bergin yurtimga Sen, Masihim! //

[C1]
.  C#               Ebm    Ab  C#
   Yigʻlagani yupatguvchi, Masihim!
.  C#          Bbm    Ebm  Ab  C#
   Qiynalganga orom berdi, Masihim!
.  F#                Ab        C#
   Chifo bergin bemorlarga, Masihim!
.  C#          Ebm    Ab       C#
   Yuragimga chiroq yoqdi, Masihim!
.  C#                F#        C#
   Gunohkorni kechirguvchi, Masihim!
.  Ebm            F# Ab      C#
   Toza yurak yaratuvchi, Masihim!
.     C#                 F#      C#
   // Oʻz qonini toʻkib bizga, Masihim!
.  F#                  F#     Ab  C#
   Qurbon boʻldi qurbonligin, Masihim! //
.  F#             C#     F#   Ab  C#
   Qurbon boʻldi qurbonligin, Masihim!</lyrics>
<title>Oʻlgan edim tiriltirdi, Masihim! Q106</title>
</song>