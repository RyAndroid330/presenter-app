<?xml version="1.0" encoding="UTF-8"?><song><title>Kuylang, kuylang doʻstlarim Q118</title>
<key>F</key>
<lyrics>[V1]
.   Dm           C
 // Gʻam alamli kunlar yoʻqoldi,
.Gm                   Dm
 Ozodlikdan koʻzlar yoshlandi. //
.   Gm             C
 // Koʻksim ichra koʻnglim yumshaldi, //
.   F                   Dm
 // Sevdi meni Xudoyim tanlab. //

[C1]
.  Gm                    F
   Kuylang, kuylang doʻstlarim,
.  Gm           C          F
   Najotkorga kuylang doʻstlarim.
.  Gm                   F
   Kuylang, kuylang doʻstlarim,
.     F            C      Dm
   // Sevdi meni Xudoyim tanlab. //

[V2]
 // Sen bilan menga duo yogʻilgan,
 Jannat eshiklari ochilgan. //
 // Koʻksin ichra koʻngling yumshalsin, //
 // Sevdi seni Xudoyim tanlab. //</lyrics>
<aka>Gʻam alamli kunlar yoʻqoldi</aka>
<hymn_number>118</hymn_number>
</song>