<?xml version="1.0" encoding="UTF-8"?><song><aka>Asirga ozod boʻl deb</aka>
<key>Bm</key>
<lyrics>[V1]
.   Bm                      Em
 // Xudovandning Ruhi Menga yor,
.F#                      Bm
 U Meni muqaddas moyila moyladi.
.Bm                           Em
 Bechoralarga mujda yetkazmoq uchun,
.F#                         Em
 Dilabgorlarga shifo bermoq uchun,
.Em        F#       Bm
 Xudovand meni yubordi,
.Em       F#                 Bm
 Xudovand sizni (bizni) yubordi. //

[V2]
.   Bm
 Asirga ozod boʻl deb,
.                         A      F#
 Basirga ochilsin koʻzing demoq uchun
.F#               Bm
 Xudovand meni yubordi.
.   Bm
 Asirga ozod boʻl deb,
.                         A      F#
 Basirga ochilsin koʻzing demoq uchun
.F#                Bm
 Xudovand bizni yubordi.

[V3]
.   Bm                        Em
 // Mazlumga erkinlikni eʼlon etib,
.F#                      Bm
 Marhamat yili boʻlsin demoq uchun. //
.Em       F#      Bm
 Xudovand meni yubordi.
.Em       F#        Bm
 Xudovand bizni yubordi.

[V4]
.   G          A    D     Em       A  F#
 // Sen ibtido va intiho, avvaliyu oxiri, //
.   G             A    D   Em          A        F#(Bm)
 // Bosh va soʻnggidirsan, yorugʻ tong yulduzidirsan. //
.   Bm            G   A             F#
 // Ruh ham kelin ham kel deb chorlayapti,
.Bm              G       D   F#
 Eshitgan kishi ham kel desin. //
.     Em          A     D       G
 //// Chanqagan kelsin hayot suvidan
.Em          F#    Bm
 Tekin tekin bahra olsin. ////
.Em          F#    Bm
 // Tekin tekin bahra olsin. //</lyrics>
<title>Hudovandning Ruhi Q195</title>
<hymn_number>195</hymn_number>
</song>