<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Egamizga shukur ayting
 Unga sajda qiling
 Taranum qilib uni
 Hamdu Sano ila qoʻshiq ayting //

[C1]
   // Muqaddas nomi ila
   Muqaddas nomi ila
   Egamiz bilan faxrlaning //

[V2]
 // Qudratli Egamizga
 Yurakdan sajda qiling
 Uning xuzurida
 Boʻlishga intiling //

[C2]
   ️ // Muqaddas nomi ila
   Muqaddas nomi il
   Egamiz bilan faxrlaning️ //

[B1]
   Yurakdan unga koʻylang, koʻylang
   Yurakdan unga sajda qiling sajda qiling
   Egamiz loyiqdir shon shuxratlaga
   Uning nomini taranum eting
   Taranum Taranum Taranum
   Eting uni Halleluya</lyrics>
<title>Taranum Eting</title>
<author>Sobir Umurov</author>
</song>