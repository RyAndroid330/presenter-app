<?xml version="1.0" encoding="UTF-8"?><song><title>Sokin tun 02 Q38</title>
<key>Bm</key>
<lyrics>[V1]
.Bm                F#
 Sokin tun, ajoyib tun,
.F#                 A
 Farishtalar madh kuylagan.
.D              Em
 Munajjimlar sharqdan izlagan,
.F#                       Bm
 Shimoʻn bobo ham juda kutgan-ey.

[C1]
.     G                D
   // Najotkor Masih kelgan-ey,
.  Em     F#       Bm
   Bugun Iso tugʻilgan. //

[V2]
 Sokin tun, ajoyib tun,
 Kalomulloh yerga keldi.
 Samodan kelgan bizlar uchun,
 Ilohiy nurini bizga sochgan.

[V3]
 Sokin tun, ajoyib tun,
 Gunohlarni yuvish uchun.
 Doʻzaxdan bizlarni asrash uchun,
 Xudovand oldida oqlash uchun.

[V4]
 Sokin tun, ajoyib tun,
 Farishtalar madh kuylagan.
 Munajjimlar sharqdan izlagan,
 Shimoʻn bobo ham juda kutgan-ey.</lyrics>
<hymn_number>38</hymn_number>
</song>