<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26</hymn_number>
<author>Zafar</author>
<title>Dengizdagi bir kema kabi W26</title>
<lyrics>[V1]
.    D                    G
 // Dengizdagi bir kema kabi,
.A            A7        D
 Bir tanu bir jon boʻlaylik.
.D                    G
 Haq Rabbonim boshimizda,
.A            A7      D
 Biz bir mahalla boʻlaylik. //

[C1]
.     D     G         A
   //  Xudoyimiz muqaddas,
.          F#m          Bm
   Sen ham boʻlgin muqaddas.
.      Em                      A
   Nurafshon (Qadrdon) Oʻzbekiston,
.       D              D7
   Muqaddas boʻl, muqaddas! //

[V2]
 // Mehru muruvvat shiorimiz,
 Solih mehribon boʻlaylik.
 Rabbiy boʻlsin panohimiz,
 Xur Oʻzbekiston boʻlaylik! //

[B1]
   Ey, muqaddas mahallam
   Muqaddas boʻl, muqaddas!</lyrics>
<key>D</key>
</song>