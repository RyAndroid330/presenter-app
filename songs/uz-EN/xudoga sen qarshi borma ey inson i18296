<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em                         F
 // Xudoga sen qarshi borma ey inson,
.F                     Dm        Em
 Xudo soʻzin eshitgin, ey qalbi zindon. //

[C1]
.     Am                    D        G
   // Yaratganga sen qarshi borib ey inson,
.  Am                 D       G
   Oʻzingga laʼnatlar olma ey inson.
.  C        Am       Dm       Em
   Oʻzingga yomonlik qilma ey inson. //

[V2]
.   Em                       F
 // Tavba qilmovchi bu yurak bilan,
.F                  Dm         Em
 Qayon ketmoqdasan, qay manzil tomon. //

[C2]
.     G                        Am
   // Oxiratda javob Oʻzing berursan,
.  C                 Dm       Em
   Doʻzax azoblarin unda koʻrursan. //

[V3]
.Em                   D       G
 Hali vaqt bor senda darhol yarashgin,

[C3]
.     C(Am)                D(Dm)    G(Em)
   // Gʻiybatu yomonlikdan yuz ugir inson. //
.  Em                  D         G
   Hali vaqt bor senda darhol yarashgin,

[C4]
.     C          Am      D(Dm)   G(Em)
   // Qalbingga Masihni kirit ey inson. //</lyrics>
<title>Xudoga sen qarshi borma ey inson</title>
</song>