<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Birodarlarning inoq boʻlib yashashi,
   Mana qanday yaxshi va qanday soz. //

[V1]
 Boshga surtilgan xushboʻy yogʻ kabidir u,
 Va Horunning soqoliga oqib tushgan.
 Tun yoqasiga oqib tushgan moydek,
 Boshga surtilgan xushboʻy yogʻ kabidir u.

[V2]
 // Sion tepaliklarigacha tushib kelgan,
 Koʻhi Hermon shabnami kabidir u. //

[V3]
 // Zero Sionda Xudovand barakatni,
 Abadiy hayotni amr etgan. //</lyrics>
<title>Birodarlarning inoq boʻlib yashashi Q198</title>
<hymn_number>198</hymn_number>
</song>