<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G     C            D  C
 Nomingni ulugʻlayman__
.G     C           D   C
 Ey Xudo, Seni kuylayman
.G     C             D  C
 Men bilan boʻlishingdan
.G     C           D   C
 Qutqarganingdan xursandman!

[C1]
.  G        C         D      C      G
   Osmondan erga kelding, Yoʻl boʻlishga!
.          C          D    C       G
   Yerdan xochga bording, ayb olishga
.         C          D       Bm       C
   Xochdan keyin qabrga, qabrdan osmonga,
.      D            G
   Nomingni ulugʻlayman!</lyrics>
