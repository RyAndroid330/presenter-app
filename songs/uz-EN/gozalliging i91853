<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em                 Am
 // Bizga mehribon boʻl, boʻl Ey Xudo
.B                 Em
 Bizni duo qilgin Ey Egam Xudo
.Em                    Am
 Munavvar Yuzingni yana, yana bir bor
.B                   Em(B)
 Ustimizga porlatgin Sen Rabbim Iso //

[C1]
.     Em        Am
   // Goʻzalliging buyukliging
.  B                Em
   Er yuziga shodlik olib kelsin
.  Em          Am
   Goʻzalliging yuksakliging
.  B                Em(B)
   Butun yer yuzida namoyon boʻlsin //

[V2]
 // Yer yuzi boʻylab Sening Ey Egam Xudo
 Rohing maʼlum boʻlsin Ey Rabbim Iso
 Barcha xalqlar Seni sevib Seni bilsin
 Sening najotingga Ey Xudo erishsin. //</lyrics>
<aka>Bizga mehribon boʻl</aka>
<title>Goʻzalliging</title>
</song>