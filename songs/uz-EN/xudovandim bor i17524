<?xml version="1.0" encoding="UTF-8"?><song><aka>Xudovand yezgoʻ-shafqatli</aka>
<lyrics>[C1]
.  E H     C#m      A
   Xudovand ezgu va shavqatli,
.  E H         C#m  A
   Xudovand qudratli!
.  E  H     C#m     A
   Rabbiy xohlagan ishini qilar,
.  E H         C#m   A
   Osmon hamda yerda!

[V1]
.C#m      A                F#m
 Meni Oʻziga oʻxshash yaratgan,
.           H
 Xudovandim bor!
.C#m              A               F#m
 Har vaqt, har joyda, har ishga qodir,
.           H
 Xudovandim bor!

[P1]
.                  E
   Quvontirishni sevar,
.                      H/D#
   Hayratga solishni sevar,
.          A/C#                     H
   U har kuni yangilik yaratishni sevar!
.         E                H/D#
   U hammani sevar, u seni ham sevar,
.           A/C#
   U har ishga ruhsat berar,
.  H            E
   Gunohdan boshqa!

[C2]
.     E H     C#m      A
   // Xudovand ezgu va shavqatli,
.  E H         C#m  A
   Xudovand qudratli!
.  E  H     C#m     A
   Rabbiy xohlagan ishini qilar,
.  E H         C#m    A
   Osmon hamda yerda!  //</lyrics>
<key>C#m</key>
<title>Xudovandim bor!</title>
<author>Novoye Pokoleniye tserkovʹ g. Riga</author>
</song>