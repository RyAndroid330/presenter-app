<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Najotkor</title>
<key>D</key>
<lyrics>[V1]
.D
 Shon-sharaf boʻlsin
.D
 Marhamat kelsin
.G
 Ota-Xudoga
.A          D
 Hamd sano toʻlsin!

[V2]
 Sevgisi tugal
 Sevgandir azal.
 Iso Rabbimda
 Hayotim goʻzal!

[C1]
.  D
   Iso Najotkor,
.  D
   Iso Najotkor.
.  G
   Xudoning Oʻgʻli
.  A        D
   Bizga madadkor.

[V3]
 Qoʻshiq kuylaymiz
 Yayrab oʻgʻil-qiz.
 Najotkorimiz
 Kuylab toʻymaymiz

[V4]
 Iso Masihim
 Bermoqda bilim.
 Shon-sharaf aytsam
 Yayraydi dilim!

[C2]
   Iso Najotkor,
   Iso Najotkor.
   Xudoning Oʻgʻli
   Bizga madadkor.</lyrics>
<author>Ravshan Xizirov, Bauirjan Pulatov</author>
</song>