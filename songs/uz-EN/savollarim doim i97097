<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am               Em
 Savollarim doim bisyor...
.Am               Em
 Har qadamda muammo bor...
.Am                Em
 Lek mening koʻnglim xotirjam
.Am               Em
 Xudoyimda javob tayyor!

[C1]
.  G                     Am
   Savol qilar koʻnglimni tor...
.  Am                 Em
   Muammo ham qilar bedor...
.  Am                  Em
   Lek mening koʻnglim xotirjam
   Otamizda javoblar bor!

[V2]
 Xudoyimda javob tayyor
 Muammoga yechim ham bor
 Umid qilib charchamayman
 Ibodatda boʻlib bedor</lyrics>
<title>Savollarim doim</title>
<author>Ulugʻbek Joʻrayev</author>
</song>