<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ey Xudo hech bir inson,
 Sen kabi odil emas.
 // Soʻzlaring yoqut misol,
 Dilga malham, dashnom emas. //

[V2]
 // Koʻngilu jonim fido,
 Aylagum Sen bor uchun. //
 // Sen uchun jonin fido
 Qilmagan farzand emas. //

[V3]
 // Gʻamlarim olding Oʻzing,
 Sitamlarim olding Oʻzing. //
 //// Bor gunohim olgin Oʻzing! ////
 Ey Xudo hech bir inson,
 Sen kabi odil emas.
 // Soʻzlaring yoqut misol,
 Dilga malham, dashnom emas. //</lyrics>
<title>Ey Xudo, hech bir inson</title>
<author>Abduhalimov Ulugʻbek</author>
</song>