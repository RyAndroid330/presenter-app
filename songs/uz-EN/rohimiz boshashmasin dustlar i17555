<?xml version="1.0" encoding="UTF-8"?><song><title>Roʻhimiz boʻshashmasin dustlar</title>
<key>Am</key>
<lyrics>[V1]
.Am
 Yulduzlarning yorugʻligi keldi sizga,
.    G              Am
 Haqiqat kalomi boʻlgin!
.  Am
 YOrlarni yoritadi Iso,
.    G              Am
 oʻzining nurlari bilan!

[P1]
.  Am Dm        G
    Izlayin ommaviy minglab yulduzlar,
.        C               F
   Qayirilib xizmatlar qilar.
.    Dm             E
   Qorongʻu kun tushganda shu kech,
.  Am       G     Am
   Orom keladi sizga!
.  Am Dm        G
    Izlayin ommaviy minglab yulduzlar,
.        C               F
   Qayirilib xizmatlar qilar.
.    Dm             E
   Qorongʻu kun tushganda shu kech,
.   F       E     Am
   Orom keladi sizga!

[C1]
.      Am Dm            G
   // Ruhimiz boʻshashmasin doʻstlar,
.   C               F
   Iso xizmati yoʻlida!
.    Dm             E
   Qorongʻu kun tushganda shu kech,
.   Am      G     Am     (2P/F,E,Am)
   Orom keladi sizga! //
.  Am   F       E     Am
   Tinchlik keladi sizga!

[V2]
 Doʻstlar tana oqardi,
 olam yigʻim keldi
 Tovush taraldi ertada,
 ish vaqti keldi!

[P2]
   // Gʻayrat bilan ishlaylik
   Biz oqshom yigʻimida
   Qorongʻu kun tushganda shu kech
   Orom keladi sizga! //

[C2]
   //// Ruhimiz boʻshashmasin doʻstlar
   Iso xizmati yoʻlida
   Qorongʻu kun tushganda shu kech
   Orom keladi sizga! ////
   Tinchlik keladi sizga!</lyrics>
</song>