<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>178</hymn_number>
<lyrics>[V1]
.G        D      G     C            Am        D
 Sen ulugʻvorlik Shohi Sen tinchlikning Shohisan
.Bm             Em
 Eru falakning Podshohisan
.C          Am         D
 Haqiqating la kelgansan
.G        Bm         Em       C       Am  D
 Farishtalar sajda qilar va olqishlar Seni
.G          Am    Bm       Em
 Chunki abadiy Kalom Sendan
.C              D     G
 Mening Rabbim Iso Masih
.  G        Bm    Em
 Tasanno Senga Dovud Nasli
.  C           Am         D
 Tasanno Senga shohlar Shohi
.G                 Bm   Em    C         D     G
 Butun dunyoning xaloskorisan Rabbimiz Iso Masih.</lyrics>
<key>G</key>
<title>Sen ulugʻvorlik Shohi</title>
</song>