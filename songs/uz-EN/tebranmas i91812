<?xml version="1.0" encoding="UTF-8"?><song><title>Tebranmas</title>
<lyrics>[V1]
 // Quyosh yorugʻlik oy, yulduzlar qorayar
 Yomgʻirli bulutlar oʻtib ketar
 Lek Xudoning kalomi hech qachon tugamas
 Unga ishonganlar aslo tebranmas //

[C1]
   // Tebranmas
   Aslo tebranmas
   Tebranmas
   Aslo yiqilmas //

[V2]
 // Xudo oʻgʻlini koʻrib inson quvonar
 Xatto yulduz odam ham unga tiz choʻkar
 Chunki u buyuk Xudo
 Hamma undan qoʻrqar
 Yer yuzida butun jonzot unga tiz choʻkar //

[C2]
   // Tiz choʻkar hamma tiz choʻkar
   Tiz choʻkar hamma bosh egar //</lyrics>
</song>