<?xml version="1.0" encoding="UTF-8"?><song><key>A</key>
<lyrics>[V1]
.   A           F#m
 // Ota, Seni sevamiz,
.D        E       A   E
 Senga shukur qilamiz!
.A           F#m
 Sen - qudratli Sen!
.D       E           A
 Sen yagona, Sen yagonasan! //

[C1]
.            A          C#m
   // Iso Masih Sen Xudoyimsan
.  D           E           A
   Sen bizlar uchun Qurbonlik boʻlding
.                       C#m
   Iso Masih Senga hamdlar boʻlsin
.  D     E              A
   Senga olqishlar boʻlsin! //

[V2]
 // O Rabbim Sen bizni gunohdan olding
 Va bizga imon berding
 Sen Qudratlisan
 Sen yagona, Sen yagonasan //</lyrics>
<title>Ota, Seni sevamiz W93</title>
<hymn_number>93</hymn_number>
</song>