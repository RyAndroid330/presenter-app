<?xml version="1.0" encoding="UTF-8"?><song><title>Asta, asta bu dunyoda yuroyin</title>
<key>Am</key>
<lyrics>[V1]
.Am                   Dm
 Asta-asta bu dunyoda yuroyin
.F           Em        Am
 Gunohlardan uzoqlarda turoyin
.   Am                      Dm
 // Rabbim bergan Kalomlari dilimda
.F            Em             Am
 Olloh qurgan jannatlarni koʻroyin! //

[C1]
   Birodarlar davrasida turoyin
   Tangrimizning najotini koʻroyin
   // Xaloskorim suhbatini quroyin
   Men ham samo sirlarini biloyin! //

[V2]
 Dasta-dasta gullar bilan boroyin
 Yoʻllarimda doʻst-u yorga qaroyin
 // Yaqinlarga mehrimni men soloyin
 Tangrimizning inoyatin oloyin! //

[C2]
   Birodarlar davrasida turoyin
   Tangrimizning najotini koʻroyin
   // Xaloskorim suhbatini quroyin
   Men ham samo sirlarini biloyin! //</lyrics>
</song>