<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em       C   G    Em
 Xudo kalomin qoldirma,
.Em   C             Em
 Ziyodan koʻz olib qochma.
.Em    C  Am         Em
 Dilingni gʻazablantirma,
.C       B       Em
 Najot olishdan kechikma.

[C1]
.  Am                Em
   Ertangi kun balki kelmas,
.  Am                    Em
   Quyosh ham yogʻdusin sochmas.
.  D            B        Em
   Fursat keldi, dono boʻlgin,
.  C       B          Em
   Najot olishga shoshilgin.

[V2]
 Gunoh bizni hech ham yoritmas,
 Zahar bizga hayotin bermas.
 Najotkoringga ishonib yurgin,
 Erkin boʻlish uchun kelgin.

[V3]
 Rabbimiz kelganni quvib chiqarmas,
 Najot topgan oʻlim aslo koʻrmas.
 Xudo uchun xizmat qilishga turgin,
 Najot topishga shoshilgin.</lyrics>
<title>Xudo Kalomin Q3</title>
<hymn_number>3</hymn_number>
</song>