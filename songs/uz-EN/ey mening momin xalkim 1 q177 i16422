<?xml version="1.0" encoding="UTF-8"?><song><title>Ey mening moʻmin xalkim (1) Q177</title>
<key>F#m</key>
<lyrics>[C1]
.     F#m         G       F#m
   // Ey, mening moʻmin xalqim,
.   G            Em     F#m
   Koʻzingni och degim kelur. //
.      Bm
   // Seni koʻrib, qalbim yonib,
.  A          G     F#m
   Isoga kel degim kelur. //

[V1]
.   F#m
 // Iso yoʻli abadiydur,
.Bm          E      A
 Jonga rohat topqusidur. //
.   Bm       A
 // Ibodatni kanda qilma
.G             Em     F#m
 Qalbing nurga toʻlgʻusidur. //

[B1]
.  D
   Iso Masih aytganidek:
.                 Em     F#m
   Yasha endi mening xalqim!
.  D
   Shunda sani qabul qilgay,
.             Em  F#m
   Osmondagi Otajonim!

[C2]
   Ey, mening moʻmin xalqim,
   Koʻzingni och degim kelur.
   // Seni koʻrib, qalbim yonib,
   Isoga kel degim kelur. //
   // Isoga kel degim kelur! //</lyrics>
<hymn_number>177</hymn_number>
</song>