<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Xizirov, Ulugʻbek Abduhalimov</author>
<lyrics>[V1]
 // Yiqilsam gar
 Goho goho
 Kelganida
 Nogoh jafo. //
 Qoʻlim ochib
 Qilsam duo
 Kuch beradi
 Rabbim mening
 Kuchga toʻlar
 Qalbim mening

[V2]
 Yo oʻzimdan
 Tonib qoʻydim
 Yo alamda
 Yonib qoʻydim
 Desam agar
 Jondan toʻydim
 Kuch beradi
 Rabbim mening
 Kuchga toʻlar
 Qalbim mening!

[V3]
 &quot;-Menda boʻlsang
 Men sendaman
 Yarataman
 Senga chaman.
 Ishon faqat
 Ishonchda Man&quot;
 Kuch beradi
 Rabbim mening
 // Kuchga toʻlar
 Qalbim mening //

[V4]
 &quot;-Tark etmagin
 Ogʻir damda
 Yo shodlikda
 Yoki gʻamda
 Sen mendasan
 Men Otamda
 Kuch beradi
 Mening Rabbim
 // Izmimdadir
 Olam mening!&quot; //

[V5]
 Xafa boʻlsam
 Goh taqdirdan
 Ogoh etar
 Buyuk sirdan:
 Sevgim cheksiz
 Senga, birdan
 Kuch beradi
 Rabbim mening
 Kuchga toʻlar
 Qalbim mening!

[V6]
 Ibodatim-
 Muxtojligim.
 Sizsiz Rabbim
 Ayting men kim?
 Muqaddas Ruh
 Boʻling xokim
 Kuch beradi
 Rabbim mening
 Kuchga toʻlar
 Qalbim mening!

[V7]
 // Sanolarim
 Tizim-tizim
 Rabbim yorugʻ
 Qiling yuzim //
 Men ishongan
 Yolgʻiz soʻzim:
 // Kuch beradi
 Rabbim mening
 Kuchga toʻlar
 Qalbim mening! //</lyrics>
<title>Kuch beradi Rabbim mening</title>
</song>