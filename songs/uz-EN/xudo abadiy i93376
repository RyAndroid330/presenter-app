<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<lyrics>[V1]
 // Yoʻllarimda toʻlib tosh
 Yigʻlarman koʻzlarimda yosh //
 // O Rabbim senga deyman
 Sendan boshqa meni sevadigan yoʻq //
 // Seni deb yashayman
 Seni deb koʻylayman //

[V2]
 // Hamrohimsan ey Rabbim
 Doim seni yonimda koʻrdim //
 Seni ulugʻlayman
 Buyukligingni koʻylayman
 Senga sajda qilaman Iso
 // Nomingni tarannum etaman //
 Buyukligingni koʻylayman
 Muqaddas Xudo Podshoh
 Sen borsan abadiy
 Sen men bilan abadiy
 Sen biz bilan abadiy</lyrics>
<title>Xudo Abadiy</title>
</song>