<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13</hymn_number>
<aka>Ey, Doʻstlarim</aka>
<lyrics>[V1]
 // Ey, doʻstlarim men dunyodan,
 Panohimni topganman. //
 // Qalbimga tinchlik bergan,
 Podshohimni topganman. //
 // Kecha-kunduz uyimda,
 Doim mening oʻyimda. //
 // Ishlab yursam ishimda,
 Madorimni topganman. //

[C1]
   Izlab-izlab haqiqatni,
   Men dunyoda sarson boʻldim.
   Qalbim qiynagan savolga,
   Javobimni topganman!

[V2]
 // Dunyo toʻlsa uyimga,
 Koʻnglim sira toʻlmadi. //
 // Seni topib Xudoyim,
 Koʻnglim toʻldi Panohim. //
 // Koʻnglim topdi Panohim! //</lyrics>
<title>Seni topdim Xudoyim Q13</title>
</song>