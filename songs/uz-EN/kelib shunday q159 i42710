<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Kelib shunday zamonlar,izlarin tavof aylar,
 Bosh egadi insonlar,noming yurakka joylar. //
 // Muborak kalomlaring avlodaga boʻlar yodgor, //
 // Chehralarida soʻnmas, sirli ilohiylik bor. //

[V2]
 // Har kimsa orzu qilar koʻrishsam deya diydor //
 // Iso Masih Najotkor,boʻlsin deya Madadkor. //
 // Koshonasi boʻlajak,qutlugʻ ziyorat dargoh, //
 // Duoga qoʻlin ochar Yaratgan Oʻzi Olloh. //

[V3]
 /// Kelib shunday zamonlar,izlarin tavof aylar,
 Bosh egadi insonlar,noming yurakka joylar. ///</lyrics>
<title>Kelib shunday Q159</title>
<hymn_number>159</hymn_number>
</song>