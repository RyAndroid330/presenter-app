<?xml version="1.0" encoding="UTF-8"?><song><title>Tong otgandan Q230</title>
<key>A</key>
<lyrics>[V1]
.C#m           F#m           Ab          C#m
 Tong otgandan kun botguncha ulugʻlaymiz Xudoni,
.F#m            C#m
 Soʻzlarimizda, kuylarimizda.
.C#m           F#m           Ab            C#m
 Tong otgandan kun botguncha ulugʻlaymiz Xudoni,
.F#m            C#m
 Ishlarimizda, hayotimizda.

[C1]
.  F#m                  C#m
   Yeru koʻkni yaratgan qudratli Xudovandga,
.  Ab                       C#m
   Xursand boʻlib kuylaylik doʻstlar.
.  F#m                  C#m
   Eru koʻkni yaratgan qudratli Xudovandga,
.  F#m                      Ab
   Chin yurakdan yogʻilsin hamdlar.

[V2]
 Tong otgandan kun botguncha ulugʻlasak Xudoni,
 Osmon ochilar hayotimizda.
 Tong otgandan kun botguncha ulugʻlasak Xudoni,
 Qaygʻular ketar yuragimizdan.</lyrics>
<hymn_number>230</hymn_number>
<author>Malohat Pulatova</author>
</song>