<?xml version="1.0" encoding="UTF-8"?><song><title>Ulugʻ Tangrim</title>
<key>F#m</key>
<lyrics>[V1]
.   F#m
 Muqaddas maskaningda
.      C#m
 Senga nigox tashladim
.     D
 Qudratingni, shuxratingni
.       C#m
 Koʻrsatding menga Rabbim

[V2]
.    F#m
 Bir umr, to abad
.      C#m
 Senga madxim kuylayman
.       D
 Butun qalbim jonim bilan
.      C#m
 Senga sajda qilaman

[C1]
.   F#m
   Ulugʻ Tangrim
.     C#m
   Intilaman Senga
.    D
   Suvsiz qolgan tuproq kabi
.   C#m
   Jonim tashnadir Senga
.  F#m
   Buyuk Rabbim
.    C#m
   Mening madadkorim
.     D
   Qanotlaring soyasida
.    C#m
   Panox topaman doim</lyrics>
<hymn_number>52648</hymn_number>
</song>