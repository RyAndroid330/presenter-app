<?xml version="1.0" encoding="UTF-8"?><song><title>Men ado boʻlarman Q27</title>
<key>Gm</key>
<lyrics>[V1]
.Gm                Cm
 Men ado boʻlarman Masihsiz oʻtsam,
.Gm              Cm
 Armonga aylanib qolmasin Egam.
.   Eb                  Cm        Gm
 // Bir nafas Rabbiysiz yashab ʼblurmi?
.Cm           Eb   F            D(Gm)
 Dunyoni oʻt olib, suv bossa ne gʻam? //

[C1]
.  Gm                Dm         Gm
   Men ado boʻlarman Masihsiz oʻtsam,
.  Eb                F       Gm
   Jannatning kaliti asli oʻzi U.
.     Cm                  Eb        Gm
   // Shaytonni bir oʻzi xochga mixlagan,
.  Eb         F               Gm
   Bu qudrat sohibi Rabboniy Egam. //

[V2]
 Men ado boʻlarman Masihsiz oʻtsam,
 Doʻzaxning zaharli tomirlarini
 // Shifolab, giyoh etgan tabibim Otam.
 Chunki U Xudoning oʻng tarafida. //

[C2]
   Saroyning sirlari voqifi Egam.
   Men ado boʻlarman Rabbimsiz oʻtsam,
   // Gunohning qanchalar maʼlum sirlarin,
   U jirkanch taʼsir-la ifoda etgan. //

[V3]
.Gm                Cm
 Men ado boʻlarman Masihsiz oʻtsam,
.Gm               Cm
 Armonga aylanib qolmasin Egam.
.   Gm                Cm
 // Men ado boʻlarman Masihsiz oʻtsam! //</lyrics>
<hymn_number>27</hymn_number>
</song>