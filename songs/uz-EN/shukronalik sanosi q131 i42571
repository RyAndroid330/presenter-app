<?xml version="1.0" encoding="UTF-8"?><song><title>Shukronalik sanosi Q131</title>
<lyrics>[C1]
.     C                  F          C
   // Ey butun yer yuzi, Xudovandni olqishlang,
.  F          C            G         C
   Xudovandga xursandchilikla xizmat qiling.
.  F        C               G        C
   Huzuriga hayqiriqlar ila yaqinlashing. //

[V1]
.C        Em        Am    Dm
 Bilingki Xudovand, haq Xudodir,
.G                   C
 Uning Oʻzi bizni yaratgan.
.C      Em    Am     Dm
 Bizlar Unga tegishlimiz,
.G                               C
 Oʻz xalqiyu yaylovining qoʻylarimiz.

[C2]
   // Ey butun yer yuzi, Xudovandni olqishlang,
   Xudovandga xursandchilikla xizmat qiling.
   Huzuriga hayqiriqlar ila yaqinlashing. //

[B1]
.  C                              G
   Maʼbad darvozalariga shukrona aytib kiring,
.  G                                 C
   Maqtovlar aytib Xudoning huzuriga keling.
.  C                                 G
   Unga shukr qilib ismiga hamd sano oʻqing,
.  G                                C
   Chunki Xudovand ezgudir, abadiy inoyatlidur.
.      F                    G              C
   /// Sadoqati esa davrdan davrga hukm surar. ///</lyrics>
<key>C</key>
<aka>Ey butun yer yuzi</aka>
<hymn_number>131</hymn_number>
</song>