<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.     Abm
   // Yaratgan Tangrim mening,
.  F#
   Borligʻinga ming shukur.
.  E
   Har bir kunimda bergan,
.  Ebm
   Rizq-roʻzinga ming shukur. //

[V1]
.   Abm      F#        Abm
 // Dardli kunlarimda Seni,
.Abm           F#  Abm
 Men chaqirdim Xudoyim. //
.   Abm               F#
 // Dardimga bir davo boʻlib,
.E          C#m            Ebm
 Kelganinga mingdan ming shukur. //

[C2]
   // Yaratgan Tangrim mening,
   Borligʻinga ming shukur.
   Har bir kunimda bergan,
   Rizq-roʻzinga ming shukur. //

[V2]
 // Haqiqatni, Seni tanimay,
 Men dunyodan qidirdim. //
 // Haqiqatni menga toʻldirib,
 Berganinga mingdan ming shukur. //</lyrics>
<key>Ebm</key>
<aka>Shukr</aka>
<title>Yaratgan Tangrim mening Q55</title>
<hymn_number>55</hymn_number>
</song>