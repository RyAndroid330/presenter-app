<?xml version="1.0" encoding="UTF-8"?><song><title>Kalom keldi Inson qiyofasida Q162</title>
<lyrics>[V1]
.   Bm                        Ebm
 // Bajo boʻlar har bir Xudo soʻzlari,
.B                 Bm
 Kelib qolar Xudo aytgan kunlari.
.Bm                         Ebm
 Kelgin deydi Xudo har bir insonga,
.B                         Bm
 Qolib ketma yolgʻonchi bu dunyoda. //

[C1]
.     Bm                Ebm
   // Kalom keldi inson qiyofasida,
.  Ab                      C#
   Keldi menu sen uchun bu dunyoga.
.  F#                         B
   Och yuraging, qabul qilgin Isoni,
.  Abm                        B
   Sen baxtlisan, baxtiyorsan ey inson. //

[V2]
 // Kelib qolsa oʻsha kunlar nogahon,
 Tayyor turgin, hushyor boʻlib ey inson.
 Olib ketar tanlangan Oʻz xalqini,
 Quvonch, kulgi, tinchlik boʻlgan samoga. //</lyrics>
<key>Em</key>
<aka>Bajo boʻlar har bir Xudo soʻzlari</aka>
<hymn_number>162</hymn_number>
</song>