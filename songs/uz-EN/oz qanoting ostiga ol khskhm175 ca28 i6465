<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>175</hymn_number>
<author>Reuben Morgan</author>
<key>C</key>
<lyrics>[V1]
.C   G   Am     F D  G
 Oʻz qanoting ostiga ol,
.C  G    Am     F    D       G
 Saqla meni, sevgi kuching bilan!

[C1]
.  C             F      G     C
   Hatto kuchli toʻfon kelsa ham,
.  Am            F     G   Am
   Men Sen bilan birga uchaman!
.  C          F      G    C
   Hudoyim Sen mening qoyamsan!
.  Am         F        G    F
   Tinchlik topaman Senda doim!

[V2]
 Tinchlik topdim, Senda yuragim!
 Sevgingga, ishonaman Ota!

[C2]
.     C             F      G     C
   //  Hatto kuchli toʻfon kelsa ham,
.  Am            F     G   Am
   Men Sen bilan birga uchaman!
.  C          F      G    C
   Xudoim Sen mening qoyamsan!
.  Am         F        G    C
   Tinchlik topaman Senda doim! //</lyrics>
<aka>Tinchlik Topaman Senda Doim</aka>
<title>Oʻz qanoting ostiga ol ҲСХМ175 CA28</title>
</song>