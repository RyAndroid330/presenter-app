<?xml version="1.0" encoding="UTF-8"?><song><title>Menga bergan hayoting uchun ҲСХМ207 Q227</title>
<key>E</key>
<lyrics>[V1]
.   C#m                    F#m
 // Menga bergan hayoting uchun,
.G#          G#7      C#m/G#
 Men Senga nima bera olaman?
.   C#m                    F#m
 Menga qilgan gʻamxoʻrlik uchun,
.G#          G#7      C#m
 Men Senga nima qila olaman? //

[P1]
.     C#m      F#m
   // Faqat kuylayman men Seni,
.          C#m
   Va ulugʻlayman men Seni,
.            G#         G#7     C#m/C#7
   Va, rahmatlar men Senga aytaman! //

[C1]
.     C#m/C#7                        F#m
   //  Rahmat Senga - Ota, Oʻgʻling uchun!
.     B7                       E    C#m
   Rahmat Senga - Iso, qoning uchun!
.     A                            F#m
   Rahmat - Muqaddas Ruh, kuching uchun!
.     A               B7
   Rahmat Senga - Tangrim,
.            E         C#m
   Rahmat Senga - Tangrim! //</lyrics>
<hymn_number>207</hymn_number>
</song>