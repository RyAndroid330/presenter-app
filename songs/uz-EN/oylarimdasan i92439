<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Otgan tonglarday nurlar taratding
 Yurakda yangi yurak yaratding //

[C1]
   // Oʻylarimdasan, kuylarimdasan
   Yuragimdasan Iso, sevaman Seni //

[V2]
 // Bilaman Seni azaldan borsan
 Buyukdir sevging, hammaga yorsan //

[V3]
 // Sen Yoʻl, Haqiqat va Hayotdirsan
 Qalbim tubida bir bayotdirsan //

[V4]
 // Kutaman Seni vaʼda bergansan
 Vaʼdangga koʻra qaytib kelarsan //</lyrics>
<aka>Otgan Tonglarday</aka>
<title>Oʻylarimdasan.</title>
</song>