<?xml version="1.0" encoding="UTF-8"?><song><title>Rahmat Ayting Xudoyimizga ҲСХМ24</title>
<aka>Abadiy Sen sodiqsan</aka>
<key>F</key>
<lyrics>[V1]
.F
 Rahmat ayting Xudoyimizga!
.F
 Uning muhabbati abadiy.
.Bb
 U ajoyib hamma narsadan,
.Bb
 Uning muhabbati abadiy.
.C                Bb
 Hamdlar ayting, Hamdlar ayting!

[V2]
 Mahobatli bagʻri quchogʻi ila,
 Uning muhabbati abadiy.
 Yangi bergan hayoti ila,
 Uning muhabbati abadiy.
 // Hamdlar ayting, Hamdlar ayting! //

[C1]
.  F
   Abadiy Sen sodiqsan,
.   Dm
   Abadiy qudratli,
.  C
   Abadiy biz bilansan.
.  Bb
   Abadiy!

[V3]
 Kun chiqib va botguncha,
 Uning muhabbati abadiy.
 Xudo inoyati ila biz yashaymiz,
 Uning muhabbati abadiy.
 // Hamdlar ayting, Hamdlar ayting! //</lyrics>
<author>Chris Tomlin</author>
<hymn_number>162</hymn_number>
</song>