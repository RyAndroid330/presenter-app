<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>165</hymn_number>
<lyrics>[V1]
 // Xohlagan kelib kumushsiz olsin, //
 Xudoning tortigʻi, najotin topsin.
 // Eshitganlar, doʻstlar harakat qiling, //
 Kambagʻal kelsin va tekin olsin.
 // Kelsin ruhiy qiynalgan, ruhiy qiynalgan. //

[V2]
 Xudoni soʻzi seni daʼvat etar,
 Hayot suvlari sizlar uchun oqar.
 Chanqagan tekin ichsin, tekin ichsin,
 Kambagʻal kelsin va tekin olsin.
 // Kelsin ruhiy qiynalgan, ruhiy qiynalgan. //

[V3]
 // Bechora doʻstim tez kelib olgin,
 Ertaga kech boʻlib inoyat soʻzi. //
 // Daʼvat etmaydi seni doʻstim. //
 Kambagʻal kelsin va tekin olsin.
 // Kelsin ruhiy qiynalgan, ruhiy qiynalgan. //

[V4]
 Istagan kelsin Xudo yoʻliga,
 Uning kalomi ajoyib bizlarga.
 // Erkinlik vaʼdasin U bizga bergan. //
 Kambagʻal kelsin va tekin olsin.
 Kelsin ruhiy qiynalgan, ruhiy qiynalgan.

[V5]
 // Xohlagan kelib kumushsiz olsin, //
 Xudoning tortigʻi, najotin topsin.
 // Eshitganlar, doʻstlar harakat qiling, //
 Kambagʻal kelsin va tekin olsin.
 // Kelsin ruhiy qiynalgan, ruhiy qiynalgan. //</lyrics>
<title>Xohlagan kelib Q165</title>
</song>