<?xml version="1.0" encoding="UTF-8"?><song><title>Ota Sening sevging naqadar buyuk</title>
<key>Em</key>
<lyrics>[V1]
.Em    Am         D           G
 Ota Sening sevging naqadar buyuk va ulugʻ
.C      Am             B7
 Sensiz hayotimni men anglay olmayman!
.Em          Am
 Sen oʻzing meni qutqarding
.D             G
 Men Sening farzanding boʻldim
.C          Am          B7
 Va butun hayotimda men Sen bilan qolaman

[C1]
.     Em   Am           D     G
   // Seni ulugʻlayman, Senga topinaman
.  C     Am           B7      (Em)
   Senga aytmoqchiman Sevaman Ota! //</lyrics>
