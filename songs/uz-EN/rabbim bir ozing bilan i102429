<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.  G                             Bm   Em
 Rabbim bir Oʻzing bilan men qoniqaman
.       C                         G/D    D
 Mening borligʻim boʻlgan, Rabbim kuylayman
.      G                   Bm Em
 Menga abadiy hayot bergan Iso
.       C          D      G
 Baland ovoz bilan kuylayman
.G      D          C        D     G
 Rabbimning buyuk sevgisin kuylayman
.       C      G        D
 Mening kuchim quvvatim boʻlgan Rab
.      Am   D        Bm   Em
 Butun hayotim oʻzgardi Unda
.       Am       D         G
 Buyuk Rab sevgisin kuylayman.</lyrics>
<title>Rabbim bir Oʻzing bilan</title>
<hymn_number>151</hymn_number>
</song>