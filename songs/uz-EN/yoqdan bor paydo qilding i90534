<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12542</hymn_number>
<author>Chris Tomlin, Matt Redman, Jonas Myrin, Jesse Reeves</author>
<title>Yoʻqdan bor paydo qilding</title>
<key>Em</key>
<lyrics>[V1]
.Em           C        G  D
 Yoʻqdan bor paydo qilding
.Em          C          G
 Koʻrlar koʻzin Sen ochding
.        Am     Am7      Dsus4  D
 oʻxshashing yoʻq, oʻxshashing yoʻq
.Em        C        G  D
 Zulmat ichra yashading
.Em       C         G
 Bizlarga hayot berding
.        Am     Am7   Dsus4     D
 Oʻhshashing yoʻq, oʻhshashing yoʻq

[C1]
.  Em             C
   Qudratli Xudo, ulugʻvor Xudo
.  G                 D
   Sen hammadan ustivor boʻlgan Xudo
.  Em              C
   Shifokor Xudo, tenging yoʻq aslo
.     G   Dsus4  D
   Tanho, tanho__

[B1]
.  Em                 C
   Xudo biz bilan birga, kimlar bas kelar bizga?
.  G                     Dsus4        D
   Xudo biz bilan birga, kim qarshi chiqar bizga?</lyrics>
<aka>Qudratli Xudo</aka>
</song>