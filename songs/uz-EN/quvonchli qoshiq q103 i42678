<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>103</hymn_number>
<lyrics>[V1]
.B                           E    B
 Quvonchli qoʻshiq aytinglar samoda,
.F#                      B
 Darbadar oʻgʻil qaytib keldi.
.B                    E         B
 Xudo bilan yarashib,koʻz-yoshi ila,
.F#                  B
 Mangu quchogʻiga jo boʻldi.

[C1]
.  B          E   F#         B
   Shon-sharaflar aytinglar samoda,
.  B     E     F#         B
   Va takrorlanglar yer yuzida.
.  B                 E          B
   Rabbimiz toʻkkan xochda qoni ila,
.  F#                       B
   Qul ozod boʻldi bugungi kunda.

[V2]
 Quvonchli qoʻshiq aytinglar samoda,
 Yoʻqolgan qoʻy bugun topildi.
 Musofir gunohlarda oʻlgan edi,
 Ota makonida jonlandi.

[V3]
 Quvonchli qoʻshiq aytinglar samoda,
 Uyqisiraganlar uygʻonsin.
 Madh etinglar Rabbimiz muhabbatin,
 Maqtovga dillar toʻlib toshsin.</lyrics>
<key>B</key>
<title>Quvonchli qoʻshiq Q103</title>
</song>