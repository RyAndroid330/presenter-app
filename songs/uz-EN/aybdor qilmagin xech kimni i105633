<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am         E       Am
 Boshinga kulfatlar tushganda.
.G        C     Am
 Yuraging olovi oʻchganda.
.   Dm            Am
 // Togʻingdan qorlaring koʻchganda.
. E               Am
 Aybdor qilmagin xech kimni. //

[V2]
 Doʻsting sendan bosh tortganida.
 Ustinga ogʻir yuk ortganida.
 // Noxaqlik joninga botganida.
 Aybdor qilmagin xech kimni. //

[V3]
 Bogʻingda qurisa gullaring.
 Uyqusiz oʻtganda tunlaring.
 // Yoningda qolmasa pullaring.
 Aybdor qilmagin xech kimni. //

[V4]
 Hech kimga keraksiz boʻlganda.
 Yaqinlaring sendan bezganida.
 // Oʻzingni yolgʻiz sezganingda
 Aybdor qilmagin xech kimni. //

[C1]
   Iso xochda azob chekganda.
   Ayibsiz oʻz qonin tukganda.
   // Ushaldi rejasi dildagi.
   Hech kimni aybdor bilmadi. //</lyrics>
<title>Aybdor qilmagin xech kimni</title>
<author>Timoʻtiy</author>
</song>