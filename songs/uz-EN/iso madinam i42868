<?xml version="1.0" encoding="UTF-8"?><song><title>Iso madinam</title>
<aka>Sensan borim</aka>
<key>Dm</key>
<lyrics>[V1]
.Dm            Gm         Dm
 Odamlar togʻu-toshni izlamang,
.Gm               Dm
 Xudovand undan yuqori.
.   Gm        A         Dm      Bb
 // Uni izlab uzoqlarni koʻzlamang,
.      Gm  A          Dm
 Yurak bor joyda U bordir. //

[C1]
.            Gm            C         F    Dm
   // Sensan borim, najot tojim, Iso Masihim.
.         Gm       A       Dm
   Sensan borim, hayotim mening. //

[V2]
 Seni desam otilmagan tosh qolmadi,
 Xaqorat aytmagan dillar, tillar qolmadi.
 // Sen poklagan maʼbadga dogʻ sololmadi,
 Yana Seni deyman Rabbonim. //

[V3]
 Bu dunyoda yurarman men devona,
 Xalq meniki dillar esa meniki.
 Xiyonatchi atrofimda parvona,
 Lek, lek Sen meni qoldirmading Rabbonim.
 Yana yana Seni deyman, Seni deyman Rabbonim.</lyrics>
</song>