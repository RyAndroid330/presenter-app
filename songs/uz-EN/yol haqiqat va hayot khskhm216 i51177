<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>216</hymn_number>
<key>G</key>
<lyrics>[V1]
.G
 Hayoting boʻlmasin sarson,
.G
 Yoʻlda poylar seni shayton
.F                  C
 Lekin bilgin shuni inson,
.      G
 Iso - Qalqon

[V2]
.G
 Dushmanimizga berdik gul,
.G
 Nafsimizga boʻlmaymiz qul,
.F              C
 Koʻzimizdan oqadi yosh,
.      G
 Dilda quyosh.

[C1]
.     D                 C            G
   // Yoʻl, haqiqat va hayot - bizga najot //

[V3]
.G
 Moʻljalimiz cheksiz samo,
.G
 Sardorimiz Mangu Iso,
.F                 C
 Borligʻimiz zikru sano,
.      G
 Senga Xudo</lyrics>
<title>Yoʻl, Haqiqat va Hayot ҲСХМ216</title>
</song>