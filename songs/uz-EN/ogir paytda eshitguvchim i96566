<?xml version="1.0" encoding="UTF-8"?><song><title>Ogʻir paytda Eshitguvchim</title>
<key>C</key>
<lyrics>[V1]
.   C                   Am
 // Ogʻir paytda Eshitguvchim
.  F             G
 Ibodatda Yupatguvchim
. C         Am
 Har holatda Suyanguvchim
.F              G
 Borligʻimsan Otajonim //

[C1]
.      Dm
   // Olib turgan Nafasim
.   Am
   Urib turgan yuragim
.   C           G
   Mehribon Otajonim //

[V2]
 // Hayotimni oʻzgartirgan
 Har holatda meni sevgan
 Yuragimda maskan qilgan
 Nafasimsan Otajonim //

[B1]
   Moʻjizaga Qodir Otam
   Deding: &quot;Seni sevdim, bolam!&quot;
   Bilsa edi butun olam
   Hayotimsan Otajonim</lyrics>
</song>