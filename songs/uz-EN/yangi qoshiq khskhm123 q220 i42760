<?xml version="1.0" encoding="UTF-8"?><song><title>Yangi Qoʻshiq ҲСХМ123 Q220</title>
<lyrics>[V1]
.   C                       Am
 // Yangi qoʻshiq kuylayman Senga Iso,
.F                  G
 Chunki Seni juda sevaman.
.C                      Am
 Senga kuylash jonga tegmaydi aslo,
.F       G           C
 Chunki Sen meni oqlagansan. //

[C1]
.     Dm               Am     F  G   C
   // Hayotimda Sen yagonasan Rabbim Iso,
.  Dm              Am        F  G   C
   Men uchun doim parvonasan Rabbim Iso.
.  Dm                      Am     F  G   C
   Sening isming men uchun qalqon Rabbim Iso,
.  Dm                  Am      F      G
   Sen orqali ochiqdir osmon, rahmat Senga Iso. //

[V2]
 // Yangi hayot beradi senga Iso,
 Chunki seni juda sevadi.
 Gunohingni kechiradi U tanho,
 Tavba qilsang senga keladi. //</lyrics>
<key>C</key>
<aka>Yangi qoʻshiq koʻylayman Senga - Iso</aka>
<hymn_number>123</hymn_number>
<author>Malohat Pulatova</author>
</song>