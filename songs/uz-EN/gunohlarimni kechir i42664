<?xml version="1.0" encoding="UTF-8"?><song><title>Gunohlarimni kechir</title>
<aka>Iso bandangman men</aka>
<key>Am</key>
<lyrics>[C1]
.     Am            Dm      E            Am
   // Gunohlarimni kechir, gunohlarimni koʻtar. //
.     Am       Dm            E       Am
   // Ey Iso bandangman men, Ey Iso qavmingman men. //
.     Am            Dm         E         Am
   // Gunohlarimni kechir, gunohlarimni koʻtar. //

[V1]
.   Am            Dm
 // Yurak kasal, qalbim nogiron,
.G            C
 Orom bergin intizordirman. //
.   Am              Dm
 // Shifobaxsh Ruh hamrohim boʻlsin,
.E               Am
 Endi bu qalb shodlikka toʻlsin. //

[V2]
 // Izladim koʻp bormisan Oʻzing?
 Izladim koʻp gapirgin soʻzing //
 // Endi bildim bordirsan Oʻzing,
 Endi bildim gapirding soʻzing. //</lyrics>
</song>