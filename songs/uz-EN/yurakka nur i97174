<?xml version="1.0" encoding="UTF-8"?><song><title>Yurakka nur</title>
<aka>Umidsizlikka</aka>
<key>Am</key>
<lyrics>[V1]
.Am                Dm
 Umidsizlikka tushganimda
.G                     C
 Hayot qorongʻi koʻringanida
.Am                Dm
 Maʼno, mohiyat qolmaganida
.G                  C
 Nigohimni Senga qaday Ota

[C1]
.    Am          F         Dm
   YUrakka nur berguvchi Oʻzing
.   G          C             E
   Hayotimga YOlgʻiz maʼno Oʻzing
.   Am          F        Dm
   Qalbimga umid toʻldirding Oʻzing
.   G         C               E
   Nigohim doim Senda boʻlsin Ota

[V2]
 Ishlarim ham oʻxshamaganida
 Koʻzga hech zot koʻrinmaganda
 Najot ham yoʻqday tuyulganida
 Nigohimni Senga qaday Ota

[V3]
 Tushkunlikka tushib qolganimda
 Umidsizlikka joy berganimda
 Sabr-toqat ham qolmaganida
 Nigohimni Senga qaday Ota</lyrics>
<author>Ulugʻbek Joʻrayev</author>
</song>