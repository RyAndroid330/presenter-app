<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>153</hymn_number>
<author>jeontaehyeog</author>
<title>Qadim Zamonda ҲСХМ153</title>
<lyrics>[V1]
.C         Am    Dm      G
 Qadim zamonda, baland osmonda,
.C          Am     Dm       G
 Sen uchun maxsus reja bor edi.
.C         Am    Dm        G
 Xudovand senga nazar solganda,
.C          Am   Dm       G
 Dedi: qanchalar sen ajoyibsan.
.F       G        Em     Am
 Erdagi hamma narsadan ajoyib,
.       Dm            G       C
 Qilib qoʻlim bilan yaratdim seni.
.F         G             Em   Am
 Men sen tufayli xursand boʻldim.
.   Dm         F  G    C
 Qanchalar men seni sevaman.
.C  G Am      F   G  Dm  G
 Sevaman, marhamatlayman,
.   C        G      Am
 // Sening qalbing sevgi bilan
. Dm         G   C
 toʻlishini tilayman. //</lyrics>
<key>C</key>
</song>