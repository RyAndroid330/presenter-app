<?xml version="1.0" encoding="UTF-8"?><song><aka>Baxt faqat Senda ekan</aka>
<lyrics>[V1]
.Em         Am
 Baxt faqat Senda ekan,
.B7             Em
 adashib yurgan edim,
.C          D            Em
 Oʻylamagan bir yoʻl boshladim,
.Em            Am
 bir doʻst tayanchim boʻldi,
.B7             Em
 Hayotim oʻzgartirdi,
.C           D         Em
 vafodor oʻzgarmas muqaddas.

[C1]
.         G           D
   Parvardigor, Parvardigor,
.  Am          Bm        Em
   Xudoning Qurbonlik Qoʻzisi,
.          G          D
   Parvardigor, Parvardigor,
.  Am         Bm       E
   Osmondan kelgan Najotkor!</lyrics>
<key>Em</key>
<title>Parvardigor W12 CA4</title>
<hymn_number>12</hymn_number>
<author>Tash aka</author>
</song>