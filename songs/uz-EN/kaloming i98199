<?xml version="1.0" encoding="UTF-8"?><song><title>Kaloming</title>
<key>C</key>
<lyrics>[V1]
.C          Em        Am
 Kalomingda vaʼdalar bisyor
. F             Dm          G
 Har Soʻzingda javoblaring bor
 Kalomingdan oziqlanamiz
 Kaloming-la chekmas jon ozor

[C1]
.   C          Em        Am
   Kalomingdir mening ozuqam
.   F          Dm        G
   Kaloming qalbimga malham

[V2]
 Kalomingdan yupanch olamiz
 Kaloming-la olgʻa boramiz
 Kalomingda Hayot Kalomi
 Har bir Soʻzni kuchga solamiz

[V3]
 Kalomingni qalbimda saqlay
 Kalomingdan men malham olay
 Kalomingni boshqalarga ham
 Muhabbat bilan doim ulashay</lyrics>
<author>Ulugʻbek Joʻrayev</author>
</song>