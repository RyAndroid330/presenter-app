<?xml version="1.0" encoding="UTF-8"?><song><title>Bizdagi Xudo</title>
<lyrics>[V1]
.G
 Bizdagi Xudo buyukdir
.Em                     D
 Bizdagi Xudo bilar bizni
.             C
 Bizni qoldirmas

[V2]
.G
 Bizning Xudovand kuchlidir
.Em                         D
 Bizning Xudovand biz tomonda
.             C               G
 Bizni qoldirmas, aslo yengilmas

[C1]
.      C      G     D
   Abadiy turar bu sevging
.      C      G      D
   Abadiy yashar bu sevging
.      C       G            D       Em
   Koʻzlarimiz och, nuring bilan qopla
.      C       G     D
   Rabbim, sevging abadiy

[V3]
 Qudratli Xudo biz bilan
 Qudratli Xudo - qutqaruvchi
 U yoʻlni ochar, U yoʻlni ochar,

[B1]
.  Em        C      G     D
    Xudo qoʻriqlar bizni har dam
.  Em       C      G     D
    Xudo kurashar biz uchun
.  Em         C     G       D
    Xudo qaygʻurar biz-chun har dam
.  C            G   Em           D
   Yolgʻiz emasmis, yolgʻiz emasmis</lyrics>
<key>G</key>
<author>Chris Brown</author>
</song>