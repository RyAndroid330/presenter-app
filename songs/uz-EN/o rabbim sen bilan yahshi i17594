<?xml version="1.0" encoding="UTF-8"?><song><aka>Olqishlar ayting doʻstlar</aka>
<key>Bm</key>
<lyrics>[V1]
 Intro:
.Em Bm Em Bm
 -__
.Bm              D      A
 O Rabbim, Sen bilan yaxshi!
.G         Em          Bm
 Yuragimga tinchlik berding.
.Bm                       D      A
 Chunki Sen menga yangi hayot berding.
.G      Em         Bm
 Va meni muqaddaslading,
.Bm                      D          A
 U Masih xaqi menga muhabbat koʻrsatdi.
.G            Em              Bm
 Meni dunyo yaratilishidan avval tanladi,
. Bm                    D       A
 Endi men Senga jonim bagʻishlayman.
.G            Em             Bm
 Senga cheksiz olqishlar boʻlsin!

[C1]
.     D            Bm        A
   //  Olqishlar ayting doʻstlar,
.  Bm                    A
   Rahmatlar ayting doʻstlar,
.  Em            G          D
   Barhayot Rabbimiz U - sevgi!
.  Em          G           D
   Ota, Oʻgʻil va Muqaddas Ruh! //

[V2]
 // Yo Xudoyim Sen bilan yaxshi!
 Oʻz Oʻgʻlingni berding, gunohim yuvding
 Men ojizni olamdan qutqarding
 Va Oʻzingga oʻgʻil qilib olding! //

[C2]
   // Olqishlar ayting doʻstlar
   Rahmatlar ayting doʻstlar
   Barhayot Rabbimiz U sevgi
   Ota, Oʻgʻil va Muqaddas Ruh! //

[B1]
   Olqishlar ayting doʻstlar!
   Rahmatlar ayting doʻstlar!
   Barhayot Rabbimiz U sevgi,
   Rahmat senga Rabbim.
   Chunki Sen meni dunyo,
   Yaralishidan oldin tanlading.
   Senga olqishlar boʻlsin!

[C3]
   /// Olqishlar ayting doʻstlar
   Rahmatlar ayting doʻstlar
   Barhayot Rabbimiz U sevgi
   Ota, Oʻgʻil va Muqaddas Ruh! ///</lyrics>
<title>O Rabbim - Sen bilan yahshi</title>
<hymn_number>150</hymn_number>
</song>