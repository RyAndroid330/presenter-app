<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Osmondagi Otajon Senga shon sharaf boʻlsin. //
 // Rabbim Iso Masihga hamdu sanolar boʻlsin. //

[V2]
 // Osmonda bor abadiy hayot bu yoʻl Iso yoʻlidir. //
 // Men Otamni koʻraman ey u vatanga borganda mangu. //

[V3]
 // Iso mening yonimda men nimadan qoʻrqaman?! //
 // Iso soʻzin aytganda juda baxtli boʻlaman. //

[V4]
 // Osmondagi Otajon Senga shon sharaf boʻlsin. //
 // Rabbim Iso Masihga hamdu sanolar boʻlsin. //
 // Hamdu sanolar boʻlsin. //</lyrics>
<title>Osmondagi Otajon Senga shon-sharaf boʻlsin Q95</title>
