<?xml version="1.0" encoding="UTF-8"?><song><title>Rabbimizga hamdu sanolar Q50</title>
<aka>Otajonim kechiring bizni</aka>
<lyrics>[V1]
 // Otajonim kechiring bizni,
 Bilmay qilgan gunohimizni //
 // Otajonim boshqaring bizni
 Chin koʻngildan istaymiz shuni. //

[C1]
   // Rabbimizga hamdu sanolar,
   Xudoyimga shonu sharaflar //

[V2]
 // Birodarlar tetik boʻlinglar,
 Imonda siz qattiq turinglar //
 // Otajonim farzandlaringiz
 Yuragida Muqaddas Ruhing. //

[C2]
   // Rabbimizga hamdu sanolar,
   Xudoyimga shonu sharaflar. //

[V3]
 // Ibodatga borgan bandalar,
 Vasvasaga tushganlari bor. //
 Shaytonlarni albat yengamiz,
 Otajonim qudrating bilan.
 Shaytonlarni albat yengamiz,
 Xudo yoʻlidan adashmangiz.

[C3]
   // Rabbimizga hamdu sanolar,
   Xudoyimga shonu sharaflar. //

[V4]
 // Ibodatni tark etganlar ham,
 Ishonamiz hali keladi. //
 Otajonim qudrati bilan,
 Hamma yovuzlikni yengadi.
 Otajonim qudrati bilan,
 Barcha yovuzlikni yengadi.

[C4]
   // Rabbimizga hamdu sanolar,
   Xudoyimga shonu sharaflar. //
   // Xudoyimga shonu sharaflar. //</lyrics>
<hymn_number>50</hymn_number>
</song>