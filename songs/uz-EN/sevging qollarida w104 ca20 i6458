<?xml version="1.0" encoding="UTF-8"?><song><aka>Oddiy sevgi qoʻshigini</aka>
<key>G</key>
<lyrics>[V1]
.G        D           Em Em7
 Oddiy sevgi qoʻshigini,
.   C Am     D
 Isoga kuylayman,
.G     D             Em Em7
 Eru Osmonning Shohiga,
.      C  Am       D7
 Rabbimga, Najotkorga!

[P1]
.  C          G        D        Em
   Qalbim Sen bilan quvonar birga,
.  A9          G          D
   bundan yaxshi joy menga!

[C1]
.  G          D     Em Em7
   Sevging qoʻllaridan koʻra,
.  C         A9       D
   Sevgi qoʻllaring bilan,
.       G         D       Em Em7
   Meni ushla quyib yuborma,
.   C        D7    G
   Sevgi qoʻllaringdan!</lyrics>
<title>Sevging Qoʻllarida W104 CA20</title>
<hymn_number>104</hymn_number>
<author>Craig Musseau</author>
