<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   F                  C
 // Shukur chin qalbimizdan
.    Dm7      Am
 Shukur muqaddas Rabga
.    Bb             F
 Shukur chunki Isoni
.          Eb    C
 Taqdim qildi bizga //

[C1]
.       Am     Dm              Gm
   // Endi, ojizlar kuchga toʻldi
.       C7              F
   Kambagʻallar boy boʻldi
.      Dm          Eb    C7
   Xudoning muhabbati uchun //
.        F
   Shukur !

[B1]
.         F             Bb6
   Shukur chin qalbimizdan!
.      F         Bb6
   Shukur muqaddas Rabga!</lyrics>
