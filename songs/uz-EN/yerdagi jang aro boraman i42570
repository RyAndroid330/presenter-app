<?xml version="1.0" encoding="UTF-8"?><song><title>Yerdagi jang aro boraman</title>
<key>Dm</key>
<lyrics>[V1]
.Dm                Gm
 Yerdagi jang aro boraman,
.Gm    A           Dm
 Choʻponga oʻxshab choʻlda.
.Dm             Gm
 Yurakdagi ibodatlarim,
.Gm    A        F
 Ruhni koʻtarar menda

[C1]
.       F          Gm
   // YUrakdagi ibodatlarim,
.  Gm           Dm
   Yurakdagi ibodatlarim
.  Dm           Gm
   Yurakdagi ibodatlarim
.  Gm       A      F(Dm)
   Ruhni koʻtarar menda. //

[V2]
 Olis joyga ketyapman men,
 Xudovandning uyiga,
 U yerda daryoday oqadi,
 Hamdu sano Xudoga.

[C2]
   // U yerda daryoday oqadi,
   U yerda daryoday oqadi
   U yerda daryoday oqadi
   Hamdu sano Xudoga. //

[V3]
 Tilla shaharga kirganimda,
 Shu zahoti koʻraman.
 Malaklar madhiyasi ichra,
 Mehribon Xudovandni.

[C3]
   // Malaklar madhiyasi ichra,
   Malaklar madhiyasi ichra,
   Malaklar madhiyasi ichra,
   Mehribon Xudovandni. //</lyrics>
</song>