<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>84</hymn_number>
<lyrics>[V1]
 // Ey Parvardigor Senga soʻzim bor, //
 // Muqaddas nomingga hamdu sanolar. //
 // Ijozat bersang quling boʻlsam Seni,
 Yer yuzida mahsuling boʻlsam Seni. //

[V2]
 // Ey Rabbim Iso kel qalbimizga, //
 // Sen abadiy hayot baxsh etding bizga. //
 // Ijozat bersang quling boʻlsam Seni,
 Yer yuzida timsoling boʻlsam Seni. //

[V3]
 // Muqaddas Ruhga toʻldi bu badan, //
 // Oʻz qoning ila meni olding zulmdan. //
 //// Ijozat bersang quling boʻlsam Seni,
 Yer yuzida Oʻz nuring boʻlsam Sani. ////</lyrics>
<title>Ey Parvardigor Senga soʻzim bor Q84</title>
</song>