<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>172</hymn_number>
<lyrics>[V1]
 // Osmonga yoʻl Masihdur,
 Hayot bergan Masihdur. //
 // Quvonch bergan Masihdur,
 Jannatga yoʻl Masihdur. //

[V2]
 // Keling barcha insonlar,
 Masih soʻzin eshiting. //
 // Xudo nomin olqishlab,
 Hamdu sano bir bering. //

[V3]
 // Madadkorim Xudoyim,
 Muqaddas qon toʻkibsan. //
 // Olqish soʻzga loyiqsan,
 Qurbon boʻla bilibsan. //

[V4]
 // Qurbon boʻla bilibsan,
 Gunohlarni koʻmibsan. //
 // Soʻng qaytadan tirilib,
 Insonga baxt beribsan. //
 Osmonga yoʻl Masihdur,
 Jannatga yoʻl Masihdur.</lyrics>
<title>Osmonga yul Masixdur Q172</title>
</song>