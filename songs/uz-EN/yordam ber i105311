<?xml version="1.0" encoding="UTF-8"?><song><title>Yordam ber</title>
<lyrics>[V1]
 // Yordam ber Iso sen bilan boʻlishga
 Oʻz xochimni koʻtarib men yurishga
 Xar kuni bu dunyo uchun oʻlishga
 Sen kelgancha men tayyor boʻlishga //

[C1]
   // Faqat Senga kuylayman Rabbim,
   Sendan tinchlik topar yuragim
   Faqat Sen loyiqsan olqishlarga
   Iso, Iso, Iso //

[V2]
 // Yordam ber dushmanlarimni sevishga
 Bor vaqtimni Iso senga berishga
 Imon musobaqada gʻolib chiqib
 Sen atagan gʻolib tojni kiyishga //</lyrics>
</song>