<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.Bm          A        F#m   Bm
 Parvardigor olamni yaratganida,
.          G       Em F#m   Bm
 Yer uzra quyoshni porlatganida,
.Em                      A     D
 Boʻldiyo zaminga ziyon taratganida.
.   C#m        G            F#m        Em
 // U buyurgan oʻsha soʻz, kalom eding Sen. //
.Bm          Em   A           D
 Kalom eding Sen, kalom eding Sen.
.   D          G            F#m        Em(Bm)
 // U buyurgan oʻsha soʻz, kalom eding Sen. //

[V2]
.Bm                   Em     D
 Dunyoga gunoh kelib adashganida,
.G                     A       D
 Insonlar boylik deya talashganida.
.Em                    A        D
 Haqiqat yolgʻon bilan almashganida.

[C1]
.     D              G        F#m       Em(Bm)
   // Xudo yuborgan Najotkor, Iso eding Sen, //
.  Bm        Em   A         D
   Iso eding Sen, Iso eding Sen.
.     D          G        F#m           Em(Bm)
   // Xudo yuborgan Najotkor, Iso eding Sen. //

[V3]
.Bm      G                   A
 Ilohiy nur porlar sirli koʻzida,
.F#m         Em         A       D
 Bir dunyo maʼno bor, aytgan soʻzida.
.Em                 A        Em
 Odamga yod xislat, bordur oʻzida.

[C2]
.     Em          (G)   A(F#m)     Em(Bm)
   // Inson qiyofasida, Xudo eding Sen, //
.             Em   A          D
   Xudo eding Sen, Xudo eding Sen.
.     Em        G       F#m        Em(Bm)
   // Inson qiyofasida, Xudo eding Sen, //
.  Bm          Em   A           D
   Kalom eding Sen, kalom eding Sen.
.                     G       F#m        Em(Bm)
   // U buyurgan oʻsha soʻz, kalom eding Sen. //
.  Bm        Em   A         D
   Iso eding Sen, Iso eding Sen.
.               G       F#m             Em(Bm)
   // Xudo yuborgan Najotkor, Iso eding Sen. //
.  Bm         Em    A         D
   Xudo eding Sen, Xudo eding Sen.
.               G        F#m          Em(Bm)
   // Inson qiyofasida, bizni sevding Sen. //
.     Bm(A)         G(Bm)
   // Bizni sevding Sen! //</lyrics>
<title>Parvardigor olamni yaratganida</title>
</song>