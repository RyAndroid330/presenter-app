<?xml version="1.0" encoding="UTF-8"?><song><title>Bu dunyoda adashdim W19</title>
<key>D</key>
<lyrics>[V1]
.   D
 //  Bu dunyoda adashdim,
.Bm
 Koʻplar meni aldashdi,
.B7                Em
 Gunohning toʻriga tushib!
.G
 Muhabbat bilan oʻynashdim,
.D      Bm
 Gunohni oʻylamadim,
.Em        A             D
 Yuragimda hech tinchlik yoʻq! //

[C1]
.     D/Bm    G        A
   //  Xudoga kel tavbaga:
.          D          Bm
   Xudoyim meni kechir deb,
.           G           A
   Mening umrimni oʻzgartir,
.       D
   Xudoyim! //

[V2]
 // Bu dunyoda adashding,
 Koʻplar seni aldashdi,
 Gunohning toʻriga tushib!
 Muhabbat bilan oʻynashding,
 Gunohni oʻylamading,
 yuragingda hech tinchlik yoʻq! //</lyrics>
<author>Zafar</author>
<hymn_number>19</hymn_number>
</song>