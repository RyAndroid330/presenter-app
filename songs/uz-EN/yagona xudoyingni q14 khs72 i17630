<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>14</hymn_number>
<title>Yagona Xudoyingni Q14 ҲС72</title>
<aka>Xudoning kalomida bor ikki amir</aka>
<lyrics>[V1]
 // Xudoning kalomida bor ikki amr: //
 // Yagona Xudoyingni, Yagona Xudoyingni,
 Butun qalbing, butun joning,
 Butun aqling va kuching bilan sevgin! //

[V2]
 // Oʻzingni sevgandek oʻzgani sevgin! //
 // Yagona Xudoyingni, Yagona Xudoyingni,
 Butun qalbing, butun joning,
 Butun aqling va kuching bilan sevgin! //

[V3]
 // Oʻzgani hukm qilma boʻlmaysan mahkum! //
 // Yagona Xudoyingni, Yagona Xudoyingni,
 Butun qalbing, butun joning,
 Butun aqling va kuching bilan sevgin! //

[V4]
 // Solihlik yoʻlidan yur boʻlmaysan nobud! //
 // Yagona Xudo seni, Yagona Xudo seni,
 Butun hayotingda, tutgan hayolingda,
 Jannat makonida qoldirmas yolgʻiz! //

[V5]
 // Kalomni eshitganmas bajargan solih! //
 // Yagona Xudoyingni, Yagona Xudoyingni,
 Butun qalbing, butun joning,
 Butun aqling va kuching bilan sevgin! //</lyrics>
</song>