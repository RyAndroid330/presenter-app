<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>222</hymn_number>
<author>Минсоп Ли</author>
<title>Xudoning Muhabbati bilan ҲСХМ127</title>
<key>D</key>
<lyrics>[C1]
.     D        A            Bm
   // Xudoning muhabbati bilan qabul qilamiz,
.  G          D         Em7    A(D)
   Hayotingiz ichida Xudo sevgisin koʻramiz. //

[V1]
.D       A                        Bm
 Azaldanoq boshlangan Xudoning rejasi bilan,
.G              D      Em7    A
 Bizning uchrashuvimiz amalga oshdi.
.D      A            Bm
 Bizning oramizda borligingiz uchun,
.G          D             Em7    A     D
 Hammamiz xursandmiz quvonib, olqishlaymiz.

[C2]
   // Xudoning muhabbati bilan qabul qilamiz,
   Hammamiz Isoni olqishlaymiz. //</lyrics>
</song>