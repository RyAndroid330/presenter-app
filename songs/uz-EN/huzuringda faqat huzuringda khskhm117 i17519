<?xml version="1.0" encoding="UTF-8"?><song><title>Huzuringda, Faqat huzuringda ҲСХМ117</title>
<lyrics>[C1]
.     G                         Em
   // Huzuringda, faqat huzuringda,
.  C Am         D7
   Bexatar boʻlaman!
.          G                 Em C
   Huzuringda, faqat huzuringda,
.  Am         D7
   bu yerda turaman! //

[V1]
.                G      Em
 Agar toʻfon boʻlsa ham,
.  Em7         Bm
 lekin huzuringda,
.C Am         D7
 Bexatar boʻlaman!
.                    G    Em
 Chunki Sen mening panohim,
.       Em7         Bm     C
 Mening bexatar qoʻrgʻonim,
.Am         D
 bu yerda turaman!</lyrics>
<key>G</key>
<hymn_number>117</hymn_number>
<author>Zafar</author>
</song>