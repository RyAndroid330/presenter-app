<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Muqaddas Rux tinchlik Ruxisan
 Tinchlik bergin meni qalbimga
 // Ozod boʻlay men
 Dunyo tashvishlaridan
 Muqaddas Rux tinchlik Ruxisan //

[V2]
 Muqaddas Rux donolik senda
 Donolik ber sendek boʻlay men
 // Sensiz hech kim emasman
 Va hech kim boʻlolmasman
 Muqaddas Rux donolik senda //

[B1]
   Muqaddas Rux kuch qudrat Ruxi
   Sen bilan qoʻrqmasman aslo
   // Kalomningni soʻzlashni oʻrgat
   Muqaddas Rux tinchlik Ruxisan //</lyrics>
<title>Mukaddas Rux Tinchlik Ruxisan</title>
</song>