<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ruhdir meni paydo qilgan Xudoyim,
 Suratimni toʻliq qilgan Xudoyim.
 // Borligʻimni butun qilib Xudoyim,
 Koʻrkam qilib yaratganim Xudoyim. //

[V2]
 // Sevmaganda bizni sevgan Xudoyim,
 Bilmaganda bizni bilgan Xudoyim //
 Ulugʻ noming ulugʻlansin yurtimda,
 Senga qoʻshiq madhlar boʻlsin Xudoyim.

[V3]
 // Ovoz berding ohang berding Xudoyim, //
 Nomingni men kuylab oʻtgum dunyoda.
 Ovoz berding ohang berding Xudoyim,
 Nomingni men kuylab oʻtgum dunyoda.

[V4]
 // Qurbon qilib borligʻimni Oʻzingga,
 Shukr aytib sayrab oʻtgum dunyoda. //
 Yoʻqdan meni paydo qilgan Xudoyim,
 /// Suratimni toʻliq qilgan Xudoyim. ///</lyrics>
<aka>Ruhdir meni</aka>
<title>Xudoyim mening Q114</title>
<hymn_number>114</hymn_number>
</song>