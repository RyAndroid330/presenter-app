<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23643</hymn_number>
<author>Sobir Umurov</author>
<lyrics>[V1]
.Db      Fm
 Sen Egam mening umidimsan
.Db                 Eb
 Yoshligimdan Senga umid bogʻlayman

[C1]
.     Fm            Db           Ab
   // Tugʻulganimdan biyon Senga suyandim
.                Eb      (Fm)
   Doimo Senga hamdu sano aytaman //

[V2]
.Db          Fm
 Mening panoh qoyam boʻlgin
.Db                Eb
 Har doim men Senga kela olay

[V3]
.Db                   Eb           Fm
 Ogʻzimdan aslo tushmas Senga hamdu sanolar
.Db                    Eb          Fm
 Kun boʻyi shuhratingni eʼlon qilaman Egam

[V4]
.Db               Eb              Fm
 Keksaygan chogʻimda meni tashlab qoʻymagin
.Db             Eb          Fm
 Quvatim ketganda meni tark etmagin</lyrics>
<key>Db</key>
<title>Umidimsan</title>
</song>