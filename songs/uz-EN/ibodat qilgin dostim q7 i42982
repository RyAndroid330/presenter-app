<?xml version="1.0" encoding="UTF-8"?><song><title>Ibodat qilgin doʻstim Q7</title>
<lyrics>[V1]
 // Ibodat qilgin doʻstim, imoning saqla. //
 // Gunohdan ozod boʻlgin, burchingni oqla. //
 // Kalom qilichdan ham oʻtkir Rabbonim, //
 // Avvali-yu oxiri ham Sensan qalqonim. //

[V2]
 // Rabbim kuch-quvvat bersin, koʻzing sinovida.
 Savob ishga qoʻl urgin, boʻlgin sinovda. //
 Ota-onangni ulugʻlab, Sen Tangrim qonim.
 // Muqaddas Ruhingda men, toʻlay har doim. //

[V3]
 Fikring va zikring Menda, doim inoyat boʻl.
 Egilgan odamga, doim hamroh boʻl.
 // Soddadillik tez ketib, men gerdayib ketmay. //
 // Tangrim Meni ulugʻlagin, Oʻzing tarafla. //
 // Ibodat qilgin doʻstim, imoning saqla. //
 // Gunohdan ozod boʻlgin, burchingni oqla. //
 // Imoning saqla, burchingni oqla. //</lyrics>
<hymn_number>7</hymn_number>
</song>