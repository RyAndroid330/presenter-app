<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Kim, Seni sevgingdan,
 Meni judo qilar ekan // /
 Qaygʻumi, siqilishmi,
 Quvgʻinmi, ochlikmi,
 Yalangʻochlikmi, xavf-xatarmi
 yoki qilichmi?

[V2]
 /// Na oʻlim va na hayot, na farishtalar
 Va na jin-ajinalar,
 Na hozirgi va na kelgusi,
 Hamda na yaratilgan boshqa biron mavjudod
 Rabbimiz sevgisidan judo qilishga qodir emas ///
 Rabbimiz Iso sevgisidan
 Judo qilolmas</lyrics>
<title>Kim, Seni sevgingdan W62</title>
<hymn_number>62</hymn_number>
</song>