<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>88</hymn_number>
<lyrics>[V1]
.C#m            A     F#m   C#m
 Derazam ortida yoqsa oppoq qor,
.B                      F#m
 Sen yodimga kelarsan takror.
.A                     B
 Yodga tushar Sening siymoing,
.Abm
 Koʻzdan ketmas bergan imoning.

[C1]
.      C#m                  E
   // Orzu havas dilga ber endi,
.   B                     C#m
   Sensiz dunyo menga tor endi.
.  A                    B
   Ushbu qordek erigan bagʻrim,
.  F#m                    C#m
   Mudom yurak Senga zor Rabbim. //

[V2]
 Yana kelar qish,yogʻadi qor,
 Qalbim toʻrida bir savol.
 Bugun meni sochlarimda oq,
 Najoting ber boʻlmayin gumroh.</lyrics>
<key>E</key>
<title>Yurak Senga zor Q88</title>
</song>