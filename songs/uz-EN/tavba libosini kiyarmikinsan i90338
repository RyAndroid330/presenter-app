<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Jahlda kimgadir zahar sochishdan
 Voajab oʻzingni tiyarmikinsan //
 // Xudoning oldida kechirim soʻrab
 Tavbaning libosin kiyarmikinsan //

[V2]
 Gʻaribu boylarni baravar koʻrib
 Qalbda imon qasrin qurarmikinsan
 // Men tanlab borayotgani hayot yoʻlimdan
 Yonma-yon men bilan yurarmikinsan //

[V3]
 Baʼzida koʻrinsam horgʻin va maʼyus
 Bir ogʻiz dalda soʻz soʻzlarmikinsan
 // Men orzu qilganman moviy maʼvoni
 Sen ham yuksaklarni koʻzlarmikinsan //

[V4]
 // Seni deb sargʻaygan somon rangimni
 Vaslga rizo boʻlib ranglarmikinsan //
 // Tomirimda qon emas muhabbat oqar
 Shu oqim qudratin anglarmikinsan //
 Tavba libosini kiyarmikinsan
 Yonma-yon man bilan yurarmikinsan?</lyrics>
<aka>Jahlda kimgadir zahar sochishdan</aka>
<title>Tavba libosini kiyarmikinsan</title>
</song>