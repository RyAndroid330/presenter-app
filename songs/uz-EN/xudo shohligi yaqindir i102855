<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>212</hymn_number>
<lyrics>[V1]
.     A          F#m   D                    E
 Xudo Shohligi YAqindir Rabbimiz qaytib keladi
.      F#m                  C#m D       B7         E
 Sen uygʻon Masih izidan yurgin U Seni daʼvat etmoqda
.      A             F#m   D                  E
 Dunyo zulmat ichida yashab izlamoqda Iso nurini
.      F#m            C#m
 Faqat sen uygʻon va nuring porlasin
.D             B7          E
 Xudo sharafi senga tushmoqda

[V2]
.           D     A      F#m
 Oʻrningdan tur Xudo ila kuchli askar boʻl
.D        Bm                          E
 Rabbimiz sen bilan doim sen bilan birga
.          D      A            F#m
 Rabbimiz qaytib keladi yoʻl hozirlang
.D        Bm                  E
 Qudratli Xudo va Shohlar Shohi
.D       A
 Endi kelar</lyrics>
<key>A</key>
<title>Xudo Shohligi Yaqindir</title>
</song>