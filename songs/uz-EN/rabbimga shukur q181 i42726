<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Men Xudoning farzandiman, Iso Masih ummatiman, //
 Muqaddas Ruhning doʻstiman, Tangrimga shukur, shukur.
 Muqaddas Ruhning doʻstiman, Rabbimga shukur, shukur.

[V2]
 // Berdi Muqaddas Kalom, hayotim qildi farovon. //
 Sevdim dedi ishon va quvon, Rabbimga shukur,shukur.
 Sevdim dedi ishon va quvon, Tangrimga shukur,shukur.

[V3]
 // Hayotimni angladim men, gunohlarim topshirdim men, //
 // Rabbim bilan ahd tuzdim men, muqaddas inson boʻldim men. //
 // Doʻstim keling Xudoyimga, hurmat aylang Kalomiga, //
 // Diqqat qiling soʻzlariga, rozi boʻling amrlariga. //

[V4]
 // Men Xudoning farzandiman, Iso Masih ummatiman, //
 Muqaddas Ruhning doʻstiman, Tangrimga shukur, shukur.
 Muqaddas Ruhning doʻstiman, Rabbimga shukur, shukur.</lyrics>
<aka>Men Xudoning farzandiman</aka>
<title>Rabbimga shukur Q181</title>
<hymn_number>181</hymn_number>
</song>