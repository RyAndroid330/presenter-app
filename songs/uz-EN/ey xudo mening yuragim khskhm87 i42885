<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>24</hymn_number>
<key>D</key>
<lyrics>[V1]
.D        Em        A
 Ey, Xudo mening yuragim,
.         D       Bm
 Rabbimga doim shaydir.
.     Em   A    D
 Men Seni kuylayman.
.D         Em         A
 Uygʻongin ey mening Ruhim,
.          D           Bm
 Uygʻongin chang ila gʻijjak.
.     Em  A         D
 Saharni uygʻotib yuboraman.

[C1]
.          Em       D
   Ilohiy ohang, bilan
.       Em        A         D
   Iso Masih mening qoʻshigʻim,
.          Em               D
   Mening kuchim, mening Rabbim.
.  Em       A       D
   Isoni olqishlayman.</lyrics>
<title>Ey Xudo, Mening Yuragim ҲСХМ87</title>
</song>