<?xml version="1.0" encoding="UTF-8"?><song><title>Sen hamdu sanolar ichida yashaysan</title>
<key>Cm</key>
<lyrics>[V1]
.Cm                Ab
 Sen hamdu-sanolar ichida yashaysan
.B                    Gm             Cm
 Er yuzida barcha hamdlar Seniki boʻlsin
.                    Ab
 Sen Oʻz shuhratingni hech kimga bermaysan
.B                 Gm            Cm
 Yuragimdagi maqtovlar Senga yogʻilsin

[C1]
.  Cm         Ab
   Hamdu-sano Buyuk Xudo
.  B        Gm       Cm
   Ulugʻlayman Nomingni

[V2]
.Cm                Ab
 Sen butun dunyoni qoʻlingda ushlaysan
.B                     Gm        Cm
 Sening qudratingga kim teng keladi?
.                   Ab
 Sen Oʻz Soʻzlaringning ustidan bedorsan
.B                  Gm            Cm
 Sening har bir Soʻzing bajo boʻladi</lyrics>
<author>Malohat Pulatova</author>
</song>