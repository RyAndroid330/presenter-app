<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<lyrics>[C1]
   // Egamizga hamdu sanolar boʻlsin,
   Egamizga hamdu sanolar boʻlsin,
   Samolarda, falaklardan,
   Unga hamdu sanolar boʻlsin. //

[V1]
 // Ey Uning farishtalari,
 Egamizga hamdu sanolar boʻlsin. //
 // Ey Uning samoviy lashkarlari,
 Egamizga hamdu sanolar boʻlsin. //

[V2]
 // Hamdu sano ayting yigit-qizlar,
 Yeshu qari hammangiz birga, //
 // Madhiya ayting Rabbimizga.
 Yolgʻiz Uning Nomi yuksakdir! //</lyrics>
<title>Egamizga hamdu sanolar boʻlsin</title>
</song>