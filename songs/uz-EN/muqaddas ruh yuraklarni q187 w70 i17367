<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Muqaddas Ruh yuraklarni
 Nuring bilan yoritgin. //
 // Olamning zulmatini Sen
 Sevgin bilan toʻldirgin. //

[V2]
 // Endi bizning dilimizda
 Oʻzing makon yaratgin,
 Nurli olov boʻlib yongin
 Qalbimizga joylashgin! //

[V3]
 // Muqaddas Ruh qudratingla
 Sodiqlarga kuch bergin
 Jamoatingni tiklagin
 Oʻzbek xalqin uygʻotgin! //</lyrics>
<title>Muqaddas Ruh yuraklarni Q187 W70</title>
