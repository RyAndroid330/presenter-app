<?xml version="1.0" encoding="UTF-8"?><song><title>Orkaga chekinmayman Q19</title>
<lyrics>[C1]
   // Orqaga chekinmayman. //
   // Lannatni koʻchasining,
   sharobin icholmayman. //

[V1]
 Rabbim kelgin bagʻringa ol,
 Men Seni kutayapman.
 Men Sening farzandingman,
 Men Sening dilbandingman.

[V2]
 // Dardlarim duosiga,
 Armonlarim noligan. //
 // Nohaqlik girdobida,
 Solihang qon yigʻlagag. //
 // Kel, Rabbiy qoʻlingni choʻz,
 Uzoqdaman ingragan. //

[V3]
 // Eshit mening ohim,
 Quloqsizning savodin. //
 // Ich-etim yebon har dam,
 Sahrodan oʻtayapman. //
 // Qalbimga tirik goʻsht berar,
 Oʻtmishdan kechayapman. //
 // Men seni izlayapman. //

[V4]
 Jafolik Xudoyim mening,
 Nolasin chidolmayman.
 // Yurakinam yonimda boʻl,
 Men sensiz yashay olmayman //
 // Nolay-u faryodimni,
 Men sensiz yecha olmayman //

[V5]
 Rabbim kelgin bagʻringa ol,
 Men Seni kutayapman.
 // Men Sening farzandingman,
 Men Sening dilbandingman. //
 Men Sening dilbandingman!</lyrics>
<hymn_number>19</hymn_number>
</song>