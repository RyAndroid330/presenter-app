<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em               C
 //  Samoviy Otamizga boʻlsin doim shon,
.D         B      B7         Em
 Uning mehribonligi bizga bepoyon //

[C1]
.  G             D
   Shon-sharaflar Rabbimizga,
.  C          Em   D/F#
   Shon-sharaf Xudoga!
.  G          D
   Muqaddas Ruxing bizlarga,
.  C                  B7
   Yor boʻlsin - ey, Omin.

[V2]
 // Xaloskorim Senga ham
 Boʻlsin doim shon
 Faqat Senda najot topdi
 Gunohkor inson //

[V3]
 // Muqaddas Rux Senga ham
 Boʻlsin doim shon
 Ogʻir xayot yoʻlimizni
 Sozlaysan oson //</lyrics>
<key>Em</key>
<title>Samoviy Otamizga CA37 W129 ҲС66 Q128</title>
