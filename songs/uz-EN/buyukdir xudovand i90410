<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12520</hymn_number>
<author>Jesse Reeves, Ed Cash, Chris Tomlin</author>
<lyrics>[V1]
.     C
 Shoxning ulugʻvorligi
.  Am
 Buyuklik libosi
.               F
 Borliqni toʻldirar
.              F
 Butun olam kuylar
.   C
 Huzuri nurga toʻlgan
.    Am
 Zulmat qochar Undan
.           F
 Larza ovozida
.           F
 Larza ovozida

[C1]
.    C
   Buyuk! Xudovand
.              Am
   Kuyla men bilan U buyuk
.                   F
   Butun borliq kuylar
.      G        C
   U Buyuk Xudovand

[V2]
. C
 Asrlar uzra U bor
. Am
 Vaqt uzra Hukmdor
.            F
 Boshi va Oxiri
.            F
 Boshi va Oxiri
.   C
 Muqaddas Uchlik - yakdil
.  Am
 Ota, Muqaddas Ruh, Oʻgʻil
.             F
 Qoʻzi timsolida
.               F
 Va Sher timsolida

[B1]
.        C
   Borliqda Noming Buyuk
.         Am
   Barcha Olqishga loyiq
.       F
   Yuragim kuylar
.      G          C
   U Buyuk - Xudovand</lyrics>
<key>C</key>
<title>Buyukdir Xudovand</title>
</song>