<?xml version="1.0" encoding="UTF-8"?><song><title>Kim biladi Q224</title>
<key>Em</key>
<lyrics>[V1]
.Em                G
 Kim biladi Xudo mehrini,
.G                     D
 Aytinglar kim Uning ismini?
.   Am       C(Em)
 // Iso aziz Iso,
. B           Em
 Iso rahmdil Iso. //

[V2]
 Kim yaratgan olamni bizni,
 Keling doʻstlar aytinglar shuni?
 // Iso aziz Iso,
 Iso ijodkor Iso. //

[V3]
 Odamlarning gunohi uchun
 Kimning qoni toʻkilgan yerga?
 // Iso aziz Iso,
 Iso jonimiz Iso. //

[V4]
 Ozodlikka chiqarib bizni
 Oʻrnimizga kim qurbon boʻlgan?
 // Iso qahramon Iso,
 Iso qudratli Iso. //

[V5]
 Endi bildik Sening mehringni,
 Bizga boʻlgan muhabbatingni,
 // Iso qadrli Iso,
 Iso sevikli Iso. //

[V6]
 Biling doʻstlar chin Xudo kim ekan?
 Bizlar uchun pok qonin toʻkkan
 // Iso aziz Iso
 Iso Rabbimiz Iso. //</lyrics>
<hymn_number>224</hymn_number>
</song>