<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Senga Kelaman ҲСХМ7</title>
<lyrics>[V1]
.   E      H       C#m
 // Iso, Iso Senga kelaman
.  F#m  E       H
 Iso, Iso shoshilaman
.E          H        C#m
 Ogʻir yoʻllar kezganimda
.     G#m          F#m
 Meni topib olding Sen
.    A         F#m         E   H
 Xazinamga aylanding endi Sen Iso //

[C1]
.  E  H         C#m            A
   O Iso Hayot bahsh etding menga
.  E       H          C#m    H
   Bordir mening taqdirim Senda
.  E  H        C#m           A
   O Iso sevgi yoʻllayman Senga
.  E      H         Esus4      E
   Buyuk hamdu sano boʻlsin Senga

[V2]
.   E     H        C#m
 // Iso, Iso Senga kelaman
.F#m    E     H
 Iso, Iso kuylayman
.E      H        C#m
 Atrofimda faqat Sensan
.      G#m          F#m
 Senga toʻlgandir Hayotim
.    A          F#m       E    H
 Xuzuringda xar kuni boʻlarman doim //</lyrics>
<key>E</key>
<author>Nodira Xoshimova</author>
<hymn_number>7</hymn_number>
</song>