<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Unga qanday qilib qaytaray</title>
<aka>Juda ham koʻp azob cheksam ham</aka>
<lyrics>[V1]
 Juda ham koʻp azob cheksam ham
 Xudoga boʻlgan ishonchim yoʻqolmadi
 Oʻylamasdan hamma odamlar
 Yolgʻonchidir dedim

[C1]
   Egam menga qilgan yaxshiliklarini
   Unga qanday qilib qaytaray
   Najot topganimni nishonlayman
   Egamga sajda qilaman
   Egam menga qilgan yaxshiliklarini
   Unga qanday qilib qaytaray
   // Egamiz xalqning koʻzi oldida
   Unga bergan ontimni ado etaman //

[V2]
 // Oʻzing kishanlardan meni ozod qilgansan
 Shukrona qurbonligini Senga nazr qilaman
 Jamiki xalqingni koʻzi oldida
 Senga bergan ontimni ado etaman //</lyrics>
</song>