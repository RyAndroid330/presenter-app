<?xml version="1.0" encoding="UTF-8"?><song><title>Yupating Meni Rabbim</title>
<key>Em</key>
<lyrics>[V1]
.Em         Am
 Koʻrsangiz koʻz yoshimni
.D           Em
 Chilparchin bardoshimni
.Em         Am
 Silab asta boshimni
.D           Em
 Yupating meni Rabbim

[V2]
 Maftun qilsa gar dunyo
 Aldasa qilib riyo
 Qalbimga sochib ziyo
 Yupating meni Rabbim

[C1]
.     Am         Em
   // Toʻldiring Ruhingizga
.  Em            D
   Sodiq qolayin men Sizga
.  Am           D
   Sinovlar kelsa bizga
.  Em         D       Em
   Yupating meni Rabbim //

[V3]
 Najotkorim Oʻzingiz
 Har bir aytgan Soʻzingiz
 Muhtojman Sizga xargiz
 Yupating meni Rabbim

[V4]
 Oʻrgating itoatni
 Sabr ila toqatni
 Bilmasam ibodatni
 Oʻrgating meni Rabbim</lyrics>
<author>Ravshan Hizirov</author>
</song>