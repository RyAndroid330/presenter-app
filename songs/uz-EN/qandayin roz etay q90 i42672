<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>90</hymn_number>
<title>Qandayin roz etay Q90</title>
<lyrics>[V1]
 // Qandayin rozi etayin men Seni Rabbiy?
 Bir kuni oxirat eshik qoqadi. //
 // Och bugun qiyomat soating desang o Rabbiy,
 Gunohkor bu qalbim qayga chopadi? //

[V2]
 // Soʻramassan ne yeding,ichding,kiyding
 Qay yurtlar kezding qancha doʻstlaring? //
 // Dunyoning shohimisan sultoni kim,
 Saroyin,qasriyu qiziqmas Egam. //

[C1]
   // Qandayin rozi etayin men Seni Rabbiy?
   Bir kuni oxirat eshik qoqadi. //
   // Och bugun qiyomat soating desang o Rabbiy,
   Gunohkor qalbim qayga chopadi? //

[V3]
 // O Rabbiy Oʻzingsan boshpanam,qoyam,
 Adolatda tengi yoʻq solih Egam. //
 // Qutqargan bu ruhing imlab oʻtmasin jon Rabbiy,
 Imkonim ber Senga qilayin xizmat. //</lyrics>
</song>