<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>5</hymn_number>
<title>Injilni men qoldirmayman Q5</title>
<aka>Abadiy qoldirmayman Injili Sharifni</aka>
<lyrics>[V1]
.   F#m    D            Em        F#m
 // Abadiy qoldirmayman Injil sharifni, //
.   Bm                    Em           F#m
 // Undan xalos boʻlganman tashlab gunohlarimni. //

[C1]
.  Bm           A           G       Em         F#m
   Hech qachon, hech qachon Injilni men qoldirmayman.
.  Bm           A           G       Em         F#m
   Hech qachon, hech qachon Injilni men qoldirmayman.

[V2]
 // Men vasvasaga tushsam U yoritar meni, //
 // Dushmanlar tahdid qilsa, gʻolib qilur meni. //

[V3]
 // Agar yoʻlda adashsam hayot oʻrmonida, //
 // Menga yordam beradi, dalda berib yoʻlda. //

[V4]
 // Unga men ishonganman, Unda bor chin yorugʻ, //
 // Undan hayot topganman, olamda tengi yoʻq. //</lyrics>
<key>F#m</key>
</song>