<?xml version="1.0" encoding="UTF-8"?><song><title>Osmon oʻ yerni yaratgan Tangrim</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 // Osmon-u yerni yaratgan Tangrim!
.Am
 Oy-u quyoshni qaratgan Tangrim!
.F               Dm             Em
 Barcha jonzotni yayratgan Tangrim! //

[C1]
.     Em
   // Sen yagona olqishlarga munosib,
.  Am
   Butun ruhingni yerni bosib,
.  F              Dm            Em
   Nopok insonlar jamolingdan qochib! //

[C2]
   // Butun borliqni yaratgan Allohim!
   Sen va mening axd-u qarorim!
   Soʻnmas yuraklarda bahorim! //

[V2]
 // Yor-u osmonni yoritgan Allohim! !
 Oʻz jonidan kechgan Isoyim!
 Taxt-u murodiga yetgan Xudoyim! //

[C3]
   // Butun borliqni yaratgan Allohim! !
   Sen va mening axd-u qarorim!
   Soʻnmas yuraklarda bahorim! //</lyrics>
</song>