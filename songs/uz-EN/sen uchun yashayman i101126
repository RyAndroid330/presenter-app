<?xml version="1.0" encoding="UTF-8"?><song><author>Joel Davies and Aodhan King</author>
<tempo>128</tempo>
<lyrics>[V1]
.C             D
 Xayotimga Sen maʼno berding
.Em              G
 Ruyeb bular orzular,
.              C     D
 Sen uchun men yashayman
.            Em    G
 Bu mening karorim.

[V2]
.C                D
 Xayratlanaman Senga doim
. Em             G
 Abadiy yoshmiz Senda,
.             C
 Guzaldir Sendagi Ozodlik
.                   Em    G
 Kadrlayman xar bir kunni.

[C1]
.  C           D
   Kuyosh nuri kurinar Senda
.  Em                 G
   Rang barang bular butun olam,
.  C              D        Em
   Najotkorim meni kutkardi
.     G               C  D    Em
   // Sen uchun yashayman. //

[V3]
.C                 D
 Yul kursatib meni etaklaysan
.Em             G
 Segingda tuliklik,
.                 C    D
 Eng yaxshi xayot Sendadir
.            Em     G
 Bu mening karorim Iso.

[B1]
.          C           D
   Yetaklaysan meni doimo Sen
.            Em          G
   Sevging kanotida uchaman,
.          C           D
   Ozodlik eshigi ochildi
.           Em           G
   Keraksan fakat menga Sen</lyrics>
<key>C</key>
<title>Sen uchun yashayman</title>
<time_sig>4/4</time_sig>
</song>