<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G           Em          Am        D
 Sen doimo yuragimda, men bilan birgasan,
.G           Em          Am         D
 Yuragimni saqlagin, haqiqatga yetaklagin.
.Bm                C        Bm           C D
 Koʻzlarim Senga qaraydi, qalbim Seni kutadi.

[C1]
.       G           Em
   Kuylayman butun qalbim bilan,
.       D            C
   Najotkorim Sen Oʻzing.
.    G                      Em
   Sendan hech qachon voz kechmayman,
.   D                        C
   Hayotimning maʼnosi Sen Oʻzing.

[B1]
.  G   Em    Am  D
   Xaleluya, Xaleluya,
.  G    Em   C    D   G
   Xaleluya, Xaleluya.</lyrics>
<title>Sen Doimo Yuragimda ҲСХМ66</title>
<hymn_number>66</hymn_number>
</song>