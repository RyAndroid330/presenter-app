<?xml version="1.0" encoding="UTF-8"?><song><title>Inson ishonsa</title>
<aka>Baxtsizlik gunohkor ketidan boradi</aka>
<lyrics>[V1]
.Am                          Em
 Baxtsizlik gunohkor ketidan boradi,
.Em               F         G
 Solihning mukofoti esa baxtdir.
.Am                     Em
 Yurak oʻzi oʻz dardini biladi,
.Em                 F         G
 Solihlikka intilganni Xudo sevadi.

[C1]
.      Am              Em
   // Inson ishonsa, inson ishonsa
.  F               G
   Xudo Oʻgʻliga hayoti oʻzgarar bir umrga //
.  Am         Em
   Inson ishongin Xudo Oʻgʻliga
.  F             G
   Hayoting oʻzgartirgin bir umrga</lyrics>
<key>Am</key>
<author>Sobir Umurov</author>
<hymn_number>21971</hymn_number>
</song>