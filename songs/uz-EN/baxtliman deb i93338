<?xml version="1.0" encoding="UTF-8"?><song><title>Baxtliman deb</title>
<lyrics>[V1]
.   Em     Am    H     Em
 // Baxtliman deb hammalarni aldadim
.    C    Am    H     Em
 Lekin yurak yolgʻonlikdan charchadi
.    Am      D  G  Em
 Shuncha yashab men Xudoni bilmadim
.     C    Am   H     Em
 Chaqirganda ovozini eshitmadim //

[C1]
   // Qoʻling bilan dushmanlardan saqlading
   Qoning bilan gunohlardan poklading
   Meni Senday boshqa hech kim sevmaydi
   Faqat Sen bilan boʻlishni istayman //

[V2]
 // Bu dunyoda yurak tinchlik topmadi
 Yer boyliklar meni baxtli qilmadi
 Gunohlarim yerga toshday tortadi
 Faqat Xudo menga yordam beradi //

[C2]
   // Qoʻling bilan dushmanlardan saqlading
   Qoning bilan gunohlardan poklading
   Meni Senday boshqa hech kim sevmaydi
   Faqat Sen bilan boʻlishni istayman //
   // Meni Senday boshqa hech kim sevmaydi
   Faqat Sen bilan boʻlishni istayman //</lyrics>
