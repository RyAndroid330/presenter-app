<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8</hymn_number>
<aka>Saodatlisiz</aka>
<lyrics>[C1]
.     Dm       Gm
   // Saodatli odamdir u
.  Bb            Cm        Dm
   fosiqlar maslahatiga yurmas,
.  Dm          Gm
   Gunohkorlar yoʻliga kirmas,
.  Bb            Cm        Dm
   Buzuqilar yigʻinida oʻtirmas. //

[V1]
.Dm                Gm
 Illo Xudovandning qonunidur
.C           F
 Uning zavqu orzusi,
.Dm              F
 Tunu-kun Tangri qonuni ila
.Gm            C       F
 Banddir uning fikri zikri.
.Dm           Gm        Bb   Gm
 Oqar suvlar qanoriga oʻtkazilgan,
.Dm        Gm       Bb  Cm Dm
 Mevasini mavsumida tugadigan,
.Dm                 Gm
 Barglari esa soʻlmaydigan
.       Bb         Dm
 daraxt kabidir u kishi.
.     Gm(Dm)
 //// U neki qilsa tole unga yor boʻlur. ////

[B1]
.  Dm
   Fosiqlar esachi bunday emaslar,
.  Eb                 Cm       Dm
   Shamolda toʻzgʻusi toʻpondurlar.
.  Dm                        Eb
   Fosiqlar hukm qilinganda bosh koʻtarmas,
.                 Cm            Dm
   Gunohkor solih majlisida turolmas.
.     Dm(Gm)            Eb(F)
   // Xudovand solihlar yoʻlini asrar,
.  Cm(Bb)          Bb(Cm)      Dm
   Fosiqlar oʻz yoʻlida halok boʻlar. //

[C2]
   /// Saodatli odamdir u
   fosiqlar maslahatiga yurmas,
   Gunohkorlar yoʻliga kirmas,
   Buzuqilar yigʻinida oʻtirmas. ///</lyrics>
<key>Dm</key>
<title>Saodatli odamdir Q8</title>
</song>