<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.      Am               Em
 Men Seni sevaman Otajonim
.    Am                  G    C
 Qalbimni ochishga men tayyorman
.       Dm                   Am
 // Yanada muqaddas qilgin meni
.   F                G       Am
 Oldingda pok boʻlishni istayman. //

[C1]
.    Dm                          G
   Muqaddassan, muqaddassan Tangrim
.    C                           F
   Buni men ming marta takrorlayman.
.    Am                        Em
   Muqaddassan, muqadassan Tangrim
.      F         G         Am
   Kuylamoqda buni farishtalar ham.

[V2]
.      Am               Em
 Sen meni poklagin Otajonim
.  Am                 G    C
 Huzuringda turishni xohlayman.
.   Dm                         Am
 Qordan ham oppoq qilgin Sen meni
.   F            G        Am
 Buni tanho Sen qila olasan.</lyrics>
