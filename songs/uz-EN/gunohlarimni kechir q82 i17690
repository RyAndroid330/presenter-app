<?xml version="1.0" encoding="UTF-8"?><song><title>Gunohlarimni kechir Q82</title>
<aka>Xudo bandangman men</aka>
<lyrics>[V1]
.   Gm            Eb
 // Gunohlarimni kechir,
.Cm            Gm
 Gunohlarimni koʻtar. //
.   Cm                 Bb
 // Ey Xudo bandangman men,
.Eb            D    Gm
 Ey Xudo qavmingman men. //

[C1]
.  Cm             Bb
   Gunohlarimni kechir,
.  Eb       D      Gm
   Gunohlarimni koʻtar.

[V2]
.   Cm                     Bb
 // Yurak kasal, qalbim nogiron,
.Cm     F      Bb
 Orom bergil intizordirman. //
.   Cm                       Bb
 // Shifobaxsh Ruh hamrohim boʻlsin,
.Eb           D            Gm
 Endi bu qalb shodlikka toʻlsin. //

[C2]
.  Cm       F     Bb
   Gunohlarimni kechir,
.  Eb       D      Gm
   Gunohlarimni koʻtar.

[V3]
.   Gm
 // Izladim koʻp bormisan Oʻzing?
.Cm            F        Bb
 Izladim koʻp gapirgil soʻzing //
.   Cm                      Bb
 // Endi bildim bordirsan Oʻzing,
.Eb          D          Gm
 Endi bildim gapirding soʻzing. //

[C3]
.     Cm       F    Bb
   // Gunohlarimni kechir,
.  Eb      D     Gm
   gunohlarimni koʻtar. //
.     Bb      D     Gm
   // Gunohlarimni koʻtar. //</lyrics>
<key>Gm</key>
<hymn_number>82</hymn_number>
</song>