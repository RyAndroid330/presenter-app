<?xml version="1.0" encoding="UTF-8"?><song><title>Yoʻlda janjallashmanglar Q209</title>
<lyrics>[V1]
 Yoʻlda janjallashmanglar ey aziz doʻstlar,
 Bu yoʻl oq rangdur qaro qilmangiz.
 Yoʻlda janjallashmanglar ey katta kichik,
 Yoʻl yaqin narsadur yiroq qilmangiz.

[V2]
 // Parvardigor Oʻzi harohim boʻlsin,
 Hamrohim senga kuch quvvatin bersin. //
 // Osondir toshloqli yoʻllardan bormoq,
 Solmagin sen yomon yoʻllarga oyoq. //

[V3]
 // Akamdir, Ukamdir yoʻlda Hamrohim,
 Suvimdir,Nonimdur yoʻlda Hamrohim. //
 // Ey Xudo bandangni Oʻzing asragin,
 Tunim ham yorugʻdur, bordir ishonchim. //</lyrics>
<hymn_number>209</hymn_number>
</song>