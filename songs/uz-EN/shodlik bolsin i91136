<?xml version="1.0" encoding="UTF-8"?><song><title>Shodlik Boʻlsin</title>
<key>Em</key>
<lyrics>[V1]
.Em          Am  D       G
 Shodlik boʻlsin gʻamdan koʻra
.Em        Am   D       G
 Sevgi boʻlsin xasaddan koʻra
.   C         G    Am        Em
 // Botir boʻlgin qoʻrquvdan kechib
.Em       Am    D         Em       H
 Sogʻman degin xastalikni engib //

[C1]
.     Em            Am   D            G
   // Ey jonim nega sen tushkunlikdadirsan
.  Em         Am   D              G
   Nega bexalovat boʻlib qaygʻurasan
.  Em           Am    D          G
   Xudoga umid bogʻla Unga umid bogʻlagin
.  Em         Am         H   Em
   U Najotkor U xaloskor Egamiz //</lyrics>
<hymn_number>23008</hymn_number>
<author>Sobir Umurov</author>
</song>