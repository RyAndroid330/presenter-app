<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm           Gm   Dm
 // Inson qalbi poralidur,
.Gm     Bb      Gm    Dm
 Sensiz yashay bilmam Iso,
.Dm            Gm  Dm
 Bu hayotim azobdadir,
.Gm     Bb      Gm    Dm
 Sensiz yashay bilmam Iso. //
.   Dm Gm    Dm      Gm
 // Ey yora, yoʻqdir chora,
.Gm     Bb     Gm     A
 Sensiz yashay bilmam Iso, //

[C1]
.  D            Gm   D
   Moʻjizalar yaratganga,
.  Gm             Bb  A
   Shukur ayting Masihga.
.  D          Gm  D
   Muqaddas jamoatida
.  Gm         Bb    A
   Topajaksiz Xushxabar.
.     Dm Gm     Dm     Gm
   // Ey yora, yoʻqdir chora,
.  Gm       Bb    Gm    A
   Sensiz yashay bilmam Iso. //

[V2]
 // Inson qalbi nurni koʻrdi,
 Sensiz yashay bilmam Iso,
 Bu nuringni Senda koʻrdi,
 Sensiz yashay bilmam Iso. //
 // Ey yora, yoʻqdir chora,
 Sensiz yashay bilmam Iso. //</lyrics>
<key>Dm</key>
<title>Inson qalbi Q117</title>
<hymn_number>117</hymn_number>
</song>