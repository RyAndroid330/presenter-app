<?xml version="1.0" encoding="UTF-8"?><song><aka>Ravshan boʻlar yoʻlimiz</aka>
<lyrics>[V1]
.Am                       C
 Biz tetik boramiz, hayot yoʻlidan,
.Dm
 Rabbimiz Isoga ishonsak.
.Am                     C
 Xudo kuchini biz ishda topamiz,
.   D(F)      E       Am
 // Rabbimiz Isoga ishonsak. //

[C1]
.  Am
   Ravshan boʻlar yoʻlimiz,
.  Dm            Am
   Doim xursand boʻlamiz.
.  Dm
   Dushmanlardan qoʻrqmaymiz,
.     F        (E)    G(Am)
   // Rabbimiz Isoga ishonsak. //

[V2]
 Xudo vaʼdalari yorqin boʻladi,
 Rabbimiz Isoga ishonsak.
 Marhamati yurakni toʻldiradi,
 // Rabbimiz Isoga ishonsak. //

[V3]
 Uning istagiga koʻra ishlaymiz,
 Rabbimiz Isoga ishonsak.
 Koʻzlarimizni koʻkka koʻtaramiz,
 // Rabbimiz Isoga ishonsak. //</lyrics>
<key>Am</key>
<title>Biz tetik boramiz Q18</title>
<hymn_number>18</hymn_number>
</song>