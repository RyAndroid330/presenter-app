<?xml version="1.0" encoding="UTF-8"?><song><title>Xudo xammasini biladi</title>
<lyrics>[V1]
.Am
 Xudo bilar xamma ishimni.
.A7          Dm
 Xatto bilar oʻy-xayolimni,
.   Dm           Am
 // Xoxish, istak, oxu nolamni,
.E          Am
 Xudo bilar butun borimni. //

[V2]
 Yolgʻiz ibodat qilganimda,
 U xamisha yonimda boʻlar.
 // Koʻcha-koʻyda,ishda yursam xam.
 Kunlarimning barchasin bilar. //

[C1]
.  C             G
   Yurakdagi gʻam va shodlikni.
.  Dm             Am
   Xursandchilik, qaygʻularimni.
.  C           G
   Xudo xammasini biladi,
.  E            Am
   U yonimda bular xamisha.

[V3]
 Zulmatda xam bizni koʻradi.
 Xatto quyuq tumanlarda xam.
 // Achchiq qaygʻu,xafa boʻlganda,
 Ikkilanib yurganimda xam. //

[V4]
 Qanday yaxshi xamma-xammasin,
 Eshitguvchi va bilguvchi bor.
 // Doʻzaxdan qutqarib olamda,
 Abadiy xayot berguvchi bor. //</lyrics>
<key>Am</key>
<author>TIMUTIY</author>
</song>