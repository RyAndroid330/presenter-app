<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>111</hymn_number>
<aka>Najot</aka>
<key>G</key>
<lyrics>[V1]
.   Am
 // Tanga orom berding,
.C           D    G
 Dilga ilhom berding. //
.   G
 // Osmonlarda nur boʻlib,
.C                Am
 Sen menga najot berding
.C           D    G
 Sen menga najot berding. //

[V2]
 // Olgan eding qalbimni,
 Koʻrgan eding oʻzimni. //
 // Jannatinga yoʻl berib,
 Tutqazding kalomingni
 Tutqazding kalomingni. //

[V3]
 // Bilmas edim Oʻzingni,
 Koʻrmas edim nuringni. //
 // Necha yillar adashib,
 Topdim endi Oʻzingni
 Topdim endi Oʻzingni. //</lyrics>
<title>Tanga orom Q111</title>
</song>