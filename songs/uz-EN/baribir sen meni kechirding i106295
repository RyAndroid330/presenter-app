<?xml version="1.0" encoding="UTF-8"?><song><author>Timoʻtiy</author>
<lyrics>[V1]
 // Nega endi Rabbim boshqasan
 Noloyiqman Sevginga Sening.
 Gunoh botqogʻiga botsam ham,
 Baribir Sen meni kechirding. //

[C1]
   // Nega meni Rabbim kechirding?
   Oʻtmish ishlarini oʻchirding.
   Sevgingga loyiq boʻlmasam ham,
   Baribir Sen meni kechirding. //

[V2]
 // Boʻxton, yolgʻon tilim soʻzlaydi.
 Yuragimni nafrat qoʻzgʻaydi.
 Jirkansam ham hatto oʻzimdan,
 Baribir Sen meni kechirding / //</lyrics>
<title>Baribir Sen meni kechirding</title>
</song>