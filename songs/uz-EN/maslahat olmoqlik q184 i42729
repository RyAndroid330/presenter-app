<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>184</hymn_number>
<key>Gm</key>
<lyrics>[V1]
.Gm                     Dm
 Maslahat olmoqlik endi kech dema,
.F                  Gm
 Kel vijdon amriga boʻysungin odam.
.   Bb              Cm
 // Eshiging ortida qalbida kalom,
.      Eb                F          D(Gm)
 Bosh egar taʼzimdadir, bitta buyuk Zot. //

[C1]
.    Cm                Dm      Gm
   Ezilgan qoʻllarga xushnavo Egam,
.     Cm              Eb     D
   Bu ertak emas, bu afsona dema.
.           Cm          Dm           Eb
   // Dunyo gʻaflatidan kecha olsang bas,
.     F            Dm           Gm
   U hakam, qalbingning shirin tuhfasi. //

[V2]
 U Rabbiy hayotning shirin bulogʻi,
 Biz uchun Xudodan tushirilgan Zot.
 // Unga xos sevinchla taʼzim aylagin,
 Oxirat azobida saqlaydi seni. //

[C2]
   Shoshilgin kel biroq kech dema faqat,
   U imon U Rabbiy Masih atalgan.
   // Azobli qilkoʻprik sir sirotidan,
   Shu yerning yuzida oʻtarsan omon. //</lyrics>
<title>Maslahat olmoqlik Q184</title>
</song>