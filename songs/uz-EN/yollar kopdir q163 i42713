<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.     C                F
   // Yoʻllar koʻpdir, yoʻllar koʻpdir,
.  F                          C
   Hayot sari eltuvchi yoʻl yagona. //
.  F                        C
   Hayot sari eltuvchi yoʻl yagona, yagona
.     G                        C
   // Hayot sari eltuvchi yoʻl yagona //

[V1]
.   C                 F           C
 // Men yoʻl, haqiqat va hayotdirman. //
.   C
 // Mensiz Otaning oldiga hech kim borolmas. //

[C2]
   // Yoʻllar koʻpdir, yoʻllar koʻpdir,
   Hayot sari eltuvchi yoʻl yagona. //
   Hayot sari eltuvchi yoʻl yagona, yagona
   // Hayot sari eltuvchi yoʻl yagona //

[V2]
.C            F           C
 Men tirilish va hayotdirman,
.C               G                C
 Menga ishongan odam abadiy yashaydi
.G            C
 abadiy yashaydi.
.C        F        C
 Men olamning nuriman,
.C             G               C
 Menga kelgan odam nurda yashaydi
.G            C
 nurda yashaydi.

[C3]
   // Yoʻllar koʻpdir, yoʻllar koʻpdir,
   Hayot sari eltuvchi yoʻl yagona. //
   Hayot sari eltuvchi yoʻl yagona, yagona
   // Hayot sari eltuvchi yoʻl yagona //

[V3]
 Men hayot noniman,
 Menga kelgan odam
 Sira och qolmas,sira chanqamas.
 Men Ibtido va Intiho,
 // Avvalu oxiri, Boshi va soʻnggidirman. //</lyrics>
<key>C</key>
<title>Yoʻllar koʻpdir Q163</title>
