<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.D        G     A
 Qabul qilding buyuk Sening sevging,
.D         G      A
 Kechirildim, Sen mihlanding.
.D         G            A
 Men yasharman endi Sen bilan tinchlikda,
.G          A          D
 Oʻlib men uchun va tirilding.

[C1]
.  D            G
   Iso Sening sevging ajoyib,
.  D               A
   Hayoting bizga berding.
.  D          G
   Hayotim muqaddas qilding,
.  D                 A
   Muqaddas Ruhing berding.
.            G              D
   // Bor qoʻshigʻim Senga Rabbim. //
.     D         G D
   // Iso Sen SHohimsan. //</lyrics>
<title>Qabul Qilding ҲСХМ105</title>
