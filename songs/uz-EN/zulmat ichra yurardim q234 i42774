<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>234</hymn_number>
<title>Zulmat ichra yurardim Q234</title>
<key>Am</key>
<lyrics>[V1]
.   Am                     Dm
 // Zulmat ichra yurardim, borar yoʻlim bilmasdan,
.E                           Am
 Sen men uchun yoʻl boʻlding Rabbim.
.Am                        Dm
 Haqiqat izlab noxaqlikdan oʻtdi umrim boʻlib zavol,
.E                          Am
 Men uchun Haq boʻlding Sen Rabbim. //

[C1]
.     F          G        Am          C
   // Qutqarding Sen meni ming azoblardan,
.  F          G        Am         C
   Qutqarding Sen meni ming oʻlimlardan.
.  F         G         Am          C
   Minnatdorman Sendan oʻz umrim bilan,
.  F        G        C
   Minnatdorman men Sendan. //</lyrics>
</song>