<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Masih Podshohimiz Q149</title>
<lyrics>[C1]
.     C                      F             C
   // Iso Masih podshohimiz, Iso Masih qudratimiz.
.  C              E        Am       Dm   C
   Iso Masih shuhratimiz, qurbonligimiz omin. //

[V1]
.   C                            Dm                  G
 // Osmonda yozilgan ismlarimiz, Parvardigorga tashakkur.
.G                  Dm   Am                  C
 Quvonamiz ruhimiz toza, Parvardigorga tashakkur. //

[C2]
.     C                        F                      C
   // Iso Masihning muhabbati, Iso Masihning kuch-quvvati,
.  C                   E   Am      Dm    C
   Iso Masih Muqaddas Ruhi yuragimizda omin. //

[V2]
.   C                             Dm                 G
 // Osmonda mukofotimiz buyukdir, Parvardigorga tashakkur.
.G                    Dm    Am                  C
 Sevinamiz, ruhimiz baland, Parvardigorga tashakkur. //

[C3]
.     C                        F                  C
   // Iso Masihdan yorugʻlik, Iso Masihdan gʻamxoʻrlik,
.  C                 E     Am      Dm   C
   Iso Masihdan haqiqatlik hayotimizda omin. //

[V3]
.   C                                Dm              G
 // Osmondan tinchligimizni yuborgan, Parvardigorga tashakkur.
.G                    Dm     Am                  C
 Berilgan Sening Oʻgʻlingga, Parvardigorga tashakkur. //

[C4]
.     C                     F               C
   // Iso Masih podshohimiz, Iso Masih qudratimiz.
.  C                E     Am        Dm   C
   Iso Masih shuhratimiz, qurbonligimiz omin. //</lyrics>
<key>C</key>
<hymn_number>149</hymn_number>
</song>