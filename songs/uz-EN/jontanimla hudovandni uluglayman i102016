<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>46</hymn_number>
<key>E</key>
<lyrics>[V1]
.E            D          C        B7
 Jon-tanim-la Hudovandni ulugʻlayman
.E        D           C                 B7
 Xaloskor Tangrim ila koʻnglim shod-xurram

[C1]
.  E                         A            E
   Qodir Tangri rahm-shafqat koʻrsatdi menga
.  E          B7       E
   Uning ismi muqaddasdir
.  E                  A          E
   Uning marhamatlari nasib boʻlgay
.  E              B7       E
   Undan qoʻrqqan ajdodlarga

[V2]
.E         D            C            B7
 Kuchini U koʻrsatdi-da qoʻlidan keladi
.E           D          C             B7
 Manmanlarni oʻz hayoli toʻzday toʻzitdi

[C2]
.  E                     A        E
   Taxtlaridan tushirdi hukmdorlarni
.  E           B7          E
   Balandga koʻtardi moʻminni
.  E                           A        E
   Ochlarni toʻygʻizib baxt-saodatli qildi
.  E           B7          E
   Quppa-quruq joʻnatdi boyni

[V3]
.E        D           C            B7
 Ota-bobomizga bergan vaʼdasi boʻyicha
.E         D           C         B7
 Ibrohimga hamda uning zurriyotiga

[C3]
.     E                      A        E
   // Shafqat qilishni yodda tutib mangu
.  E           B7          E
   Oʻz halqiga himmat ayladi //  Omin.</lyrics>
<title>Jontanimla Hudovandni ulugʻlayman</title>
</song>