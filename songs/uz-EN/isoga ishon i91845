<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<hymn_number>23007</hymn_number>
<key>Em</key>
<lyrics>[V1]
.Em            C
 Isoga ishon imonli boʻlgin
.D          Am
 Uni unutma soʻzlaridan chiqma
.Em                  C
 Isodan yuz oʻgirma seni himoya qilar
.D               Am
 Uni sevgin sen, seni asraydi

[V2]
.Em             C
 Xudoni hurmat qilgin
.D            Am
 Seni koʻkka koʻtaradi
.Em             C
 Isoni kuchgin sen
.D                   Am
 Seni shon-shuhratga erishtiradi</lyrics>
<aka>Isoni Sev.</aka>
<title>Isoga ishon</title>
</song>