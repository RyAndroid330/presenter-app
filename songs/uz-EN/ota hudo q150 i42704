<?xml version="1.0" encoding="UTF-8"?><song><title>Ota Hudo Q150</title>
<aka>Nazar Soldi</aka>
<lyrics>[V1]
 // Ota Xudo nazar soldi qalbimizga,
 Gunohlarni bering doʻstlar Rabbimizga. //
 // Muqaddas Ruh shifo bersin dardimizga, //
 // Birodarlar, shukr qiling Rabbimizga. //

[V2]
 // Iso Masih kelib koʻku falaklardan,
 Gunohlarni olib ketdi yuraklardan. //
 Xudo ogoh yaxshi yomon tilaklardan,
 Qoʻrqing bugun gunohkorlar gunohlardan.
 Xudo ogoh yaxshi yomon tilaklardan,
 Qoʻrqing bugun masihiylar gunohlardan.

[V3]
 // Masihiylar gunohlardan boʻldi ozod,
 Masih bilan yeru koʻk ham boʻlsa ozod. //
 // Muqaddas qon bilan bugun masihiylar shod,
 Sevgi bilan jamoat ham boʻlar obod. //

[V4]
 // Ota Xudo nazar soldi qalbimizga,
 Gunohlarni bering doʻstlar Rabbimizga. //
 // Muqaddas Ruh shifo bersin dardimizga, //
 // Birodarlar, shukr qiling Rabbimizga. //</lyrics>
<hymn_number>150</hymn_number>
</song>