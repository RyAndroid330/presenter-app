<?xml version="1.0" encoding="UTF-8"?><song><title>Hamisha Qalbimda</title>
<lyrics>[V1]
.Em       Am       Dm           Em
 Hamisha qalbimda nurdek porlab tur
.Em            Am     D        Em
 Qayda boʻlsam doimo Sen men bilan yur
.Em             Am          D     Em
 Tashlab ketma hech qachon Rabbim Sen meni
.Em            Am         Dm    Em
 Marhamatla tunu kun oʻylayin Seni

[C1]
.  Em          Am        D      G Am
   Ketma-ketma ketmagin, qolgin qalbimda
.  Em         Dm               Em
   Ming bora inoyat (marhamat) qilib

[V2]
 Hayot zavqli doimo men bilan boʻlsang
 Ketar gʻamlar yurakdan Sen boqib tursang
 Yurakda imon tinchlik Sen boring uchun
 Maqtayman doim Seni borliging uchun</lyrics>
<key>Em</key>
</song>