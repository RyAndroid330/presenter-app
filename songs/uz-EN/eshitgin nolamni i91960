<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em                   C
 Chodiringni to abad maskan qilay
.D                        Am
 Qanotlaringni soyasida panoh topay
.Em                    C
 Senga har doim hamdu-sano kuylay
.D                       Am
 Bergan ontimni har kuni ado etay

[C1]
.  Em        C         D      Am
   Eshitgin, Ey Xudo, oxu nolamni
.  Em         C        D       Am
   Tinglagin, Ey Xudo, mening ibodatimni

[V2]
.Em                  C
 Yerning u chetidan Senga yolvoraman
.D                     Am
 Yuragim qon boʻlganda Seni chaqiraman
.Em                    C
 Etib boʻlmas baland qoyaga meni olib chiqqin
.D                     Am
 Sen mening panohim boʻlgandirsan Iso

[B1]
.  C              D         Am        Em
   Sevging sadoqating doimo yuragimda boʻlsin</lyrics>
<title>Eshitgin Nolamni</title>
<author>Sobir Umurov</author>
<hymn_number>23308</hymn_number>
</song>