<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[C1]
.  Em  Am   G      D   Em   Am     G D
    Menda yasha Rabbim Iso, hayotimsan,
.  Em Am     G          D        Em      Am    G D
    Faqat Senga oʻxshashni xohlayman, faqat Senga.

[V1]
.G       D            C         G
  Har kuni men Sen bilan yashayman,
.       D       C
 Sen yaqin doʻstim.
.G    D           C        G
 Ishonaman men Senga har doim,
.        D      C
 Koʻrsatgin yoʻlim.
.Am            Em             C         G
 Balki Seni koʻp ranjitarman men yo Rabbim,
.Am        Em             C             D
 Lekin bilaman doim koʻtarar Sening sevging.</lyrics>
<title>Menda yasha Rabbim Iso</title>
</song>