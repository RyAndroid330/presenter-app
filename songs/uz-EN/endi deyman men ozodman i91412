<?xml version="1.0" encoding="UTF-8"?><song><title>Endi Deyman Men Ozodman</title>
<lyrics>[V1]
 // Hayotimga kelding
 gunohlarim yuvding
 Meni qalbimni yoritding sen
 jonimga Rux berding //

[C1]
   // Endi deyman men ozodman
   Endi deyman men koʻrarman
   Endi deyman eshitarman
   Yangi hayotdaman //

[V2]
 // Xaloskorim mening
 aziz Iso Rabbim
 Yangi hayot bagʻishlading sen
 jonimga Rux berding //</lyrics>
</song>