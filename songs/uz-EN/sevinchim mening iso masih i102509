<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>167</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.   Dm     Gm          A    Dm
 // Sevinchim mening, Iso Masih
.Dm   Gm           A    Dm
 Sevgilim mening, Iso Masih //

[V2]
.Dm
 Osmondagi Otamiz!
.Gm                   Dm   A
 Isming muqaddas boʻlsin! Omin
.Dm
 Podshohliging ham kelsin!
.   Gm
 Irodang yerda ham
.      C             F    A
 Osmondagi kabi boʻlsin! Omin
.Gm    C  F      Bb
 Kundalik nonimizni
.Gm         A       Dm   D
 Bizlarga berib turgin! Omin
.Gm         C  F      Bb
 Qarzlarimizni kechirgin
.Gm           A      Dm   A
 Makkordan xalos qilgin! Omin

[C1]
.     Dm     Gm            A        Dm
   // Chunki Podsholik, qudrat, shuhrat
.         Gm         A Dm
   Abadiy Senikidir! Omin //

[V3]
 Sevinchimiz, Iso Masih!
 Isming muqaddas boʻlsin! Omin
 Podshohliging ham kelsin!
 Irodang Oʻzbekistonda ham boʻlsin! Omin

[V4]
 Kundalik nonimizni
 Bizlarga berib turgin! Omin
 Qarzlarimizni kechirgin
 Makkordan xalos qilgin! Omin

[C2]
   // Chunki Podsholik, qudrat, shuhrat
   Abadiy Senikidir! Omin //
   Sevinchim mening, Iso Masih
   // Sevgilim mening, Iso Masih //</lyrics>
<title>Sevinchim mening, Iso Masih</title>
</song>