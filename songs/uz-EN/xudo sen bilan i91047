<key>Em</key>
<lyrics>[V1]
.Em               Am
 Egamiz mehribon odildir
.D         G
 Xudoyimiz rahimdildir
.C             Am
 Egamiz sodda insonlarni
.   H
 // Himoya qilar //

[C1]
.  Em          Am
   Xaf-xatarda qolganingda
.      D        G
   /// Xudo sen bilan ///
.  C          Am
   Xudo bilan boʻlganingda
.      H
   /// Joning xotirjam ///

[V2]
.Em             Am
 Egam jonimni oʻlimdan qutqarar
.D             G
 Qoʻzlarimni yosh toʻkishdan
.C           Am
 Oyoqlarimni qoqilishdan
.   H
 // Egam qutqarar //</lyrics>
<title>Xudo Sen Bilan</title>
</song>