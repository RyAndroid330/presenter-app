<?xml version="1.0" encoding="UTF-8"?><song><title>Qol, yuragim</title>
<lyrics>[V1]
.  Bm
 Olis yoʻl bosib boʻlmas
.   C
 Yelkangda xoch, oʻylaysan meni
.            C                  Em
 Manzil tomon borarsan Rabbim men uchun

[V2]
.  Bm
 Qanchalar ogʻriqli, tikanli
.  C
 Boshingdagi Sening tojing
.         C                   Em
 Sen Shohimsan azobni yenggan Rabbim

[P1]
.   Em                         C
   Qolgin qalbimga menga berib najoting
.  Em
   Sevarman Seni
.  C
   Men ham oʻtarman
.  Em                 C
   Bu sharafli yoʻlingni

[P2]
   Sevgi izhorim Senga tinmay aytarman Rabbim
   Muqaddassan Oʻzing
   Najotkorim Oʻzing
   Qalbim Seniki

[C1]
   Qol, yuragim ochiq Sen uchun
   Sen uchun Rabbim ihtiyorim doim Senda boʻlsin Xudo

[C2]
   Qol, yuragim ochay Senga
   Men sharaf bilan
   Muqaddasim Sen
   Borligʻim ham Sen Rabbim

[V3]
 Xochda turib sevgi izhoring
 Aylading Sen men uchun
 Naqadar buyuk
 Sen bergan qurbonlik

[V4]
 Kim teng kelar Senga Rabbim
 Kim teng kelar Senga Rabbim
 Ulugʻlayman Seni
 Jonim fido boʻlsin Senga

[C3]
   Qol, yuragim ochay Senga
   Sen maskan qilgin
   Mening qalbim doim
   Sen uchun ochiq Rabbim

[C4]
   Qol, Sen uchun ochay qalb, yuragim va ruhim
   Muhtojman Senga
   Sening najotingga Rabbim

[V5]
 Olis yoʻl
 Kim ham oʻtar undan
 Qonli yoʻl, sharafli yoʻl
 Najotli yoʻl
 Sen bosib oʻtding men uchun

[C5]
   Qol, yuragim ochay Sen uchun
   Mening Najotkorim, Rabbim Oʻzing
   Rabbim Sen Oʻzing Iso

[C6]
   Qol, yuragimga to abad Seni
   Sevib oʻtarman
   Sen uchun men yashayman endi Rabbim

[V6]
 Sen oʻlding men uchun xochda
 Joning berding sharafli bu yoʻlda
 Toʻllvni toʻlab, shaytondan sotib olding meni

[V7]
 Men uchun xochda azob chekding
 Yaralarim Senda shiqo topdi
 Ozodman endi,
 Noming ila solihman

[C7]
   Qol, Rabbim yonimga endi
   Yashayman Sen uchun
   Yuragimga maskan qilgin Oʻzing

[C8]
   Qol, Rabbim yuragim ochay
   Doim Sen uchun maskan qilgin qalb yuragim Sen uchun fido boʻlsin</lyrics>
<key>Bm</key>
<aka>Olis yoʻl bosib boʻlmas</aka>
<author>Ulugʻbek Joʻrayev</author>
</song>