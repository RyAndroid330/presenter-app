<?xml version="1.0" encoding="UTF-8"?><song><title>Keldi Rabbim</title>
<lyrics>[V1]
 Keldi Rabbim mening qalbimga
 Bir bor kirib mehmon boʻlay deb
 Buncha zulmat buncha qorongʻu
 Yuraginga nurim beray deb
 Kelgin Rabbim oʻzgartir meni
 Zulmat ichra qolgan qalbimni
 Shunda dedi:men barxayot Xudo
 Boqiylik va hayot yechimi

[C1]
   // Kechirimga toʻla qalbingda
   Men uchun ham ajratgin makon
   Marhamatla meni yuragim
   Bir umr seni koʻylab oʻtayin //

[B1]
   // Hamdu sano, Hamdu sano
   Hamdu sano aytamiz senga //</lyrics>
<author>Ulugʻbek Joʻrayev</author>
</song>