<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23136</hymn_number>
<author>Sobir Umurov</author>
<key>Em</key>
<lyrics>[V1]
.Em      D      C
 Men yerning tuziman
.Am     D      Em
 Men dunyoning nuriman

[C1]
.  Em          D
   Soʻzlarim tamli
.  C           D      Em
   Yurishim nurli mening

[V2]
.Em      D        C
 Siz yerning tuzisiz
.Am     D        Em
 Siz dunyoning nurisiz

[C2]
.  Em         D
   Soʻzlaris tamli
.  Am          D        Em
   Yurishisiz nurli boʻlsin

[V3]
.Em       D      Em
 Biz yerning tuzimiz
.Am    D       Em
 Biz dunyoning nurimiz

[C3]
.  Em        D
   Soʻzlaris tamli
.  Am          D        Em
   Yurishisiz nurli boʻlsin</lyrics>
<title>Men Yerning Tuziman</title>
</song>