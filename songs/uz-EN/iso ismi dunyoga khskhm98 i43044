<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>98</hymn_number>
<title>Iso Ismi Dunyoga ҲСХМ98</title>
<key>D</key>
<lyrics>[V1]
.D        G    D
 Iso ismi dunyoga,
.G    D       A
 dunyoga tarqalmoqda,
.D            G    D
 Yoʻqolganlar Iso Nomin
.G       D             A
 bu Nom eshitib qaytib kelar.

[C1]
.   G        A      F#m  Bm
   Iso shod boʻlib kuylaydi,
.        G        A            D
   Yoʻqolganlar qaytib kelishi bilan.
.   G        A      F#m     Bm
   Iso shod boʻlib raqsga tushadi,
.     G          A              D
   Yoʻqolganlar qaytib kelishi bilan.

[V2]
 Iso ismi dunyoga
 ovoza qilinmoqda,
 Xudoning Shohligi xalqlardan
 xalqlarga kelmoqda.

[C2]
   // Xudo shod boʻlib kuylaydi,
   Hamma xalqlar qaytib kelishi bilan. //</lyrics>
</song>