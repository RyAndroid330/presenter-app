<?xml version="1.0" encoding="UTF-8"?><song><title>Najotkorim yolgʻiz Sen</title>
<key>Am</key>
<lyrics>[V1]
.Am                 Dm
 Najotkorim yolgʻiz Sen, Iso
.G                    C
 Sirdoshim ham Oʻzingsan, Iso
.Am                 G
 Yolgʻiz Senga aytaman dardim
.   F           E
 Senga aytay yurak dardim
.Am              Dm
 Sen Oʻzing meni tanlading
.G                C
 Abadiy hayot menga berding
.Dm
 Hatto Oʻzingni ham*
.F
 Ayamading bizlardan
.D                       E
 Mana bu haqiqiy muhabbatdir -x2

[C1]
.  Am          F
   Otajon, Sen ulugʻsan
.    Dm            E
   Seni maqtashga soʻz yetmas
.  Am          F     G
   Otajon, Sen yagona
.                E
   Bizning qalbimizdasan -x2
.               E         Am
   Bizning qalbimizdasan, Ota
   *yoki Hatto Oʻz joningni ham.</lyrics>
