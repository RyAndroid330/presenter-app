<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>70</hymn_number>
<title>Senga Hamdu Sano Kuylayman ҲСХМ70</title>
<lyrics>[V1]
.   G                C      D
 // Senga hamdu sano kuylayman,
.           G      Em
 Senga kuylayman Rabbim.
.       C
 Chunki Sen buyuk
.     D       G    C    G
 ulugʻlansin noming. //

[V2]
 // Nomingni ulugʻlayman, Rabbim
 Ulugʻlayman Rabbim
 Chunki Sen buyuk ulugʻlansin Noming //

[C1]
.     G            C
   // Ajoyibsan Xudoyim,
.  D               G
   Sen goʻzalsan Xudoyim,
.  Em          C
   Ajoyibsan Xudoyim,
.  D               G   C    G
   Hamdu sano kuylayman. //

[V3]
.    G          C
 // Isoning buyukligi,
.D            G
 tugamasdir chiroyi,
.Em            C
 Qalbimizning tubida
.D              G   C G
 yulduz kabi porlaydi. //</lyrics>
<key>G</key>
</song>