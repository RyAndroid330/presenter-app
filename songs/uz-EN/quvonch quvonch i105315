<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>42226</hymn_number>
<title>Quvonch, quvonch</title>
<lyrics>[C1]
   Quvonch, quvonch doim quvonch
   Tinmay xursand boʻlaylik
   Xudo bergan sevinch nuri
   Qalbimizda soʻnmasin

[V1]
 Xudo bizni boshqaradi
 Bizga yordam beradi
 Musibatdan qutqaradi
 Bizga quloq soladi

[V2]
 Masix izidan boraylik
 Unga yaqin boʻlaylik
 Ogʻir mushkulot ostida
 Nobud boʻlib ketmaylik

[V3]
 Xayotbaxsh imon quvonchi
 Quyoshday porlab tursin
 Xudo bizlarni sevadi
 Dillar xotirjam boʻlsin</lyrics>
</song>