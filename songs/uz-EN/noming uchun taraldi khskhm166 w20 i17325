<?xml version="1.0" encoding="UTF-8"?><song><title>Noming Uchun Taraldi ҲСХМ166 W20</title>
<aka>Biz vaqtincha</aka>
<lyrics>[V1]
.C#     G#      Ebm      Bbm
 Biz vaqtincha, Sen abadiysan
.F#  C#   B     G#
 Asrlar va azal Xudosi
.C#     G#   Ebm        Bbm
 Bizlar omonat, Sen doim borsan
.F#      C#   G#
 Tugallanmas sevgi Egasi

[C1]
.  Bbm    F#   C#       G#
   Muqaddassan Qudratli Egam
.  Bbm   F#  C#        G#
   Qurbonlik Qoʻzisi loyiqsan
.  Bbm   F#      C#       G#
   Oliy maqtov, hurmat va sharaf
.     Ebm    Bbm    G#
   // Noming uchun taraldi! //

[V2]
 Bizlar bemor, Sen shifokorsan
 Iso Qudratli Xaloskorsan
 Biz kuylaymiz sevgi qoʻshigʻin
 Noming ulugʻlansin Sen borsan.</lyrics>
