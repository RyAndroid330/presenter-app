<?xml version="1.0" encoding="UTF-8"?><song><title>Tinchlikni senga beraman (anʼanaviy) Q232</title>
<lyrics>[V1]
 Tinchlikni senga beraman,
 Dunyoda yoʻq boʻlgan tinchlikni.
 Tinchlikni, tinchlikni, tinchlikni senga beraman,
 Dunyo senga bera olmagan.

[V2]
 Umidni senga beraman,
 Dunyoda yoʻq boʻlgan umidni,
 Umidni, umidni, umidni senga beraman,
 Dunyo senga bera olmagan.

[V3]
 Sevgini senga beraman,
 Dunyoda yoʻq boʻlgan sevgini,
 Sevgini, sevgini, sevgini senga beraman,
 Dunyo senga bera olmagan.

[V4]
 Najotni senga beraman,
 Dunyoda yoʻq boʻlgan najotni,
 Najotni, najotni, najotni senga beraman,
 Dunyo senga bera olmagan.

[V5]
 Farzandim moylayman seni,
 Dunyoda yoʻq xushboʻy moy bilan
 Moylayman, moylayman, moylayman seni moylayman
 Dunyoda yoʻq xushboʻy moy bilan
 Umidni, najotni, sevgini senga beraman,
 Dunyo senga bera olmagan.</lyrics>
<hymn_number>232</hymn_number>
</song>