<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G                           Am
 Birgina Isoda baxtiyor boʻldim
.            D             G
 Birgina Isoda jonga dam oldim
.                    G7           C
 U Doʻstimga men dil sirlarin ochdim
.           G              D  G
 Eng yaxshi Doʻstimni Unda topdim

[C1]
.  Am
   Qanday baxtiyorman Doʻst boʻlib Unga
.                   D               G
   Soʻzlab berolmaydi tilim hech kimga
.                G7        C
   Birgina dilim Unda quvonadi
.             G           D      G
   Bu Doʻstim bilan xatar boʻlmaydi

[V2]
 Bu Doʻstim bilan sevgida yashayman
 U meni xalos qildi gunohlardan
 Muhabbatini isbot etdi xochda
 Eng yaxshi Doʻstimni topdim Unda

[V3]
 Doʻstlik ittifoqin men bilan tuzgan
 Yoshligimdan yetaklar qoʻli bilan
 Baxt oʻlkasiga U meni olib borar
 Abadiy jonim Unda quvonar</lyrics>
<title>Birgina Isoda baxtiyor boʻldim</title>
</song>