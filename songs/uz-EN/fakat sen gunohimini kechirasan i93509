<?xml version="1.0" encoding="UTF-8"?><song><title>Fakat Sen gunohimini kechirasan</title>
<lyrics>[V1]
 Faqat Sen gunohimini kechirasan
 Faqat Sen xastaligimga davosan
 Faqat Sen yuragimga yaqinsan
 Faqat Sen hayotimning Egasisan

[P1]
   // Ulugʻlarning ulugʻi Sen Rabbim
   Buyuklarning buyugi Sen //

[C1]
   // Sen Shohim, qudratim
   Yolgʻiz sendan umidim
   Najot ber, hayot bergin bizga //

[V2]
 Faqat Sen xaqiqatni soʻzlaysan
 Faqat Sen hamma amrni oʻrgatasan
 Faqat Sen hayot suvi berasan
 Faqat Sen barchani qutqarasan

[P2]
   // Ulugʻlarning ulugʻi Sen Rabbim
   Buyuklarning buyugi Sen //

[C2]
   // Sen Shohim, qudratim
   Yolgʻiz sendan umidim
   Najot ber, hayot bergin bizga //
   Iso Iso Iso</lyrics>
<author>Sobir Umurov</author>
</song>