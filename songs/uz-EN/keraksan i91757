<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Keraksan</title>
<lyrics>[V1]
 // Erta tongdan seni uchratmoqchiman
 Jamoling nurini men koʻrmoqchiman
 Bu dunyo tashvishlarini unutmoqchiman
 Seni panohingda yashashni istayman //

[C1]
   // O Sen keraksan menga Rabbim
   O sensiz yasholmayman Tangrim //
   // Shuning uchun boʻlgin Rabbim yaqin
   Hayotimda boʻlgin sen panohim //

[V2]
 // Qayerga boraman axir sen haqiqat yoʻlsan
 Sensiz hayotimni taʼsavvur qilolmayman
 Chunki sendan kelar najot men tomon
 Sen bilan yuragim shodlikka toʻlar hamon //</lyrics>
</song>