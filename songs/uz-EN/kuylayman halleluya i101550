<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.   C                         F
 Kuylayman halleluya, dushmanlar huzurida
.   Am                G
 Kuylayman halleluya, shubhalarim parchalab
.   C                     F
 Kuylayman halleluya, chunki bu mening kuchim
.   Am                G
 Kuylayman halleluya, osmon men chun kurashar

[C1]
.  F               C
   Men kuylayman, boʻronlar ichra
.  Am                   G
   Baland ovozda, sanolarim aytib Senga
.  F              C
   Tuproqlar uzra umidim porlar
.  Am                    G
   Magʻlubdir oʻlim, shoxim tiriksan.

[V2]
.   C                   F
 Kuylayman halleluya, butun vujudim bilan
.   Am               G
 Kuylayman halleluya, zulmat yoʻq bulib ketar
.    C                     F
 Kuylayman halleluya, agar qolsam adashib
.   Am               G
 Kuylayman halleluya, qoʻrquv yoʻqolib ketar

[B1]
.  C
   Baland ovozim-la, (Baland ovozim-la)
.  F
   Baland ovozim-la, (Baland ovozim-la)
.  Am
   Baland ovozim-la, (Baland ovozim-la)
.  G
   Kuylayman Xudoga, (Kuylayman Xudoga)
.  C
   Baland ovozim-la, (dushmanlar huzurida)
.  F
   Baland ovozim-la, (shubhalarim parchalab)
.  Am
   Baland ovozim-la, (chunki bu mening kuchim)
.  G
   Baland ovozim-la, (osmon men chun kurashar)</lyrics>
<title>Kuylayman halleluya</title>
<author>Jonathan David &amp; Melissa Helser, Jonathan David, Melissa Helser</author>
</song>