<?xml version="1.0" encoding="UTF-8"?><song><title>Odamlar yshoninglar</title>
<lyrics>[V1]
.    D
 Odamlar yshoninglar,
.    Bm          A
 Odamlar eshitinglar:
.     Em             G
 Rabbimiz Xudodan kelgan,
.        A
 bizni sevib, biz oʻchun oʻlgan!
.     D
 Ykki ming yil ilgari,
.     Bm           A
 Rabbimiz yerga kelgan,
.      Em             G
 Hech ayibsiz oʻldirilgan,
.      A
 Sen oʻchun, sen oʻchun!
.      D          Bm
 Goʻnohlaringni olgan,
.     Em         A
 Oʻzi oʻlimga borgan,
.         D                Bm
 Shoʻncha sevib, qonin toʻkkan,
.Em    A
 Sen oʻchun!

[C1]
.  D          Bm       A
   Boʻgun ham tirigtur Oʻ,
.            Em   A   D
   Oʻz jonin, Oʻz qonini!
.  D         Bm          A
    Soligʻlikka bir keltirar,
.  Em     A   D
    Qalbingga ol!</lyrics>
<key>D</key>
</song>