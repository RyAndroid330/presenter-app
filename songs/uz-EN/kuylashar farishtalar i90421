<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12350</hymn_number>
<author>French, Elevation Worship</author>
<aka>Shon sharaf Buyuklar buyugiga</aka>
<lyrics>[V1]
.A
 Kuylashar Farishtalar
.            E   A
 Yerga ohang taralar
.A
 Javoban bunga togʻlar
.             E    A
 Shodlik sadosin berar

[V2]
.A
 Choʻponlar nechun shodsiz?
.             E     A
 Ayting nega tinmaysiz?
.A
 Bu qanday Hush xabarki
.             E    A
 Osmon oshdi kuyingiz?

[C1]
.  AF#HmEADE      A   D       A  E
    Shon sharaf Buyuklar buyugiga
.  AF#HmEADE      A     D     AEA
    Shon sharaf yuksalgan Xudoga

[V3]
 Baytlahm tomon keling
 Tugʻildi bola, koʻring
 Masih - Rab, Shohimizga
 Tiz choʻkib taʼzim qiling

[C2]
   Shon sharaf Buyuklar buyugiga
   Shon sharaf yuksalgan Xudoga

[B1]
   Najotkor Shohimizga
   Tiz choʻkib taʼzim qiling
   Najotko Shohimizga
   Tiz choʻkib taʼzim qiling</lyrics>
<key>A</key>
<title>Kuylashar Farishtalar</title>
</song>