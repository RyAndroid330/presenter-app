<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>62</hymn_number>
<title>Kaloming ruhimni Q62</title>
<lyrics>[V1]
 Kaloming ruhimni uygʻotgan damda,
 Hamdu sano yangrasin butun olamda.
 // Muqaddas Ruh boshqarsin har bir qadamda, //
 // Rabbim muloqotingni biram qumsayman. //

[V2]
 // Men bugʻdoy boʻlishni juda xohlayman,
 Somon boʻlib yonishdan juda qoʻrqaman. //
 // Rabbim madhingni tildan qoʻymayman, //
 // Iso degan ismingga sira toʻymayman. //

[V3]
 // Gunohlarim xochingga mixlanib ketsa,
 Muqaddas qonlaring koʻzimdan oʻtsa. //
 // Seni aytgan soʻzlaring qilichdan oʻtsa, //
 // Rabbim muhabbatingni biram qumsayman. //
 // Iso degan ismingga sira toʻymayman. //</lyrics>
</song>