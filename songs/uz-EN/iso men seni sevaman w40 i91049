<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>40</hymn_number>
<author>Ulugʻbek Joʻrayev</author>
<key>C</key>
<lyrics>[V1]
.C        Em     Am
 Iso men Seni sevaman
.F       Dm         G
 Hamma narsadan koʻprok
.C      Em     Am  Dm
 Qalbim kuylashni xohlaydi
.C       Em      Am
 Iso men Seni sevaman

[C1]
   Yuragimda bordur Senga muhabbat
   Aytgim kelar Rabbim Senga shuni faqat
   Chin dildan, yurakdan, qalbim bilan
   Iso men Seni sevaman

[V2]
 Ota men Seni sevaman
 Hamma narsadan koʻprok
 Kalbim kuylashni xohlaydi
 Ota men Seni sevaman

[C2]
   Ota buyuksan doim buyuklardan
   Marhamatlarsan inson qalbini
   Senga doim sano aytaman
   Ota men Seni sevaman

[V3]
 Mukaddas Ruh Seni sevaman
 Hamma narsadan koʻproq
 Kalbim kuylashni xohlaydi
 Mukaddas Ruh Seni sevaman

[C3]
   Muqaddas Rux Sen Rabbimning pok Ruhisan
   Toʻldirasan bizning yuraklarimizni
   Xursandmiz, shodmiz Sen bilan
   Mukaddas Ruh Seni sevamiz!
   Ota biz Seni sevamiz!
   Iso biz Seni sevamiz
   Iso men Seni sevaman</lyrics>
<title>Iso, men Seni sevaman W40</title>
</song>