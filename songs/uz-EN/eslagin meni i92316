<?xml version="1.0" encoding="UTF-8"?><song><title>Eslagin Meni</title>
<lyrics>[V1]
 // Meni eslagin Rabbim
 Meni kechirgin Tangrim
 Toki senga umid qilay
 Bor gunohimni yuvayin //

[C1]
   // Eslagin meni eslagin
   Yana bir bor sen eslagin
   Qalbimni sen yumshatgin Rabbim
   Meni yana bir bor sen eslagin //

[V2]
 Menga qaragin Rabbim
 Meni xolimni bil Tangrim
 Bilaman seni xafa qildim
 Seni oʻzinga gunoh qildim</lyrics>
</song>