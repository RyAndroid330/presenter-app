<?xml version="1.0" encoding="UTF-8"?><song><aka>Azalda Kalom bor edi</aka>
<lyrics>[V1]
.   F#               Ebm
 // Azalda Kalom bor edi,
.B           C#      F#
 Kalom Xudo huzurida edi. //
.F#         Ebm
 Kalom Xudo edi,
.B          C#     F#
 Azaldanoq Xudoda edi.
.F#               Ebm
 Azalda Kalom bor edi,
.B           C#       F#
 Kalom Xudo huzurida edi.

[V2]
.   F#                   Abm
 // Borliq U orqali bor boʻlgan,
.B          C#               F#
 Usiz hech narsa bor boʻlgan emas. //
.F#                Abm
 Neki bor boʻlgan boʻlsa,
.B         C#     F#
 U orqali bor boʻlgan.
.F#               Ebm
 Azalda Kalom bor edi,
.B           C#      F#
 Kalom Xudo huzurida edi.

[V3]
.F#             Ebm
 Unda hayot bor edi,
.B          C#        F#
 Hayot insonlar nuri edi.
.F#              Ebm
 Nur zulmatda porlaydi,
.B            C#          F#
 Zulmat esa nurni qoplay olmadi.
.F#                      Ab
 Kalom inson qiyofasiga kirdi,
.B        C#     F#
 Biz aro maskan qildi.

[C1]
.     F#               Ebm
   // Azalda Kalom bor edi,
.    B           C#      F#
   Kalom Xudo huzurida edi. //
.     B           C#      F#
   // Kalom Xudo huzurida edi. //</lyrics>
<key>F#</key>
<title>Borliq U orqali bor boʻlgan Q168</title>
<hymn_number>168</hymn_number>
</song>