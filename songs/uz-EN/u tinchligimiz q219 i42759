<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>219</hymn_number>
<lyrics>[C1]
.     Cm         Fm
   // U tinchligimiz,
.  Cm         Fm
   U tinchligimiz,
.  G                      Cm
   toʻsiq devorni qulatdi Iso. //

[V1]
.   Eb              Fm
 // Unga bering tashvishni,
.Eb             Cm
 yordam berar U sizga. //

[C2]
.     Cm         Fm
   // U tinchligimiz,
.  Cm         Fm
   U tinchligimiz,
.  G                      Cm
   toʻsiq devorni qulatdi Iso. //

[C3]
   // U tinchligimiz,
   U tinchligimiz,
   kasallarimizni oldi Iso. //

[V2]
 // Unga bering kasallarni
 shifo berar U sizga. //

[C4]
   // U tinchligimiz,
   U tinchligimiz,
   kasallarimizni oldi Iso. //

[V3]
 // Unga bering hayotingizni
 najot berar U sizga. //

[C5]
   // U tinchligimiz,
   U tinchligimiz,
   toʻsiq devorni qulatdi Iso. //</lyrics>
<key>Cm</key>
<title>U tinchligimiz Q219</title>
</song>