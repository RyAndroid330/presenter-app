<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.E                       F#m
 Baliqlar suvda, qushlar osmonda,
.B                  E
 Ohu dalada, gullar chamanda.
.E               F#m
 Sevadi Najotkor uni, buni,
.B                          E
 Hammadan koʻproq biz bolalarni.

[C1]
.  E                A
   Koreyslarni ham, Hindularni ham
.  B                    E
   Qora tanlikni hamda oqlarni.
.  E               A
   Sevadi Najotkor uni, buni,
.  B                          E
   Hammadan koʻproq biz bolalarni.

[V2]
 Eshiting odamlar, Xudo sizni sevar,
 Har vaqt soatda u bizga boqar.
 Sevadi Najotkor uni, buni,
 Hammadan koʻproq biz bolalarni.

[C2]
   Koreyslarni ham, Hindularni ham
   Qora tanlikni hamda oqlarni.
   Sevadi Najotkor uni, buni,
   Hammadan koʻproq biz bolalarni.</lyrics>
<title>Baliqlar suvda Q259</title>
<hymn_number>259</hymn_number>
</song>