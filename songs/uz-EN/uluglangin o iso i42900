<?xml version="1.0" encoding="UTF-8"?><song><title>Ulugʻlangin o Iso</title>
<key>C</key>
<lyrics>[V1]
.   C            G     F(Am)
 // Qolimga olib gitaramni,
.C           G        Am        F
 Sen uchun kuylayman qoʻshigʻimni.  //

[C1]
.  C           G      Am           F
   Ulugʻlangin o Iso, kuylayman Senga hamdu sano,
.  C          G       F
   Faqat bu hamdlarga Sen loyiqsan, o Iso, o Iso.
.         C          Am   F     C
   // Sen uchun, Sen uchun, Sen uchun,
.      Am      F
   Sen uchun, faqat Sen uchun.  //

[V2]
 // Senga aytaman qoʻshiqlarim,
 Yurakdan chiqqan soʻzlarim.  //

[V3]
 // Sen shahanshohimsan Rabbim,
 Ulugʻlayman Sening noming.  //</lyrics>
</song>