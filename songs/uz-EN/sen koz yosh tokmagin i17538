<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Sen koʻz yosh toʻkmagin</title>
<aka>Aytgin Halleluya</aka>
<key>Am</key>
<lyrics>[V1]
.   Am                      G
 //  Sen koʻz yoshlar toʻkmagin,
.Am                  Em
 Umiding, Xudoda boʻlsin! //
.   Am               G
 // Kundan-kun ulgʻayib,
.Am                   Em
 Nigohing, Xudoda boʻlsin! //

[C1]
.  Am          Em
   Aytgin Halleluya!
.  Am C         G
   Aytgin Halleluya!
.  Am           Em
   Kuylagin Halleluya!
.  Am    C        G
   Kuylagin Halleluya!

[V2]
 // Men bilgan Xudo - sevgi!
 Koʻz yoshlarni artguvchi! //
 // Yomgʻir yogʻib keladi,
 Osmondan kelar, toʻlib sevgi! //

[C2]
   Aytaman Halleluya!
   Aytaman Halleluya!
   Kuylayman Halleluya!
   Kuylayman Halleluya!</lyrics>
</song>