<?xml version="1.0" encoding="UTF-8"?><song><author>Jurayev Ulugbek</author>
<hymn_number>235</hymn_number>
<lyrics>[V1]
.Em            Am
 Qanot bergin, koʻklarga uchib,
.D                 G
 Seni nomingni men ulugʻlay.
.Em            Am
 Ovoz bergin, farishtalarday,
.D                   G
 Tinmay kuylay Seni nomingni.

[C1]
.     Am        B          Em            D
   // Men uchun hamma narsadan chiroylisan,
.  Am        B          Em           D
   Men uchun hamma narsadan muqaddassan.
.  Am       B          Em            D
   Minnatdorman men Sendan mehribon Otam,
.          Am       B     Em
   Mening Rabbim, mening Rabbim. //

[V2]
 Shaydo boʻlib Seni soʻzingga,
 Yurarman ergashib ortingdan.
 Imkon bergin bir bora quchay,
 Kuylayin qalbimdagi qoʻshiqlarimni.</lyrics>
<key>Em</key>
<aka>Qanot bergin</aka>
<title>Men uchun Muqaddassan Q235</title>
</song>