<?xml version="1.0" encoding="UTF-8"?><song><key>Eb</key>
<lyrics>[V1]
.Eb               Bb
 Yey, doʻstim kim yaratdi?
.Eb             Bb
 Quyosh, osmon, atrofni.
.Eb      Ab     Eb
 Yaratdi buyuk Xudo,
.Eb       Bb     Eb
 Ayt unga hamdu sano.

[V2]
 Dengizdagi toʻlqini,
 Oltin qum qirgʻoqlarni.
 Yaratdi buyuk Xudo,
 Ayt unga hamdu sano.

[V3]
 Olmos toshga oʻxshagan
 Har xil chigʻanoqlarni.
 Yaratdi buyuk Xudo,
 Ayt unga hamdu sano.

[V4]
 Baliqlar suvda suzar,
 Qush inida oʻtirar.
 Yaratdi buyuk Xudo,
 Ayt unga hamdu sano.

[V5]
 Koʻkda qush halasini
 Yaylovlarda gullarni
 Yaratdi buyuk Xudo,
 Ayt unga hamdu sano.

[V6]
 Yulduzchalar yaltirar,
 Xudo haqida soʻzlar.
 Yaratdi buyuk Xudo,
 Ayt unga hamdu sano.</lyrics>
<title>Ey, doʻstim kim yaratdi</title>
</song>