<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em                           B
 Koinotni yaratgan Kudratli Xudoim
. G           B     Em
 Mukaddas va Adolat Xudoim
.Em                                          B
 Bizga bulgan buyuk sevging ishlaringda koʻrinadi
.G           B        Em
 Barxayot va mexribon Xudoim

[C1]
.  Em           Am
   Samodagi Ota Xudoim
.  D                  G
   Sening shoxliging bizga kelsin
.  Em                  C
   Sening irodang osmonda boʻlgandek
.  B                  Em
   Er yuzida xam doim bajo boʻlsin

[V2]
.    Em
 Misrda ajoyib moʻjizar yaratding
.                                Am
 Kullikdan isroil xalkqa ozodlik berding
.                      D
 Kizil dengizni bulib yoʻlni ochding
. G                     Em
 Mannani saxroda sochib rizkni yetkazding
.Am                   Bm              Em
 Bulut boʻlib issik kunda koʻlanka tutding
.Am                       Bm           Em
 Olov boʻlib zulmat tunda yorugʻlik berding

[V3]
.   Em
 Inson kiyofasida xochda kon toʻkding
.                              Am
 Gunoximni yuvib mangu hayotni berding
.                    D
 Kiyin kunda avaylab etaklaysan
. G                   Em
 Ibodatga javob berib kuvontirasan
.Am                    Bm              Em
 Seni sevdim Sen bilan boʻlishni xoxlayman
.Am                    Bm          Em
 Xayotimni bagʻishlab Seni ulugʻlayman</lyrics>
<aka>Koinotni yaratgan Qudratli Xudoyim</aka>
<title>Samodagi Ota Xudoim</title>
</song>