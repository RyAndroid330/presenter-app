<?xml version="1.0" encoding="UTF-8"?><song><title>Men doʻstni topdim ҲСХМ152</title>
<key>C</key>
<lyrics>[V1]
.C              Dm
 Men doʻstni topdim,
.C        Dm
 Akadan yaqin U!
.C           Dm
 Undan yaqin yoʻq,
.C          Dm
 Doim men bilan U!

[C1]
.  F C  F C Am G C
    Iso, Iso, Iso !
.  F C G   C
    Abadiy Doʻst!

[V2]
 Men doʻstni topdim,
 Onadan yaqin U!
 Qalbim qiynalar,
 Undan yiroq boʻlsam!</lyrics>
<aka>Iso - Abadiy Doʻst</aka>
<hymn_number>152</hymn_number>
<author>Murod Azizov, Malohat</author>
</song>