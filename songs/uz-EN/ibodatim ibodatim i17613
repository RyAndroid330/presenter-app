<?xml version="1.0" encoding="UTF-8"?><song><key>Bm</key>
<lyrics>[C1]
.     F#m
   // Ibodatim, ibodatim,
.  G         Em    F#m
   Xudodan berilgansan. //
.     Bm                F#m
   // Hayotim toʻlqinlarida,
.  G          Em     F#m
   Men senga suyanganman. //

[V1]
.F#m
 Xudoyim sen bilasan,
.F#              Bm
 Jonim juda qiynalgan,
.Bm                     F#m
 Darmonsizman yerga yiqildim.
.     G         Em
 // YOrdam ber menga, //
.G                F#m
 Hayot tashvishlarida.

[C2]
   // Ibodatim, ibodatim,
   Xudodan berilgansan. //
   // Hayotim toʻlqinlarida,
   Men senga suyanganman. //

[V2]
.F#m
 Xudoyim oson hayotni,
.F#            Bm
 Umrimda istamayman.
.F#m
 Mayli yoʻlingda qaygʻursam,
.G          Em    F#m
 Izingdan chekinmayman.

[C3]
   Ibodatim, ibodatim,
   Xudodan berilgansan.
   // Hayotim tashvishlarida,
   Men senga suyanganman! //
   // Men senga suyanganman! //</lyrics>
<aka>Hayotim toʻlqinlarida 1</aka>
<title>Ibodatim, ibodatim</title>
</song>