<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>146</hymn_number>
<title>Sen Qudratli Yaratuvchim Q146</title>
<key>Dm</key>
<lyrics>[V1]
.Dm                Bb
 Sen qudratli Yaratuvchim,
.      C         Dm
 Butun olam Egasisan,
.Dm          Bb
 O mehribon Qutqaruvchim,
.           C           Dm
 Qutqarding Sen soʻzing bilan.

[C1]
.     Dm   F             Gm
   // Otajomin Seni maqtayman,
.        C            Dm
   Mehribonim olqishlayman.
.  Dm      Bb         C
   Oʻyimdasan, dilimdasan,
.           A           Dm
   Yurakdan Seni men sevaman.  //

[V2]
 Sen ulugʻsan, manguliksan,
 Isming buyuk barhaq Xudo,
 Odil hukming, muhabbating
 Bizga porlar misli ziyo.</lyrics>
</song>