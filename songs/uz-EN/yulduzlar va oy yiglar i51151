<?xml version="1.0" encoding="UTF-8"?><song><title>Yulduzlar va oy yigʻlar</title>
<key>G</key>
<lyrics>[V1]
.G                D
 Yulduzlar va oy yigʻlar,
.                Em
 Zulmat quyoshni yopar,
.              C        G
 Xochga mixlandi dunyo Najotkori.
.               D
 Xochda azoblanar,
.               Em
 Qoni biz uchun oqar,
.             C           G
 Gunohning laʼnatini Masih Oʻziga oldi

[V2]
.G                 D
 Soʻnggi nafasni oldi,
.               Em
 Quyosh nuri soʻndi
.               C        G
 Qabrga qoʻyildi Xudoning Oʻgʻli
.G              D
 U biz uchun oʻldi,
.               Em
 va gʻalaba qildi
.              C         G
 Doʻzohning oʻlim kuchini U magʻlub etdi

[V3]
.G            D
 Yer larzaga keldi,
.               Em
 Qabr toshi ochildi,
.              C           G
 Masihning sevgisi gʻalaba qildi.
.                 D
 Oʻlim kuchi yengildi,
.                Em
 Rabbiy Iso tirildi
.                C
 Dunyo gunohdan xalos boʻldi.

[V4]
.G             D
 Abadiy ulugʻlangin,
.  Em         C
 Abadiy yuksalgin Sen
.G            D
 Abadiy hayotsan,
.       C           G
 Sen barhayot, Sen barhayot!

[V5]
.G            D
 Kuylaymiz Halleluya,
.             Em
 Kuylaymiz Halleluya
.             C
 Kuylaymiz Halleluya,
.                G
 Iso gʻalaba qildi!</lyrics>
<aka>Abadiy II</aka>
<author>Bethel Music, Kari Jobe</author>
</song>