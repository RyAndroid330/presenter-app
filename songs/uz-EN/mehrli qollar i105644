<?xml version="1.0" encoding="UTF-8"?><song><author>Timoʻtiy</author>
<lyrics>[V1]
.Am           F
 Bu qoʻllar oddiy emasdir
.G                F
 Qiynalgan xochda sen uchun.
.   Dm        Am
 // Sevgi ila koʻrsatgan.
.F        G         Am
 Bu dunyoga oʻz kuchin. //

[C1]
.  F
   Bu qoʻllar toʻlgan mexrga,
.  G                 C
   Koʻrsatgan buyuk sevgisin
.  Dm         Am
   Yaralari gunohdan,
.  C      E        Am
   Ozodlikning belgisi

[V2]
 Yigʻlagan maʼyus kimsaning,
 Silagan sevib boshini.
 // Bu teshik qoʻllar mehrli,
 Koʻzlarning artgan yoshini. //

[V3]
 Qoʻlidagi oqqan qonlarning.
 Bahosi qimmat men uchun.
 // Gunohlarni yuvishda,
 Qoqilgan xochda sen uchun. //</lyrics>
<key>Am</key>
<title>Mehrli qoʻllar</title>
</song>