<?xml version="1.0" encoding="UTF-8"?><song><author>Gulnora Joʻrayeva, Ulugʻbek Joʻrayev</author>
<title>Senga Aytay Hamdu Sanolar</title>
<lyrics>[V1]
.Dm
 Olamga nur taratding shukur,
.C
 Inson qilib yaratding shukur,
.Am
 Oʻzing tomon qaratding shukur,
.E
 Senga aytay hamdu sanolar!

[V2]
. Am           G           C
 Sen jonimsan qalqonim Oʻzing,
. E
 Sen borimsan qoʻrgʻonim Oʻzing,
. Dm                  E
 Haqiqatdir har aytgan Soʻzing,
.E
 Senga aytay hamdu sanolar!

[C1]
.   Am            G            C
   Sen boʻlmasang boʻlarman yomon,
.    E
   Saqlagaysan meni sogʻ-omon,
.   Dm                   E
   Koʻzlarimni tikib Sen tomon,
.  E
   Senga aytay hamdu sanolar!

[V3]
 Har bir kecha-kunduzlar uchun,
 Oy-u quyosh, yulduzlar uchun,
 Barcha daryo, dengizlar uchun,
 Senga aytay hamdu sanolar!

[V4]
 Senda vafo sadoqat bordur,
 Muhabbatu, saodat bordur,
 Bu pok Sevging hammaga yordur,
 Senga aytay hamdu sanolar!</lyrics>
<key>Am</key>
</song>