<?xml version="1.0" encoding="UTF-8"?><song><key>C#m</key>
<lyrics>[V1]
.C#m
 Xudo hamma narsa berar,
.    G#
 Men baxtiyorman.
.G#
 Quyosh, yomgʻirni vaqtida,
.    C#m
 Men baxtiyorman.
.   F#m                B
 // Gullar, oʻtlarni sevaman.
.              E
 Bogʻlar, barglar, daraxtlarni,
.A         F#m
 Ulardagi mevalarni,
.       C#m
 Men baxtiyorman. //

[V2]
 Ota-onam mehribondir,
 Men baxtiyorman.
 Menga gʻamxoʻrlik qiladi,
 Men baxtiyorman.
 // Sevgi bilan ovqat berar,
 Yangi kiyim olib berar.
 Erkalab sevadi meni,
 Men baxtiyorman. //

[V3]
 Xudo gʻamhoʻrlik qiladi,
 Men baxtiyorman.
 Osmonda uy tayyorlaydi,
 Men baxtiyorman.
 // U yer ajoyib va goʻzal,
 Doʻstlarimni uchrataman.
 Xudo ularni beradi,
 Men baxtiyorman. //</lyrics>
<aka>Xudo hamma narsa berar</aka>
<title>Men bahtiyorman</title>
<hymn_number>39994</hymn_number>
</song>