<?xml version="1.0" encoding="UTF-8"?><song><key>B</key>
<lyrics>[V1]
.   Abm          E
 // Rabbimiz va Tangrimiz,
.F#         Ebm
 Qudratga loyiqsan.
.E       C#m
 Hammaga qodir Xudo,
.Ebm          Abm
 Hurmatga loyiqsan. //

[C1]
.     Abm
   // Bor boʻlgan
.  E     F#   Ebm Abm
   Hozir ham, bor boʻlgan
.  E     F#   Ebm Abm
   Hozir ham, bor boʻlgan
.           F#
   Bor boʻlgaysan. //

[V2]
 // Hammani Sen yaratding,
 Irodang bilan.
 Yoʻqdan bor paydo qilding,
 Soʻzing bilan. //

[C2]
.     Abm
   // Bor boʻlgan
.  E     F#   Ebm Abm
   Hozir ham, bor boʻlgan
.  E     F#   Ebm Abm
   Hozir ham, bor boʻlgan
.           F#
   Bor boʻlgaysan. //

[B1]
.  Abm       E     F#   Ebm
   Shon-shuhrat va kuch-qudrat,
.          F#
   Bor boʻlgaysan.</lyrics>
<aka>Rabbimiz va Tangrimiz</aka>
<title>Bor boʻlgan W109</title>
<hymn_number>109</hymn_number>
</song>