<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Xizirov</author>
<title>Sizni ulugʻlashchun</title>
<lyrics>[V1]
 Sizdan ulugʻ Zot yoʻq
 Sizdan buyuk yoʻq
 Odam bolasidan
 Sizga suyuk yoʻq
 Ota deganimda
 Qalbimda bir choʻq
 Sizni ulugʻlashchun
 Alanga yoqar!

[V2]
 Bu Sizning Sevgingiz,
 Mehringiz qaynoq
 Borliqni yaratib
 Sevdingiz mutloq
 Mehringizga tashna
 Xatto qizgʻoldoq
 Sizni ulugʻlashchun
 Qalbimni yoqar!

[C1]
   // Tasanno Tasanno
   Tasanno Tasanno //

[V3]
 Dav-daraxtga boqsam
 Qudratingiz bor
 Togʻlarga termulsam
 Shuhratingiz bor
 Xatto kapalakda
 Moʻjizangiz yor
 Sizni ulugʻlashchun
 Yuragim yoqar!

[V4]
 Kunimda Siz borsiz
 Tunimda Siz bor
 Sizga muxtoj borliq
 Sizga intizor
 Xamma narsa uchun
 Bir Siz ulugʻvor
 Sizni shoningizni
 Madh etish yoqar!

[V5]
 Kalomingiz ulugʻ
 Soʻzingiz ulugʻ
 Xar soniyada bergan
 Umringiz qutlugʻ
 Yashash uchun qalbga
 Solgansiz bir choʻgʻ
 Sizni ulugʻlashchun
 Bir umr yetar!</lyrics>
</song>