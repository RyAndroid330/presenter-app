<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Dm           A                         Dm
 Menga kelgan shubhalarni bartaraf qil Xudoyim,
.   A                Dm          A         Dm
 // Achchiqlik samaralari dilda dogʻ qoldirmasin. //

[V2]
.A                                        Dm
 Farzandingman bir zumga ham shubha meni ezmasin,
.   A                  Dm         A         Dm
 // Sening lashkaring safida faol boʻlib yurayin. //

[V3]
.A              Dm     A           Dm
 Madorsizligim tufayli daf et shubhalarimni,
.    A               Dm            A              Dm
 /// Oʻzing kelgin, jangga boshla, ber ruhiy gʻalabangni. ///</lyrics>
