<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>186</hymn_number>
<author>Hillsong</author>
<title>Sendan Minntadorman ҲСХМ140</title>
<key>Bb</key>
<lyrics>[V1]
.Bb           Eb  F
 Sendan minnatdorman
.Bb            Eb  F   Bb
 men uchun jon berganingga,
.Bb         F  Gm
 Gunohlarimni olib,
.  F    Eb   Cm           F
 sevgi bilan inoyating berding.
.Bb          Eb   F
 Sendan minnatdorman
.   Bb          Eb  F
 qoʻllaring mixlanganiga,
.            F     Gm
 Qoning bilan poklading,
. F      Eb                F
 bildim endi meni kechirganingni.

[C1]
.  Bb        F      Gm       Eb
   Qoʻziga sharaf taxtda oʻtirgan,
.  F              Bb
   Gʻalaba qilib boshqarasan,
.  Cm           F
   men sajda qilaman.
.  Bb             F  Gm      Eb
   Baland yuksalgan Iso qoʻzisan,
.  F            Bb            Eb       Bb
   Xochda mixlangan sevuvchi Qoʻziga sharaf.</lyrics>
</song>