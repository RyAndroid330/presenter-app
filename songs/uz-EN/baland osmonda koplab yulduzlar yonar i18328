<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>42224</hymn_number>
<title>Baland osmonda koʻplab yulduzlar yonar</title>
<lyrics>[V1]
.Bm                     F#        Bm
 Baland osmonda koʻplab yulduzlar yonar,
.Bm                  F#       Bm
 Lekin bittasi bayramdagidek porlar.
.   D                     A       Bm
 // Bu yulduz kichkintoy Rabbimizniki,
.Bm             F#       Bm
 Onasi avaylab oxurga yotqizdi. //

[V2]
 Sharqdan munajjimlar yulduz tomon borar,
 Va sovgʻalarni Rabbimizga keltirar.
 // Bolalar shoshinglar, Rabbimiz tomon,
 Va yuraklarni berishga boʻling tayyor. //</lyrics>
<key>Bm</key>
</song>