<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Sen uchun bu dunyoga kelgan U,
 Gunohing uchun xochda jon bergan.
 //  Maysalarga qizil qon toʻshalgan,
 Rabbimning bu ilk sevgisi.

[V2]
 Dod solganda ayollar qoshingda,
 Xochda tura Rabbiy dalda berding.
 // Maysalar uzra poyandoz qoning,
 Bu sevgi haqiqiy sadoqat ramzi. //

[V3]
 Bu yoʻl haqiqat, muhabbat taxti,
 Gunohning toʻrida qiynalganlar.
 // Kel seni hayotga chorlar Rabbim,
 Bu buyuk Rabbimning jasorati. //
 // Kel seni hayotga chorlar Rabbim,
 Bu sevgi muqaddas hayot ramzi. //</lyrics>
<title>Sen uchun Q178</title>
<hymn_number>178</hymn_number>
</song>