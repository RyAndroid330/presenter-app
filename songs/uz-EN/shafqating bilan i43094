<?xml version="1.0" encoding="UTF-8"?><song><author>Sergey Danilʹchenko (Serzh Dani)</author>
<hymn_number>230</hymn_number>
<key>Dm</key>
<lyrics>[V1]
.Dm                G
 Shafqating bilan toʻla bor zamin,
.C                Am
 Shafqating bilan toʻla hayotim.
.Dm                       E
 Sening shafqating ustun hukmdan,
.Am           G            C
 Kechirding, uyingga olib kirding.

[C1]
.      Dm         G      C   Am
   // Sen qutqarding va oqlading,
.  Dm        E      Am
   Aybimdan ozod qilding. //
.       Am      Dm     E
   /// Minnatdorman Sendan. ///</lyrics>
<title>Shafqating bilan</title>
</song>