<?xml version="1.0" encoding="UTF-8"?><song><title>Sendan boshqa Najotkorim yoʻq Q144</title>
<aka>Najotkorim, Hayot shoshar qaygadir yelib</aka>
<key>Gm</key>
<lyrics>[C1]
.     Gm             Eb
   // Sendan boshqa Najotkorim yoʻq,
.  F              Bb
   Sendan boshqa Madadkorim yoʻq.
.  Eb            Cm
   Sendan boshqa Umidvorim yoʻq
.  Dm            Bb  Cm     Dm
   Sendan boshqa Xaloskorim yoʻq! //

[V1]
.Gm             Eb
 Hayot shoshar qaygadur yelib,
.F           Dm
 Odam ogʻli najot kutib,
.Eb               Cm
 Bir kun ming kun kabi oʻtib
.   Dm           Bb(Cm)   Gm
 // Yaratganni izlab oʻylanib! //

[V2]
.   F          Dm
 // Bagʻringda oʻsdim ulgʻaydim,
.Gm         Cm     (Dm) (Gm)
 Lekin Seni eshita olmadim! //
.Gm
 Baxtimga bor ekansan Rabbim
.   F(Eb)         Bb(Cm)     Dm
 // Meni Oʻzing bagʻringga olding! //

[V3]
.   Bb         Dm
 // Yaratganga kelsin odamzod,
.Cm             F
 Hayot koʻrsin bilsin odamzod! //
.Gm              Eb
 Ming shukurlar desin odamzod
.F               Bb
 Sendan boshqa Najotkorim yoʻq
.Eb             Cm        D
 Sendan boshqa adadkorim yoʻq!</lyrics>
<hymn_number>144</hymn_number>
</song>