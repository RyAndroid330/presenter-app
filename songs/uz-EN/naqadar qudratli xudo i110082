<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.E4    D               A
 Xudo buyuk, olqishga loyiq
.          E        F#7
 Xaleluya, Ismi eng ulugʻ
.          D             A
 Olov koʻzida, shifo qonida
.         E             F#7
 Shuxrati namoyon har yerda
.               D                A
 Yulduzlarga qarang barin nomlagan
.       E                F#m7
 Oldida xamma tiz choʻkar
.                   D                A
 Jinlar xam qochar, Farishtalar kuylar
.E4                F#m7     E
 Shamol, toʻlqinlar boʻysunar

[C1]
.      D          A
   Rabbiy - qudratli Xudo
.     E       F#m7    E
   Podshox osmon-u yerda
.     D     A
   Sevgi va donolikda
.     E                F#m7
   Rabbimiz qudratli Xudo

[V2]
 Undan ketsam ham, mendan ketmadi
 Oʻlimni yengib, uni sindirdi
 Juma kun hochda, biz uchun oʻldi
 Yakshanba kun qaytib tirildi
 Chandiqlarga qarang, qoʻl, oyo-gʻida
 Jonimiz qutqardi to abad
 Loyiqdir Qoʻzi, shuhrat Podshohi
 Oh, Farishta-yu ellar kuylar

[V3]
 Koʻz toʻla ishonch, yuraklar kutar
 Bir kun qaytib, koʻz yoshni artar
 Koʻz yoshlar, ogʻriqlar
 Qaygʻu, gunohlar tugar
 Qirolimiz yana qaytar
 Sevgisi hukmron boʻlar
 Bor qilgan ishlaring, hozirgi ishlaring
 Boʻlajak ishlaring biz kuylaymiz

[C2]
   Rabbim, Sen qudratlisan
   Har ishda buyuksan
   Seni ulugʻlash chun
   Meni yaratgandirsan
   Rabbiy - Qudratli Xudo
   Podshox osmon-u yerda
   Sevgi va donolikda
   Naqadar qudratli Xudo</lyrics>
<title>NAQADAR QUDRATLI XUDO</title>
<author>Phil Wickham</author>
</song>