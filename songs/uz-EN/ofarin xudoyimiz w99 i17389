<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>99</hymn_number>
<title>Ofarin Xudoyimiz W99</title>
<lyrics>[V1]
.   Am        B7 Em
 // Ofarin Xudoyimiz,
.G
 Bizga mehribonsan
.D                  Am         B7 Em
 Yaʼni xayrixohsan, ofarin Xudoyimiz //

[C1]
.     C         D         G  Bm C
   // Menga umr kafolat bayon
.  Am       B7        Em
   Haqiqat, yoʻl va hayot //

[V2]
.   Am        B7   Em   G
 // Iso Masih Rabbimiz, shuhrat, madhiya va
.D                 Am           B7   Em
 Olqish hamdu sano bir Sengadir Rabbimiz //</lyrics>
<key>Am</key>
</song>