<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13868</hymn_number>
<author>Malohat Pulatova</author>
<lyrics>[V1]
 Intro:
.Cm G# Eb G Gsus
 -__
.       Cm               Ab
 // Xudoning sevgisi, dunyoni ushlab turar,
.      B             Gm
 Uning inoyati, bizga barakat berar!
.    Ab                  Eb
 Xudoning sevgisi, oʻzgartiradi bizni,
.     Fm             G
 Uning inoyati, bir qildi hammamizni! //

[C1]
.     Cm                    Ab
   // Naqadar buyukdir, Xudoning sevgisi,
.       B               Gm
   U bizga abadiy hayot beribdi!
.  Ab                    Eb
   Naqadar buyukdir, Xudoning sevgisi,
.         Fm                G
   Biz Xudoning farzandlarimiz - endi! //

[V2]
.    Cm              Ab
 Xudoyim sevadi hammani, juda ham,
.        B              Gm
 Uning muhabbati, doim berar malham,
.    Ab                  Eb
 Xudoning sevgisi, menga kuch beradi,
.    Fm               G
 Uning inoyati, har doim oqlaydi!</lyrics>
<key>F</key>
<title>Xudoning Sevgisi</title>
</song>