<?xml version="1.0" encoding="UTF-8"?><song><title>Senda meni ihtiyojim borligim</title>
<lyrics>[V1]
 Senda meni ihtiyojim borligim
 Sen hayot bulogim nonim
 Basirlikda ochilgan kuzim
 Jonsizlikda olgan nafasim

[V2]
 Samolar kuklarga kutargan sevgan
 Ezguligi beqiyos buyuk
 Gunohkordeb ulgan tirilgan
 Sevgiga loyiq Iso Masihim

[C1]
   Bosh egib senga intilgan
   Kurmas ulim qaygu istirob
   Ozodligim hayot javobi
   Ishtiyoqim yurak savobi</lyrics>
<author>Ulugʻbek Joʻrayev</author>
</song>