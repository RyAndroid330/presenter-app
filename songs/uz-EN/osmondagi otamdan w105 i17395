<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>105</hymn_number>
<lyrics>[V1]
 Osmondagi Otamdan,
 bizga keldi sadoqat(2m)
 Gunohlardan ozod qilib
 hayot berdi to abad(2m)

[C1]
   Mangu hayot, mangu hayot,
   Taqdim qildi bizga Ota mangu hayot

[V2]
 Mehribonliging cheksiz
 Unutmaymiz manguga(2m)
 Ogʻir hayot yoʻlimdan,
 Ozod qildi manguga(2m)

[V3]
 Muqaddas Ruhing ulugʻ,
 qaygʻu kelsa boshimga(2m)
 Najotkorimiz Iso,
 doim birga qoshimda (2m)</lyrics>
<title>Osmondagi Otamdan W105</title>
</song>