<?xml version="1.0" encoding="UTF-8"?><song><aka>Alamlarim</aka>
<lyrics>[V1]
 // Alamlarim koʻpdur bir jahon,
 Meni ezib yuborgan shayton. //
 // Muqaddasdur Oʻzing toʻkkan Qon,
 Alamimni olib ber Otajon! //

[V2]
 // Mening kabi yigʻlaganlar koʻp,
 Jigar bagʻrim tigʻlaganlar koʻp. //
 // Qasos oʻtila yonganlar koʻp,
 Alamimni olib ber Otajon! //

[V3]
 // Oʻchira olay shayton oʻtini,
 Fosh qilayin mahluq betini. //
 // Qurita olay uning zotini,
 Alamimni olib ber Otajon! //

[V4]
 // Oyoq osti boʻlganda qadrim,
 Tilka pora boʻlganda qalbim. //
 // Hayotdan soʻnganda umidim,
 Boshlarimni siladi Rabbim. //
 Tamom tugab bitganda sabrim,
 // Boshlarimni siladi Rabbim. //</lyrics>
<title>Boshlarim siladi Rabbim Q56</title>
<hymn_number>56</hymn_number>
</song>