<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Hizirov, Ulugʻbek Abduhalimov</author>
<title>Yaratganga muhtojman</title>
<lyrics>[V1]
 Molim oshib toshsa ham
 Yoʻqchilikdan bossa gʻam
 Yigit boshim boʻlsa ham
 Yaratganga muhtojman.

[V2]
 Kulsam kulgimdir yolgʻon
 Yurak yigʻlar, yigʻlar jon.
 // Gʻam cheksa suygan janon
 Yaratganga muhtojman. //

[V3]
 // Farzand koʻzni qarogʻi
 Kuydirmasin hech dogʻi. //
 // Yoshim ulgʻaygan chogʻi
 Yaratganga muhtojman. //

[V4]
 Shayton izgʻisa har kun
 Har qadamda men tutqun.
 // Kuch soʻrab Rabbim bugun
 Yaratganga muhtojman. //

[V5]
 Rabbim kuchim - quvvatim
 Topgan baxtim - davlatim.
 Rabbimga bitdim xatim:
 &quot;Yaratganga muhtojman&quot;

[V6]
 Toʻldirar Ruh qudrati
 Xudodan javob xati.
 Iso Xudo surati
 Yaratganga muhtojman.

[V7]
 Bugun bir Bani Odam
 Qaddi egik, chekar gʻam.
 Demoqda butun olam:
 &quot;Yaratganga muhtojman&quot;</lyrics>
</song>