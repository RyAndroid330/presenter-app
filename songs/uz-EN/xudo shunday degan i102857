<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am
 // Xudo shunday degan,
.Dm
 Sendan aslo ayrilmayman,
.E                       Am E
 Seni aslo tashlab ketmayman. //

[C1]
.     Dm       E        Am
   // Botir yurak bilan safarga chiqaman,
.  Dm           E
   Qoʻrqmayman, qoʻrqmayman.
.  Dm                 E
   Xudo chuponimdir, dushmanlar meni
.    Am Dm     E             Am
   Nima qiloladi, nima qiloladi? //</lyrics>
<title>Xudo shunday degan</title>
<hymn_number>213</hymn_number>
<author>Iliyas Tursun</author>
</song>