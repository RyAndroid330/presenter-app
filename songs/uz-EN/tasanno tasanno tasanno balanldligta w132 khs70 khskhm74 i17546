<?xml version="1.0" encoding="UTF-8"?><song><title>Tasanno, Tasanno, Tasanno Balanldligta W132 ҲС70 ҲСХМ74</title>
<lyrics>[V1]
.   G           D
 // Tasanno, tasanno,
.Em           C   D
 Tasanno balandlikda //

[C1]
.  C                 G
   Nomingni ulugʻlaymiz(olqishlaylik),
.  C                 G
   Qalbingizdan ishoning,
.  C            G  Em
   Qadrlaymiz Xudoimizni!
.  Am           D A G
   Tasanno balandlikda!

[V2]
 // Shon -sharaf, shon -sharaf
 Shon -sharaf Shohlar -Shohiga! //

[V3]
 // Shuhrat shuhrat shohlarning shohiga shuhrat //</lyrics>
