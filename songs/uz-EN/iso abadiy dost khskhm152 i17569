<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>152</hymn_number>
<author>Murod Azizov, Malohat</author>
<title>Iso - Abadiy Doʻst ҲСХМ152</title>
<aka>Men doʻstni topdim</aka>
<lyrics>[V1]
.C              Dm
 Men doʻstni topdim,
.C        Dm
 Akadan yaqin U!
.C           Dm
 Undan yaqin yoʻq,
.C          Dm
 Doim men bilan U!

[C1]
.  F C  F C Am G C
    Iso, Iso, Iso !
.  F C G   C
    Abadiy Doʻst!

[V2]
 Men doʻstni topdim,
 Onadan yaqin U!
 Qalbim qiynalar,
 Undan yiroq boʻlsam!</lyrics>
<key>C</key>
</song>