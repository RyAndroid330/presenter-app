<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.    Em
 // Qudratli Xudoni sevaman.
. Am         Em
 Unga sano aytaman.
. Am           Em
 Tengsiz buyuk ishlarini,
. D         Em
 Madhiyalayman. //

[C1]
.     (Em) Am           Em
   // Birodar, opa-singillarim,
.    D        Em
   SHodlanib kuylanglar.
.   Am           Em
   Xursand boʻlinglar doimo,
.   D         Em
   Xudoga oʻynanglar. //

[V2]
 // Uning sinovi - marhamat.
 Sevgisi - inoyat.
 Izlaganga topilgan,
 Yoʻldir - Haqiqat //

[V3]
 // Buyukdir Uning sevgisi.
 His etib oʻynayman.
 Huzurida abadiy.
 Sano kuylayman. //</lyrics>
<key>Em</key>
<title>Kuylanglar va oʻynanglar</title>
<author>Timoʻtiy</author>
</song>