<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>123</hymn_number>
<author>Nelson Greg, Philip McHugh</author>
<lyrics>[V1]
.C#            Ab   F# C#           Ab
 Har kun inson koʻzida maʼnosiz kun koʻraman,
.Fm        Bbm           B            Ab
 Mavhumlik kunlar kutar, rangsiz xayollar.
.C#              Ab   F#  C#       Bbm
 Ogʻriq, qoʻrquv yurakda, alamli sevinch,
.F#m              C#    Ebm   Ab
 Kim ular qalbin bilar, faqat Iso.

[C1]
.  C#       F#     C#       F#
   Odamlar muhtoj, Xudoga muhtoj,
.  F          Bbm         F#   Ab
   Mazmunsiz boʻlsa hayot, Iso najot.
.  C#        F#     C#     F#
   Odamlar muhtoj, Xudoga muhtoj,
.  F            Bbm       Ebm Ab    C#
   Hamma kelsin huzuriga, odamlar muhtoj.</lyrics>
<key>F#</key>
<title>Odamlar Muhtoj</title>
</song>