<?xml version="1.0" encoding="UTF-8"?><song><author>New Sreation</author>
<title>Xudo biz bilan</title>
<lyrics>[V1]
 Joningni qurbon qilding,
 &quot;Gunohdan poklayin &quot;-deb!
 Bizlarga Najot berding,
 &quot;Azobda qolmasin&quot;-deb!

[V2]
 Poyingda sajda qilar,
 Elatu barcha xalqlar!
 Najotkor Masihliging,
 Bu dunyo tanib bilar!

[C1]
   // Xudo biz bilan boʻlsa,
   Kim bizga qarshi chiqar
   Masihning gʻalabasi,
   Abadiy hukm surar! //

[V3]
 Inoyatga boy Xudo,
 Ahdiga qildi vafo!
 Oʻlimni yenggan Iso,
 Ulugʻlangin doimo!

[V4]
 Shodlikka toʻla qalblar,
 Qudratingni kuylashar!
 Xudoning sevgisini,
 Kim bizdan tortib olar?!

[C2]
   // Xudo biz bilan boʻlsa,
   Kim bizga qarshi chiqar?!
   Masihning gʻalabasi,
   Abadiy hukm surar! //</lyrics>
</song>