<?xml version="1.0" encoding="UTF-8"?><song><title>Kimki, Xudoyi Taoloning panohida yashar</title>
<key>Cm</key>
<lyrics>[C1]
.     Cm            Eb
   // Kimki, Xudoyi Taoloning panohida yashar,
.  Fm           Ab       Bbm        Cm
   Qodir Tangri soyasida orom topar ekan. //
.     Fm(Eb)
   // U Xudovandga aytadi //
.     Eb            Fm             Eb
   // Oʻzingsan boshpanam, qasrim mening
.  Fm     Ab     Bbm     Cm
   Umidim faqat senda Xudoyim. //

[V1]
.Cm                  Eb
 Xudo meni ovchi qopqonidan ham
.Ab              Bbm   Cm
 Va vabo-qazodan xalos etar.
.Cm                  Fm     Eb
 U oʻz parlari bilan meni yopar,
.Eb                Ab   Bbm    Cm
 Qanotlari ostida behatar boʻlaman.
.Cm                              Bb
 Haqiqati menga qalqon va toʻsiq boʻlar,
.Eb        Ab           Bb
 Na tungi vahimadan qoʻrqaman.
.    Bbm                 Fm
 Na kunduzi uchayotgan oʻqdan,
.   Bb           Ab      Bb
 Na zulmatda kezuvchi vabodan,
.Bb                           Cm
 Na qiyom chogʻi qiruvchi oʻlatdan,
.Fm                         Bb
 Mening yonimda mingtasi yiqilib.
.Eb      Ab          Bb
 Tuman qulab ketsada oʻng yonimda
.Eb     Fm                Ab
 Balo qazo menga yaqin yoʻlamas.
.Cm                  Eb
 Men faqat koʻzlarim bilan boqib,
.Fm           Ab     Bbm        Cm
 Fosihlarga berilgan jazoni koʻraman.

[C2]
   Kimki, Xudoyi Taoloning panohida yashar,
   Qodir Tangri soyasida orom topar ekan.
   // U Xudovandga aytadi //
   // Oʻzingsan boshpanam, qasrim mening
   Umidim faqat senda Xudoyim. //

[V2]
.   Cm                     Fm       Eb
 // Xudovandni panohim deb bilganim uchun,
.Ab                      Bb     Eb
 Xaq Taoloni qoʻrgʻonim deganim uchun. //
.Ab                     Bb       Eb
 Tushmas boshimga biron bir falokat
.Fm            Ab         Bbm        Cm
 Yoʻlamas chodirimga ham qandaydir oʻlat.
.Cm                    Eb
 U oʻz farishtalariga men haqda amr etgay,
.Fm         Ab           Bbm      Cm
 Toki butun yoʻllarimda meni asrasinlar,
.Cm         Eb
 Ular meni qoʻllarida koʻtarib ketarlar,
.Fm      Ab            Bbm    Cm
 Oyogʻim ham toshga qoqilib ketmas.
.Cm                    Eb
 Sher va boʻgʻma ilon ustidan bosib oʻtaman.
.Fm        Ab      Bbm         Cm
 Arslon va ajdarni ezib tashlayman!

[V3]
.   Cm                      Fm   Bb     Eb
 // U menga mehr bergani uchun qutqazaman
.Ab                       Bb       Eb
 Nomimni tan olgani uchun omon saqlayman. //
.Fm                 Bb            Eb
 U meni chaqirgan chogʻida javob beraman.
.Fm       Ab       Bb          Eb
 Qaygʻuli kunida u bilan birga boʻlaman.
.Fm   Ab         Bb        Eb
 Uni halos etib hurmatga sazovor qilaman.
.Fm   Ab         Bbm            Cm
 Uzoq umr berib koʻnglini toʻygʻazaman,
.Cm             Eb
 Uzoq umr berib koʻnglini toʻygʻazaman,
.Fm         Ab    Bbm         Cm
 Najotkorligimni unga namoyon qilaman.</lyrics>
</song>