<?xml version="1.0" encoding="UTF-8"?><song><author>Lenny LeBlanc</author>
<lyrics>[V1]
.D            A      Hm
 Hech kim yoʻqdir Sendak,
.G          D     A
 Hech kim meni qalbimni shilmas!
.   D      A          Hm     G
 // Butun umr qidirib topolmadim,
.     D                A      D
 O Rabbim hech kim yoʻqdir Sendak! //

[V2]
 Sening qoʻling menda
 Men qoʻrqmayman
 Chunki Sen yonimda
 // Mening orzu - umidlarim bilan san
 O Rabbim hech kim yoʻqdir Sendak! //

[V3]
 Gunohlarimni oldi
 Chunki U aytadi: gunohlaring menda
 // Muhabbating bizga Rabbim topdi
 O Rabbim hech kim yoʻqdir Sendak! //

[V4]
 Hech kim yoʻqdir Sendak!
 Hech kim meni qalbimni chulgʻab!
 // Butun umr qidirib topolmadimb
 O Rabbimb hech kim yoʻqdir Sendak! //</lyrics>
<key>D</key>
<title>Hech kim yoqdir Sendak</title>
</song>