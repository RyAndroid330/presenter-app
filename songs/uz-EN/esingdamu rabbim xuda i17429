<?xml version="1.0" encoding="UTF-8"?><song><title>Esingdamu Rabbim Xuda</title>
<lyrics>[V1]
.   Em                   B
 // Esingdamu Rabbim - Xuda,
.Am               B            Em
 Toʻgʻri yoʻl koʻrsatganing menga?! //
.Am                    Em
 Esingdamu, qoʻlogʻ solmay,
.B           B7        Em
 Rabbim Seni rad, qilganim?!
.   Am                      Em
 // Hochga mihlanding oʻshanda,
.B           B7        Em
 Goʻnohlarim olib Oʻzinga! //

[V2]
 Kechir Rabbim, meni kechir,
 Senga toshlar otkanim oʻchun!
 Kechir Rabbim, meni kechir,
 Seni yomon deganim oʻchun!
 // Goʻnoh qilib yashabman, bilsam,
 Rabbim borligʻingni bilmay! //

[V3]
 Faqat Rabbim Sendan soʻrayman,
 Kechirgin goʻnohlarimni!
 Shohliging kelsin tezrogʻ,
 Abadiy yoningda boʻlay!
 Endi, Rabbim menman qoʻling,
 Koʻnglimga quvonchlar berding,
 // Abadiy hayotga ketarman,
 Hamiysha bahtiyod boʻlaman! //</lyrics>
<key>Em</key>
</song>