<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Iltijo</title>
<key>Fm</key>
<lyrics>[V1]
.Fm                    Bbm
 Iltijo qilganimda menga javob aylagin
.C              Fm
 Ey mening odil Xudoyim.
.Fm            Bbm
 Tang qolganimda Oʻzing najot bergansan,
.C                    Fm
 Yana menga mehribonlik koʻrsatgin

[P1]
.     Bbm         C          Ebm          F
   // Ibodatimga, ibodatimga, ibodatimga javob bergin //

[C1]
.          Bbm            C
   Koʻplar soʻramoqdalar kim bizga baxt-saodat keltirar ekan deb,
.  Fm
   Jamoling nurini ustimizga solgin
.  Bbm        C
   ey Xudovand, ey Xudovand.
.  Ebm                       F
   Ularning bugʻdoy va sharobi koʻpaygan biroq,
.      Bbm           C
   Sen mening dilimga shodlik berding koʻproq
.  Fm
   Osoyishta yotaman, ham uygʻonaman chunki
.  Bbm        C
   Ey Xudovand, ey Xudovand
.         Db      Bbm   C    Fm
   Xotirjamligimga yolgʻiz Sen posbon.</lyrics>
</song>