<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Hizirov</author>
<lyrics>[V1]
 // Men gunohni qaʼrida
 Savob ishdan narida //
 Adashgandim barida
 /// Xudoyim meni topdi ///

[V2]
 // Dildagi ezgu ishim
 Kimgadir kerilishim //
 // Gunoh edi qilmishim
 Xudoyim meni topdi //
 Xudoyim meni topdi

[V3]
 // Oʻz Oʻgʻlini men uchun
 Qurbon qildi oʻshal kun //
 // Gunohdan poklab butun
 Xudoyim meni topdi //

[V4]
 // Xushxabar berdi menga
 Barchamizga, ham senga //
 Yetkaz yosh qari tengga
 // Xudoyim meni topdi //</lyrics>
<title>Xudoyim Meni Topdi (anʼanaviy)</title>
</song>