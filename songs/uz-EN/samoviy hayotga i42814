<?xml version="1.0" encoding="UTF-8"?><song><title>Samoviy Hayotga</title>
<lyrics>[V1]
.   Dm       Am         Dm         Am
 // Masihim Najotkor, U bizlarga keldi,
.C        Bb      Am       Dm
 Nasihat kalomin bizlarga berdi.
.Dm      Am        Dm         Am
 Omadni, yangilik, baxtni keltirdi,
.C         Bb        Am        Dm
 Muqaddas soʻzlarga bizni toʻldirdi. //

[C1]
.     F       C       Gm      Dm
   // Samoviy hayotga bizni oʻrgatar,
.  F        C       Gm     Dm
   Osmon shohligiga Oʻzi kuzatar.
.  F         C        Gm       Dm
   Insonga yangi baxt berib qoʻyibdi,
.  F         C         Gm      Bb Am  Dm
   Osmonda yangi taxt qurib qoʻyibdi bizga. //

[V2]
 Kim gʻolib chiqsa gar ruhiy hayotda,
 Gʻalaba tojisin berib qoʻyibdi.
 Azizlar qoʻrqmanglar Masih biz bilan,
 Olamni yaratgan Xudo biz bilan.

[C2]
   // Samodan kelganga doim boʻlsin shon,
   Masihga doimo boʻlsin sharaf-shon.
   Chunki U olqish,maqtovga loyiq,
   Madhiya sanolar Unga munosib Iso. //</lyrics>
<key>F</key>
</song>