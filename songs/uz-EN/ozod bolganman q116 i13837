<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>116</hymn_number>
<title>Ozod boʻlganman Q116</title>
<lyrics>[C1]
.     Fm          Bbm
   // Ozod, ozod, boʻlganman
.  Fm         Bbm
   Gunohning zanjirindan
.  Fm            Bbm
   Xalos, xalos, boʻlganman
.  Fm(C#)    (Eb)  Bbm(Fm)
   Shaytonning quligindan! //

[V1]
.   Ab               Bbm
 // Qullikdan qutilganman, //
.   Ab            Bbm
 // Isoning qoni bilan, //
.   Ab                 Bbm
 // Yurakdan shod boʻlganman, //
.   Ab               Bbm
 // Xudoning Oʻgʻli bilan! //

[V2]
 // Ibrohimni boy qildi! //
 // Yoqubni duo qildi! //
 // Yusufni podshoh qildi! //
 // Bizlarni ozod qildi! //
 // Yusufni podshoh qildi! //
 // Bizlarni ozod qildi! //

[V3]
 // Osmonga yetib bordi, //
 // Azizlarning duosi! //
 // Muqaddas Ruh yubordi, //
 // Yuraklarning shifosi! //

[V4]
 // Osmon-u yer ham yoʻq boʻlar, //
 // Birgina sevgi qolar! //
 // Iso oldinda xalqlar, //
 // Bir kun kelib yiqilar! //</lyrics>
<key>Fm</key>
</song>