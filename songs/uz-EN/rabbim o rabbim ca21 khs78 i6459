<?xml version="1.0" encoding="UTF-8"?><song><aka>Meni Oʻzgartir</aka>
<key>D</key>
<lyrics>[V1]
.   D         Em  A          D
 // Haqiqat bilan meni oʻzgartir,
.Bm          Em   A          D
 Sendek boʻlayin, meni oʻzgartir! //

[C1]
.  F#      Bm     G     A     D
   Sen Kulolimsan, men esa loyman,
.  F#   F#7/Bm     G         A
   Yasab oʻzgartir, ibodatim shu!

[V2]
.D         Em A            D  Bm
 Haqiqat bilan, meni oʻzgartir,
.Bm          Em   A          D
 Sendek boʻlayin, meni oʻzgartir!

[C2]
.  G  A     F#m Bm
   Rabbim, o Rabbim!
.       Em       A Asus D7    B7
   qilay chin dildan Senga taʼzim!
.  G  A     F#m Bm
   Rabbim, o Rabbim!
.       Em       A            D
   qilay chin dildan Senga taʼzim!

[V3]
.D6 D4 A  G         A7
  U sizni butun muxabbati,
.    D           Bm
 ila toʻla qamrab olsin!
.     Em         A
 Butun sevgisini berib,
.    D      Bm      D7
 yurakka shodlik solsin!
.D6 D4 A  G         A7
  U sizni butun muxabbati,
.    D           Bm
 ila toʻla qamrab olsin!
.     Em         A
 Butun sevgisini berib,
.       D    Bm       D7
 qalblarga quvonch solsin!</lyrics>
<title>Rabbim, o Rabbim CA21 ҲС78</title>
<author>Eddie Espinosa</author>
