<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>47</hymn_number>
<title>Ijodkor, ijoding</title>
<lyrics>[C1]
.  Em           Bm               F#                G
   Ijodkor, ijoding orasida boʻlding sezmadi baʼzilar
.  Em            Bm                     F#             Bm
   Qancha moʻjizalar koʻrsatgan boʻlsangda bilmadi odamlar
.  Em             Bm             F#                G
   Barcha hamdu-Sano sen uchun Xudoyim ofarin barkamol
.     Em              Bm            F#                Bm(F#)
   // Kechirgin bizlarni tavba qilamiz afsus kech nadomad //

[V1]
.Bm         Em            Bm           G   F#m
 Iso Rabbim Senga shukuru shon-sharaf, mmm-mmm.
.Em                        Bm    F#
 Bizlar uchun pok qonin qurbon etgan
.Bm        Em           Bm           G  F#m
 Muhabbat, ofarin Senga shon-sharaf, mmm-mmm.
.Em                   Bm      F#
 Bizlar uchun azob-uqubat chekkan
.Bm       Em            Bm        G F#m
 Xudoyim, panohimdirsan har doim, mmm-mmm.
.Em                         Bm      F#
 Sen borsanki xotirjamdir tanamda jonim
.Bm       Em             Bm           G  F#m
 Ojizman, Sen Oʻzing bilasan Xudoyim, mmm-mmm.
.Em                     Bm     F#
 Ergashay, yetaklagin Oʻzing borim

[B1]
.     Bm              Em           F#
   // Ofarin Xudoyim, shukur Egam, shukur Egam mening //
.  Bm                        Em        F#
   Madhiya olqishlar boʻlsin bir Senga Rabbimiz.
.     Bm                    Em         F#
   // Shon-sharaf, mmm-mmm, Hamdu Sano ofarin //
.  Bm                        Em        F#
   Madhiya olqishlar boʻlsin bir Senga Najotkorimiz.
.     Bm                    Em         F#
   // Shon-sharaf, mmm-mmm, Hamdu Sano ofarin //</lyrics>
<key>Em</key>
</song>