<?xml version="1.0" encoding="UTF-8"?><song><title>Buyuk taxting oldiga kelaman Q61</title>
<aka>Yuragim bilan</aka>
<key>D</key>
<lyrics>[V1]
.   D                    A
 // Buyuk taxting oldiga kelaman,
.Bm                        G  A
 Shuhratingni yogʻdirgin Xudoyim!
.D                      A
 Senga, yaqin boʻlishni istayman,
.Bm                        G  A
 Shuhratingni yogʻdirgin Xudoyim! //

[C1]
.               D           A
   // Yuragim bilan, Senga ishonaman!
.            Em   G        Bm  A
   Yuragim bilan, men Seni sevaman!
.            D            A
   Yuragim bilan, Senga intilaman!
.            Em   G        Bm   A
   Yuragim bilan, men Seni izlayman! //</lyrics>
<author>Malohat Pulatova</author>
<hymn_number>61</hymn_number>
</song>