<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Yigit oʻz yoʻlini qanday qilib sof saqlar
   Sening Kaloming bilan yursa bu bajo boʻlar //

[V1]
 Men Seni chin koʻngildan qidirmoqdaman
 Amrlaringdan bosh tortishimga yoʻl qoʻyma
 Senga qarshi gunoh qilmasdan
 Kalomingni yuragimda saqlayman
 // Ey Xudovand, Senm olqishlayman
 Qonun-qoidalaringni menga oʻrgatgin //

[V2]
 Ogʻzingdan chiqqan barcha hukmlarni
 Oʻz irnim bilan xabar qilaman
 Sening vahiylaring yoʻlida men
 Katta boylik topganday xursand boʻlaman
 Buyruqlaringni teran oʻylab
 Sening yoʻllaringga koʻz tikaman
 // Nizom qoidalaringdan zavq topaman
 Unutmayman Kaloming Sening //</lyrics>
<title>Yigit oʻz yoʻlini qanday qilib sof saqlar</title>
</song>