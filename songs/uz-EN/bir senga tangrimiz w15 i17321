<hymn_number>23</hymn_number>
<title>Bir Senga Tangrimiz W15</title>
<key>Bm</key>
<lyrics>[V1]
.   Bm
 // Bir Senga Tangrimiz
.Em
 Iltijo ayladik
.Bm    F#     G  F#
 Omonat foniy dunyoda
.Bm                Em
 Muqaddas Rabbimiz sevgingga, rahmingga
.Bm        F#  Bm
 Mehringga hamdu sano. //

[C1]
.     G                     D
   // Qiynalgan chogʻlarda panohiy madadkor
.  Em        G     D F#
   Najotkor Sen Rabbimiz
.  Bm                 Em
   Najotli ahdingga, sevgingga, rahmingga
.  Bm         F#    Bm
   Mehringga hamdu sano //

[V2]
 // Mehribon Otamiz, osmonlarda mavjud
 Qudratli gʻolibona
 Muqaddas Rabbimiz sevgingga, rahmingga
 Mehringga hamdu sano. //</lyrics>
</song>