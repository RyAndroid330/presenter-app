<?xml version="1.0" encoding="UTF-8"?><song><key>Ebm</key>
<lyrics>[V1]
.Ebm        C#      B         Bb
 Xudoning shahrida billurdek tiniq,
.Ebm        C#      B       Bb
 Oʻz hayot daryosi bizlarga oqar.
.   Ebm        Abm     Ebm     C#
 // Xudoning shahrida hayot daraxti,
.B         C#       Abm        Bb  (Ebm)
 Barglari xalqlarga shifo uchun yoqar. //

[C1]
.  Ebm                   C#       Ebm
   Ruh bugun seni kelgin deb chorlaydi,
.  Ebm            B          C#     Ebm
   Eshitgan kishi ham keling deb aytsin.
.     Abm        B          F#      C#
   // Chanqagan kelsin va xohlagan kelsin,
.  Ebm      B            C#   Ebm
   Hayot suvidan tekin bahra olsin. //

[V2]
 Boshqa hech qanday laʼnat qolmaydi,
 Xudoning va qoʻzinig taxti oldida.
 // Boshqa tun boʻlmaydi, quyosh boʻlmaydi,
 Lek Xudoning nuri porlar samoda. //</lyrics>
<title>Hudoning shahrida Q193</title>
<hymn_number>193</hymn_number>
</song>