<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.   E            A  E
 // Isoning qoni meni oqladi,
.B             E           A
 Isoning qoni meni ozod qildi.
.E            A E  B    C#m
 Isoning qoni meni butunlay,
.  F#m      B      E
 Gunohlarimdan oqladi. //

[C1]
.     E            A    F#m   B
   // Senga shon-sharaf Iso Masih,
.  B             E   B7   C#m
   Senga shon-sharaf Iso Masih.
.  E            A    F#m  B
   Senga shon-sharaf Ota Xudo,
.                E
   Oʻgʻling Iso uchun. //

[B1]
.  E
   Iso gʻalaba qildi,
.  A           B
   Iso gʻalaba qildi
.  F#m                C#m           B
   U kasallarimizni va Gunohlarimiz oldi,
.  E
   Iso gʻalaba qildi,
.  A             B
   Iso gʻalaba qildi,
.     A         B             E
   Rahmat Senga Ota Oʻgʻling uchun.</lyrics>
<title>Isoning Qoni Meni Oqladi ҲС24 ҲСХМ10</title>
<author>Jack Schrader</author>
<hymn_number>72</hymn_number>
</song>