<?xml version="1.0" encoding="UTF-8"?><song><title>Xudo uchun mayliga</title>
<lyrics>[V1]
 // Qoʻshnilarim toʻylar qilib
 Aytmasalar mayliga //
 // Doʻstim deb yurganlarim
 Yuzimga ursalar mayliga //

[V2]
 // Qarindoshlar qaramasdan
 Yuz oʻgirsalar mayliga //
 // Izzatimni tuproqlarga
 Qorsalar ham mayliga //

[V3]
 Mahallada qoʻshnilar
 Gap qilsalar mayliga
 Dinin sotgan deb meni
 Tosh otsalar mayliga

[V4]
 Rabbim Oʻzi kelib
 Bir kun olib ketadi
 Samoviy jannatidan
 Yaxshi joylar beradi</lyrics>
<aka>Qoʻshnilar toʻylar qilib</aka>
</song>