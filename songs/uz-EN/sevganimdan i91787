<?xml version="1.0" encoding="UTF-8"?><song><title>Sevganimdan</title>
<lyrics>[V1]
 // Qarsak chalaman Rabbimga qoʻshiq aytaman
 Uning nomini tinmay sheʼrga bitaman
 Shodlanaman Rabbimni ulugʻlaganimda
 Oʻynab kulaman Rabbimni sevganimdan //

[C1]
   // Sevganimda uning nomini koʻylayman
   Sevganimdan uni ulugʻlayman
   Sevganimda uning nomini koʻylayman
   Sevganimdan uni ulugʻlayman //

[V2]
 // Keling doʻstlar birgalashib oʻynab kuylaylik
 Qarsak chalib oʻyin kulgu hozir qilaylik
 Rabbim meni sevadi sizni ham xuddi shunday
 Oʻz quvonchini beradi sizga sevganimdan //</lyrics>
</song>