<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D           A      Em           A
 // Xochda, xochda u yerda men oʻlganman,
.     D        A     Em    A   D
 Bu sevgi qalbimda daryoday oqadi. //

[C1]
.         Bm      F#m
   Hayot berdi U menga,
.          G     F#m
   quvvat berdi ruhimga,
.        G        F#m
   Umid berdi hayotimga,
.   G        A
   Hayotim Seniki.

[V2]
 // Xochda, xochda u yerda men oʻlganman,
 Bu sevgi qalbimda daryoday oqadi. //

[C2]
.          Bm           F#m
   Shon-shuhrating men bilan,
.          G        F#m
   Kuch-qudrating qalbimda,
.        G       F#m
   Marhamating hayotimda,
.   G        A
   Hayotim Seniki.</lyrics>
<title>Xochda ҲСХМ125</title>
<hymn_number>125</hymn_number>
</song>