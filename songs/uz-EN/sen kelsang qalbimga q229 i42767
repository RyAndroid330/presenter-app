<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.Dm                   Gm
 Sen kelsang qalbimga abadiy bahor,
.A                        Dm
 Koʻklam quvonchi kelar yurgimga.
.Dm                      Gm
 Men uchun quyosh boʻlib porlasang Rabbim,
.Bb              A
 Engib oʻtardim zulmatlarni.

[C1]
.                Gm
   // Sen mening qoyamsan Rabbim,
.                  Dm
   Deb ulugʻlayman Seni nomingni.
.           F
   Muqaddas Ruhing ila,
.           C
   toʻldirding Sen qalbimni.
.         Gm
   Abadul abad Sen bilan
.               A
   Tinchlanar mening bu qalbim,
.      Dm(A)
   Najotkorim.  //

[V2]
 Sen kelsang qalbimga abadiy tinchlik,
 Sening sevging toʻla yuragimga.
 Men uchun quyosh boʻlib inoyat qilsang,
 Unutardim barcha armonlarni.</lyrics>
<title>Sen kelsang qalbimga Q229</title>
<hymn_number>229</hymn_number>
</song>