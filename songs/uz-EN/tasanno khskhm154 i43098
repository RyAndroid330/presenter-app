<?xml version="1.0" encoding="UTF-8"?><song><author>Hillsong, Reuben Morgan</author>
<hymn_number>154</hymn_number>
<key>C</key>
<lyrics>[V1]
.   C          G       C
 // Kuchsizlar kuchli boʻlur,
.    F             Am
 Kambagʻallar boy boʻlur.
.C         G      C
 Ojizlar nurni koʻrur.
.       G        C
 Xudo sevgisi shudir. //

[C1]
.  G           Am
   Tasanno, tasanno,
.  F           C
   Osmondagi Xudoga.
.  G           Am
   Tasanno, tasanno,
.  C           G  C
   Qutqaruvchi Isoga.

[V2]
 // Mehringga choʻmdirgansan,
 Gunohdan oqlagansan.
 Mazmunli hayot berib,
 Quvonchga toʻldirgansan. //</lyrics>
<title>Tasanno ҲСХМ154</title>
</song>