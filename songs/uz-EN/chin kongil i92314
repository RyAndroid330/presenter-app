<?xml version="1.0" encoding="UTF-8"?><song><title>Chin Koʻngil</title>
<lyrics>[C1]
   /// Chin koʻngildan yolvorayapman
   Menga javob bergin e Xudovand ///
   Chin koʻngildan yolvorayapman
   Sening qonun-qoidalaring saqlayman

[V1]
 // Senga yolvorayapman qoʻtqargin meni
 Toki shaodadinga sodiq qolayin //
 // Sahar chogʻi toʻrib nola-yu figʻon qilaman
 Sening soʻzinga umid bogʻlayman //

[C2]
   // Chin koʻngildan yolvorayapman
   Menga javob bergin e Xudovand
   Chin koʻngildan yolvorayapman
   Sening qonun-qoidalaring saqlayman //

[V2]
 // Kalomingni fikr qilib tunni tongga oʻlayman
 Koʻzlarimga uyqu bermayman aslo //
 // Inoyat qilib ovozimni eshitgin yo Rabbim
 Adolat qilib menga jon bergin //

[C3]
   // Chin koʻngildan yolvorayapman
   Menga javob bergin e Xudovand
   Chin koʻngildan yolvorayapman
   Sening qonun-qoidalaring saqlayman //

[V3]
 // Fisq fasot payida boʻlgan buzuq niyatlilar
 Qonuningda uzoqlashib menga yaqinlashdilar //
 // Biroq sen juda yaqinsan ey Xudovand
 Barcha amrlaring esa haqiqatdir //

[C4]
   Chin koʻngildan yolvorayapman
   Menga javob bergin e Xudovand
   Vahiylaring azaliy deb
   Men sen ularni barqaror qilgansan
   Chin koʻngildan yolvorayapman
   Menga javob bergin e Xudovand
   Chin koʻngildan yolvorayapman
   Sening qonun-qoidalaring saqlayman
   Sening qonun-qoidalaring saqlayman</lyrics>
</song>