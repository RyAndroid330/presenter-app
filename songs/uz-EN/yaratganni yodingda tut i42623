<?xml version="1.0" encoding="UTF-8"?><song><title>Yaratganni yodingda tut</title>
<lyrics>[V1]
.Em                                      Am
 Dunyoga keltirgan seni, hayotda asragan seni,
.Am                           B                 Em
 Oʻgʻlim deb saqlagan seni, YAratganni yodingda tut.
.Em                                      Am
 Dunyoga keltirgan seni, hayotda asragan seni,
.Am                         B                 Em
 Qizim deb saqlagan seni, YAratganni yodingda tut.

[C1]
.    Em                D                          Am
   YAralding, dunyoga kelding, koʻz ochib dunyoni koʻrding,
.                      D                            B
   Yaxshi yomon ishlar qilding, Yaratganni yodingda tut.
.  Em                 Am      D                        G
   Hayot sirli hamda tartibi, ham quvonchli, ham tashvishlidir,
.     Em                  Am        B                   Em
   // Ming bir boylikdan qimmatdir, Yaratganni yodingda tut. //

[V2]
.Em                 D                   Am
 Dunyo charx urib aylanar, odam Xudosiz qiynalar,
.Am               D                         B
 Yaratganni istab oʻyla, Yaratganni yodingda tut.
.Em                Am        D          G
 Yomon kunda yoningdadir, yuragingda joningdadur,
.   Em                 Am      B                Em
 // Soyaboning yoningdadur, Yaratganni yodingda tut. //

[V3]
.   Fm                                          Bbm
 // Bu dunyoga hech quvonma, mol mulkingga hech suyanma,
.                             C                   Fm
 Yor doʻstungga hech ishonma, Yaratganni yodingda tut. //
.    Bm              C                     Fm
 Yor doʻstungga hech ishonma, Yaratganni yodingda tut
.   Fm            Fm
 // yodingda tut, yodingda tut
.Bm        C      Fm
 Yaratganni yodingda tut
.Fm                 Bbm        C                 Fm
 Yodingda tut, joningda tut, YAratganni yodingda tut. //</lyrics>
