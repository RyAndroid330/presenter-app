<?xml version="1.0" encoding="UTF-8"?><song><key>F#m</key>
<lyrics>[C1]
.     F#m        E
   // Osiy edim, yuvding mani,
.  F#m         E
   gunohlarim quvding mani. //
.     A(D)       (C#)
   // El ichida suyding mani //
.        E               F#m
   Parvardigorim, Parvardigorim.

[V1]
.   A            B            D   E      F#m
 // Qudratingdin yoʻqdin yana bor aylagaysan,
.A            B            D    E     F#m
 Gunoh qilsam keng jahonni tor aylagaysan. //
.   A              E       C#m           F#m
 // Tavba qilmas osiylarni xor aylagaysan ey, //
.E          F#m
 Zor aylagaysan.

[C2]
   // Osiy edim, yuvding mani,
   gunohlarim quvding mani. //
   // El ichida suyding mani //
   Parvardigorim, Parvardigorim.

[V2]
 // Mana endi kech boʻlsada keldim qoshingga,
 Rahm aylading koʻzdan oqqan achchiq yoshimga. //
 // Bu ne baxtki qoʻling qoʻyding gʻamli boshimga, //
 Gʻamli boshimga.

[V3]
 // To tirikman madhingni men kuylab oʻtarman,
 Xushxabaring eling ichra bayon etarman. //
 Kuni kelsa shohligingga men ham ketarman,
 Kuni kelsa huzuringga // bir kun borarman. //</lyrics>
<title>Osiy edim suydim meni Q137</title>
<hymn_number>137</hymn_number>
</song>