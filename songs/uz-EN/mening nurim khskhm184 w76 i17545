<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>184</hymn_number>
<lyrics>[V1]
.Em               C       G        D
 Mening Nurim, Najotkorim, Xudovandim!
.Em            C         G  D
 Hayotimsan, YUpatuvchim , Madadkorim!
.E                  G
 Xudovandimdan bir tilagim bor,
.     D                Bm
 Faqat oʻshani men izlayman:
.    Em            C
 Xudovand uyida umrbod turishni,
.G        D
 Men istayman!

[C1]
.      Am    C         Em    D
   Xudovandimdan bir tilagim bor,
.       Am    C  D        Bm
   Faqat oʻshani men izlayman!
.       Am   C         Em   D
   Butun yuragim, butun vujudim,
.       Am       C
   Butun ongim bilan,
.            D                 Bm
   Uni (Seni) sevishni men istayman!</lyrics>
<key>Em</key>
<title>Mening Nurim ҲСХМ184 W76</title>
</song>