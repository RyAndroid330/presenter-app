<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Hammadan buyuk Rabbim Isodir
   Har ishdan muhim, ulugʻ Xudodir //

[V1]
 // Seni tanladim kechib oʻzimdan
 Senga qarshi boʻlgan qaro koʻzlardan //

[V2]
 // Sen borsan, haq Yoʻlim ey Najotkorim
 Senga ishongayman, yoʻq doʻst-u yorim //
 // Shayton hujum qilmas kor qilmas sira
 Sendan voz kechmasman Sen endi jonim //

[V3]
 // Senga ishonganim uchun asraysan
 Qoʻlimdan tutasan tashlab qoʻymaysan //
 Sen sodiq Doʻstimsan, Sen Vafodorim
 // Seni sevib adashmadim suyangan togʻim //</lyrics>
<title>Hammadan Buyuk Rabbim</title>
</song>