<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>183</hymn_number>
<key>Eb</key>
<lyrics>[V1]
.(Eb)             Fm     Bbm                Cm
 Zamona oxirlab qoldi, bu dunyo huvullab qoldi,
.Fm        Am         C#    Bbm              Cm
 Xudo Shohligi yaqin qoldi, tavba qiling odamlar.

[C1]
.  Eb                     Fm     Bb      Eb
   Azaldan Kalom bor edi, azalda Xudoda edi.
.    Fm                  C#            Bbm     C#      Cm
   Kalom inson boʻlib dunyoga keldi, tavba qiling odamlar.

[V2]
.Cm           Fm    Bbm                     Eb
 Najot eshigi tordir, bu yoʻldan yurganlar ozdir,
.Fm             Bbm     Fm             Cm
 Erga keldi Iso Masih, tavba qiling odamlar.

[C2]
   Azaldan Kalom bor edi, azalda Xudoda edi.
   Kalom inson boʻlib dunyoga keldi, tavba qiling odamlar.

[B1]
.  Ab                    Bbm             Eb(Cm)
   Oxiratni oʻylanglar, haqiqatni tinglanglar,
.  Ab                      Bbm          Eb(Cm)
   Gunohdan qutulinglar, tavba qiling odamlar.
.  Cm      Fm              Bbm            Cm
   Tavba qilish inoyatdir, Haqni yurakka soldi,
.  Fm      Bbm     Ab       Bbm            Cm
   Oxirgi murojaat boʻldi, tavba qiling odamlar.</lyrics>
<title>Zamon oxirlab qoldi Q183</title>
</song>