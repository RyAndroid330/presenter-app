<?xml version="1.0" encoding="UTF-8"?><song><title>Yupating Meni Rabbim (anʼanaviy)</title>
<aka>Koʻrsangiz Koʻz Yoshimni</aka>
<lyrics>[V1]
 // Koʻrsangiz koʻz yoshimni
 Chilparchin bardoshimni //
 Silab asta boshimni
 Yupating meni Rabbim

[V2]
 Maftun qilsa gar dunyo
 Aldasa qilib riyo
 Qalbimga sochib ziyo
 // Yupating meni Rabbim //

[V3]
 // Toʻldiring Ruhingizga
 Sodiq qolayin men Sizga //
 // Sinovlar kelsa bizga
 Yupating meni Rabbim //

[V4]
 // Oʻrgating itoatni
 Sabr ila toqatni //
 // Bilmasam ibodatni
 Oʻrgating meni Rabbim //

[V5]
 // Najotkorim Oʻzingiz
 Har bir aytgan Soʻzingiz //
 Muhtojman Sizga xargiz
 // Yupating meni Rabbim //</lyrics>
<author>Ravshan Hizirov</author>
</song>