<?xml version="1.0" encoding="UTF-8"?><song><title>Sogʻindim</title>
<lyrics>[V1]
 // Kechayu kunduz Rabbim
 Xayolimdan sen chiqmaysan //
 // Qoʻllarimda sening kaloming
 Sevib sevib menga gapirasan //

[C1]
   /// Oh mening Rabbim
   Tangrim
   Seni juda koʻp sogʻindim ///

[V2]
 // Kalomlaringni men oʻqiganda
 Yurak bagʻrim meni quvonar //
 // Bir xursinib qoʻyganimda
 Seni sogʻinganim sezilar //

[B1]
   // Osmonlarga termulsam uchgim keladi
   Seni jamolinga
   Toʻygim keladi //

[C2]
   // Oh mening Rabbim
   Tangrim
   Seni juda koʻp sogʻindim //
   Sogʻindim</lyrics>
</song>