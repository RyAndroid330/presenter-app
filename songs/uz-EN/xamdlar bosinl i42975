<?xml version="1.0" encoding="UTF-8"?><song><key>A</key>
<lyrics>[V1]
.E                               C#m
 Hamdlar, boʻlsin, hamdlar ayting Xudoga.
.F#m                            E
 Xudovand nomiga, hamdu sano aytinglar.
.   E                          C#m
 // Xudovand nomiga olqishlar boʻlsin,
.F#m                              E
 Hozirdan boshlab, to mangudekga qadar. //

[C1]
.     E                       C#m
   // Kun chiqqandan, to kun botarga qadar,
.  F#m                        E
   Xudovand ismiga maqtovlar boʻlsin. //

[V2]
.   E                        F#m      E
 // Xudovand barcha xalqlar ustidan oliydur,
.E                  F#m        E
 Ulugʻvorligi esa osmondan balandur. //
.   E                      C#m         F#m
 // Rabbimiz Xudovand yuksaklarda oʻtiribdur,
.E           C#m    B          E
 Unga oʻxshaydigan kim ham bor ekan? //

[V3]
.E                   C#m
 U ham, yer ham koʻkdagilarni koʻray deya,
.A                          E
 Tubanlikga engashib nigoh tashlar.
.E                            C#m
 Bechora holini, U tuproqdan koʻtarar,
.A                        E
 Faqrni axlatdan olib yuksaltirar.
.A
 Ularni elning ulugʻlari bilan,
.C#m                            E
 Oʻz xalqining beklari bilan oʻtqazar.
.   A                         F#m
 // Tugʻmas ayolni U uyida unashtirar,
.                               E
 Uni farzandlar onasi qilib quvontirar. //</lyrics>
<title>Xamdlar Boʻsinl</title>
</song>