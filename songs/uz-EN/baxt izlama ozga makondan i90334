<?xml version="1.0" encoding="UTF-8"?><song><title>Baxt izlama oʻzga makondan</title>
<lyrics>[V1]
 // Baxt izlama oʻzga makondan.
 Baxtsizman deb oʻylama aslo //
 // Baxt aslida Xudo yaratgan,
 Pok qalbingda boʻlgaydir paydo //

[V2]
 // Pok qalbingni asragin doim,
 Gʻam-gʻussalar unga kirmasin, //
 // Senda aslo hukm surmasin,
 Na bir alam, na bir musibat //

[V3]
 // Xudo seni Oʻz suratida,
 Benuqson-u, goʻzal yaratgan. //
 // Har insonni juft boʻlsin deya,
 Erkak uchun ayol yaratgan. //
 Baxt izlama oʻzga makondan
 Baxtsizman deb oʻylama aslo

[V4]
 // Biz ne uchun nolib yashaymiz?
 Ne istasak hamma narsa bor, //
 // Faqat koʻngling kengroq qil doʻstim.
 Shunda senga dunyo boʻlmas tor! //
 Chin yurakdan shukrona aytib,
 Yashamoqqa imkonimiz bor,
 // Chunki har tong bizga yangi kun!
 Yaratuvchi Xudovandim bor. //
 Baxt izlama oʻzga makondan
 Baxtsizman deb oʻylama aslo!</lyrics>
</song>