<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Cm        Fm
 // Osmondan najot keldi,
. Ab      Gm
 Xudodan xabar keldi.  //
.   Fm             Ab
 // Insonlarning kalbina
.   Fm          Gm   Cm
 yarqiragan nur keldi.  //

[C1]
.     Fm
   // Ozodlik yoʻlin berdi,
.  Ab               Gm   Cm
   yorugʻlik yoʻlin berdi.  //
.     Fm
   // Insonlarning kalbina
.  Ab             Gm  Cm
   yarqiragan nur keldi.  //

[V2]
 // Nur zulmatda porladi,
 zulmat qoplay olmadi.  //
 // Har nainki ot boʻlsaya
 Iso bilan yaraldi.  //

[V3]
 // Nur borinda yuringlar,
 Unga xizmat etinglar.  //
 // Sevgisidan totinglara
 ruhindan ruhlaninglar.  //

[V4]
 // Yaratganning nomidan
 men roziman Oʻgʻlidan,
 Bergan yorqin yoʻlidan
 shodlanaman koʻnglimdan.  //</lyrics>
<key>Cm</key>
<title>Osmondan najot keldi Q167</title>
<hymn_number>167</hymn_number>
</song>