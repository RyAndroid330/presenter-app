<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Masih Keladi Qayta</title>
<lyrics>[V1]
.   Dm          Hb         F    A
 // Koʻzlarimni yo Rabbim Senga tikaman,
.Dm         Hb F         A
 Tezroq kelgin Seni kutaman. //
.Hb             Dm
 Najotkorim Sen Iso Masihim,
.Hb                    F          A
 To oʻlguncha Seni men kuylab oʻtaman.

[C1]
.       Dm     Hb              Dm    Hb
   //// Iso Masih keladi qayta. ////

[V2]
 // Seni oʻylab har kuni tunlarim bedor,
 Ibodatda koʻzlarim Senga intizor. //
 Har biringizga boʻlsin Xudo yor,
 Osmon Shohligi topsin barqaror.

[C2]
   //// Iso Masih keladi qayta. ////

[V3]
 // Sendan minnaddorman barhayot Ota
 Iso Masih albatta keladi qayta, //
 Yerdagi farzandlaring Seni kutadi,
 Bergan najotingga shukurlar aytib.

[C3]
   //// Iso Masih keladi qayta. ////</lyrics>
<key>Dm</key>
</song>