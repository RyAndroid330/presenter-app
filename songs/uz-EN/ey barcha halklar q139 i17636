<?xml version="1.0" encoding="UTF-8"?><song><title>Ey barcha halklar Q139</title>
<key>F#m</key>
<lyrics>[V1]
.   F#m
 // Yey, barcha xalqlar,
. Bm         F#m  E      F#m
 Xudovandni madh qilinglar! //
.                E         F#m
 // Unga hamdu - sano aytinglar
.B#m       F#m E F#m
 Ey, butun millatlar! //

[C1]
.     F#m              Bm
   // Hamdlar boʻlsin! Hamdlar boʻlsin!
.   F#m E      F#m
   Hamdlar boʻlsin! //

[V2]
.   F#m                         E    F#m
 // Uning bizga bergan inoyati behaddir! //
 // Abadiydur Xudovandning
.          E    F#m
 Vafosiyu haqiqati! //

[C2]
   // Hamdlar boʻlsin! Hamdlar boʻlsin!
   Hamdlar boʻlsin! //
   Hamdlar boʻlsin! Hamdlar boʻlsin!</lyrics>
<hymn_number>139</hymn_number>
<author>Zafar</author>
</song>