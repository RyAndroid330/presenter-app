<?xml version="1.0" encoding="UTF-8"?><song><title>QUDRATLI XUDO</title>
<lyrics>[V1]
 KELING HALQLAR,
 KOʻRING XUDO ISHLARIN, U BUYUK
 KAMON, OʻQNI PARCHALAB,
 JANGLARNI U TOʻHTATAR
 OH ISROIL QODIR XUDOSI
 SEN BIZ TOMONDA
 BUYUK XUDO BILAN OLGʻA BORAMIZ IYMONDA

[C1]
   XUDOVAND BIZ BILAN
   OLOVDA BIZ BILAN
   BOʻRONDA BIZ BILAN
   PANOHIMIZ U
   U OLIB OʻTAR
   OGʻIR JANGLAR UZRA
   BIZ BILAN HAR YERDA
   QUDRATLI XUDO

[V2]
 YOQUB XUDOSI QUDRATLI,
 LARZA OVOZIDA
 BORLIQ TAʼZIM ETAR,
 TOGʻLAR QOLAR SUV OSTIDA
 U ODAMZOD NIYATLARIN BILIB
 SABR ETAR
 MAGʻRUR TOGʻLAR TITRAB,
 RABBIM SENGA TAʼZIM
 QILAR
 MAGʻRUR TOGʻLAR TITRAB, RABBIM SENGA TAʼZIM QILAR

[B1]
   DENGIZ TOSHIB, BOʻRON KELSA
   ULARNI SEN TINCHLATARSAN
   YURAGIMNI SEN SAQLAYSAN
   OSTIN-USTUN BOʻLSA YERLAR
   SHOVQIN KOʻTARSA BU HALQLAR
   XUDO HAMMASINI USHLAR</lyrics>
<author>Shane&amp;Shane</author>
</song>