<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>51</hymn_number>
<title>Iso yoʻldir, U haqiqat Q154</title>
<aka>Oʻzbekiston</aka>
<lyrics>[V1]
 // Oʻzbekiston Xudo soʻzin eshit,
 Oʻzbekiston Unga qara. //

[C1]
   // Iso yoʻldir, U haqiqat,
   Iso hayotdur, olamga bugun. //

[V2]
 // Uning oldida har bir jon tiz choʻksin,
 Iso hamma uchun Rabbiy. //

[V3]
 // Butun xalqlar uchun faqat bitta yoʻl bor,
 faqat bitta Iso Masih, //

[V4]
 // Oʻzbekiston Xudo soʻzin eshit,
 Oʻzbekiston Unga qara. //</lyrics>
</song>