<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>98</hymn_number>
<author>Malohat Pulatova</author>
<title>Sevging hayot berdi menga Q98</title>
<lyrics>[V1]
.Gm Cm F Bb Gm
  
.Gm Cm D7 Gm
  
.   Gm         Cm           D7            Gm  Gm7
 //  Sevging hayot berdi menga, mening Rabbim!
.Gm  G                  G7            Cm
  O__rom topdim huzuringda, mening Rabbim!
.          D7                       Gm
 Qilgan qurbonligingni men qabul qildim,
.         Cm          Eb           D7
 Sening qoning bilan Iso, men oqlandim! //

[C1]
.  D7          Gm   Gm6
    // Hayotim Sen uchun,
.  Gm        Cm
   Borligʻim Sen uchun,
.             F
   Sevgim ham Sen uchun,
.            Bb D7   (Gm)
   Mening Rabbim! //

[V2]
 // Sen doimo yonimdasan, mening Rabbim,
 Har bir kunimda tayanchim, mening Rabbim,
 Sening Soʻzing yoritadi hayot yoʻlim,
 Faqat Senga ishonaman mening Rabbim!!! //

[V3]
 Endi butun hayotimni mening Rabbim,
 Sening qoʻlingga topshirdim, mening Rabbim.
 Senga xizmat qilaman men butun umrim,
 Faqat kalomingga Iso men ishondim.</lyrics>
<key>Gm</key>
<aka>Xayotim Sen uchoʻn</aka>
</song>