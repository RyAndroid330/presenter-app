<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>45</hymn_number>
<title>Vatan boʻm boʻshligiga qaragin ҲСХМ45</title>
<key>G</key>
<lyrics>[V1]
.G           D            Em
 Vatan boʻm boʻshligiga qaragin
.          C        Am        D
 Osmondagi Xudovand Rahm shafqatli Otamiz
.G         D             Em
 Bizning gunohlarimizni kechirgin
.Am                 D
 Vatanimizni shifolagin
.G         D             Em
 Hammamiz Sen bilan bir tan boʻlib
.              C       Am      D
 Yurtimizning buzilgan poydevorin qurganimizda
.G       D            Em
 Butun gunohlarimizni yondiradigan
.Am        F            D
 Muqaddas Ruh olov tushsin

[C1]
.  G                    Em
   Uygʻonish alangasi yona versin
.  Am                          D
   Haqiqat Kalomi yurtimizni yangilagin
.  G                   Em
   Inoyat daryosi oqa versin
.  Am                      D
   Muqaddas shamol esa vergin

[B1]
.     G    Bm           Em      C Am      D
   Ey ulugʻvorlikka toʻlgan yangi kun kelgin
.         G      Bm         Em Am D      G
   Sening shohliging shu yerga Tezroq kelsin</lyrics>
</song>