<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Ey Xudo, yuragim Senga sodiq</title>
<lyrics>[V1]
 // Ey Xudo, yuragim Senga sodiq,
 Jonim boricha Seni kuylab kushik aytaman. //

[C1]
   Sodiq Sevging - samolardan ham yuksakdir,
   Sadoqating - bulutlardan ham balanddir.
   Ey Xudo, falakdan ham yuqori yuksalaver,
   Shuhrating butun zamin uzra yoyilsin.

[V2]
 // Oʻng quling ila gʻalaba ato kilgin,
 Iltijoyimga javob bergin Sendan najot topayin. //

[B1]
   // Senga hamdu-sano kuylayman,
   Senga hamdu-sano kuylayman
   Ellar orasida Noming ulugʻlayman! //</lyrics>
</song>