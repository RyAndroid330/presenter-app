<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>33</hymn_number>
<lyrics>[V1]
 Xudo sevar, menga ayon,
 Imonsizlar bunga xayron,
 Qaygʻurar U men uchun,
 Men zaifman, Xudo ustun,
 Xalleluya, Iso Masih.

[V2]
 Rahm shafqat inoyatda,
 Azob chekdi Iso xochda,
 Gunohlarim U oldi,
 Va qalbimdan joy oldi,
 Xalleluya, Iso Masih.

[V3]
 Senga Rabbim tashnadirman,
 Faqat Senda topinaman,
 Sening nuring porlar menda,
 Va oʻchmas bu qalbimdan,
 Xalleluya, Iso Masih.</lyrics>
<title>Xudo sevar ҲСХМ33</title>
</song>