<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16581</hymn_number>
<author>Sobir Umurov</author>
<title>Donolik</title>
<key>Bm</key>
<lyrics>[V1]
.Hm                   Em
 Donolikni kumush izlaganday izlasang,
.       F#
 Xazina qidirganday qidirsang,
.        Hm         F#
 Xudo Kimligini bilasan.

[V2]
.     Hm            Em
 Donolik nasihatlarini qabul qilsang,
.       F#
 Amrini yuragingda saqlasang,
.       Hm                   H
 Egamizdan qoʻrqish nimaligin tushunasan.

[C1]
.       G      A       D      G
   Chunki donolikni Egamiz beradi,
.    Em       F#        Hm           H
   Bilim va idrok Uning Oʻzidan chiqadi,
.         G       A        D           G
   Egamiz toʻgʻri odamni eson-omon saqlaydi,
.       Em             F#          Hm
   Toʻgʻri yuradiganga Oʻzi qalqon boʻladi.</lyrics>
</song>