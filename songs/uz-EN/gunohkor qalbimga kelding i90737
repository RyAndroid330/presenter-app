<?xml version="1.0" encoding="UTF-8"?><song><author>Ulugʻbek Joʻrayev</author>
<title>Gunohkor qalbimga kelding</title>
<lyrics>[V1]
.Em          D          Em
 Gunohkor qalbimga kelding
.Em               D         C
 Va shohligingni Sen oʻrnatding
.   Am             D        G      Em
 // Oʻzgartirding meni Sen Rabbim qalbimni
.Am           D            Em
 Endi ozod boʻldim gunohlardan //

[V2]
.Em                 D     Em
 Sendan voz kechmasman aslo
.Em             D       C
 Kaloming tutarman qalbimda
.   Am            D         G      Em
 // Sevgi qanotingda saqlading doimo
.      Am         D          Em
 Kechirib Sen qilgan gunohlarim //

[B1]
.  G        D   Am           Em
   Butun dunyo Nomingga sano aytar
.  G        Am      G      Em
   Barcha jonzod Seni ulugʻlar
.  C            G
   Muqaddassan Mehribon Xudoyim
.  G       Am  D        Em
   Ulugʻlayman abadiy Seni</lyrics>
<key>Em</key>
</song>