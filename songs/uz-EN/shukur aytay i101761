 Chiroq yoqqin yoʻllarimga
 Rahmat Ulugʻ Otajonim
 Bagʻringga olganingga

[C2]
   // Shukur aytay har onda,
   Sen bergan har bir kunda //

[V3]
 Akkord:
.Em Bm
 -__
.C  D
 -__</lyrics>
