<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23003</hymn_number>
<author>Sobir Umurov</author>
<lyrics>[V1]
.   Hm
 // Agar uxlab qolgan boʻlsang
.F#
 Iso seni seni uygʻotadi
.G
 Agar holdan toygan boʻlsang
.F#
 Iso senga senga yordam beradi //

[C1]
.     Hm
   // Kuch-qudratim Iso de
.  F#
   Mening oromim Iso de
.  Hm
   Har qanday toʻsiqlarni
.  F#
   Iso bilan yengaman de //

[V2]
.Hm
 Agar togʻdek muammo boʻlsa ham
.F#
 Agar yaqinlaring yuz oʻgirsa ham
.G
 Agar senga ogʻir botsa ham
.F#
 Ne boʻlsa ham Masihda baxt topasan</lyrics>
<key>Bm</key>
<title>Kuch Kudratim Iso</title>
</song>