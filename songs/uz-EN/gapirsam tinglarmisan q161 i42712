<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>161</hymn_number>
<title>Gapirsam tinglarmisan Q161</title>
<key>Eb</key>
<lyrics>[V1]
.Cm                    C#
 Gapirsam tinglarmisan yoʻqsa laʼnatlarmisan?
.Eb                   C#               Cm
 Gapiraman tingla sen ham, Iso hayotin bergan.

[C1]
.  Cm               C#
   Xudo sevdi seni Xushxabardir bu,
.  C#               Gm
   Qutqardi seni gunohdan.
.  Ab                     C#
   Najotli qurbonni, berdi U Masihni,
.  C#                Cm
   Sen ham qoʻshil hayotga.

[V2]
 Quloq berdingmi bu soʻzga, bu xabar hammamizga,
 Keling endi Masihga, qoʻshiling jannat yoʻliga.</lyrics>
</song>