<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>225</hymn_number>
<key>Cm</key>
<lyrics>[V1]
.Cm           Ab         Cm
 Qanchalar Xudoyim kechiraman,
.Cm           Ab        Cm
 Qanchalar Xudoyim kechiraman.

[C1]
.     Fm           Bb
   // Hammani kechiraman,
.      Eb            Cm
   Sen bilan boʻlish uchun.
.  Fm           Bb        Cm
   Qanchalar Xudoyim kechiraman. //

[V2]
.  Cm                G
 YEtmishdan yetmish marta
.G                 Cm
 Etmishdan yetmish marta
.Cm                 Fm
 Etmishdan yetmish marta
.Eb
 kechiraman.

[C2]
.  Fm            Bb
   Hammani kechiraman,
.         Eb            Cm
   // Sen bilan boʻlish uchun.
.  Fm            Bb        Cm
   Qanchalar Xudoyim kechiraman. //</lyrics>
<title>Qanchalar Xudoim kechiraman Q225</title>
</song>