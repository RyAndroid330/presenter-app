<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4</hymn_number>
<key>D</key>
<lyrics>[V1]
.Bm            A           G       Bm
 Hech nimadan qoʻrqma, men yoningdaman,
.Bm          A        G        Bm
 Qorongʻu yoʻlingda yoritqichingman.
.   Bm         A      D       Bm
 // Bulutlarni yorib porlar nurlari,
.Bm              A   G          Bm
 Men sen bilan doim hech qoldirmayman. //

[C1]
.  Bm       Em     A
   Men yolgʻiz emasman,
.  A         D      Bm
   Hech yolgʻiz emasman.
.  Bm       Em      A
   Rabbim mening yonimda,
.  A         D     Bm
   Hech yolgʻiz emasman.

[V2]
 Gullar soʻlib qolsin, quyosh ham botsin,
 Qoʻshiqlar dilimni hech qoldirmasin.
 // U mening quvonchim kechayu kunduz,
 Meni bu dunyoda qoldirmaydi yolgʻiz. //

[V3]
 Yoʻlim xiralanib, xavf solar gʻanim,
 Ravshan eshitaman, men Sen ila doim.
 // Samoda men yaqqol koʻrsam yuzingni,
 Qoʻshigʻimda deyman qoldirmaydi meni. //</lyrics>
<title>Xech nimadan Q4</title>
</song>