<?xml version="1.0" encoding="UTF-8"?><song><title>Noʻmon mohovlikdan</title>
<key>E</key>
<lyrics>[V1]
.E           B     A         E
 Noʻmon moxovlikda juda azob chekkan,
.E              A            B      E
 Unga boylik va shuhrat yordam bermagan.
.E                       A
 Elishay Xudosi yolgʻiz qutqaradi,
.E                    B      E
 Butunlay uni sogʻlom qila oladi.

[C1]
.  E     A       B        E
   Xudo qodir, U juda qudratli,
.  E     A        B       E
   Xudo qodir, chaqiraman Uni.
.  E      A      E
   Xudo qodir, aybimni olishga,
.  E    B  E
   Xudo qodir.

[V2]
 Gunoh moxovlikdan biz juda charchadik,
 Boylik va odamlar yordam berolmaydi.
 Faqat buyuk Xudo bizni qutqaradi,
 Iso orqali yangi hayot beradi.

[C2]
   Xudo qodir, U juda qudratli,
   Xudo qodir, chaqiraman Uni.
   Xudo qodir, aybimni olishga,
   Xudo qodir.</lyrics>
</song>