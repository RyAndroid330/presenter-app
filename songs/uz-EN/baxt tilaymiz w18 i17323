<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>18</hymn_number>
<lyrics>[V1]
 Baxt tilaymiz
 Sizlarga kelib, qoʻshigʻim kuylayman
 Qoʻshigʻim sizlarga, boʻlsin tabrik
 Sizlarga baxt tilayman, tilayman tinchlik
 Sizlarga Xudodan marhamat tilayman

[V2]
 // Sizlarga baxt tilaymiz //
 Sizlarga Xudodan marhamat tilaymiz

[V3]
 Keling aziz doʻstlar bu qoʻshiqni kuylaylik
 Qoʻshigʻim sizlarga, boʻlsin tabrik
 Keling ularga, baxt tilaylik
 Ularga tilaylik Xudodan sevgi.

[V4]
 // Sizlarga sevgi tilaymiz //
 Sizlarga Rabbimdan sevgi tilaymiz.

[V5]
 Barchamiz birga bu qoʻshiqni kuylaylik
 Qalbimizdagi tilaklar, sizlarga tabrik
 Sizlarga baxt tilaylik, sizlarga baxt
 Ularga Parvardigordan tinchlik tilaylik.</lyrics>
<aka>Tabrik</aka>
<title>Baxt tilaymiz W18</title>
</song>