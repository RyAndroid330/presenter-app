<?xml version="1.0" encoding="UTF-8"?><song><title>Hiylagar tun zindonidan</title>
<lyrics>[V1]
.   G                        D       Bm
 // Hiylagar tun zindonidan, ozodlik ravshaniga
.Em            G             D
 Muqaddas Ruh, boshla meni doim //

[C1]
.     Bm
   // Muqaddas Ruh bu dunyodan
.  G              D
   Tor yoʻl bilan mangu hayot
.  Em          G             D
   Osmon tomon boshla meni doim //

[V2]
.   G                    D          Bm
 // Dunyo vasvasa sinov, mukammal imon tayanch
.Em            G            D
 Kamolot iloh, Kalomida hikmat //</lyrics>
<key>G</key>
<hymn_number>282</hymn_number>
</song>