<?xml version="1.0" encoding="UTF-8"?><song><author>Bethel Music</author>
<lyrics>[V1]
.Em     C      G          D
 Unutmayman meni ozod qilganing
.Em     C     G            D
 Yuragimni tundan olib chiqqaning
.Em          C
 Sen topding, qutqarding,
.G        D           Em
 Suvlarni ikkiga boʻlding
.   C   D
 Yo Rabbim!

[C1]
.       Em
   Xudo men uchun jangda,
.          C
   Har bir gʻalaba unda
.      G           D
   Haleluyya, Haleluyya
.       Em
   Xudo dengizni boʻldi,
.        C
   Ummondan U utkazdi,
.      G           D
   Haleluyya, Haleluyya.

[V2]
.Em       C    G         D
 Kunduzlari bulut ila kuzatding
.Em      C   G           D
 Kechalari olov ila boshlading
.Em           C
 Sen topding, qutqarding,
.G        D           Em
 Suvlarni ikkiga boʻlding
.   C   D
 Yo Rabbim!

[B1]
.      C
   Men-chun misrga kelding
.       D
   Qoʻllarimdan tutding
.     Em
   Vaʼda qilgan yerga Sen
.     G
   Meni yetaklading
.     C
   Seni men unutmayman
.      D
   Ishlaring kuylayman
.        Em
   Buyuk sevging bilan Rabbim
.       G
   Oʻlimni Sen yoʻq qilding</lyrics>
<key>Em</key>
<title>Misrga kelding</title>
</song>