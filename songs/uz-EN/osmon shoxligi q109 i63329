<?xml version="1.0" encoding="UTF-8"?><song><title>Osmon Shoxligi Q109</title>
<key>A</key>
<lyrics>[V1]
.   A              D(Bm)   F#m(A)
 // Osmon shohligi ochildi bizga,
.D               Bm     D     F#m
 Xudo Muqaddas Ruhin yubordi bizga. //
.   A            Bm     E        A
 // Jonim bilan qoʻshiq aytayin Sizga,
.D          Bm           D    C#  F#
 Dardlarga davo boʻlsin hamdu sanolar. //

[C1]
.     F#m   A        Bm
   // Hamdu sanolar, hamdu sanolar,
.  D         Bm           C#     F#m
   Dardlarga davo boʻlsin hamdu sanolar. //

[V2]
.   F#m      A          Bm
 // Egamizga yaqinlashaylik,
.E            A
 Gunohlardan uzoqlashaylik. //
.Bm            E    A
 Qalb koʻzimiz koʻr boʻlmasin hech,
.D          C#      D     C#  F#m
 Yaratganga boʻlsin hamdu sanolar.

[C2]
   // Hamdu sanolar, hamdu sanolar,
   Yaratganga boʻlsin hamdu sanolar //

[V3]
.   F#m                    E
 // Yomonlarga gʻashlik qilmaylik,
.D           C#         F#m
 Badkirdorga havas qilmaylik. (2m) //
.A             Bm       E     A
 Qalb koʻzimiz koʻr boʻlmasin hech,
.Bm        E   A
 Yaratganga boʻlsin hamdu sanolar.

[C3]
   Hamdu sanolar, hamdu sanolar
   Yaratganga boʻlsin hamdu sanolar.
   Hamdu sanolar, hamdu sanolar,
   Dardlarga davo boʻlsin hamdu sanolar.</lyrics>
<hymn_number>109</hymn_number>
</song>