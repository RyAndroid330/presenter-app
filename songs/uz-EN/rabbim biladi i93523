<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<lyrics>[V1]
 // Agar biz Masih bilan birga oʻlgan boʻlsak
 U bilan birga ham yashaymiz
 Agar qiyinchiliklarga chidasak
 U bilan birga hukmronlik qilamiz //

[P1]
   Bordiyu uni rad etsak
   U ham bizni rad etadi
   Sodiq boʻlmasak ham Masih
   Sodiq boʻlib qolaveradi

[C1]
   // Egamiz biladi
   Egamiz sevadi
   Egamiz kutadi
   Oʻzinikilarni biladi //</lyrics>
<title>Rabbim Biladi</title>
</song>