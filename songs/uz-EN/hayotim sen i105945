<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Dunyo aldab meni
 Qoldirsa dogʻda
 Bulbullar boʻlmasa
 Men kezgan bogʻda //
 Senga muhtoj boʻlsam
 Yiqilgan chogʻda
 Hayotim Sen bilan
 Yodim Sen bilan!

[V2]
 Kuylab avj pardasin
 Torlarin chertdim
 Hayotim, umrimni
 Baxshida etdim.
 Ohista boʻlsada
 Ortingdan ketdim
 // Hayotim Sen bilan
 Yodim Sen bilan! //

[V3]
 Kel endi, kelaqol
 Mehrim, ardogʻim
 Men uchun Sevgisi
 Bagʻri qaynogʻim
 Sen kutim oʻtsin
 Har kunim, chogʻim
 // Hayotim Sen bilan
 Yodim Sen bilan! //

[V4]
 Dunyo aldab meni
 Qoldirsa dogʻda
 Bulbullar boʻlmasa
 Men kezgan bogʻda
 Senga muhtoj boʻlsam
 Yiqilgan chogʻda
 Hayotim Sen bilan
 Yodim Sen bilan</lyrics>
<title>Hayotim Sen</title>
<author>Ravshan Hizirov</author>
</song>