<?xml version="1.0" encoding="UTF-8"?><song><title>Yuragimda Umidim Bor ҲСХМ193</title>
<key>Ab</key>
<lyrics>[V1]
.Em   C        G
 Yuragimda umidim bor,
.Em          C         G
 Chunki Sen menda yashaysan.
.F           C          G         D
 Faqat Sen istaganday inson boʻlaman.
.   F                 D
 // Seni bilishni xohlayman. //

[V2]
 Yuragimda umidim bor,
 Chunki Sen menda yashaysan.
 Faqat Sen istaganday inson boʻlaman.
 Faqatgina sevgingda yashay desam
 Hayotimda Sen keraksan.

[C1]
.     G                    C
   // Sen uchun men yashayman,
.            Em     D          C
   Butun hayotim Sening qoʻlingda.
.  G                    C
   Sen uchun men yashayman,
.             Em      D         C
   Va men orqali dunyoni oʻzgartir. //

[B1]
.     G
   // Sen keraksan
.   D              Em
   Sen keraksan menga
.  C
   Rabbim. //</lyrics>
<hymn_number>248</hymn_number>
</song>