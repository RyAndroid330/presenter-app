<?xml version="1.0" encoding="UTF-8"?><song><title>Yullaringni yoritgan Nur</title>
<key>Em</key>
<lyrics>[V1]
.      Em
 Yoʻllaringni yoritgan Nur
.       C
 Kimligini tanib bilgin
.    G
 Vujudinga yashayotgan
.       D
 Haq Xudoni tanib bilgin
.    Em
 Jaroxatlar evaziga.
.   C
 Oklangansan ey inson!
.     G
 Gunoxlardan butunlay
.      D
 Poklangansan sen ishon!

[C1]
.     Am                C
   // Shon - sharaf Tangrim Senga
.     G          D
   Hamdu sano Najotkorimga //

[V2]
.    Em
 Xudovandning irodasi:
.      C
 Sen abadiy yashashingdir
.       G
 Shu muqaddas hayotingni
.      D
 Poklikda saklashingdir

[C2]
.     Am               C
   // Shon - sharaf Tangrim Senga
.     G          D
   Hamdu sano Najotkorimga //

[B1]
.  C                  Em
   Xa Tangrim hayotim Senga tegishli
.  Am                D
   Vujudim Sen uchun abadiy Mabad
.  C                     Em
   Men Tangrim ortingdan borarman abad
.  Am                    D
   Shu hamdlar tilimdan tushmaydi har vaqt</lyrics>
