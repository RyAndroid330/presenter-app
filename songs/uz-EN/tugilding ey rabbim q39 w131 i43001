<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>39</hymn_number>
<key>A</key>
<lyrics>[V1]
.A                          D          A
 Tugʻilding, ey Rabbim, Sen bir pok qizdan,
.A                   D        A
 Muqaddas Ruh bilan jisming tuzilgan.

[C1]
.     D                 A
   // Muso va Dovuddek insondan emas,
.  D                 A
   Xudoning Ruhidan toʻliq tuzilgan. //

[V2]
.A                     E        A
 Dilimga oʻchmas bir chiroqni yoqding,
.E                          A
 Chiroq deb aytishga tilim bormaydi.

[C2]
.     D                A
   // Masihning Oʻziku hatto quyoshdek,
.  D                        A
   Bir oq nur kabi oʻchmay porlaydi. //

[V3]
.A                          D          A
 Tugʻilding, ey Rabbim, Sen bir pok qizdan,
.A                   D           A
 Muqaddas Ruh bilan jisming tuzilgan.

[C3]
.     D                A
   // Muso va Dovuddek insondan emas,
.  D                        A
   Xudoning Ruhidan toʻliq tuzilgan. //

[V4]
.A                  E          A
 Dilimga Sen yoqgan oʻchmas bu chiroq,
.E                             A
 Boʻron, shamolda ham oʻchib qolmaydi.

[C4]
   // Uning manbasidir Sening oloving,
   Abadul-abad yashab porlaydi. //

[V5]
.A                E           A
 Butunlay oʻzimni topshirdim Senga.
.E                            A
 Iso, Sen bir ulugʻ Najotkor boʻlgach,

[C5]
   // Hamisha madhiya aytaman shunda,
   Qalbimda Sen uchun muhabbat toʻlgach. //</lyrics>
<title>Tugʻilding, ey Rabbim Q39 W131</title>
</song>