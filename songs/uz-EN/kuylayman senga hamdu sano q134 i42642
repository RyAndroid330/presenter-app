<?xml version="1.0" encoding="UTF-8"?><song><title>Kuylayman Senga hamdu sano Q134</title>
<aka>Rabbim Seni olqishlashni istayman</aka>
<lyrics>[V1]
.   Em                         B
 // Rabbim Seni olqishlashni istayman,
.Am        B       Em
 Va Sendan minnatdorman.
.Em                      B
 Birgina Sen mening umidimsan,
.Am        B       Em
 Men Senga xizmatkorman. //

[C1]
.     Em               Am
   // Kuylayman Senga hamdu sano,
.  D                 G
   Kuylayman Senga Masihim.
.  C                       Am
   Chunki Sen qiynalding begunoh,
.  B                    Em
   Yaratuvchi Seni sevdim ey. //

[V2]
.   Em                         B
 // Qachon men yoʻllarimda yiqilsam,
.Am         B        Em
 Koʻrdim Seni kuyishingni.
.Em                   B
 Qachon nola bilan intilsam
.Am         B      Em
 Men Sendan minnatdorman. //

[V3]
.   Em              B
 // Masihim men bilmabman,
.Am        B       Em
 Qanday Sen mehribonsan.
.Em                   B
 Sen bir daqiqada kechirasan,
.Am         B    Em
 Va yurakni nurlaysan. //</lyrics>
<key>Em</key>
<hymn_number>134</hymn_number>
</song>