<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Osmonga</title>
<key>Gm</key>
<lyrics>[V1]
.   Gm      Eb   F     Gm
 // Osmonga koʻzlaring tikgin
.Gm      Eb  F    Gm
 U yerda Rabbimiz kutar
.Gm    Eb     F     Gm
 Isoni eslab kelgin doʻstim
.Gm     Eb       F      Gm
 Shunda qalbing tinchlik topar. //

[C1]
.     Gm      Eb    F
   // Faqat Uning yoniga
.  Gm         Eb       F
   Yuragingni ochgin Masihga
.  Gm      Eb     F
   Faqat Uning soʻziga
.  Em         Eb        F
   Ishonib mahkam tur imonda. //

[V2]
 // Qoʻrqmagin qiyinchilikdan
 Oʻzi Rabbim Sen bilan
 Yuz oʻgirmagin Isodan
 Shunda baxtli boʻla olasan. //</lyrics>
</song>