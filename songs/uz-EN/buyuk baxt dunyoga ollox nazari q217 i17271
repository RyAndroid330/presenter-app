<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>217</hymn_number>
<author>Zafar</author>
<key>Ab</key>
<lyrics>[V1]
.   Ab               Eb
 // Buyuk baxt dunyoga Xudo nazari,
.Db        Eb          Ab     Db Eb
 Olam olam tan olar uning haqligin.
.Ab                Eb
 Har bir inson Unga bagʻishlar qalbin,
.Db        Eb   Ab
 Madh etar uni jannat-la zamin. //

[C1]
.  Gb       Db     Dbm        Ab
   Berdi U dunyoga muhabbatni haqiqatni,
.  Gb       Db      Dbm     Ab
   Ato etdi basharga vatan ila millatni.
.  Gb          Db   Dbm       Ab
   Uning ishqi erur ilohiy bir moʻjiza,
.  Gb        Db     Dbm        Ab
   Haq va goʻzalligin namoyon etar bizga.

[V2]
 // Rabbimiz buyuk baxt dunyoga buyuk Xaloskor,
 Jon borki Uning butun mehriga maftun.
 Dovonlar, qir-adirlar shafaqlar takror,
 Kuylaydi Xudoning sevgisin mamnun. //</lyrics>
<title>Buyuk baxt dunyoga Ollox nazari Q217</title>
</song>