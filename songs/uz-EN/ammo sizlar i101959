<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8</hymn_number>
<lyrics>[V1]
.G                  Bm
 Ammo sizlar, tanlangan avlod
.C                        Am
 Shohanshoh ruhoniylar, Muqaddas halq
.D7     G        E7
 Xudoning aziz qavmisizlar
.Am            D7
 Xudo sizni qorongʻulikdan
.C             Am
 Oʻzining nuriga davat etgan
.C                 D     Bm    E7
 Sizni chaqirgan, ulugʻvor Xudoni
.Am    D7            C  G
 Maqtaymiz Xudoni O, Xamdu-sano.</lyrics>
<key>G</key>
<title>Ammo sizlar</title>
</song>