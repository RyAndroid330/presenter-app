<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am                    Dm
 Dardimni Senga aytib, Otajonim madad ber,
.   Bb               Dm       Gm            Am
 // Bu gʻam gʻurbat dunyodan olib chiqqin Masihim. //
.Am                   Dm
 Men adashgan edimku, Sen meni topib olding,
.   Bb            Dm        Gm            Am
 // Hayotimni oʻzgartirib, abadiy hayot berding. //

[V2]
 Rabbim Senga tashakkur, inson boʻlmasin noshukur.
 // Bu shaytonning kulbasi yonib ketar bir kuni. //
 Mayli Rabbim Sen uchun azob cheksam chekayin,
 // Sen oʻtgan izlaringdan men ham bosib oʻtayin. //

[V3]
 Dardimni Senga aytib, Otajonim madad ber,
 // Bu gʻam gʻurbat dunyodan olib chiqqin Masihim. //
 Men adashgan edimku, Sen meni topib olding,
 // Hayotimni oʻzgartirib, abadiy hayot berding. //</lyrics>
<title>Dardimni Senga aytib</title>
</song>