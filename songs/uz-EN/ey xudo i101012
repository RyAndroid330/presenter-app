<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ey Xudo
 Menga inoyat qilib
 Mehribonlik koʻrsatgin
 Cheksiz rahm-shavqating toʻfayli
 Qonunsizlik ishimdan kechib yuborgin //

[C1]
   Qilmishimdan qonunsizlik deb tan olaman
   Qilgan gunohim koʻz - ungimdadur
   Bu gunohlarim bu gunohlarim
   Bu xatolarim

[V2]
 // Men senga faqat senga qarshi gunox qildim
 Sening koʻz oldingda yomonlik qildim
 Sen esa soʻzingda doim barhaqsan
 Hukm qilganingda faqat odilsan //

[C2]
   // Qilmishimdan qonunsizlik deb tan olaman
   Qilgan gunohim koʻz - ungimdadur
   Bu gunohlarim bu gunohlarim
   Bu xatolarim bu xatolarim //</lyrics>
<title>Ey Xudo</title>
<author>QURBON MUKUMOV</author>
</song>