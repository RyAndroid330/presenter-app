<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am                G
 Egam meni qutqardi
.   G             Am
 Xizmatiga tanladi.
.Dm           Am
 Iso Masih sevgisi.
.E            Am
 Inoyatga toʻldirdi.

[C1]
.  Am               G
   Kalomi bilan Isoning,
.  E           Am
   Shifolanar qalblar.
.  Dm            Am
   Qutqarilib zulmatdan,
.  E            Am
   Ozod boʻlar xalqlar.

[V2]
.Am                  G
 Qudratiga toʻldirib.
.   G                Am
 Muqaddas Ruh qamradi.
.Dm           Am
 Xushxabar aytib joʻshib,
.E              Am
 Iso tilda yangradi.</lyrics>
<title>Ishayo 61:1</title>
<author>Baurjon Poʻlatov</author>
</song>