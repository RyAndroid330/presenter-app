<?xml version="1.0" encoding="UTF-8"?><song><title>Buyuklarning Buyugisan</title>
<aka>Sening Nomingda</aka>
<key>E</key>
<lyrics>[V1]
.   Cm             B            Ab
 Sening nomingda, men najot topdim,
. C                         Fm
 Ulugʻ Sening noming Iso Masih!
.   Fm            Gm          Cm/A
 Sening noming menga shifo berdi,
.       Fm          Gm      Cm
 Men kuylayman nomingni - abadiy!

[C1]
.          Cm(Eb)              B    Ab
   // Buyuklarning, buyugisan Iso, Iso!
.       Fm
   Muqaddaslar Xudosisan,
.         B    Gm
   Ulugʻlangin doimo! //
.     (Cm)
   Doimo!

[V2]
.     Cm            B               Ab
 // Oppoq, kiyimlarga meni kiyintirding,
.  C                       Fm
 Ulugʻ Sening noming Iso Masih!
.    Fm        Gm          Cm/Ab
 Gunohlarim uchun azob chekding,
.       Fm         Gm        Cm
 Men kuylayman nomingni - abadiy! //</lyrics>
<author>Malohat Pulatova</author>
</song>