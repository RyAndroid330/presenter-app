<?xml version="1.0" encoding="UTF-8"?><song><author>Ravshan Hizirov</author>
<title>Rabbim Sizni Izlayman (anʼanaviy)</title>
<lyrics>[V1]
 // Yuragimda ogʻir tosh
 Ezar bagʻrim, yoʻq bardosh
 Qoʻzlarimdan oqib yosh
 Rabbim Sizni izlayman... //

[V2]
 // Kular koʻzim yolgʻonchi
 Shodon soʻzim yolgʻonchi //
 Qalbimda bir &quot;talonchi&quot;
 /// Rabbim Sizni izlayman... ///

[V3]
 Yukim ogʻir yelkamda
 Doim u kam, bu kamda
 Yashayman doim gʻamda
 // Rabbim Sizni izlayman... //

[V4]
 // Keling hayotimga Siz
 Har bir bayotimga Siz //
 Ojizman endi Sizsiz
 Rabbim Sizni izlayman...

[V5]
 Haqiqat Sizda Rabbim
 Yoʻl, Hayot Sizda Rabbim
 // Hamdlar kuylaydi qalbim
 Rabbim Sizni izlayman... //</lyrics>
<aka>Yuragimda Ogʻir Tosh</aka>
</song>