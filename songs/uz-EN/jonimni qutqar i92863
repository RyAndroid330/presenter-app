<?xml version="1.0" encoding="UTF-8"?><song><author>Kurbon</author>
<hymn_number>15867</hymn_number>
<title>Jonimni qutqar</title>
<aka>Dodu figʻonimga</aka>
<key>Fm</key>
<lyrics>[V1]
.C#               Fm
 Dodu figʻonimga, quloq solgani uchun
.G#                D#
 Men Xudovandni sevaman
.C#                  Fm
 Qulogʻini men tomon tutgani uchun
.C#                         D#
 Umrim boricha Uni men chaqiraman
.C#                           Fm
 Oʻlim toʻrlari meni chulgʻab oldi
.G#                            D#
 Doʻzax azoblari boshimgʻa tushdi

[C1]
.  G#                   D#
   Yo Xudovando jonimni qutqar dedim
.  A#m           Cm         Fm
   Xudovand mexribon va odildir
.  G#                 D#
   Ha Xudoyimiz rahmdildir
.  A#m           Cm              Fm
   Xudovand soddadil odamlarni asrar

[V2]
.C#                               Fm
 Juda siqildimu dard alamga qoldim
.G#                                D#
 Oʻshanda Xudovand ismini chaqirdim
.C#                           Fm
 Ojiz qolganimda Oʻzi meni qutqarar
.G#                   D#
 Ey jonim rohatingga qaytgin
.C#                            Fm
 Mana Xudovand senga ezgulik qilgan
.G#                        D#
 Jonimni oʻlimdan koʻzimni yoshdan

[C2]
.  G#                          D#
   Yo Xudovando jonimni qutqar dedim
.  A#m           Cm         Fm
   Xudovand mexribon va odildir
.  G#                  D#
   Ha Xudoyimiz rahmdildir
.  A#m          Cm               Fm
   Xudovand rahmdil odamlarni asrar

[V3]
.C#                          Fm
 Oyogʻimni esa qoqilib ketishdan
.G#                   D#
 Oʻzing tiygansan yo Rabbim
.C#                     Fm
 Men tiriklar diyorida qolaman
.C#                      D#
 Xudovand huzurida yuraveraman

[C3]
.     G#                          D#
   // Yo Xudovando jonimni qutqar dedim
.  A#m           Cm         Fm
   Xudovand mexribon va odildir
.  G#                 D#
   Ha Xudoyimiz rahmdildir
.  A#m           Cm              Fm
   Xudovand soddadil odamlarni asrar //</lyrics>
</song>