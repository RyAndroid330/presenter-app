<?xml version="1.0" encoding="UTF-8"?><song><title>Ey Xudovand</title>
<lyrics>[V1]
.   Am             C              Em
 // Ey Xudovand, yuzimni yorugʻ qilgin. //
.Am             C            Em
 Chunki Men, pokdil boʻlib yurdim.
.Em                  Am       G
 Xudovandga tayanib, ikkilanmadim.
.   G              Am    C  D     Em
 // Ey Xudovand, yuzimni yorugʻ qilgin. //

[C1]
.  Am                D          G
   Sening inoyating koʻzim oldidadur.
.  Am              D            G
   Men Sening haqiqating ila yurdim.
.  Em            C     Am  D        G
   Yolgʻonchi odamlar, aro oʻtirmasman.
.  Em         Am       D       G
   Yurmasman ham hiylagarlar bilan.
.     G              Am    C  D     Em
   // Ey Xudovand, yuzimni yorugʻ qilgin. //

[V2]
.Em                    C    D      Em
 Halol qoʻllarimni, chaydim Men Xudovand.
.Em                     C         D    Em
 Sening qurbongohingni, aylanib chiqurman.
.Em            C     Am     D     G
 Senga shukronalar, ayturman har dam.
.Em            C      Am   D  G
 Moʻjizangni, birdek hikoyat etib.
.   G              Am    C  D     Em
 // Ey Xudovand, yuzimni yorugʻ qilgin. //
.   C  D     Em
 // Yorugʻ qilgin! //</lyrics>
<key>G</key>
</song>