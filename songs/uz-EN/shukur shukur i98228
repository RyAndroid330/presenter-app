<?xml version="1.0" encoding="UTF-8"?><song><title>Shukur! Shukur!</title>
<lyrics>[V1]
 Shukur qilaylik
 Rahmat aytaylik
 Rabbimizga
 Barchasi uchun

[V2]
 Rahmat tinmasin
 Shukur toʻxtamasin
 Minnatdor boʻlaylik
 Barchasi uchun

[C1]
   Nafas uchun
   Hayot uchun
   Borliq uchun
   Shukur! Shukur!
   Najot uchun
   Kechirim uchun
   Jannat uchun
   Shukur! Shukur!

[V3]
 Tushkun boʻlganda ham
 Qaygʻu bosganda gʻam
 Tiz choʻkib doʻstim
 Shukur qilaylik

[V4]
 Umid soʻnsa ham
 Sizni yutsa gʻam
 Koʻzlar ham boʻlsa nam
 Shukur qilaylik

[V5]
 Akkord:
.Am
 Akkord
. Em
 Akkord
.F
 Akkord
.G
 Akkord</lyrics>
<key>Am</key>
<author>Ulugʻbek Joʻrayev</author>
</song>