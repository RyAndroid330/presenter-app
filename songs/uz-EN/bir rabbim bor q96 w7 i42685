<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>96</hymn_number>
<title>Bir Rabbim bor Q96 W7</title>
<aka>Zulmatdan yoʻl</aka>
<lyrics>[V1]
 Zulmatdan yoʻl ochgan bir Rabbim bor,
 Shaytonni yengib chiqqan bir Rabbim bor.
 // Endi U Otaning oʻng qoʻl tarafida,
 Menga pok nur sochgan bir Rabbim bor, //
 bir Rabbim bor.

[V2]
 Sevgidan dars bergan, bir Rabbim bor,
 Aybsiz dunyoga kelgan, bir Rabbim bor,
 // Gunohimga berib kechirim,
 Issiq quchogʻin ochgan, bir Rabbim bor. //
 bir Rabbim bor.

[V3]
 Odam sirin bilgan, bir Rabbim bor,
 Menga sevgisin bergan, bir Rabbim bor.
 // Qonin men uchun toʻkkan, bir Rabbim bor,
 Issiq quchogʻin ochgan, bir Rabbim bor. //
 bir Rabbim bor.

[V4]
 Sevmasam ham sevgan, bir Rabbim bor,
 Oʻrnimga qurbon boʻlgan, bir Rabbim bor.
 // Rahmsiz xochga mixlangan bu,
 Menga qalbin ochgan, bir Rabbim bor. //
 bir Rabbim bor.

[V5]
 Oʻlimdan ham tirilgan, bir Rabbim bor,
 Mangulik hayot bergan, bir Rabbim bor.
 // Qonin men uchun toʻkkan, bir Rabbim bor,
 Issiq quchogʻin ochgan, bir Rabbim bor. //
 bir Rabbim bor.

[V6]
 Qayta dunyoga kelgan, bir Rabbim bor,
 Mangulik hayot bergan, bir Rabbim bor.
 // Qonin men uchun toʻkkan, bir Rabbim bor,
 Menga koʻnglin ochgan, bir Rabbim bor. //
 bir Rabbim bor.

[V7]
 Zulmatdan yoʻl ochgan bir Rabbim bor,
 Shaytonni yengib chiqqan bir Rabbim bor.
 // Endi U Otaning oʻng qoʻl tarafida,
 Menga pok nur sochgan bir Rabbim bor, //
 // bir Rabbim bor. //</lyrics>
</song>