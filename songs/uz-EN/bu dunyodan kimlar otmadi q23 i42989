<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Bu dunyodan kimlar oʻtmadi,
 Isoni koʻplar eshitmadi. //
 Bugun yana Seni esladim,
 Seni Iso yana sogʻindim.
 Bugun yana Seni esladim,
 Seni Rabbim yana sogʻindim.

[C1]
   Ayriliqni Men istamayman,
   Senga ibodatlar qilgayman
   Ayriliqni Men istamayman,
   Senga murojaatlar qilgayman
   Kalomingni oʻqib toʻlgayman,
   Seni Rabbim yana sogʻindim.
   Kalomingni oʻqib toʻlgayman,
   Seni Iso yana sogʻindim.

[V2]
 // Jannatingga borgim keladi,
 Va abadiy qolgim keladi. //
 Iso Masih Noming ulugʻdir,
 Najotkorim Seni sogʻindim.
 Iso Masih Noming ulugʻdir
 Xaloskorim Seni sogʻindim.</lyrics>
<title>Bu dunyodan kimlar oʻtmadi Q23</title>
<hymn_number>23</hymn_number>
</song>