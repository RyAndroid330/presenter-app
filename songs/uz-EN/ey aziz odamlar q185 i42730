<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>185</hymn_number>
<lyrics>[V1]
.Gm          D    Eb      Gm
 Ey aziz odamlar, Masihga keling,
.    Gm         D    Eb          Gm
 Biz uchun siz uchun xochda jon bergan.
.    Cm         Ab             Bb
 // Iblisning hiylakor makrini bilib,
.   Ab           Bb   Eb        Gm
 Yolgʻiz U shaytonni xochga mixlagan.  //

[C1]
.  Gm             Eb   F          D
   Xoch soʻzin eshitib sakramang ortga,
.  Gm           Eb    Eb        Gm
   Asirlik kishanlari mixlaylik xochga.
.     Fm                          Gm
   // Qalbingizda gʻiybat, nafrat limmo-lim,
.  Gm           Ab            Bb      G
   Keling gunoh chandiqlarin beraylik Unga.  //

[V2]
.Gm            D     Eb   Gm
 U barcha dillarga beradi orom,
.    Gm          D     Eb      Gm
 Men uchun, sen uchun kelgan u hayot.
.   Cm          Ab               Bb
 // Oʻlimni bir Oʻzi xochga mixlagan,
.Ab           Bb     Eb        Gm
 Shundanda bu hayot toʻliq mujassam.  //

[V3]
.Gm           D   Eb       Gm
 U bilan Xudoning sir asrorlari,
.      Gm      D   Eb        Gm
 Chunki U samoning nur Shaxzodasi.
.   Cm        Ab               Bb
 // Chunki U Xudoning oʻng qoʻlidir,
.     Ab      Bb   Eb         Gm
 Shul sabab biladi iblis nayrangin.  //

[C2]
.  Gm               Eb    F         D
   Xochdan emas, Xudodan qoʻrqing odamlar,
.  Gm            Eb      Eb       Gm
   Gunohning botqogʻida ingramang aslo.
.     Fm                     Gm
   // Kim ham sizni eshitar bagʻriga bosa,
.   Gm          Ab     Bb       G
   Masihdan boshqakim barisi yolgʻon.  //</lyrics>
<key>Gm</key>
<title>Ey aziz odamlar Q185</title>
</song>