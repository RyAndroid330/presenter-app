<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  Bm          Em       A            D
   Kechir meni Xudoyim, ishonchim Senda doim
.  Bm          Em
   Kechir meni Podshohim ey,
.     G           A(Am)D(Bm)
   // ishonchim Senda doim. (2m) //

[V1]
.Bm         C           D           C      Bm
 Dilga Seni kech soldi, mendek gunohkor bandang.
.Em              C      D          C    Bm
 Kechir bundan avvalroq Seni taniy olmabman.
.   Bm           Em  Bm     A(G)        D(Am)(Bm)
 // Shayton soʻziga kirib, Senga quloq solmabman. //

[C2]
   Kechir meni Xudoyim, ishonchim Senda doim
   Kechir meni Podshohim ey,
   // ishonchim Senda doim. //

[V2]
.Bm                    Em      A       D
 Men notavon Sen bilan behuda janglar qildim.
.Bm                 Em         A    D
 Olovli oʻqlar otib azobladim, xor qildim.
.Bm    A               Bm            A    D
 Hatto madad bermabman oʻsha mashʼum bahorda,
.   Bm          Em      A(G)         G D(Bm)
 // Yovuzlar qiynaganda Nuridiydangni xochda. //

[C3]
   Naqorat:
   Kechir meni Masihim, ishonchim Senda doim
   Kechir meni Podshohim ey,
   // ishonchim Senda doim. //

[V3]
.G              Am       C         A      Bm
 Ammo bir kun gʻaflatdan uygʻondi Sening quling,
.      G         Am    C      Am    Bm
 Yuragimga malhamdek tegdi muborak qoʻling.
.Bm               C     Am         Em      D
 Oʻtgan kunlar yodimda koʻzlarimni ochding Sen,
.   Bm             (Em)        C(G)         Em(Am)  D(Bm)
 // Gunohlar koʻp botqoqdan ey zab qutqarib qolding Sen. //

[C4]
   Kechir meni Xudoyim, ishonchim Senda doim
   Kechir meni Podshohim ey,
   // ishonchim Senda doim. //

[V4]
.Bm        G            Am        C    Bm
 Mana endi taʼzim aylab ibodatda turibman,
.Bm             G        Am             C    Bm
 Shak keltirish yoʻq endi porloq yoʻlda yuribman.
.Am         C           Em              A      D
 Hayotim baxshida Senga qaytish yoʻqdir soʻzlardan,
.   Bm         Em           A(G)       (Am)  D(Bm)
 // Faqat endi Tangrim meni asra yomon ishlardan. //

[C5]
   Naqorat:
   Kechir meni Masihim, ishonchim Senda doim
   Kechir meni Podshohim ey,
   // ishonchim Senda doim. //

[V5]
.G              Am   C           Am    Bm
 Endi Seni nomingni Muqaddas deb bilgayman,
.Bm   G           Am   C               Am   Bm
 Har ibodat qilganimda Sen toʻgʻringda oʻylayman.
.Bm               C    Am           Em     D
 Ey bandalar uygʻoning Nur koʻrindi qanday soz,
.Bm                  C             Em   D
 Kelaver Parvardigor dillar Senga poyandoz.
.Bm       Em            G            Am   Bm
 Kelaver Masih Ustoz ey dillar Senga poyandoz.

[C6]
   Naqorat:
   Kechir meni Masihim, ishonchim Senda doim
   Kechir meni Xudoyim ey,
   // ishonchim Senda doim. //</lyrics>
<key>Bm</key>
<title>Kechir meni Xudoyim Q53</title>
<author>Bir xil qoʻshiq soʻzlari i13698</author>
<hymn_number>53</hymn_number>
</song>