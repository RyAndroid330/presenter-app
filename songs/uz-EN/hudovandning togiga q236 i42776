<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D            (F#m)    Em(Bm)    D(Bm)
 // Xudovandning togʻiga kim chiqib boradi?
.D(Em)     Bm(A)         Em(A)     D
 Uning muqaddas makonida kim tura oladi? //
.   D                  G           D
 // Kimki qoʻli halol, koʻngli pok boʻlsa,
.D                F#m  G        D
 Yolgʻon-yashiq gapga koʻngil bogʻlamas.
.D           G                D
 Makkorona qasamyod qilmas ekan u,
.D         Bm     Em     D
 U Xudovanddan barakat topadi. //
.Em                 G       D
 Xaloskor Xudosidan najot topadi.

[V2]
.   D             G        D
 // Ey darvozalar, kengroq ochiling,
.G                      A      D
 Balandroq koʻtariling, mangu qopqalar. //
.   G              Bm            Em
 // Toki ulugʻvor podshoh kirib kelsin,
.Em                   A       D
 Qudratli va muzaffar Xudovanddir. //

[C1]
.     D            F#m     Em(Bm)   A(Bm) D(Bm)
   // Xudovandning togʻiga kim chiqib boradi?
.  D(Em)    Bm(A)          Em(A)    A   D
   Uning muqaddas makonida kim tura oladi? //
.     D                  G            D
   // Kimki qoʻli halol, koʻngli pok boʻlsa,
.  D              F#m    G          D
   Yolgʻon-yashiq gapga koʻngil bogʻlamas.
.  D          G               D
   Makkorona qasamyod qilmas ekanu,
.  D         Bm     Em   A  D
   U Xudovanddan barakat topadi, //
.  Em                  A      D
   Xaloskor Xudosidan najot topadi.

[V3]
.   D                        Em(G)      D
 // Xudovandga shukr qiling, ismini chorlang,
.D              Em(G)      A       D
 Xalqlar aro ajoyibotin tarannum eting. //
.   D            G                      D
 // Mana budir Xudovandni qidiruvchilar nasli,
.G(Em)        Bm      Em     A     D
 Sening huzuringga intiluvchilar nasli. //</lyrics>
<title>Hudovandning togʻiga Q236</title>
<hymn_number>236</hymn_number>
</song>