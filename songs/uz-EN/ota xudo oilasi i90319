<?xml version="1.0" encoding="UTF-8"?><song><title>Ota Xudo oilasi</title>
<aka>Bolta urar ildiziga gunoh</aka>
<lyrics>[V1]
 // Bolta urar ildizga
 Gunoh yaratgan dogʻi //
 // Ogʻir kechar yolgʻizga
 Sinov oynasi chogʻi //

[V2]
 // Berar ishora-imo,
 Chorlar sevgi oʻchogʻi! //
 // Ochiq boʻlar doimo.
 Otang qalbi, quchogʻi! //

[V3]
 Toʻla Xudoning uyi
 Uning aziz bolasiga.
 // Aka-uka, opa-singil,
 Dalda, zaif nolasiga. //

[V4]
 Yolgʻizlikka koʻnmagin!
 Seni oilang kutmoqda.
 // Yongin, yongin soʻnmagin!
 Umring suvdek oʻtmoqda. //</lyrics>
</song>