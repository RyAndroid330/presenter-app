<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>214</hymn_number>
<title>Xudo ulugʻ</title>
<lyrics>[C1]
.    Em D Em    C             D
   Xudo ul-ugʻ, qoʻshiq aytib kuylaylik
.    Em D Em    C       D
   Xudo ul-ugʻ, bu haqiqat
.    Em D  Em   C            D
   Xudo ul-ugʻ, qalbimizdan kuylaylik
.    Em D  Em   C         Em
   Xudo ul-ugʻ, bu shaksizdir

[C2]
.  Am7   D         Em
   Muhabbatingizni eslasam
.         Am      D           Em
   Qalbim yashnaydi, qalbim yashnaydi

[V1]
.Am7     D         Em
 Seni maqtashga tilim ojiz
.      Am              B
 Ey Rabbim, mening Rabbim

[V2]
.Am7      D       Em
 Qurbonligingni eslasam
.         Am    D           Em
 Qalbim yashnaydi, qalbim yashnaydi

[V3]
.Am7     D         Em
 Ulugʻlayman Seni hamisha
.      Am        B
 Shukrona, Shukrona</lyrics>
<key>Em</key>
</song>