<?xml version="1.0" encoding="UTF-8"?><song><title>Tez kelgin, Rabbim oldiga kelgin Q171</title>
<key>Em</key>
<lyrics>[P1]
.     Bm
   // Doʻstim eshit hushxabarni,
.  C         Am       Em
   Sen uchun Masih oʻlgan! //
.     G
   // Seni ogʻir gunohingni,
.  Am        B     Em
   Oʻz zimmasiga olgan! //

[C1]
.  Em              G
   Tez kelgin, tez kelgin,
.     G(C)   (B)     (Em)
   // Rabbim oldiga kelgin! //

[V1]
.G
 Xudodan sen uzoqlashib,
.C        D         G
 Oʻz bilganingcha yurding.
.G
 Mangulikni istamading,
.C        D        G
 Orzu-havasga choʻkding.

[V2]
 Oʻlim uyqusidan uygʻon!
 Masihni kirit qalbga!
 Xochdagi qon kuch birlan,
 Baxt topasan jonga!

[V3]
 Unga ochgil istagingni,
 Dil kalitin ber Unga.
 Ulugʻ Muqaddas qonida,
 Najot berar U senga!

[C2]
   Tez kelgin, tez kelgin,
   // Rabbim oldiga kelgin! //
   Tez kelgin, tez kelgin,
   // Rabbim oldiga kelgin! //
   // Rabbim oldiga kelgin! //</lyrics>
<aka>Doʻstim eshit hushxaʼarni</aka>
<hymn_number>171</hymn_number>
</song>