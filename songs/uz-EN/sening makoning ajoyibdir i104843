<?xml version="1.0" encoding="UTF-8"?><song><title>Sening makoning ajoyibdir</title>
<lyrics>[V1]
 Sening makoning ajoyibdir
 Ey Sarvari Olam
 Ey Egam Sening hovlingga
 Kirmoqni jonim istar

[C1]
   // Barhayot Xudo, Barhayot Xudo
   Qalbim vujudim kuylar Senga sano
   Barhayot Xudo, Barhayot Xudo
   Sevinch ili jonim Sengadir fido  //

[V2]
 // Ey Sarvari Olam Shohim
 Doim Senga hamdu sanolar
 Sendan qudrat olgan baxtlidir
 Chindildan sajda qilganlar //

[V3]
 // Parvardigor Egam eshit kuyimni
 Yoqubning Xudosi tinglagin meni
 Ey Sarvari Olam Xudoyimsan
 Sendan umid qilib yashayman //</lyrics>
<aka>Barhayot Xudo</aka>
</song>