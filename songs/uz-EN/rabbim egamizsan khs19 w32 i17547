<?xml version="1.0" encoding="UTF-8"?><song><author>Don Moen, Paul Kyle</author>
<hymn_number>65</hymn_number>
<title>Rabbim Egamizsan ҲС19 W32</title>
<aka>Iso Egamizsan</aka>
<key>G</key>
<lyrics>[V1]
.G             Em   C
 Rabbim (Iso) Egamizsan,
.      Am     D
 bu yerga kelgin,
.Em         Bm
 Bizning oramizga,
.C        Am         D
 bizning maqtovlarni olgin!

[C1]
.  G      Em    C
   Seni ulugʻlaymiz,!
.       D    G  Em
   Seni ulugʻlaymiz,!
.  C     D    G  Em
   Seni ulugʻlaymiz,!
.           C          D   G
   Kelgin Rabbim (Iso) taxtingga!</lyrics>
</song>