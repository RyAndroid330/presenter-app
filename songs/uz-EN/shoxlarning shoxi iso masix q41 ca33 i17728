<?xml version="1.0" encoding="UTF-8"?><song><title>Shoxlarning Shoxi Iso Masix Q41 CA33</title>
<lyrics>[V1]
.   F#                D#m Abm
 // Shoxlarning Shoxi Iso Masix,
.C#                       F#
 Osmondan tushar, kelishi yaqin! //
.   F#               D#m    Abm
 // Muxabbati bilan bizni yoritar,
.C#                     F#
 Xayot nonini bizlarga berar! //

[C1]
.     F#(Abm)          (C#) (F#)
   // Senga sharaflar, Iso Masix, //
.     F#          C#        F#
   // Yuragimizda doim yashagin! //
.     F#                          Abm
   // Bizlar qoʻzichoq, qoʻzichoqlaring,
.  C#                      F#
   Mexribon Choʻpon - Iso Masix! //

[V2]
 Shoxlarning Shoxi Iso Masix,
 Osmondan tushar eng yorugʻ yulduz.
 // Senga kelganlar jonni qutqarar,
 Abadiy xayotga ega boʻlishar! //

[C2]
   // Senga sharaflar, Iso Masix, //
   // Yuragimizda doim yashagin! //
   // Bizlar qoʻzichoq, qoʻzichoqlaring,
   Mexribon Choʻpon - Iso Masix! //

[V3]
 Shoxlarning Shoxi Iso Masix,
 Naqadar ulugʻ Muqaddas Noming!
 // Seni bilganlar saodatlidir,
 Najot topganlar iqbolidir! //

[C3]
   // Senga sharaflar, Iso Masix, //
   // Yuragimizda doim yashagin! //
   // Bizlar qoʻzichoq, qoʻzichoqlaring,
   Mexribon Choʻpon - Iso Masix! //</lyrics>
<key>F#</key>
<hymn_number>41</hymn_number>
</song>