<?xml version="1.0" encoding="UTF-8"?><song><title>Uzun tunlar juda qiynaldim</title>
<lyrics>[V1]
 // Uzun tunlar juda qiynaldim
 Baʼzida sendan tondim //
 // Faqat senga senga ishondim
 Rabbim mening dardim tingla //
 // Koʻp yogʻildi tuhmat toshlari
 Yuzim yuvdi koʻzim yoshlari //
 // Shunda bildim bagʻritoshlarni
 Rabbim mening dardim tingla //

[V2]
 Qiyin kunlar, bu kunlar oʻtar
 Yomonliklar olislab ketar
 // Hech boʻlmasin tana toshlari
 Endi oqmas koʻzim yoshlari //
 Yoʻqolmasin topgan imonlar
 Uzilamasin ahd-u paymonlar
 Yakson boʻlsin usha shaytonlar
 // Rabbim mening dardim tingla //</lyrics>
<aka>Dardim tingla</aka>
</song>