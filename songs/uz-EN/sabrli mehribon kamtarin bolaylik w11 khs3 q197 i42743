<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>11</hymn_number>
<key>C</key>
<lyrics>[V1]
.C        G
 Bir-birimizni sevib,
.C        G
 birodar boʻlaylik,
.C        G         C
 birodar boʻlaylik, boʻlaylik
.C        G
 Sabrli, mehribon,
.C         G
 kamtarin boʻlaylik
.C         G          C
 kamtarin boʻlaylik, boʻlaylik

[C1]
.     C         Em        Dm       Am
   // Iso meni kechirib, gunohim olgandek, //

[V2]
.   C           G
 // Biz ham bir-birimizga
.C          G
 kechirim beraylik.
.C          G        C
 kechirim beraylik, beraylik //

[B1]
.  Am       F         Am     G    Am
   Birodar boʻlaylik, sabrli boʻlaylik,
.  Dm             Am   F              Am
   Mehribon boʻlaylik, kamtarin boʻlaylik.</lyrics>
<aka>Bir-birimizni sevib</aka>
<title>Sabrli, mehribon kamtarin boʻlaylik W11 ҲС3 Q197</title>
</song>