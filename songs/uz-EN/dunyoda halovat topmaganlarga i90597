<?xml version="1.0" encoding="UTF-8"?><song><aka>Saodatlisiz</aka>
<key>B</key>
<lyrics>[V1]
.   B               Abm
 // Dunyoda halovat topmaganlarga
.E     Gb     B
 Samo lazzatin soʻzlaydi Iso
.B                  Abm
 Baxtu taxt taʼmini totmaganlarga
.E     Gb      B
 Mangu saodat koʻzlaydi Iso //

[C1]
.  B         Gb
   Kamtarin-u oh-zorlar
.  Abm          E
   Qalbiga poklik yoʻllar
.  B     Gb   Abm   E
   Saodatlisiz, saodatlisiz
.  B        Gb
   Faqir oʻtayotganlar
.  Abm              E
   Koʻz yosh toʻkayotganlar
.  B    Gb
   Saodatlisiz
.  Abm       E      Gb    B
   Zero siz azoblarda yupatilursiz

[V2]
 // Dunyoda bulgʻanmay yashamoq davlat
 Muqaddas boʻl, deb chorlaydi Iso
 Bu dunyo oʻtkinchi behuda savlat
 Mangu hayotga boshlaydi Iso //

[C2]
   Adolatga tashnalar,
   Haqiqatga oshnolar
   Saodatlisiz, saodatlisiz
   Ruhan qashshoq boʻlganlar
   Quvgʻin dardin koʻrganlar
   Saodatlisiz
   Zero Osmon Shohligin
   Meros olursiz

[C3]
   Kamtarin-u oh-zorlar
   Qalbiga poklik yoʻllar
   Saodatlisiz, saodatlisiz
   Faqir oʻtayotganlar
   Koʻz yosh toʻkayotganlar
   Saodatlisiz
   Zero siz azoblarda yupatilursiz!</lyrics>
<title>Dunyoda halovat topmaganlarga</title>
</song>