<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>78</hymn_number>
<lyrics>[V1]
 Xudo bugun uygʻotgin rahmating bilan,
 Qalbimga nuring sochib rahmating bilan.
 // Sening soʻzingni tinglay rahmating bilan,
 Ey Xudoyim bu kunni Oʻzing rahmatla.(2m) //

[C1]
   naqorat
   Oʻzing rahmatla, Oʻzing rahmatla,
   Yolvoraman bu kunni Oʻzing rahmatla.
   Oʻzing rahmatla, Oʻzing rahmatla,
   Ey Xudoyim bu kunni Oʻzing rahmatla.

[V2]
 Gunohlardan ozod qil rahmating ila,
 Iso mehringni sochib rahmating ila.
 // Nuring bizda porlasin rahmating ila,
 Ruhan koʻzimni ochib Oʻzing rahmatla.(2m) //

[C2]
   naqorat
   Oʻzing rahmatla, Oʻzing rahmatla,
   Yolvoraman bu kunni Oʻzing rahmatla.
   Oʻzing rahmatla, Oʻzing rahmatla,
   Ey Xudoyim bu kunni Oʻzing rahmatla.

[V3]
 Doim Senga muhtojman rahmating ila,
 Jannat sari yoʻl boshla rahmating ila.
 // Podshohim men Sen bilan rahmating bilan,
 Iso bizni qutqarib Oʻzing rahmatla.(2m) //

[C3]
   naqorat
   Oʻzing rahmatla, Oʻzing rahmatla,
   Yolvoraman bu kunni Oʻzing rahmatla.
   Oʻzing rahmatla, Oʻzing rahmatla,
   Ey Xudoyim bu kunni Oʻzing rahmatla.</lyrics>
<title>Xudo bugun Q78</title>
</song>