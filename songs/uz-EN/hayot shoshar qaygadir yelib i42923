<?xml version="1.0" encoding="UTF-8"?><song><title>Hayot shoshar qaygadir yelib</title>
<aka>Sendan oʻzga Najotkorim yoʻq</aka>
<key>Em</key>
<lyrics>[C1]
.     Em                      Am
   // Sendan oʻzga Najotkorim yoʻq,
.  D                       G
   Sendan oʻzga Madadkorim yoʻq.
.  Em              Am
   Sendan oʻzga Umidvorim yoʻq,
.  B                       Em
   Sendan oʻzga Xaloskorim yoʻq. //

[V1]
.Em                     Am
 Hayot shoshar qaygadur elib,
.D                   G
 Odam oʻgʻli najotni kutib,
.Em                      Am
 Ming kun bir kun kabi oʻtib,
.D                  G
 Yaratganni izlab oʻylab,
.Am                  Em
 Bagʻringda oʻsdim ulgʻaydim.
.Am         B        Em
 Lekin Seni hech tanimadim.
.   Am       D             G
 // Baxtimga bor ekan Sen Rabbim
.Am         B         Em
 Meni Oʻz bagʻringga olding. //

[V2]
.Em
 Yaratganga kelsin odamzod,
.Em                    Am
 Hayot bersin, bilsin odamzod,
.   Am             D       G
 // Ming shukurlar desin odamzod,
.Am           B        Em
 Meni oʻz bagʻringga olding. //

[C2]
.  Em                       Am
   Sendan boshqa Najotkorim yoʻq,
.  D                        G
   Sendan boshqa Madadkorim yoʻq.
.  Em                      Am
   Sendan boshqa Umidvorim yoʻq,
.  C              B         Em
   Sendan boshqa Xaloskorim yoʻq.
.  Em                      Am
   Sendan oʻzga Najotkorim yoʻq,
.  D                       G
   Sendan oʻzga Madadkorim yoʻq.
.  Em                     Am
   Sendan oʻzga Umidvorim yoʻq,
.  C              B        Em
   Sendan oʻzga aloskorim yoʻq.</lyrics>
</song>