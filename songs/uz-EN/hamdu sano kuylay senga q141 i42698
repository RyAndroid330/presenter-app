<?xml version="1.0" encoding="UTF-8"?><song><title>Hamdu sano kuylay Senga Q141</title>
<lyrics>[V1]
.Ab                      C#   Ab
 Hamdu sano kuylay Senga Masihim,
.C#            Ab        C#   Ab
 Dil toʻrida saqlay Seni Masihim.

[C1]
.     C#            Eb               Ab
   // Menga bergan xushkaloming qoʻlimda,
.  Eb         C#          Eb  Ab
   Elu yurtga soʻylay uni Masihim. //

[V2]
 Yiqilganni turgʻizuvchi Masihim,
 Toza yurak yaratuvchi Masihim.

[C2]
   // Gunohkorni gunohdan ozod etib,
   Oʻz jonini qurbon qilgan Masihim. //

[V3]
 Hamdu sano kuylay Senga Masihim,
 Dil toʻrida saqlay Seni Masihim.

[C3]
   // Menga bergan xushkaloming qoʻlimda,
   Elu yurtga soʻylay uni Masihim. //</lyrics>
<key>Ab</key>
<hymn_number>141</hymn_number>
</song>