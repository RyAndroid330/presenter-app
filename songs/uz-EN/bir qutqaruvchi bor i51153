<?xml version="1.0" encoding="UTF-8"?><song><author>Melody Green</author>
<title>Bir qutqaruvchi bor</title>
<lyrics>[V1]
.A      E    D    A
 Bir Qutqaruvchi bor,
.E      D      A E
 Tangri Oʻgʻli Iso,
.A     E      D      A
 Hurmatli tangri Qoʻzisi,
.D       E       A
 Eng ilohiy boʻlgan.

[C1]
.  A        E    D  A
   Senga shukur Otajon,
.   D    E  A  E
   Iso Qoni uchun,
.     A  E        D     A
   Endi Sening Ruhing bilan,
.    Bm      E  A
   Bajarilar ishing.

[V2]
 Iso Qutqaruvchi,
 Boshqa biri yoʻq,
 Hurmatli Tangri Qoʻzisi,
 Voz kechaman gunohdan.</lyrics>
<key>D</key>
<aka>Qutqaruvchi</aka>
</song>