<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22061</hymn_number>
<lyrics>[C1]
.  G              D    G
   Xudo - buyuk jangchi
.  C                    D   G D
   Xudo - kuchli va qudratli
.  G              D    G
   Xudo - buyuk jangchi
.              C       D G
   Shoxlar shoxi - Xudo

[V1]
.C         D          G
 Xudoyim mening qalʼam
.C        D          G
 U Quyosh va qalqonim
.C    D            Em
 Xudo - xaloskordir
.     Am    D         G
 Unga umid qilganlarga

[V2]
.C                 D     G
 U Kuch berar Oʻz xalqiga
.C                      D G
 Kuchli oʻng qoʻlida asrar
.C                D    G
 Farishtalar oʻrab olar
.     D            Em
 Uning farzandlarin
.Am     D      G
 Va Xalos qilar</lyrics>
<key>G</key>
<title>Xudo Buyuk Jangchi</title>
</song>