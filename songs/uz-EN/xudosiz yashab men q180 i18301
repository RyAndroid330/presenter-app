<?xml version="1.0" encoding="UTF-8"?><song><aka>Dunyo, dunyo, yolgʻonchi dunyo</aka>
<key>Em</key>
<lyrics>[V1]
.   Em                  Am
 // Xudosiz yashab men bu dunyoda,
.                      D      G
 Yolgʻonlarga duch keldim men bu dunyoda. //
.   Am               D         G
 // Kim haqu kim nohaq men bilmas edim,
.Am            C      Dm     Em
 Sen Oʻzing haq ekansan yaratgan Tangrim. //

[C1]
.     Em(G)  (A)      C     F
   // Dunyo, dunyo yolgʻonchi dunyo,
.  F      Am    Dm     Em
   Dunyo, dunyo aldamchi dunyo. //

[V2]
.   Dm             Am    D  G
 // Bu dunyo aslida shaytonni qoʻlida,
.Dm                 Am D  G
 Hamma yolgʻonlar xam Uning izmida. //
.   Am                D     G
 // Qalbi koʻr nodonlar Uning yoʻlida, //
.Am       C     Dm   Em
 Sevgisiz aldovlar ular oʻyida.

[V3]
.Em                      F
 Chiroyli koʻrinar bu dunyo doʻstim,
.C        F      Dm     Em
 Gʻaroyib koʻrinar bu dunyo doʻstim.
.   Em               (Am)(D)F(G)
 // Hech qachon bu dunyo vafo qilmagan,
.C(Am)   F(C)   Dm        Em
 Aldab yashamoqni bas qilgin doʻstim. //
.Am                Am   D  G
 Hech qachon bu dunyo vafo qilmagan,
.Am        C     Dm    Em
 Imon koʻzi ila qaragin doʻstim.</lyrics>
<title>Xudosiz yashab men Q180</title>
<hymn_number>180</hymn_number>
</song>