<?xml version="1.0" encoding="UTF-8"?><song><title>Osmonga yoʻl Masihdur</title>
<key>B</key>
<lyrics>[C1]
.  Abm
   Osmonga yoʻl Masihdur,
.        C#m        F#
   Hayot bergan Masihdur.
.          B          E
   Quvonch bergan Masihdur,
.              F#(C#m)  Ab (Ebm)
   // Jannatga yoʻl Masihdur. //

[V1]
.   Eb              Abm
 // Keling barcha insonlar,
.(E)   B           F#
 Masih soʻzin eshitinglar. //
.     Abm      E
 Xudo nomin olqishlab,
.         F#(C#m) Abm (Ebm)
 // Hamdu sano bildiringlar. //

[C2]
   Osmonga yoʻl Masihdur,
   Hayot bergan Masihdur.
   Quvonch bergan Masihdur,
   // Jannatga yoʻl Masihdur. //

[V2]
.   Ebm          F#
 // Madadkorim Xudoyim,
.B        C#m       F#
 Muqaddas qon toʻkibsan. //
.C#
 Olqish soʻzga loyiqsan,
.   Abm    C#         F#
 // Qurbon boʻlib oʻlibsan. //
.Abm
 Qurbon boʻlib oʻlibsan,
.C#         F#
 Gunohlarni koʻmibsan.
.Abm
 Soʻng qaytadan tirilib,
.           F#       Abm
 // Insonga baxt beribsan. //</lyrics>
</song>