<?xml version="1.0" encoding="UTF-8"?><song><key>Eb</key>
<lyrics>[V1]
.Eb           Ab    Eb  Ab          Eb
 Rabbimiz va Tangrimiz hurmatga loyiqsan,
.Eb             Ab  Eb  Fm       Bb    Eb
 Kuch qudratli Sen Xudo hurmatga loyiqsan.

[C1]
.     Ab       Eb   Bb       Cm   Ab  Bb     Eb
   // Bor boʻlgan, hozir ham bor, bor boʻlgaysan. //

[V2]
 Hammani Sen yaratding irodang bilan,
 Yoʻqdan bor paydo qilding Kaloming bilan.

[C2]
   // Bor boʻlgan, hozir ham bor, bor boʻlgaysan. //

[V3]
 Taxtda oʻtirgan Qoʻzining oldida yigʻilib,
 Madhiyalar kuylashib, sajda qilaylik.

[C3]
   // Shon-shuhrat, hurmat, qudrat maqtovga loyiqsan. //</lyrics>
<title>Bor Boʻlgan ҲСХМ114 ҲС57 W109 Q120</title>
<hymn_number>114</hymn_number>
<author>Iliyas Tursun</author>
</song>