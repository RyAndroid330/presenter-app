<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>112</hymn_number>
<title>Muqaddas Rabbim, Senga intildim W79 Q47</title>
<key>C</key>
<lyrics>[V1]
.   Am                G       Am
 // Muqaddas Rabbim, Senga intildim,
.G                    C
 Chunki Sen dillarga orom. //

[C1]
.     Am      Dm         F    G
   // Sening bagʻringda orom topaman,
.  C         Dm        Am
   Mening dilim orom topadi. //

[V2]
 // Bilaman Senda abadiy quvonch,
 Va ulugʻ muhabbat Senda. //

[V3]
 // Va endi hech kim mendan ololmas,
 Sen menga bergan shodlikni. //

[V4]
 // Va qachon kelsa qazo soatim,
 Olasan meni Oʻzingga. //</lyrics>
<aka>Muqaddas Rabbim</aka>
</song>