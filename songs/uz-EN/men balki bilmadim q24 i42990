<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>24</hymn_number>
<title>Men balki bilmadim Q24</title>
<lyrics>[V1]
 Men balkim bilmadim Sen-la yashashni,
 Hayot janglarida birga boʻlishni.
 // Gʻoliblik tojini kiyolmadim Men,
 Noshuda farzanding kechirolsang bas. //

[V2]
 Orzular qanotida suzgan bir qushman,
 Yaralangan qalbim zogʻlarga ayon,
 // Lekin Sen, ey Rabbiy tirik ekansan,
 Men azob botqogʻidan chiqaman omon. //</lyrics>
</song>