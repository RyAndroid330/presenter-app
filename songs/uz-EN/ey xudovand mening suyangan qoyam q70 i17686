<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>70</hymn_number>
<title>Ey Xudovand Mening Suyangan Qoyam Q70</title>
<lyrics>[V1]
 // Ey Xudovand mening suyangan qoyam,
 Munojotimga quloq solgin. //
 // Seni chaqiraman meni eshitmay qolmagin. //

[V2]
 // Sen menga jon bermasang gar,
 Yer bagʻriga tushganlarga oʻxshab qolarman. //
 Men Senga yolvorib figʻon qilsam,
 Muqaddas makoning tomon qoʻllarim choʻzsam,
 Munojotimga quloq solgin.
 // Seni chaqiraman meni eshitmay qolmagin. //

[V3]
 Xudovand mening qalqonimdir,
 Men chin yurakdan Unga umid bogʻladim.
 // U menga yordam berganda quvonchga toʻldim,
 Qoʻshigʻim bilan Unga shukrlar deyman. //
 // Ey Xudovand mening suyangan qoyam,
 Munojotimga quloq solgin. //
 Seni chaqiraman meni eshitmay qolmagin.

[V4]
 Oʻz xalqingga Oʻzing najot bergin,
 Oʻz mulkingni muborak aylagin.
 // Ularni abadiy yuksaltirib borgin,
 Munojotimga quloq solgin. //
 // Ey Xudovand mening suyangan qoyam,
 Munojotimga quloq solgin. //
 Seni chaqiraman meni eshitmay qolmagin.</lyrics>
</song>