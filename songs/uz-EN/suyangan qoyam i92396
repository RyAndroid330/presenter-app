<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<hymn_number>23562</hymn_number>
<lyrics>[V1]
.Dm              F         G
 Mening panohim qoyam boʻlgin
.Dm              F      G
 Har doim Senga bora olay
.Dm                    F      G
 Meni qutqarmoq uchun amr bergin
.Dm                         F         G
 Chindan ham Seni suyangan qoyam deb aytay

[C1]
.  Dm    F          G
   Senda men panoh topaman
.  Dm          F       G
   Senda men sharmanda boʻlmayman hech

[V2]
.Dm             F          G
 Ey Xudo mendan uzoq ketmagin
.Dm                F         G
 Tez kel Ey Xudo menga madad bergin
.Dm               F            G
 Har doim Senga umid bogʻlab yashayman
.Dm                 F            G
 Yanada koʻp hamdu sano Senga aytaman</lyrics>
<key>Dm</key>
<title>Suyangan Qoyam</title>
</song>