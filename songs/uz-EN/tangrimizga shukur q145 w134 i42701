<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>145</hymn_number>
<title>Tangrimizga shukur Q145 W134</title>
<lyrics>[V1]
 // Tangrimizga shukr, Masih Najotkorga,
 Hamdu sano shukr, bizning shohimizga.
 U quvonch va hayot, sevgi va baxt bergan,
 U bizni qutqardi gunohlardan. //

[C1]
   // Shon-sharaflar, rahmat Senga Masih,
   Shon-sharaflar, Sen Xudoning Oʻgʻli.
   Shon-sharaflar, Parvardigorimiz,
   Shon-sharaflar, Iso Masih. //

[V2]
 // Tangrimizga shukr, Masih Najotkorga,
 Hamdu sano shukr, bizning shohimizga.
 U quvonch va hayot, sevgi va baxt bergan,
 U bizni qutqardi gunohlardan. //

[C2]
   // Muqaddasan Sen muqaddas Masix,
   Muqaddasan Sen Xudoning Oʻgʻli.
   Muqaddasan Parvardigorimiz,
   Muqaddasan Iso Masih. //</lyrics>
</song>