<?xml version="1.0" encoding="UTF-8"?><song><author>French, unknown</author>
<title>Kelgin Immanuyel</title>
<lyrics>[V1]
 KELGIN KELGIN IMMANUEL
 QULLIK ZANJIRLARIDAN OZOD QIL
 XUDO OʻGʻLI KELGUNICHA
 YOLGʻIZ VA QUVGʻINDAGI HALQING

[C1]
   SHODLAN, SHODLAN! IMMANUEL
   KELAR SENGA XUDO TANLAGAN EL

[V2]
 KELGIN XUDONING QUDRATLI KUCHI
 YAKSON BOʻLSIN IBLIS KISHANLARI
 QUTQAR AZOBLARDAN BIZNI
 BERGIN OʻZ HALQINGA GʻALABANGNI

[V3]
 KELGIN XUDONING MUQADDAS NURI
 UYGʻOT GʻAFLAT UYQUSIDAN BIZNI
 KETSIN ZULMAT BULUTLARI
 KETSIN BU YERDAN OʻLIM SOYASI

[V4]
 KELGIN, KELGIN DOVUDNING KALITI
 OCHGIN OSMON UYING DARVOZASIN
 OʻZING TOMON BOSHLA BIZNI
 ASRA DOIM YOʻLLARIMIZNI

[V5]
 KELGIN QUDRATLI XUDO ADONAY
 MUQADDAS MASKANINGDIR TOGʻ SINAY
 BERDING HALQINGGA QONUNLARING
 YUBOR ENDI BUYUK MARHAMATING

[C2]
   SHODLAN, SHODLAN! IMMANUEL
   KELDI SENGA XUDO TANLAGAN EL</lyrics>
</song>