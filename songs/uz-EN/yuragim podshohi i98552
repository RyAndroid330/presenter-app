<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.     A                 D              A
 Yuragim Podshohi mustahkam qoyam boʻlsin,
.  F#m              E            D       A
 Hayotbahsh bulogʻ boʻlsin, U mening madhim
.     A                D          A
 Yuragim Podshohi panoxida yashirsin,
.  F#m        E         D        A
 Hayotimni U olsin, U mening madhim.

[C1]
.      F#m  E  D   A
   Ezgusan Sen yo Rab
.      F#m  E  D   A
   Ezgusan Sen yo Rab
.      F#m  E  D   A
   Ezgusan Sen yo Rab
.      F#m  E  D   A
   Ezgusan Sen yo Rab

[V2]
.     A                  D            A
 Yuragim Podshohi yoʻllarim yoʻnaltirsin,
.    F#m         E          D      A
 Boʻronlarda saqlasin, U mening madhim.
.     A                  D            A
 Yuragim Podshohi tomrim quvvati boʻlsin,
.   F#m            E         D      A
 Kunlarimni toʻldirsin, U mening madhim.

[B1]
.  A
   Sen aslo qoldirma,
.  A
   Meni tark etma Rabbim.</lyrics>
<key>A</key>
<title>Yuragim Podshohi</title>
<hymn_number>30509</hymn_number>
<author>John Mark McMillan &amp; Sarah McMillan</author>
</song>