<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<author>Zafar</author>
<title>Shukur aytaman W21</title>
<key>Cm</key>
<lyrics>[V1]
.Cm         Fm   G#   A#m  Cm
 Bu dunyoda men, gunohkor edim,
.Cm            Bb         G#         Eb
 Men uchun qon toʻkilganin bilmagan edim
.   Fm                Bb7         Eb
 // Bu ne azoblar ekan endi men bildim
.G#        Eb       C#    A#m    Cm
 Bu dunyoda endi men gunox qilmasman! //
.   Eb          Cm Bb         Eb
 // Xudo Sen bizni olib yurgaysan
.G#         Eb     Fm     Bb    Eb
 Oʻz panagda bizni saqlab yurgaysan! //
.   Fm                  G#        Eb
 // Rabbim Sen qandayin ulugʻ donosan
.Fm            Eb      C#    A#m  Cm
 Farzanding qilganinga shukur aytaman! //

[C1]
.     Cm       Fm       G#/A#m Cm
   // Shukur aytaman, shukur aytaman,
.  Fm           Eb      C#   A#m Cm
   Farzading qilganinga shukur aytaman! //

[V2]
 Bu dunyoni yaratgan Tangrimga shukur
 Qum tuproqdan bizlarni yaratgan Egam!
 // Sen qanday qudratlisan bu dunyoni yarating
 Oʻz mehringni bergansan har birimizga! //
 // Rabbim Sen bizni tanlab olgansan
 Oʻz muhabbatingni bizga bergansan! //
 Endi men Sen hech unutolmayman
 Ohirigacha biz bilan boʻlgaysan!
 Rabbim Sen qandayin ulugʻ donosan
 Farzanding qilganinga shukur aytaman!</lyrics>
<aka>Bu dunyoda men, gunohkor edim</aka>
</song>