<?xml version="1.0" encoding="UTF-8"?><song><aka>Bir Kun Dunyo Tugarmish</aka>
<lyrics>[V1]
.Gm
 Bir kun dunyo tugarmish,
.Eb     Fm        Gm
 Oxirat ham boʻlarmish.
.Gm          Bb
 Ochilmagan dunyo siri,
.Eb          F    Gm
 Ochilib ham ketarmish,
.Bb
 Osmon uzra Masih Oʻzi,
.Eb             Gm
 Er yuziga kelarmish.

[C1]
.     Cm
   // Ayrilmagin ey ayrilma,
.  Bb(F)        (Bb)
   Imoningdan ayrilma. //
.  Eb                     Ab
   Bu besh kunlik dunyoni deb,
.  Fm            Gm
   Boyliklarga berilma.
.  Cm               Eb
   Bu besh kunlik dunyoni deb,
.  Fm            Gm
   Ortingga sen qayrilma.

[V2]
.   Cm              Gm
 // Boylik seni tortadi,
.Gm    F    B
 Dunyo seni tortadi. //
.   Cm
 // Shayton yoʻliga kirib,
.B          Gm
 Imoningdan ayrilma. //

[C2]
   // Ayrilmagin ey ayrilma,
   Imoningdan ayrilma. //
   Bu besh kunlik dunyoni deb,
   Boyliklarga berilma.
   Bu besh kunlik dunyoni deb,
   Boyliklarga berilma.

[V3]
.   D              Gm
 // Qoʻllaring ishda boʻlsin,
.Eb          F     Gm
 Dilginang Unda boʻlsin. //
.   Gm            Cm
 // Gunohlardan yuz oʻgir,
.F               B
 Yaxshilik payidan boʻl. //

[C3]
   // Ayrilmagin ey ayrilma,
   Imoningdan ayrilma. //
   Bu besh kunlik dunyoni deb,
   Boyliklarga berilma.
   Imoningdan ayrilma.</lyrics>
<key>Gm</key>
<title>Ayrilmagin</title>
</song>