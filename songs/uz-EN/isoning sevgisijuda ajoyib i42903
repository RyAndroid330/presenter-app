<?xml version="1.0" encoding="UTF-8"?><song><title>Isoning sevgisi-juda ajoyib</title>
<lyrics>[V1]
.    D
 Isoning sevgisi juda ajoyib,
.     A             D
 Juda ajoyib, juda ajoyib.
.   D
 Isoning sevgisi juda ajoyib,
.   A        D
 Sevgisi ajoyib!

[V2]
 /// Isoning sevgisi Juda ajoyib ///
 Ajoyibdir

[C1]
.  D
   Shunday baland, undan baland nima bor?
.  A
   Shunday keng, undan kengroq nima bor?
.  D
   Shunday chuqur, undan chuqur nima bor?
.  A          D
   Sevgisi ajoyib!</lyrics>
<key>A</key>
<hymn_number>26</hymn_number>
</song>