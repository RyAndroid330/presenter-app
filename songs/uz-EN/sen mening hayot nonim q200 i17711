<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>200</hymn_number>
<lyrics>[V1]
 // Sen mening hayot nonim,
 Mehribonim,Choʻponim. //
 // Senda quvondi jonim, //
 // Mehribonim,Choʻponim. //
 Rahmdil Otajonim.

[V2]
 // Jonajon deb aytdilar,
 Ulugʻvor deb aytdilar. //
 // Seni xochda qoqdilar, //
 // Mehribonim,Choʻponim. //
 Rahmdil Otajonim.

[V3]
 // Huzurimga kel deding,
 Bolam boʻlib yur deding. //
 // Soʻzlarimni bil deding, //
 // Mehribonim,Choʻponim. //
 Rahmdil Otajonim.</lyrics>
<title>Sen mening hayot nonim Q200</title>
</song>