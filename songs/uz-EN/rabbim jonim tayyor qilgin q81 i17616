<?xml version="1.0" encoding="UTF-8"?><song><key>F#</key>
<lyrics>[C1]
.     F#                  Abm
   // Rabbim jonim tayyor qilgin,
.  B        C#     F#
   Quloq va koʻzim ochgin. //
.     F#
   // Kaloming bilim eshitsin,
.  B        C#          F#
   Osmon yorugʻin koʻrsatgin. //
.     F#
   // Fahm-idrok jonimga bergin,
.  B           C#           F#
   Hayot gʻiybatlarin yoʻqotgin. //
.     F#
   // Rabbim jonim tayyor qilgin,
.  B        C#        F#
   Quloq va koʻzim ochgin. //

[V1]
.B
 Hayotda koʻp xato qilamiz.
.                C#m
 Zulmat orasinda yurib,
.B
 Odil boʻlishga urinmaymiz.
.                 C#m
 Yovuzlikdan uzoqlashib
.C#m
 Rabbim ruhing bilan yoritgin,
 Gunohlardan forih qilgin.

[C2]
.     C#m(F#)              (B)
   // Rabbim jonim tayyor qilgin,
.  C#(Abm)  (C#)    F#
   Quloq va koʻzim ochgin. //

[B1]
.     F#
   // Sen yorugʻlikdan, yorugʻlikdan,
.  B        C#         F#
   Xudoning yakka Oʻgʻlisan //
.  F#
   Sening soʻzing eshitsam men,
.  B        C#     F#
   Qalbim bilan quvonaman.
.  F#               B
   Rabbim men bilan doim boʻlgin.
.  C#                  F#
   Orom berib baxtiyor qilgin.

[C3]
.     F#
   // Rabbim jonim tayyor qilgin,
.  B        C#      F#
   Quloq va koʻzim ochgin. //
.     B        C#        F#
   // Quloq va koʻzim ochgin! //</lyrics>
<title>Rabbim jonim tayyor qilgin Q81</title>
<hymn_number>81</hymn_number>
</song>