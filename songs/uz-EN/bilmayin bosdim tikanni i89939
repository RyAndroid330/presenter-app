<?xml version="1.0" encoding="UTF-8"?><song><title>Bilmayin bosdim tikanni</title>
<aka>Adashgan edim</aka>
<lyrics>[V1]
.F#m            Bm
 Bilmayin bosdim tikanni
.E           A
 Tortadurman jabrini
.D                Bm
 Bilsam edim bosmas edim
.C#m7         F#m
 Tortmas edim jabrini
.F#m             Bm
 Hayotda men koʻp adashdim
.E            A
 Topa olmasdan yoʻlimni
.D               Bm
 Birodar-u yor-u doʻstlarim
.C#m7          F#m
 Tashlab ketdi meni

[C1]
.  Bm                  F#m
   Yolgʻiz qoldim keng bu olam
.  Bm               F#m
   Boʻlib qoldi menga tor
.  Bm                F#m
   Qayga borishni bilmayman
.  D      C#m7   F#m
   Izlab qoldim madadkor

[V2]
 Rabbim soʻzin eshitib
 Bordim men shu yoʻl tomon
 Xudo haqi bundayin yoʻl
 Koʻrmagandim hech qachon
 Endi hozir men olamni
 Kezmoqdaman be armon
 Rabbim soʻzin nasihatin
 Tinglamoqdaman hamon

[C2]
   Yolgʻiz qoldim keng bu olam
   Boʻlib qoldi menga tor
   Qayga borishni bilmayman
   Izlab qoldim madadkor

[V3]
 Hayotda koʻp adashibsan
 Qiynalibsan der menga
 Etagimdan yaxshilab ushla
 Yordam beraman senga
 Endi har kun men Rabbimni
 Quchogʻida boʻlaman
 Uning soʻzin nasihatin
 Halqimga yetqazaman

[B1]
.  F#m             Bm
   Birodar-u yor-u doʻstlarim
.  E              A
   Keling-chi men tomon
.  D             Bm
   Bu qoʻshiqni sizlar uchun
.  C#m7         F#m
   Kuylamoqdaman hamon

[C3]
.     Bm               F#m
   // Yolgʻiz qoldim keng bu olam
.  Bm               F#m
   Boʻlib qoldi menga tor
.  Bm              F#m
   Qayga borishni bilmayman
.  D     C#m7   F#m
   Izlab qoldim madadkor //
.     D     C#m7   F#m
   // Izlab qoldim madadkor //</lyrics>
<key>F#m</key>
<author>OYBEK, QURBON MUKUMOV</author>
