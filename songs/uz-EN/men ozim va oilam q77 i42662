<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
.Bb           F       Eb          Bb
 Men oʻzim va oilam Senga Masih xizmat qilay,
.   Eb            Bb           Cm        Bb
 // Lekin darmon bergin menga, itoatkor quling boʻlay. //

[V2]
 Ishlarimda yordam bergin, hammaga ibrat boʻlay.
 // Men bilan yashab turganni chin koʻngildan sevib yuray. //

[V3]
 Oʻzimni va oilamni hayoli Senda boʻlsin,
 // Maʼbad tuzgin dilimizda, O mening Xaloskorim. //

[V4]
 Oʻzimni va oilamni Senga Rabbim qurbon qildim,
 /// Bergin menga duoingni, Senga dilimla yolvordim. ///</lyrics>
<title>Men oʻzim va oilam Q77</title>
<hymn_number>77</hymn_number>
</song>