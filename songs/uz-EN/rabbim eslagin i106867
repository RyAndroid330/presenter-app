<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Gunoh botqogʻiga
 Yiqilsam qoʻl choʻz
 Ruhim koʻzlariga
 Ochilsin ayt soʻz //
 // Tuproq bilan bir kun
 Toʻlganida koʻz
 Rabbim Shohligingda
 Meni eslagin! //

[V2]
 Gʻiybat ostonasin
 Xatlamadi kim
 Xatolarim eslab
 Muzlaydi etim.
 Men ojiz bandangga
 Aylagin rahm
 // Rabbim Shohligingda
 Meni eslagin! //

[V3]
 Hatto birodarga
 Chap berib oʻtdim
 Yordam ber desang Sen
 Gap terib oʻtdim.
 Muhtojga koʻkragim
 Goh kerib oʻtdim...
 Rabbim Shohligingda
 Meni eslagin!

[V4]
 Men loyiq emasman
 Inoyatingga
 Umid qilib keldim
 Marhamatinga
 Masihim muhtojman
 Shafoatingga
 // Rabbim Shohligingda
 Meni eslagin! //

[V5]
 Ziyoga talpinib
 Ziyo izladim
 Oʻzimga oʻzga bir
 Dunyo izladim
 Chin dildan aytilgan
 Duo izladim...
 Rabbim Shohligingda
 Meni eslagin!

[V6]
 Yoqmadim, yaqinim
 Yov qarab oʻtdi
 Ishq dardi yurakda
 Oʻt qalab oʻtdi
 Shayton hiyla qilib,
 Har soniya kutdi
 // Rabbim Shohligingda
 Meni eslagin! //</lyrics>
<title>Rabbim Eslagin</title>
<author>Ravshan Xizirov</author>
</song>