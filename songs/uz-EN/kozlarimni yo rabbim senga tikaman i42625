<?xml version="1.0" encoding="UTF-8"?><song><title>Koʻzlarimni yo Rabbim Senga Tikaman</title>
<lyrics>[C1]
.     Em                    G       Am
   // Koʻzlarimni yo Rabbim Senga tikaman,
.  Am            C          D     Em
   Tezroq kelgin yo Rabbim Seni kutaman.
.  Em                  G   Am
   Najotkorim Sen, Iso Masihim,
.  Am           C          D       Em
   To oʻlguncha men Seni kuylab oʻtaman. //

[V1]
.   Em          C        Bm        Am
 // Seni oʻylaʼ har kuni tunlarim bedor,
.Em           C      Bm       Am
 Ibodatda koʻzlarim Senga intizor. //
.   Am                 G        Am
 // Har biringizga boʻlsin Xudo yor, //
.   Am        C           D    Em
 // Osmon Shohligi topsin barqaror. //

[V2]
.Em          C        D        Em
 Sendan minnatdorman, barhayot Ota,
.Em                        Am
 Iso Masih albatta keladi qayta.
.   Am                    G      Am
 // Yerdagi farzandlaring Seni kutadi, //
.   Am             C       D     Em
 // Bergan najotingga shukrlar qiladi. //

[C2]
.  Em                    G       Am
   Koʻzlarimni yo Rabbim Senga tikaman,
.  Am            C         D      Em
   Tezroq kelgin yo Rabbim Seni kutaman.
.  Em              G     Am
   Najotkorim Sen, Iso Masihim,
.      Am           C         D       Em
   /// To oʻlguncha men Seni kuylab oʻtaman. ///</lyrics>
<key>G</key>
</song>