<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22066</hymn_number>
<author>Һәmra aka</author>
<key>D</key>
<lyrics>[V1]
.          Bm           Em            A
 Najotkor noming ulugʻ boʻlgay falaklarda,
.A                   F#m            Bm
 Va yerda ham ulugʻ boʻlgay Masih noming.
.          Bm           E           A
 Najotkor noming muqaddasdir yuraklarda,
.A                   F#m            Bm
 Muhabbat, yoʻl va haqiqat, hayot noming.

[C1]
.              Em          A           Bm
   // Muhabbat yoʻl bilan bizga yaqinlashding,
.           Em         A          Bm
   Muqaddas Ruh bilan bizni yangilading. //

[V2]
 Rabbim Iso tashakkur aytaman Senga,
 Najotli inoyatingga shodiyona (minnatdorman).
 Rabbim Iso shuhrat va madhiya Senga,
 Muqaddas Ruh madadkorim gʻalabangga.</lyrics>
<title>Najotkor Noming W87 ҲС49 Q119</title>
</song>