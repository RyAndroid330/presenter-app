<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.C         G   D          Em
 Biz bahramand gʻalabadan shodumon
.Bm         D        Am       C       G
 Najotlikka erishgan pok imon shod inson
.C        G  D        Em
 Biz begumon holisona shodumon
.Bm           D         Am      C       G
 Chunki Masih biz uchun kafolat haq qurbon,
.D   Em
 Haq qurbon
.Em           D        Am       C  G
 Olqishlaylik muqaddas Najotkor noming
.Em         D       Am        G
 Rabbimizga vafodor bepoyon shod
.Em          D        Am       C    G
 Xudo ochgan mahfirat Najotkor yoʻlini
.Em          D        Am       G
 Toʻsolmaydi hasadkor hiylagar yov</lyrics>
<key>C</key>
<title>Biz bahramand</title>
<hymn_number>14</hymn_number>
</song>