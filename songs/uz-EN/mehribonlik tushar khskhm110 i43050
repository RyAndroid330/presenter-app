<?xml version="1.0" encoding="UTF-8"?><song><title>Mehribonlik Tushar ҲСХМ110</title>
<lyrics>[V1]
.   Eb      Fm    Eb     Bb
 // Mehribonlik tushar, tushar,
.Eb      Fm      Eb       Bb
 Mehribonlik bahorgi yomgʻirday,
.Eb      Fm         Em    Bb  Eb  Fm Eb B
 Mehribonlik meni oʻrab oladi. //

[C1]
.     Eb         Fm         Bb
   // Hey xou, mehribonlik bilan,
.  Eb       Fm       Bb
   Hey xou inoyati bilan,
.  Eb        Fm           Bb   Eb
   Hey xou abadiy raqsga tushaman. //
.      Eb      Fm     Bb   Eb
   /// Xalelu-xalelu, halleluya. ///</lyrics>
