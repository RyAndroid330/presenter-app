<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>152</hymn_number>
<key>C</key>
<lyrics>[V1]
.Em                 C       Em
 Parvardigor olamni yaratganida,
.G        Am       Dm      Em
 Er uzra quyoshni porlatganida.
.Am                     Dm      Am
 Boʻldiyo zaminga ziyo taratganida.
.F                 G               Em
 U buyurgan oʻsha soʻz Kalom eding Sen.

[C1]
.     Em          Am   D            G
   // Kalom eding Sen, Kalom eding Sen,
.  C            F         Dm         Em
   U buyurgan oʻsha soʻz Kalom eding Sen. //

[V2]
.    G                         Am
 // Dunyoga gunoh kirib adashganida,
.C        Am          D        G
 Insonlar boylik deya talashganida. //
.Am                    C        Am
 Haqiqat yolgʻon bilan almashganida,
.Em       Am    G    C      D     Em
 Xudo yuborgan Najotkor Iso eding Sen!

[C2]
   // Iso eding Sen, Iso eding Sen,
   Xudo yuborgan Najotkor Iso eding Sen! //

[V3]
.   Em                 G
 // Ilohiy nur porlar sirli koʻzida,
.C               F   Dm        Em
 Bir dunyo maʼno bor aytgan soʻzida. //
.C                   Am     G
 Odamga yot xislat bordir Oʻzida,
.C                  Dm         E
 Inson qiyofasidagi Xudo eding Sen!

[C3]
   // Xudo eding Sen, Xudo eding Sen,
   Inson qiyofasidagi Xudo eding Sen! //</lyrics>
<aka>Kalom eding Sen</aka>
<title>Parvardigor olamni yaratganida Q152</title>
</song>