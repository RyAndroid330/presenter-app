<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am
 // Samoviy taxtini qoldirib
.G            Am
 Dunyomizga keldi Iso Ixtiyoridan kechib
.D             Em
 Xizmatkor boʻldi Iso //

[C1]
.     Em
   // Iso men uchun qurbon
.  Am
   Iso men uchun qurbon boʻldi
.  Am
   Gunohlarim tufayli
.  D          Em
   Xochda U azob chekdi //

[V2]
.   Am
 // Men qilgan gunohlarim
.G          Am
 Juda juda koʻp edi Masihim baribir
.D             Em
 Ulardan meni oqladi //</lyrics>
<key>Am</key>
<title>Samoviy taxtini qoldirib</title>
