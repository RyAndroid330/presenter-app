<?xml version="1.0" encoding="UTF-8"?><song><key>Bm</key>
<lyrics>[V1]
.Bm      Em     F#      Bm
 Hayotim boʻyi izlayman seni,
.Bm   C7          F#         Bm
 Kaloming ila men yashayman sening,
.Bm            Em       F#     Bm
 Qoʻshiqlaring ila joʻshiyman sening,
.Bm          C7     F#       Bm
 Hayotimni berdim senga men Rabbim.

[C1]
.     Em               F#
   // Yashayman sening ila,
.  Bm             G
   Oʻlaman sening ila,
.  Em           A(F#)   (Bm)   D   F#
   Sening ila gʻalaba qilaman Rab Iso! //
.  Bm  D   A   G   A  Bm
   Lay lay lay lay lay. . .

[V2]
 Oʻzingdadur hayot sengdadir haqiqat
 Qoʻlingda yuraman sevinchla faqat
 Koʻrsatasan bizga oʻz muhabbating ila,
 Jonli huzuringni oʻshanda borligʻingni.</lyrics>
<title>Xayotim boʻyi izlayman Seni</title>
</song>