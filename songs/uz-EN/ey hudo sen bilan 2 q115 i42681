<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>115</hymn_number>
<title>Ey Hudo Sen bilan (2) Q115</title>
<lyrics>[V1]
 // Ey Xudo Sen bilan turmushim obod,
 Ey Xudo Sen bilan dillarimiz shod. //
 // Ey Xudo Oʻzingsan dardlarga shifo,
 Sensiz bilmasmiz hayot ne aslo. //

[C1]
   /// Ey Xudo ///  Oʻzingsan ulugʻsan ey Xudo.
   /// Ey Xudo ///  Seni sevdim doimo ey Xudo.

[V2]
 // Ey Xudo yurakni Oʻzing davola,
 Ey Xudo qulingga bergin kuchingni. //
 // Ey Xudo nuringni Oʻzing toʻldirib,
 Bu yorugʻ dunyoga koʻrsat kuchingni. //

[V3]
 // Ey Xudo bemorga bergin kuchingni,
 Ey Xudo nomingni ulugʻlaylik biz. //
 // Ey Xudo doimo yod etib Seni,
 Xudosiz turmushni koʻrmaylik aslo. //</lyrics>
<aka>E, Xudo Sen bilan</aka>
</song>