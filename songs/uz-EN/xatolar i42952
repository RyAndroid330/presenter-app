<?xml version="1.0" encoding="UTF-8"?><song><title>Xatolar</title>
<key>Em</key>
<lyrics>[V1]
.   Em              D     Em
 // Xatolar koʻp, jafolar ham.
.Em                 D    Em
 Sirsang, kayf-u safolar ham. //
.Am
 Bu vafolar, vafolar ham,
.   Em
 // Bu dunyoda yolgʻonlar koʻp. //

[C1]
.  Em
   Haqiqatdan haqiqatlar,
.  Am              G
   Kalomdadur kalomda.
.  Em
   Biz bilmagan sinoatlar,
.  Am                G
   Tangrimdadur Tangrimda.
.     Am
   // Shirinzabon zamonlar ham,
.  Em              Am
   Tangrimdadur Masihda.
.  F             Dm      Em
   Bu dunyoda yolgʻonlar koʻp. //
.  Am
   Ilk dunyoda yolgʻonlar koʻp.
.  Em
   Bu dunyoda yolgʻonlar koʻp!

[V2]
.   Em              D      Em
 // Endi doʻstlar amin boʻldim,
.Em               D      Em
 Haq yoʻliga koʻngil qoʻydim. //
.Am
 Toza imon Masihdadur,
.   Em
 // Bu dunyoda yolgʻonlar koʻp. //</lyrics>
</song>