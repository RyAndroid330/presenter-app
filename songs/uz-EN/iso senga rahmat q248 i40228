<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>248</hymn_number>
<title>Iso, Senga rahmat Q248</title>
<lyrics>[C1]
.  F    Bb
   Iso Senga rahmat,
.  C                Bb
   Men Sen bilan gaplasha olaman doim.
.  F     Bb
   Iso Senga rahmat,
.  C              F
   Meni Sen eshitasan.

[V1]
.F                Bb
 Hamma qaygʻu va tashvishni
.C             F
 Senga beraman Rabbim.
.F           Bb
 Shubhalarni ham Senga
.C            F
 Topshiraman doim.

[C2]
   Iso Senga rahmat,
   Men Sen bilan gaplasha olaman doim.
   Iso Senga rahmat,
   Meni Sen eshitasan.

[V2]
 Inoyat va shodlik uchun
 Minnatdorman men Sendan.
 Chunki Sening sadoqating
 Juda ham ulkan.

[C3]
   Iso Senga rahmat,
   Men Sen bilan gaplasha olaman doim.
   Iso Senga rahmat,
   Meni Sen eshitasan.

[V3]
 Hammasidan ham koʻproq
 Sen meni bilasan Rabbim.
 Hayotimni Senga
 Topshiraman Xudoyim.

[C4]
   Iso Senga rahmat,
   Men Sen bilan gaplasha olaman doim.
   Iso Senga rahmat,
   Meni Sen eshitasan.
   Iso senga rahmat!</lyrics>
<key>F</key>
</song>