<?xml version="1.0" encoding="UTF-8"?><song><title>Xudo Yusufni asradi</title>
<lyrics>[V1]
.D            G
 Xudo Yusufni asradi,
.A              D
 Koʻp narsaga u erishdi.
.D            G
 Xudo Yusufni saqladi,
.A         D
 Koʻpga u erishdi.

[C1]
.  G       D
   Ha uni asradi Xudo
.  A          D
   Va Yusufni bildi dunyo.
.  G      D
   Ha uni saqladi Xudo
.  A         D
   Bildi uni dunyo.

[V2]
 Yusuf juda ham qiynaldi,
 Chunki Misrga sotildi.
 Yusuf juda ham qiynaldi,
 Qullikka sotildi.

[C2]
   Ha uni asradi Xudo
   Va Yusufni bildi dunyo.
   Ha uni saqladi Xudo
   Bildi uni dunyo.

[V3]
 Misrda qamoqqa tushdi,
 Lekin Xudo qoldirmadi
 Misrda qamoqqa tushdi,
 Xudo qoldirmadi.

[C3]
   Ha uni asradi Xudo
   Va Yusufni bildi dunyo.
   Ha uni saqladi Xudo
   Bildi uni dunyo.

[V4]
 Xudo sevgi va kuch berdi,
 Yusuf sinovlardan oʻtdi,
 Xudo sevgi va kuch berdi,
 Yusuf yengilmadi.

[C4]
   Ha uni asradi Xudo
   Va Yusufni bildi dunyo.
   Ha uni saqladi Xudo
   Bildi uni dunyo.</lyrics>
<key>D</key>
</song>