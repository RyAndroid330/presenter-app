<?xml version="1.0" encoding="UTF-8"?><song><title>Senga tangrim</title>
<key>G</key>
<lyrics>[V1]
.   G                      Em
 // Butun dunyoni yaratgan qodir Xudoyim,
.     C               D
 Meni hayotimni faqat Sen oʻzgartirding.
.       G                  Em
 Va men qoʻshiq kuylashni istadim shu on,
.       C                   D
 Bergan muhabbating cheksiz sevging bilan. //

[C1]
.        C                   G
   Senga Tangrim rahmatlar aytaman.
.        C            D         G
   Senga qalbimni men bagʻishlayman.
.        C        D         B     Em
   Senga Tangrim sevgim va hayotim,
.  C                D       G
   Hayotimga toʻliq maʼno berding.

[V2]
 // Butun dunyoni yaratgan qodir Xudoyim,
 Va tun oʻrtasida menga nuringni sochding.
 Menga boʻlgan mehringni bilganim uchun,
 Chin dildan men Senga Rabbim xizmat qilayin. //</lyrics>
</song>