<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>117</hymn_number>
<lyrics>[V1]
 Rabbim, yoʻlimga nurin sochib
 Uyga olib keladi (2m)
 Yolgʻiz qolsamda,
 Yoʻlimda adashsamda
 Sen, meni yetaklaysan
 Shunda qoʻrqinich,
 Birdan gʻoyib boʻladi
 Rabbim meni, tashlama,(2m)

[V2]
 Bagʻringda men sevinaman o Otam
 Senda mening bor umidim
 Yoʻlimda mening, Iso odil sherigim
 Qutqaruvchi men bilan, men bilan</lyrics>
<title>Rabbim, yoʻlimga nurin sochib W117</title>
</song>