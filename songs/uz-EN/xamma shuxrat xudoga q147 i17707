<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>147</hymn_number>
<lyrics>[V1]
.   Am            Em
 // Hamma shuhrat Xudoga, //
.   G                     D          Em
 // Qalbim va jonim bilan Xudoni sevaman. //
.   Am            Em
 // Hamma shuhrat Xudoga. //

[C1]
.     Am                  Em
   // Iso olqishlarimizni olgin, //
.     G                     D       Em
   // Gunohlarni kechirdi, Muqaddas Ruhin berdi. //
.     Am                  Em
   // Iso olqishlarimizni olgin. //

[V2]
.   Em(G)   A        Bm(C)(Bm)Em
 // Tasalli beruvchi Muqaddas Ruh, //
.   G(C)     (Bm)      Am(Em)
 // Yuragimizda turib bizni boshqaradi. //
.   G        Em(Am)  G(C)C(Bm)Em
 // Tasalli beruvchi Muqaddas Ruh. //

[C2]
.     Am
   // Iso olqishlarimizni olgin, //
.     G                    C  Bm    Em
   // Gunohlarni kechirdi, Muqaddas Ruhin berdi. //
.     G                   C Bm Em
   // Iso olqishlarimizni olgin. //</lyrics>
<key>Am</key>
<title>Xamma shuxrat Xudoga Q147</title>
</song>