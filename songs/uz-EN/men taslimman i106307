<?xml version="1.0" encoding="UTF-8"?><song><author>Hillsong United</author>
<lyrics>[V1]
 Shu joyda,
 Men tiz choʻkaman oldingda,
 // Taslim boʻlaman //

[V2]
 Oʻz yoningga
 Meni yaqinlashtirgin
 Juda muhtojman,
 Seni izlayman
 Men taslimman

[V3]
 Ruhan ochligim
 Marhamating bilan,
 Oʻzing toʻydirgin,
 Bagʻringga bosgin

[V4]
 Qalbim zoʻr Senga
 Yuragimda joy Senga
 // Soʻzing kutaman //

[C1]
   // Men taslimman //
   Seni bilishim uchun
   Koʻproq bilishim uchun
   // Men taslimman //
   Seni bilishim uchun
   Koʻproq bilishim uchun

[B1]
   Shamollar kabi
   Nafasing eshitay
   Irodangni men
   Sendan soʻrayman
   Ochib ber
   Tebrantir meni
   Ozod et meni
   Irodangni men
   Sendan soʻrayman
   Ochib ber</lyrics>
<title>Men taslimman</title>
</song>