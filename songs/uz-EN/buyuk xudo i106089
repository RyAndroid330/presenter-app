<?xml version="1.0" encoding="UTF-8"?><song><title>Buyuk Xudo</title>
<lyrics>[V1]
 // Kuylayman men buyuk, buyuk Xudoni!
 Farishtalar kuylar, kuylar Xudoga!
 Men bilan Rabbim birga kuylagin !
 Buyukligingni koʻrsin, koʻrsin bu olam! //

[V2]
 // Buyuk Podshoh Uzingdursan bu Xaq !
 Sen Nursan senda bulmas zulmat.
 Ovozingdan chaqmoqlar chaqar.
 Larzaga kelar, kelar yerlar titrab. //

[V3]
 // Yaratguvchi buyuk, buyuk Xudo Otam!
 Boshi da oxiri Uzingiz Rabbim!
 Ota, Ugʻil va muqaddas rux,
 Sen Quzisan Yagona, Yagona Xudo! //

[C1]
   // Shon -sharaf !
   Sening Nominga!
   Jonim kuylar,
   Buyuk Xudoni! //</lyrics>
<author>Timutiy</author>
</song>