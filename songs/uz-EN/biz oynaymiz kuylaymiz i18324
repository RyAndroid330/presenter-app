<?xml version="1.0" encoding="UTF-8"?><song><title>Biz oʻynaymiz, kuylaymiz</title>
<key>D</key>
<lyrics>[V1]
.   D          G        A
 // Biz oʻynaymiz, kuylaymiz,
.D        G       A
 Nomingni ulugʻlaymiz,
.    G           Bm
 Iso bilan bizni nikoh kutmoqda,
.G       A      D
 U bilan baxtiyormiz. //

[C1]
.  D               G               A
   Halleluya buyuk Xudovand bizni kutmoqda,
.  D               G                 Bm  A  D
   Halleluya buyuk Xudovand bizning hukmdorimiz.
.  D               G             A
   Halleluya buyuk Xudovand juda xursandmiz,
.  D               G                 Bm A    D
   Halleluya buyuk Xudovand gunohdan qutilganmiz .</lyrics>
<aka>Xudovand bizni kutmoqda</aka>
<hymn_number>16</hymn_number>
</song>