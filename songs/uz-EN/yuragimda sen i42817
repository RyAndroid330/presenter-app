<?xml version="1.0" encoding="UTF-8"?><song><title>Yuragimda Sen</title>
<key>D</key>
<lyrics>[V1]
.   D                Bm     Em           A
 // Yuragimda Sening noming muqaddasdir, muqaddas,
.G                 D       Em             D
 Iso Masih oʻchmas noming, muqaddasdir, muqaddas. //
.   D                    Bm            Em
 // Oʻzbekiston yoshlari Masihni ulugʻlaylik,
.G       Em       G       A       D
 Kelajak avlodiga ibratni oʻrgataylik. //

[V2]
 // Orom toparman Isoda, quvonch koʻrdim Masihda,
 Otam Oʻgʻli, Yupatuvchi muqaddasdir, muqaddas. //
 // Kelajak avlodimiz, muqaddas maʼbadimiz,
 Abadiy qoʻlingdadir, bir umr jannatdadir. //</lyrics>
</song>