<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Unutib boʻlmaydi
 Sening moʻjizangni
 Ununtib boʻlmaydi marhamatingni
 Unutib boʻlmaydi
 Sening shavqatingni
 Unutib boʻlmaydi sevgingni

[C1]
   // Men unutmayman //
   Men unutmayman sevgingni
   // Men unutmayman //
   Men unutmayman. Men buni

[V2]
 Faqat Seni koʻylayman
 Buyuk ismningni
 Seni deb yasharman
 Men Rabbim
 Faqat koʻylayman mehribonligingni
 Faqat koʻylayman
 Rabbim Seni

[C2]
   // Seni koʻylayman //
   Seni koʻylayman. Sen borim Iso
   // Seni koʻylayman //
   Seni koʻylayman. Sen baxtim</lyrics>
<title>Unutib Bulmaydi</title>
<author>Sobir Umurov</author>
</song>