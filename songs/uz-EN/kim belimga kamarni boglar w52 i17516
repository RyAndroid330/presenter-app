<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.    E           B7          E  C#m
 //  Kim belimga kamarni bogʻlar,
.E            B7        E  C#m
 Kim menga gʻalaba keltirar?  //
.    A      B7         E  C#m
 //  Faqat Uni ulugʻlayman,
.F#m    B7           E
 Faqat Uni yuksaltiraman!  //

[C1]
.      E    A      B7        C#m
   //   Men Seni tarannum etaman,
.    A B7         E  C#m
   Birodarlarim bilan.
.  A    B7   E       C#m
   Yuk- sal- ti- ra- man,
.    F#m    B7      E
   Sening Noming Rabbim.
.        C#m    F#m    B7      E
   O, Rabbim, Sening Noming Rabbim!  //</lyrics>
<key>E</key>
<title>Kim Belimga Kamarni Bogʻlar W52</title>
<hymn_number>52</hymn_number>
