<?xml version="1.0" encoding="UTF-8"?><song><title>Ayting ayting Xudoga ayting</title>
<lyrics>[V1]
.Gm
 Shon-sharaf Xaloskorimga,
.Bb                D
 Oʻliming bilan menga,
.Cm
 Huquq, berding boʻlishimga,
.F                D
 Doʻstlarning oldida!
.Gm
 Jonga tinchlik izlaganman,
.Bb               D
 Men dunyoni unutib,
.Cm
 Kun keldi imon topdim,
.F                   D
 Quvondim, baxtli boʻlib!
.Gm
 Shu kunlar hayotimni,
.Bb              D
 Xudoga bagʻishladim,
.Cm
 Xushxabarga qulogʻimni,
.F              D
 Doimo, burib oldim!

[C1]
.     Gm      Cm     F      Bb
   //  Ayting, ayting Xudoga ayting,
.  Cm      Gm        D          Gm
   Xudoga, hamisha, Hamdu sano ayting! //

[V2]
 Xizmatchingman va quling
 Hayotda yoki oʻlimda
 Boʻlgin mening yonimda
 Qoʻychivondek oborarsan
 Yetaklab meni olgʻa
 Mehribon Shohligingga
 Abadiy hayotingga
 Shon-sharaf Xudoyimga
 Mehribon xizmatingga
 Xochda oʻlding berib menga
 Abadiy hayot jonimga</lyrics>
<key>Gm</key>
<aka>Shon sharaf Xaloskorimga</aka>
</song>