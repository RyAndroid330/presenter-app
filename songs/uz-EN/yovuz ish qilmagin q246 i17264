<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>246</hymn_number>
<title>Yovuz ish qilmagin Q246</title>
<lyrics>[V1]
.A
 Yovuz ish qilmagin,
.E          A
 Yomon soʻzlama!
.A
 Biz Masih farzandi,
.E         A
 Nazar sol Unga!

[C1]
.     D
   // Iso beozordir,
.  A
   Solih gunohsiz.
.          D
   U kabi boʻlsak,
.       E           A
   Biz baxtli boʻlamiz. //

[V2]
 Yovuz ruh doimo
 Bizni poylaydi.
 Yomon qilmishlarga,
 Aldab boshlaydi.

[V3]
 Yomon ruhdan qochib,
 Uni tinglama!
 Yovuzlikni yengib,
 Soflikdan qolma!</lyrics>
<key>A</key>
</song>