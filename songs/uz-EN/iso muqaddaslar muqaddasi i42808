<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am                   Bb
 // Imonlining balanddir boshi,
.             Dm     Am
 Imonsizning koʻzida yoshi.
.Am                   Bb
 Gunohkorlar koʻpayib ketdi,
.     Gm          Am
 Bu dunyoda, bu dunyoda.  //

[C1]
.     Am
   // Iso, Muqaddaslar Muqaddasi,
   Iso, Xudoning irodasi.
.  Dm
   Iso, Najotkorlar Najotkori,
.  Bb   Gm          Am
   Iso, hamdu sano aytamiz.  //

[V2]
.Am      F          Gm        C
 Abadiy hayot uchun yashar solih farzandlar,
.Am               F       Gm      C      Dm
 Lek imonsizlar bandalar boylik ketidan quvar.
.    Dm          C          Bb           Gm  Am
 // Keling aziz doʻstlarim, panoh toping jamoatda.  //

[V3]
.Am      Bb          Gm       C
 Imonli azob chekdi, sabr bardoshli boʻldi.
.F             Dm      Bb          Gm     Am
 Jannat tomon intilib, vaqt kelib uchib ketdi.
.Am         Bb        Gm         C
 Imonsiz qolib ketdi, lekin endi kech edi,
.F                 Dm     Bb        Gm     Am
 Koʻzlaridan yosh tomib, afsuslar chekib qoldi.
.Am               F     Gm         C        Dm
 Eshiting Xushxabarni, siz ham afsuslar chekmang,
.   Dm           C             Bb      Gm      Am
 // Boshingizni tik koʻtarib, Rabbim oldiga uchinglar.  //</lyrics>
<key>F</key>
<title>Iso Muqaddaslar Muqaddasi</title>
</song>