<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.Dm
 Yorit meni yuraklarimni, yorit meni koʻz nurlarim,
.C
 Yorit meni tilaklarimni, yorit meni umidlarimni.
.Bb                                                A
 Yorit meni hayotlarimni, yorit meni Tangrim soʻrayman.

[V2]
 Yorit meni hayot yoʻlimni, yorit meni xayollarimni,
 Yorit meni savollarimni, yorit meni halol qoʻlimni.
 Yorit meni boru yoʻgʻimni, yorit meni Sendan soʻrayman.

[C1]
.     Dm                       C
   // Bosib oʻtgan hayotimni, qoʻldan ketgan imkonimni,
.  Bb                     A
   Senga bergan qarorimni yorit.
.  Dm                       C
   Aytgan Senga muhtojimni, erdan koʻtargan boshimni,
.  Bb                       A
   Senla qilgan bardoshimni yorit. //</lyrics>
<title>Yorit meni</title>
</song>