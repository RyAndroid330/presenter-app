<?xml version="1.0" encoding="UTF-8"?><song><title>Oʻz nafsidan toʻymaganlar Q239</title>
<lyrics>[V1]
.Cm
 Oʻz nafsidan toʻymaganlar baxtsizlarni izlaydilar,
.   Fm                        Cm
 // Labin tishla koʻzin qisa, tul ayolni izlaydilar. //
.Cm
 Bir oyogʻin goʻr sudragan, Xudo qolib yor izlagan,
.   Fm                     Cm
 // Kechalari nafs yoʻlida shaʼmlar yoqib yor izlagan. //

[C1]
.  Cm                      Fm            Cm
   Qoʻllarida sharobu may, zino aylab koʻzlari toʻymas.
.     Fm                   Cm         G      Cm
   // Tillarida Xudo degan tul ayolni avrab toʻymas. //
.  Cm
   Bu kun Rabbiy tanib bilgan solihasin tinch qoʻy shayton,
.     Fm                       Cm
   // Faryodlarin Xudo eshitar bevalarni tinch qoʻy shayton. //
.  Cm
   Oʻz nafsidan toʻymaganlar baxtsizlarni izlaydilar,
.     Fm                        Cm
   // Labin tishla koʻzin qisa, tul ayolni izlaydilar. //</lyrics>
<key>Cm</key>
<hymn_number>239</hymn_number>
</song>