<?xml version="1.0" encoding="UTF-8"?><song><title>Xudovandning marhamati</title>
<lyrics>[V1]
.   Am                        Dm
 // Quyosh nurin sahiy sochar yurtimga,
.Bb          Gm       Am
 Xudovandimning marhamati.
.Am                    Dm
 Daraxtlar meva tugar mavsumida,
.Bb         Gm        Am
 Xudovandimning marhamati. //

[C1]
.     F              Bb
   // Sogʻlik berar tanamga,
.  Gm            C
   bardam qilar ruhimni.
.  F            Bb
   Meni sevgan Xudovandga
.      Gm       C
   jonimni beraman. //
.     Bb  Gm    Am
   // jonimni beraman. //

[V2]
.Am                      Dm
 Makonida tinchlik hukm surar,
.Bb        Gm           Am
 Solihlari faqat xizmat qilar.
.Am                 Dm
 Inoyatin berganiga men ham beraman,
.Bb            Gm         Am
 Oʻn borimdan birini Unga beraman.
.Am                        Dm
 Hayot makonimga ham urugʻ sochar,
.Bb                Gm    Am
 Parvarishda doim birga boʻlar.
.Am                        Dm
 Hosil paytida meni kutib turar,
.Bb            Gm          Am
 Oʻn borimdan birini Unga beraman.</lyrics>
<key>F</key>
</song>