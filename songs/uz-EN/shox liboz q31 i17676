<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>31</hymn_number>
<title>Shox liboz Q31</title>
<key>Bbm</key>
<lyrics>[V1]
.Bbm                       Ebm
 Shoh libos kiyilib, tikan toj boshingda,
.F                       Bbm
 Qoʻllaring zanjirband etilgandi.
.Bbm                 Ebm
 Qancha qaygʻu alam oqargan yuzingda,
.F                           Bbm
 Qancha mehr-muhabbat koʻzlaringda.
.Bbm                 Ebm
 Lekin tana azobi qaygʻulik ham emas.
.F                       Bbm
 Uyatli qiynoq qancha dahshatdur.

[C1]
.     Bbm                          Ebm
   // Shu soat Sen uchun qiynoqdan ham ogʻir,
.  F                       Bbm
   Koʻplarga qurboning befoydadur. //

[V2]
.C#                   Ebm
 Muhabbat yonilur porlagan yuzingda,
.G#                    C#
 Qalbinga olishni intilarding.
.C#                     Ebm
 Rabbimning sevgisin koʻplari bilmadi,
.F                 Bbm
 Xaloyiq ustidan kulishardi.
.Bbm                   Ebm
 Rabbimiz shu azob va qaygʻu kechirdi,
.F                   Bbm
 Xaloyiq Xudoni hukm etdi.

[C2]
   // Sen uchun ey doʻstim Najotkor qiynaldi.
   Sen uchun ogʻir yukni koʻtardi. //</lyrics>
</song>