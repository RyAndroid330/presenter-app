<?xml version="1.0" encoding="UTF-8"?><song><title>Ber Toza Muqaddas Ehtirosni</title>
<aka>Yuragim bilan ergashaman</aka>
<key>C</key>
<lyrics>[V1]
.   C                    Am   Em
 // Ber toza, muqaddas ehtirosni,
.F          Dm         G
 Ber menga ajoyib bir fikrni.
.C                        Am       Em
 Ber hayotimga intilish, umid bir maqsad,
.F         G          C
 Yuragim bilan ergashaman. //

[C1]
.  C         F         G
   Yuragim bilan ergashaman,
.  Am        F        G
   Haqiqatingga yaqinlashib.
.       Am           Em
   Bu dunyo yovuz va boʻsh,
.          Am        D
   Rabbim Sening oldingda.
.             F             G        Am(C)
   // Ber qoʻlingni men ortingdan boraman. //</lyrics>
<hymn_number>13</hymn_number>
</song>