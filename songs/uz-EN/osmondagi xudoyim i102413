<?xml version="1.0" encoding="UTF-8"?><song><title>Osmondagi Xudoyim</title>
<key>G</key>
<lyrics>[V1]
.G         G/Eb           Em    C
 Osmondagi Xudoyim, bu yerda turib
.G         G/Eb    Em C
 Bir soʻz bilan aytayin

[C1]
.     Am   G/B C      D  G
   // Iso, men seni sevaman.
.        G     F Em C
   Seni qarshilayman //
.      Am    G/B     C
   Bir soʻz bilan aytayin
.  Am   G/B   C  D   G
   Iso, men seni sevaman.

[V2]
.G            G/Eb        Em        C
 Barcha sevgi qoʻshigin senga kuylayman
.G        G/Eb     Em C
 Bir soʻz bilan aytayin
.Am   G/B  C    D   G
 Iso, men seni sevaman.</lyrics>
<hymn_number>134</hymn_number>
</song>