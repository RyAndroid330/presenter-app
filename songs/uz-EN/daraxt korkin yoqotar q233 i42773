<?xml version="1.0" encoding="UTF-8"?><song><title>Daraxt koʻrkin yoʻqotar Q233</title>
<key>C</key>
<lyrics>[V1]
.   Am      C                G
 // Daraxt koʻrkin yoʻqotar bargsiz,
.Am          C       G
 Daryo daryo emasdir suvsiz.
.Am        C            G
 Bu dunyo ham qorongʻu nursiz,
.Am           C            G
 Men ham hech kim emasman Sensiz. //

[C1]
.     Dm          F           G        Am
   // Sevishni oʻrgatding Sen menga, qalbimga,
.  Dm        F         G   Am
   Minnatdorman men Sendan Iso. //

[V2]
 // Orzularim armondir Sensiz,
 Yaxshilik ham yomonlik Sensiz.
 Bu dunyo ham maʼnosiz Sensiz,
 Men ham hech kim emasman sevgingsiz. //</lyrics>
<hymn_number>233</hymn_number>
</song>