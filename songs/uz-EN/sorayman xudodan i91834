<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em
 // Biz uchun bir oʻlib tirilgan
.Em                 Am
 Gunohlar qon bilan yuvilgan
. Am
 Farzandlar yangidan tugʻilgan
. C                    B7
 Tanlangan farzandlar oqlangan //

[C1]
.     Em
   // Soʻrayman Xudodan soʻrayman
.   Em                   Am
   Dunyoning tinchligin soʻrayman
.   Am
   Soʻrayman Isodan soʻrayman
.    C       B7      Am
   Xudoning Sevgisin soʻrayman //

[V2]
 Dunyoning neligin angladim
 Birgina Xudoni tanladim
 Onamning qalbidek mehrli
 Isoning Kalomin tanladim</lyrics>
<key>Em</key>
<title>Soʻrayman Xudodan</title>
<author>Sobir Umurov</author>
