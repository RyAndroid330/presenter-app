<?xml version="1.0" encoding="UTF-8"?><song><title>Qodirlab men Seni</title>
<key>F#</key>
<lyrics>[V1]
.               G  C               Am
 Xotirlab men Seni, huzuringga keldim,
.D               G            C               Am
 Dardlarimni men aytib Senga, yolvordim men Senga
.D              G       C             Am
 Rabbim deb yigʻlarman, ibodatda har kuni!
.D             G   C                   Am
 Yo Rabbim Sen mening gunohimni kechirgin
.D             G      C                 Am
 Endi Sen hech mendan, uzoqlashma yo Rabbim!
.D               G
 Dardlarimni men Senga aytib,
.C                Am
 Topshirdim yo Rabbim!

[C1]
.   D
   (Jon Otajon)
.   G                              Am
   Iso Masih, minnatdorman men Sendan!
.        D                                      G
   Yosh toʻkdim, yosh toʻkdim Sevginga, men toʻlib
.                            Am
   Yo Rabbim kuzimda, yoniq qoʻshiqsiz,
.          Bm     C        D         G
   Dilimda har kuni qoʻshiqday yayraysiz!

[V2]
 Imonga men kelib, dilim poklandi
 Ey Tangrim meni Oʻzing asragin
 Chunki panoh topganman
 Men Xudovandga ayttim:
 Sen mening Rabbimsan,
 Chunki Sendan boshqa,
 Yoʻqdur Iso Rabbim!
 Ey Xudovand Sen mening nasibamsan
 Kosam oqi Oʻzingdirsan
 Taqdirimni Sening qoʻlingga,
 Topshirdim yo Rabbim!</lyrics>
<hymn_number>204</hymn_number>
</song>