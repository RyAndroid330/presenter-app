<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>110</hymn_number>
<title>Qoʻshiq aytishni Q110</title>
<key>Gm</key>
<lyrics>[V1]
.Gm                D
 Qoʻshiq aytishni istayman,
.Cm      D       Gm
 Xafalik mendan yoʻqolsin.
.Gm                  D
 Masih doʻstim U men bilan,
.Cm         D       Gm
 Dilim shodlikka toʻlsin.
.Gm                  Bb
 Bilib qolib men shodlandim,
.Cm   F          D
 Meni Masih sevganidan.
.Gm              Eb
 Men uchun oʻlib tirilgan,
.Cm        D    Gm
 Unga doim kuylagayman.

[C1]
.     Cm
   // Kuylang, kuylang doʻstlarim,
.  F           Bb
   Najotkorga kuylang.
.  Eb                Cm
   Kuylang, kuylang doʻstlarim,
.  D            Gm
   Rabbimizga kuylang. //

[V2]
 Gunoh aldovi zoʻr kelsa,
 Men Masihga yolvorgayman.
 Koʻzlarim yoshga toʻlib qolsa,
 Rabbimga kuylagayman.
 Men hammaga xabar qilsam
 Najotkorim haqinda,
 Butun olamni qoʻzgʻotsam
 Kuylash uchun Rabbimizga.

[C2]
   // Kuylang, kuylang doʻstlarim,
   Najotkorga kuylang.
   Kuylang, kuylang doʻstlarim,
   Rabbimizga kuylang. //
   // Rabbimizga kuylang. //</lyrics>
</song>