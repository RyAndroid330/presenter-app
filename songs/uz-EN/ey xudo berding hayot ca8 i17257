<?xml version="1.0" encoding="UTF-8"?><song><title>Ey Xudo berding hayot CA8</title>
<lyrics>[V1]
.   Em      D
 // Ey Xudo berding hayot,
.C               Em
 Sevding shuncha bandangni, //
.   Em     D
 // Balki biz nodonlar,
.C       Em
 Unutdik shafqatingni //

[C1]
.     Am        G
   // Keldi Iso oramizga,
.  C      D
   Nurini sochishga,
.  Am           G
   Bizlar uchun Masix oʻldi,
.  C           D
   gunohimizni yuvishga //

[V2]
 // Gunohimiz yuvildi,
 Masih Iso qonida //
 // Hayotga erishdik
 Rabbimizning yonida //

[C2]
   Keldi Iso oramizga,
   Nurini sochishga,
   Bizlar uchun Masih oʻldi,
   gunohimizni yuvishga...</lyrics>
<key>Em</key>
