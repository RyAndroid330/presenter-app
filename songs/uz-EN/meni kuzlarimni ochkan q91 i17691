<?xml version="1.0" encoding="UTF-8"?><song><title>Meni kuzlarimni ochkan Q91</title>
<key>Gm</key>
<lyrics>[V1]
.   Gm
 // Meni koʻzlarimni ochgan,
.Bb
 Menga porloq nurin sochgan.
.Cm
 Undan iblis ham qochgan,
.Cm             Gm
 Iso Xudoning Oʻgʻli. //

[C1]
.          Gm      Cm
   // Iso jonim mening,
.       D       Gm
   Iso tanim mening,
.  Dm                Gm
   Hayotim, Nonim mening. //

[V2]
 // Meni Oʻz bagʻriga olgan,
 Menga Muqaddas Ruhini yuborgan.
 Men bilan abadiy qolgan,
 Iso Xudoning Oʻgʻli. //

[C2]
   // Iso jonim mening,
   Iso tanim mening,
   Hayotim, Nonim mening. //</lyrics>
<hymn_number>91</hymn_number>
</song>