<?xml version="1.0" encoding="UTF-8"?><song><author>Marty Sampson, Matt Crocker, Hillsong Worship</author>
<lyrics>[V1]
 Xudo olamni sevdi
 Yagona Oʻgʻlini berib
 Unga ishonganlar nobud bolmaydilar
 Abadiy hayotga ega boʻlib

[C1]
   Xochga men tayanaman
   Xudoga suyanaman
   Sevgisi ozod qildi
   Gunohdan halos etdi

[V2]
 Faqat Uni men kutaman
 Soʻziga ishonaman
 Qutqarildim Mehri bilan
 Oqlandim Inoyat bilan

[B1]
   Bebaho qoning
   Qutqardi meni
   Olqishlaymiz Seni Iso
   Boʻysintiramiz hamasin Senga
   Najotim Isoda</lyrics>
<title>Xudo olamni sevdi</title>
</song>