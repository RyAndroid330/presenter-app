<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.E         B
 Sen xochimni olding,
.           E
 Va Sen oʻlding,
.      A        B
 'Ozod boʻlib yasha' deb,
.E       B
 Hayotim Seniki,
.         E     A      B
 Va har doim inoyatingni kuylay.

[C1]
.                A      B
   // Loyikdir Noming, Iso
.             E
   Maqtovga loyiq
.             C#m
   Loyiqdir Noming //

[V2]
.E       B
 Isnodim yuvildi,
.          E         A        B
 Zavqlanyapman shubhasiz Sevgingdan men
.E      B
 Inoyatning meni
.          E      A        B
 Toʻldiryapti u hakida kuylay doim

[C2]
   // Loyiqdir Noming Iso,
   Maqtovga loyiq,
   Loyiqdir Noming, //

[B1]
.    A
   Osmonlarda yuksalgansan,
.       F#m
   Buyukliging shu yerda
.     C#m
   Yolgʻiz Sen maqtovga loyiq
.       B             E
   Buyuksan hamma Nomdan

[C3]
   // Loyiqdir Noming Iso,
   Maqtovga loyiq
   Loyiqdir Noming. //</lyrics>
<key>E</key>
<title>Loyikdir Noming</title>
<author>Kovcheg tserkovʹ Dnepropetrovsk</author>
<hymn_number>25503</hymn_number>
</song>