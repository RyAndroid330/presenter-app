<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>104</hymn_number>
<key>Gm</key>
<lyrics>[V1]
.   Gm
 // Bizlarga falak ochiq,
.Gm
 Bizga Xudo duo bermoqda. //
.   Cm                Eb
 // Va inoyat taxtida U,
.Cm          Dm        Gm
 Oʻz xalqini duo qilmoqda. //

[C1]
.     Gm       Cm(Eb)
   // Duo qilmoqda, //
.  Cm          Dm        Gm
   Oʻz xalqini duo qilmoqda.
.     Gm       Cm (Eb)
   // Duo qilmoqda, //
.  Cm            Dm        Gm
   Oʻzbekistonni duo qilmoqda.
.     Gm       Cm(Eb)
   // Duo qilmoqda, //
.  Cm         Dm       Gm
   Andijonni duo qilmoqda.

[V2]
.Gm
 Zavq va ozodlik,shodlik va hayot,
.Gm
 Falakdan U yaxshi tortiq qiladi.
.   Gm     Cm  Gm         Eb
 // Unga sajda qilgan kimsaga,
.Cm      Dm       Gm
 Xudo inoyatin beradi. //</lyrics>
<title>Bizlarga falak ochiq Q104</title>
</song>