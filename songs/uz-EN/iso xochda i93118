<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Xochda</title>
<lyrics>[V1]
 // Iso xochda jon berganding
 Najot uchun
 Sen tirilding
 Kechir bir kam gunohlarim
 Doʻstim Rabbim Najotkorim
 Oʻzgartir hayotimni
 Rabbim senga xizmat qilay
 Yangila hayotimni
 Uni senga men bagʻsh etay //

[B1]
   Hayotim yangilagin
   Men senga xizmat qilay
   Hayotim yangilagin
   Sen uchun yashay
   Sen uchun doim doim yashay</lyrics>
</song>