<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23313</hymn_number>
<author>Sobir Umurov</author>
<title>Kel, Kel, Kel</title>
<aka>Sen Kelyapsan</aka>
<lyrics>[V1]
.Em         C  D          Em
 Sen Kelyapsan buni zamon aytyapti
.Em         C    D              Em
 Sen yoʻldasan buni yuragim xis qilyapti
.Em             C    D         Em
 Sen Kelyapsan Iso buni zamon aytyapti
.Em             C    D          Em
 Sen yoʻldasan Iso buni yuragim his qilyapti

[C1]
.   C   D  Em
   Kel Kel Kel
.   C        D          Em
   Iso Masix Qudrat bilan kel.
.   C   D  Em
   Kel Kel Kel
.    C      D        Em
   Ulugʻvorlik ila Iso kel.

[V2]
 Dunyo qolar hayratda,
 Seni koʻrgan chogʻida.
 Farzandlar xursand bular,
 Xudo Oʻgʻlini koʻrganda.</lyrics>
<key>Em</key>
</song>