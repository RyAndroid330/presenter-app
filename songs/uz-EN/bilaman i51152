<?xml version="1.0" encoding="UTF-8"?><song><title>Bilaman</title>
<lyrics>[V1]
.Em            C            G
 Meni ozod qilgan Rabbim Qoni,
.             D            Em
 Gunohimni yuvib poklar meni
.                C             G
 Mening ichimda borligʻing yashar
.             D                Em
 Yuragim quvonar, Borligʻim quvonar

[V2]
.                C          G
 Qamrab olgan haqiqating meni
.              D             Em
 Inoyating tiklar singan qalbimni
.                  C           G
 Muqaddas Ruh kuchli daldam meni
.                 D                 C
 Muhabbating buyuk, Muhabbating buyuk

[C1]
.  G           D      Em        C
   Bilaman berding - Sen yagona Oʻgʻlingni
.  G            D      Em         C
   Bilaman boʻlding - Sen yagona Xaloskor
.      G            D   Em            C
   Kelding - Men uchun, xochga bording
.      G       D   Em          C
   Berding sevgi, loyiq boʻlmasam ham</lyrics>
<key>G</key>
<author>Hillsong, Hillsong United</author>
<hymn_number>12507</hymn_number>
</song>