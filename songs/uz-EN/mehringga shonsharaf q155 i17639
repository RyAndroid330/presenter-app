<?xml version="1.0" encoding="UTF-8"?><song><title>Mehringga shon-sharaf Q155</title>
<lyrics>[V1]
.   C#                   A#m
 // Birodarim eslagin sevgi soʻzini
.F#                 D#m     C#
 Diling bilan anglagin soʻzning sirini! //

[C1]
.     C#                D#m    C#
   // Muhabbat qoʻshigʻi osmonga chiqsinki
.  D#m           F#
   Rabbimga shon, Rabbimga shon
.  G#            C#
   Mehringga shon-sharaf! //

[V2]
 // Xaloskorda dunyoga muhabbat keldi
 Yosh oqizgan insonga orom keltirdi! //

[C2]
   // Muhabbat insonga, baxtlik berdi jonga
   Rabbimga shon, Rabbimga shon
   Mehringga shon-sharaf! //

[V3]
 // Goʻzal quvonchga toʻlgan Muhabbat soʻzin
 Dilga yoqimli boʻlgan Xudo soʻzlari! //

[C3]
   // Rabbim muhabbati ruhni uygʻotadi
   Rabbimga shon, Rabbimga shon
   Mehringga shon-sharaf! //
.     G#            C#
   // Mehringga shon-sharaf! //</lyrics>
<key>F#</key>
<aka>Birodarim eslagin sevgi soʻzini</aka>
<hymn_number>155</hymn_number>
</song>