<?xml version="1.0" encoding="UTF-8"?><song><aka>Xudovandga yangi bir qoʻshiq ayting</aka>
<key>A</key>
<lyrics>[C1]
.     F#m                     Bm
   // Xudovandga yangi bir qoʻshiq ayting,
.  D                E         F#m
   Chunki U koʻp moʻjizalar yaratdi. //
.     F#m                   Bm
   // Oʻzining oʻng qoʻli muqaddas qoʻli,
.  D         E       F#m
   Unga zafarlar keltirdi. //

[V1]
.A
 Ey, butun yer yuzi Xudovandni olqishlang,
.Bm         D       E          F#m
 Quvnab kuy kuylang cholgʻu chaling.
.A
 Xudovand shaʼniga gʻijjak chaling,
.Bm             D        E    F#m
 Gʻijjak chalib qoʻshiqlar ayting.
.   D                      Bm
 // Karnay va surnay tovushlari bilan
.D            E           F#m
 Podshohimiz Xudovandni kuylang! //

[C2]
.     F#m              Bm
   // Xudovandga yangi bir qoʻshiq ayting,
.  D             E             F#m
   Chunki U koʻp moʻjizalar yaratdi. //
.     F#m            Bm
   // Oʻzining oʻng qoʻli muqaddas qoʻli,
.  D          E      F#m
   Unga zafarlar keltirdi. //

[V2]
.F#m                       D
 Dengiz va undagi barcha mavjudot,
.Bm                        E         A
 Dunyo va unda yashaydiganlar joʻsh ursin.
.D
 Xudovand oldida daryolar qarsak ursin,
.Bm                      E       A
 Togʻlar ham qoʻshilib tarannum etsin!
.D                            Bm
 Chunki U yerni hukm etgani keladi.
.Bm                          A
 U keladi-da dunyoni adolat bilan,
.Bm                           D
 Xalqlarni odillik bilan hukm qiladi.
.   D          E        F#m
 // Xalqlarni odillik bilan! //</lyrics>
<title>Chunki U koʻp moʻjizalar yaratdi Q130</title>
<hymn_number>130</hymn_number>
</song>