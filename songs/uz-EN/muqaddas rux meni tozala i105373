<?xml version="1.0" encoding="UTF-8"?><song><author>Timutiy</author>
<title>Muqaddas rux meni tozala</title>
<key>Am</key>
<lyrics>[V1]
.   Am                  Em
 // Tangrim Yaratguvchi Otam
.F      G   Am
 Rabbim Iso Masix
.Am           Em
 Muqaddas ruxing bilan meni
.F       G      Am
 Etakla tugʻri yulinga //

[C1]
.  Dm          Am
   Yuragim, ongim, fikirim.
.   G              Am
   Qalbim toza pok bulmasa
.  Dm          Am
   Yulib olib tashla olovga.
.  G                Am
   Iso senga tugʻri kelmasa.

[C2]
   Ogʻzim bilan faqat ulugʻlay.
   Sano aytib Rabbim Isoga.
   Gʻibat, yolgʻon, nafrat suzlardan.
   Muqaddas rux meni tozala.

[V2]
 // Burgutday qilgin gʻayratli
 Ilonday sezgir bulayin.
 Muqaddas ruxinga tuldirgin.
 Kabutarday bulay mulayim. //

[V3]
 // Notugʻri kursa kuzlarim
 Yulib olib tashagin Rabbim.
 Muqaddas ruxing bilan meni.
 Tozala, qayta ishlagin. //</lyrics>
</song>