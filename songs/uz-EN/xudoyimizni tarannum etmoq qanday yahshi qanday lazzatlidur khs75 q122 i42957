<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>75</hymn_number>
<key>E</key>
<lyrics>[C1]
.  C#m      E
   Hamdlar boʻlsin!
.           F#m
   Hamdlar boʻlsin!
.  B        E
   Hamdlar boʻlsin!
.      F#m           C#m
   // Xudoyimizni tarranum etmoq,
.         A    Bm            C#m
   Qanday yaxshi, qanday lazzatlidur. //

[V1]
.C#m E             F#m B    E
 Quddusni, qayta qurajak Xudovand.
.  E             F#m         E
 Isroilning tarqalib ketganlarini,
.         F#m    E
 Oʻzi toʻplab olajak.
.     F#m         B        E
 U ezilgan koʻngillarni davolab,
.     F#m     A Bm   C#m
 Yaralariga malham surtadi.
.      F#m          B  E
 U yulduzlar sonini belgilab,
.     F#m  A    Bm     C#m
 Hammasini noma-nom chaqiradi.

[C2]
   /// Hamdlar boʻlsin! ///
   // Xudoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur. //

[B1]
.  C#m              B      F#m E
   Rabbimiz buyuk, quvvati azmdur.
.  A               B           F#m E
   Donoligini, esa oʻlchab boʻlmaydi.
.  F#m                  B        E
   Xudo hokisorlarni, yuqori koʻtarar.
.         F#m     A  Bm    C#m
   Betofiqlarni, esa erga urar.

[C3]
   /// Hamdlar boʻlsin! ///
   Xudoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur.
   Isoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur.

[V2]
.      F#m            E
 Xudovandga shukrona aytib,
.      F#m        E
 Kuylanglar, kuylanglar.
.      F#m       E       F#m   E
 Gʻijjakda kuylanglar, Xudoyimizni.
.      F#m      B         E
 U bulutlar ila, osmonni qoplaydi.
.       F#m   B      E
 Yer uchun, yomgʻir hozirlaydi.
.     A        Bm         C#m
 Togʻlarda esa giyoh oʻstiradi.
.    E         F#m    B        E
 Hayvonlarga, U rizqi-roʻzini beradi.
.       F#m    A                 Bm      C#m
 Qarrilaydigan qargʻa bolalarini toʻygʻizadi.

[C4]
   /// Hamdlar boʻlsin! ///
   // Xudoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur. //

[V3]
.C#m                       B        F#m    E
 Xudovand otning, kuch-quvvatidan rozi boʻlmas.
.A                            B       F#m    E
 Chopqirning boldirlari, Unga manzur boʻla olmas.
.   C#m   F#m        B            E
 // Xudovand oʻzidan qoʻrqadiganlardan,
.     F#m B     E
 Inoyatiga umid bogʻlaganlardan. //
.A     Bm    C#m
 Rozi, rozi boʻlar.

[C5]
   /// Hamdlar boʻlsin! ///
   Xudoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur.
   Isoyimizni tarranum etmoq,
   Qanday yaxshi, qanday lazzatlidur.
   // Mana U koʻp maqtovga munosibdir! //</lyrics>
<aka>Hamdlar boʻlsin!</aka>
<title>Xudoyimizni tarannum etmoq, qanday yahshi, qanday lazzatlidur ҲС75 Q122</title>
</song>