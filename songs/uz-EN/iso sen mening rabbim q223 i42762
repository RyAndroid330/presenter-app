<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>223</hymn_number>
<title>Iso Sen mening Rabbim Q223</title>
<key>Ab</key>
<lyrics>[V1]
.   C#                     F#        Ab
 // Iso Sen mening Rabbim, mening Xaloskorim.
.C#                     F#        Ab
 Iso Sen mening Rabbim, mening Najotkorim. //

[C1]
.           F#          Ab     Fm          Bbm
   // Hamma maqtovlarim Senga, olqishlarim Senga,
.  Ebm                  Ab    C#
   Moʻjizalaring koʻrib quvonaman.
.        F#          Ab       Fm        Bbm
   Hamma maqtovlarim Senga, olqishlarim Senga,
.  Ebm                 Ab       C#
   Huzuringda xursand boʻlib kuylayman. //

[V2]
.     C#                   F#     Ab
 //// Iso mening qalqonim, mening hayot tojim. ////

[C2]
   // Dilim bilan quvonaman, ruhim ila shodman,
   Kuylayman har doim Rabbim men Senga. //
   // Hayotimni oʻzgartirding, ruhimni shod etding,
   Yolgʻiz Senga men Rabbim talpinaman. //</lyrics>
</song>