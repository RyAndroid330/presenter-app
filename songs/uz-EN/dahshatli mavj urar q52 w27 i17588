<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>273</hymn_number>
<author>QURBON MUKUMOV</author>
<title>Dahshatli mavj urar Q52 W27</title>
<key>G</key>
<lyrics>[V1]
 Intro:
.G  Bm Em Em7/C D G D
 -__
. G Bm Em Em7/C D G
 -
.   G                   Bm     Em
 // Dahshatli mavj urar, hayot ummoni,
.C             D           G   D
 Toʻfon qoplar hayotim qayigʻin!
.G             Bm    Em
 Vahima ostida kulfatda doim,
.C         D           G
 Yo Xudoyim eshitgin zorimni! //

[C1]
.  C      D         G     Em    Em7
   Rahm qilib menga najot ber Oʻzing!
.  C             D      G       Em/Em7
   Hayotning qoʻrquvi bosar meni,
.  C          D       G    Em     Em7
   Kurashga mador yoʻq ojizman Rabbim!
.  C          D          G
   Yo Xudoyim eshitgin zorimni!

[V2]
 // Amrlaring sokin bandargohiga
 Qadamim yoʻlatib bergin orom
 Hayot tashvishlari tubsiz girdobidan
 Qirgʻoqqa yetkaz aziz Xudoyim! //

[C2]
   //// Rahm qilib menga najot ber Oʻzing!
   Hayotning qoʻrquvi bosar meni,
   Kurashga mador yoʻq ojizman Rabbim!
   Yo Xudoyim eshitgin zorim! ////</lyrics>
<aka>Hayot Ummoni</aka>
</song>