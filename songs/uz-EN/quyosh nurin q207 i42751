<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>207</hymn_number>
<lyrics>[V1]
.   Em                  G        Am
 // Quyosh nurin saxiy sochar yurtimga,
.Em         G      D     Em
 Xudovandimning bu marhamati. //
.   Em              G       Am
 // Daraxtlar meva tugar mavsumida,
.Em         G       D    Em
 Xudovandimning bu marhamati. //

[C1]
.     Am             Em      Am            Em
   // Sogʻlik berar tanamga, bardam qilar ruhimni,
.  Am           Em         D        Em
   Meni sevgan Xudovandga jonimni beraman. //

[V2]
.Em                     G     Am
 Makonida tinchlik abad hukm surar,
.Em         D    G            Em
 Solihlari Unga faqat xizmat qilar.
.G                               Am
 Yuragimga Oʻzi faqat tinchlik berar,
.Am                          Em
 Inoyatim berganiga men ham beraman,
.Am                          D     Em
 Oʻzim borimdan bir qismini Unga beraman.

[V3]
.Em              G               Am
 Hayot makonimga U ham urugʻ sochar,
.Em          D         G      Em
 Parvarishda Oʻzi doim birga boʻlar.
.G                              Am
 Hosil paytta meni kutib chetta turar,
.G                  Em      Am
 Inoyatim berganiga men ham beraman,
.G                          B    Em
 Oʻzim borimdan bir qismini Unga beraman.

[B1]
.     Em                           Am
   // Quyosh nurin saxiy sochar yurtimga,
.  G                      Em
   Xudovandimning bu marhamati. //
.     Em                       Am
   // Daraxtlar meva tugar mavsumida,
.  G                      Em
   Xudovandimning bu marhamati. //</lyrics>
<key>Em</key>
<title>Quyosh nurin Q207</title>
</song>