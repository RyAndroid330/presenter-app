<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Halqlar Umidi ҲСХМ144</title>
<key>A</key>
<lyrics>[V1]
.A                            D        F#m
 Iso xalqlar umidi, Iso tinchlik manbaisan,
.      E       D       E
 Sen yerdagi, jannat umidisan.
.A                                D     F#m
 Iso nur bu zulmatda, Iso yagona yoʻldirsan.
.      E          D       E
 Sen yurakda porlayotgan nurim.
.    D                F#m
 Sen biz uchun yerga kelding,
.Bm            E
 Qoning bilan xalos qilding.

[C1]
.          A         D          E              A
   Sensan najot, umidimiz, biz ishongan hayot toshimiz.
.       F#m          D             E
   Bu dunyoda hamma uchun porlagan nur.
.              A          D
   Sen yer qabridan koʻtarilding, tinchlik
.     E         A
   Shohimiz yetaklagin.
.         F#m         D             E             A
   Butun borliq olam uchun boʻlgan najot Sensan Rabbim!

[B1]
.     A
   // Sensan Rabbim!
.           D            F#m
   Sen biz uchun xochga bording.
.  Bm           E
   Sevgi berib qayta tirilding! //</lyrics>
<author>Brian Doerksen</author>
<hymn_number>144</hymn_number>
</song>