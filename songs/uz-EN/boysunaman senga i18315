<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12</hymn_number>
<title>Boʻysunaman Senga</title>
<aka>Bepoyondir sevging</aka>
<lyrics>[V1]
.D            G
 Bepoyondir sevging, inoyating cheksiz,
.D            G
 Tengi yoʻq najotni, abadiy hayot
.Em           G
 Sen menga berding.

[V2]
.D                G
 Otajonim Rabbim quvonchim baxtim,
.D                   G
 Sensan Qutqaruvchim va marhamating
.Em          G
 Sen menga berding.

[C1]
.  D             A
   Boʻysunaman Senga,
.  D                  A
   Hayotimni beraman Senga.
.  D             A
   Meni qamrab olarsan,
.         Bm   G       A   D
   Boshim egarman huzuringda.</lyrics>
<key>D</key>
</song>