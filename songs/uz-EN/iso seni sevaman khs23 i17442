<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Seni sevaman ҲС23</title>
<lyrics>[V1]
 // Iso Seni sevaman //
 Faqat Seni sevaman,
 Va Senga men oʻzimni bagʻishlayman.
 Iso Seni sevaman

[V2]
 // Iso Sen ajoyibsan! //
 Ismingni takrorlayman,
 Ulugʻlayman va madhlayman men Seni!
 Iso Sen ajoyibsan!</lyrics>
<hymn_number>23</hymn_number>
</song>