<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Samoviy Otamizga
 Boʻlsin doim shon
 Uning mehribonligi
 Bizga bepoyon! //

[C1]
   // Shon-sharaflar Rabbimizga!
   Hamdo sano Xudoga!
   Muqaddas Ruhing bizga,
   Yor boʻlsin ey, Oming! //

[V2]
 // Xaloskorim Senga ham
 Boʻlsin doim shon
 Faqat Senda najot topdi
 Gunohkor inson! //

[V3]
 // Muqaddas Ruh Senga ham
 Boʻlsin doim shon
 Ogʻir hayot yoʻlimizni
 Sozlaysan osson! //</lyrics>
<title>Samoviy Otamizga</title>
</song>