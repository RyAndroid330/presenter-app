<?xml version="1.0" encoding="UTF-8"?><song><author>Bauirjan Pulatov</author>
<key>Em</key>
<lyrics>[V1]
.Em             D   Em
 Kelar kuni Rabbimning,
.Am      H7      Em
 Yaqin qoldi azizlar,
.Em        Am     D  G
 Bu duniyoning arzimas,
.   Am    H7      Em
 // Aldamasin tashvishlar. //

[C1]
.  Em         Am     D  G
   Xursand boʻlib yuraylik,
.  Am      H7     Em
   Xudovandga kuylaylik.
.  Em          Am   D   G
   Xudo bergan shodlikning,
.  Am    H7      Em
   Qadriga yetaylik.
.  Am     H7      Em
   Iso Masih tufayli, (Sevgisida Isoning,)
.     H7               Em
   Xursand boʻlib yuraylik.

[V2]
 Huzuriga Xudoning,
 Minnatdor boʻlib kelinglar,
 Bor muhtojliklaringni,
 // Xudovandga beringlar. //

[V3]
 Yuragingdan doimo,
 Xursandchilik ketmasin,
 Tinchlik kelib Isodan,
 // Balo-qazo yetmasin. //</lyrics>
<title>Xursand boʻlib yuraylik</title>
</song>