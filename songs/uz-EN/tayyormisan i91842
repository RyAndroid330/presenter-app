<?xml version="1.0" encoding="UTF-8"?><song><title>Tayyormisan</title>
<key>Em</key>
<lyrics>[V1]
.Em                    C
 Iso koʻz yosh toʻkadi har birimizni sevadi
.Am                 H
 Har birimiz uchun jonin fido qilgandi
.Em                      C
 Gunohkormisan yoki yoʻk Unga buni farqi yoʻq
.Am                   H
 Agar tavba qilsang Xudodan boʻlar koʻngling toʻq

[C1]
.     C  D    Em      Am   H   Em
   // Tayyormisan yuragingga bir qara
.  C  D    Em       Am     H  Em
   Tayyormisan hayotingga bir qara //

[V2]
.Em                  C
 Yaqinda Iso keladi xursand boʻlib aytadi
.Am                    H
 Qani kelinglar Mening hayot maskanimga
.Em                        C
 Boshqalarga qarab aytadi sizlarni tanimayman
.Am                    H
 Gunohkor ishlaringiz Mendan ayirdi sizni</lyrics>
<hymn_number>23006</hymn_number>
<author>Sobir Umurov</author>
</song>