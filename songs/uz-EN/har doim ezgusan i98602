<?xml version="1.0" encoding="UTF-8"?><song><key>F</key>
<lyrics>[V1]
.F                Fmaj7
 Togʻlar bagʻrida kutarsan,
.F            Fmaj7
 qayerdaligim bilarsan,
.Bb                     F  Fmaj7
 Uysiz darbadarman - Sensiz

[V2]
.F               Fmaj7
 Ming oʻ-yu hayollarimda,
.F            Fmaj7
 savollarimga Sen javob
.Bb                   F Fmaj7
 Sevging toʻla hayotimda

[P1]
.  Bb                           Dm
   Qoʻrquvlarim ol, tinchlik bergin
.  Bb                         C
   Ogʻir yukim ol, yengil qilgin

[C1]
.             Bb
   Seni kuylayman,
.    F       C
   Ezguligingni,
.               Bb
   Tinmay kuylayman
.   F        C
   Muruvvatingni,
.               Dm
   Quyosh botganda
.  C
   Sen bor yonimda,
.  Bb                  F Fmaj7
   Har doim Ezgusan menga.

[V3]
.F             Fmaj7
 Komil qilgin imonimni
.F              Fmaj7
 Yasab oʻzgartirgin meni
.Bb                   F  Fmaj7
 Toki boʻlay Senga maqbul

[B1]
.  F/A
   Har bir sanoyim
.  Bb
   Marhamat qilib Sen
.  C
   Qaytarding Sen</lyrics>
<title>Har doim Ezgusan</title>
<author>Hannah McClure / Rita Springer</author>
<hymn_number>30513</hymn_number>
</song>