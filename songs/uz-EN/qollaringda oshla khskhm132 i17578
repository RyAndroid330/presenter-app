<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>132</hymn_number>
<author>Hillsong</author>
<title>Qoʻllaringda oʻshla ҲСХМ132</title>
<aka>Senga Kelib Hudo</aka>
<key>D</key>
<lyrics>[C1]
.  D         A
   Qoʻllaringda ushla,
.  Bm        G
   va qoʻyib yuborma!
.  D         A
   Mangu Sen bilan,
.     Bm           G
   boʻlishni hohlayman!

[V1]
.D       A     Bm
 Senga kelib Hudo,
.D        A     Bm
 Hamdlarim kuylayman!
.D       A     Bm
 Menga kerak faqat,
. G            D
 Iso Sening sevging!
.D       A      Bm
 Hayotim qoʻlingda,
.D        A      Bm
 men uchun oʻlgansan,
.D       A     Bm
 Menga kerak faqat,
. G       D
 Iso ezguliging!

[V2]
 Endi, yonimdasan,
 Atrof oʻzgargandir,
 Boʻtunlay oʻzgargandir - Rab!
 Ahir, boshqa hayot,
 Sovgʻa qilding,
 Sen bilan boʻlishni,
 xoxlayman har doim!

[B1]
.  Bm       G          D  A
   Doim men kuylayman Senga!
.   Bm         A
   Men, abadiy xuzuringda,
.  Bm             G
   Boʻlishni istayman!</lyrics>
</song>