<?xml version="1.0" encoding="UTF-8"?><song><title>Najot galdi</title>
<key>Cm</key>
<lyrics>[V1]
.   Cm       Fm           Ab       Gm     Cm
 // Osmondan najot galdi, Xudodan xabar galdi, //
.   Fm           Ab      Fm          Gm   Cm
 // Insonlarninq kalbina yarqillagan nur geldi. //

[C1]
.     Fm                    Ab        Gm      Cm
   // Ozodlik yoʻlin berdi, yorugʻlik yoʻlin berdi, //
.     Fm                   Ab          Gm
   // Insonlarninq kalbina yarqillagan nur geldi. //

[V2]
 // Nur zulmatda porladi, zulmat qoplay olmadi, //
 // Har nainki ot boʻlsaya Iso bilan yaraldi. //

[V3]
 // Nur borinda yuringlar, Unga xizmat etinglar, //
 // Sevgisidan totinglara, Ruhindan ruhlaninglar. //

[V4]
 // Yaratganin nomidan ming roziman Oʻgʻlidan,
 Bergan yorqin yoʻlindana, shodlanaman koʻnglimdan. //</lyrics>
</song>