<?xml version="1.0" encoding="UTF-8"?><song><author>Ulugʻbek Joʻrayev</author>
<lyrics>[C1]
   // Xayolimdasan yuragimdasan
   Seni sevaman Iso
   Qalban intilib Seni sogʻinib
   Yashayapman (kutayapman) men //

[V1]
 Bu dunyoning dastidan
 Yurak toʻla jarohat
 Orzu emas armon koʻp
 Koʻzda toʻla yoshlar

[V2]
 Azoblardan qiynalib
 Dardim oshkora etib
 Armonlarga topolmay yechim
 Keldim huzuringga Rabbim

[C2]
   // Xayolimdasan yuragimdasan
   Seni sevaman Iso
   Qalban intilib Seni sogʻinib
   Yashayapman (kutayapman) men //

[B1]
   Sen mening Najotkorim
   Sen mening Yupatuvchim
   Koʻz yoshlarim artguvchim
   Qalbga tinchlik berguvchim
   Umidimsan Rabbim

[C3]
   // Xayolimdasan yuragimdasan
   Seni sevaman Iso
   Qalban intilib Seni sogʻinib
   Yashayapman (kutayapman) men //</lyrics>
<title>Xayolimdasan yuragimdasan</title>
</song>