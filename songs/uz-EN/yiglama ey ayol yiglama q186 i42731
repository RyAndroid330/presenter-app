<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>186</hymn_number>
<title>Yigʻlama ey ayol yigʻlama Q186</title>
<lyrics>[V1]
 // Yigʻlama ey ayol yigʻlama, sen uchun Masih oʻlgan, //
 // Va qaytadan tirilib, sen uchun hayot bergan. //

[V2]
 // Yigʻlama hech yigʻlama sen uchun Masih kelgan, //
 // Xoʻrlanma xop yuraging hayoting tugalmagan. //

[V3]
 // Kel endi Rabbimizning farzandi dilbandi boʻl, //
 // Shahanshoh sultonining ruhoniy malikasi. //

[V4]
 // Qalbingda Rabbiy yashar,bagʻringga quvonch kelar, //
 // Hijronli tunlaringda Rabbiy yoningda boʻlar. //</lyrics>
</song>