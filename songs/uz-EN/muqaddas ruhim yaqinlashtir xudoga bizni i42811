<?xml version="1.0" encoding="UTF-8"?><song><title>Muqaddas Ruhim, Yaqinlashtir Xudoga bizni</title>
<lyrics>[V1]
.   Am
 // Yurakda ruh alanga olar,
.Dm                  Am
 Osmon tomon yoyilib borar.
.Dm                C
 Ibodatni yetkazib borar,
.Bb          Gm        Am
 Oqlovchidir Muqaddas Ruhim.
.Dm                C
 Ibodatni yetkazib borar,
.Bb          Gm        Am
 Oqlovchidir Muqaddas Ruhim. //

[C1]
.     Am              G        Am
   // Muqaddas Ruhim, mehribon doʻstim.
.  Dm           Em     Am
   Yaqinlashtir Xudoga bizni.
.  Am              G        Am
   Muqaddas Ruhim, mehribon doʻstim.
.  Dm          Em       Am
   Uzoqlashtir gunohdan bizni. //

[V2]
 // Qalbimga U ishonch bagʻishlar,
 Madad berar tolgan yurakka. //
 // Ruhlantirar tolgan yurakni,
 Saqlovchidir Muqaddas Ruhim. //

[V3]
 // Iso Masih bergan sovgʻa bu,
 Tezroq oling qimmat sovgʻa bu. //
 // Yuragimda sevgi uygʻonar,
 Masih tomon intilib borar. //</lyrics>
<key>Am</key>
</song>