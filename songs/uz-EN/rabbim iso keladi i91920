<?xml version="1.0" encoding="UTF-8"?><song><title>Rabbim Iso Keladi</title>
<lyrics>[C1]
.     Am             F
   // Rabbim Iso keladi,
.  Em             Am
   keladi U yaqin orada
.  Am              F
   Oʻz jamoatin oladi,
.  Em             Am
   oladi Oʻz maskaniga //

[V1]
.   Am             Dm Em   Am
 // Solih boʻl, boʻlgin Muqaddas,
.Am              Dm Em    Am
 Imonda boʻl, boʻlgin har nafas. //

[V2]
.C         G    Dm     Am
 Samoda solihlar bazmi boʻladi,
.Dm    Am       Em     Am
 Ota farzandlarin qayta quchadi.
.G           C    Dm     Am
 Shod boʻl, quvon ey birodarim,
.Dm          Am         Em      Am
 Sen bilan osmonda yangi Quddus shahrida.

[V3]
.C          G    Dm   Am
 Samoda solihlar bazmi boʻladi,
.Dm      Am      Em    Am
 Ota farzandlarin qayta quchadi.
.C          G         Dm    Am
 Isoning nurli yuzini birga koʻramiz,
.Dm           Am    Em  Am
 Quvnaymiz qoʻshiqlar aytamiz.</lyrics>
<key>Am</key>
<author>Sobir Umurov</author>
</song>