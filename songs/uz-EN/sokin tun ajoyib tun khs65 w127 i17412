<?xml version="1.0" encoding="UTF-8"?><song><title>Sokin tun, ajoyib tun ҲС65 W127</title>
<lyrics>[V1]
 Sokin tun, ajoyib tun
 Farishtalar madh kuylagan
 Munajjimlar sharqdan izlagan
 Shimʼoʻn bobo ham juda kutgan
 // Najotkor Masih kelgan,
 Bugun Iso tugʻilgan //

[V2]
 Sokin tun, ajoyib tun
 Kalomulloh yerga keldi
 Samodan kelgan bizlar uchun
 Ilohiy nurin bizga sochgan
 // Najotkor Masih kelgan,
 Bugun Iso tugʻilgan //

[V3]
 Sokin tun, ajoyib tun
 Gunohlarni yuvish uchun
 Doʻzaxdan bizlarni asrash uchun
 Xudovand oldida oqlash uchun
 // Najotkor Masih kelgan,
 Bugun Iso tugʻilgan //</lyrics>
<hymn_number>65</hymn_number>
</song>