<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.C            G
 Mening Isom, Najotkorim
.Am       G        F
 Sen kabi hech kim yoʻq
.          C     F            C
 Bor kunlarim, Sening sevgingni,
.Dm              Bb     G
 Buyuk mehringni kuylayman.

[V2]
.C           G
 Tinchligim, panohim
.Am           G        F
 Kuchsiz boʻlganda kuchim
.         C       F      C
 Bor yuragim, borligʻim ila,
.Dm          Bb    G
 Kuylayman Seni Rabbim.

[C1]
.  C        Am    F          G
   Xudoga kuyla dunyo biz bilan,
.      Am     F        C       G
   Maqtov kuyini kuylaymiz Shohga
.  C           Am          F
   Tiz choʻkar togʻlar, ummonlar kuylar,
.         G   F      G
   Sen uchun, Sen uchun.
.  C         Am         F         G
   Men kuylayman Sening bor ishlaringni,
.  Am       F       C       G
   Abadiy sevaman Seni men Iso.
.  C           Am         F        G       C
   Yoʻq hech narsa sevgingni, oʻrnini bosuvchi.</lyrics>
<key>C</key>
<title>Mening Isom, Najotkorim</title>
<hymn_number>102</hymn_number>
<author>Darlene Zschech</author>
