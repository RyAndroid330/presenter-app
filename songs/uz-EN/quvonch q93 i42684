<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>93</hymn_number>
<title>Quvonch Q93</title>
<lyrics>[V1]
 // Xudo bergan sevinch nuri qalbimizdan soʻnmasin, //
 // Xudo bizni boshqaradi, bizga yordam beradi. //
 // Musibatdan qutqaradi, bizga quloq soladi.2 //

[C1]
   //// Quvonch quvonch doim quvonch,
   Tinmay xursand boʻlaylik.? ////

[V2]
 // Masih izidan boraylik, Unga yaqin boʻlaylik. //
 // Ogʻir mushkul ostida nobud boʻlib ketmaylik. //

[V3]
 // Hayotbaxsh imon quvonchi quyoshdek porlab tursin. //
 // Xudo bizlarni sevadi,dillar xotirjam boʻlsin. //</lyrics>
</song>