<?xml version="1.0" encoding="UTF-8"?><song><title>Tashnaligimni</title>
<key>C#m</key>
<lyrics>[V1]
.   C#m            F#m
 // Tashnaligimni Sen qondir Rabbim
.H                     G#m
 Ojiz qalbimni Sen toʻldir Tangrim
.       C#m                F#m
 Sensiz yashay olmasman, yonimda boʻlgin
.    H                 G#m
 Qoʻllaringda meni doim saqlagin! //

[C1]
.  A                        G#m
   Sendek boʻlgim kelar, oʻzgartir meni
.    F#m                  C#m     G#m
   Muqaddasligingda pokla hayotimni
.  A                        G#m
   Hayotim mazmunsiz boʻlib qolar Sensiz
.  F#m                  C#m         H
   Sen bilan birga yashamoq istayman

[B1]
.     A                     C#m
   // Soʻngan ruhim qayta tirilmoqda
.  E                   H
   Yuragim yana Senga talpinmoqda
.       A                  C#m
   Koʻzlarim koʻrmoqda Sening jamolingni
.      E                   H
   Qalbim orom topmoqda Senda ey Tangrim //</lyrics>
<author>New Sreation</author>
</song>