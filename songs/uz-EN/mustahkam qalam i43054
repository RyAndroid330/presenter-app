<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>11238</hymn_number>
<lyrics>[V1]
.E            A
 Xudo bergan sevinch nuri,
.C#m         B
 Qalbimizdan soʻnmas aslo.
.E            A
 Quyoshdayin porlar doim,
.       C#m      B
 Sening nuring bizda doim.

[C1]
.  E   B       A
   Mustahkam qalʼam,
.          B          C#m
   Sen bilandir har qadam.
.          A              C#m
   Mening kuchim, mening Rabbim,
.         A     B      E
   Faqat Sensan Xudovandim.

[V2]
 Botir yurak, najot, iymon,
 Qalbimizdadir har on.
 Zulmat bizni yengmas aslo,
 Uning kuchi boʻlgan ado.</lyrics>
<key>E</key>
<title>Mustahkam Qalam</title>
</song>