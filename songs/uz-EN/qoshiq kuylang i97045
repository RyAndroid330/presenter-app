<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<title>Qoʻshiq kuylang</title>
<key>Em</key>
<lyrics>[V1]
.Em     Am      D    Em
 Xudoga, qudratimiz manbaiga
.Am       D      G
 Sevinch ila kuylang
.Am    D   Em Am D    Em
 Yoqubning Xudosiga shodlik ila hayqiring

[C1]
.  Em               Am
   Qoʻshiq kuylang doira cherting
.  C           D
   Xushovoz lira arfa chaling
.  Em             Am
   Burgʻu chalib xursand boʻling
.  C          D       Em
   Ey azizlar Egamizni kuylang

[V2]
 Egamiz buyuklarning buyugi
 Yeru osmoning Egasi
 Bizga hayot beruvchi tingchligimiz posboni</lyrics>
</song>