<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>19</hymn_number>
<key>D</key>
<lyrics>[V1]
.   D             G      D
 // Bizning osmondagi Otamiz
.          A    D
 Sening noming ulugʻ! //
.   D             G
 // Osmonda boʻlgani kabi
.D           A     D
 Erda ham noming ulugʻ! //

[C1]
.     D                G
   // Hamdlar boʻlsin, hamdlar boʻlsin
.  D                A D
   Hamdlar boʻlsin Otaga! //

[V2]
.   D           G      D
 // Bizga gunoh qilganlarni
.             G   D
 Biz kechirib yuramiz //
.   D               G          D
 // Sen ham bizning gunohlarimizni
.      A     D
 Kechirgin Ota //

[V3]
.   D            G            D
 // Rizq-roʻzimizni kunda bergan
.         G   D
 Otamiz muqaddas //
.   D             G
 // Kuchu qudrat, shonu shuhrat
.D            A  D
 Saltanat Senikidir! //</lyrics>
<title>Bizning osmondagi Otamiz</title>
</song>