<?xml version="1.0" encoding="UTF-8"?><song><author>Neizvestnyy</author>
<hymn_number>67</hymn_number>
<key>G</key>
<lyrics>[V1]
.G        D           Em
 Sen dunyoni qutqargansan,
.         G/B        C
 Sevgi va nurni bergansan.
.            Am                D
 Soʻngan yuraklarga umid bergansan.
.G     D        Em
 Biz Sening farzandlaringmiz,
.G/B                C
 Oldingda turib kutamiz.
.       Am7         D
 Ota Sendan minnatdormiz,
.            G
 Seni olqishlaymiz.

[C1]
.  G                    D/F#
   Shon-sharaflar Rabbimizga,
.  Em                   D
   Barcha millatu xalqlarga.
.  C                      G/B
   Qudrating Sening cheksizdir,
.  Am                    D
   Shafqating hamma xalqlarga.</lyrics>
<title>Sen Dunyoni Qutqargansan ҲСХМ67</title>
</song>