<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>20</hymn_number>
<lyrics>[C1]
   //// Men Xudoning farzandiman! ////
   Osmondan tugʻildim bugun.
   Men Xudoning farzandiman!

[V1]
 // Uzoq uzoq yoʻllar kechdim. //
 // Dunyoning zaharini ichdim. //
 // Oxiri Injilni ochdim.
 Tanladim yangi axdni men. //

[V2]
 // Iso menga boʻldi hamroh. //
 // U bilan yashayman uzoq. //
 // Qalbimdadur Muqaddas Ruh,
 Xudovandning maʼbadiman. //

[V3]
 // Xudovandga sodiq qolay, //
 // Toza pok muqaddas boʻlay. //
 // Rabbim kuch ber asrab qolay,
 Bu abadiy hayotni men. //</lyrics>
<title>Men Hudoning Q20</title>
</song>