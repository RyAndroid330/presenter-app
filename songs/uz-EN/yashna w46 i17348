<?xml version="1.0" encoding="UTF-8"?><song><author>Қuddus aka</author>
<hymn_number>46</hymn_number>
<key>Am</key>
<lyrics>[V1]
.Am                               Dm
 Iso Rabbim Xudoning Soʻzi durdonasi
.E                             Am F E
 Insoning shodligi xursandchiligi.
.Am                         Dm
 Iso Rabbim haqiqatning quyoshi
.E                             Am
 Iso Rabbim Xudoyimning haq yoʻli.

[C1]
.  FE    Am     F       G         Am
   Yashna, yashna, yashna Iso Rabbim
.  FE    Am     F       G         Am
   Yashna, yashna, yashna Iso Rabbim

[V2]
.Am                               Dm
 Iso Rabbim Xudoning Soʻzi durdonasi
.E                              Am FE
 Sendadur oʻzbegimning tasallisi.
.Am                          Dm
 Iso Rabbim madodkorlar qudrati
.E                                Am
 Sen yashnaysan bugun, erta abadiy.

[C2]
.  FE    Am     F       G            Am
    Yashna, yashna, yashna oʻzbek xalqim
.  FE   Am       F       G           Am
    Yashna, yashna, yashna oʻzbek xalqim.</lyrics>
<title>Yashna W46</title>
</song>