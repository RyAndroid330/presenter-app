<?xml version="1.0" encoding="UTF-8"?><song><aka>Geladi</aka>
<key>G</key>
<lyrics>[C1]
.  G              Am         D       C
   Eshitinglar odamlar, osmondan Iso keladi.
.  D
   Keladi, keladi.
.  G                     Am
   Ishoninglar, quvoninglar bir boshqa
.  D            C       D
   Dunyo keladi, keladi, keladi.

[V1]
.   G               (C)                 G
 // Chaqmoq chaqib otilib, quyosh oyla tutilib, //
.G                       C          Bm
 Daryo, dengizlar toʻlib, alomatlar boʻladi.
.Am                     C          D      G
 Odamzod hech koʻrmagan malomatlar boʻladi.

[C2]
.  G               Am            D   C
   Eshitinglar odamlar, osmondan Iso keladi,
.      D
   Keladi, keladi.

[V2]
.   G              (Bm)C (Am)  D       G
 // Avval dunyoga boradi, dunyo Uni tanimadi. //
.C           Bm    Am    D           G
 Kelishiga yaqin qoldi, uygʻoninglar tez keladi.

[C3]
.  G                    Am
   Ishoninglar, quvoninglar bir boshqa
.  D     C       D            G
   Dunyo keladi, keladi, keladi.

[V3]
.   G           C(Bm)    (Am)       D       G
 // Oxiratni oʻylanglar, haqiqatni tinglanglar. //
.   C         Bm          Am       D      G
 // Gunohdan qutulinglar, Najotkor Iso keladi. //

[C4]
.  G               Am
   Eshitinglar odamlar, bir boshqa
.   D    C       D
   Dunyo keladi, keladi, keladi.
.     G                C(Bm)(Am)         D     G
   // Bu dunyoda gʻaribmiz, aytganingdek yuribmiz. //
.     C           Bm        Am        D         G
   // Isoni kutib turibmiz, ishonchli qalqon keladi. //
.  G                Am             D     C
   Ishoninglar odamlar, bir boshqa dunyo keladi.
.  D               Am   C           D       G
   Eshitinglar odamlar, ishonchli qalqon keladi.</lyrics>
<title>Eshitinglar odamlar, osmondan Iso keladi Q36</title>
<hymn_number>36</hymn_number>
</song>