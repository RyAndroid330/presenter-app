<?xml version="1.0" encoding="UTF-8"?><song><author>Paul Mabury, Michael Farren, Lauren Daigle</author>
<key>G</key>
<lyrics>[V1]
.G
 Hamma orzularimni olib,
.Em
 Poylaring ostiga qoʻyaman
.Am
 Hatto adashgan chogʻlarimda,
.C                        D
 Sening sevging hech oʻzgarmaydi
.G
 Koʻp janglarda bir oʻzim kurashdim,
.Em
 Jonim toliqdi, men charchadim
.Am
 Sening orominga muhtojman,
.C                         D
 Chunki Sen qudratli Podshohimsan

[C1]
.  G                   D
    Hatto yoʻllarimdagi togʻlar siljimasa
.  Em                    C
    Hatto dengiz suvlari  aslo boʻlinmasa
.  G                   D
    Hatto savollarimga  javob ololmasam
.  Em             C            G
    Baribir, doimo men ishonaman

[V2]
 Ertanggi kunni Sen bilasan,
 kelajagim ham Senga ayondir
 Hayotim va nafasim boʻlgin,
 men irodangni istayman Rabbim

[B1]
.  C                       D
    Kuchim va Tayanchimsan, yengilmas Bilagim
.  Em                              D      C
    Mustahkam poydevorim, mening qoya toshim
.  C                      D
    Yoʻllaring ajoyibdir,  rejalaring ezgu
.  Em                      D
    Bor zamin qoʻlingdadir, borliq ham qoʻlingda</lyrics>
<title>Doimo men ishonaman</title>
</song>