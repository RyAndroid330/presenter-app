<?xml version="1.0" encoding="UTF-8"?><song><author>Morris Chapman</author>
<hymn_number>16</hymn_number>
<title>Men hech qoʻrqmayman W16</title>
<key>C</key>
<lyrics>[C1]
.     F     C     Am     F
   // Botir boʻl, kuchli boʻl!
.          C       F      G
   Chunki, Xudovand sen bilandir! //

[V1]
.   F        G       Am
 // Men hech qoʻrqmayman,
. F      G      Am
 Umidsiz boʻlmayman.
.F             G      C     Am
 Chunki, men yuraman imon bilan,
.F           G        C     Am
 Keling va yuringlar imon bilan! //

[V2]
 // Biz hech qoʻrqmaymiz,
 Umidsiz boʻlmaymiz.
 Chunki biz yuramiz imon bilan,
 Keling va yuringlar imon bilan! //
 Chunki Xudovand biz bilandir!</lyrics>
<aka>Botir boʻl, Kuchli boʻl</aka>
</song>