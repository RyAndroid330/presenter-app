<?xml version="1.0" encoding="UTF-8"?><song><title>Mehribon Menig Chopanim</title>
<key>Em</key>
<lyrics>[V1]
.   Em             C
 // Mehribon menig Chopanim,
.D          G
 Meni olgʻa boshlagin,
.Am             Em
 Qanday goʻzzal yaylaularing,
.C      D     Em
 Toʻnuq suvga opargin! //
.   Em          D
 //  Yer yuzida doʻstim boʻlgin,
.Am         G
 qoʻzilarni saqlagin,
.Am         Em
 Osmon noʻrida yondirgin,
.C    D     Em
 Adashqanni qaytargin! //

[V2]
 // Bergan vaʼdangni bajargin,
 Menga inoyyat bergin,
 Ogʻir yoʻl tomom boʻlganda,
 Jonimini qobul qilgin! //
 // Tayorlagin yuragimni,
 Amringni bajorishka,
 Men qabi imon topgandek,
 Chin qalbimdan sevishka! //</lyrics>
</song>