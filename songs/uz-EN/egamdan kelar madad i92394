<?xml version="1.0" encoding="UTF-8"?><song><title>Egamdan Kelar Madad</title>
<lyrics>[V1]
.   Em
 // Togʻlarga tikaman koʻzlarimni,
.Am
 Qayerdan kelar menga madad?
.H
 Eru osmoni yaratgan
.Em
 Egamdan, kelar menga madad. //
.   Am
 // Qoqilishimga U yoʻl qoʻymas,
.Em
 U posbonimdir, aslo mudramas.
.Am
 Ha mening posbonimdir U,
.H
 Mudramaydi, uxlamaydi U aslo. //</lyrics>
<key>Em</key>
<hymn_number>23413</hymn_number>
<author>Sobir Umurov</author>
</song>