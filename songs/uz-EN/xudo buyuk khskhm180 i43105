<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
.C      F             G
 Bor dunyo kuylar Senga,
.C      F                G
 sajda qilib ruh, haqiqatda,
.Am    F            G
 Maqtovlar aytar Senga,
.  Am      G  FDmG
 Xudo Oʻgʻli Iso.
.C    F           G
 Ulugʻlaydi bor zamin,
. C       F         G
 yoʻqdir aslo oʻxshashing.
.Am    F           G
 Borliqda, mangulikda,
. Am    G     FDmG
 faqat Sen hokim,

[C1]
.         C        Am        G        F
   Xudo buyuk, U Podshoh samoda va zaminda,
.        C         Am         G
   Bor zamin Xudo nomini ulugʻla.
.         C           Am                 F
   Xudo buyuk, Uni maqta bor samo va bor zamin,
.        Am            C               G
   Biz yashaymiz nomingni ulugʻlash uchun,
.    Am      G     F  Dm G
   Seni ulugʻlash uchun.

[B1]
.     C          G
   // Muqaddas Xudo
.            F
   dunyo kuylar.
.  Dm        G
   Senga kuylar. //</lyrics>
<title>Xudo Buyuk ҲСХМ180</title>
