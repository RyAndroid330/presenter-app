<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<author>Һәmra aka</author>
<title>Vatan W23</title>
<lyrics>[B1]
.  A              Dm   A     Bb   Am
   Osmonlarda samoviy bor mangu makon
.  A               Dm A    Bb   Am       Gm A
   Muqaddaslar vatani u goʻzal, jannat makon

[V1]
.   Dm                    Gm
 // Vatan, osmonda bordir vatan
.            Bb
 Bu dunyodan afzal
.              A
 Goʻzal ilohiy makon //

[V2]
 // Erkin, vatanda hamma erkin
 Muhabbat va adolat
 Haqiqat tantanadir //

[V3]
 // Vatan, osmonda bordir vatan
 Vatanga yetmoq uchun
 Bu zindondan ketmoq lozim //

[V4]
 // Xursand, vatanda hamma xursand
 Ohu qilganlar yoʻq hech
 Chunki Xudo bor joydir //</lyrics>
<key>Dm</key>
<aka>Vatan, osmonda bordir vatan</aka>
</song>