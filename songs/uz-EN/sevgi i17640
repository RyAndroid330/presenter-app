<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[C1]
.  G  C   G   C  G  C   G  C
   Sevgi, sevgi, sevgi, sevgi,
.     G                     C
   // Sabrli va koʻngilchangdur! //

[V1]
.G  C  G        C
 Sevgi xasad qilmas,
.G  C  G     C
 Sevgi kekkaymas
.G  C  G       C
 Sevgi shishinmas!

[V2]
 Sevgi xudbinlik qilmas
 Sevgi beboshlik qilmas
 Sevgi kek saqlamas!

[V3]
.G  C  F               C
 Sevgi nohaqlikka sevinmas
.G  C  F                   C
 Sevgi haqiqat ila shod boʻlur
.G  C  F                C
 Sevgi har narsani koʻtarar!

[V4]
 Ishonch, har yoʻlda ishonch xosil qilar
 Umid, har sharoitda umid saqlar
 Sevgi har narsaga toqat qilar

[V5]
.   C              F   C
 // Endilikda nima qoladi? //
.F           C
 Ishonch qoladi
.   C              F   C
 // Endilikda nima qoladi? //
.F        C
 Umid qoladi
.   C              F   C
 // Endilikda nima qoladi? //
.F         C
 Sevgi qoladi</lyrics>
<title>Sevgi</title>
<hymn_number>166</hymn_number>
</song>