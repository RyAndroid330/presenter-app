<?xml version="1.0" encoding="UTF-8"?><song><title>Ishlatgin meni Rab</title>
<lyrics>[V1]
.    Am7     Cmaj7
 Barhayot Najotkor
.    Em           F
 Yoʻnaltir Sen tomon
.   Am7      Cmaj7
 Muqaddas Ruhing-la
.    Em        F
 Yangilagin meni

[V2]
.      Am7        Cmaj7
 Qoʻrqmayman, men endi
.     Em          F
 Chunki Sen yonimda
.    Am7       Cmaj7
 Taxtingda, poyingda
.   Em         F
 Qilarman iltijo

[C1]
.               F             G
   Ishlatgin meni Rab, borligʻim
.               Em           Am
   Senga topshiraman, ishlatgin!
.               F           G
   Ishlatgin meni Rab, hayotim
.                  C
   Topshiraman Senga Rabbim!

[V3]
.     Am7       Cmaj7
 Shuhratim, boyligim
.    Em           F
 Senga Rabbim, olgin!
.   Am7         Cmaj7
 Mukofot, yutuqlarim
.   Em        F
 Seni ulagʻlasin

[B1]
.  Am
   Oqlading Sen, Oqlading Sen
.            G
   Pokman endi!
.   Dm
   Qutqarding Sen, Qutqarding Sen
.         Am       G
   Senikiman! Egamsan!
.  C
   Ajratolmas, ayirolmas,
.              G
   Bizni hech kim!
.        F
   Oshiqman Senga Rabbim,
.         Am G
   Senikiman!</lyrics>
<key>G</key>
<author>Naira Amirkkhanyan</author>
</song>