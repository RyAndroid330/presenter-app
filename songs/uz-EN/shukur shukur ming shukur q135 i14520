<?xml version="1.0" encoding="UTF-8"?><song><title>Shukur, shukur, ming shukur Q135</title>
<lyrics>[V1]
.   E        F#m
 // Aziz xalqini sevgan,
. C#m             F#m
 Tinchlikni bizga bergan //
.   A         Bm
 // Bizlarni duo qilgan,
. C#           F#m
 Xudoga shukur ming shukur! //

[C1]
.     E              F#m
   // Shukur shukur ming shukur
.  C#m
   Xudoga shukur ming shukur! //

[V2]
 // U bizlar uchun keldi,
 Hamma odamni sevdi! //
 // Bizlar uchun jon berdi
 Xudoga shukur ming shukur! //

[V3]
 // Endi gunoh qilmaymiz
 Xudoyim bilan yashaymiz! //
 // Qoʻshiq aytib kuylaymiz
 Xudoga shukur ming shukur! //

[V4]
 // Oʻz xalqining choponi
 Berdi bizga Isoni! //
 // Olqishlaylik Xudoni
 Xudoga shukur ming shukur! //</lyrics>
<key>E</key>
<aka>Aziz xalqini sevgan</aka>
<hymn_number>135</hymn_number>
</song>