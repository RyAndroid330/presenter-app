<?xml version="1.0" encoding="UTF-8"?><song><aka>Ehtiyot boʻl, ehtiyot,</aka>
<lyrics>[V1]
 // Oʻtgan-ketganga jar solma,
 Yaxshilik qilajak boʻlsang. //
 // Odamzod uchun qilma,
 Savob qilajak boʻlsang. //
 // Ehtiyot boʻl, ehtiyot,
 Ikkiyuzlamachi boʻlma. //
 // Insonni koʻnglin dema,
 Jannatga borajak boʻlsang. //

[V2]
 // Osmondagi otangni,
 Rozi qilgin Xudoni. //
 // Toʻkib sochgin gunohni,
 Jannatga borajak boʻlsang. //

[V3]
 // Qolsin sendan zurriyot,
 Yaxshi nomu, yaxshi ot. //
 // Xudoyimni qilgin shod,
 Baraka topajak boʻlsang. //

[V4]
 // Ota-onangni siylagin,
 Qargʻishini olmagin. //
 Oʻtkinchi dunyo, bilgin,
 Baraka topajak boʻlsang.
 Oʻtkinchi dunyo, bilgin,
 Jannatga borajak boʻlsang.
 Yaxshilik qilajak boʻlsang.
 Jannatga borajak boʻlsang.</lyrics>
<title>Utgan-ketganga Q11</title>
<hymn_number>11</hymn_number>
</song>