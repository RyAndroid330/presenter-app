<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.   C
 // Yosh va qari, yaqin va nari boʻlganlar
.        G                   C
 Shukur qilaylik, xursand boʻlaylik //

[C1]
.     F
   // Xudoyim Senga rahmat aytamiz
.           G (C)
   Shukurga loyiqsan //

[V2]
 // Shimol va sharqda, janub va gʻarbda turganlar
 Shukur qilaylik, xursand boʻlaylik //

[V3]
 // Oʻzbek va ruslar va barcha xalqlar Xudoga
 Shukur qilaylik, xursand boʻlaylik //

[V4]
 // Oriq va semiz, pakana novcha hammamiz
 Shukur qilaylik, xursand boʻlaylik. //</lyrics>
<title>Yosh va qari Q222 W28 ҲС13</title>
<hymn_number>222</hymn_number>
<author>Iliyas Tursun</author>
</song>