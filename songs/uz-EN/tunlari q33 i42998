<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Tunlari osmonga termilib,
 Masihni sogʻinib yigʻlayman. //
 // Gohida oʻylasam azobin,
 Qorongʻu dunyoga sigʻmayman. //

[C1]
   // Shu sabab yigʻlayman qon-qon,
   Osmon ham yigʻladi oʻsha on. //
   Otam ham yigʻladi oʻsha on.
   // Tikandan toj kiydi, kim uchun?
   Men uchun, Sen uchun, Biz uchun. //

[V2]
 // Xochda U jon berdi, kim uchun?
 Men uchun, Sen uchun, Biz uchun. //
 // Maʼbadda pardalar yirtildi,
 Yer-yuzi larzaga keltirdi. //
 // Uch kunda Isoni tiriltirdi, kechirdi.
 Gunohim kechir deb yigʻlayman. //</lyrics>
<title>Tunlari Q33</title>
<hymn_number>33</hymn_number>
</song>