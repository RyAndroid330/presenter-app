<?xml version="1.0" encoding="UTF-8"?><song><title>Dunyo boshdan oyoq nodonlashib CA23 W25 Q214</title>
<aka>Bor Parvardigor Xudo</aka>
<lyrics>[V1]
.   Am                   F
 // Dunyo boshdan oyoq nodonlashib,
.Em                     G
 Yaratguvchi Ega yoʻq desa, //
.   Am                F
 // Bor Parvardigor Xudo!
.C                      G F G
 Osmonlarda mangu mavjud bor! //  .

[V2]
 // Gunohkor inson gunohning iligidan
 Ozod boʻlmoq chora yoʻq desa, //
 // Bor Parvardigor Xudo
 Koʻkdan yerga kelgan Najotkor! //

[V3]
 // Ishonchi yoʻq banda jafoga duch kelib
 Noumid hech amal yoʻq desa //
 // Bor Parvardigor Xudo
 Qutqaruvchi Iso Masih bor! //

[B1]
   Bor Parvardigor Xudo
   Osmonlarda mangu mavjud bor!
   Bor Parvardigor Xudo
   Koʻkdan yerga kelgan Najotkor!
   Bor Parvardigor Xudo
   Qutqaruvchi Iso Masih bor!</lyrics>
<key>Am</key>
<hymn_number>23</hymn_number>
<author>Һәmra aka</author>
</song>