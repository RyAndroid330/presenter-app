<?xml version="1.0" encoding="UTF-8"?><song><aka>Kuylayman Senga hamdu sano</aka>
<lyrics>[V1]
.Cm                        Fm
 Rabbim Seni olqishlashni istayman,
.G                Cm
 Va Sendan minnatdorman.
.Cm                       Fm
 Birgina umidim, tilagim Senda,
.G              Cm
 Taʼzim Senga aylayman.

[C1]
.       Cm                   Fm
   // Kuylayman Senga hamdu sano,
.  Fm                Eb
   Kuylayman Senga Masihim.
.  Cm                      Fm
   Chunki Sen qiynalding begunoh,
.  G                  Cm
   Yaratuvchim Seni sevdim. //

[V2]
.Cm                      Fm
 Agar men yoʻllarimda yiqilsam,
.G                Cm
 Bilaman Seni koʻrishingni.
.Cm                      Fm
 Va qachon nola bilan intilsam,
.G              Cm
 Berasan Oʻz najotingni.

[C2]
.     Cm            Eb
   // Xudoyim men bilaman,
.  Eb               Fm
   Qanday Sen mehribonsan.
.  Fm                    G
   Sen bir daqiqada kechirasan,
.  Ab              G
   Va yurakni nurlaysan. //</lyrics>
<key>Cm</key>
<title>Rabbim Seni olqishlashni istayman Q134</title>
<hymn_number>134</hymn_number>
</song>