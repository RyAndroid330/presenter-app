<?xml version="1.0" encoding="UTF-8"?><song><author>Bethel Music, Kari Jobe</author>
<hymn_number>28717</hymn_number>
<lyrics>[V1]
.G#               D#
 Butun osmon yigʻlar,
.                Fm
 Tong Yulduzi soʻnar
.              C#            G#
 Dunyo Xaloskori qurbon boʻldi
.G#              D#                 Fm
 Xochda Uning tani, qoni ham toʻkildi
.                 C#     G#
 Bizning gunohlarni U oldi

[V2]
 Soʻnggi nafas berdi,
 Osmon yuz oʻgirdi
 Xudo Oʻgʻli zulmatda qoldi
 Qabr ushlolmadi, oʻlimni U yengdi
 Doʻzoxni U mangu yakson qildi

[C1]
.     G#              D#                     Fm
   // Yer larzaga keldi, Tosh qum boʻlib ketdi
.                 C#         G#
   Kuchli sevgisini yengolmadi
.  G#/C             D#
   Oʻlim zaxring qani?
.                 Fm
   Shohimiz tirildi
.                C#
   Seni magʻlub qildi
.    G#         D#
   Abadiy Sen Ulugʻlangin,
.    Fm       C#
   Abadiy Sen Yuksalgin
.    G#         D#
   Abadiy Sen Hayotsan
.        Fm         C#
   Sen hayot, Sen hayot //

[B1]
.  G#            D#
   Kuylang Halleluya,
.                Fm
   Kuylang Halleluya
.                C#
   Kuylang Halleluya,
.                  G#
   Iso gʻolib boʻldi!</lyrics>
<key>Ab</key>
<aka>Abadiy I</aka>
<title>Butun osmon yigʻlar</title>
</song>