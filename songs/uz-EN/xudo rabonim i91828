<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em          Am
 // Xudo oldida mening qalbim tinch
.H7            Em
 Faqat Undadir mening umidim
.Em            Am
 Har dam Unga umid bogʻlayman
.H7           Em
 Uning Oldida dilim ochaman //

[C1]
.     Em             Am
   // Xudodir mening Panohim
.  H7              Em
   Xudodir mening Rabonim
.  Em              Am
   Xudodir mening Qoʻrgʻonim
.  H7                Em
   U bilan yaxshidir umrim //

[V2]
.   Em            Am
 // Xudo oldida tinchlan qalbim
.H7            Em
 Udir Najotim Udir Izzatim
.Em            Am
 Rabni kuyla gʻamni unutib
.H7             Em
 Unga ishongin Uni sen kutib //</lyrics>
<title>Xudo Rabonim</title>
<hymn_number>22712</hymn_number>
<author>Sobir Umurov</author>
</song>