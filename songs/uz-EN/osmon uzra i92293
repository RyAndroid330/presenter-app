<?xml version="1.0" encoding="UTF-8"?><song><title>Osmon Uzra</title>
<lyrics>[V1]
 // Osmon uzra yulduzlar charaqlar
 Koʻklarda quyosh oʻz nurin sochar //
 // Bu olamni yaratga Xudoyim
 Kechayu kunduz biz tomon termoʻlar //

[C1]
   Ey odamlar tinchligimiz deb
   Xudoyimiz oʻz oʻgʻlini qildi dunyo uchun fido
   Ey odamalar naxotki sizlar buni ish bilmaysizlar
   Baxtli yashashimizning sababchisi Iso
   Baxtli yashashimizning sababchisi Xudo

[V2]
 // Osmon uzra farishtalar uchar
 Koʻklarda hayotni musaffo etar. //
 // Bu keng dunyoni yaratgan Xudoyim
 Har qanday musibatdan oʻzing asra. //</lyrics>
<aka>Ey Odamlar</aka>
</song>