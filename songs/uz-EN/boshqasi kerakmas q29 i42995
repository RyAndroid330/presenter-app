<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>29</hymn_number>
<lyrics>[V1]
 // Boshqasi kerakmas, boshqasi
 Bu Rabbimning ulugʻ tuhfasi, //
 // Bu yoʻl tartib intizom yoʻli
 Ham imtihon, intiqo yoʻli. //
 Boshqasi kerakmas, boshqasi
 Bu Rabbimning ulugʻ tuhfasi!

[V2]
 // Boshqa yoʻlni tanlamaymiz,
 Tanimaymiz, tan olmaymiz. //
 // Ahdimiz shu jiddiy, qatʼiy,
 Biz Rabbiy farzandlari. //

[C1]
   Boshqasi kerakmas, boshqasi
   Bu Rabbimning ulugʻ tuhfasi!
   Bu yoʻl tartib intizom yoʻli
   Ham imtihon, intiqo yoʻli.

[V3]
 // Qarang, qanday ajoyib,
 Bir mamlakat boʻlganmiz.
 Kim oʻzbegu, qozoq, rus,
 Til topishib qolganmiz. //

[V4]
 // Bizning tosh yuragimiz
 Halimday yumshoq qilgan, //
 // Magʻrurlik va xudbinlik,
 Bizdan yiroqlab qolgan. //</lyrics>
<title>Boshqasi kerakmas Q29</title>
</song>