<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>28240</hymn_number>
<author>Һәmra aka</author>
<title>Azaldan</title>
<lyrics>[V1]
.   Em     D              Em           Bm
 Azaldan qurbon boʻlishga tanlangan Qoʻzi,
.     Em     D           Em        Bm
 Tashakkur Senga Muqaddas Najotkorimiz.
.    Em     D             Em         Bm
 Azaldan qurbon boʻlishga tanlangan Iso,
.   Em     D           C        D
 Ofarin Senga qudratli tarafdorimiz.

[C1]
.        G      C             G       D
   Men hargiz oqlana olmasdim Xudo oldida,
.       Em     D         C          D
   Agar Sen ey Rabbim Iso boʻlmaganingda.
.         G     C            G        D
   Men hargiz kechirilmasdim qonun adolat,
.       Em     D          C           D
   Agar Sen ey Rabbim Iso boʻlmaganingda.

[V2]
 Azaldan qurbon boʻlishga tanlangan Iso,
 Tashakkur Senga jazodan Qutqaruvchimiz.
 Xudovand insonlararo Yarashtiruvchi,
 Qiyomat kunida bizni Oqlaguvchimiz.

[C2]
   Men hargiz oqlana olmasdim Xudo oldida,
   Agar Sen ey Rabbim Iso boʻlmaganingda.
   Men hargiz kechirilmasdim qonun adolat,
   Agar Sen ey Rabbim Iso boʻlmaganingda.

[B1]
.  Em  D      Em  Bm
   Ofarin! Ofarin!
.  A            D      G    B7
   Ofarin Senga Rabbimiz Iso!</lyrics>
<key>Em</key>
</song>