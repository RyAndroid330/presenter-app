<?xml version="1.0" encoding="UTF-8"?><song><aka>Iso Sevadi</aka>
<key>Em</key>
<lyrics>[V1]
.Em      D    Em    D
 Iso sevadi Seni meni
.Em        D     Em     D
 Iso oʻz jonini fido qildi.
.Em      D    Em    D
 Iso biladi Seni meni
.Em         D       Em    D
 Axir Uning Oʻzi bizni tanladi

[C1]
.  Em         D         Em
   Kahramonim Iso, Iso Masihim
.  Em         D          Em
   Najotkorim Iso, Iso Masixhim
.  Em          D           Em
   Shohlarning shohi Iso, Masihim
.  Em   C   D   Em
   Iso, Iso, Iso Masixim

[V2]
 Dadil boʻling barcha farzandlar
 Iso biz bilan olgʻa boringlar
 Tor yoʻldan yurib xursand boʻlinglar
 Siz kutgan oʻsha kunlar kelar</lyrics>
<title>Qahramonim Iso</title>
<author>Sobir Umurov</author>
<hymn_number>16381</hymn_number>
</song>