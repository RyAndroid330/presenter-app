<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<hymn_number>16694</hymn_number>
<title>Uygon Ey Inson</title>
<key>Dm</key>
<lyrics>[V1]
. Dm                 G
 Tunlari koʻzlarimga uyqu kelmas,
. C           Am
 Ota yuragini koʻpchilik bilmas.
. Dm             E
 Uning sevgisin, Uning shavqatin,
.Am      A
 Odamzod nega anglamas!

[V2]
.      Dm               G
 Tun-u kun faryod qilib titraydi osmon,
.   C            Am
 Gunoh uyqusidan ey inson uygʻon.
.       Dm          E
 Yashashing istaydi Barhayot Xudo,
.  Am        A
 Berib senga yana bir bor imkon

[C1]
.    Dm    G     C      Am
   Xudo sevgi, Xudo sabrli
.    Dm       E      Am    A
   Xudo inoyatli sen-u menga.
.    Dm         G   C         Am
   Xudo kechirimli Xudo qudratli,
.   Dm       E       Am A
   Uning abadiy sevgisi.</lyrics>
</song>