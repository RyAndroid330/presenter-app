<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>80</hymn_number>
<key>C</key>
<lyrics>[C1]
.     C
   // Muqaddasdirsan, Xudo
.  Em
   Muqaddasdirsan
.  Am   Em Am   Em
   Muqaddassan - Ota //

[V1]
.C                        Em
 Shohlarning Shohidirsan, Iso
.C                     Em
 Xudoning Soʻzidirsan, Iso
.C                   Em
 Najotkorimizdirsan, Iso

[B1]
.  Am       C           G
   Imonimiz komildir Senga
.  Am          C             G
   Shuhratimiz cheksizdir Senga
.  Am               C          G
   Olqish, shuhrat, madhiya Senga

[V2]
.C                          Em
 Zoʻr kelib shaytondan Sen, Iso
.C                      Em
 Gʻalaba qozonding Sen, Iso
.C                      Em
 Haqiqat osmonidan Sen, Iso</lyrics>
<title>Muqaddasdirsan, Xudo W80</title>
</song>