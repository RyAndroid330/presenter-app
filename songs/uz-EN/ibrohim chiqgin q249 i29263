<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  Eb        Ab     Eb         Bb
   Ibrohim chiqqin, yoʻlga otlangin,
.  Eb        Ab     Bb             Eb
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V1]
.Eb          Ab            Bb
 U hamma narsani qoldirib, Xudoga ishondi,
.Eb          Ab          Eb     Bb     Eb
 Xudo aytganidek chiqib, begona yurtga ketdi.

[C2]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V2]
 Qiyinchilik va ochlik uchradi yoʻlida,
 Lekin u Xudoga ishonib yurdi oldiga.

[C3]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V3]
 Ikki kishiga joy yetmas, Ibrohim hamda Lutga,
 Lekin Ibrohim izlamas oʻziga hech narsa.

[C4]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V4]
 Soro keksa, bolasi yoʻq, Xudovand unga aytdi.
 Osmondagi yulduzlar kabi avloding koʻpayadi.

[C5]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V5]
 Mana Isʼhoq, kutilgan bola Xudodan berildi.
 Qurbon boʻlishi kerak edi, lekin Xudo qutqardi.

[C6]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.

[V6]
 Ibrohimga oʻxshab har kim Xudoga ishonsa,
 Doʻstimsan, seni sevaman deydi Xudoyim unga.

[C7]
   Ibrohim chiqqin, yoʻlga otlangin,
   Ibrohim chiqqin, Xudo sen bilan bilgin.</lyrics>
<key>Eb</key>
<title>Ibrohim chiqgin Q249</title>
<hymn_number>249</hymn_number>
</song>