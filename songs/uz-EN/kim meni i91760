<?xml version="1.0" encoding="UTF-8"?><song><title>Kim Meni</title>
<key>Am</key>
<lyrics>[V1]
.   Am              F
 // Kim meni quvonchimni
.Em                Am
 Mendan olib qoʻyar ekan
.Am           F
 Axir Xudoning oʻzi
.Em               Am
 Meni oʻgʻlim deb aytgan //

[C1]
.     C            G
   // Gar mening hayotimga
.  F             Am
   Qiyinchliklar kelsa
.  Am                   F
   Men hech bundan qoʻrqmayman
.   Em            Am
   Axir Xudo men bilan //

[V2]
 // Kim sening quvonchingni
 Sendan olib qoʻyar ekan
 Axir Xudoning oʻzi
 Seni qizim deb aytgan //

[C2]
   // Gar sening hayotinga
   Qiyinchliklar kelsa
   Sen hech bundan qoʻrqmagin
   Axir Xudo sen bilan //

[V3]
 // Kim bizning quvonchimizni
 Bizdan olib qoʻyar ekan
 Axir Xudoning oʻzi
 Bizni farzandim deb aytgan //

[C3]
   // Agar juda koʻp tila
   Sen hayotingdan topsang
   Bilgin bayram boʻladi
   Men bilan koʻylasang //</lyrics>
</song>