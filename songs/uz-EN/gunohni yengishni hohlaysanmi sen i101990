<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>37</hymn_number>
<key>G</key>
<lyrics>[V1]
.   G                    C      G
 Gunohni yengishni hohlaysanmi sen
.   D               G
 Qonda kuch bor, Masih qonida
.  G                  C        G
 YUraging bilan sen Masihga kelgin
.     D                G
 Kuch bordir Uning Qonida.

[C1]
.                 C             G
   Xudoning kuchi hayot baxsh etar,
.        D      G
   O, Masih qonida
.                  C            G
   Xudoning kuchi hayot baxsh etar,
.         D           G
   Qimmatli Masih qonida.

[V2]
 Magʻrurlikni yengishni hohlaysanmi sen
 Qonda kuch bor, Masih qonida
 Masih gunohingdan ozod qiladi,
 Kuch bordir Uning Qonida.

[V3]
 Qorday oq boʻlishni hohlaysanmi sen
 Qonda kuch bor, Masih qonida
 Masih qoni yuva olar hammasin,
 Kuch bordir Uning Qonida.

[V4]
 Xudoga xizmatni hohlaysanmi sen
 Qonda kuch bor, Masih qonida
 Borligʻing bilan sen Masihni kuyla,
 Kuch bordir Uning Qonida.</lyrics>
<title>Gunohni yengishni hohlaysanmi sen</title>
</song>