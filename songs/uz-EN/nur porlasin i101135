<?xml version="1.0" encoding="UTF-8"?><song><title>Nur porlasin</title>
<key>C</key>
<lyrics>[V1]
.C
 Sevgingga shubha yoʻqdir
.F
 Nazaring nurga toʻla.
.      G            F
 Qudratlisan, Mehribonsan.

[V2]
.C
 Yashirin narsa yoʻqdir
.F
 Inoyating cheksizdir.
.      G           F
 Qudratlisan, Mehribonsan.

[C1]
.            C
   Nur porlasin
.                     F
   Ojizlar koʻzi koʻrsin
.                G
   Oloving tozalasin
.            F             C
   Ichimda yasha, Iso yetakla

[V3]
.C
 Sening Sevging cheksizdir
.F
 Hammani sevasan Sen
.      G            F
 Shohanshohim, Xaloskorim.

[V4]
.C
 Xochdan Sen voz kechmading.
.F
 Toʻlovni bila turib.
.      G             F
 Xaloskorim, Shohanshohim.

[C2]
.            C
   Nur porlasin
.                     F
   Ojizlar koʻzi koʻrsin
.                G
   Oloving tozalasin
.            F
   Ichimda yasha
.           C
   Nur porlasin
.           F
   Yuraging biz koʻraylik
.        G       F
   Tashnalikda kutib Seni
.  F
   Bizda porlagin Sen
.                   C
   Irodangni koʻrsatgin.

[B1]
.  C
    Xushxabar bizga keldi
.  Dm7
    Tasalli bizga berdi.
.  Am7              F
    Singan yuraklar hayqiramiz.

[B2]
.  C
    Bizga ozodlik berdi.
.  Dm7
    Gʻam shodlikka aylandi.
.  Am7               F
    Yoʻqolganlar uchun hayqiramiz.

[B3]
.  C
    Eulmatni buzib oʻtib
.  Dm7
    Ojizlar koʻzin ochding
.  Am7              F
    Asir boʻlganlar hayqiramiz

[B4]
.  C
    Ozodlik eʼlon qilgin
.  Dm7
    Va Yangi kunni kutgin
.  Am7             F
    Kul oʻrniga toj

[C3]
.            C
   Nur porlasin
.                     F
   Ojizlar koʻzi koʻrsin
.                G
   Oloving tozalasin
.            F
   Ichimda yasha
.           C
   Nur porlasin
.           F
   Yuraging biz koʻraylik
.        G       F
   Tashnalikda kutib Seni
.  F
   Bizda porlagin Sen
.                   C
   Irodangni koʻrsatgin.

[C4]
.  C
   Sendan keladigan nur
.  F
   Porlasin menda Ota
.  G
   Zulmat yoʻqdir bu yoʻlda
.              F
   Bizni yetakla
.           C
   Sen yetakla.</lyrics>
<author>Hillsong Worship</author>
