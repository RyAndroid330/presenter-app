<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>124</hymn_number>
<lyrics>[V1]
 // Birodarlar kelinglar,
 Qoʻllarni qoʻlga beringlar. //
 // Xudoni madh etaylik ey,
 Isoga sano aytaylik. //

[V2]
 // Endi bizlar ozodmiz,
 Gunohlardan forigʻmiz. //
 // Chalib dutor torni biz ey,
 Xudoni madh etaylik. //
 // Xudoni madh etaylik ey,
 Isoga sano aytaylik. //

[V3]
 // Kelinglar ibodat qilaylik,
 Qalblarga imon tilaylik. //
 Iso bilan boʻlaylik,
 Xudoni madh qilaylik.

[V4]
 // Iso tanladi bizlarni,
 Bizlarniyu sizlarni. //
 Yashnatib koʻngil sozlarni,
 Xudoni madh etaylik.

[V5]
 Yashnatib qaro koʻzlarni ey,
 Xudoni madh qilaylik.
 // Ochib qaro koʻzlarni ey,
 Xudoni madh qilaylik. //</lyrics>
<title>Birodarlar kelinglar Q124</title>
</song>