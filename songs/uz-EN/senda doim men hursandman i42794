<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.Cm            B7                  Bb
 Shuhratingni koʻrdim, moʻjizangni bildim,
.               F         Fm
 Muqaddas Ruhla yaratgan, Xudoyim Iso.
.Ab      G       Cm
 Ozodlik soʻzlaringda.
.Cm            B7           Bb
 Sem meni koʻtarasan, maqtovlarga
.              F        Fm
 Hayotimni toʻldirasan, Xudoyim Iso,
.Eb                  Ab
 Ketingdan boraman, borliq boʻyingda,
.  Bb             Eb
 Bilaman menla boʻlasan.

[C1]
.     Ebm        Bb          Fm
   // Senda doim men xursandman,
.  Cm              Bb
   Mening kuchim Senda Rabbim.
.  Eb        Bb         Fm
   Qoʻlingda meni ushlaysan,
.  Cm    Bb         Eb
   Xudo Senda xursandman. //

[V2]
.   Fm         Eb                         Cm
 // Sen bilan men yana, yangitdan hayot boshlayman.
.Fm       Eb           Ab           Bb           Eb
 Ogʻriqlarim olding va qalbga Muqaddas Ruhni berding. //

[B1]
.       Eb    Fm Ab  Bb               Eb
   //// Bilaman mening kuchim Senda Rabbim. ////</lyrics>
<aka>Shuhratingni koʻrdim</aka>
<title>Senda doim men hursandman</title>
</song>