<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>86</hymn_number>
<title>Dunyolardan toʻygan Q86</title>
<lyrics>[V1]
.Dm          Bb               Dm
 Dunyolardan toʻygan kunlarim ketsin,
.Dm            Bb               Dm
 Achchiq lim kosalardan zardobi yutgan,
.   C          Bb        Gm
 // Farzanding nolalarin eshitgin bugun.
.F        C        Dm(Bb)   A(Dm)
 Azizing oyoqlarin yuvganim Egam. //

[C1]
.  Dm              C   Bb
   Dunyoning tarozisi boʻynimga toʻrva,
.  Gm        F                Dm
   Orzulari armon boʻlgan qizingman.
.     Gm            F     Gm         F
   // Qalbimda Sen tirik, Sen yasha faqat,
.  Bb                 C      A(Dm)
   Bu dunyo bilgani qilgani minnat. //

[V2]
 Sen aytding tashvishing xadya et Menga,
 Bu dunyo jumboqlarin tortiq et Menga.
 // Gʻanimlar sen uchun chogʻ qazib yashar,
 Hushyor tur, poylarlar chuqur gʻorlarda. //</lyrics>
<key>Dm</key>
</song>