<?xml version="1.0" encoding="UTF-8"?><song><title>Baxt tilaymiz</title>
<key>F#</key>
<lyrics>[V1]
 Baxt kuylaymiz, Sevgi senga tilaymiz!
 Biz baxt senga tilaymiz, yuragimiz senga!
 Rabbim kelgin biz uchun,
 Yoshlarni haq qilgin.
 Muhabbat ila ularni dillarini birlashtir.
 //// Seni, seni sevdi, sevgili doʻstim! ////

[C1]
   Biz baxt kuylaymiz, Sevgi senga tilaymiz!
   Biz baxt senga tilaymiz, yuragimizdan senga!
   //// Seni, seni sevdi, sevgili doʻstim! ////

[B1]
   Kel, sen doʻstim Masih yoʻliga,
   Iso Rabbim seni sevadi,
   Abadiy hayot beradi senga!
   Dunyo boyligi teng kelmas,
   U oltin shaharga,
   Bu yerda seni qoldirmas,
   Oʻzi bergan, senga vaʼda!
   //// Seni, seni sevdi, sevgili doʻstim! ////</lyrics>
<aka>Baxt kuylaymiz</aka>
</song>