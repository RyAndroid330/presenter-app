<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em      D        Em
 Ummon yalangligi uzra,
.G       D      G
 Doʻstlar uyga keturmiz.
.   C     D        G   Em
 // Tuman pardasi ortida,
.C     D     Em
 Mangu makon topurmiz. //

[C1]
.     Em(C)           C(D)    Am
   // Tezda boʻronlar bosilur,
.  D(Am)       (D)   G     Em
   Shunda biz langar tashlaymiz. //

[V2]
 Yelkanni rostlang ufursin,
 Shamol kemangiz uzra.
 // Muft najotning quvnoq madhi
 Yangrasin dengiz uzra. //

[V3]
 Tashlab xavfsiz langarni,
 Qaygʻu daf boʻldi deymiz.
 // Goʻzal shaharga kirib biz,
 Unda mangu yashaymiz. //</lyrics>
<key>G</key>
<title>Umon yalangligi Q2</title>
<hymn_number>2</hymn_number>
</song>