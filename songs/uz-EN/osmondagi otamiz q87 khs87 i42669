<?xml version="1.0" encoding="UTF-8"?><song><title>Osmondagi Otamiz Q87 ҲС87</title>
<lyrics>[C1]
.     Dm
   // Osmondagi Otamiz
.  C             Am
   muqaddas boʻlgay Sening noming. //

[V1]
.Gm                Dm
 Yetib kelgay saltananting,
. Gm         Dm        Asus A
 bergaysan bugun rizqimizni.

[V2]
 Biz boshqalarni kechirgandek,
 bizlarni kechirgaysan,

[V3]
 Xalos qilgaysan bizni
 shaytonning nayranglaridan,

[V4]
 Shon shuhrat va kuch qudrat
 saltanat va madh Senga,</lyrics>
<key>Dm</key>
<hymn_number>87</hymn_number>
<author>Iliyas Tursun, DSJ</author>
</song>