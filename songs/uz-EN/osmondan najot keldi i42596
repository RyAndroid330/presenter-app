<?xml version="1.0" encoding="UTF-8"?><song><title>Osmondan najot keldi</title>
<lyrics>[V1]
.   Gm         Cm
 // Osmondan najot keldi,
.Eb       Dm     Gm
 Xudodan xabar keldi. //
.   Gm           Cm
 // Insonlarning qalbiga
.Eb         Dm     Gm
 Yaltiragan ruh berdi. //

[C1]
.     Gm          Cm
   // Ozodlik yoʻlin berdi,
.  Eb         Dm      Gm
   Yorugʻlik yoʻlin berdi. //

[V2]
.   Cm
 // Nur zulmatda porladi,
.Eb            Dm  Gm
 Zulmat qoplay olmadi. //
.   Gm            Cm
 // Neki yaralgan bulsa
.Eb        Dm   Gm
 Iso bilan yaraldi. //

[V3]
.   Cm
 // Nur borida yuringlar,
.Eb          Dm    Gm
 Unga xizmat qilinglar. //
.   Gm          Cm
 // Sevgisidan totinglar,
.Eb          Dm   Gm
 Ruhidan ruhlaninglar. //

[V4]
.   Cm
 // Yartganning odamidan,
.Eb           Dm     Gm
 Ming roziman Oʻglingdan, //
.   Gm             Cm
 // Bergan yorugʻ yoʻlingdan,
.Eb          Dm      Gm
 Shodlanaman koʻnglimdan. //</lyrics>
<key>Gm</key>
</song>