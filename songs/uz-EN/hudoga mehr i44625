<?xml version="1.0" encoding="UTF-8"?><song><title>Hudoga mehr</title>
<lyrics>[C1]
.     F#          Ebm        B C#
   // Bu dunyodan toʻydim Man
.  F#          Ebm        B    C#
   Xudoga mehr qoʻydim Man. //
.  F#             Ebm
   Goh shodlanib quvonib ey,
.  C#                  F#
   Hayot yoʻlin topdim Man.
.  F#             Ebm        B C#
   Yolgʻonchidan toʻydim Man,
.  F#          Ebm        B C#
   Xudoga mehr qoʻydim Man.
.     F#          Abm
   // Bu dunyodan toʻydim Man
.  C#                  F#
   Xudoga mehr qoʻydim Man. //

[V1]
.   F#           Fm
 // Bu dunyo bir oʻtkinchi,
.B          C#
 Hayotingda aldoqchi. //
.   B
 // Bir-biridan gʻiybatchi ey, //
.   B         C#
 // Bemehrdan toʻydim Man,
.B           C#       F#
 Xudoga mehr qoʻydim Man. //

[V2]
 // Zamon boshqacha kelyotir,
 Qarang boshqacha boʻlyotir. //
 // Uyat andisha yoʻqolyotir, //
 // Bemehrdan toʻydim Man,
 Xudoga mehr qoʻydim Man. //

[V3]
 // Men U bilan yashayman.
 Nima boʻlsa ham chidayman. //
 // Yaxshilikni oʻylayman. //
 // Haqiqat yoʻlin topdim Man
 Xudoga mehr qoʻydim Man. //

[B1]
.  F#         Fm        B
   Baxtimizga Xudoyimiz bor ekan,
.  F#      Fm            B
   Inoyati har koʻngilga yor ekan.
.  F#         Fm        B
   Baxtimizga Iso Masih bor ekan,
.  F#          Fm        B
   Inoyati har koʻngilga yor ekan.
.     Ebm
   // Quvonaman najot yoʻli bor ekan. //
.  F#            Abm
   Hayot yoʻlin topdim Man
.  C#                  F#
   Xudoga mehr qoʻydim Man.

[V4]
.F#          Abm
 Xudo yoʻlin topdim Man
.C#                  F#
 Xudoga mehr qoʻydim Man
.F#           Abm    F#
 Bu dunyodan toʻydim Man
.B           C#       F#
 Xudoga mehr qoʻydim Man.
.F#             C#
 Yaxshi koʻrib Xudoni
.    F#
 /// Hayot yoʻlin topdim Man. ///</lyrics>
<key>F#</key>
</song>