<?xml version="1.0" encoding="UTF-8"?><song><title>Muhabbat</title>
<lyrics>[V1]
.   Em
 // Agar men inson va malak tillarida
.                     Am
 Gapirsamu lek muhabbatim boʻlmasa
.B                                        Em
 Jaranglaydigan mis cholgʻu zang boʻlib qolaman //

[C1]
.           Am          D
   Muhabbat sabrli koʻngilchandir
.           B                 Em
   Muhabbat hasad qilmas kekkaymas
.           Am
   Muhabbat beboshlik qilmas
.             G
   Xudbinlik qilmas
.             Am            D
   Har yoʻlda ishonch hosil qilar
.            B        Em
   Va har sharoitda umid saqlar
.      Am      D      G
   Har narsaga toqat qilar

[V2]
 // Butun sirlardan agar men voqif boʻlsam
 Va togʻlarni koʻchira olsam men agar
 Mulkimni taqsimlasam muhabbatsiz hech narsamasman. //</lyrics>
<key>Em</key>
<hymn_number>26157</hymn_number>
</song>