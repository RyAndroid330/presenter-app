<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>162</hymn_number>
<aka>Qul Emasman Men Endi</aka>
<key>G</key>
<lyrics>[V1]
.G          C           G         C     D
 Bilmasdim oldin Seni, zulmatda yashar edim,
.G         D                  C
 To nur kelmagunicha mening qalbimga.
.G                 C   D    G        C     D
 Mehringni Sen koʻrsatding, jonimga orom berding.
.G        D                C
 Imonim komil endi Rabbim Senga.

[C1]
.      F           C      D                G
   Qul emasman men endi, farzandingman men Seni.
.         F         C      D           G
   Jasoratga toʻldirding, Sen mening yuragimni.
.  Em                F               C
   Gʻalaba endi menda dushman oyoq ostida,
.  G          D           G
   Kuchli Sening noming menda.</lyrics>
<title>Bilmasdim oldin Seni ҲСХМ162</title>
</song>