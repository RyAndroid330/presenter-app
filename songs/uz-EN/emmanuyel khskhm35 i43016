<?xml version="1.0" encoding="UTF-8"?><song><title>Emmanuyel ҲСХМ35</title>
<key>E</key>
<lyrics>[V1]
.E         C#m             A
 Muqaddassan taʼzim qilaman
.      C#m    B
 Rabbimsan mening,
.E     C#m             A
 Halleluya kelding biz uchun
.      C#m      B
 Olamni yangilading.

[C1]
.  F#m      B   E      A            B
   Immanuil Iso Masih qoʻllaringda ushla,
.  F#m          B        E       A   C#m
   Sen Choʻponim, asra meni doim Immanuil.

[V2]
 Xoʻp ajoyib nomlangandirsan
 Tungi yulduzlarni,
 Sevganing uchun chaqirding meni,
 Senga ergashaman.

[C2]
   Immanuil Iso Masih qoʻllaringda ushla,
   Sen Choʻponim, asra meni doim Immanuil.

[B1]
.     B      C#m   B     A
   // Muqaddassan, buyuksan Xudo,
.  B     C#m         B   A
   Sen kabi hech kim yoʻq. //

[C3]
   Immanuil Iso Masih qoʻllaringda ushla,
   Sen Choʻponim, asra meni doim Immanuil.</lyrics>
<aka>Immanuil, Muqaddassan taʼzim qilaman</aka>
<author>Hillsong</author>
<hymn_number>242</hymn_number>
</song>