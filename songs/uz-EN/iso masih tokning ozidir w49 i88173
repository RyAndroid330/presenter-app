<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Masih Tokning Oʻzidir W49</title>
<key>Am</key>
<lyrics>[V1]
.      Am
 // Iso Masih Tokning Oʻzidir,
.   Dm     (E)  Am
 Biz esa Uning novdasi. //
.         Dm    E      Am
 // Parvardigor Bogʻbonimiz
.     Dm   E   Am
 Iso Masih tomirimiz
.      Dm         E       Am
 Va Muqaddas Ruh hayot bulogʻimizdir. //</lyrics>
<author>Anvar Joʻrayev</author>
