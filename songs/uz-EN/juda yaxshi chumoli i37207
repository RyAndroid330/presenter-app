<?xml version="1.0" encoding="UTF-8"?><song><title>Juda yaxshi chumoli</title>
<key>B</key>
<lyrics>[V1]
.B         F#  B
 Juda yaxshi chumoli,
.F#                 B
 Orttirdi koʻp doʻstlarni.
.   Abm         B
 // Va endi chumolida,
. F#
 Doʻstlari hamma joyda. //

[V2]
 Kun boʻyi ishlaydi u,
 Dangasalik qilmaydi.
 // Oila va doʻstlarga,
 Boʻlar doim xizmatda. //

[V3]
 Yaxshi ishlarni qiling,
 Va bunda kuchli boʻling.
 // Doʻstlaringizni sevib,
 Unga oʻxshagan boʻling. //

[V4]
 Xudoyim bizlar Sening,
 Sevilgan bolalaring.
 // Mehnatni biz sevaylik,
 Doʻstlarni qadrlaylik. //</lyrics>
</song>