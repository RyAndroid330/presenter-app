<?xml version="1.0" encoding="UTF-8"?><song><aka>Gunoh ichra yurdim shuncha vaqt</aka>
<lyrics>[V1]
 Gunoh ichra yurdim shuncha vaqt
 Qirq yoshimda imonga keldim
 // Qani edi bilsaydim barvaqt!
 Fursatimni shaytonga berdim!/ //

[V2]
 // Lekin Xudo Qudratli albat
 Vaqt oʻtsada meni tanladi //
 // Chetlatildi bashariy odat.
 Iblis ishi befoyda boʻldi. //

[V3]
 Bu muhabbat uchun ming shukur!
 Xudoyimga taʼzim qilarman!
 Xizmatida borimcha butkul!
 Yaratganga borim beraman!
 Gunoh ichra yurdim shuncha vaqt
 Qirq yoshimda imonni bildim
 // Qani edi bilsaydim barvaqt!
 Fursatimni shaytonga berdim! //</lyrics>
<title>Qirq yoshimda</title>
</song>