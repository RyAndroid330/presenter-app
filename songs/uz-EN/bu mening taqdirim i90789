<?xml version="1.0" encoding="UTF-8"?><song><title>Bu mening taqdirim</title>
<key>C</key>
<lyrics>[V1]
.C         Fmaj7
 Bu mening taqdirim,
.Dm     G
 Bu abadiy umidim,
.Em        Am         Fmaj7          G
 Buyuk Sevging kabi komil boʻlish Xudo
.C        Fmaj7
 Mening orzuim
.Dm       G
 Mening oliy maqsadim
.Em        Am             Fmaj7         G
 Oʻzimdan voz kechib, Rab Sen uchun yashay

[C1]
.  Em   Am
   Yetakla
.  F           G          Em     Am
   Muqaddas sevging panohida yashir
.  F         G
   Bexatar huzuringda Rab
.  Em   Am
   Qoplagin
.     F          G         Em     Am
   Sening muqaddas huzuringga kelaman
.        F                      G
   Chiroying (Jamoling) koʻray Rabbim</lyrics>
<author>Murod Azizov</author>
<hymn_number>13993</hymn_number>
</song>