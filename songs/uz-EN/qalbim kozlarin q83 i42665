<?xml version="1.0" encoding="UTF-8"?><song><title>Qalbim koʻzlarin Q83</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm                  Gm     Dm
 // Qalbim koʻzlarin ochgin Rabbim
.Dm                  Gm     Dm
 Qalbim koʻzlarin ochgin Rabbim
.Dm             A
 Seni koʻrgim kelar,
.               Dm
 Seni koʻrgim kelar. //

[V2]
.   Dm          Gm    Dm
 // Yuksaklikda Sen turib,
.               Gm    Dm
 ulugʻvorlikda porlaysan, //
.   Dm           Gm
 // Porlaysan Rabbim,
. A          Dm
 porlaysan Rabbim. //

[V3]
.   Dm              Gm         Dm
 // Buyuk sevgingni Sen koʻrsatding,
.Dm      A    Gm     Dm
 Ey Xudoyim muqaddassan. //
.     A             Dm
 //// Muqaddasan Rabbim. ////
.   Dm             A
 // Seni koʻrgim kelar,
.              Dm
 Seni koʻrgim kelar. //
.Dm                Gm       Dm
 Qalbim koʻzlarin ochgin Rabbim.</lyrics>
