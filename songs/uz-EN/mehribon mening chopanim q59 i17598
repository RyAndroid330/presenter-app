<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<lyrics>[V1]
 // Mehribon mening choʻponim,
 Meni olgʻa boshlagin. //
 // Qanday goʻzal yaylovlaring,
 Tiniq suvga oborgin. //

[C1]
   // Mening Rabbim, Mening Rabbim
   Men uchun Sen qon toʻkding. //

[V2]
 // Yor yuzida doʻstim boʻlgin,
 Qoʻzilarni saqlagin. //
 // Osmon nuri ila yoritgin,
 Adashganni qaytargin. //

[V3]
 // Bergan vaʼdangni bajargin,
 Menga inoyat bergin. //
 // Ogʻir yoʻl tamom boʻlganda,
 Jonimni qabul qilgin. //

[V4]
 // Tayyorlagin yuragimni
 Amringni bajarishga. //
 // Men kabi iymon topganni
 Chin qalbimdan sevishga. //</lyrics>
<title>Mehribon Mening Chopanim Q59</title>
</song>