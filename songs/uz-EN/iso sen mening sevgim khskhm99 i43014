<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>13816</hymn_number>
<author>Steve McPherson, John Ezzy, Daniel Grul</author>
<key>Em</key>
<lyrics>[V1]
.   G        F#m     B7
 // Iso Sen mening sevgim,
.Em   C               D
 Iso qoldirmayman men Seni.
.G              F#m       B7
 Zulmatdan olib chiqding meni,
.Em     Em7     C           D
 Tayanchim mening va bilaman endi. //

[C1]
.     G         F#m
   // Senga men muhtojman,
.  Em  Em7        C        D
   Sevaman Seni, qoldirma meni.
.  G        F#m       B7
   Najotkor yaqin doʻstim,
.  Em   Em7       C           D
   Sevaman Seni Rabbim Iso Rabbim. //

[B1]
.       Em/G  D      C
   //// Ulugʻlayman Seni yana va yana. ////</lyrics>
<title>Iso Sen mening sevgim ҲСХМ99</title>
</song>