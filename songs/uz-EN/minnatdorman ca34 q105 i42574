<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[P1]
.     C
   // Iso Sen Rabimsan,
.                         Am
   minnatdorman Sening shifoing uchun,
.             Dm
   Iso Sen Rabbimsan,
.                   G
   minnatdorman ozodliging uchun.
.  C
   Iso Sen Rabbimsan,
.                 A
   minnatdorman Sening vahiying uchun,
.  Dm     G             C
   Iso, sevaman Seni Rabbiy. //

[C1]
.  C                              Em
   Sening kaloming uchun, umid muhabbat uchun,
.  Am                                  Dm
   Oʻzligingni bizga oshkor qilganing uchun,
.  F                              C       Am
   Sen hadya qilganlaring yoʻl, haqiqat, hayot,
.     F             G               C
   // Mening ila boʻlganing uchun Rabbiy. //

[V1]
.C                                  Dm
 Va shuning uchun Seningla boʻlgim keladi.
.G                                C
 Va shuning uchun qoʻshiq aytgim kelar Senga.
.C                                   Dm
 Va shuning uchun quyosh, yulduzlar, koinot,
.G                             C
 Sharaflaydi Sening nomingni Rabbiy.</lyrics>
<key>C</key>
<title>Minnatdorman CA34 Q105</title>
<hymn_number>34</hymn_number>
</song>