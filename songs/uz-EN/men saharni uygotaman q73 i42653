<?xml version="1.0" encoding="UTF-8"?><song><title>Men saharni uygʻotaman Q73</title>
<lyrics>[V1]
.Bm                 Em   G        Am        Bm
 Men saharni uygʻotaman, qalbimni kuyga shaylayman
.   Em                      Am      D         Bm
 // Ellar aro shukr deyman, Xudoyim Seni kuylayman. //

[C1]
.  Bm        Am
   Inoyating koʻklardan baland,
.  D          C          D
   Haqiqating bulutdan yuksak,
.     D         C     G         D
   // Ulugʻvorliging dunyoga yoyilsin,
.  Em          G       Am       Bm
   Menga quloq solgin najoting bergin. //

[V2]
 Kuchli qoʻling uzat menga, dushmanga qarshi chiqay men,
 // Noming bilan botirlik qilay, Senga doim madhiya kuylay. //</lyrics>
<key>G</key>
<hymn_number>73</hymn_number>
</song>