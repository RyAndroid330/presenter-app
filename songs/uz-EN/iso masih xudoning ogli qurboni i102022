<?xml version="1.0" encoding="UTF-8"?><song><title>Iso Masih Xudoning Oʻgʻli qurboni</title>
<key>Am</key>
<lyrics>[V1]
.   Am          G             Am
 // Iso Masih - Xudoning Oʻgʻli Qurboni
.            G                    Am
 Iso Masih - Xudoning Oʻgʻli Qurboni //

[C1]
.          Dm            G            Am
   Muhabbating bilan, qoning bilan pokla meni
.          Dm          Em            Am
   Gunohlarimni Sen olding, hochga borib
.           Dm             G             Am
   Muqaddas Ruh bilan, Soʻzing bilan oʻzgart meni
.          Dm          Em            Am
   Kasallarimni Sen olding, hochga borib

[V2]
.   Am          G               Am
 // Iso Masih - kechirgin meni, Yo Rabbim
.            G               Am
 Iso Masih - menga yordam bergin //

[V3]
.   Am          G            Am
 // Iso Masih - qalbim doimo Sen bilan
.            G             Am
 Iso Masih - umrim faqat Senda //

[V4]
.   Am          G           Am
 // Iso Masih - Muqaddas qurbonligimiz
.            G        Am
 Iso Masih - Najotkorimiz //</lyrics>
<hymn_number>53</hymn_number>
</song>