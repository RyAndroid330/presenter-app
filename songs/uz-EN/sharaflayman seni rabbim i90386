<?xml version="1.0" encoding="UTF-8"?><song><title>Sharaflayman Seni Rabbim</title>
<aka>Qara Rabbim</aka>
<lyrics>[V1]
.Am                  Em
 Sharaflayman Seni Rabbim
.Am                Em
 Ulugʻlayman Najotkorim
.F                 G
 Shohligingga koʻchirib
.Am             Em
 Tiklading Xaloskorim

[C1]
.  Am               Em
   Zulmatlarda kezganimda
.  Am          Em
   Mehrni izlaganimda
.  F                 G
   Haqiqat yoʻq deganimda
.  Am                 Em
   Najot berding Najotkorim

[V2]
.Am               Em
 Qara Rabbim hozir endi
.Am                  Em
 Shifo topgan mening qalbim
.F                     G
 Minnatdor boʻlib yashnaydi
.Am               Em
 Tashna sof Kalomingga

[B1]
.  Am
   Qara Rabbim hozir endi
.  Em
   Shu umidim boshqalarga
.  F
   Ulashishga shoshilaman
.  G
   Ruhingning yetagida
.  Am
   Qara Rabbim hozir endi
.  Em
   Birodarlar orasida
.  F
   Ulugʻlaymiz Otamizni
.  G
   Bir Ruhda, haqiqatda</lyrics>
<key>Am</key>
</song>