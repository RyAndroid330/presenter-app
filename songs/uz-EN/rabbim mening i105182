<?xml version="1.0" encoding="UTF-8"?><song><title>Rabbim mening</title>
<key>Am</key>
<lyrics>[V1]
.Am             G
 Yayratadi qalbim mening
.Dm            Am
 Sano kuylar labim mening
.Am             G
 Najtkorim, Qutqaruvchim
. Em                 Am
 Iso Masih Rabbim mening

[V2]
 Qiziqtirmas qandoqligim
 Qora, sariq yo oqligim
 Rabbim mening
 Mehri cheksiz
 Yuvar mehri
 Qalb dogʻligim

[C1]
.        C               G
   // Yayratadi tashna qalbim
.    Dm              Am
   Kuylatadi tinmay labim
.  Am                G
   Maqtovlarga loyiq abad
.    Em               Am
   Xudovandim mening Rabbim //

[V3]
 Rabbim men-chunn toʻkdi qonin
 Ayamadi shirin jonin
 Men uchun U bagʻishladn
 Qoʻlda borin bor imqonin

[V4]
 Rabbim mening chekdi jafo
 Xudovandga qildi vafo
 Hoch orkali oʻlim kuchin
 Barbod qildi yoʻk muammo</lyrics>
<author>Ravshan Xizirov, Timoʻtiy</author>
</song>