<?xml version="1.0" encoding="UTF-8"?><song><title>Yangrasin CA14 ҲС91 Q121</title>
<lyrics>[V1]
.   Bm                                  F#
 // Yangrasin, Senga qoʻshiqlarim yangrasin!
.Bm                      F#           Bm
 Yangrasin, chalgan sozim Senga yangrasin! //

[C1]
.  A                                     Bm
   Sening qilgan yaxshiliging elga yangrasin!
.  A                      G            F#
   Dovud aytgan qoʻshiqlar qayta yangrasin!

[V2]
 Yangrasin, yer-jahonga qoʻshiq yangrasin!
 Yangrasin, muqaddas pok Noming yangrasin!
 Yangrasin, bu olamga qoʻshiq yangrasin!
 Yangrasin, muqaddas pok sevging yangrasin!

[C2]
   Seni sevgan yurak boʻlsa, Senga yangrasin!
   Dil ovozim, chalgan sozim, Senga yangrasin!

[V3]
 Yangrasin, yer-jahonga qoʻshiq yangrasin!
 Yangrasin, muqaddas pok Noming yangrasin!
 Yangrasin, bu olamga qoʻshiq yangrasin!
 Yangrasin, Iso degan noming yangrasin!</lyrics>
<key>Bm</key>
<hymn_number>14</hymn_number>
<author>Һemidәm һәdә</author>
</song>