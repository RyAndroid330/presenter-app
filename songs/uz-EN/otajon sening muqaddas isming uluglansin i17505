<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.      Cm           Eb                        Bb
 // Otajon - Sening, muqaddas isming, ulugʻlansin,
.         G#                Eb   G/Gsus
 Mening hayotimda, mening yuragimda!
.      Cm       Eb                       Bb
 Sen meni zulmatdan yorugʻlikka olib chiqding,
.         G#                  Eb               G/Gsus
 Mening jonim uchun Oʻz - Oʻgʻlingni qurbon qilding! //

[C1]
.        Cm          Bb             G     Gsus  Cm
   Quvonadi mening dilim, kuylayman Senga hamdlarim,
.          G#         Fm        G       Gsus
   Shon-shuhrat, saltanat Senikidir, abadiy!
.           Cm             Bb        G   Gsus   Cm
   Qoʻshiqlarim faqat - Senga, yagonasan hayotimda,
.        G#         Fm           G          Gsus
   Sen meni, sevgingda Shohligingga olib kirding!
.  Gsus    Cm
   Olib kirding!</lyrics>
<title>Otajon Sening Muqaddas Isming ulugʻlansin</title>
<author>Malohat Pulatova</author>
</song>