<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>59</hymn_number>
<title>Mening Umidim Sen - Rabbim II ҲСХМ59</title>
<key>G</key>
<lyrics>[V1]
.G             D
 Mening umidim Sen - Rabbim!
.    Em                Bm
 Tashvish ichida tinchlik berding.
.    C            G            D
 Men bilaman Sen menga, sodiqsan!
.G                 D
 Atrofda tashvish boʻlsa ham,
.   Em             Bm
 Dunyoga qoʻrquvsiz qarayapman,
.C                    G      Am B7
 Bilaman Sen men bilan har doim!

[C1]
.             C             Dsus4
   Kunduz va kech mening Rabbim,
.            C    Am Dsus4 D
   Faqat Senga ishonaman!__
.           G                 D
   Sendan yaqin yoʻqdir menga!
.            Em           C
   Oʻzgaruv aslo yoʻq Senda!
.        G     C      Em     Am    Dsus D
   Abadiysan kecha, bugun va har doim!__
.          G             D
   Umid va tinchlik berasan,
.            Em         C
   Vaʼdangni saqlab turasan,
.  G        Am           D
   Mening qoyam, buyuk Xudo.
.          G
   Senga shukur!</lyrics>
</song>