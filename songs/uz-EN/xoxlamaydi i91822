[V2]
 // Xoxlamaydi va ortga qolishga
 Istamaydi baxt xazon boʻlishga //
 /// Har neki boʻlar Xudo qoʻlida
 Gar shoshmasa inson qoladi azobga ///

[C2]
   /// Sen men keldik Xudoga
   Nega bu dunyo bosh egamas unga ///
   Sen men keldik Xudoga
   Endi dunyo kerakmikan kimga</lyrics>
<title>Xoxlamaydi</title>
</song>