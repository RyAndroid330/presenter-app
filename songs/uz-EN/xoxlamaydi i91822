 // Xoxlamaydi tun kunduz boʻlishga
 Istamaydi oy quyosh boʻlishga //
 // Kelmaydi inson Xudo yoniga
 Negaki inson asr gunohga //

[C1]
   // Sen men keldik Xudoga
   Nega bu dunyo bosh egamas unga
