<?xml version="1.0" encoding="UTF-8"?><song><author>Shohista, Ulugʻbek Joʻrayev</author>
<lyrics>[V1]
 // Qalbimni yoritgay huzuring Rabbim
 Bilsamda gunohga qoʻyaman qadam
 Jazolaring yengil, tortsamda azob
 Baribir mehribon Oʻzingsan Tangrim. //

[C1]
   // Ne qilay yuragim Seni desa ham
   Choʻkaman dunyoning tubi jariga
   Bir kuni albatta Senga etaman.
   Ketaman qoʻl siltab bari-bariga //

[V2]
 Sendagi bu huzur qayda ham bordir
 Oʻzimiz ursakda har joy har yonga
 Baribir toʻhtalish manzili Sensan
 Najot ber har yoʻlda yurgan har jonga</lyrics>
<title>Qalbimni yoritgay huzuring Rabbim</title>
</song>