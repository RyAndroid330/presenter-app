<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>156</hymn_number>
<title>Rabbim taxtiga yaqinlashib</title>
<lyrics>[C1]
.  A      D         E    A
   Rabbim taxtiga yaqinlashib
.       D           A/C#      Bm7   Esus4  E7
   Chin orom va shodlikni cheksiz topaman__
.     A         D         E     A
   Sajda qilib, huzuring qidiraman
.      Bm7           Esus4 A
   Sadoqatli Rabbim kuylayman
.         Bm7      E            A E F#m
   Sadoqatli Xudovand, sadoqatli Rab
.                 Bm7     D      E     A
   Mening Rabbim, Xudoyim Sadoqatli Rabbim

[V1]
.A    D               E A
 Ibodatim tinglovchi Xudo,
.       D            A     Bm7      Esus4 E7
 Zulmat ichra chirogʻim va qoʻshigʻimsan__
.A        D           E      A
 Qanotlaring ostida orom olar jonim
.    Bm7           Esus4  A
 Sadoqatli Rabbim, kuylayman

[V2]
.A        D         E   A
 Tinchlik berguvchi Xudovand
.      D         A      Bm7         Esus4  E
 Men orqali qiynalganga tasalli bergin Oʻzing
.   A          D         E      F#m
 Umrim boʻyi tarannum etaman sevgingni
.    Bm7          Esus4 E A
 Sadoqatli Rabbim kuylayman.</lyrics>
<key>A</key>
</song>