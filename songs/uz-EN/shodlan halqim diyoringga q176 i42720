<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.   Dm                            A
 // Shodlan xalqim diyoringga nur tushdi,
.Gm                    A      Dm
 Arshi aʼlo Oʻzi berdi Qutqaruvchi. //
.   Dm                           Gm
 // Choʻponlarga kelganidek Xushxabar,
.A                             Dm
 Qorongʻu qalbingga, senga ham keldi. //

[C1]
.     Dm                 C        F
   // Yurakni och Uning Xushxabariga,
.  Dm                    C            F
   Osmonlarni toʻldirib,farishtalar keldi. //

[V2]
.   Dm                           A
 // Yuraklarga malham surib qoni bilan,
.Gm                       A    Dm
 Gunohlardan ozod qilgani Iso keldi. //

[V3]
.   Dm                             A
 // Hamdlar boʻlsin Ota Xudo Masihga,
.Gm                          A    Dm
 Gunoh uchun qurbon boʻlgani Iso keldi. //
.Dm                       A
 Hamdlar boʻlsin Ota Xudo Masihga,
.    Gm                        A    Dm
 /// Bizga hayot taqdim etgani Iso keldi. ///</lyrics>
<title>Shodlan halqim diyoringga Q176</title>
<hymn_number>176</hymn_number>
</song>