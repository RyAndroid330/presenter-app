<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>216</hymn_number>
<lyrics>[V1]
 Yo Rabbim kel-kel, Sultonim mani kel-kel.
 Man boʻlsam Sanga oshiq, San podshohim boʻlib kel,
 Man boʻlsam Sanga oshiq, San shahzodam boʻlib kel,
 // Sensiz yashay olmasman, //
 // abadiy hayotimsan. //
 // Yo Rabbim kel-kel, Sultonim mani kel-kel. //

[V2]
 Yuragim yaralarin shifolagan Oʻzingsan,
 Yuragim kasallarin shifolagan Oʻzingsan.
 // Ismingni chaqirganga, //
 // Oʻzing najot berasan. //
 // Yo Rabbim kel-kel, Sultonim mani kel-kel. //

[V3]
 // Bizga abadiy hayot bergan Rabbim Oʻzingsan, //
 // Oyogʻingni ostiga, //
 // xalqimni olib kelgin. //
 // Yo Rabbim kel-kel, Sultonim mani kel-kel. //</lyrics>
<title>Yo Rabbim kel Q216</title>
</song>