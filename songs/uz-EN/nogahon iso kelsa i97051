<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir Umurov</author>
<lyrics>[V1]
 Nogahon Iso kelsa
 Kelib seni uchratsa
 Hayotingga qara
 Imon topolmasa

[V2]
 Shunda Iso senga
 Nega kutmading desa
 Kutsa eding Meni
 Olib ketardim seni

[C1]
   Otam yoniga
   Uning huzuriga
   Otam tayyorlagan
   Yangi Quddusga</lyrics>
<title>Nogahon Iso kelsa</title>
</song>