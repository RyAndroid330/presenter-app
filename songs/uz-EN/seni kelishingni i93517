<?xml version="1.0" encoding="UTF-8"?><song><author>Sobir</author>
<lyrics>[V1]
 // Otajonim Mehribonim
 Tunu kunda seni oʻylayman
 Sevging bitib sheʼrlar yozib
 Ich-ichimdan toʻlib-toshaman //

[C1]
   // Seni kelishingni
   Seni kelishingni
   Seni kelishingni
   Intiq koʻtaman //

[V2]
 // Yozay desam sevgisi olov
 Soʻzin ohista sen boʻzding osmon
 Marhamati abadiy cheksiz
 Yasholmasman men hech usiz //

[B1]
   // Har bir dillarga beradi orom
   Uning Kalomi bizlarga darmon
   Sevaman seni deydi u hamon
   Bizlarga bergandir cheksiz bir imon //</lyrics>
<title>Seni Kelishingni</title>
</song>