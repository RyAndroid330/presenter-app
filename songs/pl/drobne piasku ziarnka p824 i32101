<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>824</hymn_number>
<presentation>V1 V2 V3 V4 V5</presentation>
<lyrics>[V1]
 Drobne piasku ziarnka,
 Małe krople dżdżu,
 Tworzą ówdzie morza,
 / Ląd zaś piękny tu. /x2

[V2]
 Małe krótkie chwile
 W szybkim biegu lat,
 Tworzą cale wieki,
 / Jakie przebył świat. /x2

[V3]
 Małe błędy wiodą
 Łatwo w każdy czas
 Z drogi pięknej cnoty
 / Na manowce nas. /x2

[V4]
 Małe dobre czyny
 Są korzyścią nam,
 Bo prowadzą z ziemi
 / Do wieczności bram. /x2

[V5]
 Nawet z drobnych groszy
 Wielką korzyść masz,
 Jeśli je dla biednych
 / Jako dar swój dasz. /x2</lyrics>
<title>Drobne piasku ziarnka P824</title>
</song>