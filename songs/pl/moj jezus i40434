<?xml version="1.0" encoding="UTF-8"?><song><title>Mój Jezus</title>
<key>G</key>
<lyrics>[C1]
.      G     C             D
   Mój Jezus Królem królów jest,
.       G    Am            D
   Mój Jezus władać będzie wciąż.
.     G      C             D
   Królestwo Jego wiecznie trwa,
.  G
    On zbawił duszę mą i teraz
.  Am              D
   we mnie mieszka już. // x2 //

[V1]
.   G              C    D
 On dał mi całkiem nowe życie,
. G           C             D
 uczynił mnie dzieckiem światłości
.    G               C      D
 Dziedzictwem swym obdarzył mnie,
.      G              C      D
 bo umiłował mnie mój Ojciec Bóg.

[V2]
 On wziął na siebie moje winy,
 On wyrwał mnie z królestwa ciemności,
 Choroby wszystkie wziął na siebie
 i już nie muszę się niczego bać.</lyrics>
<hymn_number>391</hymn_number>
<author>Krzysztof Szczypuła</author>
<presentation>C V1 C V2 C</presentation>
</song>