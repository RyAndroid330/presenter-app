<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>253</hymn_number>
<presentation>V1</presentation>
<lyrics>[V1]
 Jak wielki jest Bóg,
 Cudowny nasz Pan,
 W miłości bez miar
 objawił się nam,
 Przez Morze Czerwone
 przeprowadził swój lud,
 Przyrzekł nie opuścić ciebie,
 więc zaufaj Mu.</lyrics>
<title>Jak wielki jest Bóg W253 PNŻ150</title>
</song>