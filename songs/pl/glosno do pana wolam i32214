<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 C V2 C</presentation>
<title>Głośno do Pana wołam</title>
<lyrics>[V1]
 Głośno do Pana wołam,
 Głośno aby usłyszał.
 Szukam mojego Boga,
 Ręce swoje wyciągam!

[C1]
   Bóg mój wzmacnia mnie tak,
   On wzmacnia mnie,
   On sam przebaczył mój grzech.

[V2]
 Głośno do Pana wołam,
 Głośno Pana wzywam.
 Ręce moje wyciągam,
 Śpiewam dla mego Boga</lyrics>
</song>