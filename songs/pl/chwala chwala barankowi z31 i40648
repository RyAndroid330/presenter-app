<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>31</hymn_number>
<title>Chwała, chwała Barankowi Z31</title>
<lyrics>[V1]
 /:Chwała, chwała, Barankowi cześć:/
 On godzien chwały jest i godzien by Go czcić,
 Nasz Pan na tronie swym.
 Wielbijmy Go, bo godzien chwały jest
 Nasz Pan na tronie swym.</lyrics>
</song>