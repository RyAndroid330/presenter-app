<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>525</hymn_number>
<author>A i S Kiełbowicz</author>
<presentation>C V1 C V2 C</presentation>
<key>F</key>
<lyrics>[C1]
.  D     Em   A7        D
   Podaj rękę siostrze, bratu
.          Em       A         Am6 B7
   niechaj nikt nie czuje się sam.
.           Em        A7        F#  Bm
   Chrystus przyszedł pokój dać światu
.        Em    A        D
   i ten pokój zostawia nam.

[V1]
.       A              D
 Jesteś Panie, Chlebem Życia,
.     G      D          A
 jako pokarm dajesz się nam.
.    Em     A        F#m      G
 I zaprawdę ten, kto wierzy w Ciebie
.D     A       D
 życie wieczne ma.

[V2]
 Chcemy Panie, naszym braciom
 Twoją Miłość i pokój dać,
 aby wszyscy ludzie poznawali
 uczniów Twoich w nas.</lyrics>
<title>Podaj rękę siostrze, bratu</title>
</song>