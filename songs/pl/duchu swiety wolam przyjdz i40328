<?xml version="1.0" encoding="UTF-8"?><song><presentation>C V</presentation>
<hymn_number>129</hymn_number>
<author>Ewa Szymczykowska</author>
<tempo>70</tempo>
<key>D</key>
<lyrics>[C1]
.  D            D4           D
   Duchu Święty wołam przyjdź
.  Am/D
   bądź jak ogień duszy mej,
.  G/D
   bądź jak ogień w ciele mym,
.  D
   rozpal mnie. // x2 //

[V1]
.        Am7  G               D
 Wszechmogący Bóg jest pośród nas,
.    Am7      G            D
 miłosierdzie Jego wielkie jest,
.    Am7 G            D
 okazuje dobroć swoją dziś
.    Am7  G                    A7sus4
 dla tych, którzy chcą miłować Go.</lyrics>
<title>Duchu Święty wołam przyjdź</title>
</song>