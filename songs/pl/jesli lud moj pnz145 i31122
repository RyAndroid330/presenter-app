<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>145</hymn_number>
<presentation>V</presentation>
<title>Jeśli lud Mój PNŻ145</title>
<lyrics>[V1]
 Jeśli lud Mój zwany imieniem
 Mym w modlitwie ukorzy się,
 szukając Mnie,
 wróci ze swoich dróg,
 wtedy wysłucham z niebios,
 odpuszczę grzech, uzdrowię kraj,
 jesli lud Mój
 w modlitwie ukorzy się.</lyrics>
</song>