<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 V2 V3 V4</presentation>
<hymn_number>175</hymn_number>
<lyrics>[V1]
 Ojcze, pełen chwały,
 weź me życie całe
 jakże kocham Cię!

[V2]
 Jezu, pełen chwały,
 weź me życie całe
 jakże kocham Cię!

[V3]
 Duchu, pełen chwały,
 weź me życie całe
 jakże kocham Cię!

[V4]
 Trójco, pełna chwały,
 weź me życie całe
 jakże kocham Cię!</lyrics>
<title>Ojcze pełen chwały PNŻ175</title>
</song>