<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>53</hymn_number>
<title>Twoja krew oczyszcza mnie Z53</title>
<lyrics>[V1]
 Twoja krew oczyszcza mnie
 Nowe życie znajduję w Twojej krwi
 Twoja krew przelana jest
 By wykupić z grzechów mnie
 Obmywa tak, abym bielszym był niż śnieg, niż śnieg
 Mój Jezu zmazujesz winy me</lyrics>
</song>