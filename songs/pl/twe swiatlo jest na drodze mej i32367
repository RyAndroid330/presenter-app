<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1</presentation>
<title>Twe światło jest na drodze mej</title>
<lyrics>[V1]
 Twe światło jest na drodze mej
 Nic nie zgasi go
 Wiem nie zgubie się
 Bo we mnie jasno jest
 Świecisz Ty w każdej ciemności
 Blaskiem swym ogarniasz mnie</lyrics>
</song>