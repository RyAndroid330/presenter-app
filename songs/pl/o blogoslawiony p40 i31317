<?xml version="1.0" encoding="UTF-8"?><song><title>O, błogosławiony P40</title>
<lyrics>[V1]
 O, błogosławiony,
 Łaską nam wsławiony
 Narodzenia Pańskiego czas!
 Na ten świat zgubiony
 Chrystus narodzony;
 Cieszcie, cieszcie się,
 chrześcijanie, wraz!

[V2]
 O, błogosławiony,
 Łaską nam wsławiony
 Narodzenia Pańskiego czas!
 Chrystus Sam się zjawił,
 Aby nas wybawił;
 Cieszcie, cieszcie się,
 chrześcijanie, wraz!

[V3]
 O, błogosławiony,
 Łaską nam wsławiony
 Narodzenia Pańskiego czas!
 Ku Twej czci niebianie
 Wznieśli swe śpiewanie;
 Cieszcie, cieszcie się,
 chrześcijanie, wraz!</lyrics>
<presentation>V1 V2 V3</presentation>
<hymn_number>40</hymn_number>
</song>