<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 C V2 C</presentation>
<hymn_number>653</hymn_number>
<author>Andrzej Mazurek Wojciech Sówka</author>
<lyrics>[V1]
.E              A          E
 Tyś jak skała, Tyś jak wzgórze
.E           B    E
 Panie nasz, Boże nasz.
.E               A        E
 Tyś jak wiatr w swej naturze,
.E                   B       E
 Tyś jest Stwórcą wszystkich nas.

[C1]
   Łamdarej, łamdaoo,
   Łamdarej, łamdao // 2x //

[V2]
 Światłem swym rozświetlasz drogę,
 która prosto wiedzie nas.
 Tam, gdzie źródło Twej miłości,
 gdzie radośnie płynie czas.</lyrics>
<key>D</key>
<title>Tyś jak skała, Tyś jak wzgórze</title>
</song>