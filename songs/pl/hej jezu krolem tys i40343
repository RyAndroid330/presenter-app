<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.G         C    G
 Hej Jezu Królem Tyś.
.G         C   G   D
 Życie Twe uwalnia mnie.
.G           C    G
 Będę sławić cały dzień,
.G         C  G  D
 doskonałe drogi Twe.
.G        C     G
 Hej Jezu Panem Tyś
.G            C  G   D
 Chcę słuchać Twoich słów.
.G             C      G
 Twe Królestwo ujrzeć chcę,
.G    Am  G     Am  C  G
 wola Twa niech spełni się.

[V2]
.A           D    A
 Chwała Barankowi cześć,
.A           D  A  E
 weź mnie do ziemi swej.
.A            D    A
 Zwyciężymy w Imię Twe,
.A    Bm A  Bm D  A
 ogłosi__my rządy Twe.
.A           Bm A Bm A
 Hej o hej o Lwie Judy
.A      Bm A   Bm D  A
 jak potężnym jesteś Ty.
.A           Bm A Bm A
 Hej o hej o Lwie Judy
.   Bb    Bm  A    Bm D   A
 // Jak wspaniałym jesteś Ty. //</lyrics>
<title>Hej Jezu Królem Tyś</title>
<hymn_number>221</hymn_number>
<author>Joseph Vogels</author>
<presentation>V1 V2</presentation>
<tempo>102</tempo>
</song>