<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>270</hymn_number>
<presentation>V1 C V2 C</presentation>
<key>Em</key>
<lyrics>[V1]
.Em               Am7
 Jeden jest tylko Pan,
.                Em
 tutaj jest Jego dom.
.Em
 Klęknijcie wszyscy,
.D
 którzy tu wchodzicie
.Bm              Em
 i razem chwalmy Go.

[V2]
 On mieszka z nami tu
 by przyjacielem być.
 Składamy dzięki
 za miłość i dary,
 którymi łączy nas

[C1]
.  Em                Am
   Miejsce to wybrał Pan,
.                Em
   aby wysłuchać nas.
.  Em
   Śpiewajmy wszyscy,
.  D
   słudzy w Jego domu,
.  Bm           Em
   Bogu oddajmy cześć.</lyrics>
<title>Jeden jest tylko Pan</title>
</song>