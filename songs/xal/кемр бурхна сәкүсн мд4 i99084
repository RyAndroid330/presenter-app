<?xml version="1.0" encoding="UTF-8"?><song><author>Фред Хаммонд</author>
<hymn_number>4</hymn_number>
<title>Кемр Бурхна Сәкүсн МД4</title>
<lyrics>[V1]
. Hm
 Кемр Бурхна Сәкүсн
.Em      F#    Hm
 Чини зүркнд бәәхлә
.    Em/D   Em  A Hm F#
 /// Чи зальврҗ чадхч ///
. H     Hm
 Давид әдл.

[V2]
 Кемр Бурхна Сәкүсн
 Чини зүркнд бәәхлә
 /// Чи дуулҗ чадхч ///
 Давид әдл.

[V3]
 Кемр Бурхна Сәкүсн
 Чини зүркнд бәәхлә
 /// Чи биилҗ чадхч ///
 Давид әдл.

[V4]
 // Когда Дух Господень
 наполняет меня,
 Молюсь я так, как Давид. //
 // Молюсь я, молюсь я,
 молюсь я так, как Давид //

[V5]
 // Когда Дух Господень
 наполняет меня,
 Пою я так как Давид //
 // Пою я, пою я, пою я
 так как Давид //

[V6]
 // Когда Дух Господень
 наполняет меня,
 Танцую я так, как Давид //
 // Танцую, танцую, танцую я
 так как Давид //</lyrics>
<key>B</key>
</song>