<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am    F     Dm   E  Am
 // А-а, а-а-а, а-а, а-а-а,
. F    G     C
 А-а, а-а-а, а-а-а. //
.Am      Em     Am
 Цугтан Бурхиг магттн,
.F       G        C
 Цуг улс магтал өргхмн.
.F         G        C      Am
 Терүнә сольлт уга дурн а алдр!
.   Am      Em    Am
 // Терүнә иткмҗ мөңк! //

[V2]
. Am        F
 Бурхиг магттн!
. C       Am
 Бурхиг дуудтн!
. F      G         C
 Бурхиг зүркндән орултн!
.   F     Dm     E    Am
 // А-а, а-а-а, а-а, а-а-а,
.F      G     C
 А-а, а-а-а, а-а-а. //</lyrics>
<title>Бурхиг магттн! МД10</title>
<hymn_number>10</hymn_number>
