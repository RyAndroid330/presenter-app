<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>29</hymn_number>
<title>Кузё-Инмаре МС29</title>
<lyrics>[V1]
 //
 Кузё-Инмаре //
 Мон Тонэ яратӥсько!

[V2]
 //
 Мынам Утисе //
 Уть монэ Тон, Утисе!

[V3]
 //
 Тон-пӧзись ошмес //
 Ошмес вуос жильырто

[V4]
 //
 Тон-Улон Сётӥсь //
 Быронтэм улон сётӥсь!

[V5]
 //
 Милям Эксэймы //
 Вань дауръёслы Эксэй!

[V6]
 //
 Ас кулонэныз кулонэз вормиз //
 Улӟыса султонэныз асьмелы улон сётӥз.</lyrics>
</song>