<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  G      C
   عیسی مینِّتدار،
.      D            G
   مِن ساِنینگ بیلِن گهپلِشیپ بیلیَن.‏
.  G       C
   عیسی میننِتدار،
.      D        G
   سِن ماِنی دینگلاِیَنگ.‏

[V1]
.G          C
 مِرحِمِت و شاتلیغینگا،
.C             D
 مینِّتدارلیق بیلدیریَن.‏
.G               C
 سِنینگ بو بِییک رههمینگه،
.D           G
 مِن حایران قالیان.‏

[V2]
 خوداییم سانگا قایغیمی،
 آلادامی گِتیریَن.‏
 شوبهِلِریمینگ بارینی،
 مِن سانگا بِریَن.‏</lyrics>
<key>G</key>
<title>مینِّتدار N111 CA34</title>
<hymn_number>111</hymn_number>
</song>