<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>19</hymn_number>
<title>بو گون اینجیل یِتیپ گِلدی!‏ N19 CA16</title>
<key>G</key>
<lyrics>[C1]
.     G            Em
   // تورکمِن ایلیم بوشلوق سانگا،
.     Am           G
   بو گون اینجیل یهتیپ گِلدی، //
.     C          Am           D       G
   // یارادانینگ اِرکی بیلِن اینجیلدِن خالاسگَر گِلدی.‏ //
.     G
   // سِنی خودای سُییَر دییّپ،
.  C             G
   بو گون اینجیل خابار بِریَر.‏ //
.     G          Am
   // اُلوم، گونَه یِنگیلدی دییّپ،
.     D         G
   اینجیلدِن خوش خابار گِلیَر.‏ //

[C2]
   قایتالاما:‏

[V1]
.   G
 // گونَه‌نگ قارا توملوگینده
.C          G
 اُتوران مِنگ تورکمِن خالقیم، //
.   G       Am
 // حالال ایشینگه دایانیپ،
.D           G
 حاقیقاتی بیلمَن قالدینگ.‏ //
.   G
 // حاقیقاتی بیلجِک بُلسانگ،
.C          G
 تیز-تیز اینجیل آلغیل اِله //
.   G        Am
 // خودایینگ بِییک سُیگیسی
.D         G
 بِریلیپدیر عیسی بیلِن //

[C3]
   قایتالاما:‏

[V2]
.G
 سِنینگ اوچین عیسی اُلدی
.C           G
 صلیبدا قُلغُت دوزلوگینده،
.G             Am
 سِنگ گونَه‌نگ موزدینی تُلِدی
.D             G
 قربانلیق مالی حُکمونده.‏
.G
 بو گون عیسی دیری بُلوپ،
.C            G
 سانگا دورموش بِرجِک بُلیار.‏
.C           Am
 آچ قاپینگی، قاقیان دییّپ،
.D               G
 سِنگ قالبینگا گیرجِک بُلیار.‏</lyrics>
</song>