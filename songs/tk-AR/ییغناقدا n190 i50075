<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>190</hymn_number>
<lyrics>[V1]
 ییغناقدا سِنینگ روحونگ
 بیز بیلِن بُلسون.‏
 ییغناقدا آلقیشلاریس
 سِنگ آدینگی.‏ بیز بیلیَس
 سانگا سِجده اِدِنیمیزده،
 // آق پاتانگی بِریَنگ
 سِن بیزه //
 آق پاتانگی سِن بِریَنگ.‏
 سِنینگ سُیگینگ

[V2]
 رِبّیمیز چَکسیزدیر!‏
 و سِنینگ مِرحِمِتینگ
 اوزنوکسیز.‏
 سِن بیزه هِر گون ایردِن،
 بیزه هِر گون ایردِن،
 // اُز سُیگینگی بِر،
 رِبّیمیز //
 سِن بیزینگ رِبّیمیز.‏</lyrics>
<title>ییغناقدا N190</title>
</song>