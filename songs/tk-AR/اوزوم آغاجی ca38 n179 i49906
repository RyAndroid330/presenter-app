<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em
 سِنینگ سُزونگه دوشونِنده،
.       Am         B
 عیسی مهسیه خالاصگَهریم،
.  Am                  B
 مهنینگ سِنسیز هیچ کیمدیگیمه،
.       Em       E
 دُلی مِن گُز یِتیریَهرین.‏

[V2]
.      Am           D
 // سِن مِنینگ مُقادِّس آقاجیم //
.     G                Em
 // و مِن سِنینگ کیچی شاهخانگ، //
.     Am                B
 // سهنینگ یاشاییش چِشمَنگدِن مِن، //
.           Em        (E)
 // اییمیتلِنیَن خالاصگَهریم.‏ //

[V3]
 سِنینگ چِشمَنگ مِنی دیرِلدیَر،
 دینچلیق و شاتلیق گِتیریَر،
 روحوم تَسینلیگینگی دوییار،
 مِنینگ رِبّیم خالاصگَریم.‏

[V4]
 // هاچاندا سِندِن داشلاشامدا //
 // و بُلماسام قاتناشیقدا، //
 // روحوم اِجیر چِکیَر، قینانیار، //
 // پاراحاتلیغی ییتیریَر.‏ //

[V5]
 شُنونگ اوچین مِنینگ ایسلِگیم،
 هِمیشه سِنگ بیلِن بُلماق،
 یِردَکی اَهلی ایشلِریمی،
 سِنگ گویجونگده بِرجای اِتمِک.‏

[V6]
 // سِن مِنگ اوچین مُقادِّس آغاچ //
 // و مِن سِنینگ کیچی شاخانگ، //
 // سِنده اییمیتلِنیپ اُسمَگه، //
 // هِر گون کُمِک اِت، رِب، مانگا!‏ //</lyrics>
<key>Em</key>
<title>اوزوم آغاجی CA38 N179</title>
<hymn_number>38</hymn_number>
</song>