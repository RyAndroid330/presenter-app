<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<lyrics>[V1]
 اُز یانینگا چِک،
 سِندِن گیتمَیین،
 بار زاتلاریمی بِریَن،
 دُستومدیغینگی بیلیَن.‏
 سِن مِنگ ایسلِگیم،
 سانگا دِنگ هیچ کیم،
 بُلماز و یِرینگی آلماز،
 رِب سِنگ سُیگینگ قوتارماز،
 یُلی تاپایین،
 اُز یانینگا چِک.‏

[C1]
   مِنگ ایسلِگیم،
   اِبِدی مَتَجیمسینگ،
   مِنگ ایسلِگیم،
   مِنینگ کُمِکچیم سِن!‏</lyrics>
<title>اُز یانینگا چِک N126</title>
</song>