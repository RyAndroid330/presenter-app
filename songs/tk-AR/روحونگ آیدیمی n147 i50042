<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 رِبّینگ اُزی سِنی
 دُلدورسون، سُیگیسی،
 روحی بیلِن،
 قُی، یورِگینگی،
 قالبینگی قاندیرسین.‏
 قُی، اُل اَهلی بایلیغینگ
 بُلسون،
 اُزگِردیپ سِنگ دورموشینگ،
 سِنگ اِگنینگه کِپدِری
 بُلوپ قُنسون.‏
 قایتالاما:‏
 اُ، رِبّیم،

[V2]
 عیسی مسیح،
 اُزونگی گُرکِز بیزه!‏
 اُ، رِبّیم،
 عیسی مسیح،
 گِلسِنه بیزه!‏
 یورِگینگدَکی شاتلیغینگی
 آیتسانا آیدیم اِدیپ.‏
 اِل‍لِرینگ قالدیریپ
 اُنونگ آدینا،
 بِر اُنگا آغیرینگ،
 گُزیاشینگ،
 مَحتَجلیک ییل‍لارینگی،
 و عیسانگ آدینا گیر
 سِن دورموشا.‏
 کِپدِری بُلوپ گیر
 دورموشیمیزا!‏</lyrics>
<title>روحونگ آیدیمی N147</title>
<hymn_number>147</hymn_number>
</song>