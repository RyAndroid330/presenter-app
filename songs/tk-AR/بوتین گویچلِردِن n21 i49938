<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<author>لِنني لِبلَنك, پَُل بَلُكهِ</author>
<lyrics>[V1]
.       C       D      G
 بوتین گاویچلِردِن، شالاردان،
. C           D        G
 تاِبیگاتدان و یارادیلیشدان،
.   Em         D          C G
 هِر عاقیلدان و اینسان یُلوندان -
.Am                    B
 سِن باردینگ اُزال باشلانایشدان.‏
.    C      D       G
 هِر شآلیقدان، تاختلاردان،
.         C      D           G
 دونیَه‌نگ بایلیَن аسلا گِنگ زادیندان،
.      Am       D        C G
 هِر بایلیقدان و خازینالاردان،
.Am            B         B7
 سِن بِییک بُلوپ داوریانگ تانگریم!‏

[C1]
.  G    Am   D           G
   چویلِندینگ صلیبه و جایلآندینگ
.  G    Am    D              G
   اُلوم اوچین یاشاپ، اینکَر اِدایلدینگ
.        Em       D         C
   بَگول کایمین، یهره باسغیلاندینگ،
.         Am         C        G
   سِن ییقیلدینگ، مِنگ اوچین رِب عیسی.‏</lyrics>
<key>C</key>
<title>بوتین گویچلِردِن N21</title>
</song>