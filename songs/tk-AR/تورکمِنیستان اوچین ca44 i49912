<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 قُی دیلِگیم مِنینگ یِتسین
 بُلسون سانگا اُل یاقیملی
 یورِگیمینگ دیلِگی یِتسین
 گُکلِرینگ پاتیشاهلیغینا

[V2]
 //  تورکمِنیستان اوچین دیلِگ اِدیَن مِن
 خالقیم اوچین یالباریان مِن
 باغیشلانگ سِن، خالاص اِت سِن
 مِرحِمِتینگی بیزه گُرکِز.‏
 رِبّیم بِریَن پاتیشاهلیغینگدا
 اِبِدی بُلارسینگ سِن بیز بیلِن
 شاتلیق بِردینگ پاراحاتلیق
 جانیما بِردینگ راحاتلیق
 آدیمی یازدینگ سِن گُکلِره.‏ //

[C1]
   مُقادِّس دیری سُزلِرینگده
   یاشاماقلیغا یُل گُرکِزدینگ
   آداملار سِنی تاناماقلیغی اوچین
   صلیبدا اُزونگو قربان بِردینگ.‏</lyrics>
<title>تورکمِنیستان اوچین CA44</title>
<hymn_number>44</hymn_number>
</song>