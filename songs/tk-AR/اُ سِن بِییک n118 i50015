<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>118</hymn_number>
<lyrics>[V1]
 بِییک تانگریم،
 یارادیجیم،
 مِن سِنی سُییَن.‏
 سِن رِحملی و مَهیرلی،
 سِنینگ دِنگ-تایینگ یُقدور.‏
 قایتالاما:‏
 اُ سِن بِییک،
 سِن عجاییپ،
 سِن بِییک.‏
 سِنگ اُنگونگده
 تاغظیم اِدیَن،
 سِن مِنینگ رِبّیم.‏
 سِنگ اُنگونگده تاغظیم اِدیَن،
 مُقادِّس خودای.‏
 راحاتلیق چِشمه‌سین
 تاپدیم،
 دینگه سِنینگ دُشونگده.‏</lyrics>
<title>اُ سِن بِییک N118</title>
</song>