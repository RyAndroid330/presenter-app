<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>89</hymn_number>
<title>عیسانینگ آدیندا N89</title>
<lyrics>[V1]
 // عیسانینگ آدیندا //
 بیز دونیَنی یِنگدیک!‏
 // عیسانینگ آدیندا //
 ایبلیس بیزدِن قاچیَر.‏ رِبّیم اِدیَن ایشینگده، بیز یِنیشه اُنگه باریَریس، عیسی مسیحین آدیندا، بیز دونیَنی یِنگدیک!‏</lyrics>
</song>