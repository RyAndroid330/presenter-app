<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Em      Am
 قادردان خالاصگَریم،
.B7             Em
 مِن سِنینگ بیلِن باُلسام،
.Em         Am
 یِردَکی هِر مینودیم،
.D               G
 مِن سانگا خیزمات اِتسِم.‏

[C1]
.      Am           D
   // ساِنسیز مانگا داینچلیق یُق
.  G            C
   سِنسیز مانگا بآغت یُق،
.  Am         B7
   سِندِن مانگا نور ساچیار،
.  Em        E(Em)
   باقی یاغتیلیق.‏ //

[V2]
 مِن گونَه‌نگ اِلیندِدیم،
 سِن مِنی خالاص اِتدینگ،
 و بِییک سُیگینگ بیلِن،
 تَزه دورموشا اِلتدینگ.‏

[C2]
   // آراسّا یورِکده مِن،
   سِنده راحاتلیق تاپدیم،
   سُیگیلی عیسام - سِنده،
   مِن شاتلیق تاپدیم.‏ //

[V3]
 بیگونَه قانینگ دُکوپ،
 مِنگ اوچین اِجیر چِکدینگ،
 جِبیر-جِپالاردا اُلوپ،
 جانینگی قایغیرمادینگ.‏

[C3]
   // مِن سِنینگ بیلِن بُلسام،
   مِن سانگا خیزمات اِتسِم،
   دینگه سِنده مِن بیلیَن،
   مِنینگ گِلجِگیم.‏ //</lyrics>
<key>Em</key>
<title>قادردان خالاصگَریم N41 CA22</title>
<hymn_number>41</hymn_number>
</song>