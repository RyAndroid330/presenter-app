<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 کیم مِن؟
 شُهراتینگ بُلِگی اِدیپ،
 یارادیجیم مِنی یاراتدینگ.‏
 هِنیز دُغولمازیمدان
 گُروپ،یاشاییش
 کیتابینگا یازدینگ.‏

[C1]
   کیم مِن؟ شِیله سِن
   گُگه قالدیردینگ،
   اُزونگه اُغول اِدیپ آلدینگ.‏
   مینِّتدارلیغیم
   نَدیپ آیدایین،
   پاتیشاهلیغینگا
   سایلادینگ.‏

[V2]
 کیم مِن؟
 سِن شِیله مانگا مَهیرلی،
 دینچلیق بِریَنگ
 گِچیپ گونَه‌می.‏
 سِنینگ سُیگینگ،
 سِنینگ رِحمینگ
 اِگسیلمِیَر دِپَمده
 مِنینگ.‏

[V3]
 کیم مِن؟
 مِنی شِیله
 گویچلی سُیوپ،
 جلجتادا
 سِن جِبیر چِکدینگ.‏
 هِمیشه یامانلیقدان
 قُراپ،
 مِنی اِلینگدِن
 گُیبِرمِدینگ.‏</lyrics>
<title>کیم مِن؟ N96</title>
<hymn_number>96</hymn_number>
</song>