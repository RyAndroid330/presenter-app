<?xml version="1.0" encoding="UTF-8"?><song><title>سِن یارادیجی N157</title>
<key>Bb</key>
<lyrics>[V1]
.   Bb         Eb  Bb
 // خودای - سِن یارادیجی،
.Bb
 خالِلویا،
.Eb  Bb
 خالهلویا.‏ //

[C1]
.     Gm        Cm
   // شُهراتلان، شُهراتلان
.  Gm
   عاصیرلار بُیی.‏ //

[V2]
 خودای، بیزی یاراتدینگ،
 خالِلویا، خالِلویا.‏

[V3]
 خودای - سِن بیزی سُیدونگ،
 خالِلویا، خالِلویا.‏

[V4]
 خودای اُلومی یِنگدی،
 خالِلویا، خالِلویا.‏</lyrics>
<hymn_number>157</hymn_number>
</song>