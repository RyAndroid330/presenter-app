<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 گونبه-گوندِن آرتیار
 قایغی-آلادا،
 چیقماغا یُل یُق،
 یاغتی جاهانا،
 قارانگقیلیق باسیار،
 نور یُق دونیَه‌ده،
 خوداییمی تانامان
 آرزو-خییالدا.‏

[V2]
 بیردِنکَه دینغیسیز
 قاپیم قاقیلیار،
 قاپینگی آچ، قاپینگی آچ
 دییّپ قیغیریار.‏
 کیم گِلدیکَه دییّپ
 آچدیم قاپینی،
 سیپالادی کِلَّمدِن
 اِگیپ باشیمی.‏

[V3]
 مَهریبانیم کیمکَه
 دییّپ سِراِتسِم،
 آق اِشیکلی، آلتین قوشاق
 دور اُنگومده،
 قابول اِتسِنگ گیرمِک
 ایسلِیَن دییدی،
 سِنینگ آلادانگی
 پایلاشیان دییدی.‏

[V4]
 بِگِنجیمدِن راحاتلیق
 گِلدی قالبیما،
 دویشومّیکَه،
 هوشومّیقَه دییدیم
 مِن اُنگا،
 قُرقومدان ییقیلدیم
 آیاق آستینا،
 سِن مِنینگ سایلانیم
 دییدی اُل مانگا.‏

[V5]
 خوداییم، خوداییم -
 دییّپ آغلادینگ،
 اِجیر چِکدینگ، اِنچه
 ییل‍لار مِنسیز سِن،
 اینه گِلدیم مِن بو گون
 سِنینگ یانینگا،
 موغت بِرِیین سُیگیمی
 شیرین جانینگا.‏

[V6]
 یاغتیلدی اُیومده،
 اُچمِز چیرالار،
 آیریلدی اُنگومده
 داغدیر-دِریَلار،
 یورِکده جُشیار
 آرزو خییال‍لار،
 تانگریم عیسی
 سِنی تانان گونومدِن.‏

[V7]
 قایغی-آلادام دییّپ
 دونیَه گِلدینگ سِن،
 گونَه‌لِریم اوچین صلیبدا
 اُلدینگ سِن،
 مِنی بار گونَه‌مدِن
 آزات اِتدینگ سِن،
 تانگریم عیسی سِنی
 تانان گونومدِن.‏

[V8]
 ایردِن توروپ
 حوضورینگا گِلیَرین،
 بارلیغینگا سانگا
 شوکور اِدیَرین،
 کیمه تاغظیم
 اِدیَنیمی بیلیَرین،
 تانگریم عیسی
 سِنی تانان گونومدِن.‏</lyrics>
<title>گونبه-گوندِن.‏.‏ N59</title>
<hymn_number>59</hymn_number>
</song>