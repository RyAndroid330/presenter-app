<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>146</hymn_number>
<key>B</key>
<lyrics>[V1]
.B               F#
 خودای سانگا مینِّتدار،
.         B
 مِنی یاراتدینگ.‏
.B              F#
 اُغلونگ یِره ایبهریپ،
.           B
 اُزونگ تاناتدینگ.‏

[C1]
.  B           C#m
   روحوم شات سانگا،
.            B
   مینِّتدار سانگا
   نَچه واسپینگ
.  F#
   اِتسِم-ده مِن،
.            B
   شُنچا آز مانگا.‏

[V2]
 اُز اوستونگه آلدینگ سِن،
 اَهلی گونَه‌نی.‏
 مِنینگ اوچین اُلدینگ سِن،
 چِکیپ جِزانی.‏

[C2]
   اوچ گوندِن سُنگ دیرِلیپ،
   حایرانا قُیدونگ.‏
   مِنگ دورموشیما گیریپ،
   آرقاداق بُلدونگ.‏
   قایتالاما:‏</lyrics>
<title>روحوم شات سانگا N146</title>
</song>