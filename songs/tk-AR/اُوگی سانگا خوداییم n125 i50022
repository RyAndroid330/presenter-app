<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   G           Bm
 // اُوگی سانگا هاوداییم،
.Em            Bm
 اُوگی سانگا موقآددِس،
.C            G
 اُوگی عیسی اوچاین، سِنینگ
.F  D
 اُغلاونگا!‏ //

[C1]
.  Bm         Em
   ایندی اِجیز آیدار:‏
.            Am
   ‏«‏مِن گویچلی!‏»‏،
.         D             G
   قاریپ آیدار:‏ ‏«‏مِن بآی!‏»‏،
.       Em     F
   شُل سِباَپلی خودای،
.        D      G
   بیزه باِردی اُوگی.‏</lyrics>
<title>اُوگی سانگا خوداییم N125</title>
<hymn_number>125</hymn_number>
<author>هِنري سمِته</author>
<copyright>١٩٧٨ ِنتِگرِتي'س هُسَننَ! مُسِك</copyright>
</song>