<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>156</hymn_number>
<lyrics>[V1]
 سِن - سُزلِر،
 و سِن - ساز
 سِن مِن آیدیَن آیدیمیم.‏
 سِن - اُواز،
 سِن - سازلاشیق،
 سُهرات اِرتِرین سانگا.‏

[C1]
   سِن قودراتلی خودای!‏
   سِن دینگه بیر خودای!‏
   شالارینگ بِییک شاسی!‏
   // مِن اِرتِرین سانگا //

[V2]
 // آیدیَن آیدیمیمی،
 سِن مِنگ آیدیَن
 آیدیمیم!‏ //</lyrics>
<title>سِن -- سُزلِر و سِن - ساز N156</title>
</song>