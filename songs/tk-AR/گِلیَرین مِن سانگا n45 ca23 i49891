<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   C                    Am
 // گِلیَرین مِن سانگا اُوگی بیلِن،
.      F
 قودراتاینگ سِنینگ بِییک،
.  G
 سُیگونگ هِم سِنینگ گویچلی.‏ //

[C1]
.           C                   Am
   // اُ سِن باِییک، سِن عجاییپ، سِن بِییک،
.                  F
   باشغا یُق، سِنینگ یالی
.        G
   باشغا یُق، سِنینگ یالی.‏ //

[V2]
 // اِبِدی آیدارین سانگا آلقیش،
 گُکدِن بِرِن مِرحِمِتینگ،
 رِحمینگ، سُیگینگ اوچین.‏ //</lyrics>
