<?xml version="1.0" encoding="UTF-8"?><song><title>خودای سُیگی N74</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm                     Gm
 // خودای سُیگی.‏ بیز نَهیلی باغتلی.‏
.Dm           Bb  C     Dm
 خودای سُیگی.‏ اُل بایزی سُیدی.‏ //

[C1]
.     Dm                        Gm
   // هِر بیر آدام آیدیم آیتسین شاُهراتلاپ،
.  Dm          Bb  C      Dm
   اُنی شُهراتلاپ.‏ هاودای شاُیگی.‏ //

[V2]
.   Dm                      F
 // خودای سُیگی.‏ اُل اُغلونی باِردی.‏
.F            C       F
 خودای سُیگی.‏ قوتولیش بِردی.‏ //

[V3]
.   Dm                       F
 // خودای سُیگی.‏ بیز گونَه‌نگ گاولودیق،
.F         C           F
 خودای سُیگی.‏ اُل آزات اِتدی.‏ //

[V4]
.   Dm                   F
 // خالاصگَریم باغیشلادی ماِنی،
.F        C        F
 خالاصگَریم آقلادی ماِنی.‏ //

[C2]
   // سِنی آیدیمدا باقی شُهراتلارین،
   مِن شُهراتلارین سِنگ سُیگینگی!‏ //</lyrics>
<hymn_number>74</hymn_number>
</song>