<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>152</hymn_number>
<lyrics>[V1]
 سِن قودراتلی یارادیجیم
 بوتین عالِمینگ اِیه‌سیسینگ.‏
 اُل مَهریبان
 خالاصگَریم، خالاص اِتدینگ
 سُزونگ بیلِن.‏
 آتاجانیم سِنی
 اُوِرین، مَهریبانیم
 آلقیشلارین.‏
 اُییمداسینگ، دیلیمدِسینگ،
 یورِکدِن سِنی سُییَرین.‏
 سِن قالقان سِن،
 اِبِدیلیک سِن،
 آدینگ آرتار بارها سِنینگ.‏
 ساغ قاناتینگدا آلیپ
 گِل سِن
 پاتیشاهلیغینگ

[V2]
 گِلسین سِنینگ.‏
 آتاجانیم سِنی
 اُوِرین، مَهریبانیم
 آلقیشلارین.‏
 اُییمداسینگ، دیلیمدِسینگ،
 یورِکدِن سِنی سُییَرین.‏</lyrics>
<title>سِن قودراتلی یارادیجیم N152</title>
</song>