<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 سِنگ سُیگینگه داغام اِرَر،
 سِن سُیگینگی
 آداما بِردینگ،
 // یُنه سِنی
 تانامادیلار،
 سِنگ سُیگینگی
 بیلمِدیلِر.‏ //
 اُز اُغلونگی
 سِن قربان اِتدینگ،
 اُز اُغلونگی
 سِن صلیبه چویلِتدینگ،
 // عیسی سِنی سُییَرین مِن، //

[V2]
 مِنینگ خالاصگَریمسینگ
 سِن!‏ //
 عیسی اُلوپ،
 سِن اوچونجی گون،
 دیرِلدینگ
 سِن بیزینگ اوچین،
 // سِنگ اُلومینگ، سِنینگ
 قانینگ، تَمیزلِدی
 آدامزادی!‏</lyrics>
<title>سِنگ سُیگینگه داغام اِرَر.‏.‏ N160</title>
<hymn_number>160</hymn_number>
</song>