<?xml version="1.0" encoding="UTF-8"?><song><title>مِنینگ نِپِسیمسینگ N106</title>
<lyrics>[V1]
 // مِنینگ نِپِسیمسینگ، //
 مِنده یاشایان مُقادِّس
 بارلیغینگ؛
 // گونلوک چُرِگیمسینگ!‏ //
 سِنینگ هِر سُزونگ
 مانگا آیدیلان
 ایندی سانگا مَحتَج مِن،
 ایندی سِنسیز ییتِن مِن.‏
 // مِنینگ نِپِسیمسینگ، //
 مِنده یاشایان
 مُقادِّس بارلیغینگ
 // گونلوک چُرِگیمسینگ، //
 سِنینگ هِر سُزونگ
 مانگا آیدیلان.‏
 ایندی سانگا مَحتَج مِن
 ایندی سِنسیز ییتِن مِن.‏</lyrics>
<hymn_number>106</hymn_number>
</song>