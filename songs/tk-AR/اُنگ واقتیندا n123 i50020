<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>123</hymn_number>
<lyrics>[V1]
 اُنگ واقتیندا،
 اُنگ واقتیندا،
 هِمّه زات عجاییپدی
 اُنگ واقتیندا.‏
 رِب گُرکِز گونده مانگا
 اُورِدیَن یُلونگ مانگا
 سِن آیدیشینگ
 یالی-دا اِدیَنگ
 اُز واقتینگدا.‏
 سِنگ واقتینگدا،
 سِنگ واقتینگدا،
 هِمّه زات عجاییپدی
 سِنگ واقتینگدا.‏
 رِب دورموشیمی بِریَن،
 قُی هِر آیدیمیم آیدیان،
 یاقیملی بُلسون سانگا،
 سِنگ واقتینگدا.‏</lyrics>
<title>اُنگ واقتیندا N123</title>
</song>