<?xml version="1.0" encoding="UTF-8"?><song><title>یِنه سُیگی، یِنه گویچ N187</title>
<lyrics>[V1]
 // یِنه سُیگی؛ یِنه گویچ
 سِنی ایسلِیَرین.‏ //
 سانگا سِجده اِتجِک
 بوتین یورِکده،
 سانگا سِجده اِتجِک
 بوتین آقلیمدا،
 سانگا سِجده اِتجِک
 بوتین گویجیمده،
 چونکی سِن رِبسینگ!‏</lyrics>
<hymn_number>187</hymn_number>
</song>