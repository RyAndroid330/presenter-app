<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4</hymn_number>
<author>تاش ئاكا</author>
<title>باقی دورموش بار سِن اِکِن CA4</title>
<lyrics>[V1]
.Em               Am
  باقی دورموش بیر سِن اِکِن
.B7             Em
  آزاشیپ، یُر اِکهنیم
.C          D         Em
  اُیلانماغا بیر فُرصات گِلدی

[V2]
.Em          Am
  دایانجیم بُلدی بیر دُست
.B7              Em
  دورموشومی اُزگِرتدی
.C             D         Em
  وِفادار، اینامدار، موقاددِس

[V3]
.      G         D
 پِروِردیگَر، پِروِردیگَر
.Am           Bm         Em
  خودایینگ قوربانلیق قوزوسی
.      G         D
 پِروِردیگَر، پِروِردیگَر
.Am        Bm       Em
  آسماندان گِلِن خالاصگَر</lyrics>
<key>Em</key>
</song>