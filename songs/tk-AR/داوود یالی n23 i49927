<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<lyrics>[V1]
.Cm             F      Cm
 مِنی خودای روحی بیلِن دُلدوراندا
.   Fm      Bb (Eb)
 // یورِکدِن آگلارین، //

[C1]
.     Fm     Bb    Eb    Ab
   // داوود یآلی، دآووت یآلی،
.  Fm     G   Cm
   یورِکدِن آغلارین.‏ یورِکدِن آغلارین.‏ //

[V2]
.Cm             Fm         Cm
 مِنی خودای روحی بیلِن دُلدوراندا
.   Fm   Bb   (Eb)
 // دُغا اِدِرین مِن، //

[C2]
.     Fm     Bb    Eb    Ab
   // داوود یآلی، دآووت یآلی،
.   Fm    G     Cm
   دُقا اِدهرین مهن.‏
.  Fm    G     Cm
   دُغا اِداِرین ماِن.‏ //

[V3]
.Cm             Fm         Cm
 مِنی خودای روحی بیلِن دُلدوراندا
.   Fm     Bb   (Eb)
 // آیدیم آیدارین مِن //

[C3]
.     Fm      Bb    Eb   Ab
   // داوود یالی، داووت یآلی،
.  Fm     G     Cm
   آیدیم آیدارین مِن.‏
.  Fm     G     Cm
   آیدیم آیدارین مِن.‏ //

[V4]
.Cm             Fm        Cm
 مِنی خودای روحی بیلِن دُلدورآندا
.   Fm     Bb     (Eb)
 // شاتلانیپ راقص اِدِرین، //

[C4]
.     Fm     Bb    Eb    Ab
   // داوود یآلی، دآووت یآلی،
.  Fm       G      Cm
   شاتلانیپ راقص اِداِرین.‏
.  Fm       G      Cm
   شاتلانیپ راقص اِداِرین.‏ //

[V5]
.Cm               Fm       Cm   Fm     Bb   Eb
 مِنی خودای روحی بیلِن دُلدوراندا داُغا اِدهرین ماِن.‏</lyrics>
<key>Cm</key>
<title>داوود یالی N23</title>
</song>