<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 اُنونگ آدی:‏ تَسین، باقی،
 مُقادِّس.‏
 آخیرییِتده اُل
 حُکومدار بُلار.‏
 اُنونگ آدی:‏ شُهراتلی،
 خودایینگ شِکیلی.‏
 آسمان گویجونینگ شاسی،
 پِریشده‌لِنگ باشی.‏
 اُنونگ آدی:‏ سُزدور، سُز
 - باقی خودای.‏
 اُنگ قُراغی بُلماسا،
 دونیَه دورمازدی.‏

[V2]
 اُنونگ آدی:‏
 اینامدار، سِردار،
 پیغامبِر.‏
 چَکسیز سُیگیسینده،
 آزات اِتدی بیزی.‏
 اُل - باش روحانیمیزدیر،
 قوواتلی، یاقیملی.‏
 گونَه‌نگ یِسیری اُندا،
 راحاتلیق تاپدی.‏
 اُنونگ آدی:‏ نَزیک،
 اُل قاوی چُپان.‏
 رِحمه بای، چَکسیز
 شاتلیغی دُلی.‏
 اُل - تَسین ماصلاحاتچی،
 قینچیلیقلاردا.‏
 چاغیران
 دِمینگده اُل،
 شُل فُرصات گِلِر.‏
 اُل - مُقادِّس شاخا،
 اُز آتاسیندا.‏
 اینامدا بِرکلِشیپ،
 یورِکلِر اُنگا گِلیَر.‏</lyrics>
<title>اُنونگ آدی.‏.‏ N122</title>
<hymn_number>122</hymn_number>
</song>