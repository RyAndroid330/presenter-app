<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>17</hymn_number>
<author>مِلُدي گرِِن</author>
<lyrics>[V1]
.   C           F   C
 // بیر خالاصگَر باردایر
.G           C  G
 تانگری اُغلی ایسآ،
.C        F       C
 قیمّاتلی تآنگری قوزیسی،
.G           C
 اینگ اولی بُلآن.‏ //

[C1]
.     C      F     C
   // سانگا شاوکور آتاجان
.  G           C  G
   عیسانگ قانی اوچاین،
.  C           F      C
   ایندی سِنینگ روحونگ بیلِن
.  G        C
   دُلاناریس بیز.‏ //

[V2]
 // عیسی خالاصگَردیر باشغا
 بیری یُق،
 حُرماتلی تانگری قوزوسی،
 اِل چِکِرین گونَه‌دِن.‏ //
 قایتالاما:‏</lyrics>
<key>D</key>
<title>بیر خالاصگَر باردیر، تانگری اُغلی عیسی N17</title>
</song>