<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>68</hymn_number>
<lyrics>[V1]
 // هِمّه آتلاردان عجاییپ
 سِنگ آدینگ عیسی!‏
 هِمّه آتلاردان یُقاری آسماندا هِم یِرده!‏ //

[V2]
 // چَکسیز اُویَن سِنی،
 چَکسیز اُویَن سِنی،
 چَکسیز اُویَن سِنی، مِنگ رِبّیم!‏ //</lyrics>
<title>هِمّه آتلاردان عجاییپ.‏.‏ N68</title>
</song>