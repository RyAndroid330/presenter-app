<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 سِن مِنگ گویجوم،
 قُوشاق واقتیم،
 سِن مِنگ گُزلِیَن
 بایلیغیم.‏
 مَحتَجلیگیم مِنینگ.‏
 سِنی قیمّات داش
 یالی گُزلَپ،
 رِب یادادیم ایزّات اِدیَن،
 مَحتَجلیگیم مِنینگ.‏
 عیسی خودایینگ قوزیسی
 میناسیپدیر سِنینگ

[V2]
 آدینگ.‏
 گونَه‌مدیر، صلیبیم،
 اوتانجیم آلدینگ،
 سِن دیرِلدینگ،
 آدینگ بِیگِلدِرین،
 مَحتَجلیگیم مِنینگ.‏
 ییقیلامدا،
 سِن قالدیریدینگ،
 سوسامدا، تِشنَمی
 قاندیردینگ،
 مَحتَجلیگیم مِنینگ.‏</lyrics>
<title>سِن مِنینگ گویجوم اَهلی زاتدا N154</title>
<hymn_number>154</hymn_number>
</song>