<?xml version="1.0" encoding="UTF-8"?><song><title>عیسی سِن.‏.‏ N87</title>
<lyrics>[V1]
 بَبِکلیکدِن
 یورِگیمی اِیِلَن،
 عُمرومه مانینی
 بِرِن عیسی سِن.‏
 کِسِلَّمده قُلتغی
 بِریپ قالبیما،
 یورِگیمده اُرون توتان
 عیسی سِن.‏

[V2]
 یورِگیمه مَهیر
 بارین سینگدیرِن،
 ییگرِنچلیگی
 دورموشیمدان آییران،
 خوش خاباری یِر
 یوزونه یِتیرِن،
 یورِگیمه قووات بِرِن
 عیسی سِن.‏

[V3]
 عیسام سِن آیلاندینگ
 یِرینگ یوزونه،
 واغیظ اِتدینگ
 خوداییمینگ سُزونی،
 گونَِم اوچین صلیبه
 بِریپ تِنینگی،
 قورساغیمدا مُوچ اوریان
 عیسی سِن.‏

[V4]
 آدامزادا پِشگِش
 اِتدی عُموری،
 عُمور دُوام اِتدی
 عاصیرلار بُیی،
 عُمور اوچین بِردی
 یاشاییش چُرِگی،
 یورِک داماریمینگ قانی
 عیسی سِن.‏

[V5]
 گولسِم - گولوپ
 آغلانیمدا دینگدیرِن،
 آدامزادا
 اُز سُیگوسینی سینگدیرِن،
 آدامزادینگ گونَه‌سینی
 گِچیرِن،
 عُمرومیزه عُمور قُشان
 عیسی سِن.‏

[V6]
 قارانگقیدان
 یاغتیلیغا چیقاران،
 آدامزادی قُل
 اوستونه گُتِرِن،
 یِر یوزونده یاشاییش
 ساغلیغین بِرِن،
 یورِک قالبیمینگ جانی
 عیسی سِن.‏</lyrics>
<hymn_number>87</hymn_number>
</song>