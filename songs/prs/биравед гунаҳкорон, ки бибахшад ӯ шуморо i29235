<?xml version="1.0" encoding="UTF-8"?><song><title>Биравед гунаҳкорон, ки бибахшад Ӯ шуморо</title>
<aka>Trek4</aka>
<lyrics>[C1]
.     Bm             Am   C                 Bm
   // Биравед гунаҳкорон, ки бибахшад Ӯ шуморо
.  Bm            Am  C                 Bm
   Ба Ӯ оваред якдам зи дилат ҳама гуноҳро //

[V1]
.   Bm             Em      Am        Bm
 // Ба таронаҳои ширин ба фасаноҳои рангин //
.   Bm            Am   C          Bm
 // Бенамоям нонамоён раби хуш лиқоро //

[V2]
 // Ва гар Ӯ ба ваъда гуяд, ки даме дигар биёяд //
 // Ҳама ваъдааш нигаҳ дошт ба Яҳуду ҳам Насоро //

[V3]
 // Чун ҷамоли Ӯ битобад ки ҷамоли он илоҳи //
 // Ки бувад ба ақдаси худ бидурахшад Ӯ шуморо //</lyrics>
<key>Bm</key>
</song>