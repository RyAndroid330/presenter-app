<?xml version="1.0" encoding="UTF-8"?><song><author>Iliyas Tursun</author>
<title>Iyemiz xám Tenirimiz</title>
<lyrics>[V1]
.D           G     D
 Iyemiz xám Tenirimiz,
.   Em    Bm   G
 Alǵısqa layıqsań!
.D         G      Bm
 Kudiretli Kudayımız,
.   G     A      D
 Xurmetke ılayıksan!

[C1]
.     G       D       Em  Bm
   // Bar bolgan, xázir de bar,
.  G     A   Bm
   Bar bolgaysan! //

[V2]
.D           G     D
 Xammeni Sen Jarattın,
.Em   Bm    G
 Koleuin menen.
.D             G      Bm
 Joktan bar payda kıldın,
.G    A   D
 Sozin menen.

[V3]
.D           G       D
 Taxtta otırgan Kozının,
.  Em    Bm  G
 Aldına jıtılıp,
.D            G   Bm
 Algıs-maktau aytayık,
.G    A    D
 Ogan tabınıp

[C2]
.     G       D     Em       Bm
   // Dańq ataq, xúrmet- qúdiret,
.     G     A      Bm
   Maktayga ılayıksan! //
.     G       D       Em  Bm
   // Bar bolgan, xázir de bar,
.  G     A   Bm
   Bar bolgaysan! //</lyrics>
<key>D</key>
</song>