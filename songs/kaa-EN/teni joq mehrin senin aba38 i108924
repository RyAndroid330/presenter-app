<hymn_number>38</hymn_number>
<title>Teńi joq mehriń Seniń Аба38</title>
<lyrics>[V1]
.    Em          Am           C                Dm   Em
 //  Mehrińdi dáryaǵa teńesem, dáryalardıń, shegi bolar,  //
.               Am          G          Dm     Em
 //  Teńizdey tereń desem, teńizlerde qurıp qalar!  //
.    Em                                         Am
 //  Tawday biyik kóz jetpes desem, tawlardıńda shıńı bolar,  //
.                 Am           C      Dm        Em
 //  Quyashtıń ózine teńesem, onıń da nurı az bolar!  //

[V2]
 //  Mehrińe teń keler Seniń, eshnárse joq, oylap qarasam!  //
 //  Qúdiretli-kushli Qudayım, barlıqtı Sen - jaratqansań!  //
 //  Mehirge tolǵan kózlerińdi, nur jaynaǵan júzlerińdi,  //
 //  Kulimlep turǵan - Ózińdi, hesh nársege teńep bolmas!  //</lyrics>
<key>C</key>
</song>