<?xml version="1.0" encoding="UTF-8"?><song><title>Jetele meni, jetele Аба76</title>
<lyrics>[V1]
.Em                C
 Jaratqan jerdi de aspandı da,
.Am                    B7
 Shın súyip, bas iyemen Qudayıma,
.Em              C
 Adamzat gúnadan qutılsın dep,
.Am              B7
 Jiberdi Óz Ulı - Isanıda!

[C1]
.  Am           D
    Jetele meni, jetele,
.  G             Em
    Ájayıp beyish tórine,
.  Am              D
    Ruwxıńdı berseń gewdeme,
.  G               Em
    Máńgilik qulman Ózińe!
.  Am
   Ózińe ǵana baǵınaman,
.  Em
   Ózińe ǵana tabınaman,
.  Am           B7
   Ózińnen artıq panam joq,
.  C       B7     Em
   Qudayım Saǵan sıyınaman.

[V2]
 Adasıp kóp jıllar sharshadım men,
 Sonda da tınıshlıq tappadım men,
 Sol sátte Qudaydı eske alıp em,
 Bahıtqa bólenip, shadlandım men.

[V3]
 Oqıdım Muxaddes Kitabıńdı,
 Júregim azaptan qutqarıldı,
 Umıttım qayǵımdı, azabımdı,
 Óytkeni tanıdım Qudayımdı!</lyrics>
<key>G</key>
<hymn_number>76</hymn_number>
<author>Shyntemіrov Әbіlkhay·yr</author>
</song>