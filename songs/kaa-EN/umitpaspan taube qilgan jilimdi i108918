<?xml version="1.0" encoding="UTF-8"?><song><author>Gulmira (Moynaq), Rustam</author>
<title>Umıtpaspan táube qılǵan jılımdı</title>
<lyrics>[V1]
.D                       A
 Umıtpaspan táwbe qılǵan jılımdı,
.G                    A
 Usı jılı meniń ruhım oyanǵan.
.   D                    A
 // Qalay ǵana umıtarman bul jıldı,
.Em     A            D
 Juregime Iysa sózi jazılǵan. //

[C1]
.  G                      A
   Ákem meniń bahıtlıman jáne de,
.  G         A            D
   Iysa sózi jańlap turar jurekte!
.     G                          A
   // Kelshi Iysa sherik bolshı Sen - Óziń,
.  Em         A             D
   Quwanıshım sıymay turar jurekte! //

[V2]
 Jurektegi janıp turǵan armanım,
 Jaratqannan jalbarınıp sorayman,
 // Kórsem eken taza jılı xalqımnıń,
 Bolǵanın men barlıǵınıń oyanǵan //

[V3]
 Bir Qudaydan mádet sorap xalqıma
 Jańa jılda jańa baxıt tileymen
 // Usı otırǵan tuuısqanlarımnıń barlıǵın
 Aspandaǵı jánette men kórgeymen //</lyrics>
<key>D</key>
</song>