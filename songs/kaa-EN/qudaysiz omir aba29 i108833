<?xml version="1.0" encoding="UTF-8"?><song><author>Shyntemіrov Әbіlkhay·yr</author>
<hymn_number>29</hymn_number>
<lyrics>[V1]
.Em                   B7
 Qudaysız ómir - baxıtsız ómir,
.                       Em
 Gúnaǵa tolı aldamshı ómir.
.            Am                Em
 Nege shınlıqtı bile almaysań sen?
.              B7             Em
 //  Aytshı bawırım, kimdi aldaysań sen?  //

[V2]
 Mine, taǵı da jılap tursań sen,
 Qayǵı-hásiret artıp júrmen dep.
 Nege Qudaydı tanımaysań sen?
 //  Aytshı bawırım, kimdi aldaysań sen?  //

[V3]
 Gúnaǵa batıp qıynalasań segn,
 Qayǵıńdı aytıp tunjıraysań sen,
 Nege Qudaydı tıńlamaysań sen?
 //  Aytshı bawırım, kimdi aldaysań sen?  //

[V4]
 Gúnańdı aytsań Táńir aldında,
 Bólener ediń sheksiz baxıtqa,
 Kelshi Qudayǵa, kelshi bauırım,
 Iysanıń sózin alshı qolıńa!</lyrics>
<key>G</key>
<title>Qudaysız ómir Аба29</title>
</song>