<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   G
 // Bizge bul kundi //
.     D
 // Quday jaratqan. //
.   D
 // Shadlanamız, //
.     G
 // Oynap-kúlemiz! //
.C                  D        G
 Bizge bul kundi, Quday jaratqan!
.  C             D      G
 Shadlanamız, oynap-kúlemiz!
.    G
 // Bizge bul kundi //
.  G    D    G
 Quday jaratqan!

[V2]
 // Iysa - Táńir! //
 // Seni súyemiz! //
 // Ómirimizdi, //
 // Saǵan arnaymız! //
 Iysa - Táńir, Seni súyemiz!
 Ómirimizdi, Saǵan arnaymız!
 // Iysa - Táńir! //
 Seni súyemiz!

[V3]
 // Kel kel dostım //
 // Iysa masıxqa //
 // Ol beredi //
 // Mangilik ómirdi //
 // Kel-kel dostım Iysa masixqa //
 // Ol beredi Mangilik ómirdi //</lyrics>
<title>Bizge bul kundi Аба9</title>
<hymn_number>9</hymn_number>
<author>Joy F. Patterson</author>
</song>