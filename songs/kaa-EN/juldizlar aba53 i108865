<?xml version="1.0" encoding="UTF-8"?><song><title>Juldızlar Аба53</title>
<key>G</key>
<lyrics>[V1]
.Em             B7           Em
 Juldızlar jarqırap janǵanda,
. E                    Am
 Jarıq ay kórinip aspanda,
.                        Em
 Táńirim - Ózińe, júrekti ashqanda,
.          Am        B7          Em
 //  Táńirim - Sen meni qutqardıń!  //

[V2]
 Ómirdiń taba almay baxtın,
 Jolımnıń bile aklmay baǵıtın,
 Tunshıǵıp tuńǵıyıq túbinde qalǵanda,
 //  Táńirim - Sen meni qutqardıń!  //

[V3]
 Gúnanıń shıǵa almay torınan,
 Adasıp júrippen jolımnan,
 Júrekti taǵı da jalǵızlıq basqanda,
 //  Táńirim - Sen meni qutqardıń!  //

[V4]
 Ómirdiń qayǵı menen azabın,
 Umıttım gúnanıń azabın,
 Táńirim qutqardı, quwanısh sıyladı,
 //  Táńirim gúnadan qutqardı!  //</lyrics>
