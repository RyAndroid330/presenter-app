<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.   Dm
 // Táńirimdi alǵıslayman,
.Gm
 qálem alıp men jazaman,
.F
 Juregimnen qosıq aytıp,
.Cm           Dm
 qosıqlarımdı men jazaman! //

[C1]
.     Dm
   // Dúnya meni suymese de,
.  Gm
   Táńir meni suyier eken.
.  Bb
   Dúnyada orın bolmasa da,
.  A(Cm)            (Dm)
   Táńirde orın bar eken! //

[V2]
 // Táńirimdi - alǵıslańlar,
 Onı, hesh waqıt, umıtpańlar!
 Umıtsańız, háy, adamlar,
 Qarańǵılıqta qalasız! //

[V3]
 // Quwanaman menTáńirge,
 Meni Ózi qutqarǵanına.
 Shadlanaman men máńgige,
 Táńirdiń meni tapqanına! //</lyrics>
<title>Háy xalqım! Аба56</title>
<author>Gulmira (Moynaq), Rustam</author>
