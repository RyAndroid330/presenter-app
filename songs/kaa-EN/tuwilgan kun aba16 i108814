<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>16</hymn_number>
<title>Tuwılǵan kún Аба16</title>
<key>G</key>
<lyrics>[V1]
.Em         B7             Em
 Kúnlerdiń búgin nurı bul kún,
.Em         B7             Em
 Nurlı kúnlerdiń biri bul kún,
.Em    Am             Em
 2000 jıldan beri ul kún,
.        B7             Em
 Iysa Masixım tiri bul kún.

[C1]
.  Em     Am            Em
   Iysa tiri, máńgige tiri,
.         B7             Em
   Búgin Onıń tuwılǵan kúni.
.  Em     Am          Em
   Iysa tiri, búgin tiri,
.        B7              Em
   Búgin Onıń jaratqan kúni.

[V2]
 Jarqırap tuıldıń Beytleһemde,
 Dúnyanıń barlıq jerlerinde,
 Nurlarıń jetti biziń elge de,
 Jarqırap turıpsań búgin Nókisimde!

[V3]
 Sózleriń bizge kesh jetse de,
 Bizler júrsek te bir shette de,
 Jeńimpaz atıń alǵıslana bersin,
 Alǵıslana bersin Nókiste de.

[V4]
 Jıynaldıq búgin Nókis jerinde,
 Barlıq káramatlar tek Ózińde,
 Alǵıslaymız Seni birgelikte,
 Jarqıraysań máńgi jer júzinde.</lyrics>
</song>