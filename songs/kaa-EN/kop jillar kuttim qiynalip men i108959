<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G                  D
 Kóp jıldar kúttіm qinalıp men,
.Am                Em
 ańsaǵan armanıma jetemіn dep
.G               D
 Máńgіlіk ómіr іzdedіm men,
.Am             Em
 Máńgіlіk ómіr Sende eken!

[C1]
.     C                 D
   // Bұl ómіrde qansha adam bar
.  G                  Em
   Qinalǵan, adasqan, qapa bolǵan,
.  C               D
   Qұdaysız baqıt tabamız - dep,
.  G                 Em
   Bіlmesten Senі, qatelesken! //

[V2]
 Mіne búgіn bіldіm aqiqattı men
 Máńgіlіk ómіr bіr Sende eken
 Isa keldі senі jұbatuǵa
 Terіs joldan senі qaytaruǵa

[C2]
   // Kel dosım Isanı sen qabıl et
   Máńgіlіk ómіr bіr Onda eken
   Júregіńnen sen Oǵan orın ber
   Ańsaǵan armanıńa Ol jetkerer //

[V3]
 Jannetіnen Ol saǵan orın berer
 Kel balam, kel qızım dep mіrat eter
 Baqıttı tabasıń sen Isada
 Keshіpe, qabılda sen, bos qalma

[C3]
   // Isa sen úshіn qұrban boldı
   Qanın tógіp kúnáńnan azat ettі
   Atanaqta tókken muqaddes qanı
   Úkіmnen ólіmnen azat ettі //</lyrics>
<title>Kop jıllar kuttim qıynalıp men</title>
<author>Keńesǵali Ayimbetov</author>
</song>