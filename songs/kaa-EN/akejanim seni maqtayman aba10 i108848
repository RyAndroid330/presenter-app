<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10</hymn_number>
<author>Gulmira (Moynaq), Karlıǵash</author>
<title>Ákejanim Seni maqtayman Аба10</title>
<key>F#m</key>
<lyrics>[V1]
.F#m
 Qudiretli Jaratushım,
.E                  F#m
 putkil álem Yesi - Sen!
.   F#m
 // O, meһriban Qutqarushım,
.E                      F#m
 qutqardıń Sen - Sózińmenen! //

[C1]
.     F#m                E
   // Ákejanım, Seni maqtayman,
.  E                 F#m
   Meһribanım alǵıslayman!
.  F#m           E
   Oyımdasan, keulimdesen,
.  E                F#m
   Jurekten Seni suyiemen! //

[V2]
 Sen - dańqımsan,máńgilikseń,
 Atıń ullı, bárһa Seniń!
 // Saltanatıńdı alıp kelseń,
 Patshalıǵıń kelsin - Seniń! //</lyrics>
</song>