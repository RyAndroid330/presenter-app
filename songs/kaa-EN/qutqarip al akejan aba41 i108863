<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>41</hymn_number>
<author>Keńesǵali Ayimbetov</author>
<title>Qutqarıp al, Ákejan Аба41</title>
<key>C</key>
<lyrics>[V1]
.   Am
 Mine búgin júrmiz biz,
.    Em
 Gúnakar bul dúnyada,
.       Dm
 Iysa bizdi shaqırdı,
. F       E
 Óziniń xızmetine.
. Am
 Quday - Áke bizdi tańlap,
.   Em
 Qurbanlıq - Qozısın berip,
.    Dm
 Qanı menen tazalap,
.  F          E
 Qardan da appaq qıldı!

[C1]
.    Am
   Endi bildim Qudayım,
.    F
   Miyrim-shápáátińdi,
.         C
   Súyispenshiligińdi,
.       G
   Jalǵız Ulıń - Iysanı!
.   Am
   Raxmet Quday Áke - Saǵan,
.     F
   Ulıń Iysa Masix ushın,
.      C
   Gúnamızdı keshirip,
.       G
   Máńgilik ómir ushın!

[V2]
 Endi Senen soranaman,
 Ulıń - Iysa, atı menen,
 Barlıq qaraqalpaq xalqın,
 Qutqarıp alıwıńdı.
 Quday - Áke isenemen,
 Seniń káramatıńa,
 Iysa Masix arqalı,
 Qutqarıp alatuǵınıńa.
 AWMIYN!</lyrics>
</song>