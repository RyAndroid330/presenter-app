<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>19</hymn_number>
<author>Muhabbat</author>
<key>G</key>
<lyrics>[V1]
.Em                 B7        Em
 Meniń xalqım, tıńlashı sózimdi,
.Em                B7           Em
 Meniń watanım, tıńlashı qosıǵımdı,
.   Am                   D
 Kóp jıllar júrdiń Qudaysız,
.    G                     C
 Kóp jıllar qıynaldıń Qudaysız,
.         Am           B7      Em  E
 //  Mine búgin kelip tur Qudayıń !  //

[V2]
 Jerdiń jaratıwshısı Alla-taala,
 Óz Ulın jiberdi Ol qurbanlıqqa,
 Adamlardı dozaqtan,
 Adamlardı azaptan,
 Qutqarıw ushın keldi,
 //  Quday Ulı - Iysa Masix!  //

[V3]
 Meniń xalqım,Iysa keldi saǵan,
 Júregińdi xalqım ash sen Oǵan,
 Sonda jeriń shadlanadı,
 Qayǵı-hásiret qashadı,
 Quwanısh penen bahıtqa,
 //  Eriseseń Sen xalqım!  //</lyrics>
<title>Meniń xalqım Аба19</title>
</song>