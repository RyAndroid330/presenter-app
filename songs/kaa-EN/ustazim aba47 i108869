<?xml version="1.0" encoding="UTF-8"?><song><title>Ustazım Аба47</title>
<lyrics>[V1]
.   Em                  C
 // Iysa meni haqıyqatqa, Iysa meni muhabbatqa,
.D                      C         D     Em
 Iysa meni sabır-taqatqa uyretushi - Ustazım! //

[C1]
.     C                    D
   // Iysa meni erkinlikke, Iysa meni tura jolda,
.  G                     C          D       G
   Iysa meni máńgi ómirge jeteleushim - Qutqarushım! //

[V2]
 // Iysa meniń - Qurban qozim, aqlar meni áziz qanı,
 Juregimde Patshalıǵı, máńgi Patsha - Iysa Óziń! //</lyrics>
<key>Em</key>
<hymn_number>47</hymn_number>
<author>Rustam, Gulmira (Moynaq)</author>
