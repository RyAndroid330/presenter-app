<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Bul alemde Sendey Áke, Sendey Áke joq maǵan
 Seniń miyirimińniń shegi tausılmaydı xesh qashan //
 // Adasqanda taptıń meni, qıynalǵanda jubattıń
 Qushaǵıńdı ashıp maǵan, kel balam dep shaqırdıń //

[V2]
 // Miyirimińniń shegi maǵan, tausılmasın xesh qashan
 Miyirimińdi Áke Seniń, júregimde saqlayman //
 // Adasqanda taptıń meni, qıynalǵanda jubattıń
 Qushaǵıńdı ashıp maǵan, kel balam dep shaqırdıń //

[V3]
 // Adasqanda sonsha súyip, qurbanlıq kozı berdiń
 Sol qurbanlıq arqalı, miyirimińdi kórsettiń //
 // Adasqanda taptıń meni, qıynalǵanda jubattıń
 Qushaǵıńdı ashıp maǵan, kel balam dep shaqırdıń //

[V4]
 // Ákejanım miyrimliseń, sheksiz miyirimiń Seniń
 Sendey ǵamxorshı Áke, tabılmas bul álemde //
 // Adasqanda taptıń meni, qıynalǵanda jubattıń
 Qushaǵıńdı ashıp maǵan, kel balam dep shaqırdıń //</lyrics>
<title>Bul alemde Sendey Áke, Sendey Áke joq maǵan</title>
<author>Keńesǵali Ayimbetov</author>
</song>