<?xml version="1.0" encoding="UTF-8"?><song><title>Iysa kelgen kúni Аба3</title>
<aka>Bul duniya, beskunlik ómir</aka>
<key>D</key>
<lyrics>[V1]
.Bm                    Em
 Bul dúnya, beskúnlik ómir,
.A                      Bm
 bári jalǵan, bári ótkinshi.
.   Bm                   Em
 // Dúnyadaǵı hámme nárse,
.Fm                    Bm
 Tawsılar Sen kelgen kuni.  //

[C1]
.     G             A      D Bm
   // Jańa dúnya, jańa umit,
.  Em        A            Bm
   Haqıyqat máńgilik ómir!
.  G               A        D Bm
   Tawsılmas bahıt-quwanısh,
.  Em        A           Bm
   Baslanar Sen kelgen kuni!  //
.  Fm                      Bm
   Baslanar Sen kelgen kuni!

[V2]
 Seniń mehriń dáryaday sheksiz,
 Quyashtan mol nurlarıń Seniń,
 // Ótinemen nurıńdı shash,
 Qutqarıp al xalqımdı meniń!  //

[V3]
 Qudayım keshir gunalımız,
 Senen ózge joq panamız,
 // Hámmesine qúdiretli Ózińseń,
 Jalǵız Saǵan sıyınamız!  //</lyrics>
<author>Gulmira (Moynaq), Rustam</author>
<hymn_number>3</hymn_number>
</song>