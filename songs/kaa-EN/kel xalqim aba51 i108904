<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>51</hymn_number>
<author>Keńesǵali Ayimbetov</author>
<title>Kel xalqım! Аба51</title>
<lyrics>[V1]
.  G              Am
 Bizlerdi súyip Quday,
.   C         D   G
 Berdi Ulı - Iysanı!
.   G               Am
 Kelińler, Onı maqtayıq,
.  C         D    G
 Onıń atın alǵıslayıq!

[C1]
.        C        D
   Kel xalqım, kel xalqım,
.        G          Em
   Táńirimdi - alǵıslayıq,
.      C            D          G
   Shın júrekten, Onıń atın maqtayıq!
.       C               D
   Alǵısqa ılayıqlı - Ol,
.       G             Em
   Aldında - biz tabınayıq,
.      C               D          G
   Shın júrekten, alǵıslayıq maqtayıq!

[V2]
 Milletlerdi birlestirdi,
 Quday - Iysa arqalı,
 Quuanıp shadlanıńlar,
 Xár bir millet xalıqları.

[V3]
 Qutqarıushı Iysa keldi,
 Táube qılǵan jureklerge,
 Quuanayıq, shadlanayıq,
 Qudayǵa shúkir aytayıq.</lyrics>
<key>G</key>
</song>