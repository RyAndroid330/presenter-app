<?xml version="1.0" encoding="UTF-8"?><song><title>Bul ómirde Аба58</title>
<lyrics>[V1]
.G               D      G
 Bul ómirde hámme jasaydı,
.  Am                 D
 Biraq kópshilik qayǵı menen,
. C                 D       G       Em
 Júzinde kúlki-quwanısh bolǵanı menen,
.     C           D             G
 Júreginde qorqınısh, kóz jas bar.

[C1]
.  G          D         Em
   Dostım, túsin sen sonı.
.   Am                      D
   Iysa seni gúnańnan qútqarıwǵa keldi.
.     C                  D     G       Em
   Tınıshlıq hám quwanısh jaylasqan Onda,
.    C                      D        G
   Saǵan tınıshlıq hám erkinlik beredi.

[V2]
 Quday Áke bizlerdi súyip,
 Sonıń ushın Iysanı qurban qıldı.
 Bizlerdi máńgilik ómirge iye bolsın dep,
 Óziniń Ulı Iysanı jiberdi!</lyrics>
<key>G</key>
<hymn_number>58</hymn_number>
</song>