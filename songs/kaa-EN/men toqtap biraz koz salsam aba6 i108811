<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.    Am                         F
 //   Men toqtap, biraz kóz salsam,
.G                  C
 Ómirdiń ótken jolına,
.Am                 Dm
 Hár gúna bolıp oyımda,
.E                      Am
 Men júrdim qayǵı tórinde!  //

[V2]
 Men qılǵan qansha gúna bar,
 Esitse adam uyalar,
 //  Shındıqtı aytsam Qudayǵa,
 Gúnadan meni qutqarar.  //

[V3]
 Gúnamdı alıp moynıma,
 Bas iyip Quday aldında,
 //  Ótinip, táwbe qılayın,
 Aparshı ómir jolına.  //

[V4]
 Shınlıǵın kórip jolınıń,
 Ózgertken meniń oyımdı,
 //  Qutqarıp alshı Qudayım,
 Berilip, sozdım qolımdı.  //

[V5]
 Ómirimdi Saǵan arnayın,
 Júrekte Seni saqlayın.
 //  Dúnyaǵa aytıp shınlıqtı,
 Máńgilik Seni maqtayın.  //</lyrics>
<title>Men toqtap, biraz kóz salsam Аба6</title>
<author>Bolot Aldashev</author>
<hymn_number>6</hymn_number>
</song>