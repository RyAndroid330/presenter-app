<?xml version="1.0" encoding="UTF-8"?><song><title>JEWELS</title>
<lyrics>[V1]
 1. A hung tieng leh, A hung tieng leh,
 Suongmantam lakhawm di'n;
 A suongmantam lul haw cheng chuh,
 A hehpihte chuh.

[V2]
 Zingkal aksite bangin,
 A Lallukhuk zemin;
 Hawihna suohin vak unau,
 A Lallukhuk zem di'n.

[V3]
 2. Lakhawm ina, lakhawm ina,
 A gama um dingin;
 A thiengtho cheng, avak cheng cheng,
 A hehpihte chuh.

[V4]
 3. Naupang neute, naupang neute,
 A Tanpa hehpihte;
 Suongmantam lul haw chuh ahiu,
 A hehpihte chuh.</lyrics>
<hymn_number>410</hymn_number>
</song>