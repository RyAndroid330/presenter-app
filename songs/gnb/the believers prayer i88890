<?xml version="1.0" encoding="UTF-8"?><song><title>THE BELIEVERS PRAYER</title>
<lyrics>[V1]
 1. Ka paucham nau ei Lawhtinpa,
 Lungmuonna ka ngen ui;
 Lungkham in lungzing mahleng le,
 Aw Lalpa, ei haw ki'n.

[V2]
 2. Nangmah bangin um ka nuom hi,
 Nangmah ei khawtuohpa;
 Diktaka ka um theih loh hin,
 Aw Lalpa, ei haw ki'n.

[V3]
 3. Na kipahna mu hawi kei puoi,
 Gilo ka hih ziekin;
 Na kienga hung hawi ka hi puoi,
 Aw Lalpa, ei haw ki'n.

[V4]
 4. Ka vengte leh ka chanau te'n,
 Ei deihlo mah leule;
 Guolte'n ei nusie zo mahleu,
 Aw Lalpa, ei haw ki'n.

[V5]
 5. Nuoi leiseta na hungkum in,
 Thing Kross ah Na thi a;
 Vana Na ngetsak tak ziekin,
 Aw Lalpa, ei haw ki'n.

[V6]
 6. Sapchuom haw laka um dingin,
 Thihna lau lo dingin;
 Vana phataka um dingin,
 Aw Lalpa, ei haw ki'n.

[V7]
 7. Mihing, mithi ngaihtuoh dingin,
 Lopi leh zahum in;
 Meipi laka Na hung kum tieng,
 Aw Lalpa, ei haw ki'n.</lyrics>
<hymn_number>174</hymn_number>
</song>