<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1. Kulh kawtkhakte na kihawng un,
 Kum sawt kawtkhak lunte;
 Na kihawng un,
 Lopina Lalpa A luttheih na ding in.

[V2]
 Lopina Lalpa chuh kuo a?
 Pathien hat chuh ahi;
 Lopina Lalpa chuh kuo a? (2)
 Pathien thilhih thei, Kidona a galhatpa chuh ahi (2)

[V3]
 Hallelujah (5) Amen (3)

[V4]
 2. Kulh kawtkhakte, na kihawng un,
 Kumsawt kawtkhak lunte;
 Na kihawng un,
 Lopina Lalpa A lut theih na dingin.

[V5]
 Lopina Lalpa chuh kuo a?
 Pathien hat chuh ahi;
 Lopina Lalpa chuh kuo a? (2)
 Mipite Lalpa ngei chuh Lopina Lalpa ahi (2)

[V6]
 Hallelujah (5) Amen (3)</lyrics>
<title>NEW CHAPEL BUILDING</title>
<hymn_number>218</hymn_number>
</song>