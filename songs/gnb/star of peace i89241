<?xml version="1.0" encoding="UTF-8"?><song><title>STAR OF PEACE</title>
<lyrics>[V1]
 1. Vakvai gimtheite muon Aksi,
 Ei hun salh in na vakin;
 :$: Kuongpu lungzing sukipak in,
 Tuipi gamla'h. (2)

[V2]
 2. Kinep Aksi tui kinawk ah,
 Nang hun ngaite hehpih in;
 :$: Kuongpu thawmhau chuh panpih in,
 Tuipi gamla'h. (2)

[V3]
 3. Gin Aksi huih a hat tieng leh,
 Thavai a nang hun zuon chuh;
 :$: Huih lakah amah hukdam in,
 Tuipi gamla'h. (2)

[V4]
 4. Pathien Aksi amah puiin,
 Vakvai chu na kawm tunin;
 :$: Thepna hatin sawttak a suol,
 Tuipi gamla'h. (2)</lyrics>
<hymn_number>84</hymn_number>
</song>