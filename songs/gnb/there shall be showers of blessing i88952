<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1. &quot;Vangpiekna guohpi hung zu'n tin,&quot;
 Hehpih thutiem chuh ahi;
 Halhthakna phat hung tung intin,
 Hukdampa'n A hun sawl chuh.

[V2]
 Vangpiekna guoh chuh,
 Vangpiekna guoh I ngai ui;
 Hehpih guohmal a hung chak hi,
 Guohpi hung di'n I ngen ui.

[V3]
 2. &quot;Vangpiekna guohpi hung zun tin,&quot;
 Halhna deihum hun tun in;
 Muol leh dam gam tin, mun tin ah,
 Guoh tampi hung zu gi chuh.

[V4]
 3. &quot;Vangpiekna guohpi hung zu'n tin,&quot;
 Kei-uh ei hun pie'n, Lalpa;
 Halhthakna chuh ei hun pie'n la,
 Hung in na thu limbawl in.

[V5]
 4. &quot;Vangpiekna guohpi hung zu'n tin,&quot;
 Aw, tuni'n le a zu thei;
 Pathien kawm ah ka kiphuong ui,
 Tuhin Isu ka sam ui.</lyrics>
<title>&quot;THERE SHALL BE SHOWERS OF BLESSING&quot;</title>
<hymn_number>23</hymn_number>
</song>