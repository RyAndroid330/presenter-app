<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>102</hymn_number>
<lyrics>[V1]
 yòu shì yī gè lí míng, yáng guāng sì shè de rì zi.
 yī gè xīn de mín zú, zài zhè kuài de shàng dàn shēng.
 yà bó lā hǎn de hòu yì, chéng shòu yīng xǔ de chǎn yè,
 lí kāi běn de běn zú jìn rù jiā nán de.</lyrics>
<title>jìn rù jiā nán de 迦南102</title>
</song>