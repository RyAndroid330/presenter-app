<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>127</hymn_number>
<lyrics>[V1]
 zǒu chū nǐ tiān huā bǎn de fáng wū dào nán guó qù shōu gē,
 zǒu chū nǐ tiān huā bǎn de fáng wū dào běi jiāng qù sā zhǒng,
 dào nà huāng yuán qù gēng lí dào nà tián yě qù jiāo guàn,
 lái ba ràng wǒ men yī qǐ gǎn gōng, cóng zǎo chén dào huáng hūn,
 tīng a tián yě chuán lái gē shēng, kàn nà rén men bèi zhe hé kǔn,
 lái ba ràng wǒ men yī qǐ gǎn gōng, zài nà tián yě lǐ.</lyrics>
<title>yī qǐ gǎn gōng 迦南127</title>
</song>