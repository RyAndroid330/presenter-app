<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>704</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 wǒ jīn tiān wèi nǐ zhù fú, yé hé huá bì tiān tiān kàn gù.
 nǐ zài jiā zài wài, nǐ chū nǐ rù, yé hé huá bì yī lù bǎo hù.
 nǐ dāng chú qù kǒng jù de xīn, yīn wèi zhè bù shì cóng shén lái.
 kào zhe yé sū yǒng bù dòng yáo, wǒ men yī shēng méng le dà fú.</lyrics>
<title>wǒ jīn tiān wèi nǐ zhù fú 迦南704</title>
</song>