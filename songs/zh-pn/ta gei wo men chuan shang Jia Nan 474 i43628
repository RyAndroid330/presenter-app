<?xml version="1.0" encoding="UTF-8"?><song><title>tā gěi wǒ men chuān shàng 迦南474</title>
<lyrics>[V1]
 tā gěi wǒ men chuān shàng gōng yì de wài páo, tā gěi wǒ men chuān shàng jié bái de xì má yī,
 tā de jì sī dōu pī shàng jiù ēn, tā de shèng mín dōu yáng shēng huān hū.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>474</hymn_number>
</song>