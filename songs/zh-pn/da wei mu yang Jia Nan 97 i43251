<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 dà wèi zài kuàng yě mù fàng yáng qún,
 jǐ dù shān huā kāi, jǐ dù xuě fēi chūn,
 fēng fēng yǔ yǔ duō shǎo zài.
 hēi yè dào bái tiān bù lí yáng de shēn.
 a! yǒng gǎn de dà wèi, shén de mù yáng rén,
 shí kè jǐng xǐng, hù wèi yáng qún.</lyrics>
<title>dà wèi mù yáng 迦南97</title>
<author>lǚ xiǎo mǐn</author>
<hymn_number>97</hymn_number>
</song>