<?xml version="1.0" encoding="UTF-8"?><song><title>shèng líng zài cuī cù 迦南767</title>
<lyrics>[V1]
 shèng líng zài cuī cù, yuǎn fāng yǒu hū huàn.
 qiú jiù de shēng yīn, cháng xiǎng zài ěr biān.
 qiān nián de jiāo xiǎng, wú shù shuāng qī dài de yǎn,
 shàng dì de pū rén nǎ, nǐ shì fǒu tīng jiàn kàn jiàn?
 bù guǎn nǐ zěn yàng xiǎng, bù guǎn nǐ zěn yàng kàn,
 zhǐ yào wǒ men zài, yī dìng yào bǎ fú yīn chuán biàn.
 zhǔ yǐ jiāng nà de zhǐ gěi wǒ men kàn,
 shén de pū rén nǎ, nǐ yào zhuàng dǎn.
 zhǔ yǐ dé shèng, kǔn bǎng le sā dàn,
 zhǐ yǒu yī bù yuǎn, jiù yào jìn jiā nán.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>767</hymn_number>
</song>