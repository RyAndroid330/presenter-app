<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>415</hymn_number>
<author>lǚ xiǎo mǐn</author>
<title>zhǔ kuài lái le 迦南415</title>
<lyrics>[V1]
 zhǔ kuài lái le zhǔ kuài lái le
 shéi zài hǎn nǎ! shéi zài hǎn nǎ,
 shì yé sū a! chà qiǎn rén lái
 bù fēn guó jiè xún zhǎo mí yáng
 zhǔ kuài lái le zhǔ kuài lái le
 nà yào lái de bù zài chí yán.</lyrics>
</song>