<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>446</hymn_number>
<lyrics>[V1]
 dú mù bù chéng lín, dì xiōng shǒu zú qīn,
 yé sū chà pài chuán fú yīn, liǎng gè liǎng gè lí jiā mén,
 yì xiāng duō wēi jiān, líng qiǎo yī kào shén,
 tiān yá hé chù qù, shèng líng lái zhǐ yǐn,
 xìn xiǎo yào zhā gēn, cái néng róng yào shén,
 yī bù yī gè jiǎo yìn chéng chéng shí shí qù ài shén,
 zhēn pà yǒu yī tiān bù méng zhǔ xǐ huān
 chèn zhe jī huì kuài bǎ cái bǎo wǎng tiān shàng jī cún.</lyrics>
<title>dú mù bù chéng lín 迦南446</title>
</song>