<?xml version="1.0" encoding="UTF-8"?><song><title>zhōng huá yào xìng qǐ 迦南180</title>
<lyrics>[V1]
 zhōng huá zhī jué qǐ yào chuán fú yīn, zhōng huá zhī jué qǐ yào jiù líng hún,
 zhōng huá zhī jué qǐ yào jìng wèi shén, zhōng huá zhōng huá shàng dì ài nǐ,
 yuàn nǐ dé zhe nà tiān shàng de gān lù. bù zài kuàng yě shā mò jì jū,
 yuàn nǐ xiàng tiān shàng de shén yǎng liǎn, tā de zhù fú yǒng bàn suí nǐ,
 zhōng huá yào chuán fú yīn. zhōng huá yào jiù líng hún
 zhōng huá jīn rì yào xìng qǐ, zhōng huá yào shì fèng shén.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>180</hymn_number>
</song>