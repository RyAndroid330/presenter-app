<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 wèi fú yīn bù pà zuò láo fáng, wèi fú yīn bù pà shàng xíng chǎng,
 pāo tóu lú, sǎ rè xuè, bì suí yé sū dǎ shèng zhàng,
 zhǔ suǒ zǒu guò de lù, wǒ men yě yào qù zǒu,
 bù yào shén me jiǎng shǎng, wú xū hǎo de píng jià, zhǐ qiú líng hún rì rì xìng wàng.</lyrics>
<title>wèi fú yīn 迦南158</title>
<hymn_number>158</hymn_number>
<author>lǚ xiǎo mǐn</author>
</song>