<?xml version="1.0" encoding="UTF-8"?><song><title>bù yào děng dào míng tiān zài shuō 迦南196</title>
<lyrics>[V1]
 bù yào děng dào míng tiān zài shuō,
 míng tiān de rì zi bù huì tài duō.
 shī qù le jīn tiān jiù bù zài huí lái.
 dé zhe le jīn tiān jiù yǒu shōu huò
 huǐ gǎi de jī huì, qiān wàn mò cuò guò,
 lì kè gēn suí zhǔ, shén zuì xǐ yuè,
 dāng chèn zhe jīn rì bǎ yù píng dǎ pò,
 bù yào děng dào míng tiān zài shuō.</lyrics>
<hymn_number>196</hymn_number>
<author>lǚ xiǎo mǐn</author>
</song>