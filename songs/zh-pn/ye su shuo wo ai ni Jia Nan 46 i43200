<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>46</hymn_number>
<title>yé sū shuō wǒ ài nǐ 迦南46</title>
<lyrics>[V1]
 yé sū shuō wǒ ài nǐ! yé sū shuō wǒ ài nǐ!
 wèi nǐ dīng shí jià, dān dāng nǐ zuì è.
 yé sū shuō wǒ ài nǐ! cì gěi nǐ xīn shēng mìng.
 yé sū shuō wǒ ài nǐ! ài nǐ! wèi nǐ ér sǐ.</lyrics>
</song>