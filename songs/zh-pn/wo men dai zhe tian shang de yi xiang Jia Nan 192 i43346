<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>192</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 wǒ men dài zhe dài zhe tiān shàng de yì xiàng, zǒu xiàng zǒu xiàng zǒu xiàng sì fāng,
 wǒ men dài zhe dài zhe tiān shàng de zhù fú, yòng ài xīn róng huà duǒ cáng,
 lán tiān hé dà de tóng zuò jiàn zhèng shuō wǒ men dài zhe tiān shàng de yì xiàng,
 shì jiè hé wàn guó de rén dōu yào zhī dào, wǒ men dài zhe tiān shàng de yì xiàng.</lyrics>
<title>wǒ men dài zhe tiān shàng de yì xiàng 迦南192</title>
</song>