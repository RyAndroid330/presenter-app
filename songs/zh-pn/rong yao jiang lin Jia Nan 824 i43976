<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>824</hymn_number>
<author>lǚ xiǎo mǐn</author>
<title>róng yào jiàng lín 迦南824</title>
<lyrics>[V1]
 róng yào róng yào jiàng lín, róng yào jiàng lín zài zhōng guó.
 róng yào róng yào jiàng lín, měi zuò gāo shān měi tiáo xiǎo hé.
 róng yào róng yào jiàng lín, róng yào jiàng lín zài zhōng guó.
 róng yào róng yào jiàng lín, měi zuò chéng shì měi gè cūn luò.</lyrics>
</song>