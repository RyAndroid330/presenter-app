<?xml version="1.0" encoding="UTF-8"?><song><title>yé hé huá ní xī 迦南296</title>
<lyrics>[V1]
 yé hé huá ní xī, shì wǒ de jīng qí, dé shèng de jīng qí.
 yé hé huá ní xī zhēn lǐ de jīng qí, ài de jīng qí.
 yé hé huá ní xī, shì wǒ de bǎo zhàng, yé hé huá ní xī.</lyrics>
<hymn_number>296</hymn_number>
<author>lǚ xiǎo mǐn</author>
</song>