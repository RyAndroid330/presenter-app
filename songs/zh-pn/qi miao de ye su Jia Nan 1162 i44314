<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1162</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 qí miào de yīng hái jiàng lín chén shì jiān,
 qí miào de xīng qiú yīn tā měi rì xuán zhuǎn.
 qí miào de zhěng jiù, xìn tā shēng mìng jiù gǎi biàn.
 qí miào de yī zhì, wǒ men líng hún tǐ dōu gǎi biàn.
 qí miào de yé sū, wǒ men xiàng nǐ yǎng liǎn.
 qí miào de yǐn lǐng, wǒ men xiàng nǐ zàn tàn.
 qí miào de dào lù, quán dōu shì ēn diǎn.
 qí miào de xiāng féng, shén jī jiǎng bù wán.</lyrics>
<title>qí miào de yé sū 迦南1162</title>
</song>