<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>1103</hymn_number>
<lyrics>[V1]
 zhǔ de kàn gù shèng guò wǒ men de jǐn shèn.
 zhǔ de bǎo hù shèng guò jūn wáng de dài wèi.
 zhǔ de tóng zài shì wǒ měi rì de xiǎng shòu.
 zhǔ de líng shì fàng wǒ yī shēng dé zì yóu.
 bù guǎn shì shàng yǒu duō shǎo zuò shān, duō shǎo tiáo hé liú.
 dǎng bù zhù yě dài bù zǒu wǒ duì zhǔ de qǐng xīn děng hòu.
 tā xìn shí de yǐn dǎo wǒ, háo wú cuò wù.
 tā de tóng zài bàn suí wǒ dù guò měi yī gè chūn qiū.</lyrics>
<title>zhǔ de kàn gù 迦南1103</title>
</song>