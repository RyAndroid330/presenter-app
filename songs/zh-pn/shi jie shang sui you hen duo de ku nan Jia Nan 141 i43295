<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>141</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 shì jiè shàng suī yǒu hěn duō de kǔ nán, yé sū shì wǒ zuì dà de píng ān,
 shì jiè shàng suī yǒu hěn duō de zāi nán, yé sū shì wǒ de bì fēng gǎng wān,
 wǒ yī shēng ài zhe tā, bù huì gǎi biàn, bù pà nà dà shuǐ fàn làn,
 wǒ yī zhí yī kào tā bù huì gǎi biàn, zhí dào yǒng yǒng yuǎn yuǎn.</lyrics>
<title>shì jiè shàng suī yǒu hěn duō de kǔ nán 迦南141</title>
</song>