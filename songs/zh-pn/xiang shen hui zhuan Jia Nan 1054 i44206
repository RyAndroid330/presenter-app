<?xml version="1.0" encoding="UTF-8"?><song><title>xiàng shén huí zhuǎn 迦南1054</title>
<lyrics>[V1]
 xiàng shén huí zhuǎn, kuài kuài xiàng shén huí zhuǎn,
 yīn wèi bù zhī dào shì fǒu hái huì yǒu míng tiān.
 xiàng shén huí zhuǎn, kuài kuài xiàng shén huí zhuǎn,
 qiú zhǔ de líng zài cì guāng zhào wǒ xīn jiān.
 wǒ men yào xiàng shén rèn zuì huǐ gǎi,
 zhǔ shì wǒ men dé jiù de gēn yuán.
 zhè shì yī gè xiàng shén huí zhuǎn de shí kè,
 wǒ yǐ jīng kàn jiàn shèng líng fù xìng de huǒ yàn.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>1054</hymn_number>
</song>