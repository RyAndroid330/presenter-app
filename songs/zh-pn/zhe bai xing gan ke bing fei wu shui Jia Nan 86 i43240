<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>86</hymn_number>
<lyrics>[V1]
 zhè bǎi xìng gàn kě bìng fēi wú shuǐ, zhè bǎi xìng jī è bìng fēi wú bǐng,
 nǎi shì yīn wèi bù tīng cóng yé hé huá de huà, méi yǒu jiāng tā de huà láo jì zài xīn zhōng,
 wéi yuàn wǒ men jīn rì huǐ gǎi, yuǎn lí è shì xīn cún zhèng zhí qián chéng jìng wèi,
 zhè yàng shén de ài jiù zhuǎn xiàng nǐ, xiàng nǐ shī ēn xiàng nǐ shī ēn.</lyrics>
<title>zhè bǎi xìng gàn kě bìng fēi wú shuǐ 迦南86</title>
</song>