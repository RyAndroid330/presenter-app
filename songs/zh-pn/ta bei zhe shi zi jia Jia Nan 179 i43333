<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>179</hymn_number>
<lyrics>[V1]
 tā bèi zhe shí zì jià, zǒu xiàng gè gè tā,
 tā de yǎn jīng wàng qián fāng, bù shuō yī jù huà,
 shén de dú shēng zi wèi wǒ men bèi shā,
 xiàn shàng shēng mìng liú chū le bǎo xuè zhěng jiù le pǔ tiān xià,
 tā de yī shēng liú xià duō shǎo ài de gù shì
 liè guó jiē zhī míng yáng tiān xià,
 wéi yǒu tā shì dào lù, wǒ men xìn kào tā,
 zài tiān shàng gěi wǒ men yù bèi le yī gè yǒng yuǎn de jiā.</lyrics>
<title>tā bèi zhe shí zì jià 迦南179</title>
</song>