<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>1394</hymn_number>
<lyrics>[V1]
 zhǔ yào fù xìng zhōng huá, shèng líng de huǒ yàn jiàng xià, ràng wǒ men yī tóng gǎn xiè ba,
 zhǔ yào fù xìng zhōng huá, shèng líng de huǒ yàn jiàng xià, ràng wǒ men qí dǎo zàn měi ba,
 zhuāng jià shú le, hào jiǎo chuī xiǎng le, tiáo tiáo dà lù dōu xiū píng le,
 dì xiōng huǐ gǎi le, qiān shǒu zǒu huí jiā, méng fú de zhōng huá měi lì rú huà,
 zàn měi yé sū, róng yào guī gěi tā, gǎn xiè yé sū, quán néng guī gěi tā,
 zhǔ de zhǐ yì chéng le. zhǔ de jiù ēn chéng le, zhǔ yào fù xìng chà qiǎn zhōng huá.</lyrics>
<title>zhǔ yào fù xìng zhōng huá 迦南1394</title>
</song>