<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 yé sū wǒ tài yáng, wéi yī de tài yáng,
 zhào liàng wǒ lù tú, càn làn míng liàng;
 bù guǎn shì yīn mái yì huò shì tiān qíng,
 yé sū, yé sū, wǒ wéi yī tài yáng

[V2]
 yé sū wǒ shēng mìng, měi miào de shēng mìng,
 yǔ wǒ yǒng lián jié, fú chí gōng yīng;
 zuó rì jīn rì dào yǒng yuǎn shì yī yàng,
 yé sū, yé sū, wǒ wéi yī shēng mìng.</lyrics>
<title>yé sū wǒ tài yáng</title>
</song>