<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>449</hymn_number>
<lyrics>[V1]
 zhǔ jiù shì dào lù, nǐ wǎng nǎ lǐ zǒu, gēn zhe tā shí shí chù chù dōu méng zhǔ bǎo shǒu.
 zhǔ jiù shì zhēn lǐ, jǔ shì wú shuāng, gāo jǔ tā xiàng rén chuán yáng fú lè wú jiāng.
 zhǔ jiù shì shēng mìng, chuàng zào de gēn yuán, dé dào tā zài wú suǒ ài dōu shī qù guāng cǎi.</lyrics>
<title>zhǔ jiù shì dào lù 迦南449</title>
</song>