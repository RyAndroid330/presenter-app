<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>940</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 màn màn shēn yè lǐ, wǒ men tóng shǒu wàng.
 wèi shén jiā jǔ shǒu, zhǔ bì zuò bǎo zhàng.
 màn màn shēn yè lǐ, tóng xīn dù shí guāng.
 yī chú yī lí de gēng yún zhōng, gǎn shòu dào shǐ mìng de fèn liàng.
 niú qún hé yáng qún, hái yǒu guǎng dà de hé chǎng.
 gǎn lǎn yuán pú táo yuán, nǐ kě zhī zěn me yàng?
 shēn shēn de hēi yè, wǒ men tóng shǒu wàng.
 yào zuò shén de hǎo pū rén, yào zuò shén jiā zhōng de dòng liáng.</lyrics>
<title>màn màn shēn yè lǐ wǒ men tóng shǒu wàng 迦南940</title>
</song>