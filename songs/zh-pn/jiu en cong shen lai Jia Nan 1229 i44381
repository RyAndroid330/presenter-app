<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1229</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 yǐ sī tiē mò dǐ gǎi suī bèi chóu dí lái xiàn hài.
 tóng xīn jìn shí xìn kào shén, shǐ chóu dí dà bài.
 jiù guó jiù mín lì dà gōng, shén yǔ yì rén tóng zài.
 jǔ guó huān téng qí sòng zàn, jiù ēn cóng shén lái.</lyrics>
<title>jiù ēn cóng shén lái 迦南1229</title>
</song>