<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>464</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 bié pà lù jiān nán, bié pà lù yáo yuǎn, yǐ jīng méi yǒu jǐ gè míng tiān,
 shì jiè jiāng chéng shòu jí dà de zāi nán, wǒ men yǒu zhǔ cháo xī xiāng bàn,
 jǐ jīng zhǔ shì liàn, chù chù guǒ mǎn yuán, hé cháng qīng shù bìng jiān nài suì hán,
 shě shēn wàng sǐ lí hé bēi huān wǒ men dōu shì wèi yào jiàn zhǔ miàn.</lyrics>
<title>bié pà lù jiān nán 迦南464</title>
</song>