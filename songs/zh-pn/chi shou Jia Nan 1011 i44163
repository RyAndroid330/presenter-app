<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>1011</hymn_number>
<lyrics>[V1]
 chí shǒu nǐ suǒ xìn de, chí shǒu nǐ suǒ xíng de lù,
 chí shǒu jiù shì dé shèng, chí shǒu jiù bì méng fú.
 zhòng àn nǐ yào dú míng, zhòng shuì nǐ yào dú xǐng.
 zhòng zhuó nǐ yào dú qīng, gāo jǔ zhēn lǐ yǒng bù yáo dòng.
 chí shǒu zǒu yī tiáo shí zì jià de dào lù,
 chí shǒu shén de mìng lìng, cái yǒu hǎo jiàn zhèng.
 chí shǒu zuò zhǔ zhōng pū, shèng shèng jié jié guò yī shēng.
 chí shǒu zuò zhǔ zhōng pū, shèng shèng jié jié guò yī shēng.</lyrics>
<title>chí shǒu 迦南1011</title>
</song>