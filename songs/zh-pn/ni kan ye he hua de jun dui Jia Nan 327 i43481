<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>327</hymn_number>
<lyrics>[V1]
 nǐ kàn yé hé huá de jūn duì, nǐ tīng jūn duì lǐ de hào shēng,
 yī lù xíng jūn yī lù gē, fēng yǔ yī chéng yòu yī chéng,
 wǒ men bǐ cǐ xiāng ài, wǒ men xīn líng xiāng tōng, wǒ men xíng zǒu bù fá qí zhěng,
 wǒ men gāng qiáng fèn yǒng, shān wā dōu yào tián píng, shén yòu fā chū mìng lìng.</lyrics>
<title>nǐ kàn yé hé huá de jūn duì 迦南327</title>
</song>