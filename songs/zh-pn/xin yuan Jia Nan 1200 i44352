<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>1200</hymn_number>
<lyrics>[V1]
 yuàn wǒ de xìn xīn yǒng yuǎn bù dòng yáo, yuàn wǒ de ài xīn yǒng yuǎn bù jiǎn shǎo.
 yuàn shén de néng lì tiān tiān lín dào, yuàn wǒ měi tiān bǐ tài yáng qǐ dé zǎo.
 xiàng zhe zhǔ de biāo gān zhí pǎo, zhǎi lù suī qí qū xiàng dǎo kě kào.
 qīng chǔ shǐ mìng qīng chǔ hū zhào, chuī qǐ shí dài qián jìn de hào jiǎo.
 fù shén a wǒ yuàn wèi nǐ rán shāo, qiú nǐ yòng shèng hān de ēn gāo.
 fù shén a wǒ yuàn wèi nǐ rán shāo, jiāng fú yīn chuán biàn tiān yá hé hǎi jiǎo.
 jiāng fú yīn chuán biàn tiān yá hé hǎi jiǎo.</lyrics>
<title>xīn yuàn 迦南1200</title>
</song>