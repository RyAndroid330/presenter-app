<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>724</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 shén shì jì xié de shén, tā shì dú yī zhēn shén.
 yào jiào xùn ér nǚ jì zài xīn shàng. tiān tiān bǐ cǐ tán lùn,
 shí shí tí xǐng ér nǚ men. yī shēng jìng wèi yé hé huá,
 chú diào ǒu xiàng. dān dān shì fèng tā, tā shì dú yī zhēn shén.</lyrics>
<title>shén shì jì xié de shén 迦南724</title>
</song>