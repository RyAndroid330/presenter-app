<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>186</hymn_number>
<author>lǚ xiǎo mǐn</author>
<title>wǒ men shì 迦南186</title>
<lyrics>[V1]
 wǒ men shì yǐ sè liè de zhàn chē mǎ bīng,
 wǒ men shì yǒng shì shǒu zhōng dài fā de jiàn,
 wǒ men shì xióng xióng rán shāo de huǒ,
 wǒ men shì yé hé huá shǒu zhōng de dāo.</lyrics>
</song>