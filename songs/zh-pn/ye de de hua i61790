<?xml version="1.0" encoding="UTF-8"?><song><title>yě de de huā</title>
<lyrics>[V1]
 yě de de huā,
 chuān zhe měi lì de yī shang,
 tiān kōng de niǎo ér,
 cóng lái bù wèi shēng huó máng;

[C1]
   cí ài de tiān fù,
   tiān tiān dōu kàn gù,
   tā gèng ài shì shàng rén,
   wèi tā men yù bèi yǒng shēng de lù.

[V2]
 yī qiè xū yào,
 tiān fù yǐ jīng dōu zhī dào,
 ruò xīn zhōng fán nǎo,
 ràng tā wèi nǐ chú diào;

[C2]
   cí ài de tiān fù,
   tiān tiān dōu kàn gù,
   tā shì quán néng de zhǔ,
   xìn kào tā de rén zhēn shì yǒu fú.</lyrics>
</song>