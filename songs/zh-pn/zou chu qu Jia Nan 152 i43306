<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>152</hymn_number>
<lyrics>[V1]
 zǒu chū qù xiàng nán xiàng běi, zǒu chū qù xiàng dōng xiàng xī,
 zhāng kāi nǐ jū suǒ de màn zi, kuò dà nǐ zhàng mù zhī de,
 nǐ yào shě jǐ zhǔ yào yòng nǐ, nǐ yào shě jǐ zǒu chū qù,
 féi wò de tǔ de zài nǐ miàn qián, jiǎo tà zhī de shǔ yú nǐ,
 zhǔ shuō nǐ men yào zǒu chū qù, bù yào tíng liú zài nà lǐ,
 dāng xìn nǐ shén suǒ lì de yīng xǔ tā yào jiāng nà de cì gěi nǐ.</lyrics>
<title>zǒu chū qù 迦南152</title>
</song>