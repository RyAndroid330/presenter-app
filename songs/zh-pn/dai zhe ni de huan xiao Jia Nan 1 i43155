<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>1</hymn_number>
<lyrics>[V1]
 dài zhe nǐ de huān xiào, dài zhe nǐ de gē shēng,
 dài zhe nǐ de jiě mèi, dài zhe nǐ de dì xiōng,
 dài zhe nǐ de chéng shí, dài zhe nǐ de xīn líng;
 dài zhe nǐ de yī jiā, dài zhe nǐ de lín péng;
 zǒu jìn měi hǎo de shèng suǒ, xún qiú zhēn zhèng de rén shēng,
 bǎ nǐ suǒ yǒu de zhòng dān, jiāo tuō wǒ men de shèng líng,
 zhǐ yǒu xìn yé sū cái shì wǒ men de lù dēng.
 wēn róu rěn nài qiān bēi, shùn cóng de zūn xíng
 kuài bǎ fú yīn chuán, kuài bǎ fú yīn tīng.
 huān yíng nǐ men lái dào huān yíng nǐ men lái dào wǒ men de dà jiā tíng.</lyrics>
<title>dài zhe nǐ de huān xiào 迦南1</title>
</song>