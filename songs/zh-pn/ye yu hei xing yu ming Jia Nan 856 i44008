<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>856</hymn_number>
<title>yè yù hēi xīng yù míng 迦南856</title>
<lyrics>[V1]
 yè yù hēi xīng yù míng, yào zuò yè kōng zhōng de yī kē xīng.
 yè yù hēi dēng yù míng, yào zuò hēi yè zhōng de yī zhǎn dēng.
 yào fā guāng yào jǐng xǐng, mò hòu de dào lù zuì nán xíng.
 bù yào jù pà, kào zhǔ jiān dìng, shì shì fēi fēi zhǔ kàn dé qīng.
 yīn wèi zhǔ rì lín jìn, fā shēng de shì dōu yīng yàn shèng jīng.
 yè yù hēi xīng yù míng, yī lù duō zhēn zhòng.</lyrics>
</song>