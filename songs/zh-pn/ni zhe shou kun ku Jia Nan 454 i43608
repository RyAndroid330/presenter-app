<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>454</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 nǐ zhè shòu kùn kǔ bèi fēng piāo dàng bù dé ān wèi de rén,
 yé hé huá yào lái, ān wèi fú chí nǐ,
 nǐ zhè shòu kùn kǔ bèi fēng piāo dàng, bù dé ān wèi de rén
 yé hé huá yào lái, ān wèi fú chí nǐ,
 nǐ jīng guò shuǐ huǒ, zài lú zhōng áo liàn,
 yé hé huá dōu kàn jiàn, tā méi yǒu lí kāi nǐ,
 tā yòu liàng wǒ men de jiǎo bù, lù màn màn kǔ nán yā lì,
 zhè yī qiè dōu yǔ nǐ yǒu yì.</lyrics>
<title>nǐ zhè shòu kùn kǔ 迦南454</title>
</song>