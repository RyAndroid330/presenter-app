<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>541</hymn_number>
<author>lǚ xiǎo mǐn</author>
<lyrics>[V1]
 jīn tiān wǒ men yào zhàn chū lái, yòng zhēn chéng qiāo xiǎng zhōng guó de mén,
 jīn tiān wǒ men yào hǎn chū lái, yòng fú yīn huàn xǐng zhōng guó rén.
 jǐng gào tóng bāo yù bèi jiāng lái de jié qī, bù yào zài zhì ruò wǎng wén,
 dōu yǒu yī kē gǎn shì yōu guó de xīn, tiān guó lín jìn,
 bié ná shēng mìng zuò xiào tán, shòu kǔ de fù lǎo xiāng qīn,
 wǒ men yào zhàn chū lái, hǎn chū lái, zhōng guó rén dōu yào chuán fú yīn.</lyrics>
<title>jīn tiān wǒ men yào zhàn chū lái 迦南541</title>
</song>