<?xml version="1.0" encoding="UTF-8"?><song><author>lǚ xiǎo mǐn</author>
<hymn_number>562</hymn_number>
<lyrics>[V1]
 sā zhǒng de kuài sā zhǒng ya! shōu gē de kuài shōu gē,
 zàn měi de lái zàn měi ya! jìng bài de lái jìng bài,
 kuài bǎ nǐ de hé kǔn bèi huí lái guī huí liáng cāng.
 wǒ men de zàn měi hé jìng bài zhí dá tiān táng.</lyrics>
<title>sā zhǒng de kuài sā zhǒng 迦南562</title>
</song>