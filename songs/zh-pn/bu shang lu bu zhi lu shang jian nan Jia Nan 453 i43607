<?xml version="1.0" encoding="UTF-8"?><song><title>bù shàng lù bù zhī lù shàng jiān nán 迦南453</title>
<lyrics>[V1]
 bù shàng lù, bù zhī lù shàng jiān nán, bù shàng lù, bù zhī lù tú yáo yuǎn,
 dé bù dào jiāng nán shí yǔ, tà bù shàng guān wài bái xuě,
 gēn zhǔ zǒu, tiān yá kǔ lǚ, gèng zēng tiān jǐ fēn zūn yán
 lí shì sú, yǔ zhǔ tóng bù, rén shēng lù fēn wài gān tián.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>453</hymn_number>
</song>