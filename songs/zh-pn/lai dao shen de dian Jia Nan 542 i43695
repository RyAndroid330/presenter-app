<?xml version="1.0" encoding="UTF-8"?><song><title>lái dào shén de diàn 迦南542</title>
<lyrics>[V1]
 lái dào shén de diàn, yào jǐn shèn jiǎo bù,
 lái dào shén de diàn, yào yuǎn lí bù yì,
 yīn wèi shèng jié de zhǔ zài zhè lǐ.
 yīn wèi shī ēn de zhǔ zài zhè lǐ.</lyrics>
<author>lǚ xiǎo mǐn</author>
<hymn_number>542</hymn_number>
</song>