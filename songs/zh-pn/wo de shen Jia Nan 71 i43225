<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<author>lǚ xiǎo mǐn</author>
<title>wǒ de shén 迦南71</title>
<lyrics>[V1]
 wǒ de shén! děng hòu zài nǐ de miàn qián,
 cì xià nǐ bǎo guì de yán yǔ,
 nǐ de ài, bù duàn de jiāo guàn wǒ men,
 shǐ wǒ men zhòng xīn dé lì.</lyrics>
</song>