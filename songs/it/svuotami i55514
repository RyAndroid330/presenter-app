<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Santo fuoco, brucia via
 Il desiderio per tutto ciò
 Che non vien da Te
 Ma vien da me
 Voglio più di Te
 Dentro me

[V2]
 Svuotami, svuotami
 Riempimi di Te, Signor</lyrics>
<title>Svuotami</title>
<author>Appartati per il Re</author>
<hymn_number>1021</hymn_number>
</song>