<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1273</hymn_number>
<author>UEB Italia</author>
<title>Gesù è il mio pastore</title>
<lyrics>[V1]
 Gesù è il mio pastore, nulla mi mancherà
 Mi guida alle acque chete
 Sempre con Lui vivrò
 Gesù, Gesù, sempre con Lui vivrò
 Gesù, Gesù, sempre con Lui vivrò</lyrics>
</song>