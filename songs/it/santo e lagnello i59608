<?xml version="1.0" encoding="UTF-8"?><song><title>Santo è l'Agnello</title>
<lyrics>[V1]
 Santo, Santo, Santo è l'Agnello
 Santo, Santo, Santo è l'Agnello
 Santo è l'Agnello

[V2]
 Degno di ricevere
 La gloria, l'onore, la potenza
 Tu sei degno di ricevere
 La lode, la sapienza e la forza

[V3]
 Per sempre, per sempre, per sempre
 Nei secoli dei secoli
 (2 volte)

[V4]
 Amen!</lyrics>
<author>Voci di Sion</author>
<hymn_number>474</hymn_number>
</song>