<?xml version="1.0" encoding="UTF-8"?><song><title>Ogni cosa è possibile</title>
<lyrics>[V1]
 Ogni cosa è possibile
 A chi crede in me, amen!
 Ogni cosa è possibile
 A chi crede in me, amen!

[V2]
 Tutto è possibile
 A chi crede in me
 Io posso dare la pace e l'amor
 La gioia nel cuor</lyrics>
<author>Cristo è la Risposta</author>
<hymn_number>2807</hymn_number>
</song>