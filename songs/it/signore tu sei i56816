<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2201</hymn_number>
<lyrics>[V1]
 Signore Tu sei più caro dell'argento
 Signore Tu sei più prezioso dell'oro
 Signore Tu sei più splendente dei diamanti
 Niente desidero più di Te</lyrics>
<title>Signore tu sei</title>
</song>