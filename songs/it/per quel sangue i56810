<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2197</hymn_number>
<title>Per quel sangue</title>
<lyrics>[V1]
 Per quel sangue, Signor, io vengo a Te
 Per quel sangue versato per me
 Per quel sangue Tu mi hai perdonato
 E lavato da ogni mio peccato
 Per quel sangue son giustificato
 Non ho altro fondamento
 Solo il sangue di Gesù</lyrics>
</song>