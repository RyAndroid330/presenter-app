<?xml version="1.0" encoding="UTF-8"?><song><title>Alleluia al Signore</title>
<lyrics>[V1]
 Alleluia, Alleluia
 Al Signore d'Israel
 Alleluia, Alleluia
 Su, lodiamo il Signor

[V2]
 Lui mi ha redento
 Perché mi stima
 Lui mi ha redento
 Col Suo sangue
 Cammina avanti a me
 Lui mi ristorerà
 Gloria al Signor

[V3]
 Lui ci ha redento
 Perché ci stima
 Lui ci ha redento
 Col Suo sangue
 Cammina avanti a noi
 Lui ci ristorerà
 Gloria al Signor</lyrics>
<hymn_number>2591</hymn_number>
<author>Morning Star Music</author>
</song>