<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2849</hymn_number>
<lyrics>[V1]
 Venite, cantiamo al Signor
 E mandiamo grida a Lui
 Rocca della mia salvezza

[V2]
 Con ringraziamenti
 Andiamo al Suo cospetto
 E salmeggiamo lietamente a Lui
 Perché grande Egli è
 Per essere lodato
 E temuto sopra ogni Dio</lyrics>
<title>Venite cantiamo al Signor</title>
</song>