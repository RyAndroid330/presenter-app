<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>360</hymn_number>
<author>Sara Alicino</author>
<lyrics>[V1]
 Santo, santo, santo
 Santo, santo, santo
 Santo è il Signor
 Dio potente

[V2]
 Degno della gloria
 Degno dell'onore
 Degno di ricevere lode

[V3]
 Loda, lodaLo e innanzaLo
 Loda, esalta il Suo nome</lyrics>
<title>Santo, Santo, Santo</title>
</song>