<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>532</hymn_number>
<lyrics>[V1]
 Lascia scorrere
 Come fiumi dentro me
 La presenza Tua Gesù
 Mentre adoro Te
 Io ti do tutto di me
 Il desiderio mio sei Tu

[V2]
 CORO
 Soffia ancor su me
 Soffia di nuovo il Tuo amore
 Soffia ancor su me
 Lo Spirito Tuo, Signor</lyrics>
<title>Soffia ancor su me</title>
</song>