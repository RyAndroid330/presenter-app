<?xml version="1.0" encoding="UTF-8"?><song><title>Per amarlo</title>
<lyrics>[V1]
 L'anima mia ha sete di
 Gesù che è morto anche per me
 E che pagò con gran dolor
 Il mio peccar

[V2]
 E sono qui davanti a Lui
 Per amarlo, altro non voglio
 Che stare qui ai piedi Suoi</lyrics>
<hymn_number>1198</hymn_number>
<author>Sela</author>
</song>