<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2838</hymn_number>
<title>Canterò danzerò</title>
<lyrics>[V1]
 Canterò, danzerò
 E mi rallegrerò nel mio Signor
 Canterò, danzerò
 E mi rallegrerò nel mio Signor

[V2]
 Canto per dar gioia al mio Dio
 Perch'Ei dimora nelle lodi
 Del Suo popolo
 Danzo per dar gioia al cuore Suo
 Canterò e danzerò al Signor</lyrics>
</song>