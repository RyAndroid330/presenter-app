<?xml version="1.0" encoding="UTF-8"?><song><author>Lidia Genta</author>
<hymn_number>3553</hymn_number>
<lyrics>[V1]
 Alleluia, Alleluia
 All'Eterno Dio
 El-Olam, El-Chai
 Lode al Tuo nome

[V2]
 Alleluia, Alleluia
 Solo Tu sei il Signor
 Elohai Elohim
 Regni per sempre
 Alleluia

[V3]
 Alleluia, Alleluia
 Finché vita avrò
 Finché esisterò
 Ti darò lode

[V4]
 Alleluia
 Mio rifugio Tu sei
 Spero in Te, Elohai Shalom
 Lode al Tuo nome
 Alleluia

[V5]
 Eterno Creatore
 Confido in Te
 Tu sei il mio canto
 Solo in Te gioirò
 Mio Liberatore
 Alleluia

[V6]
 Alleluia, Alleluia
 Ogni cosa è Tua
 Sei il Re dei re
 Lode al Tuo nome

[V7]
 Alleluia
 Solo Tu sei il Signor
 El-Shaddai, El-Eliòn
 Regni per sempre
 Alleluia

[V8]
 L'onore, la gloria, la maestà
 Siano al Tuo nome
 Ed in Te gioirà ogni nazione
 Alleluia</lyrics>
<title>Alleluia</title>
</song>