<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Signor Gesù, vengo dinnanzi a Te
 E in Spirito e verità
 Voglio adorare Te
 Canterò a Te, alleluia

[V2]
 A-lle-luia, Alle-lu-ia
 A-lle-luia
 Canterò a Te, alleluia</lyrics>
<title>Signor Gesù vengo dinnanzi a te</title>
<hymn_number>2212</hymn_number>
<author>Cristo è la Risposta</author>
</song>