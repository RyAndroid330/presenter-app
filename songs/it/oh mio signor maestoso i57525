<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2843</hymn_number>
<author>Cristo è la Risposta</author>
<title>Oh mio Signor maestoso</title>
<lyrics>[V1]
 Oh mio Signor
 Maestoso sulla terra
 È il nome Tuo
 Oh mio Signor
 Maestoso sulla terra
 È il nome Tuo

[V2]
 Diam lode a Te
 Ti diamo gloria
 Magnifichiamo il nome Tuo
 Ti onoriam
 Ti adoriam
 Il nome Tuo esaltiam</lyrics>
</song>