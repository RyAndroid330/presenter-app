<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2915</hymn_number>
<author>Carmela Battista</author>
<title>Alleluia griderò</title>
<lyrics>[V1]
 Questa canzone voglio cantare
 Per Gesù che in cielo sta
 Lui ci ama, ci vuole bene
 Prega il Padre per me e per te

[V2]
 Le mie mani alzerò
 Per Gesù le alzerò
 I miei piedi batterò
 Per Gesù li batterò
 Le mie mani batterò
 Per Gesù le batterò
 Con la voce canterò
 Alleluia griderò</lyrics>
</song>