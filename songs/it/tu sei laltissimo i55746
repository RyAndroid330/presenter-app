<?xml version="1.0" encoding="UTF-8"?><song><title>Tu sei l'Altissimo</title>
<lyrics>[V1]
 Tu sei l'Altissimo, Gesù Signore
 Sei l'Altissimo
 Tu sei l'Altissimo, Gesù Signore
 Sei l'Altissimo

[V2]
 Ogni ginocchio si piegherà
 Ed ogni bocca dirà, Altissimo
 Che Tu sei il figlio del grande Iddio
 Ed ora sei qui con noi</lyrics>
<hymn_number>1235</hymn_number>
<author>Sela</author>
</song>