<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2105</hymn_number>
<author>Rosaria Puci</author>
<title>Amo il Signore</title>
<lyrics>[V1]
 Amo il Signor con tutto il cuor
 Amo il Signor con l'anima
 Amo il Signor con la mia mente
 Con tutto il cuor, con l'anima e la mente mia

[V2]
 Signor Ti amo per quello che Tu sei
 Signor Ti amo per quello che Tu fai
 Signore voglio amarti ancor di più
 Con tutto il cuor, con l'anima e la mente mia</lyrics>
</song>