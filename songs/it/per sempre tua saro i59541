<?xml version="1.0" encoding="UTF-8"?><song><author>Voci di Sion</author>
<hymn_number>468</hymn_number>
<lyrics>[V1]
 Per sempre Tua
 Per sempre Tua
 Per sempre Tua sarò

[V2]
 E con Te io riderò
 E con Te io piangerò
 Su di Te mi appoggerò
 Sposo mio

[V3]
 E con Te camminerò
 E con Te io correrò
 Con Te io volerò
 Mio diletto

[V4]
 Per sempre mia
 Per sempre mia
 Per sempre mia sarai

[V5]
 E con te io riderò
 E con te io piangerò
 Su di te mi appoggerò
 Mia diletta

[V6]
 E con te camminerò
 E con te io correrò
 Su di te mi appoggerò
 Mia perfetta</lyrics>
<title>Per sempre tua sarò</title>
</song>