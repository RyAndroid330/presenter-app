<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2848</hymn_number>
<title>Io mi rallegrerò</title>
<lyrics>[V1]
 Io mi rallegrerò nel Signor
 La mia anima gioirà nel mio Dio
 Perch'Egli mi ha rivestito di salvezza
 E mi ha coperto con la giustizia Sua</lyrics>
</song>