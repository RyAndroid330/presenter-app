<?xml version="1.0" encoding="UTF-8"?><song><author>UEB Italia</author>
<hymn_number>1262</hymn_number>
<lyrics>[V1]
 Io ti celebrerò con tutto il mio cuore
 E benedirò il nome Tuo
 Ogni giorno Ti loderò

[V2]
 Tu rallegri l'alma mia
 Che in Te trova riposo
 E ricorderò finché vivrò
 Il Tuo amor, Padre, per me</lyrics>
<title>Io ti celebrerò</title>
</song>