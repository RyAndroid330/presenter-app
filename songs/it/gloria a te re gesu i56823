<?xml version="1.0" encoding="UTF-8"?><song><author>Cristo è la Risposta</author>
<hymn_number>2208</hymn_number>
<lyrics>[V1]
 Gloria a Te, Re Gesù
 Gloria a Te, Emmanuel
 Re dei re, Signor dei signor
 Stella del mattin
 E per tutta l'eternità
 Io loderò Te
 Ed insieme a Te
 Regnerò nel ciel</lyrics>
<title>Gloria a te Re Gesù</title>
</song>