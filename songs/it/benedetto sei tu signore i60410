<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>914</hymn_number>
<author>Gospel Sound Singers</author>
<title>Benedetto sei Tu Signore</title>
<lyrics>[V1]
 Padre del cielo noi T'amiamo
 E il nome Tuo esaltiamo sulla Terra
 Che il Tuo regno venga nelle nostre lodi
 Che il Tuo popolo proclami il Tuo amor

[V2]
 Benedetto sei Tu, Signore
 Iddio santo e onnipotente
 Benedetto sei Tu, Signore
 Per sempre regnerai</lyrics>
</song>