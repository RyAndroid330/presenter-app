<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1522</hymn_number>
<author>Marcelo S. Rodriguez</author>
<title>Fai piovere su di me</title>
<lyrics>[V1]
 Fai piovere su di me
 Apri la porta del cielo

[V2]
 Bramo la Tua unzione su di me
 Voglio aver, voglio sentir
 Il Tuo amor avvolgere</lyrics>
</song>