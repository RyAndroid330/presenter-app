<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>586</hymn_number>
<author>ADI Media</author>
<title>Io Ti ringrazio</title>
<lyrics>[V1]
 Io Ti ringrazio, o mio Signore
 Tutti i giorni della mia vita
 Io Ti ringrazio, o mio Signore
 Tutti i giorni della mia vita

[V2]
 Ero affamato e mi cibasti
 Ero affamato e mi cibasti
 Ero affamato e mi cibasti
 Ti ringrazio per sempre Signor

[V3]
 Io Ti ringrazio, o mio Signore...

[V4]
 Avevo sete e mi dissetasti
 Avevo sete e mi dissetasti
 Avevo sete e mi dissetasti
 Ti ringrazio per sempre Signor

[V5]
 Io Ti ringrazio, o mio Signore...

[V6]
 Non ero degno, mi cercasti
 Non ero degno, mi cercasti
 Non ero degno, mi cercasti
 Ti ringrazio per sempre Signor

[V7]
 Io Ti ringrazio, o mio Signore...</lyrics>
</song>