<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2311</hymn_number>
<author>ADI Media</author>
<lyrics>[V1]
 Per il cibo che ci doni
 Noi Ti ringraziam Signor
 L'acqua e il pane che ci doni
 Noi Ti ringraziam Signor

[V2]
 E c'è la pastasciutta
 L'uovo e la bistecca
 L'insalata fresca e la verdura cotta
 Il formaggio e la frutta
 Noi Ti ringraziam Signor</lyrics>
<title>Per il cibo</title>
</song>