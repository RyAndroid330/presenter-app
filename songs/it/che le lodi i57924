<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>3207</hymn_number>
<author>Cristo è la Risposta</author>
<lyrics>[V1]
 Che le lodi di Dio risuonino
 Dal Suo popolo
 Cantiam, gridiam
 Con gioia al nostro Re
 (BIS)

[V2]
 Lodiamo Dio, Lo esaltiam per sempre
 Lodiamo Dio, Lo esaltiamo
 Lodiamo Te, Ti esaltiam insieme
 Lodiamo Te, Ti esaltiam</lyrics>
<title>Che le lodi</title>
</song>