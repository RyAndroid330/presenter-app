<?xml version="1.0" encoding="UTF-8"?><song><title>Verso nord verso sud</title>
<lyrics>[V1]
 Verso nord, verso sud
 Verso est ed ovest
 Chi andrà? Chi andrà?
 A parlar di Gesù
 Manda me, manda me
 Col Vangelo d'amor
 Voglio andar, voglio andar
 A parlar di Gesù</lyrics>
<author>ADI Media</author>
<hymn_number>2053</hymn_number>
</song>