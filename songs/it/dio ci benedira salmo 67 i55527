<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1034</hymn_number>
<author>Appartati per il Re</author>
<title>Dio ci benedirà (Salmo 67)</title>
<lyrics>[V1]
 Dio abbia pietà di noi
 Faccia risplendere il Suo volto su noi
 Affinché la Sua via
 Sia conosciuta sulla terra
 La Sua giustizia
 Fra tutte le genti

[V2]
 Dio, il nostro Dio
 Dio ci benedirà
 Ci benedirà</lyrics>
</song>