<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4109</hymn_number>
<author>AT29</author>
<title>Vieni via</title>
<lyrics>[V1]
 Vieni via con Me
 Vieni via con Me
 Tardi non sarà
 Tardi mai sarà
 Tardi mai sarà, per te

[V2]
 Un piano ho per te
 Un piano ho per te
 Splendido sarà
 Ti sorprenderà
 Sarà pieno di Me

[V3]
 Aprimi il tuo cuore
 Ed entrerò</lyrics>
</song>