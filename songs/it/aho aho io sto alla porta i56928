<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2302</hymn_number>
<author>ADI Media</author>
<lyrics>[V1]
 Aho, aho! Io sto alla porta e picchio
 Aho, aho! Io sto alla porta e picchio
 Se tu odi la mia voce
 Se tu odi la mia voce
 E apri, apri, apri il tuo cuor
 Io entrerò</lyrics>
<title>Aho aho! Io sto alla porta</title>
</song>