<?xml version="1.0" encoding="UTF-8"?><song><title>Solo se potrò</title>
<lyrics>[V1]
 Solo se potrò toccar Gesù
 Solo se potrò in quest'ora
 Toccare la Sua veste
 Solo se potrò con fede

[V2]
 La Sua virtù mi sanerà
 La Sua potenza mi guarirà
 Solo se potrò toccar Gesù
 Con fede il mio Signor</lyrics>
<hymn_number>3832</hymn_number>
<author>Antonio Morra</author>
</song>