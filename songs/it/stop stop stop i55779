<?xml version="1.0" encoding="UTF-8"?><song><title>Stop stop stop</title>
<lyrics>[V1]
 Stop, stop, stop
 Sulla via che scende
 Bada all'avvertimento mentre puoi
 Torna indietro per la via del ciel
 Tu riceverai perdono
 Se tu vai a Gesù, a Gesù
 Oggi ancor!</lyrics>
<hymn_number>1265</hymn_number>
<author>UEB Italia</author>
</song>