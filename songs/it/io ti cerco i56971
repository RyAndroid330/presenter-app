<?xml version="1.0" encoding="UTF-8"?><song><title>Io ti cerco</title>
<lyrics>[V1]
 Io Ti cerco, io Ti cerco
 Con fuoco nel mio cuore
 Io Ti cerco, io Ti cerco
 Ricevi la mia adorazione

[V2]
 Ti anelo, di Te ho bisogno
 Ti amo, Ti desidero</lyrics>
<author>Marcelo S. Rodriguez</author>
<hymn_number>2342</hymn_number>
</song>