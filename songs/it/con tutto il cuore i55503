<?xml version="1.0" encoding="UTF-8"?><song><author>Antonio Decimo</author>
<hymn_number>1011</hymn_number>
<lyrics>[V1]
 Aspetto e alzo le mie mani
 Mi guardi
 Verrò, correndo verso di Te
 Fra le Tue braccia
 Io voglio Te

[V2]
 Con tutto il cuore
 Tu sempre di più
 Con tutto il cuore, Tu</lyrics>
<title>Con tutto il cuore</title>
</song>