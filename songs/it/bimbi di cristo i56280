<?xml version="1.0" encoding="UTF-8"?><song><title>Bimbi di Cristo</title>
<lyrics>[V1]
 Mi chiamo ..., servo il Signor.
 Mi chiamo ..., l'amo di cuor.

[V2]
 Bimbi di Cristo, sì, noi lo siam!
 Bimbi di Cristo, sì, noi lo siam!</lyrics>
<author>Centro Evangelico Modenese</author>
<hymn_number>1718</hymn_number>
</song>