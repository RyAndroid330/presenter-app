<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>935</hymn_number>
<author>Morning Star Music</author>
<title>Aprimi gli occhi del cuore</title>
<lyrics>[V1]
 Aprimi gli occhi del cuore
 Apri i miei occhi Signor
 Voglio vederti
 Voglio vederti

[V2]
 Vederti splendere Signor
 Nella luce della tua gloria
 Versa il tuo amore su noi
 Mentre cantiamo santo santo

[V3]
 Santo santo santo
 Santo santo santo
 Santo santo santo
 Voglio vederti</lyrics>
</song>