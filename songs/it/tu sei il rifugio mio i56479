<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Tu sei il rifugio mio
 Tu riempi sempre il cuor
 Con canti di libertà
 E quando ho timor
 Io confido in Te

[V2]
 Io confido in Te
 Anche se son debole
 La mia forza è nel Signor</lyrics>
<title>Tu sei il rifugio mio</title>
<hymn_number>19</hymn_number>
<author>Sara Leonardi</author>
</song>