<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Apri i miei occhi Signore
 Apri i miei occhi Signore
 Voglio vederti, voglio vederti
 Apri i miei occhi Signore
 Apri i miei occhi Signore
 Voglio vederti, voglio vederti

[V2]
 Vederti splendere su me
 Nella luce della Tua gloria
 Versa il Tuo amore su noi
 Mentre cantiamo &quot;Santo Santo&quot;
 Santo, Santo, Santo
 Voglio vederti!

[V3]
 Santo, Santo, Santo
 Santo, Santo, Santo
 Santo, Santo, Santo
 Voglio vederti!</lyrics>
<title>Apri i miei occhi Signore</title>
<author>Marcelo S. Rodriguez</author>
<hymn_number>2395</hymn_number>
</song>