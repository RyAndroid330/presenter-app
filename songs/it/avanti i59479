<?xml version="1.0" encoding="UTF-8"?><song><title>Avanti</title>
<lyrics>[V1]
 Avanti! Avanti!
 Con la mano sull'aratro
 Senza mai guardare indietro
 Andiamo avanti

[V2]
 Avanti! Avanti!
 Con il fuoco dentro il cuore
 Motivati dall'amore
 Andiamo avanti

[V3]
 O Dio, Altissimo
 Redentor, glorioso Re
 Al Tuo comando noi marcerem
 Verso una sola direzione</lyrics>
<hymn_number>4622</hymn_number>
<author>Corrado Salmè</author>
</song>