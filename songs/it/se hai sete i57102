<?xml version="1.0" encoding="UTF-8"?><song><title>Se hai sete</title>
<lyrics>[V1]
 Se hai sete, se hai sete tu puoi venire
 Perché Io son la fonte, dice il Signore
 Bevi l'acqua viva, fresca della fonte
 Bevi l'acqua viva, l'acqua del Signor</lyrics>
<author>ADI Media</author>
<hymn_number>2461</hymn_number>
</song>