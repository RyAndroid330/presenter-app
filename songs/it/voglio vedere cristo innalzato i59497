<?xml version="1.0" encoding="UTF-8"?><song><author>Voci di Sion</author>
<hymn_number>464</hymn_number>
<title>Voglio vedere Cristo innalzato</title>
<lyrics>[V1]
 Voglio sentirti
 Voglio toccarti
 Voglio conoscerti di più, Gesù

[V2]
 Voglio vedere Cristo innalzato
 Lui solo glorificato
 Vedere Cristo esaltato in me

[V3]
 Voglio vedere Cristo innalzato
 Lui solo glorificato
 Vedere Cristo esaltato in me</lyrics>
</song>