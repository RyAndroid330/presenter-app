<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Aprimi gli occhi del cuore
 Apri i miei occhi, Signor
 Voglio vederti
 Voglio vederti

[V2]
 Vederti splendere, Signor
 Nella luce della Tua gloria
 Spandi il Tuo amore su noi
 Mentre cantiamo Santo Santo

[V3]
 Santo, Santo, Santo
 Santo, Santo, Santo
 Santo, Santo, Santo
 Voglio vederti</lyrics>
<title>Apri i miei occhi</title>
<hymn_number>3900</hymn_number>
<author>ADI Media</author>
</song>