<?xml version="1.0" encoding="UTF-8"?><song><title>Ti amo Signor</title>
<lyrics>[V1]
 Ti amo Signor
 E alzo un canto a Te
 Lodarti con tutto il cuore mio
 E Tu, mio Re, prendi gioia in me
 Lascia che io sia
 Un dolce suono verso Te</lyrics>
<hymn_number>2608</hymn_number>
<author>Morning Star Music</author>
</song>