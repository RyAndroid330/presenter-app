<?xml version="1.0" encoding="UTF-8"?><song><author>Denise Faro</author>
<hymn_number>1049</hymn_number>
<title>Son piccolina</title>
<lyrics>[V1]
 Son piccolina, a Gesù voglio cantare
 Son piccolina, a Gesù voglio lodare
 A Lui soltanto il mio cuore donerò
 Per Lui soltanto il mio cuore canterà</lyrics>
</song>