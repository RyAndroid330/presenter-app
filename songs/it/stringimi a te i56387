<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1815</hymn_number>
<author>Angelo Mele</author>
<lyrics>[V1]
 Stringimi a Te, Signore
 Fammi sentire il Tuo calore
 Nel mio cuore

[V2]
 Stringimi nelle Tue braccia ancora
 Parlami, guidami Signore
 Più vicino a Te, più vicino a Te

[V3]
 CORO
 Nell'avversità sarai vicino a me
 Nell'oscurità la Tua luce
 Mi guiderà, mi guiderà
 Nell'avversità sarai vicino a me
 Nell'oscurità la Tua luce
 Mi sosterrà, mi sosterrà</lyrics>
<title>Stringimi a te</title>
</song>