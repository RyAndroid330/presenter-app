<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>475</hymn_number>
<author>Voci di Sion</author>
<title>Nuovi cieli e nuova terra</title>
<lyrics>[V1]
 Nuovi cieli e nuova terra
 Nella città del nostro Dio
 Noi cammineremo
 Per le strade tutte d'oro

[V2]
 Ei - lai - lai - la

[V3]
 E i bambini canteranno
 E i bambini faranno festa
 Con il lupo e con l'agnello
 Nella città del nostro Dio

[V4]
 Ei - lai - lai - la

[V5]
 E l'agnello ci guiderà
 Presso i rivi d'acqua viva
 Non più morte, non più pianto
 Né ferita né dolore

[V6]
 Ei - lai - lai - la

[V7]
 E ogni lacrima asciugherà
 E ogni lacrima asciugherà
 E ogni lacrima asciugherà
 Dagli occhi loro</lyrics>
</song>