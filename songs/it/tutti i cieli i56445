<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1869</hymn_number>
<author>Loredana Rapisarda</author>
<title>Tutti i cieli</title>
<lyrics>[V1]
 Santo, santo sei Signor
 Tutta la terra è ripiena di Te
 Le nazioni rendano onore
 E lode al Tuo nome

[V2]
 Che il Tuo sguardo sia su noi
 E le genti vedranno Te
 Tutti i cieli dichiarano
 &quot;Grande è il nostro Dio!&quot;
 L'universo canterà
 &quot;Alleluia al nostro Re!&quot;</lyrics>
</song>