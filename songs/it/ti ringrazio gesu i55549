<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1054</hymn_number>
<author>Denise Faro</author>
<lyrics>[V1]
 Ti ringrazio Gesù, Ti ringrazio Gesù
 Ti ringrazio con tutto il mio cuore
 (2 volte)

[V2]
 Ti ringrazio Gesù, Ti ringrazio Gesù
 Ti ringrazio per mamma e papi
 (2 volte)

[V3]
 Ti ringrazio Gesù, Ti ringrazio Gesù
 Ti ringrazio per i miei fratelli
 (2 volte)

[V4]
 Ti ringrazio Gesù, Ti ringrazio Gesù
 Ti ringrazio per le mie sorelle
 (2 volte)</lyrics>
<title>Ti ringrazio Gesù</title>
</song>