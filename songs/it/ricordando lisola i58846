<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4042</hymn_number>
<author>Albino Montisci</author>
<title>Ricordando l'isola</title>
<lyrics>[V1]
 Sa bia e sa vida sesi
 Sa berìdadi o Deus
 Tui sa sperànza sesi
 Dollu cantai a tottus

[V2]
 Ua' dì as, à torrai
 Gèsu in mes, à nosu
 Biad, à totu cussus
 Chi anti cretiu in-à Tui</lyrics>
</song>