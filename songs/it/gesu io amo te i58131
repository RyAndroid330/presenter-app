<?xml version="1.0" encoding="UTF-8"?><song><title>Gesù io amo te</title>
<lyrics>[V1]
 Gesù, meraviglioso
 Gesù, tutto Tu sei per me
 Gesù, Tu sei oro
 Gesù, prezioso per me

[V2]
 Gesù, dolce nome
 Gesù, amore Tu sei
 Gesù, glorioso nome
 Gesù, io amo Te

[V3]
 Io amo Te
 Io amo Te</lyrics>
<author>Isaura Nencini</author>
<hymn_number>3395</hymn_number>
</song>