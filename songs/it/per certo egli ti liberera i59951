<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>506</hymn_number>
<author>Cristo è la Risposta</author>
<lyrics>[V1]
 Per certo Egli ti libererà
 Dal laccio del maligno
 Per certo Egli ti libererà
 Da quello che ti opprime

[V2]
 Se vai a Gesù, le catene spezzerà
 Se vai a Gesù, libero sarai</lyrics>
<title>Per certo egli ti libererà</title>
</song>