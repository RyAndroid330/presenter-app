<?xml version="1.0" encoding="UTF-8"?><song><author>Corrado Salmè</author>
<hymn_number>4626</hymn_number>
<lyrics>[V1]
 Ritorno a Te
 Alla Tua presenza
 Ritorno a Te
 Al mio primo amor
 Con tutto il mio cuor
 Io Ti adoro, Signore
 Con tutto il mio cuor
 Ritorno a Te

[V2]
 CORO
 Per dirti Ti amo
 Per dirti Ti adoro
 Per darti il mio amore
 Per darti il mio cuore
 Tu sei la mia vita
 Tu sei la mia forza, Signor</lyrics>
<title>Ritorno a Te</title>
</song>