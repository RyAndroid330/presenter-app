<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>18</hymn_number>
<author>Sara Leonardi</author>
<lyrics>[V1]
 C'è un giardin
 Giardin della preghiera
 Dove Gesù io posso ritrovar
 Lì, Lui mi attende
 Ed aprirà la porta
 Oh quale gioia
 Allor per me sarà</lyrics>
<title>C'è un giardin</title>
</song>