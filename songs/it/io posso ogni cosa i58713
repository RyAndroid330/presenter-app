<?xml version="1.0" encoding="UTF-8"?><song><author>Sara Leonardi</author>
<hymn_number>3921</hymn_number>
<lyrics>[V1]
 Io posso ogni cosa
 Io posso ogni cosa
 Io posso ogni cosa
 In Colui che mi fortifica

[V2]
 Ha pagato già per me
 Il mio Gesù, sì, per me
 Sono forte solo in Lui
 Quando guardo verso Lui</lyrics>
<title>Io posso ogni cosa</title>
</song>