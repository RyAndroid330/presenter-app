<?xml version="1.0" encoding="UTF-8"?><song><author>Gianni Castaldo</author>
<hymn_number>2870</hymn_number>
<lyrics>[V1]
 L'unico desiderio mio sei Tu
 L'unica speranza mia sei Tu
 L'unico tesoro
 L'unica mia gioia
 L'unico amico sei, Gesù
 L'unico Signore sei per me
 L'unico Salvatore sei per noi
 L'unico che consola
 L'unico che guarisce
 L'unico mediatore è Gesù</lyrics>
<title>L'unico desiderio</title>
</song>