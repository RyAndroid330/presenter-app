<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2592</hymn_number>
<author>Morning Star Music</author>
<lyrics>[V1]
 Gesù stai cambiandomi
 Il Tuo Spirito mi fa simile a Te
 Gesù trasformandomi
 Lo splendore Tuo appare intorno a me

[V2]
 Tu il vasellaio
 E l'argilla io
 Fammi strumento
 Della Tua volontà

[V3]
 Gesù stai cambiandomi
 Quando io ti lascio spazio
 Nel mio cuor</lyrics>
<title>Gesù stai cambiandomi</title>
</song>