<?xml version="1.0" encoding="UTF-8"?><song><title>Entra nel luogo santissimo</title>
<lyrics>[V1]
 Entra nel luogo santissimo
 Per il sangue dell'Agnel
 Nella Sua presenza con canti
 Al Suo trono adoriam

[V2]
 Mani sante alziam
 Al Re dei re
 Loda Gesù
 Loda Gesù</lyrics>
<hymn_number>2842</hymn_number>
<author>Cristo è la Risposta</author>
</song>