<?xml version="1.0" encoding="UTF-8"?><song><title>Amabile</title>
<lyrics>[V1]
 Amabile sei Gesù
 Dolce sei, o Padre mio
 Amabile sei Gesù
 Dolce sei, o Padre mio

[V2]
 Il mio cuore farai traboccare
 Per le opere che fai
 Le mie mani alzerò a Te
 Perché grande è il Tuo nome</lyrics>
<hymn_number>504</hymn_number>
<author>Cristo è la Risposta</author>
</song>