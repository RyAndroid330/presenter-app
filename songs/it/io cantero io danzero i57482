<?xml version="1.0" encoding="UTF-8"?><song><title>Io canterò io danzerò</title>
<lyrics>[V1]
 Io canterò, io danzerò
 Io loderò il Signor
 Io alzerò le mani
 Ed il Tuo nome adorerò
 Gloria al Signore, io canterò
 Gloria al Signore, oggi lo farò
 Gloria al Signore, io canterò
 Gloria al Signore, per sempre io canterò</lyrics>
<hymn_number>2804</hymn_number>
<author>Cristo è la Risposta</author>
</song>