<?xml version="1.0" encoding="UTF-8"?><song><author>Evan Schoombie</author>
<hymn_number>330</hymn_number>
<lyrics>[V1]
 Oh Lord
 How great is Your name
 How great is Your name
 On the earth

[V2]
 Oh Lord
 How great is Your name
 How great is Your name
 On the earth

[V3]
 Oh Lord
 How great is Your name
 How great is Your name
 In the heavens

[V4]
 I worship You
 I adore You
 I give my praise to You

[V5]
 I worship You
 I adore You
 Oh Lord
 How great is Your name in the universe

[V6]
 Glory, glory, glory...</lyrics>
<title>How great is Your Name</title>
</song>