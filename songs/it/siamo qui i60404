<?xml version="1.0" encoding="UTF-8"?><song><author>Gospel Sound Singers</author>
<hymn_number>909</hymn_number>
<lyrics>[V1]
 Siamo qui
 Come una famiglia
 Per lodare Te
 Nell'unità
 Canteremo lodi
 Al nostro Re dei re

[V2]
 Cantiam Abba Padre
 Santo è il nome Tuo
 Abba Padre
 Santo è il nome Tuo

[V3]
 Siamo qui
 Come una famiglia
 Per lodare Te
 Nell'unità
 Esprimiamo amore
 Al nostro Re dei re

[V4]
 Cantiam Abba Padre
 Santo è il nome Tuo
 Abba Padre
 Santo è il nome Tuo</lyrics>
<title>Siamo qui</title>
</song>