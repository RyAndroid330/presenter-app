<?xml version="1.0" encoding="UTF-8"?><song><author>ADI Media</author>
<hymn_number>1532</hymn_number>
<title>Son felice</title>
<lyrics>[V1]
 Son felice ogni giorno con Gesù
 Io cammino tranquillo con Gesù
 Lui è sempre vicino a me
 La Sua mano mi guida davvero
 Con amore, proprio dappertutto
 Ora son felice ogni giorno con Gesù
 Io cammino tranquillo con Gesù</lyrics>
</song>