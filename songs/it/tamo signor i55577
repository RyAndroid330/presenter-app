<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1080</hymn_number>
<author>Gianni &amp; Katia</author>
<title>T'amo Signor</title>
<lyrics>[V1]
 T'amo Signor
 T'amo Signor
 T'amo Signor, Gesù
 Io Ti amo Signor

[V2]
 Desidero la Tua presenza
 E all'ombra delle ali Tue
 Voglio restar
 Perché sei Tu il mio rifugio
 E mi proteggerai dalle avversità</lyrics>
</song>