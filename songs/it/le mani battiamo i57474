<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2798</hymn_number>
<author>Cristo è la Risposta</author>
<title>Le mani battiamo</title>
<lyrics>[V1]
 Le mani battiamo
 Con gioia cantiamo
 Al nostro Signore
 Le mani battiamo
 Con gioia cantiamo
 Al nostro Re, Gesù

[V2]
 Lodiamo il nostro Dio
 Perché Egli è degno
 Esaltiamo il Suo nome
 Mandiamo a Lui gridi di gioia
 Alleluia!</lyrics>
</song>