<?xml version="1.0" encoding="UTF-8"?><song><title>Ogni giorno il cibo il Signor ci dà</title>
<lyrics>[V1]
 Ogni giorno il cibo il Signor ci dà:
 Pane, latte, frutta
 Che felicità!
 Egli è un Padre buono
 Ama i figli Suoi
 Lieti d'ogni dono
 Grazie, diciam noi</lyrics>
<hymn_number>1555</hymn_number>
<author>ADI Media</author>
</song>