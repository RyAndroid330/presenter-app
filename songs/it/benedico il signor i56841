<?xml version="1.0" encoding="UTF-8"?><song><author>Insieme per Cristo</author>
<hymn_number>2224</hymn_number>
<lyrics>[V1]
 Benedico il Signor
 Benedico il Signor
 Benedico il Signor
 Lode al nome Suo

[V2]
 Maestoso è (Maestoso è)
 Regnerà per sempre (Regnerà per sempre
 Salvezza è (Salvezza è)
 Lode al nome Suo

[V3]
 Per tutto il Suo regno
 Sia gloria e potenza
 Per sempre in eterno
 Amen!</lyrics>
<title>Benedico il Signor</title>
</song>