<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Shalom Aleichem
 Malahchey ha sbarre,
 Malachey Elyon,
 Mimehlech Malchey hamlachim
 Ha Kadosh Baruch hoo.

[V2]
 Boachem le shalom
 Malachey ha shalom
 Malachey El yon
 Mimehlech Malchey ham lachim
 Ha Kadosh Baruch hoo.</lyrics>
<title>Shalom Aleichem</title>
<author>Corale di Palmi</author>
<hymn_number>62</hymn_number>
</song>