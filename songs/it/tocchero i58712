<?xml version="1.0" encoding="UTF-8"?><song><title>Toccherò</title>
<lyrics>[V1]
 Toccherò il lembo della veste Sua, Signor
 Arriverò fin lì e poi Lo toccherò
 Solo se tocco il lembo Suo mi guarirà
 Arriverò fin lì e poi Lo toccherò
 Solo l'Agnel di Dio mi guarirà

[V2]
 Toccherò, toccherò la veste Sua
 Toccherò, toccherò la veste Sua</lyrics>
<hymn_number>3920</hymn_number>
<author>Sara Leonardi</author>
</song>