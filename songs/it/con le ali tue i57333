<?xml version="1.0" encoding="UTF-8"?><song><title>Con le ali Tue</title>
<lyrics>[V1]
 Ti sto cercando
 Dimora in me Signore
 Il mio desiderio
 Sei tu

[V2]
 Nel tuo amore
 M'inginocchierò
 Voglio conoscerti di più

[V3]
 Vieni Signore
 Prendi tutto il mio cuore
 Soffia su me
 Volerò con le ali tue</lyrics>
<hymn_number>267</hymn_number>
<author>Gospel Sound Singers</author>
</song>