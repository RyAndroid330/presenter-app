<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>431</hymn_number>
<author>Elisa Balsamo</author>
<title>Io amo Te</title>
<lyrics>[V1]
 Io amo Te e lo griderò
 Gioisce in Te la mia anima
 Gradisci o Re quel che Ti dirò
 Dolce sarà il mio canto al Tuo cuor
 Dolce sarà il mio canto al Tuo cuor</lyrics>
</song>