<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Voi partirete con gioia
 E in pace ritornerete
 Ed i monti ed i colli si apriranno
 Allor ci saran gridi di gioia
 Gli alberi dei campi
 Batteran, batteran le mani

[V2]
 Tutti gli alberi dei campi
 Batteran le mani
 Tutti gli alberi dei campi
 Batteran le mani
 Tutti gli alberi dei campi
 Batteran le mani
 E voi partirete con gioia</lyrics>
<title>Tutti gli alberi dei campi</title>
<author>Morning Star Music</author>
<hymn_number>2601</hymn_number>
</song>