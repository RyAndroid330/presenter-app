<?xml version="1.0" encoding="UTF-8"?><song><author>Sela</author>
<hymn_number>1234</hymn_number>
<lyrics>[V1]
 Ogni ginocchio si piegherà
 Ogni lingua confesserà
 Che Cristo è il Signor!

[V2]
 È il Signor, è il Signor
 È risorto dalla morte
 È il Signor

[V3]
 Ogni ginocchio si piegherà
 Ogni lingua confesserà
 Che Cristo è il Signor!</lyrics>
<title>È il Signor</title>
</song>