<?xml version="1.0" encoding="UTF-8"?><song><author>ADI Media</author>
<hymn_number>3901</hymn_number>
<lyrics>[V1]
 Tu sei il rifugio mio
 Tu riempi sempre il cuor
 Con canti di libertà
 E quando ho timor
 Io confido in Te

[V2]
 Io confido in Te
 Anche se son debole
 La mia forza è nel Signor
 Io confido in Te</lyrics>
<title>Tu sei il rifugio mio</title>
</song>