<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Eccomi, manda me
 Dove vorrai, andrò
 Eccomi, ungimi
 Voglio servirti, oh Dio

[V2]
 Eccomi, manda me
 Usami come vuoi
 Eccomi, lavami
 Rendimi puro, oh Dio

[V3]
 Io confiderò soltanto in Te
 Mio Re, mio Dio
 Io riposerò soltanto in Te

[V4]
 Ti seguirò, io Ti seguirò
 Ti seguirò, io Ti seguirò
 Ti seguirò, io Ti seguirò
 Ti seguirò, io Ti seguirò</lyrics>
<title>Eccomi manda me!</title>
<author>Angelo Mele</author>
<hymn_number>1837</hymn_number>
</song>