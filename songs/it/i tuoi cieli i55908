<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1382</hymn_number>
<author>Julim Barbosa</author>
<title>I tuoi cieli</title>
<lyrics>[V1]
 I tuoi cieli cantano
 Tutte le stelle gioiscono
 I giorni sussurrano ai giorni
 Le notti che parlan di Te

[V2]
 Tutto ciò che hai creato
 Racconta la gloria di Dio
 Perfino il più grande silenzio
 Ci canta che Tu sei il Signore</lyrics>
</song>