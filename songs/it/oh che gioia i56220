<?xml version="1.0" encoding="UTF-8"?><song><author>ADI Media</author>
<hymn_number>1664</hymn_number>
<title>Oh che gioia!</title>
<lyrics>[V1]
 Oh che gioia! Gesù mi ha salvato
 Oh che gioia! Gesù mi liberò
 Oh che gioia! Gesù è il mio Pastore
 La mia luce, migliore amico per me

[V2]
 Per me, per te, per me, per te
 Gesù morì sulla croce
 Per me, per te, per me, per te
 Gesù risuscitò</lyrics>
</song>