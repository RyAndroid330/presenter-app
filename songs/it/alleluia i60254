<?xml version="1.0" encoding="UTF-8"?><song><author>Corrado Salmè</author>
<hymn_number>773</hymn_number>
<title>Alleluia</title>
<lyrics>[V1]
 Alleluia, Alleluia,
 Alleluia, Alleluia
 (2 volte)

[V2]
 Tu sei degno, Tu sei degno,
 Tu sei degno, degno Tu sei
 (2 volte)

[V3]
 Tu sei santo, Tu sei santo,
 Tu sei santo, santo Tu sei
 (2 volte)

[V4]
 Tu sei qui, Tu sei qui,
 Tu sei qui, qui in mezzo a noi
 (2 volte)</lyrics>
</song>