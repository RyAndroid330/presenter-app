<?xml version="1.0" encoding="UTF-8"?><song><author>Tiziana Scala</author>
<hymn_number>4088</hymn_number>
<lyrics>[V1]
 Mi roca, mi salvacion
 Rey eterno de la gloria
 Padre inmenso
 Principe de paz Tu eres
 Dios potente
 Concejero admirable

[V2]
 Solo en Ti
 Hay salvacion
 Libertad y vida
 Tu nombre es potente
 Roca eterna
 Majestuoso, Rey de amor
 Mi roca y mi Salvador</lyrics>
<title>Roca Eterna</title>
</song>