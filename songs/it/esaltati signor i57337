<?xml version="1.0" encoding="UTF-8"?><song><author>Marcelo S. Rodriguez</author>
<hymn_number>2673</hymn_number>
<title>Esaltati Signor</title>
<lyrics>[V1]
 Esaltati Signor, innalzati Signor
 Oggi il Tuo popolo Ti vuole adorar
 Esaltati Signor, innalzati Signor
 Che tutti insieme, ad una voce
 Vogliamo esaltare Te
 Vogliamo esaltare Te

[V2]
 Veniamo ad adorare il nostro gran Signor
 Veniamo ad adorare il nostro gran Creator
 Offriamo sempre a Lui
 Sacrificio di lode e adorazione
 Esaltiamo solo Lui</lyrics>
</song>