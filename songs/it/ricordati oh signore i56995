<?xml version="1.0" encoding="UTF-8"?><song><author>Marcelo S. Rodriguez</author>
<hymn_number>2364</hymn_number>
<title>Ricordati oh Signore</title>
<lyrics>[V1]
 Ricordati, oh Signor
 Delle nazioni della terra, ricordati
 Che il Tuo favor e il Tuo amor
 Siano versati sopra il mondo
 Oh Signor
 Nella Tua bontà, ricordati</lyrics>
</song>