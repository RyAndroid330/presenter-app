<?xml version="1.0" encoding="UTF-8"?><song><title>Tu sei la vite</title>
<lyrics>[V1]
 Tu sei la vite, noi i Tuoi tralci
 Stringici forte a Te

[V2]
 Nel Tuo nome noi andremo
 E il Tuo nome proclameremo
 Ed il mondo riconoscerà
 Che hai il potere di guarire, di salvar</lyrics>
<author>Gospel Sound Singers</author>
<hymn_number>928</hymn_number>
</song>