<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>396</hymn_number>
<author>Evan Schoombie</author>
<title>Poiché sei l'eccelso</title>
<lyrics>[V1]
 Poiché sei l'eccelso, Signor
 Su tutta la terra
 Tu sei innalzato al di sopra di ogni dio.

[V2]
 Poiché sei l'eccelso, Signor
 Su tutta la terra
 Tu sei innalzato al di sopra di ogni dio.

[V3]
 Noi innalziamo Te
 Noi innalziamo Te
 Noi innalziamo Te
 Oh Signor!
 (2 volte)</lyrics>
</song>