<?xml version="1.0" encoding="UTF-8"?><song><author>Albino Montisci</author>
<hymn_number>2422</hymn_number>
<title>Popolo mio</title>
<lyrics>[V1]
 Canterò per te, popolo mio
 Affinché la gioia sgorghi dal tuo cuore!
 Affinché la morte resti fuori
 Affinché la morte resti fuori

[V2]
 Pregherò per te, popolo mio
 Affinché il tuo spirito sia saldo
 Affinché tu sia l'immagine del vero Re!
 Affinché tu sia l'immagine del vero Re!</lyrics>
</song>