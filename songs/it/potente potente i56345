<?xml version="1.0" encoding="UTF-8"?><song><author>ADI Media</author>
<hymn_number>1777</hymn_number>
<title>Potente potente</title>
<lyrics>[V1]
 Potente, potente, io so ch'è potente
 Sì, il mio Signor potente a liberar
 Potente, potente, io so ch'è potente
 Sì, il mio Signor potente a liberar

[V2]
 Guarì le malattie, liberò dal grand'error
 La vista diede al cieco, lo zoppo sollevò
 Potente, potente, io so ch'è potente
 Sì, il mio Signor potente a liberar</lyrics>
</song>