<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1521</hymn_number>
<author>Marcelo S. Rodriguez</author>
<title>Manda la pioggia</title>
<lyrics>[V1]
 Manda la pioggia, versa il Tuo Spirito
 Scenda oggi il Tuo fuoco
 Sana le ferite, restaurami Signor

[V2]
 Manda la pioggia, la rugiada del Tuo amor
 Cambia la mia vita, restaurami Signor</lyrics>
</song>