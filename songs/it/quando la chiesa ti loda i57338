<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2674</hymn_number>
<author>Marcelo S. Rodriguez</author>
<lyrics>[V1]
 Quando la chiesa Ti loda
 Quando la chiesa Ti adora
 Scenderà dal cielo il Tuo poter

[V2]
 Quando i Tuoi figli Ti lodano
 Quando i Tuoi figli Ti adorano
 Scende la Tua presenza qui</lyrics>
<title>Quando la chiesa ti loda</title>
</song>