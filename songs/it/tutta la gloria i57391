<?xml version="1.0" encoding="UTF-8"?><song><author>Marcelo S. Rodriguez</author>
<hymn_number>2722</hymn_number>
<lyrics>[V1]
 Tutta la gloria, tutto l'onore
 E la nostra lode, siano al Re
 Tutta la gloria, tutto l'onore
 E la nostra lode, siano al Re

[V2]
 Siam venuti ad esaltarti
 E cantarti, oh Signor
 Offrendoti con gioia
 Lode con il cuor</lyrics>
<title>Tutta la gloria</title>
</song>