<?xml version="1.0" encoding="UTF-8"?><song><author>Centro Evangelico Modenese</author>
<hymn_number>1712</hymn_number>
<lyrics>[V1]
 Ogni giorno, ho bisogno
 Ho bisogno di Gesù.
 Camminando e parlando
 Nel pensare e giocare
 Ho bisogno di Gesù.</lyrics>
<title>Ogni giorno ho bisogno di Gesù</title>
</song>