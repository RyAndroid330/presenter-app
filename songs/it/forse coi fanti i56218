<?xml version="1.0" encoding="UTF-8"?><song><title>Forse coi fanti</title>
<lyrics>[V1]
 Forse coi fanti mai non potrò marciar
 Né artiglieria sparar
 Né sui cavalli, in aeroplan volar
 Ma son soldato del Signor!
 Son soldato del Signor
 Son soldato del Signor</lyrics>
<author>ADI Media</author>
<hymn_number>1662</hymn_number>
</song>