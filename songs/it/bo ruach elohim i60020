<?xml version="1.0" encoding="UTF-8"?><song><author>Corale di Palmi</author>
<hymn_number>561</hymn_number>
<lyrics>[V1]
 Vieni, Spirito Santo, vien;
 vieni e riempici ognor,
 perché noi Ti bramiamo qui.
 Mostra la Tua grazia ancor.
 Vieni, Spirito, riempi i nostri cuor.

[V2]
 Baruch haba, baruch haba,
 Ruach Elohim
 Baruch haba, baruch haba,
 vieni, o Spirito!</lyrics>
<title>Bo Ruach Elohim</title>
</song>