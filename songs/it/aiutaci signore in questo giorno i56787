<?xml version="1.0" encoding="UTF-8"?><song><title>Aiutaci Signore in questo giorno</title>
<lyrics>[V1]
 Aiutaci Signor in questo giorno
 Aiutaci Signor in questo giorno
 E fa' sentire in noi la Tua presenza

[V2]
 Battezzaci Signor in questo giorno
 Battezzaci Signor in questo giorno
 E fa' sentire in noi il Tuo fuoco

[V3]
 Batti a Dio le mani, alleluia
 Batti a Dio le mani, alleluia
 Batti a Dio le mani, alleluia
 Batti a Dio le mani, alleluia</lyrics>
<hymn_number>2176</hymn_number>
<author>Cristo è la Risposta</author>
</song>