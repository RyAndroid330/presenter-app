<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>607</hymn_number>
<author>ADI Media</author>
<title>Il segreto è</title>
<lyrics>[V1]
 Il segreto è vivere giorni felici
 E senza ansietà, guardare al domani
 Il segreto è tutto nel confidare
 Solamente in Dio
 Nell'amor suo per me</lyrics>
</song>