<?xml version="1.0" encoding="UTF-8"?><song><author>Marcelo S. Rodriguez</author>
<hymn_number>2680</hymn_number>
<lyrics>[V1]
 Prezioso Dio
 Non ho altro nome più caro
 Io grido a Te
 Corri sempre in mio aiuto
 E mi rialzi Tu

[V2]
 Mi guardi attraverso Gesù
 Che versò il Suo sangue per me
 Per me, per me
 Che non ero degno del Tuo amor
 Ma per la Tua grazia son qui</lyrics>
<title>Prezioso Dio</title>
</song>