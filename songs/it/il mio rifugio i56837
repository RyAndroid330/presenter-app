<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2220</hymn_number>
<author>Insieme per Cristo</author>
<title>Il mio rifugio</title>
<lyrics>[V1]
 Signor, sei il mio rifugio
 Io vengo a Te
 Di Te ho un gran bisogno
 Perdonami, confido in Te

[V2]
 Sei la mia forza, oh Dio
 Mi rialzerai
 Sei il mio scudo, Gesù
 Mi aiuterai</lyrics>
</song>