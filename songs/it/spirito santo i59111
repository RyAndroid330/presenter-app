<?xml version="1.0" encoding="UTF-8"?><song><author>Morning Star Music</author>
<hymn_number>4288</hymn_number>
<lyrics>[V1]
 Spirito Santo
 Santo è il Tuo nome
 Riempi i nostri cuori
 Riempici di Te

[V2]
 Tu sei l'acqua viva
 Fonte che dà vita
 Riempici d'amore
 Vivi dentro me</lyrics>
<title>Spirito Santo</title>
</song>