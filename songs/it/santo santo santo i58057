<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Santo, Santo, Santo
 È il Signore Iddio
 L'universo è pieno
 Della gloria Sua
 Perché sei Santo
 Tu sei degno
 Santo, Santo
 Signore, noi T'adoriam</lyrics>
<title>Santo santo santo</title>
<author>Antonio Morra</author>
<hymn_number>3328</hymn_number>
</song>