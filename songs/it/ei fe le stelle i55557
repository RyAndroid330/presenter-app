<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1061</hymn_number>
<author>Denise Faro</author>
<title>Ei fe le stelle</title>
<lyrics>[V1]
 Ei fé le stelle e il sol
 Ei fece il mar e il ciel
 E le montagne ancor
 Ei fece me e te
 Ma io l'am di più
 Perché per me Gesù
 In sulla croce un dì per me morì</lyrics>
</song>