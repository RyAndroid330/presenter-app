<?xml version="1.0" encoding="UTF-8"?><song><time_sig>4/4</time_sig>
<title>Heilig für Immer</title>
<key>G</key>
<lyrics>[V1]
.G                   C       G
 Tausend Genrationen knien in Anbetung
.     Em          D           C
 sie singen, Alle Ehre sei dem Lamm
.G
 Und wer uns schon vorausging
.    C                 G
 und wer noch glauben wird
.        Em        D           C
 sie singen, Alle Ehre sei dem Lamm

[P1]
.  C
   (Jesus,) Dein Name ist höher
.  Em     D
   dein Name ist größer
.            Em               C
   und nichts reicht an dich heran
.       C
   Kein Thron, keine Herrschaft
.  Em    D
   kein Reich und keine Weltmacht
.  Em                        C Am
   nein, nichts reicht an dich heran

[C1]
.                  C        D
   Und der Himmel singt, heilig
.                  Bm       Em
   Alle Schöpfung singt, heilig
.                  Am       D
   Du bist hoch erhöht, heilig
.            G
   heilig für immer

[V2]
.G                        C          G
 Hat er dir vergeben und hat er dich erlöst
.      Em       D                  C
 Dann sing ihm dieses Lied für alle Zeit
.G
 Wenn er dich befreit hat
.    C           G
 und du zu ihm gehörst
.        Em     D               C
 dann sing ihm dieses Lied für alle Zeit
.        Em     D               C
 Wir singen dieses Lied in Ewigkeit

[C2]
.                  C        D
   Hör dein Volk, es singt, heilig
.                  Bm       Em
   dir, dem Herrn der Herrn, heilig
.                  Am       D
   denn du bist und bleibst heilig
.            G
   heilig für immer</lyrics>
<tempo>72 BPM</tempo>
<author>Chris Tomlin</author>
</song>