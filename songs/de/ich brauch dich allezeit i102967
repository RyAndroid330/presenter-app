<?xml version="1.0" encoding="UTF-8"?><song><author>Lowry, Robert (1826-1899), Hawks, Annie Sherwood (1836-1918)</author>
<key>D</key>
<lyrics>[V1]
.D
 Ich brauch Dich allezeit,
.   G             D
 Du gnadenreicher Herr!
.     A7            D
 Dein Name ist mein Hort,
.     A7        E7     A7
 Dein Blut mein Freudenmeer!

[V2]
.D
 Ich brauch' Dich,
.      A7
 o ich brauch' Dich,
.               D
 Jesus, ja, ich brauch Dich!
.    G              D
 Ich muß Dich immer haben:
.      A7    D
 Herr, segne mich!

[V3]
.D
 Ich brauch' Dich allezeit,
.     G               D
 Herr Jesus, steh mir bei,
.    A7             D
 daß ich bis in den Tod
.    A7     E7      A7
 Dir bleibe stets getreu.

[V4]
.D
 Ich brauch' Dich allezeit,
.   G             D
 in Freude und im Leid,
.                        D
 Du bist mein' Sonn' und Schild
.      A7  E7     A7
 jetzt und in Ewigkeit.

[V5]
.D
 Ich brauch' Dich allezeit,
.     G                D
 führ mich nur, wie Du willst;
.    A7             D
 ich harre auf Dein Wort,
.    A7    E7     A7
 das Du ja ganz erfüllst.

[V6]
.D                D
 Ich brauch' Dich allezeit,
.     G             D
 Herr Jesus, Gottes Sohn.
.    A7             D
 Bei Dir ererb' ich einst
.    A7     E7     A7
 des ew'gen Lebens Krön'.</lyrics>
<title>Ich brauch dich allezeit</title>
</song>