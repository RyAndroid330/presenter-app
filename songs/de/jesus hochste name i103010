<?xml version="1.0" encoding="UTF-8"?><song><title>Jesus Höchste Name</title>
<key>C</key>
<lyrics>[V1]
.  C              Am
 Jesus, höchster Name
.          Dm                 G  C G7
 Teurer Erlöser, siegreicher Herr
.  C                 Am
 Immanuel, Gott ist mit uns
.            Dm    G             C
 Herrlicher Heiland, lebendiges Wort

[C1]
.              F         G           C          Am
   Er ist der Friedefürst und der allmächtge Gott
.            F    G            C   C7
   Ratgeber Wunderrat, ewiger Vater
.            F        G                 C      Am
   Und die Herrschaft ruht auf seinen Schultern
.              F           G                 C
   Und seines Friedensreichs wird kein Ende sein</lyrics>
<author>Naida Hearn</author>
</song>