<?xml version="1.0" encoding="UTF-8"?><song><author>Makhanaim</author>
<lyrics>[V1]
.Em          Am      Em
 // Heilig. Heilig. Heilig. //

[V2]
.Am          D        Em
 Ja, Du bist Herr, Du bist Allmächtig
.Am           D         Em
 Du bist Herr. Bist Gott. Gott Allmächtig

[V3]
.E      D      A            E
 Der war. Und Der ist. Und Der kommen wird
.E      D      A            E
 Der war. Und Der ist. Und Der kommen wird

[V4]
.Em             Am       Em
 // Kadosch. Kadosch. Kadosch. //
.Am        D       Em
 Adonaj. Elohim. Cabaot.</lyrics>
<key>Em</key>
<title>Heilig Heilig Heilig Heilig</title>
</song>