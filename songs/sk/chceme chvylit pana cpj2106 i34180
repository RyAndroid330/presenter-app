<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>106</hymn_number>
<title>Chceme chvýliť Pána CPJ2106</title>
<lyrics>[V1]
.               G
 Chceme chvýliť Pána,
.               Em
 chceme Ho hneď z rána,
.        C            D
 po celý deň, po celý deň.
.G     Em    C      D       G
 Tebe, Pane, chválu vzdávať chcem.

[V2]
.               G
 Chceme spievať chvály,
.            Em
 i keď slnko páli,
.        C            D
 po celý deň, po celý deň.
.G      Em    C     D       G
 Pieseň radostnú ja spievať chcem.

[V3]
.           G
 Zaspievama vďaky,
.              Em
 keď sú čierne mraky,
.        C            D
 po celý deň, po celý deň.
.G     Em    C      D      G
 Tebe, Pane, chválu vdávať chcem.

[C1]
.               Em
   Po celý deň,  po celý deň,
.  C              D
    chváliť chcem, chváliť chcem,
.  G      Em   C   D   G
   svojho Pána chváliť chcem.</lyrics>
<key>G</key>
</song>