<?xml version="1.0" encoding="UTF-8"?><song><tempo>65</tempo>
<author>Janka Majdišová</author>
<title>V Getsemane</title>
<lyrics>[V1]
.         Am            Am/G
 V Getsemane keď bol na dne
.          Am/F        Am/E
 tak možno práve premýšľal
.           Dm         Dm/C
 Aj keď len ty to pochopíš
.          B          G
 tak sa to trpieť oplatí

[V2]
.        Am         Am/G
 A práve ty tu v úzadí
.          Am/F       Am/E
 tak veľmi v sebe zápasiš
.         Dm         Dm/C
 Či je láska len otázka
.         B           G
 ktorú ti nik neprezradí

[C1]
.           C        G
   Je tu tá láska ktorá vždy
.         Am                  F     G  C
   niesla vinu všedných dní a stroskotaní
.  Dm G   Am      D
   Je tu, oslávme ju
.          Dm C/E F G C
   Oslávme láaasku Ježiš

[V3]
.           Am               Am/G
 Keď bol na dne, viem, kvôli mne
.          Am/F          Am/E
 veď preto môžem dýchať, žiť
.           Dm       Dm/C
 Ja chválim Ťa a velebím
.          B          G
 že od tej lásky závisím

[C2]
.           C        G
   Je tu tá láska ktorá vždy
.         Am                  F     G  C
   niesla vinu všedných dní a stroskotaní
.  Dm G   Am      D
   Je tu, oslávme ju
.          Dm C/E F G C
   Oslávme láaasku Ježiš

[C3]
.           D        A
   Je tu tá láska ktorá vždy
.         Hm                   G     A  D
   niesla vinu všedných dní a stroskotaní
.  Em A   Hm       E
   Je tu, oslávme ju
.          Em   D G A D
   Oslávme lásku Ježiš</lyrics>
<key>Am</key>
</song>