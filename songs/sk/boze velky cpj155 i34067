<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>155</hymn_number>
<title>Bože veľký CPJ155</title>
<key>E</key>
<lyrics>[V1]
.E           H7
 Bože veľký, Kráľu nebies,
.E        H7    E
 Tvoj nám pokoj daj,
.E                 H7
 Vzhliadni na nás, biednych ľudí,
.E        H7   E
 dnes nás požehnaj,
.A             E
 v Tvojej ríši darov mnoho,
.H7               AE
 rozdeľ ich medzi nás.
.A                  E
 každý kto je tvoj, nech ti slúži,
.H7             E
 pokiaľ je ešte čas.

[V2]
.E           H7
 Ty si mocný víťaz ľudí,
.E   H7       E
 očistenie si dal,
.E            H7
 Krvou svojou nevinnou Ty
.E     H7       E
 osteň smrti si vzal.
.A            E
 Ty si platil nie peniazmi,
.H7                AE
 striebrom, ani zlatom.
.A            E
 Na tom kríži hrubom bolestnom
.H7            E
 platil si životom.</lyrics>
</song>