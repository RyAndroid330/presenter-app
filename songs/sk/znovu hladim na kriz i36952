<?xml version="1.0" encoding="UTF-8"?><song><title>Znovu hľadím na kríž</title>
<aka>Ježiš Môj pred Tvojou stojím obeťou</aka>
<lyrics>[V1]
 Ježiš Môj, pred Tvojou stojím obeťou
 Nechal si slávu, umrieť si šiel
 Teraz však ja žasnem ako máš ma rád
 // Tak stojím tu dnes ešte raz //

[C1]
   A znovu hľadím na kríž,
   kde si svoj život dal
   Som pokorený láskou,
   srdce zlomené mám, znovu ďakujem Ti,
   ďakujem, svoj život Ti dám

[V2]
 Najvyšší si teraz Ježiš na nebi
 Nebeský vládca raz budem tam stáť
 Teraz však ja žasnem ako máš ma rád
 // a chválu Ti vzdám ešte raz //</lyrics>
<presentation>V1 C V2 C</presentation>
</song>