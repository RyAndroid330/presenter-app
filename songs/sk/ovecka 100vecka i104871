<?xml version="1.0" encoding="UTF-8"?><song><author>Miro Jilo Šmilňák</author>
<hymn_number>1</hymn_number>
<title>Ovečka 100večka</title>
<key>C</key>
<lyrics>[C1]
.  C    F   G     C
    Ovečka stovečka, stratila sa nám
.  C    F   G     C
    Pán Ježiš povedal, ja ťa pohľadám

[V1]
.G
 Neskončíme v sieti
.C
 Na cestu nám svietiš
.G
 Neskončíme v jame
.B             F   G
 Keď Ťa v srdci máme.

[V2]
 V závejoch aj v búrkach
 Vždy sme v Tvojich rukách
 Neskončíme v jame
 Keď Ťa v srdci máme</lyrics>
<aka>Ovečka stovečka</aka>
</song>