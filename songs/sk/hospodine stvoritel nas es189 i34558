<?xml version="1.0" encoding="UTF-8"?><song><title>Hospodine, Stvoriteľ náš ES189</title>
<lyrics>[V1]
 Hospodine, Stvoriteľ náš,
 posväť tento nedeľný čas,
 prosíme Ťa v pokání,
 zmiluj sa nad nami!

[V2]
 Kriste, náš drahý Spasiteľ,
 všetkých ľudí verný priateľ,
 spas nás pre svoje rany,
 zmiluj sa nad nami!

[V3]
 Duchu Svätý, Posvätiteľ,
 naplň vierou celú cirkev,
 posväť kresťanské chrámy,
 zmiluj sa nad nami!

[V4]
 Pane Bože trojjediný,
 Otec, Syn, Duch nerozdielny,
 naveky zostaň s nami,
 zmiluj sa nad nami!</lyrics>
<presentation>V1 V2 V3 V4</presentation>
<hymn_number>189</hymn_number>
</song>