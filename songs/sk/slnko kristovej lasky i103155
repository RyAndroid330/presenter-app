<?xml version="1.0" encoding="UTF-8"?><song><title>Slnko Kristovej Lásky</title>
<lyrics>[V1]
 Slnko Kristovej lásky nech ožiari nás,
 oheň Svätého Ducha nech zapáli nás.

[C1]
   Nech netlejeme len,
   nech nezhasína deň,
   ten, v ktorom sa jeho meno oslavovať má.</lyrics>
<hymn_number>1</hymn_number>
</song>