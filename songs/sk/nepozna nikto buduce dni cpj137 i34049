<?xml version="1.0" encoding="UTF-8"?><song><title>Nepozná nikto budúce dni CPJ137</title>
<key>F</key>
<lyrics>[C1]
.  F       Bb    F
   Nepozná nikto budúce dni,
.                  C
   nikto len Ježiš Kristu,
.  F                    Dmi
   nepozná nikto budúce dni.
.  F       C7    F
   Pán Boh určil všetko.

[V1]
.                 Ami    Dmi
 Keď bez Teba som kráčal sám,
.F    C7
 Pane môj,
.    F             Ami     Dmi
 mne zajtrajšok sa strašný zdal,
.C7   F
 Pane môj,
.                Ami   Dmi
 no keď som Teba postretol,
.F    C7
 Pane môj,
.   F               Ami   Dmi
 si strach i smútok odňal môj,
.G7  C7 F
 Pa__ne môj.

[V2]
.                  Ami Dmi
 Od hriechov si ma očistil,
.F    C7
 Pane môj,
.  F             Ami  Dmi
 a večnosť si mi zasľúbil,
.C7   F
 Pane môj,
.                       Ami     Dmi
 viac nemám strach, veď nie som sám,
.F    C7
 Pane môj,
.   F               Ami   Dmi
 Ty vedieš ma, vždy pomoc mám!
.G7  C7 F
 Pa__ne môj!

[V3]
.                   Ami   Dmi
 Keď diabol chce ma zastrašiť,
.F    C7
 Pane môj,
.   F               Ami Dmi
 Ty stojíš pri mne, poradíš,
.C7   F
 Pane môj.
.                      Ami Dmi
 Len s Tebou chcem ísť životom,
.F    C7
 Pane môj,
.    F             Ami  Dmi
 Len s Tebou stále istý som,
.G7  C7 F
 Pa__ne môj.</lyrics>
<hymn_number>137</hymn_number>
<presentation>C 1 C 2 C 3</presentation>
</song>