<?xml version="1.0" encoding="UTF-8"?><song><title>Haleluja CPJ38</title>
<lyrics>[V1]
.    E         A
 Haleluja, Haleluja,
.E         C#mi
 putá zlámané,
.       F#mi  H7       E
 svitol zlatý deň slobody.
.    E         A
 Haleluja, Haleluja
.     E
 boje vyhrané,
.     F#mi      H7        E
 zvíťazil Ježiš som slobodný.

[V2]
.    E         A
 Haleluja, Haleluja,
.E           C#mi
 koniec otroctva,
.       F#mi   H7     E
 Pán ma k slobode povolal.
.     E          A
 Na nebesiach užívam
.         E
 už právo synovstva,
.     F#mi    H7         E
 takú mi Otec môj milosť dal.

[V3]
.    E         A
 Haleluja, Haleluja,
.E             C#mi
 dlh môj splatený,
.       F#mi   H7        E
 za mňa tiekla krv presvätá.
.    E         A
 Haleluja, Haleluja,
.       E
 Boh je zmierený,
.     F#mi       H7      E
 duša je kliatby už zbavená.

[V4]
.    E         A
 Haleluja, Haleluja,
.E           C#mi
 nemusím ísť sám,
.      F#mi  H7        E
 Ježiš vedie ma, vodca môj.
.     E             A
 Na Neho keď vždy a všade
.      E
 pevne spolieham,
.     F#mi      H7       E
 víťazstvom ukončí každý boj.

[V5]
.    E         A
 Haleluja, Haleluja,
.E           C#mi
 v nebi Otca mám,
.        F#mi    H7        E
 nech ma trebárs svet zavrhne,
.     E             A
 Jemu denne na modlitbách
.       E
 všetko vyznávam,
.      F#mi   H7       E
 srdce mi ostane radostné.

[C1]
.        H7
   Kdeže je peklo,
.        E
   Tvoje víťazstvo.
.          A
   Ty smrť strašlivá,
.  F#mi      H7
   kde osteň  tvoj?
.         E         A
   Srdce, ktoré Ježišovu
.       E    C#mi         F#mi
   obeť prijalo, z Božích rúk
.        H7     E
   ktože by vytrhol.</lyrics>
<key>E</key>
