<?xml version="1.0" encoding="UTF-8"?><song><title>Pane, smädní sme po Tebe BJB243 SK243</title>
<lyrics>[V1]
 /: Pane, smädní sme po Tebe,
 Pane, smädní sme po Tebe. :/

[V2]
 /: Nech táto oslava naplní ulice,
 chceme tancovať z lásky ku Tebe. :/

[V3]
 /: A všetko čo mám dám na oltár,
 svoj život nesiem pred Tvoju tvár. :/</lyrics>
<author>Steve Fee: „I am madly in love with You&quot;; Tomáš Mikletič</author>
<hymn_number>243</hymn_number>
</song>