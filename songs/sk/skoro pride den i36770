<?xml version="1.0" encoding="UTF-8"?><song><title>Skoro príde deň</title>
<lyrics>[V1]
 Skoro príde deň,
 keď sa zjaví slávy Kráľ,
 haleluja, haleluja,
 keď sa zjaví slávy Kráľ.
 Ó, haleluja!

[V2]
 Čakám na ten deň,
 keď sa zjaví slávy Kráľ,
 haleluja, haleluja,
 keď sa zjaví slávy Kráľ.
 Ó, haleluja!

[V3]
 Blíži sa ten deň,
 keď sa zjaví slávy Kráľ,
 haleluja, haleluja,
 keď sa zjaví slávy Kráľ.
 Ó, haleluja!

[V4]
 Teš sa na ten deň,
 keď sa zjaví slávy Kráľ,
 haleluja, haleluja,
 keď sa zjaví slávy Kráľ.
 Ó, haleluja!</lyrics>
</song>