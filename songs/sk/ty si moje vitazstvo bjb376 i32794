<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>376</hymn_number>
<author>Peter Čuřík</author>
<lyrics>[V1]
 /: Ty si moje víťazstvo,
 Ty si môj svätý prápor,
 stojíš v čele svojho vojska,
 Ježiš si Pán! :/

[V2]
 /: Tebe vzdávam všetku chválu,
 Tebe vzdávam všetku česť!
 Ty si hoden všetkej slávy,
 Ty ju vždycky budeš niesť. :/

[V3]
 /: Hľadám vždycky Tvoju tvár,
 vyznávam to bez zábran,
 žiadny nástroj proti mne
 sa nepodarí. :/</lyrics>
<title>Ty si moje víťazstvo BJB376</title>
</song>