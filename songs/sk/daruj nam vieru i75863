<?xml version="1.0" encoding="UTF-8"?><song><key>B</key>
<lyrics>[V1]
.G
 Daruj nám vieru,
.C
 daruj nám vieru,
.Em
 daruj nám vieru,
.D           C
 ktorá vrchy prenáša

[P1]
.  G
   Daruj nám vieru Kráľ,
.  C
   ísť tam kam zavoláš,
.  Em      D             C
   vravieť to, čo vravíš Ty

[P2]
   Daruj nám vieru Kráľ,
   ísť tam kam zavoláš,
   robiť to, čo robíš Ty.

[C1]
.  G           Em       D        C
   Aj cez oheň pôjdem a nepopáli ma.

[V2]
 Daruj nám nádej,
 daruj nám nádej,
 daruj nám nádej,
 ktorá bude nás viesť.

[C2]
   Aj cez oheň pôjdem a nepopáli ma

[V3]
 Daruj nám lásku,
 daruj nám lásku,
 daruj nám lásku.</lyrics>
<capo>4</capo>
<title>Daruj nám vieru</title>
<author>Marana Tha</author>
</song>