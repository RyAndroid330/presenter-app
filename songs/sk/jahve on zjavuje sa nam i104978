<?xml version="1.0" encoding="UTF-8"?><song><aka>Jahve Raffa Elohim, Medzi nami zjaví sa</aka>
<lyrics>[C1]
.  C      D         Hm
   Jahve, Raffa, Elohim,
.  Em      C       D
   Shaddai, Jireh, Adonai
.                  Em
   medzi nami zjaví sa.

[V1]
.Em
 Je cítiť,
.                     Hm
 Tvoju slávu na tomto mieste.
.               C
 Kde niečo veľké nastáva
.                     D
 nadprirodzené sa prebúdza.

[B1]
.  Em                             D
    Keď Ho chváliš, On zjavuje sa nám,
.                                C
   Keď naňho voláš, On zjavuje sa nám,
.                                C  D
   Keď Ho hľadáš, On zjavuje sa nám.

[B2]
.  Em                     D
    Jahve, Ty zjavuješ sa nám,
.                        C
   Jireh, Ty zjavuješ sa nám,
.                        C
   Raffa, Ty zjavuješ sa nám,
.  D
    Ty zjavuješ sa nám,</lyrics>
<key>C</key>
<title>Jahve On zjavuje sa nám</title>
<hymn_number>1</hymn_number>
<author>Godzone</author>
</song>