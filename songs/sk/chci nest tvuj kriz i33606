<?xml version="1.0" encoding="UTF-8"?><song><author>Karel Řežábek</author>
<tempo>Středně</tempo>
<lyrics>[C1]
   Chci nést svůj kříž,
   Tebe následovat,
   chci nést svůj kříž,
   tělo ukřižovat,
   chci nést svůj kříž,
   zemřít žádostem svým.

[V1]
 Zemřít hněvu, dráždění,
 zemřít druhých souzení,
 zemřít bratrů pomlouvání.

[V2]
 Zemřít všem svým představám,
 zemřít vlastním zásluhám,
 zemřít pýše a sobectví.

[V3]
 Zemřít, Tvojí cestou jít,
 zemřít, a tak zvítězit,
 zemřít, abych Tvůj život žil.</lyrics>
<title>Chci nést Tvůj kříž</title>
</song>