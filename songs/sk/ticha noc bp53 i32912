<?xml version="1.0" encoding="UTF-8"?><song><title>Tichá noc BP53</title>
<lyrics>[V1]
.G
 Tichá noc, svätá noc!
.Am     D    G
 Všetko spí, všetko sní,
.C                  G
 sám len Svätý bdie dôverný pár,
.C               G
 stráži dieťatko nebeský dar.
.Am     D       G    Em
 Sladký Ježiško spí, sní,
.G       D          G
 nebeský ticho spí, sní.

[V2]
 Tichá noc, svätá noc!
 Anjeli zleteli
 najprv pastierom podali zvesť,
 ktorá svetom dnes dáva sa niesť
 Kristus, Spasiteľ je tu,
 Tešiteľ sveta je tu.

[V3]
 Tichá noc, svätá noc!
 Nežná tvár, lásky žiar,
 božsky rozsieva v jasličkách tam
 bije záchranná hodina nám,
 v Tvojom zrodení Boh, Syn.
 Ježiško, Láska, Boh, Syn.</lyrics>
<key>G</key>
<hymn_number>53</hymn_number>
</song>