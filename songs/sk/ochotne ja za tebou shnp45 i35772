<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>45</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
<lyrics>[V1]
 Ochotne ja za Tebou
 kráčam, dobrý Pane môj,
 vkladám ruky v Tvoju dlaň,
 Ty veď ma k nebesiam.

[C1]
   Verne za Tebou
   kráčam, Pane môj,
   rád Ti srdce dám,
   v ňom vybuduj svoj chrám.

[V2]
 Slabý som a bezmocný,
 k dobrým činom neschopný,
 Ty však všetko môžeš, vieš,
 ó, to je blažené.

[V3]
 Nebezpečie z všetkých strán
 hrozí, Ty ma ostríhaj,
 nado mnou drž svoju dlaň,
 tak doveď k nebesiam.</lyrics>
<title>Ochotne ja za Tebou SHNP45</title>
</song>