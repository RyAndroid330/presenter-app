<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>406</hymn_number>
<lyrics>[V1]
 Viem, príde prebudenie aj k nám,
 viem, príde prebudenie aj k nám.
 Na sever, na juh,
 východ, aj na západ.
 Viem, príde prebudenie,
 viem príde prebudenie,
 viem, príde prebudenie,
 príde aj k nám.</lyrics>
<title>Viem, príde prebudenie BJB406</title>
</song>