<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.      G             A7  D
 Svoje svieže, mladé ro__ky,
.       Ami    D7   G
 Kristu chceme zasvätiť,
.                C  Cmi
 neskúsené slabé kroky
.       G      D7  G
 v Jeho šľapaj položiť.

[V2]
.       G          A7 D
 Pre tú Jeho veľkú lásku,
.         Ami   D7     G
 v ktorej On sa skláňa k nám,
.                C  Cmi
 z srdca voláme celého:
.      G      D7    G
 sláva Kristu On je Pán!

[V3]
.    G            A7  D
 Ako On, tak i my chceme,
.        Ami     D7    G
 rozsiať radosť, tíšiť žiaľ,
.                C  Cmi
 aby ľudia v Jeho mene
.       G    D7    G
 vzdali Bohu hymnu chvál.

[C1]
.        G             D
   Dávaj pozor na hlas vodcu,
.        Ami  D7    G
   čo ti nebo pripravil,
.                        C  Cmi
   noc sa chýli k svojmu koncu,
.        G    Ami D7   G
   vydrž do posledných síl!</lyrics>
<title>Svoje svieže, mladé roky CPJ73</title>
<presentation>V1 C V2 C V3 C</presentation>
<hymn_number>73</hymn_number>
</song>