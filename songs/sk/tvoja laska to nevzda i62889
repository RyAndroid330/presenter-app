<?xml version="1.0" encoding="UTF-8"?><song><author>Lámačské Chvály</author>
<key>D</key>
<lyrics>[V1]
.G          D           A
 Vyššia ako vrchy predo mnou
 Silnejšia je ako moc hrobov
 Odoláva súdom aj zmenám
 Stále trvá, navždy trvá

[C1]
.     Hm
   Tvoja láska to nevzdá,
.  G         D          A
   nezradí ma,neujde odo mňa.
   Tvoja láska, Tvoja láska,
   Tvoja láska, Tvoja láska.

[V2]
.G         D          A
 Ona, Ona, Ona to nevzdá
 Plnosťou mi dušu napĺňa
 A ja strach už nikdy viac mať nemusím
 Stále verí, navždy verí

[B1]
.      Hm         G
   Ani smrť, či život,
.  D              A
   viem že nič ma neodlúči
.     Hm D     A
   od lásky tvojej
.        Hm          G
   A môj dlh, čo som mal,
.  D            A
   krvou tvojou splatený je
.  Hm        D     A
   má moc lásky tvojej.</lyrics>
<title>Tvoja láska to nevzdá</title>
</song>