<?xml version="1.0" encoding="UTF-8"?><song><title>Duša odľahčená</title>
<key>E</key>
<lyrics>[V1]
.E                                      B
 Na na na na na na na, na na na na na na na,
.g#                                    F#
 Na na na na na na na, moja duša odľahčená.

[V2]
.E
 Čakal som, čakal...
.B
 Hľadal som, hľadal...
.g#
 A Pán sa ku mne sklonil,
.F#
 Pán sa ku mne skláňa.

[V3]
.E
 Do Božích rúk vkladám
.B
 to, čo nemám v rukách ja,
.g#
 tak nachádzam pokoj,
.F#
 krok za krokom.

[V4]
.E
 Keď do Božích rúk vkladám,
.B
 to čo nemám v rukách ja,
.g#
 tak v srdci mám pokoj...
.F#
 viem, že som tvoj.</lyrics>
</song>