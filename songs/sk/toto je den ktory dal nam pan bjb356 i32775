<?xml version="1.0" encoding="UTF-8"?><song><title>Toto je deň, ktorý dal nám Pán BJB356</title>
<lyrics>[V1]
 /: Toto je deň, ktorý dal nám Pán,
 radujme sa zaznej pieseň chvál. :/

[C1]
   /: Jasaj v Pánovi! :/

[V2]
 /: Chváľme Pána, On je prítomný,
 On je našich chvál hodný. :/</lyrics>
