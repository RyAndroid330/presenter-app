<?xml version="1.0" encoding="UTF-8"?><song><presentation>1 C 2 C 3 C</presentation>
<hymn_number>145</hymn_number>
<title>Život môj CPJ2145</title>
<key>E</key>
<lyrics>[V1]
.E                    H7
 Život môj bol slza a bôľ,
.                  E E7
 ťarchu niesol som sám.

[V2]
.E                       H7
 Vládol v duši prekliaty hriech,
.                 E E7
 nástroj smútku a rán.

[V3]
.E                      H7
 On mi káže: odhoď tiaž vín,
.                E E7
 krásny pokoj ti dám.

[C1]
.  A                 E
   Radosť mi vrátila Golgota,
.  H7              E E7
   našiel ma lásky Pán.
.  A                 E
   Radosť mi vrátila Golgota,
.  H7       E    E7
   Golgota, Golgota.
.  A                 E
   Radosť mi vrátila Golgota,
.  H7
   našiel ma Ježiš,
.      E
   môj Pán.</lyrics>
</song>