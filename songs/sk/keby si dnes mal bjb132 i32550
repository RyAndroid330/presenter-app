<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>132</hymn_number>
<author>Salvador</author>
<title>Keby si dnes mal BJB132</title>
<lyrics>[V1]
 /: Keby si dnes mal
 aspoň takú malú vieru,
 vrchy by si prenášal. :/

[V2]
 /: Povedal by si
 tomuto vrchu:
 Presuň sa, presuň sa. :/

[V3]
 /: A vrch by sa presunul,
 presunul, presunul,
 v mene Pána Ježiša,
 Ježiša, Ježiša. :/</lyrics>
</song>