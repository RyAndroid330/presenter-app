<?xml version="1.0" encoding="UTF-8"?><song><title>Ja nad hviezdami CPJ105</title>
<key>D</key>
<lyrics>[V1]
.D
 Ja nad hviezdami
 v nebi Otca mám,
.    A7         D
 Haleluja, Otca mám.
.A7    D
 S ním verne kráčam
 navzdor hriechu tmám,
.        A7       D
 všetkým zlám, nástrahám.
.G
 Ja v nebi Otca mám,
.       D         A7      D
 ó, Haleluja, Haleluja, Otca mám,
.   G
 ja v nebi Otca mám,
.       D         A7         D
 ó, Haleluja, Haleluja, Otca mám.

[V2]
.D
 Ja v nebesiach
 u Otca domov mám,
.    A7          D
 Haleluja, domov mám,
.A7 D
 a  šťastný som,
 veď za ním ponáhľam,
.         A7       D
 s ním sa tam stretnúť mám.
.G
 Ja v nebi domov mám,
.       D         A7      D
 ó, Haleluja, Haleluja, domov mám,
.   G
 ja v nebi domov mám,
.       D         A7          D
 ó, Haleluja, Haleluja, domov mám.

[V3]
.D
 Tú cestu domov
 ukázal mi Pán.
.    A7            D
 Haleluja, Kristus Pán,
.A7 D
 On predišiel nás
 k nebies výšinám,
.      A7      D
 pripraviť miesto nám.
.G                          D         A7      D
 Ja v nebi Pána mám, ó, Haleluja, Haleluja, Pána mám,
.   G
 ja v nebi Pána mám,
.       D         A7         D
 ó, Haleluja, Haleluja, Pána mám.</lyrics>
<hymn_number>105</hymn_number>
</song>