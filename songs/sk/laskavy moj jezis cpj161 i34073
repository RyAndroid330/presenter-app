<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>161</hymn_number>
<presentation>1 C 2 C 3 C</presentation>
<title>Láskavý môj Ježiš CPJ161</title>
<lyrics>[V1]
.F           C7
 Láskavý môj Ježiš,
.         F
 žitia ideál,
.Bb            F
 sám sa ku mne kloníš,
.C7           F
 Boh si môj a Pán.

[V2]
.F              C7
 Mám ťa v srdci svojom,
.              F
 mám ťa vrúcne rád,
.Bb            F
 vládneš tam pokojom,
.C7           F
 vyliečiš môj pád.

[V3]
.F            C7
 Mám ja domov pravý,
.            F
 mám otčinu, mám.
.Bb           F
 Pripravil ju verným
.C7           F
 Spasiteľ môj Pán.

[C1]
.  F             C7                   F
   Ty si pre mňa všetkým, lásku si mi dal,
.  Bb          F       C7          F
   zaznieva mi v srdci pieseň plná chvál.</lyrics>
<key>F</key>
</song>