<?xml version="1.0" encoding="UTF-8"?><song><title>Ó, ó, ó, ó, tak dobrý je náš Pán</title>
<lyrics>[V1]
 /:Ó, ó, ó, ó,
 tak dobrý je náš Pán,:/
 Ó, ó, ó, ó,
 tak dobrý je náš Pán,
 nezabudni,
 čo pre Teba vykonal.

[V2]
 On pomáha Ti stále,
 tak dobrý je náš Pán,
 On dáva novú nádej,
 tak dobrý je náš Pán,
 On sprevádza ťa stále,
 tak dobrý je náš Pán,
 nezabudni,
 čo pre Teba vykonal.</lyrics>
