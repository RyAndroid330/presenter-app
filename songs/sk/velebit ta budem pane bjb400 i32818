<?xml version="1.0" encoding="UTF-8"?><song><author>Richard Čanaky</author>
<hymn_number>400</hymn_number>
<lyrics>[V1]
 Velebiť Ťa budem, Pane,
 Hospodin a Kráľ môj,
 chváliť Teba, Boha,
 Spasiteľa svojho.

[V2]
 Ďakovať Ti budem, Pane,
 Hospodin a Kráľ môj,
 chváliť Teba, Boha,
 Spasiteľa svojho.

[V3]
 Tebe spievať budem Pane,
 Hospodin a Kráľ môj,
 chváliť Teba, Boha,
 Spasiteľa svojho.</lyrics>
<title>Velebiť Ťa budem, Pane BJB400</title>
</song>