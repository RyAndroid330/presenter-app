<?xml version="1.0" encoding="UTF-8"?><song><author>Danka Vráblová</author>
<hymn_number>88</hymn_number>
<lyrics>[V1]
 /: Iba tí sa vznášajú
 na perutiach ako orly,
 ktorí očakávajú na Teba,
 Hospodin. :/

[V2]
 /: Očakávam na Teba,
 Hospodine na Teba! :/

[V3]
 /: Nezomdlievam keď bežím,
 neustávam keď chodím,
 nadobúdam novej sily
 od Teba, Hospodin. :/</lyrics>
<title>Iba tí sa vznášajú BJB88</title>
</song>