<?xml version="1.0" encoding="UTF-8"?><song><title>Ráno, celý den</title>
<lyrics>[C1]
   Ráno, celý den,
   andělé nade mnou bdí,
   můj Pane,
   ráno, celý den,
   andělé nade mnou bdí.

[V1]
 Když probouzím se
 v nový den,
 andělé nade mnou bdí,
 můj Pane,
 s Tebou jdu a šťastný jsem,
 andělé nade mnou bdí.

[V2]
 Samota mne netíží,
 andělé nade mnou bdí,
 můj Pane,
 nebojím se obtíží,
 andělé nade mnou bdí.

[V3]
 Když je večer a jdu spát,
 andělé nade mnou bdí,
 můj Pane,
 nemusím se zlého bát,
 andělé nade mnou bdí.</lyrics>
<presentation>C V1 C V2 C V3 C</presentation>
</song>