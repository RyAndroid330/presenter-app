<?xml version="1.0" encoding="UTF-8"?><song><presentation>C V1 C V2 C V3 C</presentation>
<hymn_number>62</hymn_number>
<lyrics>[C1]
.  D                 G
   Nechcem v kúte stáť,
.  D          G
   do neba sa smutne dívať,
.  D              G
    dary stále brať,
.  D             G        Em
   perlu pri tom v rukách skrývať.
.  D         G
    Túžim oázou byť
.          A7
   v púšti všedných dní.

[V1]
.Em           Gm6        Hm
 Dlaňou stierajúcou slzy
.              Gm6
 z tvári strápených,
.Em                         Gm6
  piesňou, ktorá pomáha žiť
.                 G A7
 v tieni všedných dní.

[V2]
.Em               Gm6        Hm
 Chcem byť slovom vysloveným
.               Gm6
 Bohom v chvíli zlej,
.Em                   Gm6
  ukazovať novú nádej
.             G A7
 cesty zajtrajšej.

[V3]
.Em           Gm6         Hm
 Rozdať túžim vôkol krásu,
.             Gm6
 ktorú Boh mi dal,
.Em                           Gm6
  v tieni kríža zostať skrytý,
.         G A7
 ukazovať naň.</lyrics>
<key>G</key>
<title>Nechcem v kúte stáť CPJ262</title>
</song>