<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
. E           F#m
 S Tebou chcem chodiť
.     C#m      A
 každú chvíľu, jednoducho s Tebou byť
. E        F#m
 Poznať, Ťa poznať
. A                              H
 vždy viac a viac Tvoju blízkosť zažívať

[V2]
 S Tebou sa chcem smiať
 voľne dýchať, slobodne Ti tancovať
 V Duchu a v Pravde
 srdcom Ťa uctievať, na Tvojom slove stáť

[P1]
.   E               F#m
   S Tebou to nie je zložité
.       A            H
   veď kto Ťa hľadá, ten nájde
.    C#m        E
   ja vedľa Teba deň čo deň byť
.   A               H
   jednoducho stále chcem

[C1]
.   E          F#m
   Jednoducho s Tebou
.   A            H
   jedným duchom s Tebou
.   C#m         H          A
   prvou láskou milovať Ťa chcem</lyrics>
<title>Jednoducho s Tebou</title>
<author>Marián Lipovský</author>
<presentation>V1 V2 P C C B</presentation>
<tempo>136</tempo>
</song>