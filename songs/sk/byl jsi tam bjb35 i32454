<?xml version="1.0" encoding="UTF-8"?><song><title>Byl jsi tam BJB35</title>
<lyrics>[V1]
 Byl jsi tam,
 když byl křižován můj Pán?
 Byl jsi tam,
 když byl křižován můj Pán?

[C1]
   Nezapomeň na tu chvíli,
   když Ho všichni opustili.
   Byl jsi tam,
   když byl křižován můj Pán?

[V2]
 Byl jsi tam,
 když bděl v Getsemanech sám?
 Byl jsi tam,
 když bděl v Getsemanech sám?

[V3]
 Byl jsi tam,
 když byl Petrem zapírán?
 Byl jsi tam,
 když byl Petrem zapírán?

[V4]
 Byl jsi tam,
 když byl Ježíš bičován?
 Byl jsi tam,
 když byl Ježíš bičován?

[V5]
 Byl jsi tam,
 když klesal pod tíhou ran?
 Byl jsi tam,
 když klesal pod tíhou ran?

[V6]
 Byl jsi tam,
 když na kříži skonal Pán?
 Byl jsi tam,
 když na kříži skonal Pán?

[V7]
 Byl jsi tam,
 když tak slavně z mrtvých vstal?
 Byl jsi tam,
 když tak slavně z mrtvých vstal?</lyrics>
