<?xml version="1.0" encoding="UTF-8"?><song><presentation>C V1 C V2 C V3</presentation>
<hymn_number>9</hymn_number>
<title>Evanjelium CPJ9</title>
<key>E</key>
<lyrics>[C1]
.  E  A    E   E  A    E
   Evanjelium, evanjelium.

[V1]
.H7
 Radostnú správu hlásame,
.E
 posolstvo spásy nesieme,
.A                               E
  zvesť, ktorá lieči bôľ i žiaľ,
 do srdca Pán Boh nám ju dal,
.H7
 nesieme správu radostnú,
.E
 dobrý to liek.
.E  A    E   E  A    E
 Evanjelium, evanjelium,
.E  A    E
 evanjelium.

[V2]
.H7
 Radostná krásna je to zvesť,
.E
 v srdciach ju môžme svetom niesť,
.A                           E
  tvoj život navždy premení,
 korunou slávy odmení,
.H7
 budeme spievať nadšení:
.E
 Haleluja.
.E  A    E   E  A    E
 Evanjelium, evanjelium,
.E  A    E
 evanjelium.

[V3]
.H7
 Zvesť svetom rýchle preniká,
.E
 premení srdce hriešnika,
.A                                 E
  preč z cesty metie hriech a žiaľ,
 plní nás všetkých žalmom chvál,
.H7
 tu všetkým radosť dáva Pán:
.E
 Haleluja.
.E  A    E   E  A    E
 Evanjelium, evanjelium,
.E  A    E
 evanjelium.</lyrics>
</song>