<?xml version="1.0" encoding="UTF-8"?><song><author>M. Wiesnerová, J. Rodáková</author>
<hymn_number>79</hymn_number>
<lyrics>[V1]
 Chceme spievať pieseň novú
 jak nás vyzval Dávid, kráľ.
 Krásnu pieseň Baránkovu
 a tak každý Pána chváľ.

[V2]
 Haleluja, haleluja,
 Ježiš zvíťazil,
 haleluja, haleluja,
 On ma dnes spasil.
 Haleluja, haleluja,
 svoje srdce som mu dal,
 haleluja, haleluja,
 Jemu spievam pieseň chvál.</lyrics>
<title>Chceme spievať pieseň novú BJB79</title>
</song>