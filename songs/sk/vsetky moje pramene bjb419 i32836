<?xml version="1.0" encoding="UTF-8"?><song><title>Všetky moje pramene BJB419</title>
<lyrics>[V1]
 Všetky moje pramene sú v Tebe,
 všetky moje pramene sú v Tebe.
 Si zdroj mojej sily,
 si zdroj mojej lásky.
 Si zdroj môjho požehnania,
 všetky moje pramene sú v Tebe.</lyrics>
<author>Danka Vráblová</author>
<hymn_number>419</hymn_number>
</song>