<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
<title>Ježiš, môj vládca CPJ58</title>
<key>G</key>
<lyrics>[V1]
.G
 Ježiš, môj vládca,
.Ami      D7
 stále ma ľúbi,
.G
 dal mi svoj život,
.Ami        D7
 s Ním ma vykúpil.
.H         Emi
 Svet nemá na mňa
.Ami    D7
 nijakú moc,
.Emi      A7   D7
 som Jeho vlastníctvom!

[V2]
.G
 Únavou som raz
.Ami     D7
 zapadol v hriechu.
.G
 Pán šiel však za mnou
.Ami        D7
 podať mi ruku,
.H          Emi
 vyniesť ma hore
.Ami       D7
 z hanby a bied,
.Emi      A7   D7
 som Jeho vlastníctvom!

[V3]
.G
 Srdce sa chveje
.Ami       D7
 preveľkou vďakou
.G
 v živote chcem byť
.Ami         D7
 Kristovým žiakom,
.H        Emi
 nedám sa hriechu
.Ami      D7
 zotročiť viac,
.Emi      A7   D7
 som Jeho vlastníctvom!

[C1]
.  G             A7mi D7
   Patrím už Ježišo___vi,
.                  G
   Pán Ježiš patrí mne,
.            E7     Ami  C#dim
   tak túžim zostať na veky,
.  G           D7     G
   on mi v tom pomôcť vie.</lyrics>
</song>