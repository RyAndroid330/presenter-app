<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1. Pán je môj Pastier nebeský,
 s ním núdzu nepoznám,
 // on k vodám tichým vodí ma
 a k sviežim pastvinám. //

[V2]
 2. Chce dušu moju občerstviť
 a verne ma vždy viesť
 // po ceste spravodlivosti
 pre svojho mena česť. //

[V3]
 3. Hoc pôjdem smrti údolím,
 však nemusím sa báť,
 // prút jeho vždy ma poteší,
 on pri mne bude stáť. //

[V4]
 4. Pred neprajníkmi bohato
 on stôl mi prestiera
 // a kalich vínom milosti
 mi štedro nalieva. //

[V5]
 5. Tá jeho milsoť nesmierna
 je lásky znamením,
 // v nej kotví viery istota,
 že budem bývať s ním. //</lyrics>
<title>Pán je môj Pastier nebeský SH227</title>
<hymn_number>227</hymn_number>
<presentation>V1 V2 V3 V4 V5</presentation>
