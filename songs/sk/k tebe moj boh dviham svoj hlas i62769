<?xml version="1.0" encoding="UTF-8"?><song><title>K tebe môj Boh dvíham svoj hlas</title>
<key>C</key>
<lyrics>[V1]
.Am         F                  C
 Len Tvoja láska, z prachu nás dvíha
.    G         Am
 do Tvojej slávy z temnoty dní
.          F
 Bremená lámeš,
.              C               G
 a v trápení síl dáš, uzdravuj nás

[C1]
.   Am
   K tebe Môj Boh dvíham svoj hlas,
.  F
   Tebe Môj Boh vzdávam chválu,
.  C
   K tebe Môj Boh dvíham svoj hlas,
.  G
   spievam Aleluja

[C2]
   Aleluja, aleluja, aleluja, spievam
   aleluja, aleluja, aleluja, aleluja

[V2]
 Putá si zlámal, oči otváraš,
 armáda Kráľa, dnes začína rásť.
 Smrť viac nemá moc,
 víťazstvo nám dal, náš živý Pán

[B1]
.            Am      F      C      G
   Chválou znie, Svätý, Svätý, Svätý
.              Am        F      C      G
   Tvoje meno znie, Svätý, Svätý, Svätý</lyrics>
