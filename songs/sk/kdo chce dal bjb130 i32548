<?xml version="1.0" encoding="UTF-8"?><song><author>Tomáš Novotný</author>
<hymn_number>130</hymn_number>
<presentation>C V1 C V2 C V3 C</presentation>
<lyrics>[C1]
   Kdo chce dál, ten musí cestou chval.
   Kdo chce dál, ten musí cestou chval.
   Všechno ať zní k Boží chvále,
   dneska, zítra a tak dále,
   kdo chce dál, ten musí cestou chval.

[V1]
 Mindráky a křivdy samý,
 city stokrát převoraný,
 zoufání nad vlastní povahou
 jsou slepou cestou...

[V2]
 Výhrady a připomínky,
 utíkání do vzpomínky,
 rozpaky nad církví Kristovou,
 jsou slepou cestou...

[V3]
 Starání a různý strachy,
 dostat byt a sehnat prachy,
 vzdychání nad situací zlou,
 jsou slepou cestou...</lyrics>
<title>Kdo chce dál BJB130</title>
</song>