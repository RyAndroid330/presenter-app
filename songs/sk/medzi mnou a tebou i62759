<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9</hymn_number>
<author>Dominika Gurbaľová</author>
<key>G</key>
<lyrics>[V1]
.  Em           C
 Nemusí z toho vzísť nič nové
.    G
 len nech v nás rastie
.    D
 to, čo už máme

[V2]
.Em               C
 Ak chceš vo mne nové vzklíčiť
.G          D
 nebudem sa brániť ničím

[C1]
.      Em
   Len medzi mnou a tebou
.  C               G
   ostane to, čo má
.    D                         Em
   A svet uvidí iba plod nášho života
.  C                         G     D
   svet uvidí iba plod nášho života

[B1]
.  G      D
   Láska, dôvera
.  Em      C
   láska, dôvera
.  G  D     Em  C
   Klíčiš vo mne</lyrics>
<title>Medzi mnou a tebou</title>
</song>