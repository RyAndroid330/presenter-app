<?xml version="1.0" encoding="UTF-8"?><song><title>Ďakujem za kríž Tvoj</title>
<key>A</key>
<lyrics>[V1]
 Biblický text: Zjavenie 5:8-14, Filipanom 2:9-11
 Tempo: 95

[V2]
. A         D  E  A
 Ďakujem za kríž Tvoj
. A            D   E  A
 za všetko, čo v Tebe mám
. A            E        F#m
 Zobral si môj strach a hriech
.   E     D  Bm     A/C#  E
 si láskavý, milosť dávaš nám

[V3]
 Ďakujem za lásku
 prebodnuté ruky, bok
 V Tvojej krvi umy ma, nech navždy som
 v Tvojom náručí, môj Pán!

[C1]
.   A         E    A         A/C#   D
   Baránok Ty sám, trón svoj v nebi máš
.   E    E/D     A/C#   D
   Kráľu náš, Ty vládni nám
.     D             E
   Ty láskou vládni nám!
   Nad všetkým si Pán, Ježiš, Boží Syn
   Len Ty si zomrel za náš hriech
   hoden si, náš Pán
   hoden si, náš Pán</lyrics>
<aka>za všetko čo v Tebe mám</aka>
<author>Darlene Zschech</author>
</song>