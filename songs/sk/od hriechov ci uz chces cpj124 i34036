<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>124</hymn_number>
<presentation>1 C 2 C 3 C 4 C</presentation>
<lyrics>[V1]
.F
 Od hriechov či už
 chceš byť slobodný?
.              C7  F
 Na kríž svoj upri zrak!
 Spasenie, voľnosť
 kynú z Golgoty,
.C7             F
 na Baránka len hľaď!

[V2]
.F
 Strápený keď si,
 žiaľom ranený,
.              C7  F
 na kríž svoj upri zrak!
 Zármutok tvoj On
 v radosť premení,
.C7             F
 na Baránka len hľaď!

[V3]
.F
 V hodine skúšok,
 v hriechu pálčivom
.              C7  F
 na kríž svoj upri zrak!
 Víťazstvo slávne
 nad zlom tá ti On,
.C7             F
 na Baránka len hľaď!

[V4]
.F
 Lepšie ho nikde
 nezrieš priateľa,
.              C7  F
 na kríž svoj upri zrak!
 Každého z hriechu
 vyslobodiť zná,
.C7             F
 na Baránka len hľaď!

[C1]
.                    C7
   Na kríž svoj upri zrak,
.                 FC7
   na Baránka len hľaď!
.  F      F7     Bb      Gmi
   Iba On sám ťa vykúpiť môže,
.  F       C7     F
   na Baránka len hľaď!</lyrics>
<key>F</key>
<title>Od hriechov či už chceš CPJ124</title>
</song>