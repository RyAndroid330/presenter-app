<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C          Dm
 Ježiš, syn tesárov
.C          D
 z mestečka Nazaret,
.F        Bb
 splodený z panny,
.   C        G
 no skutočný kráľ.
.C         Dm
 Smrti moc nemohla
.C       D
 zadržať Víťaza.
.F          Bb
 Vzkriesený vládne,
.    C         G
 nuž vrúcne Ho chváľ!

[V2]
.C        Dm
 Predivne hovoril,
.C       D
 vykonal zázraky,
.F        Bb
 Spasiteľ hriešnych,
.   C         G
 Ty milosť mi daj!
.C           Dm
 Srdca chrám obsaď mi
.C            D
 Duchom v ňom zavládni!
.F             Bb
 Z pravdy nech kvitne mi
.C       G
 slobody raj!

[C1]
.    F  C   G7       C
   Hosanna, Ježiš je živý!
.    F  C        G7      C
   Hosanna, dnes odpúšťa viny.
.    F  C       G7       C
   Hosanna, dar spasenia príjmi!
.    F  C   G7       C
   Hosanna, Ježiš je Pán!
.    F  C   G7       C
   Hosanna, Ježiš je Pán!</lyrics>
<title>Ježiš, syn tesárov CPJ285</title>
<hymn_number>85</hymn_number>
</song>