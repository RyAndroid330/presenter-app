<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 /: Hledám Tvoji tvář, Pane můj,
 hledám Tvoji tvář každý den.
 Po Tobě touží duše má,
 očekávám slovo Tvé. :/

[V2]
 /: Chci jít za tebou, Ježíši,
 cestou Tvou,
 chci jít za tebou, Ježíši, :/
 za Tebou.

[V3]
 /: Za Tebou, Pane můj,
 chci jít každý den,
 za Tebou, Pane můj, chci jít. :/</lyrics>
<title>Hledám Tvoji tvář BJB67</title>
<hymn_number>67</hymn_number>
<author>Martina Střítecká</author>
</song>