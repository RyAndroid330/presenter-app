<?xml version="1.0" encoding="UTF-8"?><song><title>Svätý, svätý</title>
<key>E</key>
<lyrics>[V1]
.E      H  E
 Svätý, svätý
.A            E/G#     H   H/D#
 svätý je náš Pán všemohúci

[C1]
.     A       H    A       H
   On bol, on je a príde k nám

[B1]
.            E        A        H
   Vyvyšujme  v tejto piesni chvál
.            E    A       H
   jeho meno  nad celú zem
.              E/G# A        H
   Zdvihnime hlas a vzdajme slávu
.      A     F#m          H
   len on je hoden piesne chvál</lyrics>
<author>Rieka Života</author>
<hymn_number>1</hymn_number>
</song>