<?xml version="1.0" encoding="UTF-8"?><song><title>Môj Pán ťa čaká CPJ263</title>
<lyrics>[V1]
.Em         C
 Môj Pán ťa čaká
.  D             Em
 a chce ti lásku dať.
.          C
 On sám ťa hľadá,
.   D           Em
 On má ťa stále rád.
.       C     Am    D
 V Jeho láske môžeš isť,
.       G           Em
 v Jeho pravde nový byť
.        D/Am  Am/H  H/Em
 a s Ním život čistý žiť.

[V2]
.Em           C
 Náš Pán vždy volá
.  D           Em
 a zmeniť túži nás.
.          C
 on chráni verne.
.   D          Em
 Je Láska plná krás.
.       C     Am    D
 V Jeho láske môžeš isť,
.       G           Em
 v Jeho pravde nový byť
.        D/Am  Am/H  H/Em
 a s Ním život čistý žiť.</lyrics>
<key>G</key>
<hymn_number>63</hymn_number>
</song>