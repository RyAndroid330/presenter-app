<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 V2</presentation>
<lyrics>[V1]
 On sám,hoden všetkých chvál,
 On sám, ako Pán a Kráľ,
 On sám, prišiel na zem,
 život svoj za nás dal.
 On sám, Otca opustil,
 On sám, seba zatratil,
 On sám, všetko stratil,
 aby nám život dal.

[C1]
   /: Tak ver,slabý v Ňom už silu má,
   biedny hojnosť prežíva,
   lebo Boh sa sklonil k nám,
   seba dal :/</lyrics>
<title>On sám, hoden všetkých chvál</title>
</song>