<?xml version="1.0" encoding="UTF-8"?><song><title>Dýchaj skrze mňa SK159</title>
<lyrics>[V1]
 Tempo: 78

[V2]
. A                G
 Dýchaj skrze mňa, mám sen
. D
 o mohutných chválach na celej zemi
. A                G
 Dýchaj skrze mňa, mám sen
. D
 o fontáne vďaky z úst zachránených
 Dýchaj skrze mňa, mám sen
 ako ťa každý v národe vzýva
 Dýchaj skrze mňa, mám sen
 ako ti všetko v meste spieva

[C1]
.   A        G
   Sen o prebudení
.     D
   o zástupoch voľných z otroctva hriechu
.   A          G
   Sen o prebudení
.   D
   o hlásaní Krista na každom rohu
   Sen o prebudení
   o zmierení otcov so svojimi synmi
   Sen o prebudení
   o zmenení krčiem na Božie domy</lyrics>
<key>A</key>
<tempo>78</tempo>
<presentation>V C V C</presentation>
<hymn_number>159</hymn_number>
<author>Marián Lipovský</author>
</song>