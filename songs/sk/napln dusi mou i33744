<?xml version="1.0" encoding="UTF-8"?><song><title>Naplň duši mou</title>
<lyrics>[V1]
 Naplň duši mou,
 naplň duši mou,
 přijď, ó Duchu svatý,
 naplň duši mou.

[V2]
 Vejdi s láskou svou...

[V3]
 Vejdi s mocí svou...

[V4]
 Dej mi pokoj svůj...

[V5]
 Dej mi radost svou...

[V6]
 Přijď a potěšuj...

[V7]
 Naplň duši mou...</lyrics>
</song>