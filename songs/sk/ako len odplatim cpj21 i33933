<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<title>Ako len odplatim CPJ21</title>
<key>E</key>
<lyrics>[V1]
.E
 Ako len odplatím
.              H7
 lásku Tvoju Pane,
 že si na kríži dal
.                E
 pribiť svoje dlane.
.      H7    E
 //  Pane, Pane. //

[V2]
.E
 Za mňa Boh na Teba
.                  H7
 úzkosť hroznú dopustil,
 musel si zavolať:
.                E
 Prečo si ma opustil?
.      H7    E
 //  Bože, Bože. //

[V3]
.E
 Už sa báť nemusím
.           H7
 súdu ani pekla,
 iste ma zachráni krv
.             E
 čo za mňa tiekla.
.      H7     E
 //  Verím, verím. //</lyrics>
</song>