<?xml version="1.0" encoding="UTF-8"?><song><title>Keď smútok morí CPJ107</title>
<lyrics>[V1]
.Ami                     DDmi   Ami
  Keď smútok morí, hlodá strach,
.                            E7
 myšlienky blúdia v čiernych tmách,
.Ami                      DDmi Ami
  šťastie ušlo jak plachá laň,
.         E    A
 Ježiš ti podá dlaň.

[V2]
.Ami                     DDmi Ami
  Nehľadaj radosť na pár dní,
.                      E7
 veď z Neho večná pramení.
.Ami                   DDmi  Ami
  Lásku a nádej nájdeš v ňom,
.          E     A
 Pán je ti priateľom.

[V3]
.Ami                       DDmi  Ami
  Pán všetky Tvoje hriechy zmyl,
.                    E7
 krvou ťa svojou vykúpil.
.Ami                   DDmi Ami
  On radosť všade rozseje,
.         E   A
 Ježiš ťa miluje.

[C1]
.  Dmi         G
    Prosím ťa, nebuď smutný,
.  E          Ami
   Jemu srdce daj,
.           E7   Ami
   On vráti duši raj,
.  Dmi         G
   šťastie zas príde,
.         E            Ami  Dmi
   keď na Jeho pozrieš kríž,
.             E7 Ami
   keď v Neho uveríš.</lyrics>
<key>A</key>
<hymn_number>107</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
</song>