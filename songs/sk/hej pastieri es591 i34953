<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>591</hymn_number>
<presentation>V1 V2 V3</presentation>
<lyrics>[V1]
 Hej, pastieri,
 počúvajte,
 čo anjel hlása: do Betlema sa ponáhľajte,
 narodeného Syna Božieho privítajte!

[V2]
 Poďme aj my,
 nemeškajme!
 Hľa, hviezda svieti,
 za ňou sa, deti,
 ponáhľajme,
 narodeného
 Syna Božieho
 privítajme!

[V3]
 Vitaj, milý
 Ježiško náš!
 Všetko, čo máme,
 z lásky Ti dáme:
 prijmi od nás
 tu pri jasličkách
 naše srdiečka
 na večný čas!</lyrics>
<title>Hej, pastieri ES591</title>
</song>