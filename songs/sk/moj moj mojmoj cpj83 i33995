<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.G
 Môj, môj, môj,môj
 Ježiš je môj,
.D             Ami
 keď som strápený,
.G
 aj keď veselý,
 môj, môj, môj, môj
 Ježiš je môj,
.D                G
 Ježiš je vždycky môj.

[V2]
.G
 Mám, mám, mám, mám
 Ježiša mám,
.D              Ami
 s Ním som blažený
.G
 a v Ňom spasený,
 mám, mám, mám, mám
 Ježiša mám,
.D              G
 Ježiša vždycky mám.

[V3]
.G
 Sám, sám, sám, sám
 s Ježišom sám,
.D           Ami
 tak často bývam,
.G
 keď sa modlievam.
 sám, sám, sám, sám
 s Ježišom sám,
.D               G
 s Ježišom často sám.

[V4]
.G
 Chcem, chcem, chcem, chcem
 Ježiša chcem,
.D                   Ami
 s Ním chcem vždy chodiť,
.G
 Jeho velebiť.
 Chcem, chcem, chcem, chcem
 Ježiša chcem,
.D              G
 Ježiša vždycky chcem.</lyrics>
<title>Môj, môj, môj,môj CPJ83</title>
<hymn_number>83</hymn_number>
</song>