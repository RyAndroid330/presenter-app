<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Rád Tě mám, ó Pane,
 velmi rád Tě mám,
 svou lásku Tobě vyznávám,
 jsi mi nejdražší.

[C1]
   Před Tebou stojím,
   srdce mám plné uzdravení,
   teď chci Ti říct,
   že Tě mám rád,
   po Tobě toužím,
   jsi život můj, mé spasení,
   Ježíši.</lyrics>
<title>Rád Tě mám BJB283</title>
<author>Jiřina Markovová</author>
<hymn_number>283</hymn_number>
</song>