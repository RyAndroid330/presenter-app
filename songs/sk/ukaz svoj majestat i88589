<?xml version="1.0" encoding="UTF-8"?><song><author>Timothy</author>
<title>Ukáž svoj majestát</title>
<key>C</key>
<lyrics>[V1]
.C                G           D
 Ó Pane túžim pri Tebe blízko stáť,
.C                G           D
 Ó Pane túžim hľadieť na tvoju tvár,

[V2]
 Nič menej než Ty, nič také nestačí,
 nič menej než Ty, nič nie je dosť dobrým.

[C1]
.  G
    Ukáž svoj majestát,
.  C
    zjav svoju vznešenosť,
.  Em
    Vyvýš sa nad nebo,
.  D
    nad celú zem.

[C2]
   Kým ti tu spievame,
   vykonaj svoje divy,
   rob medzi nami to,
   to čo chceš ty.</lyrics>
</song>