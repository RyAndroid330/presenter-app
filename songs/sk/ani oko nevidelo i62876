<?xml version="1.0" encoding="UTF-8"?><song><author>Lámačské Chvály</author>
<aka>Chvalim ťa</aka>
<key>G</key>
<lyrics>[V1]
.G       D   C     D
 Chválim ťa, Ježiš.
.    G                  D
 Ani oko nevidelo, ani ucho nepočulo,
.   C      D
 čo má Boh pripravené pre nás.
.    G D         C      D
 Pre tých, ktorí milujú,
.    G D         C       D
 pre tých, ktorí vzývajú meno Pána,
.    G D         C      D
 pre tých, ktorí uveria,
.    G D         C       D
 pre tých, ktorí chvália tvoje meno Pane.</lyrics>
<title>Ani oko nevidelo</title>
</song>