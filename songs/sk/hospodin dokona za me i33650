<?xml version="1.0" encoding="UTF-8"?><song><title>Hospodin dokoná za mě</title>
<lyrics>[C1]
   Hospodin dokoná za mě.
   Hospodin dokoná za mě.

[V1]
 Proto Tě budu chválit,
 Tvé jméno vyvyšovat,
 novou píseň tu mít,
 Tobě obětovat. protože ...

[V2]
 Proto Tě budu chválit,
 Tvé jméno vyvyšovat,
 a své nepřátele,
 Tvým slovem umlčovat.

[B1]
   [: Ty nikdy, neopustíš
   dílo, rukou Tvých. :]
   Hospodin dokoná za mě.</lyrics>
<tempo>Středně</tempo>
<author>Martina Střítecká</author>
<presentation>C V1 C V2 C C B</presentation>
</song>