<?xml version="1.0" encoding="UTF-8"?><song><title>Hosana Bohu na nebi</title>
<lyrics>[V1]
 Hosana, hosana, hosana Bohu na nebi,
 hosana, hosana, hosana Bohu na nebi.

[C1]
   Jméno slavíme Tvé,
   chválí Tě srdce mé,
   vyvýšen buď, ó Bože náš,
   hosana Bohu na nebi.

[V2]
 Sláva, sláva, sláva všech králů Králi,
 sláva, sláva, sláva všech králů Králi.</lyrics>
<tempo>Velmi rychle</tempo>
</song>