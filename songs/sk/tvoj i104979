<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
. G
 Získal si ma omámil
. Hm
 Tvojou láskou zachránil
. D
 Ja Tvojim som dnes
. A
 A Tvojim chcem byť navždy

[V2]
 Pre mňa si tvár znetvoril
 Krvou za mňa zaplatil
 Ja Tvojim som dnes
 A Tvojim chcem byť navždy

[C1]
.  D
   Ja som Tvoj
.  Hm
   Ja som Tvoj
.  G
   Milovaný
.  A
   Od vekov chcený

[C2]
   Ja som Tvoj
   Ja som Tvoj
   Nič ma nevytrhne
   Z Tvojej ruky

[B1]
.  G
   S posledným výdychom
.  A
   Vidím, že Ty si môj Boh
.  Hm
   Opona trhá sa v dvoje

[B2]
   S prúdom, čo vytryskol
   Škrupina srdca môjho
   So skalami puká, je tvoje

[B3]
.  G
   Tak vlož prsty do rán
.  Hm       A
    Vlož dlaň do boku
.  G
    A spoznaj, že som Pán
.  D             A
    Ja som Tvoj Pán a Boh

[B4]
   Tak vkladám prst do rán
   Vkladám dlaň do boku
   Vyznávam, že si Pán
   Ti si môj Pán a Boh</lyrics>
<key>Bb</key>
<title>Tvoj</title>
<capo>3</capo>
<author>Godzone</author>
<hymn_number>1</hymn_number>
</song>