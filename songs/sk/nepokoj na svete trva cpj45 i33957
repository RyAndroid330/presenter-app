<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.Em         Em7   Am Am7
 Nepokoj na svete trvá,
.D        D7     G   H7
 vojny sa nemôžu skončiť.
.Em     Em7     Am
 Istota o pomoc volá,
.C        H7        Em D7
 nenávisť slzy chce množiť.

[V2]
.Em           Em7  Am Am7
 Nepokoj v človeku hlodá,
.D           D7      G H7
 k pôžitkom, zábavám beží,
.Em         Em7       Am
 vyprahlosť dušu však bodá,
.C       H7        Em  D7
 nenájde pramienok svieži.

[V3]
.Em           Em7   Am  Am7
 Pokoj kto množí deň každý,
.D          D7      G    H7
 v sebe i v rodine, v práci,
.Em       Em7     Am
 ten bude blažený navždy.
.C          H7       Em  D7
 Boh náš ho požehnať rá__či.

[C1]
.      G                C   E7
   // &quot;Pokoj svoj dávam vám!
.  A          A7    D   D7
   Pokoj svoj dávam vám!
.  H7                 Em
   Iný než dáva tento svet&quot;,
.      D7           G
   tak svojim vraví Pán. //</lyrics>
<title>Nepokoj na svete trvá CPJ45</title>
<hymn_number>45</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
</song>