<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>434</hymn_number>
<presentation>V1 C V2 C V3 C V4 C</presentation>
<lyrics>[V1]
.D    A      D     A
 Večerné keď zvony znejú,
.D    H7 G A7  D
 duša moja pamätaj,
.D     A    D    A
 za prijaté dobrodenia
.D   H7 G A7    D
 Ježišovi vďaku vzdaj!

[C1]
.  D A D A   Em A   D   A
   Haleluja! k Jeho chvále
.  D  A    D A Em A F#m
   zvučte, nebesá i zem,
.  Hm             A
   sláv Ho aj ty, duša moja,
.  D Am  H  Em D   A7 D
   veleb Ho za dnešný deň.

[V2]
 Večerné keď rastú tiene,
 na vlasť svetla pamätaj,
 kde je Kristus - Slnko jasné,
 len Jeho za svetlo maj!

[V3]
 Večerný keď pozdrav dávaš, na Ježiša pamätaj,
 On je s tebou vždy a všade,
 celý sa Mu odovzdaj!

[V4]
 Večerná keď hviezda vzíde,
 posledný deň v mysli maj,
 keď ti Ježiš - Hviezda ranná
 otvorí svoj večný raj!

[C2]
   Haleluja! k Jeho chvále,
   zvučte, nebesá i zem,
   sláv Ho aj ty, duša moja,
   veleb Ha za dnešný deň.</lyrics>
<key>D</key>
<title>Večerné keď zvony znejú, duša moja pamätaj ES434</title>
</song>