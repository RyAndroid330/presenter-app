<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>114</hymn_number>
<key>F</key>
<lyrics>[V1]
.F               C7
 Môj Bože, ja Ťa chválim,
.                 F
 môj Bože, mám Ťa rád,
.         F7    Bb
 že tak miluješ ľudí,
.        F       C7  F
 na kríž šiel si umierať.

[V2]
.F                  C7
 Len smrť mi právom patrí
.                  F
 za hriech môj veliký,
.         F7    Bb
 no láska Tvoja Božská
.       F      C7   F
 k sebe zve ma na veky.

[V3]
.F              C7
 Ó, Kráľu neba, zeme,
.                  F
 Ty sám sa skláňaš k nám
.        F7    Bb
 a dávaš práva synov,
.      F     C7     F
 večný život v tebe mám.

[V4]
.F                 C7
 Duch môj radostne plesá
.                F
 nad životom, čo mám,
.          F7   Bb
 že nie na zemi časnej,
.    F      C7    F
 ale v nebi domov mám.</lyrics>
<title>Môj Bože, ja ťa chválim CPJ114</title>
</song>