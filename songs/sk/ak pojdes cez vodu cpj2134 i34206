<?xml version="1.0" encoding="UTF-8"?><song><title>Ak pôjdeš cez vodu CPJ2134</title>
<lyrics>[V1]
.A         D
 Ak pôjdeš cez vodu,
.E            A
 iste s tebou som,
.        D
 oheň ťa nezraní
.E           A
 svojím plameňom.
.          D
 Poznám ťa po mene,
.E         A
 draho kúpený.
.          D   Hmi
 Neboj sa! Som verný,
.E       A
 nepremenný.

[V2]
.A        D
 Pohnú sa veľhory,
.E          A
 zakláti sa štít,
.           D
 nikto však milosti
.E          A
 nepretrhne niť.
.       D
 Pokoja dohodu
.E         A
 neroztrhá čas.
.         D   Hmi
 &quot;Na veky som s tebou&quot;,
.E         A
 počuj môj hlas!

[V3]
.A       D
 Ozdoba, koruna
.E            A
 v rukách Pánových!
.           D
 Žiadna moc človeka
.E            A
 nevyrve ťa z nich.
.         D
 Cisársky diadém
.E           A
 zdobí Božiu dlaň.
.        D  Hmi
 Životom Spasiteľ
.E        A
 zaplatil zaň.

[V4]
.A        D
 Drahokam základ je,
.E            A
 zafír miesto skál.
.          D
 Z rubínov postavím
.E             A
 múr tvoj, aby stál.
.          D
 Prevzácne kamene,
.E              A
 dlažba tvojich ciest,
.        D  Hmi
 pokoj a bezpečnosť,
.E       A
 zástava miest.

[C1]
.  A        D            E       A
   Čistým a spravodlivým pribúda síl,
.              D  Hmi E      A
   bez strachu pôjdu  tisíce míľ.</lyrics>
<key>A</key>
<hymn_number>134</hymn_number>
</song>