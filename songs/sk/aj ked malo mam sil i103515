<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.       C
 Aj keď málo mám síl
. G
 a cítim sa sám,
.    Am
 keď padám do hriechov
.     F
 cestu nenachádzam.
.    C
 Keď vôkol mňa
.       G
 tieň už rozkladá stan,
.       Am
 aj keď nepriateľ zúri,
.  F
 ja nezaváham.

[P1]
.        C            G
   Svoju záchranu mám hľadím na kríž,
.        Am                 F
   skoro zjav sa nám, skoro príď Ježiš.
.           C
   Z prachu dvíhaš ma sám,
.  G
   zmývaš môj hriech,
.        Am
   znovu cítim že mám
.        F
   Tvoju nádej aj smer.

[C1]
.        C         G
   Svoje srdce dám pred Tvoj trón,
.        Am             F
   život dávam len Tebe Ježiš môj Boh.
.         C               G
   Buď mi svetlom dní keď blúdim v tmách,
.         Am               F
   buď mi priateľom, chcem počuť Tvoj hlas
   (chcem počuť tvoj hlas).</lyrics>
<key>C</key>
<title>Aj keď málo mám síl</title>
<author>Richard Čanaky</author>
</song>