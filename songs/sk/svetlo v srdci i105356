<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1</hymn_number>
<title>Svetlo v srdci</title>
<lyrics>[V1]
.G
 Ja v srdci svetlo mám,
 nech stále vo mne plá.
.C
 Ja v srdci svetlo mám,
.                   G
 nech stále vo mne plá.
.G
 Ja v srdci svetlo mám,
.H7               Em
 nech stále vo mne plá.
.     G           A     G  C  G
 či je hmla, či je noc, či je tma.

[V2]
 Dal mi ho Ježiš sám,
 nech stále vo mne plá. (3x)
 či je hmla, či je noc, či je tma.

[V3]
 Kamkoľvek pôjdem len,
 nech stále vo mne plá. (3x)
 či je hmla, či je noc, či je tma.</lyrics>
<key>G</key>
</song>