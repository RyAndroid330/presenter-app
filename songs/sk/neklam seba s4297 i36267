<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>297</hymn_number>
<author>Kristína Royová, upr, Kristína Royová, upr.</author>
<presentation>V1 V2 V3 V4 V5</presentation>
<lyrics>[V1]
 Neklam seba, neklam seba!
 Ľudí klamať môžeš,
 Boha neoklameš.
 On zná vnútro tvoje,
 neklam seba!

[V2]
 Neživ pýchu, neživ pýchu!
 K závisti ťa zvodí,
 hnevy, sváry splodí.
 Od Krista sa vzdiališ,
 neživ pýchu!

[V3]
 Nesúď krivo, nesúď krivo!
 Akým súdom súdiš,
 takým trpieť musíš,
 keď Pán Ježiš príde,
 nesúď krivo!

[V4]
 Neutekaj, neutekaj!
 Za more hoc zájdeš,
 Boh ťa i tam nájde.
 Pred Ním skryť sa nedá,
 neutekaj!

[V5]
 Zmier sa s Bohom, zmier sa s Bohom!
 Podobný si tráve,
 môžeš skonať náhle.
 Zakosí smrť, zhynieš,
 zmier sa s Bohom!</lyrics>
<title>Neklam seba! S4297</title>
</song>