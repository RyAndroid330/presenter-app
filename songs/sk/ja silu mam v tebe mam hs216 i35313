<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>216</hymn_number>
<lyrics>[V1]
 Ja silu mám v Tebe mám,
 Ty si môj Boh, Ty i môj Pán,
 pokoj Tvoj ma sprevádza,
 deň čo deň silu mi dá,
 zmenil sa život môj,
 v radosť lásku a pokoj,
 tak volám, tak volám
 si môj Boh Spasiteľ a Pán.</lyrics>
<title>Ja silu mám v Tebe mám HS216</title>
</song>