<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>54</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
<lyrics>[V1]
.C        Am          F   G
 Je jedno meno, ktoré mám rád,
.      F        C  G
 v Ňom vstávam, usínam.

[V2]
.C        Am          F G
 Je jedno meno, ktoré trvá,
.    F       C   G
 nad všetkým víťazí.

[V3]
.C        Am         F G
 Je jedno meno, meno Ježiš,
.      F      C      G
 v Ňom plnosť svetla mám.

[C1]
.        C       G
   Nikdy nie som sám,
.      F     G
   On je môj štít,
.        C   G
   On ma vytrhol,
.        F     G
   v Ňom môžem žiť,
.          C  G
   z lásky ku mne mrel,
.     F   G
   ma vykúpil.
.  F             G   F
    Za mňa život dal,
.               G
   za mňa život dal.</lyrics>
<key>C</key>
<title>Je jedno meno CPJ254</title>
</song>