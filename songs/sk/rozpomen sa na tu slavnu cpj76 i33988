<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>76</hymn_number>
<presentation>V1 C V2 C V3 C V4 C</presentation>
<lyrics>[V1]
.G                        A7
 Rozpomeň sa na tú slávnu dobu,
.D7                      G
 v ktorej Boží oheň plápolal.
.                    A7
 Hrdinovia premáhali zlobu,
.D7                            G   G7
 Pán Boh svojim víťazstvo vždy dal.

[V2]
.G                     A7
 Vtedy kraje nezdobili chrámy,
.D7                        G
 Bohoslužieb predpis zmrazený,
.                          A7
 príbytok ten radosťou bol známy,
.D7                       G   G7
 Božou mocou, čistým nadšením.

[V3]
.G                       A7
 Na dedinke domy všedné, malé,
.D7                     G
 Svätým Duchom boli plnené,
.                          A7
 modlitby a piesne k Božej chvále,
.D7                    G  G7
 vysielali srdcia spojené.

[V4]
.G                        A7
 Pán Ježiš je ten istý, jak včera,
.D7                       G
 poslať oheň aj dnes silu má!
.                            A7
 S Bohom keď sa stretne naša viera,
.D7                  G  G7
 oživenia zázrak vykoná.

[C1]
.  C                    G
   Čakáme to prebudenie slávne,
.  A                      Ami
   ktoré aj náš život obnoví.
.  D7
    
.  G                        A7
   Naše prosby nikdy nie sú márne,
.  D7                      G
   zažať srdcia Boh je hotový.</lyrics>
<key>G</key>
<title>Rozpomeň sa na tú slávnu.. CPJ76</title>
</song>