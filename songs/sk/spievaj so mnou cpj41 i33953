<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[C1]
.  G                   D
   Spievaj so mnou haleluja,
.  Ami     D         G    D
   spievaj ďakovania žalm.
.  G                     D
   Z piesne vďačnej sila prýšti,
.  Ami    D         G
   chválu ďakovaním vzdám.

[V1]
.          D
 Za ten dažďov sivý čas,
.         G
 za slniečka úsmev, jas,
.       C
 za ten vzduch,
.   Ami           D
 čo zdarma dýchať smiem.

[V2]
.          D
 Za lúč lásky priateľa,
.         G
 čo ma denne ohrieva,
.      C
 za tú milosť,
.Ami        D
 ktorá nekončí.

[V3]
.         D
 Za ten zázrak vďačný som
.          G
 tam na kríži golgotskom,
.      C
 umrel Ježiš
.    Ami        D
     a ja život mám.

[V4]
.            D
 Za to, dnes že žije Pán,
.         G
 aby vždycky pri mne stál,
.         C
 z veľkej lásky
.    Ami          D
     nado mnou že bdie.</lyrics>
<title>Spievaj so mnou CPJ41</title>
<presentation>C V1 C V2 C V3 C V4 C</presentation>
<hymn_number>41</hymn_number>
</song>