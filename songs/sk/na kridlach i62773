<?xml version="1.0" encoding="UTF-8"?><song><capo>3</capo>
<title>Na krídlach</title>
<key>C</key>
<lyrics>[V1]
.Am
 Voláš ma tam,
.C
 kde tvoja sláva prebýva,
.G
 voláš ma tam,
.F
 kde láska sa neskrýva.

[V2]
.Am
 Silu mi dáš
.C
 aj keď nevládzem,
.G
 len s tebou chcem ísť
.F
 keď strácam už nádej.

[P1]
.  C  Dm Am F
   O__o__o__ooo

[C1]
.  Am
   Na krídlach lásky Pane,
.  C
   nesieš ma neprestajne,
.  G
   voláš ma do hĺbky,
.  F
   preskúmať krásu krás.

[B1]
.  Am
   Kým ruky zdvihnuté mám
.  F
   ja víťazím,
.  C
   kým pohľad na teba mám
.  G
   ja mám dosť síl.</lyrics>
<author>Espé</author>
</song>