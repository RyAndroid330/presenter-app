<?xml version="1.0" encoding="UTF-8"?><song><title>Buď pokoj branám tvým Jeruzaléme</title>
<lyrics>[V1]
 Buď pokoj branám tvým, Jeruzaléme,
 těm, kdo Boha milují.

[C1]
   Pro dům Hospodina,
   pro dům našeho Boha,
   pro dům Hospodina pokoj Tvůj hledám.</lyrics>
<tempo>Velmi pomalu</tempo>
<author>Lydie Votrubcová</author>
</song>