<?xml version="1.0" encoding="UTF-8"?><song><tempo>86</tempo>
<author>BCC Worship, Peter Lacho</author>
<title>Jediné miesto</title>
<lyrics>[V1]
 Biblický text: Žalm 46:1, Ján 16:33, Žalm 20:1
 Tempo: 85

[V2]
. G             Em
 Jediné miesto, kde pokoj nájdem
. C                        (Cm)
 tam, kde sa cítim v bezpečí
. G                  Em
 je pri Tebe, Ježiš, tam všetko nájdem
. C                        (Cm)
 Ty ma vždy o tom presvedčíš

[P1]
.        Em          Hm
   Už sa nemusím báť neistých dní
.      C              Am
   keď Ty vo mne prebývaš
.        Em                      Hm
   Teraz pevne smiem stáť, mojou istotou si
.   C             (Cm)
   Ježiš, všetko máš

[C1]
.   G  Hm   Em   Hm
   Imanuel, Imanuel
.    C             G/H             Am
   viem, že Ty sám nado mnou stále bdieš
.   G  Hm   Em   Hm
   Imanuel, Imanuel
.         C                      G/H
   v dave poznáš môj hlas, nikdy nezanecháš
.          Am
   pri mne budeš stáť</lyrics>
<key>C</key>
</song>