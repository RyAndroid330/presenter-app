<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[C1]
.     D             A
   // Za všetko kým si,
.         G        D
   za všetko čo činíš
.   G        D       A
   vyvyšujem Ťa, môj Pán //
.      D
   a Kráľ.

[V1]
. D          A         G     D
 Tvoja láska je lepšia ako život,
. G             D           A
 moje ústa Ťa chvália, môj Pán.
.D            A         G        D
 Tvoja milosť je väčšia nad nebesia
. G             D
 a Tvoja pravda siaha
.         A         D
 do najvyšších oblakov.

[V2]
 V Tebe život mám,
 lásku dávaš Ty sám.
 Vyvyšujem Ťa, môj Pán.
 V Tebe radosť mám,
 v Tebe pokoj nachádzam.
 Vyvyšujem Ťa, môj Pán a Kráľ.</lyrics>
<title>Za všetko kým si BJB426</title>
<author>Kamila Vlčková</author>
<hymn_number>426</hymn_number>
<presentation>C V1 C V2 C</presentation>
</song>