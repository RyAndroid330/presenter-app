<?xml version="1.0" encoding="UTF-8"?><song><title>Zpívejte Králi našemu</title>
<lyrics>[V1]
 Zpívejte Králi našemu všichni Jeho služebníci,
 kteří se Ho bojíte, malí i velicí.

[C1]
   Hosana, hosana, hosana, hosana, haleluja!

[B1]
   Jsi náš Král, dobrý Král,
   pro lásku svou život svůj jsi nám dal.</lyrics>
<author>Renata Ulmannová, Marek Čevela</author>
</song>