<?xml version="1.0" encoding="UTF-8"?><song><title>Dobrý si k nám</title>
<lyrics>[V1]
 // Dobrý si k nám,
 Tvoja milosť je naveky stála. //

[V2]
 Predrefrén:
 Nech každý národ, čo na zemi je,
 Nech každý ľud, každé pokolenie

[V3]
 Refrén:
 // Ti chválu vzdá,
 Halleluja, halleluja.
 Ti chválu vzdá,
 Dobrý si k nám! //

[V4]
 Bridge:
 // Dobrý si k nám,
 Každý čas.
 Každý čas,
 Dobrý si k nám. //</lyrics>
</song>