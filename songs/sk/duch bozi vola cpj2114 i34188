<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>114</hymn_number>
<title>Duch Boží volá CPJ2114</title>
<lyrics>[V1]
.G         D
 Duch Boží volá,
.A          D  D7
 počuj Jeho hlas!
.G         D
 Duch Boží volá
.A            D
 znovu, zas a zas.
.         G
 Otvor mu srdce,
.           Gm
 daj sa Ním viesť.
.           D
 Cez života skúšky
.A7         D
 On ťa bude niesť.

[V2]
.G         D
 Duch Boží volá
.A           D  D7
 pracovať aj dnes,
.G          D
 počúvaj ho srdcom,
.A             D
 tak ho poslúchneš.
.         G
 Modli sa konaj,
.             Gm
 čo chce tvoj Pán,
.              D
 neboj sa, veď väčšiu
.A7        D
 silu nepoznám.

[V3]
.G        D
 Naplnený Duchom
.A             D  D7
 nad zlom zvíťazíš.
.G          D
 Pošle ťa na roľu,
.A               D
 len sa pred Ním stíš.
.         G
 Potrebnú lásku,
.              Gm
 vernosť dá ti tiež.
.            D
 Nezatvrdzuj srdce!
.A7           D
 Pán ťa volá, bež!

[V4]
.G         D
 Duch Boží volá,
.A          D  D7
 počuj Jeho hlas!
.G         D
 Duch Boží volá
.A            D
 znovu, zas a zas.
.         G
 Otvor mu srdce,
.           Gm
 daj sa Ním viesť.
.           D
 Cez života skúšky
.A7         D
 On ťa bude niesť.</lyrics>
<key>D</key>
</song>