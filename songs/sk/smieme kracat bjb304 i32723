<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 /: Smieme kráčať vo svetle Božom,
 smieme kráčať vo svetle Božom. :/
 /: Smieme kráčať,
 kráčať, smieme kráčať,
 ó, smieme kráčať vo svetle Božom. :/

[V2]
 /: Chodíme vo svetle Pánovom,
 chodíme vo svetle Pánovom. :/
 /: Chodíme, chodíme,
 ó, chodíme vo svetle Pánovom. :/

[V3]
 /: Božiu lásku smieme prežívať,
 Božiu lásku smieme prežívať. :/
 /: Božiu lásku, lásku, Božu lásku,
 ó, Božiu lásku smieme prežívať. :/

[V4]
 /: We are marching in the light of God,
 we are marching in the light of God. :/
 /: We are marching,
 marching, we are marching,
 we are marching in the light of God. :/

[V5]
 /: Siyahamb' ekukhanyen' kwenkhos',
 siyahamb' ekukhanyen' kwenkhos'. :/
 /: Siyahamba, hamba,
 siyahamba, hamba,
 siyahamb' ekukhanyen' kwenkhos'. :/</lyrics>
<title>Smieme kráčať BJB304</title>
<hymn_number>304</hymn_number>
<author>African falksong: „Siyahamba&quot;</author>
</song>