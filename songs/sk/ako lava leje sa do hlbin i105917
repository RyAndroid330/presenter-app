<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1</hymn_number>
<author>Piar Music</author>
<aka>Volám Ježiš, Ja túžim splynúť</aka>
<lyrics>[V1]
.Cm                      Bb
 Volám Ježiš príď ku mne zas,
.     Gm           Ab
 nech láska pohltí nás.

[C1]
.      Cm   Bb
   Ako láva leje sa do hlbín,
.  Gm           Ab
   leje sa do hlbín.
.        Cm    Bb
   Tvoja láska každú pýchu borí
.  Gm               Ab
   a každé srdce tvorí znovu čistým. (2x)

[B1]
.           Cm               Gm
   Ja túžim splynúť, s Tebou splynúť,
.  Ab                  Eb
   jeden deň Láskou sa stať.
.           Cm               Gm
   Ja túžim splynúť, s Tebou splynúť,
.  Ab                 Eb
   naveky pred trónom stáť.</lyrics>
<key>Cm</key>
<title>Ako láva leje sa do hlbín</title>
</song>