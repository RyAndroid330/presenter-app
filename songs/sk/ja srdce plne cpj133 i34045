<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>133</hymn_number>
<key>G</key>
<lyrics>[V1]
.G             D7
 Ja srdce plné plesania
.      G         A D7
 chcem zložiť na oltár,
.                  G      Hmi
 že Boh mi prišiel v ústrety
.C D7            G
 a dal mi vzácny dar:
.    C            Hmi   E7
 mám nádej v Jeho zmierení,
.    Ami   D7     C
 mám slávu v Jeho spasení,
.D7       Ami         D7
 mám silu v Jeho žehnaní,
.   G      D7     G
 ja všetko v Bohu mám!

[V2]
.G                D7
 Kiež nezovšednie chvály hlas
.  G      A   D7
 a silu nestratí,
.                  G     Hmi
 nech pieseň vďaky pravdivú
.C   D7            G
 môj skutok spieva Ti:
.    C              Hmi   E7
 Mám nádej v Tvojom zmierení,
.    Ami   D7       C
 mám slávu v Tvojom spasení,
.D7       Ami           D7
 mám silu v Tvojom žehnaní,
.   G      D7     G
 ja všetko v Tebe mám.</lyrics>
<title>Ja srdce plné CPJ133</title>
</song>