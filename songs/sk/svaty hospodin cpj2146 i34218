<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>146</hymn_number>
<presentation>1 C 2 C 3 C</presentation>
<title>Svätý Hospodin CPJ2146</title>
<key>G</key>
<lyrics>[V1]
.      G
 Svätý Hospodin,
.     C
 moja sila, hrad,
.     D             G
 moja ochrana v súžení.
 Klam a ničomnosť
.       C
 človek môže dať,
.        D            G
 vernosť Božia sa nemení.

[V2]
.    G
 Ako zelená
.       C
 jabloň pri vode
.     D            G
 doby sucha sa nebojí.
 tak je dôvery
.        C
 rastiem na pôde,
.     D           G
 moje ovocie obstojí.

[V3]
.       G
 Ťarchu starostí,
.      C
 bremä námahy,
.      D           G
 nosiť nemusím ustatý.
 Oddych midlitby,
.      C
 Písma závlahy,
.        D             G
 šťastie v Otcovom objatí.

[C1]
.                    Ami
   Žehnnie, šťa rosa ranná,
.       D               G
   padá na hlavu mužov, žien,
.                  Ami
   dúfanie čo majú v Pána
.         D7            G
   ostrov istoty v mori zmien.</lyrics>
</song>