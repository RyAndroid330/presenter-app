<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8</hymn_number>
<presentation>V1 C V2 C V3 C</presentation>
<key>G</key>
<lyrics>[V1]
.G
 Keď si vyjdeš za večera,
.    D
     rozhliadni sa tmou,
.Ami
 rozhliadni sa
.D          G             D
 nekonečnou hviezdnou oblohou.
.G        E7
 Tisíce a milióny
.Ami
 svetov vidíš tam.
.D
 Ver, že všetky slávne riadi
.            D D5+
 jeden Boh a Pán!

[V2]
.G
 Večer keď sa poohliadaš
.    D
     jasnou oblohou,
.Ami
 či chceš tvrdiť,
.D            G           D
 že to všetko vzniklo náhodou?
.G          E7
 Uvedom si: každej hviezde
.Ami
 dráhu vymeral,
.D
 každú riadi udržuje
.            D D5+
 jeden Boh a Pán!

[V3]
.G
 Snáď len nechceš tvrdiť,
.      D
 že tá krásna príroda,
.Ami
 vznikla preto,
.D           G       D
 že sa stala iba náhoda...
.G           E7
 Zamysli sa, zanedlho
.Ami
 prídeš na to sám,
.D
 všetko to žepresne riadi
.            D D5+
 jeden Boh a Pán!

[C1]
.  G
   On je môjho žitia vodca,
.  D
   môjho srdca Pán.
.  Ami        D
   Spasiteľ a vykupiteľ,
.  G             D
   väčšieho nepoznám.
.  G           E7
   Bez Neho sa neobídem,
.  Ami
   On je radca môj,
.  D
   On je učiteľ môj dobrý,
.                G
   všetko vo všetkom.</lyrics>
<title>Keď si vyjdeš CPJ8</title>
</song>