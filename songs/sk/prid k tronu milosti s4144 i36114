<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 V2 V3</presentation>
<author>Christian H. Bateman, prel. Jana Nagajová, anon., zo spevníka „The Hymnal for worschip &amp; celebration&quot;, španielsky nápev</author>
<hymn_number>144</hymn_number>
<lyrics>[V1]
 Príď k trónu milosti,
 haleluja, amen,
 príď s piesňou radosti,
 haleluja, amen!
 Skloň svoje kolená,
 zlož svoje bremená,
 vstúp bránou spasenia,
 haleluja, amen!

[V2]
 Máš srdce pozdvihnúť,
 haleluja, amen,
 tiež prázdne dlane rúk,
 haleluja, amen!
 Náš Boh je lásky Kráľ,
 plán spásy dokonal,
 kríž o tom dôkaz dal,
 haleluja, amen!

[V3]
 Skús pridať vďačný hlas,
 haleluja, amen,
 chváľ Ho a vzývaj zas,
 haleluja, amen!
 Smieš mať, čo nemá svet!
 Vzácnejšej zvesti niet!
 Znie dnes a bude znieť,
 haleluja, amen!</lyrics>
<title>Príď k trónu milosti! S4144</title>
</song>