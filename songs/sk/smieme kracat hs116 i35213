<?xml version="1.0" encoding="UTF-8"?><song><author>African falksong: „Siyahamba&quot;</author>
<hymn_number>116</hymn_number>
<title>Smieme kráčať HS116</title>
<lyrics>[V1]
 /: Smieme kráčať vo svetle Božom,
 smieme kráčať vo svetle Božom. :/
 /: Smieme kráčať,
 kráčať, smieme kráčať,
 ó, smieme kráčať vo svetle Božom. :/

[V2]
 /: Chodíme vo svetle Pánovom,
 chodíme vo svetle Pánovom. :/
 /: Chodíme, chodíme,
 ó, chodíme vo svetle Pánovom. :/

[V3]
 /: Božiu lásku smieme prežívať,
 Božiu lásku smieme prežívať. :/
 /: Božiu lásku, lásku, Božu lásku,
 ó, Božiu lásku smieme prežívať. :/</lyrics>
</song>