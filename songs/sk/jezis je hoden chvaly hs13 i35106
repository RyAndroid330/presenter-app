<?xml version="1.0" encoding="UTF-8"?><song><title>Ježiš je hoden chvály HS13</title>
<key>D</key>
<lyrics>[V1]
.D(E)           A(H)   h(cis)          fis(gis)
 Ježiš je hoden chvály,Ježiš je hoden slávy,
.G(A)           D(E)        C(D)     A(H)
 Ježiš je hoden vďaky,On je Pán na veky.

[P1]
   On je ten svätý pravdivý,On je ten svätý jediný,
   On je ten svätý Boží,On je Pán na veky.

[C1]
.     D(gis)               h(cis) G(fis)              A(H)
   Je Kráľ a v sláve príde zas,je Kráľ zemou sa nesie hlas,
.  fis(gis)      h(cis)    C(fis)    A(H)
   že Kráľ Ježiš Kristuszvíťazil naveky.

[V2]
 Ježiš nám hriechy odpustil,Ježiš si svoj ľud vykúpil,
 Ježiš zasľúbil večný domovnám naveky.</lyrics>
<presentation>V1 P C V2 P C</presentation>
<author>Henry Smith</author>
<hymn_number>13</hymn_number>
</song>