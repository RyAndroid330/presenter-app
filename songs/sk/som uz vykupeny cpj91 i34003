<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>91</hymn_number>
<presentation>V1 C V2 C V3 C V4 C</presentation>
<key>A</key>
<lyrics>[V1]
.       A
 Som už vykúpený
 pravda predivná,
.        F#mi
 ne však bohatstvom,
.         H7
 pokladmi viem.
.E7     A     A7
 Svätou krvou
.           D
 duša mi je obmytá,
.         A      E     A
 o tom blažený hovoriť smiem.

[V2]
.       A
 Som už vykúpený
 iba z milosti,
.       F#mi
 všetky hriechy sú
.       H7
 zahladené.
.E7    A     A7
 Teraz túžim
.            D
 Bohu slúžiť v radosti,
.      A         E    A
 pokoj má srdce očistené.

[V3]
.       A
 Som už vykúpený
 písmo svedčí mi,
.         F#mi
 v službe diablovej
.        H7
 nemusím stáť,
.E7   A     A7
 dlhy platil
.              D
 Ježiš Kristus nevinný,
.         A            E      A
 ráčil bremeno z pliec mojich sňať.

[V4]
.       A
 Som už vykúpený
 vraví Svätý Duch,
.      F#mi
 dobrý Tešiteľ,
.          H7
 ochranca, Pán,
.E7   A     A7
 Jemu patrí
.             D
 vôľa, myseľ, zrak i sluch,
.   A             E       A
 On ma dovedie do večných brán.

[C1]
.            A7  D
   Draho som kúpený
.           A
   nie však bohatstvom,
.           H7E7
   pokladmi viem,
.         A     A7
   svätou krvou Kristovou
.      D     D#dim     A            E     A
   som zbielený, o tom s radosťou hovoriť smiem.</lyrics>
<title>Som už vykúpený CPJ91</title>
</song>