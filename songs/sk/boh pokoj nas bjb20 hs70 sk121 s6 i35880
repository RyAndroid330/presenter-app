<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>20</hymn_number>
<author>Kandela Groves: „He is our peace&quot;; J. Kremský</author>
<lyrics>[V1]
 Boh pokoj náš,
 zbúral nenávisť,
 hradbu vín.
 On pokoj náš,
 On pokoj náš.

[V2]
 Len pevne dôveruj,
 Ježiš pomôže rád,
 načo sa báť,
 On pokoj náš.</lyrics>
<key>C</key>
<title>Boh pokoj náš BJB20 HS70 SK121 S6</title>
</song>