<?xml version="1.0" encoding="UTF-8"?><song><capo>3</capo>
<title>Ty chceš viac</title>
<key>G</key>
<lyrics>[V1]
.         G            Am
 Ty chceš viac, než ja sám
.        G/H             C
 zdieľať so mnou srdce a tvár
.     Em      D/F#        C
 Vpísanú hlboko tú túžbu mám

[V2]
.         G            Am
 Ty chceš viac, než ja sám
.           G/H             C
 nech smiem počuť vždy tvoj hlas
.     Em      D/F#        C
 Vpísanú hlboko tú túžbu mám

[P1]
.           G
   Daruj mi počuť tvoje slová
.       Am
   oživ slovo tvojich slov
.            G/H
   V nich je tlkot tvojho srdca
.         C
   skrytá túžba tvojich snov

[C1]
.        Em                   C
   Svätý Duch, príď, pôsob v nás
.            G
   že nielen chcem
.         D
   ale aj konám to, po čom túžiš.

[B1]
.          Em
   Daruj mi nové srdce z mäsa
.          C
   chcem prejsť tvojou premenou
.          G
   Vpíš mi zákon do môjho srdca
.          D
   a budem živou tabuľou.</lyrics>
<author>Dominika Gurbaľová</author>
</song>