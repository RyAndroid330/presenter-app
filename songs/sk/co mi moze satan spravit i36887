<?xml version="1.0" encoding="UTF-8"?><song><title>Čo mi môže Satan spraviť</title>
<lyrics>[V1]
 Čo mi môže Satan spraviť,
 keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám.

[V2]
 Čo mi môže Satan spraviť,
 keď Teba, Pane, mám,
 ó, keď svojho Spasiteľa mám.

[V3]
 Ó, nie som sám,
 nie som sám.
 So mnou je môj Pán.

[V4]
 Ó, nie som sám,
 nie som sám.
 So mnou kráča Pán.

[V5]
 Čo mi môže človek spraviť,
 keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám.

[V6]
 Čo mi môže človek spraviť,
 keď Teba, Pane, mám,
 ó, keď svojho Spasiteľa mám.

[V7]
 Čo mi ešte viacej treba,
 keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám,
 ó, keď Teba, Pane, mám.

[V8]
 Čo mi ešte viacej treba,
 keď Teba, Pane, mám,
 ó, keď svojho Spasiteľa mám.</lyrics>
</song>