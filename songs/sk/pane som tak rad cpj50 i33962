<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 C V2 C V3 C</presentation>
<hymn_number>50</hymn_number>
<lyrics>[V1]
.D            Hmi
 Pane som tak rád,
.G         A
 že som už Tvoj.
.D            Hmi
 Pevne drž ma chráň,
.G         A
 keď hrozí boj.

[V2]
.D             Hmi
 Pane, keď som sám,
.G          A
 Ty pri mne stoj,
.D      Hmi
 cestou života
.G         A
 mi svetlo stroj.

[V3]
.D           Hmi
 Svoje srdce dnes,
.G      A
 Ti venujem,
.D        Hmi
 dávam na oltár,
.G      A
 čo dlhujem.

[C1]
.  G           A
   Pane mám Ťa rád,
.  D           Hmi
   lebo Ty mňa tiež
.  G             A
   svojou večnou láskou
.      D   Hmi
   miluješ.</lyrics>
<key>D</key>
<title>Pane som tak rád CPJ50</title>
</song>