<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>37</hymn_number>
<lyrics>[V1]
 Pôjdem, poôjdem, pôjdem
 za Ježišom, pokorne oddane
 chcem len za Ním ísť.

[V2]
 Pôjdem, poôjdem, pôjdem
 za Ježišom, kamkoľvek ma povedie
 chcem za Ním ísť.</lyrics>
<title>Pojdem, pojdem, pojdem SK37</title>
</song>