<?xml version="1.0" encoding="UTF-8"?><song><capo>2</capo>
<title>Ty dobrý si</title>
<key>G</key>
<lyrics>[V1]
.G
 Ja to chcem vykričať
 z vrcholov všetkých hôr
.C
 Si láska bezmedzná
 oplývaš štedrosťou
.Em
 Milosťou sprevádzaš
 plníš ma dobrotou
.G              D
 láskou ma premáhaš

[C1]
.       G
   A ja spievam ty dobrý si
   A ja skáčem, veď dobrý si
.       C
   a ja volám, že dobrý si
   ku mne dobrý si

[V2]
 Nikto a nič nie je
 zďaleka ako ty
 moria aj celá zem
 nám to len potvrdí
 A keď noc zastrie ma
 žiariš mi ako deň
 láskou ma premáhaš

[B1]
.            Am
   S chválou na perách
.         C
   srdcom prehlásim
.           G
   Ty dobrý si, dobrý si
.             Am
   V plači, v radosti
.        C
   život môj teší
.           G
   Ty dobrý si, dobrý si</lyrics>
<author>Timothy</author>
</song>