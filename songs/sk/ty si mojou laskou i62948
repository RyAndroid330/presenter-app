<?xml version="1.0" encoding="UTF-8"?><song><author>Rieka Života</author>
<title>Ty si mojou laskou</title>
<key>G</key>
<lyrics>[V1]
.            G
 Ty si mojou láskou,
.           C
 nemennou a stálou,
.             D
 mojím pevným miestom,
.             C
 na ňom môžem stáť.
.           G
 Tajomne ma dvíhaš,
.             C
 lásku vo mne skrývaš,
.               D
 keď si pri mne blízko,
.            C
 láska nesie ma.
.G        D        Emi
 ALELUJA, ALELUJA,  ALELUJA
.  C
 -V TEBE SPIEVAŤ CHCEM!
.             G
 Prekvapíš ma láskou,
.             C
 prenikneš ma krásou.
.             D
 Radosť prúdi zvnútra
.            C
 môjho srdca von.
.                 G
 Vždy, keď ku mne prídeš,
.                 C
 svetlom zaplavíš svet
.           D
 a ja cítim pieseň
.              C
 v mojom srdci rásť.</lyrics>
</song>