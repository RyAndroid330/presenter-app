<?xml version="1.0" encoding="UTF-8"?><song><title>Budeme slúžiť SK78</title>
<key>Em</key>
<lyrics>[C1]
.         Em
   Budeme slúžiť, Bohu živému,
.           Am             Em
   nechceme slúžiť, nikomu inému,
.           G            H7
   lebo náš Boh a len On sám,
.        C         Am
   On je živý Pán, ó-ó,
.  Em         H7
   On je živý Pán.

[V1]
.       Am     G     D
 Budeme skúšať čo je správne,
.       H7          Em
 budeme hľadať Jeho tvár,
.         Am     G     D
 lebo náš Boh má cesty priame,
.         H7
 a On nám na nich svetlo dá.</lyrics>
