<?xml version="1.0" encoding="UTF-8"?><song><title>Domov, domov BJB52</title>
<lyrics>[C1]
   Domov, domov, kráčame domov,
   tam, kde nás čaká vekov Pán.
   Tam sa vzdáva Bohu sláva,
   to je zem, tá je pravou otčinou!
   Domov, domov, kráčame domov,
   tam, kde nás čaká vekov Pán.
   Máme jasné ciele krásne,
   prečo nie, veď ideme za Tebou.

[V1]
 Rád, môj Pán,
 Ti svoje srdce dám,
 veď ma sám,
 nech viacej neklesám.</lyrics>
<hymn_number>52</hymn_number>
<author>S. Kráľ</author>
</song>