<?xml version="1.0" encoding="UTF-8"?><song><author>Jiří Jelínek</author>
<title>Ježíš, Boží syn</title>
<lyrics>[C1]
   Ježíš, Boží Syn,
   Ježíš mě zbavil vin

[V1]
 Ježíš je má skála,
 nebe je můj dům,
 má chvála zní k nebesům

[V2]
 Jemu patří sláva,
 Jemu patří dík,
 má chvála za spasení</lyrics>
</song>