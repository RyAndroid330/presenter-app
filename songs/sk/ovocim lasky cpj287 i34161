<?xml version="1.0" encoding="UTF-8"?><song><title>Ovocím lásky CPJ287</title>
<key>D</key>
<lyrics>[V1]
.Em                  Hm
 Ovocím lásky pravej ozajstnej
.Am                  D4  D
 rod ľudský nezásobí nás.
.G                      Hm
  Hoci kvet lásky často rozkvitne,
.A                       D
  skoro ho spáli hriechu mráz.

[V2]
.Em                     Hm
 Peter chcel umrieť aby miloval,
.Am                     D4 D
 na tvári majster úsmev má:
.G                         Hm
  „Iba tak príjmeš, Peter, lásky dar,
.A                    D
  ak umrie Láska bezodná.&quot;

[V3]
.Em                      Hm
 Pán Ježiš trpel, slávne z mŕtvych vstal,
.Am                   D4    D
 syn viery denne žije s Ním.
.G                        Hm
  Láska je Duchom v srdci rozliata,
.A                     D
  lebo sme novým stvorením.

[C1]
.                   G
   Správu radostnou mám:
.                   C
   Pán Boh láska je sám,
.                   D
   lásku prijímam v Ňom,
   vo mne rastie jej strom.
.  D             G
   Láska prináša plod,
.                  C
   Svätý Duch sýti knôt.
   Život plný je krás,
.               G
   Ježiš miluje nás.</lyrics>
<hymn_number>87</hymn_number>
<presentation>1 C 2 C 3 C</presentation>
</song>