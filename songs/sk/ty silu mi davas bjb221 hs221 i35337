<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Biblický text: Joel 3:2
 Tempo: 95

[V2]
.        C           Am
 Ostanem stáť, pevne stáť
.          Dm          G
 na Tvojom slove, Pane môj
.        C         Am
 s Tebou len, silu mám
.         D           G
 zdvihnúť štít, začať boj

[C1]
.             F   C
   Ty silu mi dávaš
.               F          C
   Ty láskou ma svojou napĺňaš
.                   F    C
   Tvoj pokoj smiem cítiť
.     G      C
   si úžasný Pán

[B1]
.          F                C
   Veď náš Boh bude bojovať za nás
.         Am         G    C
   vtedy, keď v Jeho vôli sme
.          F                  C
   Veď náš Pán vďačne potvrdí slová
.        Am       G     C
   ktoré s vierou vyznáme

[C2]
   Veď náš Boh bude bojovať za nás
   ako v údolí Jošafat
   Veď náš Pán, ten sa oslávi znova
   len skús vo viere pevne stáť</lyrics>
<key>C</key>
<aka>Ostanem stáť, pevne stáť, Zostanem stáť, pevne stáť</aka>
