<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>193</hymn_number>
<lyrics>[V1]
 Liturg: Pane, zmiluj sa!
 Zbor: Buď nám milostivý!
 Liturg: Kriste, zmiluj sa!
 Zbor: Zhliadni na nás, ľud svoj!
 Liturg: Pane, zmiluj sa!
 Zbor: Odpusť naše viny.
 Skloň sa k nám a vypočuj nás, Bože večný!</lyrics>
<title>Zbor: Buď nám milostivý! ES193</title>
</song>