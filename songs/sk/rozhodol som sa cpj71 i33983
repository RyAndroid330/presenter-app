<hymn_number>71</hymn_number>
<title>Rozhodol som sa CPJ71</title>
<key>C</key>
<lyrics>[V1]
.C
 Rozhodol som sa
 ísť za Ježišom,
.C7       F
 rozhodol som sa
.         C
 ísť za Ježišom,
.         Emi
 rozhodol som sa
.           Ami
 ísť za Ježišom,
.         C
 nehľadím späť,
.  G7     C
 nehľadím späť.

[V2]
.C
 Sám hoci budem,
 Ja pôjdem za ním,
.C7       F
 sám hoci budem,
.          C
 Ja pôjdem za ním,
.         Emi
 sám hoci budem,
.             Ami
 Ja pôjdem za ním,
.         C
 nehľadím späť,
.  G7     C
 nehľadím späť.

[C1]
.  C
   Svet som opustil,
   idem ku krížu,
.  C7        F
   svet som opustil,
.          C
   idem ku krížu,
.           Emi
   svet som opustil,
.             Ami
   idem ku krížu,
.            C
   nehľadím späť,
.    G7     C
   nehľadím späť.</lyrics>
</song>