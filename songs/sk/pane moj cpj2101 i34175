<?xml version="1.0" encoding="UTF-8"?><song><presentation>1 C 2 C 3 C</presentation>
<hymn_number>101</hymn_number>
<title>Pane môj CPJ2101</title>
<key>D</key>
<lyrics>[V1]
.     D   A         D
 Pane môj, Ty si mi určil,
.                       A
 po ktorých cestách mám ísť,
.    D   A       G       Gm
 aby som ku Tebe prišiel,
.      D      A      D
 mohol s Tebou večne byť.

[V2]
.    D  A            D
 Pomaly  sa cieľ môj blíži,
.                     A
 viem, že ma tam čaká Pán,
.      D  A        G     Gm
 že mi dá On novej sily,
.         D      A     D
 len nech k Nemu  dokráčam.

[V3]
.     D   A        D
 Za Tebou  ma nohy nesú,
.                  A
 za Tebou mi hodno íšť.
.       D  A        G      Gm
 Zmysel má prekonať cestu.
.      D     A        D
 Večne budem  s Tebou žiť.

[C1]
.  D
   Haleluja!
.  Em              A
   Viem, že si môj Pán,
.            D    A
   že môj si hrad.
.  D
   Haleluja!
.  Em             A
   Viem, dobre to viem,
.            D
   že máš ma rád.</lyrics>
</song>