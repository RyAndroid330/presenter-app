<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<presentation>1 C 2 C</presentation>
<title>Jas slnka i svit hviezd CPJ2126</title>
<lyrics>[V1]
.    E       C#mi
 Jas slnka i svit hviezd
.   F#mi  H7       E
 mi o Ňom rozpráva len.
.                 C#mi
 Keď počujem, šum mora,
.  F#mi  H7   E
 o Písme uvažujem.
.      A    H7
 Zeme, neba Kráľ!
.       E        C#mi
 Dar mi spasenia dal.
.      F#mi     H7
 Každý deň Jemu znie
.      E
 hymna chvál.

[V2]
.    E           C#mi
 Les čistý, kvet vonný,
.     F#mi   H7          E
 spev vtákov na stráňach hôr
.             C#mi
 mi vraví, že slávny
.  F#mi  H7      E
 a lásky plný je Boh.
.       A     H7
 Vystri vďaky dlaň!
.     E          C#mi
 Jeho ctiť neprestaň!
.    F#mi        H7
 Iba On prevziať smie
.       E
 chvály daň.

[C1]
.            A      H
   //  Život dôvery viesť,
.                  C#mi
   denne poslúchať zvesť,
.        F#mi     H7       E
   lásku Kristovu do sveta niesť. //</lyrics>
<key>E</key>
</song>