<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>78</hymn_number>
<lyrics>[V1]
 Chceme chváliť Tvorcu všetkého,
 všemocný Boh, hlas náš Teba ctí.
 Posvätené meno máš,
 posvätené meno máš.

[V2]
 Ty jediný Svätý,
 Otec, Duch a Syn,
 kráľov Kráľ a pánov Pán.
 Posvätené, posvätené,
 posvätené meno máš.</lyrics>
<title>Chceme chváliť Tvorcu všetkého BJB78</title>
</song>