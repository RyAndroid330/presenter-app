<?xml version="1.0" encoding="UTF-8"?><song><author>Koinonia Ján Krstiteľ</author>
<key>Am</key>
<lyrics>[V1]
.  Am              F
 Ty si jediný komu patriť chcem
. C              G
 Tebe svoj život dám.
. Am                F
 Ty si jediný pre koho žiť chcem,
. C            G
 iba Ty si môj Pán.

[V2]
.           Am              F
 // V tebe našiel som prameň života,
.   C            G
 spásu a silu mi dáš
 Tvoja láska viem, vždy ma povedie
 a dnes chválu Ti vzdám. //

[V3]
 // Bojovník si plný slávy,
 plný moci a plný lásky.
 Mocný víťaz nad všetkým si,
 nik nie je ako si Ty. //</lyrics>
<title>Bojovník</title>
</song>