<?xml version="1.0" encoding="UTF-8"?><song><title>Ó, príď, ó, príď, Emanuel ES14</title>
<key>Em</key>
<lyrics>[V1]
.Em                 Am D Em
 Ó, príď, ó, príď, Emanuel,
.    G           D Am Em
 tak túžobne lká Izrael
.  Am      G     D
 a očakáva nádej dňa,
.    Em         Am  D   G
 keď vôkol ťaží hriechu tma.
.   D       Hm     Am    Em
 Už blízko, blízko spásy deň,
.    G           D Am Em
 keď príde tvoj Emanuel.

[V2]
.   Em                Am  Em
 Ó, príď, ó, príď,Syn Dávidov,
.    C             D      Em
 zlo premôž láskou bezmedznou,
.   Am       Em       Hm
 premôž ho a vysloboď nás,
.      G              Am  Em
 z pút hriechu, drahý Mesiáš!
.   Hm      Em     F     Em
 Už blízko, blízko spásy deň,
.    C          D   Em
 keď príde tvoj Emanuel.

[V3]
 Ó, príď, ó, príď,Ty ranný svit,
 nás zo sna hriechov zobudiť,
 tmu hustej noci rozožeň,
 nech svitne nový jasný deň.
 Už blízko, blízko spásy deň,
 keď príde tvoj Emanuel.

[V4]
 Ó, príď, ó, príď, Syn človeka,
 Ty pravda Božia odveká.
 Ku večnej spáse veď svoj ľud
 a nedaj hriešnym zahynúť.
 Už blízko, blízko spásy deň,
 keď príde tvoj Emanuel.

[V5]
 Ó, príď, ó, príď, Ty kráľov Kráľ,
 by nám si spásu daroval,
 a keď bude posledný súd,
 nám, Kriste, milostivý buď!
 Už blízko, blízko spásy deň,
 keď príde tvoj Emanuel.</lyrics>
<hymn_number>14</hymn_number>
</song>