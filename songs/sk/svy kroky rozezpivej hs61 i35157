<?xml version="1.0" encoding="UTF-8"?><song><presentation>C V1 C V2 C V3 C V4 C</presentation>
<hymn_number>61</hymn_number>
<lyrics>[C1]
   Svý kroky rozezpívej,rozezpívej, rozezpívej,
   chválama rozezpívej,rozezpívej, rozezpívej.

[V1]
 Vzdejme Pánu díky, (echo)za vše, co nám dává, (echo)
 za vše, co nám bere, (echo)patří Pánu sláva. (echo)
 Vzdejme Pánu díky, (echo)že sa stará, aby (echo)
 nepropadli smrti (echo)Jeho lidé slabí. (echo)

[V2]
 Vzdejme Pánu díky, (echo)novou cestu klestí(echo)
 v době, která zná jen (echo)pomíjivé štěstí. (echo)
 Vzdejme Pánu díky, (echo)křížem přišel říci, (echo)
 jáj sem cesta, pravda (echo)osvobozujíci. (echo)

[V3]
 Vzdejme Pánu díky, (echo)zdroji pravé spásy, (echo)
 doutnající oheň, (echo)láska neuhasí. (echo)
 Vzdejme Pánu díky, (echo)jako děti Boží, (echo)
 že v člověku láska (echo)lásku stále množí. (echo)

[V4]
 Vzdejme Pánu díky, (echo)burcuje svým slovem, (echo)
 starý svět už umřel, (echo)my žijeme v novém. (echo)
 Vzdejme Pánu díky, (echo)mění dávné řády, (echo)
 Bůh už není v dálce, (echo)Kristus žije tady. (echo)</lyrics>
<title>Svý kroky rozezpívej HS61</title>
</song>