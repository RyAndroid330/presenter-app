<?xml version="1.0" encoding="UTF-8"?><song><author>anon./Joseph Mohr/John F. Young, Franz Gruber</author>
<hymn_number>35</hymn_number>
<lyrics>[V1]
 Tichá noc, svätá noc!
 Všetko spí, všetko sní,
 sám len svätý bdie dôverný pár,
 stráži dieťatko, nebeský dar.
 Sladký Ježiško spí, sní,
 nebeský ticho spí, sní.</lyrics>
<title>Tichá noc - koledy S435</title>
</song>