<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>302</hymn_number>
<author>Miroslav Kocholatý</author>
<title>Slunce Kristovy lásky BJB302</title>
<lyrics>[V1]
 Slunce Kristovy lásky ať ozáří nás.
 Oheň Svatého Ducha ať zapálí nás.
 Ať nedoutnáme jen,
 ať nezhasíná den,
 ve kterém se Jeho milost
 oslavovat má, oslavovat má.</lyrics>
</song>