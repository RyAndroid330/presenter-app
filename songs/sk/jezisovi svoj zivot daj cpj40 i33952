<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 C V2 C V3 C V4 C</presentation>
<hymn_number>40</hymn_number>
<key>C</key>
<lyrics>[V1]
.C             G'
 Ježišovi svoj život daj,
.               C
 pokiaľ si plný  síl.
.             G7
 Uletia roky, skoro
.                       C
 sa pred trón Boží postavíš.

[V2]
.C                G'
 Po šťastí túžiš, pokoji,
.                C
 v srdci len pustota...
.                   G7
 Pán na sto percent spokojí,
.                  C
 radostnú ti vieru dá.

[V3]
.C                 G'
 Svet tento na čas pobaví,
.                C
 drahú mu platíš  daň.
.                  G7
 Pán Ježiš hriechu pozbaví,
.                C
 vybudujev srdci chrám.

[V4]
.C              G'
 Ó, rozhodni sa Jemu žiť,
.                C
 než zvädne žitia kvet.
.                 G7
 Blažený, šťastný môžeš byť,
.                   C
 ponáhľaj sa k Nemu hneď!

[C1]
.  C               G'
   Krásny je život s Ježišom,
.                     C
   prečo bys brat môj lkal?
.                   G7
   Plnosť a hojnosť dáva On
.                  C
   rýchlo sa mu odovzdaj!</lyrics>
<title>Jezisovi svoj zivot daj CPJ40</title>
</song>