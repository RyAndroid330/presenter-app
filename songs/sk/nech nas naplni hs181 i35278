<?xml version="1.0" encoding="UTF-8"?><song><title>Nech nás naplní HS181</title>
<lyrics>[V1]
 Nech nás naplní
 kráľovstva Tvojho svätá moc,
 prídi k nám, prídi k nám.
 Ó, Duchu Svätý,
 pokoj, radosť, spravodlivosť
 v Tebe mám, v Tebe mám.

[C1]
   Príď, ó Svätý, príď (echo)
   Duchu Svätý, príď (echo)
   Duchu Svätý, príď sem k nám,
   Duchu Svätý, príď.</lyrics>
<hymn_number>181</hymn_number>
</song>