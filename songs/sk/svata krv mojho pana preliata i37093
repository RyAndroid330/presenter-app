<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 V2 V3 V4</presentation>
<key>C</key>
<lyrics>[V1]
.      C         G          C
 Svätá krv môjho Pána preliata,
.      F                  C
 svätá krv mňa a teba obmýva.

[V2]
.      F
 Stačí zmyť našu pýchu,
.      C          F
 stačí zmyť mnoho hriechov,
.      C      G           C
 svätá krv na kríži preliata.

[V3]
 Keby tvojich hriechov bolo na tisíc,
 keby tvojich hriechov bolo ešte viac.

[V4]
 On Ťa v náručí skryje,
 Jeho krv všetko zmyje,
 Jeho krv na kríži preliata.</lyrics>
<title>Svätá krv môjho Pána preliata</title>
</song>