<?xml version="1.0" encoding="UTF-8"?><song><title>Náš Boh - On sám BJB185</title>
<lyrics>[V1]
 Náš Boh - On sám
 sa rozhodol milovať teba aj mňa,
 náš Boh - On sám
 sa rozhodol, rozhodol

[V2]
 že Syna svojho jediného
 dá ako výkupné za náš hriech.
 Ducha svojho vložil do nás
 a tak nás naplnil svojou láskou.</lyrics>
<hymn_number>185</hymn_number>
<author>Danka Vráblová</author>
</song>