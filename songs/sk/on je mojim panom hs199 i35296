<?xml version="1.0" encoding="UTF-8"?><song><presentation>V1 C V2 C B</presentation>
<hymn_number>199</hymn_number>
<lyrics>[V1]
 On je mojím Pánom,
 mojou skalou, mojím žitím,
 všetko čo mám.

[V2]
 On je mojím Kráľom,
 je mojou spásou,
 mojou piesňou na perách.

[C1]
   A On ma pozná je mi tak blízko,
   On ma stráži nocou i dňom.
   On pri mne stojí aj v čase búrok.
   On ma ľúbi večnou láskou.

[B1]
   On je mojim Pánom.</lyrics>
<title>On je mojím Pánom HS199</title>
</song>