<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>69</hymn_number>
<title>Pane, vieru daj CPJ269</title>
<key>D</key>
<lyrics>[V1]
.      D         G     D
 Pane, vieru daj blúdiacim,
.                Em      A
 Pane, vieru daj všetkým nám,
.      D          G    D
 pevnú vieru daj, Bože náš,
.G  D     A     D
 ó, Pane, vieru daj!

[V2]
.      D         G     D
 Pane, lásku daj prosiacim,
.                Em      A
 Pane, lásku daj všetkým nám,
.      D          G    D
 vrelú lásku daj, Bože náš,
.G  D     A     D
 ó, Pane, lásku daj!

[V3]
.      D         G    D
 Pane, nádej daj trpiacim,
.                Em      A
 Pane, nádej daj všetkým nám,
.      D          G    D
 dobrú nádej daj, Bože náš,
.G  D     A     D
 ó, Pane, nádej daj!</lyrics>
</song>