<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>102</hymn_number>
<title>Pane, chcem Ťa oslavovať CPJ102</title>
<lyrics>[V1]
.D
 Pane, chcem Ťa piesňou oslavovať,
.A7
 Pane, chcem Ťa piesňou oslavovať,
.D
 Pane, chcem Ťa piesňou oslavovať
.A7                D
 za lásku k nám čo máš.

[V2]
.D
 Miluješ ma láskou nekonečnou,
.A7
 miluješ ma láskou nekonečnou,
.D
 miluješ ma láskou nekonečnou
.A7             D
 za to Ti vďaku vzdám.

[V3]
.D
 Odpúšťaš hriech ľudí tohto sveta,
.A7
 odpúšťaš hriech ľudí tohto sveta,
.D
 odpúšťaš hriech ľudí tohto sveta,
.A7            D
 lebo si láska sám.

[V4]
.D
 Na Golgote umieral si za mňa,
.A7
 na Golgote umieral si za mňa,
.D
 na Golgote umieral si za mňa,
.A7              D
 nemusím hynúť v tmách.

[V5]
.D
 Drahý Pane, Tebe patrí vďaka,
.A7
 drahý Pane, Tebe patrí vďaka,
.D
 drahý Pane, Tebe patrí vďaka,
.A7                D
 česť, chvála na veky.</lyrics>
<key>D</key>
</song>