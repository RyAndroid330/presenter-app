<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>187</hymn_number>
<presentation>V1 V2 V3 V4 V5 V6</presentation>
<lyrics>[V1]
 Bože, Otče dobrotivý,
 buď nám hriešnym milostivý,
 z hriechov svojich sa kajáme,
 zmiluj sa nad nami, Pane!

[V2]
 My sme hriešne pokolenie,
 iba trest zasluhujeme,
 nevernými sme dietkami,
 Bože, zmiluj sa nad nami!

[V3]
 Netresci nás v prísnom hneve,
 veď za nás na kríža dreve
 platil Syn Tvoj milovaný;
 Otče, zmiluj sa nad nami!

[V4]
 Synu Boží, Jezu Kriste,
 pre kajúcich útočište,
 lieč nás svojimi ranami,
 Pane, zmiluj sa nad nami!

[V5]
 Obeť si priniesol za nás,
 svojou smrťou splatil hriech náš,
 za ktorý sme trpieť mali,
 Kriste zmiluj sa nad nami!

[V6]
 Utešiteľ, Duchu Svätý,
 v láske hojný, prebohatý,
 teš nás, posväť a buď s nami,
 Bože, zmiluj sa nad nami!</lyrics>
<title>Bože, Otče dobrotivý ES187</title>
</song>