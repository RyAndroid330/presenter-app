<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.A       G               D
 Môžem vystúpiť na Pánov vrch
.                A
 či môžem na tom mieste stáť
.          G              D
 tam sa priblížiť sláve Božej
.                A
 prísť a spoznať Tvoju tvár

[P1]
.  Em           G
   Očisť srdce mi a
.              A
   naplň dlane sám
.  Em             G
   Lebo viem, že zem,
.                        A D
   kde chcem stáť, je svätá

[C1]
.  G              D    A  D
   Ja idem, Pane, za Tebou
.  G                D    A  D
   Len Teba hľadám, Pane môj
.  G              D    A
   Ja verím že ma premeníš
.      Em           G   D
   pri Tebe láskou horím

[C2]
   Ja hľadám Tvoju prítomnosť
   čo zahalí ma na večnosť
   Ja idem, Pane, za Tebou
.       Em          G            D  A
   Pri Tebe láskou horím, prichádzam

[B1]
.  A
   Túžim Ťa chváliť
.  G
   Túžim sa skláňať
.  D                 A
   Túžim byť len s Tebou</lyrics>
<title>Môžem vystúpiť</title>
<author>Rieka Života</author>
</song>