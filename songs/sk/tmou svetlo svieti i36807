<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.  D
 Tmou Svetlo svieti
 a život dáva,
 to Svetlo z nebies,
.                   Hm
 po ktorom túžbu ja mám.
. G             D
 Prosím, tiahni nás.

[V2]
 Je zvodná pýcha,
 tá dušu zviera,
 dušu tak biednu
 a hladnú po Svetle v tmách.
 Pravdu zasej v nás.

[V3]
 Úžasný Pán,
 svoj život dal.
 Nádherný Pán,
 tak miloval.

[V4]
 V srdci si pieseň
 o Tebe spievam,
 Tvoj Duch mnou prúdi.
 A ja tak túžim Ti riecť,
 Pane, rád Ťa mám.

[V5]
 Je mojou spásou, vo tme mi svieti,
 to meno Ježiš,
 pre ktoré v láske chcem žiť
 a pravde verný byť.

[V6]
 Úžasný Pán,
 svoj život dal.
 Nádherný Pán,
 tak miloval.

[V7]
 V srdci si pieseň
 o Tebe spievam,
 Tvoj Duch mnou prúdi.
 A ja tak túžim Ti riecť,
 prosím, tiahni nás.

[V8]
 Si mojou spásou, vo tme mi
 svietiš, to meno Ježiš,
 pre ktoré v láske chcem žiť
 a pravde verný byť.

[V9]
 Nádherný Pán,
 svoj život dal.
 Úžasný Pán,
 tak miloval.</lyrics>
<aka>Úžasný Pán</aka>
<title>Tmou svetlo svieti</title>
</song>