<?xml version="1.0" encoding="UTF-8"?><song><tempo>62</tempo>
<author>Lenka Kogutová, Barbora Ondrušková</author>
<title>Stačí tvoje áno</title>
<key>D</key>
<lyrics>[V1]
.D       A   Hm         G
 Moje dieťa, ja stále čakám
.D      A           Hm        G
 trpezlivo ti svoju náruč otváram
.D   A    Hm           G
 A dúfam, že nájdeš si čas
.D       A            Hm         G
 aby som mohol k tebe prehovárať zas

[C1]
.              D            A
   Stačí tvoje áno, tak poď za mnou
.            Hm          G
   miesto už prichystané máš
.                   D       A
   daj nech môžem s láskou, radosťou
.               Hm        G
   aj dnes tvoj život napĺňať

[V2]
 Stále stojím po tvojom boku
 a neopustím aj v tom môžeš mať istotu
 veľké veci pre teba prichystané mám
 tak dôveruj mi, nech s tebou naplním svoj plán

[C2]
.              D            A
   Stačí tvoje áno, tak poď za mnou
.            Hm          G
   miesto už prichystané máš
.                   D       A
   daj nech môžem s láskou, radosťou
.               Hm        G
   aj dnes tvoj život napĺňať

[B1]
.  D/F#              G
   Veľa pre mňa znamenáš
.                          Hm
   tak príď so všetkým, čo máš
.                            A
   ja chcem ťa s láskou prijímať
.                       D
   v dobrom aj zlom objímať
.                         G
   Si presne tým, kým máš byť
.                  Hm
   tvoj úsmev nemá nik
.                   A
   obetoval som všetko
.                     D  (A)
   by som ťa opäť stretol

[C3]
.              D            A
   Stačí tvoje áno, tak poď za mnou
.            Hm          G
   miesto už prichystané máš
.                   D       A
   daj nech môžem s láskou, radosťou
.               Hm        G
   aj dnes tvoj život napĺňať</lyrics>
<aka>Moje dieťa ja stále čakám</aka>
</song>