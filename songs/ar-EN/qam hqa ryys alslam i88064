<?xml version="1.0" encoding="UTF-8"?><song><title>qạm ḥqạ rỷys ạlslạm</title>
<lyrics>[V1]
 1- (qāma ḥaqaⁿ̃ạ qāma rayỉysu ạlsãlạm̊)
 halĩlūyā halĩlūyā ạlrãbũ qām̊

[V2]
 2- (wāltãlạmīdẖu rāảẘhu was̊ṭahum̊)
 walahum̊ qad̊ qāla: &quot;salạmuⁿ lakum̊&quot;

[V3]
 3- (ạảrāhum̊ yadaẙhi ạảẙḍaⁿạ jan̊bahu)
 ffrḥwạ ḥyn rạ̉wạ sẖkẖṣh

[V4]
 4- (halĩlūyā qad̊ tāảkãda ạl̊kẖabar̊)
 halĩlūyā sẖaẘkaẗa ạl̊maẘti kasar̊

[V5]
 5- (halĩlūyā famukẖalĩṣu ạl̊basẖar̊)
 saḥaqa ạl̊qab̊ra waqāma wān̊taṣar̊

[V6]
 6- (halĩlūyā qāma rayỉysu ạlsãlạm̊)
 halĩlūyā halĩlūyā ạlrãbũ qām̊</lyrics>
</song>