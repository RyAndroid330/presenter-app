<?xml version="1.0" encoding="UTF-8"?><song><author>ạ̹brạhym srkys, hạgẖwb jmbạzyạn</author>
<hymn_number>2077</hymn_number>
<title>lw lm yḥbny ạlmsyḥ</title>
<lyrics>[V1]
 1- laẘ lam̊ yuḥibãnī ạl̊masīḥ̊
 mā kāna ạảsẖ̊qānī
 ṭahãranī dẖāka ạldẖãbīḥ̊
 wāl̊ʿaf̊wa ạảʿ̊ṭānī

[V2]
 2- laẘ lam̊ yuḥibãnī ạl̊gẖafūr̊
 kun̊tu maʿa ạlạảsẖ̊rār̊
 ạảb̊qay̱ ại̹lay̱ dah̊ri ạldũhūr̊
 muʿadẖãbaⁿạ biạlnãạr̊

[V3]
 3- laẘ lam̊ yuḥibãnī ạl̊qadīr̊
 wayagẖ̊firi ạldẖãn̊ba
 mā kāna ại̹m̊kānuⁿ biạản̊
 ạủsākina ạlrãbã

[V4]
 4- laẘ lam̊ yuḥibãnī ạlãdẖī
 kulĩla biạlạảsẖ̊wāk̊
 kun̊tu ại̹dẖaⁿạ muqayãdaⁿạ
 fī wah̊daẗi ạl̊halạk̊

[V5]
 5- fālsẖũk̊ru minĩy wājibuⁿ
 mā dum̊tu fī ạl̊ḥayāh̊
 liman̊ faday̱ naf̊sī waman̊
 qad̊ jāda biạlnãjāh̊</lyrics>
</song>