<?xml version="1.0" encoding="UTF-8"?><song><title>ạlận rbnạ ạlqdyr</title>
<lyrics>[V1]
 1- ạlậna rabũnā ạl̊qadīr̊
 ạảmāmanā yasīr̊
 wataḥ̊ta liwā ḥubĩhi
 jamīʿunā nasīr̊
 [v2]
 2- mā dum̊nā nasīru hunā
 fah̊wa lanā rafīq̊
 warūḥuhu yaqūdunā
 warāhu fī ạlṭãrīq̊

[V2]
 3- wah̊wa ṭaʿāmunā ạlsẖãhī̃̊
 fī mudãẗi ạlsãẙri
 wāl̊manũ wālṣãkẖ̊ru lanā
 mā dum̊nā fī ạl̊qaf̊ri

[V3]
 4- fālậna yā sẖaʿ̊ba ạl̊masīḥ̊
 sīrūạ ại̹lay̱ ạlạảmām̊
 sīrūạ binā fanas̊tarīḥ̊
 fī maẘṭini ạlsãlạm̊</lyrics>
<copyright>1977</copyright>
</song>