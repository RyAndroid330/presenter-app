<?xml version="1.0" encoding="UTF-8"?><song><title>Голјат</title>
<lyrics>[V1]
.    Am
 // Голјат ҹəнҝə чыхды
.      Dm    Em   Am
 Давуд ондан һеч горхмады //

[C1]
.     C        Am
   // Аллаһын ады илə ону
.           Dm      Em   Am
   Бир дəнə даш илə өлдүрдү //

[V2]
.   Am
 // Шејтан гаршыма чыхса
.     Dm     Em   Am
 Мəн ондан һеч горхмарам //

[V3]
.     C        Am
 // Исанын ады илə ону
.        Dm       Em   Am
 Анҹаг бир сөз илə јыхарам //</lyrics>
<key>Am</key>
<aka>Голјат ҹəнҝə чыхды</aka>
<author>Һәмра ака</author>
</song>