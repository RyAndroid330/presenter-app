<?xml version="1.0" encoding="UTF-8"?><song><title>Севинҹ ҝүнү İL143 AİL107 MÇ69</title>
<key>F</key>
<lyrics>[C1]
.  Dm           Gm      Dm
   Севинҹ ҝүнү, барыш ҝүнү
.  Gm         Dm   A  Dm
   Мəсиһ дүнјамыза енди
.  Dm          Gm       Dm
   Севинҹ ҝүнү, барыш ҝүнү
.  Gm         Dm   A  Dm
   Мəсиһ дүнјамыза ҝəлди

[V1]
.Gm              Dm
 // Дүнјаја хиласкар ҝəлди
.A            Dm
 Алгышлајын ону инсанлар //

[V2]
.Gm             Dm
 // О бағышлајыр бүтүн ҝүнаһы
.A             Dm
 Үрəјинə бурах сəн Аллаһы //

[V3]
.Gm             Dm
 // Иса ҝəтирди гуртулуш, севинҹ
.A              Dm
 Севинин инсанлар севинин //</lyrics>
<hymn_number>143</hymn_number>
<author>Джоханнес Даниел Фалк, Хеинрич Холзсчухер</author>
</song>