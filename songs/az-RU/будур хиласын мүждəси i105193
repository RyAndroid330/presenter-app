<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.Am        Am                   Dm
 // Ҹаныны Рəбб бизим үчүн фəда етди -
.E7                 Am
 Будур хиласын мүждəси //

[V2]
.        Dm          Am
 Дүнјаны севди, азад етди
.     E7           Am
 Уғрунда гурбан ҝетди!
.       Dm          Am
 О сəни севди, азад етди,
.       E7             Am
 Өлүлəр арасындан дирилди!

[C1]
.                         E7
   // Ону үрəкдəн мəдһ едəрəм,
.             Am
   едəрəм, едəрəм. //

[C2]
.       E7         Am
   Һаллелуја, Һаллелуја,
.       E7         Am
   Һаллелуја, Һаллелуја!</lyrics>
<title>Будур хиласын мүждəси</title>
<author>Салвадор</author>
</song>