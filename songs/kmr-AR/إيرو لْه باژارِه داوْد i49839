<?xml version="1.0" encoding="UTF-8"?><song><author>شابان ٲوك</author>
<title>إيرو لْه باژارِه داوْد</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm                          Gm
 //  إيرو لْه باژارِه داوْد كِف أوو شاهْیَه!
.Gm                         Dm
  مْلیاكَت لْه أزمانان دیلانِه دْگْرْن. //
.Gm
 // زاروكَك پِچایي یَه دْه آفْرَكي دَه،
.Dm                Cm      Dm
 َڤ زاروك خْلاسكارِه هَموو گَلان هَ. //

[V2]
.   Gm
 //  مْزگینْیا مْن لْه وَه،
.Dm
  خْلاسكارِه مَه هات.
.Cm
  شْڤانان بْكَڤْن رِه،
 هَموو نَتَوان وَرْن
.Gm       Dm
  بْه پَرْزْن وي. //

[V3]
.   Dm                          Gm
 //  قْرالِه مْن نَه لْه تَخت أوو نَه ليه سَرایان هَ
.Gm                         Dm
  جیرانِه وي دَوار أوو پَز أوو مْیا نَه. //
.Gm
 // أو ژْه بو مَه كَرَم كْر هاتَه دْنیایِه،
.Dm                   Cm       Dm
 َم ژي ٲودَیا دْلِه خوَه ڤَكْن ژْه وي رَه. //

[V4]
.   Dm                         Gm
 //  شْكْر یا خۇدان، تَه دۇایا مْن بْهیست،
.Gm                    Dm
 َدي چاڤِه مْن خْلاسكْرْنا تَه دیت. //
.Gm
 // أڤ زاروك روناهي یَه ژْه بو هَموو گَلان،
.Dm                  Cm    Dm
 بيه سایا كۇرِه خوَدِه آزادْم، ازاد. //</lyrics>
</song>