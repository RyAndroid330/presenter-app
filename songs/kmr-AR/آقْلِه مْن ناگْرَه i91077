<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 /آقلِه مْن ناگْرَه،
 فْكرِم فِم ناكَه
 هَزكْرْنا تَه
 یا كۇ ژْه بو مَه.

[V2]
 /أم لییاق نینْن
 ناڤِه تَه هْلدْن
 تَه خوَه كْر قۇربان
 دیسا ژْه بو مَه/

[V3]
 /تَه أڤین دا مَه،
 تَه كَرَم دا مَه
 ژْه بو أم نَمْرْن
 تَه ژییان دا مَه./

[V4]
 /تَه روومَت دا مَه
 تَه بْهْشت دا مَه.
 دْخوازْم بْبِژْم
 أز تَه هَز دْكْم./</lyrics>
<title>آقْلِه مْن ناگْرَه</title>
<author>شابان ٲوك</author>
</song>