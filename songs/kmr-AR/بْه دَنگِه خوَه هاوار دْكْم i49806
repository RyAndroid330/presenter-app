<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Fm                 Eb
 // بْه دَنگِه خوَه هاوار دْكْم،
.         Db       Cm
 ژْه خوَدان رَه لاڤا دْكْم. //
.        Fm       Cm
 // أز دْرِژْم گازْنِن خوَه،
.     Db    Eb   Cm
 أز دْبِژْم تَنگاهْیِن خوَه. //

[V2]
 // مْن تْشتَك خوَست ژْه خوَدان،
 أز لْه وي گَرْیام. //
 // هَموو روژِن ژْیانا خوَه،
 لْه مالا وي بْبورینْم. //

[V3]
 // روني أوو رْزگارْیا مْن خوَدان هَ،
 أز ناتْرسْم ژْه تۇ كَسان. //
 // خوَدان هِزا ژینا مْن هَ،
 بو چْه أزِه بْتْرسْم ژْه هْنان. //</lyrics>
<key>Fm</key>
<title>بْه دَنگِه خوَه هاوار دْكْم</title>
<author>نوۇر آلو</author>
</song>