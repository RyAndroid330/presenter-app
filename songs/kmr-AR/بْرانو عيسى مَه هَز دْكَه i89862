<?xml version="1.0" encoding="UTF-8"?><song><author>مْلازْم راسسویان, كارِن توروسیان</author>
<title>بْرانو عيسى مَه هَز دْكَه</title>
<key>Am</key>
<lyrics>[V1]
.Am          Bb     Am
 بْرانو، عيسى مَه هَز دْكَه،
.Am     Bb         Am
 مْن أوو تَه أو خوَي دْكَه.
.Am        Bb       Am
 َو دْخوازَه مَه پیروز بْكَه،
.Am    Bb         Am
 كۇ أزمِن دا جیوار كَه.

[C1]
.  Dm        C
   أم دْستْرِن، بوي ناڤِه وي،
.  Am            Bb
   ازابوونا رۇه، ژيه رَهما وي.
.  Am        Bb
   یسا یَه بَختَوارییا مَه،
.  Bb         Am
   هۇبا وي سَر مَه هَیَه.

[V2]
 وي گۇنَهِن مَه باخشاندْنَه مَه،
 ژْه مَه جَزا هْلدانَه.
 وي خوینا خوَیَه پیروز رِتیَه،
 بوي مَه جَنْم دادا یَه.

[V3]
 خَبَرِن زاران تِرِه ناكْن،
 كۇ رَهما وي گْلي كْن.
 أم بْه دْل تْمِه ژِه رازي بْن،
 خْزمَتْیِرا هازْر بْن.

[V4]
 هَگَر مْن بْدْنَه بَر دیوانِه،
 بوي پَسْنِه ناڤِه خوَدِه.
 فْكْرا مْن دیسا وِه سَر وي بَه،
 هَتا بین بَر مْن دا هَبَه.</lyrics>
</song>