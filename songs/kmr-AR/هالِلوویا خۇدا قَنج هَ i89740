<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   /// هالِلوویا، خۇدا قَنج هَ، ///
   دْلوڤانْیا وي هَر هَیَه.

[V1]
 چْمكي أو جانِه مَه یِه تي،
 أو تِر دْكَه.
 جانِه مَه یِه بْرچي،
 بْه قَنجْیِه، أو تْژَه دْكَه.

[V2]
 دْه ناڤ سْیا مْرْنِه یا تاري رَه،
 أم دَرباس دْبْن.
 ژْه بَر أم // تَڤ خوَدِه نَه، //
 أم ناتْرسْن.</lyrics>
<title>هالِلوویا خۇدا قَنج هَ</title>
</song>