<?xml version="1.0" encoding="UTF-8"?><song><title>خوْشك أوو بْرا وَرْن</title>
<key>Am</key>
<lyrics>[V1]
.   Am
 // خوَدا أم تَه دْخوازْن،
.Gm
 بيه رِیا تَه سَربازْن. //

[V2]
.   F
 // عيسى مسيح ژْیان هَ،
.Dm       C      Dm
 ینجیلا پیروز دا مَه. //

[C1]
.     Dm   C    Bb     Am
   // ها.. ها.. هالِلوویا. //

[V3]
 // خوْشك أوو بْرا وَرْن،
 مسيح ژْه وَه هَز دْكَه. //

[V4]
 // رِیا وي روناهي یَه،
 هَزكْرْن أوو شاهي یَه. //</lyrics>
</song>