<?xml version="1.0" encoding="UTF-8"?><song><title>وَختِه أو هَ'وراڤا زوو ڤَگَر'هَ</title>
<lyrics>[V1]
.Bm
 وَختِه أو هَ'وراڤا زوو ڤَگَر'هَ،

[V2]
.                         F#7
 چ'هَ'ڤِه مْن گَرَه سْفَتِه وي بْبینَه.

[V3]
.F#7            Em
 شابوونا شْكْرییِه بْدْنَه، أولَدِد خوَدِه،

[V4]
.G        F#7        Bm
 هَ'زماناڤا هَر'اْمَه پِشییِه.

[V5]
.        F#7             Bm
 آخ چْه شْكْري یَه، چْه مَه'ریفَت هَ،

[V6]
.     A          D
 بَختَواري یَه ژْه خوَدِدا.

[V7]
.   Em  A         D   G
 أز شا مَه أوو گَلَك شا مَه،

[V8]
.        Em        F#7     Bm B7
 تِه بیرا مْن ه'اْزكْرْنا وییَه مَزْن.

[V9]
.Bm
 چْه مَه'ریفَتَكَه مَزْن وِه بْبَه هَ'زمانا،

[V10]
.                       F#7
 چاخِه ه'أموو پیروز ت'ٲوپ بْن،

[V11]
.                  Em
 بْه شابوونِه شْكْرییِه بْدْنَه بَرخِه خوَدِه،

[V12]
.G                F#7Bm
 هِژایي گَلَك شْكْرییِه یَه.

[V13]
.          F#7            Bm
 بووك هازْر بوویَه، زوو وَرَه خوَیي،

[V14]
.        A            D  B7
 ر'ٲۇه'ِه خَمْلي هیڤییا تَه یَ.

[V15]
.   Em  A         D   G
 أز شا مَه أوو گَلَك شا مَه،

[V16]
.        Em        F#7     Bm B7
 تِه بیرا مْن ه'اْزكْرنا وییَه مَزْن.

[V17]
.Bm
 آوا خوَیِه مَه تِه ت'أڤ پیروزا، مْلیاك'أتا،

[V18]
.                  F#7
 بْه دَنگِه بور'إيیا مَزْن

[V19]
.F#7                  Em                G    F#7 Bm
 وِه هیملي كَه پ'آدشاتیكَه مَزْن أوو هَ'دْلایي ليه سَر دْنِه.

[V20]
.        F#7             Bm
 آخ چْه شْكْري یَه، چْه مَه'ریفَت هَ،

[V21]
.     A          D
 بَختَواري یَه ژْه خوَدِدا.

[V22]
.   Em  A         D   G
 أز شا مَه أوو گَلَك شا مَه،

[V23]
.        Em                Bm  B7
 تِه بیرا مْن ه'اْزكْرْنا وییَه مَزْن__.</lyrics>
