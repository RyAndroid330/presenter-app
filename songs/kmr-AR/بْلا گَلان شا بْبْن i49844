<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Dm       F
 // بْلا گَلان شا بْبْن،
.Gm
 َو ژین بوو ژْه مْرْنِه. //
.   F
 // رابْن بْه چار هاوْردور،
.Eb        Dm
 بَلاڤ كْن مْزگینییِه. //

[V2]
.   Dm         F
 // أو خْلاسكار یسا یَه،
.Gm
 بيه خوَه كۇرِه خوَدِه یَه. //
.   Dm
 // ژْه بو كوو أم آزاد بْن،
.Eb       Dm
 یسا جانِه خوَه دایَه. //

[V3]
.   Dm          F
 // هَمد ژْه بَرخِه خوَدِه را،
.Gm
 دَستِه مَه گْرت، بَرنَدا. //
.   F
 // أو رووهِه پیروز دا مَه،
.Cm          Dm
 هات روونْشت دْلِه مَه دَه. //</lyrics>
<key>Dm</key>
<title>بْلا گَلان شا بْبْن</title>
<author>شابان ٲوك</author>
</song>