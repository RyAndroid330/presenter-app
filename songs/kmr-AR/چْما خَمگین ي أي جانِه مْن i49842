<?xml version="1.0" encoding="UTF-8"?><song><author>شابان ٲوك</author>
<key>Gm</key>
<lyrics>[V1]
.   Gm
 // چْما خَمگین ي أي جانِه مْن!
.Bb
 بو چْه دْنالَه هْناڤا مْن! //
.   Gm                F
 // هِڤْیا خوَه بْه خوَدِه ڤَ گْرِه دَه
.Eb               Gm
 چْمكي أو خْلاسكارِه مْن هَ //
.   Gm            F
 // أزِه دیسا وَرْم هْزۇرا وي
.Cm        Dm  Gm
 هَمد أوو شْكْر بْكْم. //

[C1]
.     Gm             F
   // روناهي أوو راستْیا خوَه بْشینَه،
.  Eb          Gm
   بْلا رِه نیشانِ مْن بْدْن. //
.     Gm         F
   // مْن بْبَه چْیایِ خوَه یِه پیروز
.  Cm       Dm   Gm
   ليه وْر بْپَرْزْم تَ. //

[V2]
 // چْما خَمگین ي أي جانِه مْن؟
 بو چْه دْنالَه هْنناڤا مْن؟ //
 // خوَدِه ستارگَه أوو هِزا مْن هَ،
 أوِه دیسا آلْكارْیا مْن بْكَه. //
 // بْه كَرَمكاري وِه لْه مْن بْنِرَه
 ساخبوونِه بْدَه جانِه مْن. //</lyrics>
<title>چْما خَمگین ي أي جانِه مْن</title>
</song>