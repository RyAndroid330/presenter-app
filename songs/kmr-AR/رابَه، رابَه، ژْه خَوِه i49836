<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 رابَه، رابَه، ژْه خَوِه،
 مسيح لْه تَه دْگَرَه.
 // رابَه، رابَه، ژْه خَوِه،
 مسيح بانگي تَه دْكَه. //

[V2]
 فَرسَندِه خوَه بَرنَدَه،
 روژ دَرْن بْه سَر تَه دَه.
 // خوَه نَهِلَه بِه إيمان،
 بانگي عيسى مسيح كَه. //</lyrics>
<title>رابَه، رابَه، ژْه خَوِه</title>
</song>