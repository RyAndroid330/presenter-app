<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[C1]
.     Dm     F           C  Am            Dm
   //  عيسى مَسیه، لاوِه خوَدِه، چاڤكانْیا ژْیانِه. //

[V1]
.           Gm                Dm
 // رادْكْم دَستِه خوَه، بانگ دْكْم بيه ناڤِه تَه.
.         Am         Dm
 بْه هَموو دْلِه خوَه دْپَرْزْم تَه. //

[V2]
 // تَه مْزگینْیِه دا بَلَنگازان،
 ساخْیِه ژي ژْه بو دْلشْكَستْیان. //

[V3]
 // تَه آزادْیِه آني ژْه بو گْرتْیان،
 ڤَبوونا چاڤان ژي ژْه بو كوران. //

[V4]
 // أي هَموو وَستْیایي أوو بارگْران،
 وَرْن با عيسى، با مسيح خوَدان. //</lyrics>
<title>عيسى مسيح لاوِه خوَدِه</title>
<author>گُ̈ركَن كَ̧مسُن</author>
</song>