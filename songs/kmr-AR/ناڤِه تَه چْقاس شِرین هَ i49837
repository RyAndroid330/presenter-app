<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[V1]
.   Dm       Gm   E♭   Dm
 //  ناڤِه تَه چْقاس شِرین َه،
.        Gm   F   Gm
 رَهما تَه چْقاس مَزْن َه.
.Dm      Gm        E♭
  أم هَیرانا هَزكْرْنا تَه نَه،
.Dm    Gm          F   Dm
  كَرَم بْكَه وَرَه، مَه تَزَه بْكَه. //

[C1]
.     F
   // تۇ پیروز ي، تۇ پیروز ي.
.  F                 E♭
   َم پَسنِه تَه دْدْن یا خۇدان.
.  Gm
   تۇ پیروز ي، تۇ پیروز ي.
.  Dm         F   E♭   Dm
   َم پَسنِه تَه دْدْن یا خۇدان. //

[V2]
.   Dm       Gm   E♭    Dm
 //  جانِه مَه چاوا بْرچي دْبَه،
.        Gm  F           Gm
 رۇهِه مَه وَها تي أوو بْرچي یَه.
.Dm       Gm        E♭
  بْه پَیڤا خوَه مَه تِر بْكَه،
.Dm       Gm        F     Dm
  تاما وي ژيه هْنگْڤ شِرینتْر َه. //</lyrics>
<aka>تۇ پیروز ي</aka>
<title>ناڤِه تَه چْقاس شِرین هَ</title>
<author>شابان ٲوك</author>
</song>