<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>67</hymn_number>
<title>نتشفّع ليك TN67</title>
<lyrics>[V1]
.   Em             B7          Em
 1/ //  نتشفّع ليك ليك وحدك يا ملك  //
.Am           Em     Am          Em
 //  خلّينا في عينيك، خبينا في ايديك  //
.    B7
 ///  ليك محتاجين  ///
.           Em
 يا يسوع يا ملك

[V2]
 2/ //  شعبك يا فادي ينادي ما تنساش بلادي  //
 //  من سلامك أعطينا، من روحك اروينا  //
 ///  ليك محتاجين  ///
 يا يسوع يا ملك</lyrics>
<key>Em</key>
</song>