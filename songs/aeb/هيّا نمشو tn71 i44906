<?xml version="1.0" encoding="UTF-8"?><song><capo>2</capo>
<title>هيّا نمشو TN71</title>
<key>F#m</key>
<lyrics>[V1]
.       Em                D
 1/ //  هيّا نمشو لبلاد بعيدة
.   (C)                B7
 نحكوا للناس حكايتنا جديدة  //
.      Em                 Am
 //  الناس العايشة في الاحزان
.          D        Em
 الناس المحتاجة للغفران //

[C1]
.       Em              D
   //  عندي خبر عندي دبارة
.                    Em
   المسيح غفر هذي لبشارة  //

[V2]
 2/ //  نبدا بحكاية آدم وحوّاء
 دعوة إبراهيم من أوّل مرة  //
 //   نحكيلهم قصة شعب الله
 حفظ الوصايا والبركات  //

[V3]
 3/ //  تختم بقصة المسيح
 ومحبتو لكلّ الأعداء  //
 //  يا خويا راجع راهو أكيد
 ما تقسي قلبك وتولّي عنيد  //</lyrics>
<hymn_number>71</hymn_number>
</song>