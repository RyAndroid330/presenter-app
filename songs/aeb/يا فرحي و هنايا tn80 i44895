<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // يا فرحي و هنايا نهار اليوم  //
 يا فرحي و هنايا ليوم يسوع ليوم يسوع حذايا نهار اليوم

[V2]
 1/ // فرحان باش نطير نهار اليوم  //
 فرحان باش نطير اللي يراني يقول غشير صغير
 و مغروم

[V3]
 2/ //  ياو نرقص كي داود نهار اليوم  //
 يا ونرقص كي داود حتى ما فرحتي تتعاود في كلّ يوم

[V4]
 3/ // بديت حياة جديدة نهار اليوم  //
 بديت حياة جديدة مع يسوع تنحات التنهيدة نهار اليوم

[V5]
 4/ // ها الفرحة دوّمها يا ربي  //
 ها الفرحة دوّمها على ها النّاس يا ربّي عمّمها نهار اليوم</lyrics>
<title>يا فرحي و هنايا TN80</title>
<hymn_number>80</hymn_number>
</song>