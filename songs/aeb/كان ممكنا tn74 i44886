<title>كان ممكنا TN74</title>
<key>Gm</key>
<lyrics>[C1]
.       Em              Am      Em
   //  كان ممكنا أن لا أكون للمسيح
.       Em           Am                Em
   كان ممكنا أن لا أعرف الراحة ولا أستريح  //

[V1]
.       Em         Am
 1/ //  أسرق مع السارقين
.    D          Em
 أكذب مع الكاذبين
 أزني اه مع الزناة
.          Am  Em
 عنيد عنيد  //

[V2]
 2/ //  قيدوني في الخطايا
 دربوني ع البلايا
 حاكموني من البداية
 أخجلتني صورتي  //</lyrics>
<hymn_number>74</hymn_number>
</song>