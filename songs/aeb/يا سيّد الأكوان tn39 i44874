<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>39</hymn_number>
<title>يا سيّد الأكوان TN39</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm          Gm    A             Dm
 //  يا سيّد الأكوان يسوع ابن الإنسان  //
.Gm       Dm    A                   Dm
 //  تغمرني بالفرحة و المتعة و الأمان  //

[V2]
 //  يا مانح الغفران و البرّ بالإيمان  //
 //  تشعرني بالراحة في وسط الأحزان  //
 //  مهما كان المكان مهما كان الزمان  //
 //  تعطيني ربي قوّة أقوى من الشيطان  //
 //  يا سيدي المناّن بالحبّ و الحنان  //
 //  ليبصر العميان الدنيا بالألوان  //</lyrics>
</song>