<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>72</hymn_number>
<title>يسوع ربي TN72</title>
<capo>3</capo>
<lyrics>[C1]
   القرار:
.          Em        D
   //  يسوع ربي غيّر حياتي
.      C           B7
   يسوع لحني وللممات    //

[V1]
.        Em             (C)      Am
 1/ //  عدت من بعيد من جهلي من عيوبي
.         D           B7
 صرت له قريب كي أرث السماء   //

[V2]
.         Em           (C)        Am
 2/ //  لساني سوف يشدو ترنيمة جديدة
.             D            B7
 أغنّي في الكنيسة هللويا هللويا   //

[C2]
.     Em              Am
   //  قد وعدنا يحقق وعدو
.       D     Em
   مات عنّا مات عنّا
.   Em           Am
   سوف يأتي سوف يأتي
.         D     Em
   لا تملّو لا تملّو  //</lyrics>
<key>Gm</key>
</song>