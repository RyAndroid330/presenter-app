<?xml version="1.0" encoding="UTF-8"?><song><key>Gm</key>
<lyrics>[C1]
.       Em     E7        Am
   //  تعال إليّ يا ابني تعال
.       D  B7        Em
   حبّي حقيـــقي ومش محال  //

[V1]
.       Em            D      Em
 1/ //  اخترتك قبل تأسيس العالم
.Em       D        Em
 قدستك لأرى فيك صورتي  //
.        D    C  Am    B7
 //  لأنك لأنك لأنك صنع يدي  //

[V2]
 2/ //  اقبل عطيتي و طع كلامي
 و احفظ شريعتي واقبل سلامي  //
 //  لأنك لأنك لأنك صنع يدي  //

[V3]
 3/ //  الها مشيرا قديرا لك انا
 عزيز في عينيا يا ابني انت  //
 //  لأنك لأنك لأنك صنع يدي  //</lyrics>
<title>تعال إليّ TN73</title>
<capo>3</capo>
<hymn_number>73</hymn_number>
</song>