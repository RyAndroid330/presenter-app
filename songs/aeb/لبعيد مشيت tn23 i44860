<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.       Am                               Dm          Am Dm Am
 1/ //  لبعيد مشيت و لا نهار بالشبع حسيت  //  و لا ترويت
.    Am            Dm                   Am
 //  و ف يوم و ف يوم   //  على بابي دقيت

[V2]
 2/  //  حليت بابي ليك سلمت حياتي بين يديك  //  فكري و قلبي كلو ليك
 //  و اليوم و اليوم   //   ليلي نهاري نسبح فيك

[V3]
 3/  //  يا عطشان و يا جيعان حل قلبك لابن الإنسان  //  يسوع المسيح
 //  يسوع يسوع   //  لينا الكل ضمان

[C1]
   //  و اليوم و اليوم   //  أعمل خطوة إيمان</lyrics>
<key>Cm</key>
<title>لبعيد مشيت TN23</title>
