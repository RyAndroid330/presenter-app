<?xml version="1.0" encoding="UTF-8"?><song><key>E</key>
<lyrics>[V1]
.   E               C#m
 1/ //  مع يسوع بديت حياة جديدة
.B         A   B     E
 مع يسوع تركتني الأحزان
. E            C#m
 مع يسوع تنحى الخوف عليّ
.B         A    B    E
 مع يسوع الفرحة فكلّ مكان  //
.     E         B        F#m    B      E
 //  على خاطرو خلصني و هزّ خطيتي على الصليب
.E      B    F#m      B      E
 و بدمو قدسني عمل مني انسان جديد  //

[V2]
 2/ //  وقت الضيق يمد يدو لي
 يسوع في حياتي برّ الأمان
 كل صعيب يهون علي
 مادام للكلمة في قلبي مكان  //
 //  روح الله يجدد لي القوة قد منكون تاعب و ضعيف
 الحياة مع ربي حلوة كل رزين يولي خفيف  //

[C1]
.     E            C#m
   //  مع يسوع بديت حياة جديدة
.  B         A   B     E
   مع يسوع تركتني الأحزان
.   E            C#m
   مع يسوع تنحى الخوف عليّ
.  B                                 C#
   مع يســــــــــــــوع الفرحة فكلّ مكان  //</lyrics>
<title>مع يسوع TN31</title>
