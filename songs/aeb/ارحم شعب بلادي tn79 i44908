<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>79</hymn_number>
<title>ارحم شعب بلادي TN79</title>
<capo>3</capo>
<key>Gm</key>
<lyrics>[V1]
.   m E           D
 //  يا ربّ يا يسوع الفادي
 ارحم شعب بلادي
.              C
 انت الطبيب الشّافي
.      D              B7
 تضمّد جروح المآسي  //

[V2]
.         Em
 أ/ //  يا ربّي تونس محتاجة ليك
 وأنا نسلمها بين ايديك
.D
 فيض عليها بنورك و سلامك
.C               B7
 واحفظها فممّو عينيك  //

[V3]
 قرار: يا ربّ يا يسوع الفادي...

[V4]
.        Em
 ب/ //  شافت بلادي في يوم
 الضياع و كثر اللّوم
.    D
 وزاد عليها الخوف
.       C               B7
 من القمع زعمة يدوم  //

[V5]
 قرار: يا ربّ يا يسوع الفادي...

[V6]
.      Em            D
 ج/ //  يا ربّي انت القادر
 تحرّر شعبك و تبادر
.    Em
 بالحبّ تفيض علينا
.       D               Em
 وبماك الصّافي تروينا //

[V7]
.      Em
 د/ //  يا ربّي شعب تونس
 شعب الكرم  والجود
.      D                C                  D      Em
 حطنا تحت جناحك  و نحيلها الخوف و نحيلها الخوف //

[V8]
.   Em               D
 ه/  بارك ها الأرض بحبّك
 بثمار تمجّد اسمك
. Em                    D
 و تكون بلادي رمز لسلامك

[V9]
. D                  Em
 ويكون الشعب لكلّ أولادك
.D Em
 ويكون الشعب لكلّ أولادك</lyrics>
</song>