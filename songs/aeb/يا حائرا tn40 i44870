<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   القرار:
.     Dm          A     Dm
   //  يا حائرا (يا حائرا)  //
.    Dm       Gm                    A    Dm
   يا حائرا وسط الجموع  يا سائرا بين الربوع
.    Dm Gm A Dm
   ...
.     Dm         Gm              Dm
   //  غارقا في الدموع باحثا عن يسوع  //
.     Dm     A  Dm       Dm   A  Dm
   //  اسأل جلجثة      (اسأل جلجثة)  //

[V1]
.       Dm            Gm
 1/ //   ستحكي لك عن حمل وديع
.(C)        A     Dm
 مات لأجل خلاص الجميع  //
.       Dm           Gm
 2/ //   ستخبرك عن شخص بديع
.(C)         A       Dm
 قام ليبني حصنا منيع  //
.   Dm               Gm
 3/ //   ستعطيك بعض المسامير
.(C)         A   Dm
 و بعض القطع الخشبية
. Dm             Gm
 ذكرتها بعض المزامير
.(C)         A    Dm
 و بعض الكتب النبوية  //</lyrics>
<key>Dm</key>
<title>يا حائرا TN40</title>
<hymn_number>40</hymn_number>
</song>