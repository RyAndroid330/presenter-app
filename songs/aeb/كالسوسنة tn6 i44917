<?xml version="1.0" encoding="UTF-8"?><song><title>كالسوسنة TN6</title>
<lyrics>[V1]
. Am
 1/ //  كالسوسنة بين الشوك كذلك حبيبي
.Dm      G7               E
 كالتفاح بين الوعر كذلك حبيبي  //
.   Am                 G
 //  أدخلني جنته أنشدني ألحانه
.         Dm      G7   E            Am
 يمينه تضمني هذا هو حبيبي  //  هذا هو حبيبي

[V2]
 2/ //  صوت حبيبي هوذا آت بين تخوم الواد
 يبس الشوك طلع الزهر بين تخوم الواد  //
 //  أجلسني قربه سقاني حبّه
 طيبني بطيبه هذا هو نصيبي  //  هذا هو نصيبي

[V3]
 3/ //  كالمفتون ناد باسمي وعفا عني
 صلب عني تحمّل ذنبي وعفا عني  //
 //  عرفني باسمه قدسني في شخصه
 علمني طريقه هذا هو يسوعي  //  هذا هو يسوعي</lyrics>
<key>Am</key>
<hymn_number>6</hymn_number>
</song>