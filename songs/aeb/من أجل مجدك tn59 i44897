<?xml version="1.0" encoding="UTF-8"?><song><title>من أجل مجدك TN59</title>
<lyrics>[C1]
.   Em             D   C   B7
   من أجل مجدك يا ربي حررني حررني
.  Am       Em     Am  B7  Em
   لمجد اسمك يا ربي غيرني غيرني

[V1]
.       Em        Am            B7
 1/ //  أريد أن أحيا لك بقولي و فعلي
.Am          Em         B7
 أريد أن أعبدك بقلبي و عقلي  //

[V2]
 2/ //  أكرّس كلّي لك بكلّ إيماني
 و أشهد عن حبّك لكلّ إنسان   //</lyrics>
<key>Em</key>
<hymn_number>59</hymn_number>
</song>