<?xml version="1.0" encoding="UTF-8"?><song><title>Благословине Ман Девла</title>
<lyrics>[V1]
 // Благословине ман
 Благословине ман
 Благословине ман Девла //

[V2]
 // Джанава мо животи тере вастенде
 Джанава мо животи тере вастенде
 Джанава мо ило си тере вастенде джанава //

[V3]
 // Благословине ман
 Благословине ман
 Благословине ман Девла //

[V4]
 // Мири, мири, мири, мири
 Мангава ме
 Мири, мири, мири, мири
 Родава ме //

[V5]
 // Паш Туте авава То мири ме мангава
 Паш Туте авава Девла //</lyrics>
<aka>Мири, Мири, Мири</aka>
</song>