<?xml version="1.0" encoding="UTF-8"?><song><title>Те Пенас Девла</title>
<lyrics>[V1]
 // Калке Гиляса саворенге пенав
 Те перен англал о Дел
 Те вазден васта Яка те панден
 Леске те пеназ дехаслес //

[V2]
 // Ка пенас Девла Ой Девла
 Баро сан Ту Свято Дел синян. / //</lyrics>
<aka>Девла</aka>
</song>