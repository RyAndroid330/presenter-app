<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>176</hymn_number>
<lyrics>[V1]
..Am
  // Yo tengo un barco
 Que navega por la mar,
 Y Jesucristo es el capitán. //
 // Los marineros que bogan a su lado
 Son almas que han lavado
 Su negro corazón. //
 // Si no hubiera sido por el Señor. //
 // Mi alma se hubiera perdido,
 Si no hubiera sido por el Señor. //
 -----</lyrics>
<title>Yo tengo un barco CAC176</title>
</song>