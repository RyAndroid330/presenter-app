 // Una palabra viene a mí,
 una palabra para describir //

[C1]
   Santo, Santo, Dios poderoso
   Santo, Santo, Dios poderoso
   // Eres como nadie, eres Santo, Santo //
   // Santo, santo, Dios poderoso //</lyrics>
<aka>Santo</aka>
<title>Una palabra viene a mí</title>
