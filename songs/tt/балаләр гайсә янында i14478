<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C               G
 Балалар Гайсә янына
.C             G
 Үтәргә теләделәр.
.   C                   G
 // Тик Гайсәнең шәкертләре
.C    G          C
 Кудылар, әрләделәр. //

[V2]
.C                G
 Гайсә моны күреп ала
.C                  C
 Шәкертләргә сүз ката:
.    C                    G
 // &quot;Тимәгез, үтсеннәр,&quot; ди Ул,
.C       G    C
 балаларны юата. //

[V3]
 Гайсә сөйли балаларга:
 &quot;Килегез Минем янга.
 // Гүзәл бакча-Патшалыкта
 Мин сезне көтәм анда.&quot; //

[V4]
 Балаларны фатихалап
 Мәрхәмәтен тарата.
 // Гайсә Мәсих балаларны
 Бик тә сөя, ярата. //</lyrics>
<title>Балаләр Гайсә янында</title>
<hymn_number>73</hymn_number>
</song>