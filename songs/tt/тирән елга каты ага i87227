<?xml version="1.0" encoding="UTF-8"?><song><title>Тирән елга каты ага</title>
<aka>Чиксез мәңкелек шөһрәтең</aka>
<lyrics>[V1]
. Am      G
 Тирән елга каты ага
.    F(Dm)    Em(G)(C)
 // Дулкыннары ярга кага //
.Am        G
 Киң дәрьягә ашкыналар
.   F(Dm)       Em(G)(C)
 // Нинди көчле ташкыналар //

[C1]
.     Am
   // Әй! Ходаем Синең алда,
.  Dm
   Бөртек сыман алар барда.
.  G
   Көчле Синең зур кодрәтең.
.  F7    E      Am
   Чиксез мәңгелек шөхрәтең. //

[V2]
 Иксез, чиксез тирән дәрья
 // Очрый хәтәр чоңгылларда //
 Гаҗәп бөек шарлавыклар,
 // Нинди көчле ташкыналар //

[V3]
 Зәңгәр дәрья галәм үзе
 // Меңәрләгән йолдыз күзе //
 Кайнар кояш сер йомгагы
 // Табышмактай якты ае //</lyrics>
<key>Am</key>
<author>Якты юл</author>
<hymn_number>56</hymn_number>
</song>