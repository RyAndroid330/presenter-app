<?xml version="1.0" encoding="UTF-8"?><song><title>Безнең Аллабыз шәфкатьле</title>
<key>Eb</key>
<lyrics>[V1]
.   Eb               Bb
 // Безнең Аллабыз шәфкатьле,
.             Eb
 Гадел һәм ярлыкаучы. //
.              Ab
 // Аның исемен чакырган
. Bb
 Тәкъваларны саклаучы. //

[V2]
 // Ул догамны ишеткәнгә
 Мин Аллама сыенам. //
 // Ходай яхшылык кылганга
 Рәхмәт әйтеп сөенәм. //

[V3]
 // Тәмуг газаплары күрдем,
 Чирдә, кайгыда идем. //
 // Шулчак Ходайны чакырдым:
 &quot;Җанымны коткар,&quot; дидем. //

[V4]
 // Ул миңа колагын салды,
 Кысанлыктан чыгарды. //
 // Кайгылардан тартып алды
 Һәм җанымны коткарды. //

[V5]
 // Җаным инде тынычланды,
 Күзләремнән яшь акмый. //
 // Аякларым да абынмый
 Чөнки Ходаем саклый. //

[V6]
 // Мин терелермен җирендә
 Ходай белән булырмын. //
 // Коткаручым Ул булганга
 Мин Аңа сыенырмын. //</lyrics>
<hymn_number>77</hymn_number>
</song>