<?xml version="1.0" encoding="UTF-8"?><song><title>Коткаручем</title>
<lyrics>[V1]
.   Bm             D
 // Гайсә! Син Алла Мәсихе,
.G        F#
 Сөясең һәр кешене. //

[C1]
.     Bm          A    D
   // Җаным минем Сине сөя
.             F#    Bm
   Коткаручым, Яктыртучем,
.  Em     A        D
   Бөек Гайсәм, Изге Раббым,
.  F#           Bm
   Син бит минем Ходаем! //

[V2]
 // Гайсә! Син безне коткардың
 Рәхим-шәфкатең белән. //

[V3]
 // Гайсә! Син үлемне җиңдең
 Мин дә аны җиңәрмен. //

[V4]
 // Гайсә! Син ярдәм итәсең-
 Изге Рухыңны бирдең. //</lyrics>
<key>Bm</key>
<hymn_number>109</hymn_number>
</song>