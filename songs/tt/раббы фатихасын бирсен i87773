<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<title>Раббы фатихасын бирсен</title>
<lyrics>[V1]
.Eb
 Раббы фатихасын бирсен,
.Bb     Ab      Eb
 Һәм дә сине сакласын.
.   Ab        Eb  Cm
 // Раббы якты йөзе белән
.Ab            Eb
 Үзе сиңа нур чәчсен. //

[V2]
 Раббы сиңа шәфкать итсен,
 Һәм дә сине сакласын.
 // Раббы сиңа йөзен ячып,
 Сиңа иминлек бирсен. //</lyrics>
<key>Eb</key>
</song>