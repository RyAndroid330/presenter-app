<?xml version="1.0" encoding="UTF-8"?><song><title>Бир кулыңны син Гайсәгә</title>
<lyrics>[V1]
 // Бир кулыңны син Гайсәгә
 Анда котылу юлы. //
 // Бәхетле тормышны бирә
 Аның саф, Изге кулы. //

[V2]
 // Бир кулыңны син Гайсәгә
 Ул дошманнан көчлерәк, //
 // Гайсә белән яшәр өчен
 Гөнаһны ташлау кирәк. //

[V3]
 // Бир кулыңны син Гайсәгә
 Ул һаман сине көтә, //
 // Аның тар сукмагына бас,
 Шул мәңгелеккә илтә. //</lyrics>
<hymn_number>112</hymn_number>
</song>