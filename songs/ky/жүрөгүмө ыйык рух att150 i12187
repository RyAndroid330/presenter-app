 Мен кубанам Кудайга. //
.       Am           Em
 // Дөөт падышадай, Дөөт падышадай
.     B7       Em
 Мен кубанам Кудайга. //

[V3]
.     Em                B7 Em
 // Жүрөгүмө Ыйык Рух толуп турганда,
.    B7      Em
 Сыйынамын Кудайга. //
.       Am           Em
 // Дөөт падышадай, Дөөт падышадай
.    B7      Em
 Сыйынамын Кудайга. //</lyrics>
