<?xml version="1.0" encoding="UTF-8"?><song><title>Ай, ай сайын жолуксак ATT14</title>
<aka>Ынтымак</aka>
<key>Bm</key>
<lyrics>[V1]
.Bm                  Em
 // Ай, ай сайын жолуксак, бириктирет бизди ынтымак.
. A               D         F#
 Тойлор тойго уланып, кубантат элди ынтымак. //

[C1]
.  G        A
   Ырыс алды - ынтымак.
.  D        Bm
   Ырыс алды - ынтымак.
.  Em       F#     Bm
   Ырыс алды - ынтымак. (2ж)

[V2]
.Bm                 Em
 // Элибизге үлгү болсок, кыргызга келет ынтымак.
. A                   D         F#
 Кубаныч, тынчтык төгүлүп, жыргатат элди ынтымак. //</lyrics>
<hymn_number>14</hymn_number>
<author>Рахил Ысыева</author>
</song>