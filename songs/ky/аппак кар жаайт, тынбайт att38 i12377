<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>38</hymn_number>
<key>Eb</key>
<lyrics>[V1]
.Eb        Bb       Eb  Ab           Eb
 // Аппак кар жаайт, тынбайт, жымжырт бүт айлана
.Bb     G7      Cm  Fm      Bb    Eb
 Ыйсанын туулган күнүн майрамдайбыз кубана. //

[V2]
.Eb       Bb      Eb  Ab        Eb
 // Элге тынчтык берүүгө жерге келди Кудай
. Bb     G7     Cm  Fm   Bb      Eb
 Кубанган жүрөктөрдөн жаңыра берсин ырлар. //

[V3]
.   Eb    Bb     Eb  Ab        Eb
 // Сен дагы шашылгының шашыл Ыйса Теңирге
. Bb     G7   Cm Fm    Bb     Eb
 Ааламдын Падышасы жаныңа бакыт берет. //</lyrics>
<title>Аппак кар жаайт, тынбайт ATT38</title>
</song>