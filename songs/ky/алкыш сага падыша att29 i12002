<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>29</hymn_number>
<title>Алкыш Сага Падыша ATT29</title>
<key>D</key>
<lyrics>[V1]
.D         Bm        Em             D  A
 // Алкыш Сага, алкыш Сага, алкыш Сага, Падыша. //
.D          Bm     G           A
 // Атак-даңкка бөлөнүп, кубат  менен курчалган. //
.    D          G     Em      A
 // Бийлигиң - күч-кубат, ырайымың - акыйкат. //
. D       G     A      D
 Сага алкыш жерде жана асманда.
.   G    A  Bm   G    A   D
 // Сен - Падыша, Сен - Падыша. //</lyrics>
</song>