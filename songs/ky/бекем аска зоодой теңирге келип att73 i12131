<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>73</hymn_number>
<key>Em</key>
<lyrics>[V1]
.   Em             C
 // Бекем аска зоодой Теңирге келип
.   D           Em
 Куткаруу деп жарыяла!
.  Em              C
 Сенин Куткаруучуң Ыйсанын Атын
.   D          Em
 Кылымдарга даңазала! //

[V2]
.             Am             Em
 // Ал (Сен) - Теңир! Ал (Сен) - бийик!
.           C      D      Em
 Ал (Сен) - бүт ааламга Падыша! //

[V3]
.    Em             C
 Жер жүзүнө көз чаптыргын, бир тууган,
.  D              Em
 Жаралгандын баарын кара!
.    Em            C
 // Эч бир адам жасай албаган ишти
.  D             Em
 Жаратты бир Теңир гана! //</lyrics>
<title>Бекем аска зоодой Теңирге келип ATT73</title>
</song>