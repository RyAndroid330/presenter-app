<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>263</hymn_number>
<author>Алмаз Исмаилов, Бурул Шамырканова</author>
<lyrics>[V1]
.Bbm                Ebm           F
 // Мен - сүйүү себүүчү, жаралгам берүү үчүн
.Ebm         F7        Bbm
 Анткени менде чыныгы сүйүү бар. //
.F#              Ab7       Db
 // Ээй анткени менде чыныгы сүйүү бар.
.Ebm         F7        Bbm
 Анткени менде чыныгы сүйүү бар. //

[V2]
.Bbm             Ebm           F
 // Кубаныч бере алам, Кудайдан мен алган.
.Ebm         F7         Bbm
 Кубаныч берчү Кудайым менде бар. //
.F#              Ab7         Db
 // Ээй кубаныч берчү Кудайым менде бар.
.Ebm         F7         Bbm
 Кубаныч берчү Кудайым менде бар. //

[V3]
.Bbm              Ebm        F
 // Эч качан бүтпөгөн, жеңиштин ээсимин
.Ebm        F7            Bbm
 Анткени менде ааламдын Теңири бар. //
.F#             Ab7           Db
 // Ээй анткени менде ааламдын Теңири бар.
.Ebm        F7            Bbm
 Анткени менде ааламдын Теңири бар. //</lyrics>
<key>Bbm</key>
<title>Мен - сүйүү себүүчү ATT263</title>
</song>