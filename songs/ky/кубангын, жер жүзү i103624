<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.     Am            Dm
 // Кубангын, жер жүзү,
.    E                 Dm      Am
 Куткаруучу төрөлдү. Кудайга алкыш! //
.              Em     G         C
 Ал ооруларды алды, күнөөмдү кечирди.
.       Am         Dm               E        Am
 // Ал жарык үмүт берип, кубанычка бизди толтурду! //

[V2]
 // Жар салгын, жер жүзү,
 Жаратканга шаттанып, Теңирге алкыш! //
 Сенин өмүрүң үчүн Ал Өз жанын берди.
 // Жашоонун демин үйлөп, Ыйык Рухка бизди толтурду. //

[V3]
 // Жандансын жер жүзү,
 Сүйүүсүнө кубанып, Ыйсага алкыш! //
 Ал ыйык каны менен азгырыкты жеңген.
 // Жүрөккө оту жанып, сүйүүсүнө бизди толтурду. //</lyrics>
<title>Кубангын, жер жүзү</title>
</song>