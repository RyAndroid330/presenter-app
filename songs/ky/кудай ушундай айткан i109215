<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am
 // Кудай ушундай айткан:
.Dm
 Сени эч качан калтырбайм,
.E                  Am   E
 Сени эч качан таштабайм. //

[C1]
.  F       E        Am
    Ошондуктан тайманбай айтабыз:
.  Dm         E
    Коркпойм, коркпойм!
.  F      E       Am
    Эгем - колдоочум
.              Dm         E
   Адамдар мага эмне кыла алат?
.           Am
   Эмне кыла алат?</lyrics>
<title>Кудай ушундай айткан</title>
<author>Илияс Турсун</author>
</song>