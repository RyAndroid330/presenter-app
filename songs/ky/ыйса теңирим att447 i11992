<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.    Em          C
 // Ыйса Теңирим, Ыйса Теңирим,
.D               Em
 Ыйса Теңирсиң бул ааламга. //

[V2]
.C      D     Em
 Анын аты баарынан бийик,
.C       D     Em
 Анын такты түбөлүк бекем,
.Cmaj7   D    G      Em
 Анын каны шайтанды жеңди,
.Cmaj7    Em     B7
 Куткаруучум Ыйса Теңирим.</lyrics>
<title>Ыйса Теңирим ATT447</title>
<hymn_number>447</hymn_number>
<author>Рамон Пинк</author>
</song>