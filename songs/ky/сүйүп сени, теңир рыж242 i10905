<?xml version="1.0" encoding="UTF-8"?><song><title>Сүйүп Сени, Теңир РЫЖ242</title>
<key>Dm</key>
<lyrics>[V1]
.Dm            A
 Сүйүп Сени, Теңир,
.A             Dm
 Сүйүп Сени, Теңир,
.Dm            C
 Сүйүп Сени, Теңир,

[C1]
.      C          F
   Чын дилден ишенип,
.      D             Gm
   // Издериң менен жүрөйүн,
.  C                F
   Талбай ээрчийин артыңан,
.   Dm  Gm
   Табынайын Сага дайым,
.   A            Dm
   Ишенип чын дилден. //

[V2]
 /// Кызмат кылам Сага, Теңир ///

[V3]
 /// Жашайын Өзүң сыяктуу ///</lyrics>
<hymn_number>242</hymn_number>
</song>