<?xml version="1.0" encoding="UTF-8"?><song><aka>Бир Өзүңө</aka>
<lyrics>[V1]
.Am                   E7
 Бир Өзүңө муктажмын Теңир Ата
.      E7         Am
 Жардам бер жүрөктөгү кайгыма
.   Dm                E7
 // Жалгыз Сенден суранаарым Атаке
.Am        Dm       E7 Am
 Жан-дүйнөмдөн орун алчы Атаке. //

[C1]
.     Am          E7               Am
   // Жалынам сыздап келем, атыңды даңктап келем.
.  Am             E7           Am
   Уга көр зар муңумду, кабыл ал сөзүмдү. //

[V2]
.Am                    E7
 Бир Өзүңө муктажмын Теңир Ата
. E7               Am
 Жардам бер алсыздыкта жаныма.
.   Dm               E7
 // Жараткан жалгыз Кудай Сен болсоң
.Am       Dm       E7    Am
 Айыктырчу, Сооротуучу Өзүң гана. //</lyrics>
<key>Am</key>
<title>Мен Кудайга муктажмын ATT84</title>
<hymn_number>84</hymn_number>
<author>Мунара Бектурсунова</author>
</song>