<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>180</hymn_number>
<lyrics>[V1]
.   D            Bm    G              A
 // Кел, мага батаңды төгүп, күүлөп жүрөк кылдарын
.D         Bm    G      A      D
 Ырайымыңа бөлөнүп, Сени даңктап ырдайын. //

[C1]
.     D             Bm
   // Жардам берчи, Аска-Ташым!
.   G            A
   Толтуруп Өз күчүңө.
.       D         Bm
   Мени колдоп, алып барчы
.  G       A   D
   Асмандагы үйүмө. //

[V2]
.      D          Bm    G              A
 // Обонуңа мени салып, өз тилиңде сүйлөткүн
.D              Bm    G     A      D
 Эркин болом, тамыр алып, негизинен сүйүүңдөн. //</lyrics>
<key>D</key>
<title>Кел, мага батаңды төгүп ATT180</title>
</song>