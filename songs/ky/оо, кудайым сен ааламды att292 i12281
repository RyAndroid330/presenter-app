<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>292</hymn_number>
<author>Пете Санчез Джр.</author>
<copyright>1977 Пете Санчез, Джр.</copyright>
<lyrics>[V1]
.    D    Em A7          D    Bm
 // Оо, Кудайым, Сен ааламды жараттың.
.       Em       A7      D
 Сен бардык булуттардан жогорусуң. //
.      D          A         G           D
 // Сага сыйынам, Сага сыйынам, Сага сыйынам, Кудайым. //

[V2]
.D      Em  A7        D     Bm
 // Оо, Кудайым, Сен ааламды жараттың.
.       Em       A7      D
 Сен бардык булуттардан жогорусуң. //
.      D          A          G           D
 // Сага табынам,  Сага табынам, Сага табынам, Кудайым. //

[V3]
.D     Em  A7       D    Bm
 // Оо Кудайым, бекем Сенин убадаң,
.        Em        A7      D
 Берген сөзүң ар убакта аткарылат. //
.      D          A          G           D
 // Сага кайрылам, Сага кайрылам, Сага кайрылам, Кудайым. //

[V4]
.D     Em  A7        D      Bm
 // Оо Кудайым, Сенде чындык, акыйкат
.      Em        A7          D
 Сага ишенген ар бир адам куткарылат. //
.     D         A         G          D
 // Сага ишенем, Сага ишенем, Сага ишенем, Кудайым. //</lyrics>
<key>D</key>
<title>Оо, Кудайым Сен ааламды ATT292</title>
</song>