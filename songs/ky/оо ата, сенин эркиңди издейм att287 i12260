<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>287</hymn_number>
<title>Оо Ата, Сенин эркиңди издейм ATT287</title>
<key>Fm</key>
<lyrics>[V1]
.        Fm          Bbm
 // Оо Ата, Сенин эркиңди издейм,
.  Eb           Ab
 О Ата, күчүңө толгум келет.
.  Db          Gdim
 О Ата, мен Сени даңазалайм,
.     G        C7
 Теңирим, Падышам! //

[C1]
.      Fm            Bb
   Аллелуя! Сенин эркиңди издейм.
.      Eb           Ab
   Аллелуя! Күчүңө толгум келет
.      Db             Gdim
   Аллелуя! мен Сени даңазалайм.
.       G      C
   Теңирим, Падышам.

[V2]
.        Fm        Bbm
 // Үйрөткүн жүзүңдү издегенди,
.      Eb         Ab
 баарынан жогору сүйүп Сени,
.    Db         Gdim
 Берейин курмандыкка денемди,
.       G           C7
 Күн сайын, саат сайын. //</lyrics>
</song>