<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>154</hymn_number>
<author>Рахиль Ысыева</author>
<key>C</key>
<lyrics>[V1]
.   C     Am       Dm          G
 // Жүрөктөгү ойлорумду, соттой турган тирүү Сөзүң.
. C       Am       Dm         G
 Ниетимди, жолдорумду, көрүп турган Ыйса Өзүң. //

[V2]
.C            Am     Dm       G
 // Алкыш Сага, Кудай, Ата. Алкыш Сага! //

[V3]
.   C     Am            Dm         G
 // Жашырылган эч бир жан жок, Теңир, Сенин бет алдыңда.
.C      Am           Dm         G
 Ишибизге, сөзүбүзгө да, жооп беребиз бардыгына. //</lyrics>
<title>Жүрөктөгү ойлорумду ATT154</title>
</song>