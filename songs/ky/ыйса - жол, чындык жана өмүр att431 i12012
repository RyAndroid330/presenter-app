<?xml version="1.0" encoding="UTF-8"?><song><title>Ыйса - жол, чындык жана өмүр ATT431</title>
<lyrics>[V1]
.D                 A7
 // Ыйса - жол, чындык жана өмүр,
.Bm         G         A7
 Ишеним, үмүт, тынчтык, сүйүү,
.D             A7
 Ал Өзү - жарык, биз да жарыкпыз,
.Bm      G   A7     D
 Берди бизге түбөлүк өмүр. //

[V2]
.D          A7
 // Ыйса Машаяк менин жандоочум,
.Bm        A7   G     D
 Ыйса Машаяк менин коргоочум.
.D         A7
 Ыйса Машаяк менин жыргалым,
. Bm    G     A7     D
 Кубанычым, тынчтыгым, сүйүүм. //</lyrics>
<key>D</key>
<author>Рахиль Ысыева</author>
<hymn_number>431</hymn_number>
</song>