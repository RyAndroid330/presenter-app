<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>371</hymn_number>
<key>D</key>
<lyrics>[V1]
.   D          Bm
 // Теңир менен жеңебиз,
. G           A
 Жеңиш бизге келди Кудайдан.
.        D          Bm
 Душмандын күчтөрүн тепселейбиз,
.  G      A     D
 Ыйса Теңирдин Атынан. //

[C1]
.     D       G
   // Душмандарың качып кетет,
.   A               D
   Сага эч ким каршылык кыла албайт.
.   D              G
   Шайтан бут алдында тепселет,
.    A           D
   Ыйса Теңирдин атынан. //

[V2]
.   D          Bm
 // Жеңиш ырын ырдайбыз,
. G        A
 Кудайыбызды даңазалап,
.      D          Bm
 Элге эркиндик жарыялайбыз,
.  G      A     D
 Ыйса Теңирдин атынан. //</lyrics>
<title>Теңир менен жеңебиз ATT371</title>
</song>