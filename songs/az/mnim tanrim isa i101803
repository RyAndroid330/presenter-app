<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Yolunu sənin axtarıram,
 Ardınca getməyim üçün.
 Rəbbim sənə inanıram,
 Xilası əldə etmək üçün. //

[V2]
 // Yollarını sən mənə göstər,
 Ardınca getməyi öyrət.
 Məni haqqı yolu ilə,
 Sən apar. //

[V3]
 // Sənsən padşahım mənim,
 Sənə güvənirəm Rəbbim.
 Səni sevirəm, Sənə bağlıyam,
 Mənim Tanrım İsa. //

[V4]
 // Ürəyimi sənə verirəm,
 Yalnız sənə güvənirəm.
 Məni tənha qoyma sən,
 Sənə ümid bağlayıram. //

[V5]
 // Yollarını sən mənə göstər,
 Ardınca getməyi öyrət.
 Məni haqqı yolu ilə,
 Sən apar. //</lyrics>
<title>MƏNİM TANRIM İSA</title>
</song>