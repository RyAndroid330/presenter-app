<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>227</hymn_number>
<title>Əncir ağacı bar verməsə də İL227</title>
<lyrics>[V1]
 Əncir ağacı bar verməsə də,
 Tənəklərdə üzüm olmasa da,
 Zeytun ağacı məhsul verməsə də,
 Mən Rəbdə sevinəcəyəm,
 Xilaskarıma görə şadlıq edəcəyəm!

[V2]
 Zəmilərdə buğda bitməsə də,
 Ağılda qoyun olmasa da,
 Tövlədə mal-qara tapılmasa da,
 Mən Rəbdə sevinəcəyəm,
 Xilaskarıma görə şadlıq edəcəyəm!</lyrics>
</song>