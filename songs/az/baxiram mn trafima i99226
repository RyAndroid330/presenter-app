<?xml version="1.0" encoding="UTF-8"?><song><title>Baxıram mən ətrafıma</title>
<lyrics>[V1]
 Baxıram mən ətrafıma,
 Hamı dərdli // bu dünyada. //
 Yalvarıram, ey Allahım,
 Sıxıntıdan // qurtar məni. //

[C1]
   // Tərk etmişdim doğru yolu, Günahlarla içim dolu.
   Yalvarıram, ey Allahım, Günahımdan qurtar məni. //

[V2]
 Hər dərdimi Sənə dedim,
 Xilaskarım // Sənsən mənim. //
 Həmdlər olsun, ey Allahım.
 Sən təsəllim // oldun mənim. //</lyrics>
</song>