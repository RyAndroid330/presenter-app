<?xml version="1.0" encoding="UTF-8"?><song><title>GƏLMİŞİK BU DÜNYAYA BİZ</title>
<lyrics>[V1]
 // Gəlmişik bu dünyaya biz, günah dolu əllərimiz, //
 Diz çöküb önündə yalvardım hər zaman Xudaya.
 Günah dolu, əzab dolu bu dünya eşit bizi Xudaya.
 Eşit bizi Xudaya.

[C1]
   // Eşit Ya Rəbb bizi, eşit bu səsimizi,
   Sənə qurban gətiririk bu sınıq qəlbimizi. //

[V2]
 // Çox çəkmişik bu dünyanın kədər dolu yükünü biz, //
 Diz çöküb önündə yalvardım hər zaman Xudaya.
 Günah dolu, əzab dolu bu dünya eşit bizi Xudaya.
 Eşit bizi Xudaya.

[C2]
   //// Eşit Ya Rəbb bizi, eşit bu səsimizi,
   Sənə qurban gətiririk bu sınıq qəlbimizi. ////</lyrics>
</song>