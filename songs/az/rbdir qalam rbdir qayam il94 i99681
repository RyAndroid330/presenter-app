<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>94</hymn_number>
<title>Rəbdir qalam, Rəbdir qayam İL94</title>
<lyrics>[V1]
 Rəbdir qalam, Rəbdir qayam,
 Qorxu, hürkü bilmərəm mən.
 Sağ əliylə məni tutur, sevgi, qayğı duyuram mən.

[C1]
   Rəbdir qalam, Rəbdir qayam,
   Hüzurunda yaşaram mən.
   Adım həyat kitabında,
   Sülh, əminlik tapıram mən.

[V2]
 Rəbdir qalam, Rəbdir qayam, ilhamlanıb coşuram mən,
 İsa dilimin əzbəri, sözləriylə yaşaram mən.

[C2]
   Rəbdir qalam, Rəbdir qayam,
   Yalnız Ona güvənirəm.
   Cəlalını vəsf edirəm, Ona doğru gedirəm mən.

[V3]
 Rəbdir qalam, Rəbdir qayam, Ona güvənib dururam.
 İmdadıma çatan Odur, sığınacaq tapıram mən.

[C3]
   Rəbdir qalam, Rəbdir qayam, mənə görə qurban gedən.
   Müqəddəs Ruh yol yoldaşım, sevgisiylə yaşaram mən.
   Rəbdir qalam, Rəbdir qayam,
   Səmavi məskənədir yolum.
   İsa açıb qollarını, orda xoşbəxt, rahat olaram mən.</lyrics>
</song>