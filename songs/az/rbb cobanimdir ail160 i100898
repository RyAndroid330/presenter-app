<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>160</hymn_number>
<title>Rәbb Çobanımdır AİL160</title>
<key>Em</key>
<lyrics>[C1]
.     Em                D
   // Rəbb çobanımdır. Çəmənlərdə dincəldir.
.  C                  B7
   Məni sakit suların kənarına aparır //

[V1]
.Em                D
 İçimi O yeniləyər mənim önümdə gedər
.C              B7
 Doğru yollarda Öz adı uğruna
.Em               D
 Mən qaranlıq ölüm vadisindən keçsəm
.C                   B7                 Em
 Pislikdən qorxmaram çünki Sən mənimləsən

[V2]
.Em                 D
 Sən düşmənlərimin önündə mənə
.C             B7
 Süfrə qurarsan başıma yağ çəkərsən
.Em            D
 Ömrüm boyunca yaxşılıq və sevgi
.C              B7              Em
 İzləyəcək məni evində yaşayacağam</lyrics>
</song>