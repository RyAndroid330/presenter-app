<?xml version="1.0" encoding="UTF-8"?><song><title>Mənim üçün qızıldan da baha MÇ43 AİL81</title>
<lyrics>[V1]
.Em            Am
 Mənim üçün qızıldan da baha
.B7            Em   B7
 Almazdan da qiymətli
.Em            Am
 Görünüşün yaqutdan da gözəl
.B7             Em B7
 Böyük Rəbbim Allahım

[V2]
.C       D     G         Em
 Səndən başqa Xilaskarım yox
.Am      B7   Em         E
 Səndən basqa ümid yerim yox
.C       D     G            Em
 Səndən başqa qüvvət verənim yox
.Am       B7       Em
 Yalnız Rəbbim Allahım</lyrics>
<key>G</key>
<author>DSJ</author>
<hymn_number>43</hymn_number>
</song>