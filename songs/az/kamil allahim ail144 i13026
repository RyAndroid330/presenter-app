<?xml version="1.0" encoding="UTF-8"?><song><title>Kamil Allahım AİL144</title>
<key>Dm</key>
<lyrics>[V1]
.      Dm              C
 Sənin kamilliyin tapılmaz sərhədi,
.     Bb       Gm         A
 Mənə Sənlə olmaq hər an əzizdir.
.      F                   C
 Kipriklərimdən Sən göz yaşları silən,
.      Gm               A
 Doldurursan məni diri inamla.
.        Bb                 A
 Heyran oluram Sənin gözəlliyinə,
.          Bb
 Qorxmadan şübhəsiz əllərimi
.              A
 Sənə mən yönəldirəm.

[C1]
.        Dm            F
   Kamil Allahım səcdə edirəm,
.      Gm            A
   məhəbbətinlə bürü məni Sən.
.       Dm               F
   Ruhunla doldur, qüvvətli elə,
.         Gm
   Heçbir şey güclü deyil
.    A                Dm
   Sənin kamil məhəbbətindən.</lyrics>
<author>Spaseniye tserkovʹ g. Vishnevoye, Lyubovʹ Dyachenko</author>
<hymn_number>144</hymn_number>
</song>