<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ürəyimdə hər zaman bir arzu olub,
 Allahı görməyi, onu sevməyi. //
 // Nəhayət arzuma çatmışam bu gün,
 Allahı görməyə gəlmişəm bu gün. //

[C1]
   // Ya Rəbb gözəlsən, nur üzlü həyatsan,
   Həm ürəyim, hıəm də tacım olacaqsan mənim. //

[V2]
 // Qəlbimdə dualar etsin Tanrıya,
 Kömək əlini uzadar mənə. //
 // Göz yaşımı silib bağrına basar,
 Müqəddəs ruyhunda məni yaşadar. //

[C2]
   //// Ya Rəbb gözəlsən, nur üzlü həyatsan,
   Həm ürəyim, hıəm də tacım olacaqsan mənim. ////</lyrics>
<title>YA RƏBB GÖZƏLSƏN</title>
</song>