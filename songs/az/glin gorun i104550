<?xml version="1.0" encoding="UTF-8"?><song><author>Adrienne Neusch</author>
<key>Em</key>
<lyrics>[V1]
.   Em
 // Gəlin görün Rəbbin əzəmətini
.Cmaj7
 Heyrətəngiz işlərinə sevinin
.Am
 Qüdrəti ilə cavab verir
.      B7
 Allahımız kimisi yox //

[C1]
.      Em
   // «Əməllərin nə qədər zəhmlidir!
.  Cmaj7
   O qədər qüdrətlisən ki,
.              Am
   Düşmənlərin qarşında diz çökür!
.                    B7
   Bütün dünya səcdə edir Sənə!» //

[V2]
.   Em
 // Gəlin görün Allahın qüdrətini
.Cmaj7
 Odur bizə zəfər qazandıran
.Am
 Millətlərin sevincidir
.      B7
 Allahımız kimisi yox //</lyrics>
<title>Gəlin Görün</title>
</song>