<?xml version="1.0" encoding="UTF-8"?><song><title>Göydə olan Atamız</title>
<lyrics>[V1]
 Göydə olan Tanrımız,
 Adın Müqəddəs tutulsun.
 Padşahlığın gəlsin,
 Göydə yerdə iradən olsun.
 Gündəlik çörəyimizi,
 Bizə sən bu gün ver.
 Bizdə olan günahı,
 Bizə bağışla, Tanrım.

[C1]
   // Yalvarıram, Uca Tanrım!
   Bizi sınağa çəkmə,
   Bizi iblisdən qoru,
   Mənim Tanrım, Mənim Allahım! //

[V2]
 // Sən bizimsən, biz Səni.
 Tanrımızsan bizlərin.
 Yolumuz, çırağımız,
 Yeganə Allahımız //</lyrics>
</song>