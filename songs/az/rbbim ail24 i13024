<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em          C   G
 // Çevirdin suyu şəraba
.Em       C      G
 Şəfa verdin korlara
.        Am          D
 Sənə bənzəyən, heç yoxdur //

[V2]
 // Qaranlığa parlayan,
 küldən bizi qaldıran,
 Sənə bənzəyən, heç yoxdur. //

[C1]
.     Em               C
   // Rəbbim böyükdür, O möhtəşəmdir
.  G               D
   Rəbbim hamıdan uca, ucadır.
.  Em             C              G       D
   Şəfa verənim, mənim qüvvətim, Rəbbim Rəbbim. //

[B1]
.  Em
   əgər Rəbb mənimlədirsə,
.  C
   kim mənə qarşı durar,
.  G
   əgər mənimlədirsə
.  D            Em C G D
   Məni kim dayandırar.</lyrics>
<aka>Çevirdin suyu şəraba</aka>
<title>Rəbbim AİL24</title>
<hymn_number>73</hymn_number>
<author>Chris Tomlin, Matt Redman, Jonas Myrin, Jesse Reeves</author>
</song>