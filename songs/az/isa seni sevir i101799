<?xml version="1.0" encoding="UTF-8"?><song><title>ISA SENI SEVIR</title>
<lyrics>[V1]
 // Bəlkəm çox susamısan,
 Bəlkə tənha qalmısan.
 Bəlkəm çox yorulmusan,
 Bir yol var adı İsa. //

[C1]
   // Sənə ümüdlər verər,
   Hər bir an səni səvən.
   Yolunu çox gözləyən
   Biri var adı İsa. //

[V2]
 // Qızıldan onu tacı,
 Əbədi onunladı.
 Yaşadar onu adı,
 Tanrım var adı İsa. //

[V3]
 // Sənə ümüdlər verər,
 Hər bir an səni səvən.
 Yolunu çox gözləyən
 Biri var adı İsa. //

[V4]
 Qızıldan onu tacı,
 Yaşadar onu adı.
 Səni çox o arzular,
 Əlindən səni tutar.</lyrics>
</song>