<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ürəyim, sakitləş, sakitləş, ürəyim,
 Allahın kəlamı, sözləri ilə.
 Ürəyim, eşit, eşit, ürəyim,
 Müqəddəs Ruhun səsini.

[C1]
   Oxu, ürəyim, oxu, izzətləndir Allahı.
   Oxu, ürəyim, oxu, bütün ömrüm boyu.

[V2]
 Ürəyim, oxu, oxu Allaha
 Alqışlar oxu, minnətdarlıqla.
 Bil ki, səni sevir, sevir O.
 Bil ki, səni bəsləyir O.

[V3]
 Ürəyim, yada sal, yada sal, ürəyim,
 Həmişə Allahın mərhəmətini.
 Təmiz, müqəddəs yaşamaq üçün
 Yadda saxla Allahın sözlərini.</lyrics>
<title>Ürəyim, sakitləş, sakitləş, ürəyim İL543</title>
<hymn_number>543</hymn_number>
</song>