<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<lyrics>[V1]
 Hər gün səhər və gecə
 Sənin önünə mən gəlincə
 Axtararaq sənin üzünü
 Aç mənə sən özünü

[C1]
   Sən var olan müqəddəs Rəbb Allah
   Sən var olan müqədddəs Rəbb Allah,
   Allah, Allah, Müqəddəs Rəbb Allah
   Allah, Allah, Müqəddəs Rəbb Allah

[V2]
 Gecə-gündüz ağladım,
 Yalnız sənə görə yalvardım.
 Heç nəyi vacib saymadım
 Bir tək səni axtardım</lyrics>
<title>Hər gün</title>
</song>