<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.C                 D         G
 Bütün hakimlərdən yüksəksək Sən,
.C                    D          G
 bütün təbiətdən və bütün xilqətdən.
.Em                                  C     G
 Bütün hikmət və insan yollarından yüksəksən,
.Am                   D
 Əzəldən mövcüd olan Şahsan.
.         C         D        G
 Bütün rütbələrdən yüksəksən Sən,
.         C               D     G
 insan gördüyü bütün xariqələrdən.
.           Em                    C    G
 Bütün cah-cәlalət var-dövlətdən yüksəksən,
.Am                     B7
 bənzərin yoxdur sevən Tanrı.

[C1]
.  G          Am     D         G
   Rüsvay olaraq çarmıxa çəkildin,
.  G         Am    D      G
   Ata tərəfdən inkar edildin.
.       Em    D           C             Am    F#    C
   Palçıqda əzilmiş qızıl gül kimi əfv etdin, məni sevdin
   Yüksəksən Sən.</lyrics>
<title>Rüsvay olaraq çarmıxa çəkildin</title>
<author>Lenny LeBlanc, Paul Baloche</author>
<hymn_number>58</hymn_number>
</song>