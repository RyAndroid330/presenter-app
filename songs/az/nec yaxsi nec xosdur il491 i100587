<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>491</hymn_number>
<title>Necə yaxşı, necə xoşdur İL491</title>
<lyrics>[V1]
 Necə yaxşı, necə xoşdur
 Qardaşlar bir olanda.

[C1]
   Necə yaxşı, necə də xoşdur
   Qardaşlar birgə yaşayanda.

[V2]
 Bu sanki qiymətli Məsh yağına bənzər -
 Harunun başından üzünə süzülən.

[C2]
   Bu qiymətli Məsh yağına bənzər
   Harunun ətəklərinədək süzülən.

[V3]
 Bu Hermon dağına göylərdən enən,
 Sionun quraq torpaqlarına düşən,

[C3]
   Bu Hermona göylərdən enib
   Siona düşən həzin şeh kimidir.

[V4]
 Rəbb Sion dağında vəd etdi xalqına
 Əbədi xeyir-dua və əbədi həyat.

[C4]
   Rəbb Sionda vəd etdi xalqına
   Əbədi xeyir-dua və əbədi həyat.</lyrics>
</song>