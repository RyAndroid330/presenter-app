<?xml version="1.0" encoding="UTF-8"?><song><title>Əziziyəm, ağlama,başa qara bağlama İL425</title>
<lyrics>[V1]
 Əziziyəm, ağlama,başa qara bağlama,
 İsa xilas gətirdi, düşmənə bel bağlama.

[C1]
   Məsih gəldi Göylərdən, bir yol saldı Göylərə,
   Bəxtəvər o kəsə ki, yolun saldı Göylərə.

[V2]
 Əzizim, qoşa dağlar, durub yanaşı dağlar,
 Məsih orda Qan töküb, bizi nicata bağlar.

[C2]
   Əziziyəm, gül açdı, solmuş bağlar gül açdı,
   Müjdə torpağa gəldi, qara torpaq gül açdı.

[V3]
 Əzizim, işıq saçdı, zülmətdə işıq saçdı,
 İsa zühur eylədi, qəlblərə işıq saçdı.

[C3]
   Əziziyəm, yan gedər, kədər, qüssə yan gedər,
   Məsihi qəbul etsən, lənət səndən yan gedər.</lyrics>
<hymn_number>425</hymn_number>
</song>