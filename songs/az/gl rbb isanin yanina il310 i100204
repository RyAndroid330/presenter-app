<?xml version="1.0" encoding="UTF-8"?><song><author>Brian Doerksen</author>
<hymn_number>310</hymn_number>
<lyrics>[V1]
 Gəl, Rəbb İsanın yanına, gəl, indi ürəyini ver Ona,
 Gəl, olduğun tək indi gəl,
 Gəl, Rəbbin səni qəbul edər, gəl.

[C1]
   Bir gün hamı deyəcək: «İsa Rəbdir»,
   Bir gün hamı diz çökəcək.
   Bu gün hələ vaxt var tövbə etməyə,
   Rəbbi qəbul etməyə.

[V2]
 Gəl, səni yanına səslər, gəl, səni Ata kimi sevər,
 Gəl, ürəyini ver Ona, gəl, olduğun kimi gəl, Rəbbə gəl.

[V3]
 Gəl, Rəbb İsaya həmd edək, gəl, Xilaskarımızı sevək,
 O bizi birinci sevib, gəl, bizə görə qurban gedib, gəl.

[V4]
 Gəl, Rəbb İsaya həmd edək, gəl, Xilaskarımızı sevək,
 Gəl, ürəyini ver Ona, gəl, olduğun kimi gəl, Rəbbə gəl.</lyrics>
<title>Gəl, Rəbb İsanın yanına İL310</title>
</song>