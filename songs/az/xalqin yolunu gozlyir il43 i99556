<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>43</hymn_number>
<title>Xalqın yolunu gözləyir İL43</title>
<lyrics>[V1]
 Xalqın yolunu gözləyir, haleluya, haleluya,
 Gəlinin özünü bəzəyir, haleluya, amin!
 İstəyirik Sən gəlincə, haleluya, haleluya,
 Sənin tək kamilləşək, haleluya, amin!

[C1]
   Maranata, maranata, maranata,
   Rəbbim gəlir.

[V2]
 Yer üzünə səpələnən, haleluya, haleluya,
 Xalqın yanına gəlsin, haleluya, amin!
 Zəmilərdə səpələnən, haleluya, haleluya,
 Buğdan qoy tez biçilsin, haleluya, amin!

[V3]
 Lütfünlə bizi doldur, haleluya, haleluya,
 İmanımızı artır, haleluya, amin!
 Ürəyimizi nurlandır, haleluya, haleluya,
 Günahlı nə varsa yandır, haleluya, amin!
 Xalqın yolunu gözləyir, haleluya, haleluya,
 Gəlinin özünü bəzəyir, haleluya, amin!</lyrics>
</song>