<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>129</hymn_number>
<title>Bәlkә Çox Susamısan AİL129</title>
<lyrics>[V1]
.   Em
 // Bəlkə çox susamısan.
.      Am
 Bəlkə tənha qalmısan.
.      D
 Bəlkə çox yorulmusan.
.        Em
 Bir yol var adı İsa. //

[C1]
.          Em                    Am
   // Sənə ümüdlər verən Hər bir an səni sevən
.      D                    Em
   Yolunu çox gözləyən Biri var adı İsa. //

[V2]
.       Em                Am
 // Qızıldan onun Tacı əbədi onunladır.
.     D                  Em
 Yaşayar Onun adı Tanrım var adı İsa. //

[V3]
.       Em                 Am
 // Qızıldan Onun tacı Yaşadar Onun adı
.     D                  Em
 Səni çox O arzular əlindən, səni tutar . //</lyrics>
<key>Em</key>
</song>