<?xml version="1.0" encoding="UTF-8"?><song><title>Allahım nə xoşbəxtəm</title>
<lyrics>[V1]
 // Səni tapandan bəri,
 Qəlbim məhəbbət görürü.
 Şeytanı öz içində,
 Öz xəyanəti boğur. //

[C1]
   Allahım nə xoşbəxtəm,
   Səni çox sevirəm çox.
   Sənin adın böyükdür,
   Səndən böyük kimsə yox.

[V2]
 Qadirsən hər şeyəsən,
 Padşahlıq əlindədir.
 Daha paxıllıq nifrət,
 Pislıik bilmərəm nədir.

[C2]
   Allahım nə xoşbəxtəm,
   Səni çox sevirəm çox.
   Sənin adın böyükdür,
   Səndən böyük kimsə yox.</lyrics>
</song>