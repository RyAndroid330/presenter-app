<?xml version="1.0" encoding="UTF-8"?><song><title>BAĞBAN</title>
<lyrics>[V1]
 // Hər bağın öz bağbanı var,
 Hər ağacın öz barı var.
 Bizim bağın bağbanısan,
 Ürəklərdə məbədin var. //

[C1]
   // İzzət Sənə Ulu Tanrım,
   Şöhrət Sənə Ulu Tanrı.
   Sənin bizlərin çobanısın,
   Özün Allahın oğlusan. //

[V2]
 // Zühür etdin yer üzünə,
 İnanırıq hər sözünə.
 Həyatımız səninlədir,
 Sən məlhəm çək qəlbimizə. //

[V3]
 // İzzət Sənə Ulu Tanrım,
 Şöhrət Sənə Ulu Tanrı.
 Sənin bizlərin çobanısan,
 Özün Allahın oğlusan. //

[V4]
 // Sən Məbədin çobanısan,
 Özün Allahın oğlusan.
 Sözünə sadiq qalaraq,
 Ürəklərdə yaşayırsan. //

[V5]
 /// İzzət Sənə Ulu Tanrım,
 Şöhrət Sənə Ulu Tanrı.
 Sənin bizlərin çobanısın,
 Özün Allahın oğlusan. ///</lyrics>
</song>