<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>206</hymn_number>
<title>Öz həyat yolunu mənə bildirdin İL206</title>
<lyrics>[V1]
 Öz həyat yolunu mənə bildirdin,
 Sənin hüzurunda sevinir qəlbim.

[C1]
   Müqəddəs Ruhunla məni möhürlədin,
   Ruhumu, qəlbimi sevinclə məsh etdin,
   Allahım, Allahım, Allahım mənim,
   Məsihim, Məsihim, Məsihim mənim.

[V2]
 Atamız Allaha həmdlər etməkçün
 Mənə ilham verən Müqəddəs Ruhdur.

[C2]
   Müqəddəs Ruhunla bizləri Özünə
   Sən övladlar edib bizdə izzətləndin,
   Allahım, Allahım, Allahım mənim,
   Məsihim, Məsihim, Məsihim mənim.

[V3]
 Danış, susma, danış, Müqəddəs Ruhum,
 Daxilimdə alış, gücünlə dolum.

[C3]
   Nəsihət ver mənə, Səndən hikmət alım,
   Sənə yaxın olum, qoy Səni tanıyım,
   Allahım, Allahım, Allahım mənim,
   Məsihim, Məsihim, Məsihim mənim.</lyrics>
</song>