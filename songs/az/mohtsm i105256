<?xml version="1.0" encoding="UTF-8"?><song><author>Yaşam Kilisesi</author>
<lyrics>[V1]
.   Bm       Em  A     D    Bm
 // Taxtın önündə gözləyəcəm
.      Em     F#7      Bm
 Qarşında ikən nə söyləyəcəm?
.Em           F#7      Bm   B7
 Söyləyəcəyim bu: Möhtəşəm!  //

[C1]
.  Em                A
   İsa bakirədən doğulan!
.  D                   Bm
   İsa başlanğıcda Yaradan!
.  Em                     F#7
   İsa həm Allah həm də İnsan!
.       Bm  B7
   Möhtəşəm!
.  Em                    A
   İsa heç kəs Sənə bənzəməz!
.  D                 Bm
   İsa səltənətin bitməz!
.  Em                   F#7
   İsa söylədiklərim yetməz!
.       Bm
   Möhtəşəm!

[V2]
.Bm       Em        A    D    Bm
 Mənimlə olsan, utanmayacağam!
.        Em    F#7        Bm
 Ömrüm boyunca minnətdar olaram!
.Em           F#7       Bm  B7
 Olaram minnətdar! Möhtəşəm!

[B1]
.  Bm - F# - D - F# - Bm - F# - Bm
    Möhtəşəm, möhtəşəm...</lyrics>
<key>Bm</key>
<title>Möhtəşəm</title>
</song>