<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>26</hymn_number>
<key>Gm</key>
<lyrics>[V1]
.Gm        D               Gm
 Çətin anımda gəldin köməyimə,
.              D             Gm
 Xilas etdin məni əzabli həyatdan.
.              Cm              Gm
 // Sən həyatımsan, Sən ümidimsən,
.            D                Gm
 Döyünən ürəyim, Allahımsan mənim. //

[C1]
.  Gm            Cm                     Gm
   Kainata Nur saçan, Ulduzlara işiq verən,
.                    D          Cm         D
   Ürəklərə məlhəm çəkən, Nurlu İsamsan, mənim.

[V2]
.Gm                            Gm
 Olma sən peşman etdiyin tövbədən,
.           D             Gm
 Alarsan İsadan Əbədi həyatı.
.   Gm          Cm               Gm
 // Verildi əzəldən sonsuz məbəbbəti,
.              D              Gm
 Seçmişdi dünyadan seçilmişlərini. //</lyrics>
<aka>Kainata Nur</aka>
<title>Çətin anımda gəldin AİL26</title>
</song>