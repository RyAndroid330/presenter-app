<?xml version="1.0" encoding="UTF-8"?><song><aka>Mən Səni sevirəm</aka>
<lyrics>[V1]
 // Mən Səni sevirəm
 Sənə iman edirəm
 Sən mənə Ata oldun
 Mən Sənə övlad oldum //

[C1]
   // Ürəyim gözlərim Yaşla dolur mənim.
   Ay Atam, mənim Atam. Tez gəl Sən apar məni.
   Səninlə bir olmaq istəyirəm ay Atam. //

[V2]
 // Mənə görə vuruldun,
 Mənə görə söyüldün,
 Yolumda qan tökmüsən,
 Məni Sən dəyişmisən. //

[C2]
   /// Ürəyim gözlərim Yaşla dolur mənim.
   Ay Atam, mənim Atam. Tez gəl Sən apar məni.
   Səninlə bir olmaq istəyirəm ay Atam. ///</lyrics>
<title>Ürəyim, gözlərim</title>
</song>