<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ey xalqlar, alqış edin,
 Şərəflə Rəbbə həmd edin!
 Şükür olsun Tanrımıza,
 Göydə olan Atamıza! //

[C1]
   Ey dünya, alqış edin,
   Şükür Tanrımıza!
   Ey dünya səcdə edin,
   Padşaghların, Padşahına!

[C2]
   // Alqış olsun! Həmd olsun! İsa sənə!
   Alqış olsun! Həmd olsun! İsa sənə!
   Alqış olsun! Həmd olsun! İsa sənə! //
   Alqış!</lyrics>
<title>Alqış Olsun</title>
<author>Sabina Panahova</author>
</song>