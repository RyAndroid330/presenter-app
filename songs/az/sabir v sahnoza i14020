<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // İnsan qəlbi paralıdır, sənsiz yaşaya bilmərəm mən,
 Bu dühaya bir yaralıdır, sənsiz yaşaya bilmərəm mən. //

[C1]
   // Bu yarə yoxdur çarə, sənsiz yaşaya bilmərəm mən, //
   Şükür eyləsən sən Tanrıya, çiçəklənər arzular.
   Yardanın əllərində tapacaqsan xoş vədlər. 2 dəfə

[V2]
 // İnsan qəlbi işıq gördü, sənsiz yaşaya bilmərəm mən,
 Bu işığı səndə gördün, sənsiz yaşaya bilmərəm mən, //

[C2]
   // Bu yarə yoxdur çarə, sənsiz yaşaya bilmərəm mən, //
   Şükür eyləsən sən Tanrıya, çiçəklənər arzular.
   Yardanın əllərində tapacaqsan xoş vədlər.</lyrics>
<title>SABİR VƏ ŞAHNOZA</title>
