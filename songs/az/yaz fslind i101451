<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Yaz fəslində sərin külək, qəlbimi dəlib keşər.
 Keçmiş gedən arzular səni mənə bəxş edər.
 Bəxş bir Tanrımı göydən enmiş xilaskarımı,
 Sənə baxışlarını gözəl səınin adını.

[C1]
   // Sənsən İsa Allahım, xoş mahnım, xoş çırağım,
   Sevgi ilə döyünər qəlbim, ürəyim, canım. //

[V2]
 Yaz fəslində olan təbiət səni mənə göstərər,
 Göydə uçan gözəl quşlar səni mənə bəxş edər.
 Bəxş edər bir Tanrını göydən enən bir xilaskarı,
 Sənə olan baxışlarını, gözəl sənin adını.

[C2]
   //// Sənsən İsa Allahım, xoş mahnım, xoş çırağım,
   Sevgi ilə döyünər qəlbim, ürəyim, canım. ////</lyrics>
<title>YAZ FƏSLİNDƏ</title>
</song>