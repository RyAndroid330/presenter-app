<?xml version="1.0" encoding="UTF-8"?><song><author>Sergey Danilʹchenko (Serzh Dani)</author>
<hymn_number>85</hymn_number>
<lyrics>[V1]
 // Lütfünlə doludur bütün yer üzü //
 Lütfünlə Sən qərar çıxarıb,
 sevdin, dərgahına dəvət etdin.
 // Lütfünlə doludur bütün yer üzü //
 Lütfünlə doludur mənim həyatım,
 Lütfünlə Sən qərar çıxarıb,
 sevdin, dərgahına dəvət etdin.

[C1]
   // Xilas etdin, Sən doğrultdun məni,
   Günahdan azad etdin. //
   //// Minnətdaram Sənə, /İsa/, /Rəbbim/ . ////

[B1]
   İzzət, İzzət Sənə İsa oxuyaram,
   İzzət, İzzət Sənə alqış söyləyərəm.

[P1]
   Bütün ruhumla və qəlbimlə Sənə izzət edərəm mən İsa,
   hər zaman.</lyrics>
<key>C</key>
<title>Lütfünlə doludur</title>
</song>