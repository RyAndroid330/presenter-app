<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>236</hymn_number>
<lyrics>[V1]
 İsa, canımı xilas edən,
 Qoy başımı qoyum sinənə.
 Ləkədən qoru Sən məni,
 Mənim İsam, mənim İsam.

[C1]
   Mənim İsam, Xilaskarım,
   Mənim Rəbbim, mənim əziz İsam.

[V2]
 Lütf ancaq Səndə, mənim İsam,
 Xilaskarım, mənim İsam.
 Səninlə olmaq istərəm mən,
 Mənim İsam, mənim İsam.</lyrics>
<title>İsa, canımı xilas edən İL236</title>
</song>