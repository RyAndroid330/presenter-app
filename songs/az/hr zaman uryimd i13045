<?xml version="1.0" encoding="UTF-8"?><song><key>Bb</key>
<lyrics>[V1]
.Bb           C          Am          Dm
 Atəş Sənin Gözlərində, Alovun var ürəklərdə.
.Bb         C             Am          Dm
 Işığından zülmət qaçdı, qüdrətlisən mənim Tanrım.

[P1]
.     Bb                              C
   // Sənin sevgin mənimlədir O, məni yaşadır
.  Am                 Dm
   Həyatımda ürəyimdə atəş kimi yanır //

[C1]
.     Bb
   // Sən mənimləsən
.  C
   Sən mənimləsən
.  Am          Dm
   hər zaman ürəyimdə //

[B1]
.     Bb     C      Am
   // Əbədi, Əbədi, Əbədi
.   Dm
   sevgin Sənin
.  Bb     C
   Əbədi, Əbədi
.  Am        D
   əbədidir bilirəm //</lyrics>
<title>Hər zaman ürəyimdə</title>
<hymn_number>98</hymn_number>
</song>