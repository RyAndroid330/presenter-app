<?xml version="1.0" encoding="UTF-8"?><song><author>Sabina Panahova</author>
<title>Rəbb İsa gəl</title>
<lyrics>[V1]
 Bütün xalqlar, görəcək sevgini
 Bütün xalqlar, biləcək Tanrısın
 // Nə göylərdə və dünyada
 Sənə bənzər yoxdur kainatda //

[C1]
   //// İsa buludlarla gələcək
   Bizi göylərə qaldıracaq
   Və əbədi Yaradana həmd edəcəyik ////

[V2]
 // Rəbb İsa gəl Mərhəmət göstər
 Öz xalqını pis yollardan döndər
 Rəbb İsa gəl, günahları bağışla
 İtaət edirik, biz Sənə İsa! //
 Rəbb İsa gəl!</lyrics>
</song>