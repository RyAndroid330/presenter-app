<?xml version="1.0" encoding="UTF-8"?><song><title>Gur səslə gəldin</title>
<lyrics>[C1]
   // Gur səslə gəldin, Həyatımız oldu Sənin.
   Sən xilas etdin, Çevrəmiz dəyişdi bizim. //

[V1]
 // Rəbbimizsən Sən, Azad etdin bizi bizi.
 Sevincinlə Sən, Doldurdun hər birimizi. //
 // Sən Allahımsan, Tanrımsan, Sən mənim hər gün.
 Sən Xilasımsan, Ümüdümsən, Mənim hər gün. //

[C2]
   // Gur səslə gəldin, Həyatımız oldu Sənin.
   Sən xilas etdin, Çevrəmiz dəyişdi bizim. //

[V2]
 // Gəl, Allahım gəl, Gözləyirik hər gün Səni.
 Gəl, Ya Rəbb İsam, Sevirik biz Səni, Səni. //
 // Gəl, Ya Rəbbim gəl, Gözlədik biz artıq Səni.
 Gəl, Ya Rəbbim gəl, Yalvarırıq Sənə tez gəl. //

[C3]
   // Gur səslə gəldin, Həyatımız oldu Sənin.
   Sən xilas etdin, Çevrəmiz dəyişdi bizim. //</lyrics>
</song>