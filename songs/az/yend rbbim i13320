<?xml version="1.0" encoding="UTF-8"?><song><title>Yenədə Rəbbim</title>
<lyrics>[V1]
 Yenədə Rəbbim Sənin önündəyəm
 Günahlarımı etiraf edirm
 Sən də məni, əhv edirsən həmişə
 Bilirəm Rəbbim sən sevirsən.

[C1]
   Rəbbim Padşahım, mənim Ümidgahım
   Sevimli Allahım mənim, Padşahım
   Qüdrətli olanım mənim Qalxanım
   Bir sözlə uca, əbədi Xilaskarım. Eeee

[V2]
 Bu gün yenə Ata sənin öndündəyəm
 Səni çağırıb səni səsələyirəm
 Sənlə olmaq həmişə istəyirəm
 Güc ver Ata səndə möhkəm olum.</lyrics>
<hymn_number>69</hymn_number>
</song>