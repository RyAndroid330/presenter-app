<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Bəlkə çox susamısan,
 Bəlkə tənha qalmısan.
 Bəlkə çox yorulmusan.
 Bir yol var İsa. //

[C1]
   // Sənə ümidlər verən,
   Hər bir an səni sevən
   Yolunu çox gözələyən,
   Biri var adı İsa. //

[V2]
 // Qızıldan onun tacı,
 Əbədi onunladır,
 Yaşayar onun adı,
 Tanrım var adı İsa //

[C2]
   // Sənə ümidlər verən,
   Hər bir an səni sevən
   Yolunu çox gözələyən,
   Biri var adı İsa. //

[V3]
 // Qızıldan onun tacı,
 Yaşadar onun adı.
 Səni çox o arzular,
 Əlindən sənin tutar. //</lyrics>
<title>BƏLKƏ ÇOX SUSAMISAN</title>
</song>