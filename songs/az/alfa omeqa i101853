<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Sən özün deyirsən budur tez gəlirəm,
 Kalama əməl et yolumu gözlə sən. //

[C1]
   // Gözlərəm yolunu mən, hər axşam, hər səhər,
   Bilirəm gələcəksən, tezliklə gəl İsa. //
   // Gəl İsa Allahım, Gəl mənim Padşahım,
   Gəl mənim ümüdim, Gəl mənim inamım. //

[V2]
 Mən Alfa Ameqa başlanğıc və sonam,
 Birinci axrıncı ta qədimdən varam.

[C2]
   // Gözlərəm yolunu mən, hər axşam, hər səhər,
   Bilirəm gələcəksən, tezliklə gəl İsa. //
   // Gəl İsa Allahım, Gəl mənim Padşahım,
   Gəl mənim ümüdim, Gəl mənim inamım. //</lyrics>
<title>ALFA OMEQA</title>
</song>