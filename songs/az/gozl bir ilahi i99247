<?xml version="1.0" encoding="UTF-8"?><song><title>Gözəl bir İlahi</title>
<aka>Mənim Gözəl Tanrım</aka>
<lyrics>[V1]
 // Bax qopdu tufanlar
 Yenə də yağır yağşlar
 Onlardan qorxmuram
 Çünki Sən yanımdasan //

[C1]
   Səsini duyuram qəlbimdə
   Qorxma, mənimləsən
   Günahdan Mən aldım səni
   Əbədi Mənimləsən.

[V2]
 // Tufanları ram etdim
 Qəlbimə sakitlik verdin
 Sənin Sözünə inanıram
 Sənin vədinə arxayınam //

[C2]
   Mənim Gözəl Tanrım
   Mənim Xilaskarım</lyrics>
</song>