<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hamıdan ucasan, hamıdan böyüksən,
 Hamıdan gözəlsən, ey Tanrım!
 Sən məhəbbətsən, mərhəmətlisən,
 Sən yeganəsən, Rəbbim!

[C1]
   Alqışlayıram Sənin Adını,
   Çünki Sən layiqsən izzətə.
   Və dünyada söz çatmaz
   Sənin məhəbbətini ifadə etmək üçün.

[V2]
 Rəbb Allahımsan, Sən qüdrətlisən,
 Əzəmətlisən, ey Tanrım!
 Sən əbədisən, Sən müqəddəssən,
 Sən yeganəsən, Rəbbim!

[V3]
 Rəbbim İsamsan, Sən Xilaskarsan,
 Sən Padşahımsan, ey Tanrım!
 Sən həyatımsan, Sən ümidimsən,
 Sən yeganəsən, Rəbbim!</lyrics>
<title>Hamıdan ucasan İL38</title>
<hymn_number>38</hymn_number>
</song>