<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>175</hymn_number>
<title>Ürәyim axtarır Sәni AİL175</title>
<lyrics>[V1]
.   Em                    Am
 // Ata bağrına bas məni, başımı qoyum sinənə
.B7                  Em
 Ürəyinin döyüntüsü sevgini söyləsin mənə //

[C1]
.     Am                   Em
   // Ürəyim axtarır Səni, duymaq istərəm sevgini
.  Am
   Dünya mənə zövq verməyir,
.  Em                   E7
   Göstər mənə gözəlliyini //

[V2]
.   Em
 // Sənin sevginə möhtacam,
.Am
 Təsəllim yalnız Səndədir.
.B7                 Em                    (E7)
 Yaralanmış ürəyimə çarə Sənin sevgindədir //</lyrics>
<key>Em</key>
</song>