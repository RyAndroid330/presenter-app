<?xml version="1.0" encoding="UTF-8"?><song><author>Carl Gustav Boberg</author>
<title>Rəbb Allahım heyranlıq mən duyuram</title>
<lyrics>[V1]
.           A2             D
 Rəbb Allahım heyranlıq mən duyuram
.A2      E     Bm    A2
 Uca işlərinə baxan zaman
.                          D
 Rəbb dünyanı yaratdın Öz sözünlə
.A2      E  Bm       A2
 Və idarə etdin qudrətinlə

[C1]
   Sevincinlə coşur mənim qəlbim
   Görkəmini seyr edirəm
   Nə qədər böyüksən Rəbb Allahım
   Hər gün hər an şükr edirəm

[V2]
 Mən baxıram saysız ulduzlara
 Uzaqdakı günəşə və aya
 Altın toplar kimi parıldayırlar
 Gözəl dünyamızın ətrafında

[V3]
 Mən qurbanın haqqında düşünəndə
 Xilasın dəyərini görürəm
 Sənin sevgini dərk etmək çətindir
 Günahm üçün Sən əzab çəkdin</lyrics>
<key>A</key>
</song>