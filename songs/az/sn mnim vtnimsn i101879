<?xml version="1.0" encoding="UTF-8"?><song><title>Sən mənim vətənimsən</title>
<lyrics>[V1]
 // Sən mənim vətənimsən,
 Sən mənim diyarımsan.
 Sən mənim məkanımsan,
 Azərbaycanımsan! //

[C1]
   // Alovlandım Azərbaycansan!
   Nurunu xalqlarda görsün.
   Tanrının xeyir-duasın,
   Bütün aləm eşitsin. //

[B1]
   Könlüm nəğmə dolu,
   Seviinc dolu, arzu dolu.
   Bu yolu sevgi yolu,
   Sevgi yolu, nurla dolu,
   Dönüşünüz haqqa doğru.
   Ya Rəbbimiz İlhamlae Mhrimandılr
   Oxuyuruq bu nəğməni,
   Sədalansın sülhə doğru.

[V2]
 Ucadır sənin dağların
 Sərindir sərin suaların
 Gözəldi sənin xalqın
 Azərbaycanım Mənim.

[C2]
   // Alovlandım Azərbaycansan!
   Nurun xalqlarda görsün.
   Tanrının xeyir-duasın,
   Bütün alım eşitsin. //</lyrics>
</song>