<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>112</hymn_number>
<title>Şahın Cahcalalı AİL112</title>
<key>G</key>
<lyrics>[V1]
.  G                Em
 Şahın cahcalalı, geyib əzəmətin
.               C2
 Bütün dünya sevin, bütün cahan sevin
.  G                Em7
 Nura bürünərək, zülməti yox edir
.              C2
 Qaranlıq Tanrının səsindən titrəyir

[C1]
.      G                            Em
   Tanrım böyükdür, birgə deyək Tanrım böyükdür,
.           D      C       D        G
   Hamı bilsin Tanrım, Tanrım böyükdür

[V2]
. G               Em
 Əbədi O yaşar, zaman tabe Ona
.                 C2
 Başlanğıc və sondur, Başlanğıc və sondur
.    G              Em7
 Tanrı vahid üçdür, Ata, Oğul və Ruh
.             C2
 Aslan və Quzudur, Aslan vəe Quzudur

[C2]
.  G                     Em
   Bütün addan yüksək Layiq hər şərəfə
.        C        D        G
   Qalbim oxur Tanrım böyükdür</lyrics>
</song>