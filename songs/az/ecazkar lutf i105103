<?xml version="1.0" encoding="UTF-8"?><song><title>Ecazkar lütf</title>
<lyrics>[V1]
. C               F    C
 Ecazkar lütf - səsi şirin
.              G
 Günahdan qurtadı.
.    C         F    C
 Kor gözlərimi də açdı.
.          G    C
 İtmişdim, tapıldım.

[V2]
.    C          F     C
 Həm məni qorxutdu lütfün,
.               G
 Həm qorxumu sildi.
.  C         F     C
 Sənə iman etdiyim gün
.          G      C
 Lütfün nə xoş gəldi.

[V3]
.    C               F   C
 Çox dərd, sınaq, təhlükədən
.               G
 Keçdim lütfün ilə.
.   C           F    C
 Lütfündür məni yönəldən
.       G   C
 Səmavi Vətənə.</lyrics>
<key>C</key>
<author>John Newton</author>
</song>