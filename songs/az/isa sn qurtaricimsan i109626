<?xml version="1.0" encoding="UTF-8"?><song><title>İsa, Sən qurtarıcımsan</title>
<lyrics>[V1]
 İsa, Sən qurtarıcımsan
 Tək qüvvətim,
 Sarsılmaz qayamsan

[C1]
   Mən sənə güvəndim
   Həyatı öyrəndim
   Sənə olan sevgim
   Əbədi sonsuzdur

[V2]
 Bizləri, qurtardığın üçün
 Ya Rəbb Sənə
 Həmd və şükran olsun

[C2]
   Mən sənə güvəndim
   Həyatı öyrəndim
   Sənə olan sevgim
   Əbədi sonsuzdur</lyrics>
</song>