<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em                         C
 Günəs kimi parlayır üzün Sənin
.       G                  Bm
 Isa izzətlisen, olduqca izzətlisən.
.Em                      C
 Odlu alov kimidir Gözlərin,
.       G                   Bm
 İsa izzətlisən, olduqca izzətlisən.

[C1]
.     Em               C
   // Əzəmətlisən, rəblərin Rəbbi
.  A               Bm     Em
   Əzemətlisən, şahların Şahı. //

[V2]
.Em                        C
 Axar sular kimi səsin Sənin,
.        G                    Bm
 İsa qüdrətlisən, olduqca qüdrətlisən.
.Em                        C
 Ulduzları əlində saxlayırsan,
.         G                  Bm
 İsa qüdrətlisən, olduqca qüdrətlisən.</lyrics>
<title>Günəs kimi AİL45</title>
<author>Jesus Culture</author>
<hymn_number>45</hymn_number>
</song>