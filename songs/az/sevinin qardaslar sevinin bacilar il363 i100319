<?xml version="1.0" encoding="UTF-8"?><song><title>Sevinin, qardaşlar, sevinin, bacılar İL363</title>
<lyrics>[V1]
 Sevinin, qardaşlar, sevinin, bacılar,
 Sevinin, şadlanın, nəğmələr oxuyun.

[C1]
   Qoy sizin aranızda sülh və razılıq olsun,
   Sülh və razılıq burada qovuşsun.

[V2]
 Sevinin, qardaşlar,sevinin, bacılar,
 Böyük Allah, qarşında durub övladların.

[C2]
   Xoşbəxtlik ver onlara ailə həyatında,
   Xoşbəxtlik ver, Rəbbim, övladlarına.</lyrics>
<hymn_number>363</hymn_number>
</song>