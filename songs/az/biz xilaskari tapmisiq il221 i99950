<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>221</hymn_number>
<lyrics>[V1]
 Biz Xilaskarı tapmışıq, dərdi, kədəri atmışıq,
 İstəyimizə çatmışıq, Allah, Sənə minnətdarıq.

[C1]
   Məsih söz veribdir bizə, sadiq qalsaq Rəbbimizə,
   Aparacaqdır Göylərə, Allah, Sənə minnətdarıq.

[V2]
 Məhəbbət verdi O bizə, sevinc doldu qəlbimizə,
 Yaşayırıq biz Məsihlə, Allah, Sənə minnətdarıq.</lyrics>
<title>Biz Xilaskarı tapmışıq İL221</title>
</song>