<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>116</hymn_number>
<title>ТАҤ КОЖОҤЫ СТЈК116</title>
<lyrics>[V1]
 // Таҥдакталып таҥ атса,
 Таҥ кожоҥды Сеге чӱмдейдим.
 Тамырланып кӱн чыкса,
 Кӱӱн-санаамды Сеге сыйлайдым. //

[C1]
   // Телекейди Сен јараткаҥ,
   Албатымды аргадагаҥ.
   Сӱӱжиҥди Сен бердиҥ,
   Алтайыма Сен келдиҥ. //

[V2]
 // Јаскыдагы чечектий,
 Јӱрегимде чечектедиҥ.
 Албатымды сӱӱндирдиҥ,
 Алкыжынды Сен бердиҥ. //</lyrics>
</song>