<?xml version="1.0" encoding="UTF-8"?><song><key>Bm</key>
<lyrics>[V1]
.   Bm       D        G
 // Мактагар, мактагар Ада Кудайды, //
. G         D         A
 Мактагар ончо jайалталар.
. G         Bm
 Мактагар, Ол - Jайаачы,
. Bm        D
 Аллилуйя, Аллилуйя,
.         G
 Кудайга мак, Кудайга мак!

[V2]
 // Хвалите, хвалите, Бога небес, //
 Хвалите, все в ком дыханье есть.
 Хвалите, Он - наш Творец
 Аллилуйя, Аллилуйя,
 Богу хвала, Богу хвала!</lyrics>
<title>МАКТАГАР СТЈК75</title>
<hymn_number>75</hymn_number>
<author>Океан Любви, Сергей Данильченко (Серж Дани), Яна Жарова</author>
</song>