<?xml version="1.0" encoding="UTF-8"?><song><title>КАЖЫ ЛА КӰН СТЈК47</title>
<lyrics>[V1]
.    Em
 // Кажы ла кӱн ару кӱӱниҥле,
. Hm
 Кажы ла кӱн Сениҥ jолыҥла,
. Am
 Кажы ла кӱн Сениҥ Сӱӱжиҥле,
. H7
 Кажы ла кӱн ару кӱӱн-санааҥла. //

[C1]
.      Am               Em
   // Албатым Сени санан jӱрзин.
.    Am                  Em
   Албатым ырысту jакшы jатсын,
.    Am                   Em
   Албатым Сенеҥ алкышту болзын,
.    H7                   Em
   Албатым Сенеҥ кежиктӱ болзын. //

[V2]
 // Кажы ла кӱн быйан айдып,
 Кажы ла кӱн ырыс алып,
 Кажы ла кӱн Сени алкап,
 Кажы ла кӱн Сеге бажырып! //</lyrics>
<key>Em</key>
<author>Юрий Чендыев</author>
<hymn_number>47</hymn_number>
</song>