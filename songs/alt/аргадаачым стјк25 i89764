<?xml version="1.0" encoding="UTF-8"?><song><author>перевод с кыргызского ( Юрий Чендыев)</author>
<hymn_number>25</hymn_number>
<title>АРГАДААЧЫМ СТЈК25</title>
<lyrics>[V1]
.      Am                  Dm
 // Аргадаачым, //  // Сен Jайаачым, //
.        E7           Am
 Иисус Кудай, jӱк ле Сен.
.      Am                 Dm
 // Арыгамда, //  // кӱч сураарым, //
.   E7               Am
 Агару Сӧзиҥ мени ӱредет.

[C1]
.    Am     Dm  G      C
   Сениҥ Сӧзиҥ меге jарык,
.    Am     Dm  E7    Am
   Сениҥ Сӧзиҥ меге азык.
.           Dm    G
   Тӱнде-тӱште арыбайын,
.    Am       Dm   E7
   Агару Сӧзиҥ jӱрӱм берет.

[V2]
 // Jӱрегимде //  // санааларым //
 Сеге jарап турган болзын.
 // Кӧксимнеҥ чыккан //  // сӧстӧримди //
 Агару Тынла майлап салзаҥ.

[C2]
   Јӱрӱмниҥ бажы - Сен, Иисус,
   Јӱрӱмниҥ Jарыгы - Сен, Иисус.
   Jажытта jаткан Сӧзиҥди ачтыҥ,
   Јӱрӱмниҥ байлыгы - Сен, Иисус.</lyrics>
<key>Am</key>
</song>