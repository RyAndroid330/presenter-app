<?xml version="1.0" encoding="UTF-8"?><song><author>Айас Чендыева</author>
<hymn_number>49</hymn_number>
<title>КАНАЙ ЈӰРГЕМ СЕН ЈОККО СТЈК49</title>
<key>Em</key>
<lyrics>[V1]
.    Em                Am
 // Канай jӱргем Сен jокко
. H7                Em
 Jер ӱстинде мен билбей?
. Em               Am
 Сениҥ сӱӱжиҥ эҥ бийик
. H7                    Em
 Кандый jалакай мен билбегем. //

[C1]
.      E          Am
   // Теҥериде Адабыс,
.   D           G   H7
   Азып jӱрген уулыҥды
.   Em             Am
   Кайра jанып келерде,
.   H7                 Em
   Кучактап, «балам» дедиҥ. //

[V2]
 // Сениҥ сӱӱжиҥди эм билип,
 Кӱнӱҥ ле сайын сӱӱнедим.
 Сениҥ туштажыҥ от-куйун,
 Мениҥ jӱрегимде от кӱйди. //</lyrics>
</song>