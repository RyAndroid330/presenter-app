<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.     Am      F   G             Am
 // Мактагылагар теҥериде Улу Кудайды!
.         F    G      Am
 Мактагылагар, ончо мактагылагар! //

[C1]
.     Am F  G                  Am
   // Ончо кайкамчы эткен ижи учун
.  Am    F
   улулалзын. //
.     Am F  G
   // Ончо ӱндӱ ойноткылар
.                 Am
   Јер ӱстинде угулгылазын. //
   // Мактагылагар теҥериде Улу Кудайды!
   Мактагылагар, ончо мактагылагар! //

[V2]
.    Am  F    F
 // Јакшылап шоор, топшуур,
.         Am
 Комус ӱндендирип,
. Am F
 Јаҥар айдып, //
.    Am  F
 // Јакшылап улус ончо бијелеп, ойноп,
.       F
 Бисле келип, //
.  Am
 Мактагылагар!</lyrics>
<title>МАКТАГЫЛАГАР СТЈК76</title>
<hymn_number>76</hymn_number>
</song>