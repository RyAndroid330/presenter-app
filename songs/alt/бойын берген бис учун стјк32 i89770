<?xml version="1.0" encoding="UTF-8"?><song><title>БОЙЫН БЕРГЕН БИС УЧУН СТЈК32</title>
<key>Em</key>
<lyrics>[V1]
.  Em               Am
 Кинчектеристи бойына алып,
.  D             G        H7
 Кереес агашка кададып ӧлгӧн!
.  Em             Am
 Калыгы учун ӧлӱмди jеҥген,
. D            G       H7
 Ӧрӧ ӧзӧргӧ jеҥӱни берген.

[C1]
.         Em
   Канын тӧккӧн мен учун,
.         Am
   Бойын берген мен учун,
.            D
   Берген мен учун,
.          G     H7
   Иисус тагыл болгон.</lyrics>
<hymn_number>32</hymn_number>
</song>