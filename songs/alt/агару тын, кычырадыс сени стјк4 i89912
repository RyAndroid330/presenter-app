<?xml version="1.0" encoding="UTF-8"?><song><author>Артур Суразов</author>
<hymn_number>4</hymn_number>
<title>АГАРУ ТЫН, КЫЧЫРАДЫС СЕНИ СТЈК4</title>
<key>Em</key>
<lyrics>[V1]
. Em               D
 Агару Тын! Агару Тын!
. D     Bm     Em
 Кычырадыс Сени!

[V2]
.     Em            D
 Суузап калган jӱректерди
.      Bm         Em
 Сен кӧрӧдиҥ, Кудайым,
.    Em        D
 Албатыҥныҥ ӱстине
.     Bm          Em
 Сен урулзаҥ, Агару Тын!

[V3]
.     C        Em
 Ӱргӱлjиниҥ суузын
.      C          Bm
 Jакшызынып бис ичерис!
.    Am       Em
 Сениҥ ару сууҥнаҥ
.    D    Bm     Em
 Агару Тынла толорыс!
 Агару Тын! Агару Тын!
 Кычырадыс Сени!</lyrics>
</song>