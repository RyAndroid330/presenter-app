<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<author>Айдын Курманов, Арукей Вуд</author>
<title>АЛТАЙ ТУУЛАРЫС СТЈК23</title>
<lyrics>[V1]
.    Am                  Em
 // Алтай тууларыс айландыра турат,
. G                      Am
 Кайракан кежиги бисти курчап jат. //
.    Am                  Em
 // Чактыҥ-чакка андый ла болуп jат,
.      G                 Am
 Ада Кудай бисти кару кӧрӱп jат. //

[V2]
 // Бир де кубулта jок, бир де уйуктабай,
 Алтайысты качан да таштабайт. //
 // Бистиҥ Алтайыс jайымду болзын,
 Толо аргадаш теҥеридеҥ келзин. //</lyrics>
<key>Am</key>
</song>