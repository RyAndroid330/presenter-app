<?xml version="1.0" encoding="UTF-8"?><song><title>La umbra aripilor Tale</title>
<lyrics>[V1]
 // La umbra aripilor Tale
 Loc de scapare am
 Şi ajutor, şi alinare
 Şi peste răni balsam. //

[C1]
   // Eu strig către Dumnezeu
   Către Cel Preaînalt
   Căci El aude glasul meu
   Mă scapă la loc larg //

[V2]
 // El îmi trimite izbăvirea
 Din mâna celui rău
 Domnul lucrează pentru mine
 Căci sunt copilul Său. //

[V3]
 // Vreau inima să-mi fie tare
 Cu Domnul ne-ncetat
 Şi să-L slujesc, fără-ncetare
 Căci pace El mi-a dat. //</lyrics>
</song>