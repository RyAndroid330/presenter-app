<?xml version="1.0" encoding="UTF-8"?><song><title>Am nevoie de Tine</title>
<lyrics>[V1]
 // Am nevoie de Tine //
 Am nevoie de Tine,
 Isuse Domnul meu.

[V2]
 // Nimeni nu-i ca Tine //
 Nimeni nu-i ca Tine,
 În cer şi pe pământ.

[V3]
 // Te iubesc Isuse //
 Te iubesc Isuse,
 Din toată inimioara mea.

[V4]
 // Te Slăvesc Isuse //
 Te Slăvesc Isuse,
 Din toată inimioara mea.

[V5]
 // Iţi mulţumesc Isuse //
 Îţi mulţumesc Isuse,
 Căci Tu m-ai mântuit.

[V6]
 // Te-ai jertfit Isuse //
 Te-ai jertfit Isuse,
 // Pe cruce-n locul meu //</lyrics>
</song>