<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Vrednic eşti de cinste şi-nchinare,
 Ridicăm mâinile noastre,
 Înălţăm Numele Tău //

[V2]
 Ce mare eşti!
 Şi ce mari minuni faci Tu,
 // Şi ca Tine altul nu-i //
 Ce mare eşti!

[V3]
 // Vrem să spunem lumii despre Tine,
 Cum prin moartea Ta pe cruce
 Tuturor ne-ai arătat //

[V4]
 Căci Tu esti Domn!
 Tu esti Domn cu-adevărat,
 // Şi ca Tine altul nu-i //
 Căci Tu eşti Domn! (Ce mare esti!)</lyrics>
<title>Vrednic eşti de cinste şi-nchinare</title>
</song>