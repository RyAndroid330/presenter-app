<?xml version="1.0" encoding="UTF-8"?><song><title>Isuse, Isuse, primeste-ma la Tine</title>
<lyrics>[V1]
 // Isuse, Isuse, primește-mă la Tine,
 Când eu vin din dureri și suspin. //

[C1]
   // Iartă-mă, iartă-mă, Isuse, al meu iubit!
   Iartă-mă, căci eu mult Ți-am greșit... //

[V2]
 La Tine, la Tine, Isuse, eu voi veni;
 Pe brațul Tău mă voi odihni.

[V3]
 // Isuse, Isuse, pieptul Tău fă-mi căpătâi
 Și cu mâna Ta să mă mângâi!

[V4]
 // Astăzi vin încrezător, scumpul meu Mântuitor,
 Să-mi legi rănile care mă dor. //

[V5]
 // Slavă și mărire Ție, Isuse, Isuse,
 Căci Tu-mi dai bucurii nespuse. //</lyrics>
</song>