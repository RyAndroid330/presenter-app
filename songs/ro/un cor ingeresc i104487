<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em                         D
 // Un cor ingeresc din cer se-aude chemand
.         C                     B
 O, păcătos vin la Isus, vino, vino. //

[V2]
 Refren:
.    G           D
 // Hai, hai la El nu mai sta
.      C                    B
 Azi Isus te cheamă, vino, vino //

[V3]
 // Străin tu dacă eşti, de ce pribeag mai rătăceşti
 N-auzi chemarea lui Isus, vino, vino. //

[V4]
 // Urcand sus pe Calvar, Isus şi-a dat viaţa-n dar
 De-aceea astăzi te chemăm, vino, vino. //</lyrics>
<title>Un cor ingeresc</title>
</song>