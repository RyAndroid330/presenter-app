<?xml version="1.0" encoding="UTF-8"?><song><title>Dumnezeu e dragoste Dumnezeu cel veşnic</title>
<lyrics>[V1]
 // Dumnezeu e dragoste //
 Dumnezeu cel veşnic
 Domn al păcii
 Dumnezeu e dragoste.

[V2]
 // Dumnezeu e adevăr //
 Dumnezeu cel veşnic
 Domn al păcii
 Dumnezeu e adevăr.

[V3]
 // Dumnezeu e lumina mea //
 Dumnezeu cel veşnic
 Domn al păcii
 Dumnezeu e lumina mea.

[V4]
 // Dumnezeu e-l meu Salvator //
 Dumnezeu cel veşnic
 Domn al păcii
 Dumnezeu e-al meu Salvator.

[V5]
 // În curând El vine pe nori //
 Dumnezeu cel veşnic
 Domn al păcii
 În curând El vine pe nori.</lyrics>
</song>