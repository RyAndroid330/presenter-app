<?xml version="1.0" encoding="UTF-8"?><song><title>Sa nu pot Doamne sa ma las</title>
<lyrics>[V1]
 // Sa nu pot, Doamne, sa ma las // o De Tine, niciodata!
 // Chiar de-as lasa la orice pas // o // O dragoste-ngropata. //

[V2]
 // Cu cat ma duc mereu si vin // o Mai singur de oriunde,
 // A Ta iubire mai deplin // o // Doresc a ma patrunde. //

[V3]
 // In orice loc si-n orice rand // o // Cararea-nsingurata
 // Sa mi-o invaluie, mai bland, o // Lumina Ta curata! //

[V4]
 // Sa n-am amar neindulcit, // o Nici nopti neluminate,
 // Nici orizont nestralucit, // o Nici zile zbuciumate! //

[V5]
 // Ci numai Tu sa-mi fii mereu // o Prieten pe-a mea cale,
 // Iar dorul sufletului meu: // o // Trairea voii Tale. //

[V6]
 // Mai greu de-ar fi, la orice pas, // o Sa-mi fie viata toata,
 // Sa pot orice, dar sa Te las // o // Sa nu pot niciodata! //</lyrics>
</song>