<?xml version="1.0" encoding="UTF-8"?><song><title>Isus cel inviat e astăzi printre noi</title>
<lyrics>[V1]
 /// Isus cel înviat e astăzi printre noi ///
 Isus e astăzi printre noi!

[C1]
   /// Lasă-L să te-atingă ///
   Şi vei fii eliberat.
   /// Lasă-L să te-atingă ///
   Vei fii binecuvântat.

[V2]
 /// Mormântul lui Isus şi astăzi este gol ///
 Isus e astăzi printre noi.</lyrics>
</song>