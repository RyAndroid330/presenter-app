<?xml version="1.0" encoding="UTF-8"?><song><title>Cant Aleluia</title>
<lyrics>[V1]
 // Cânt Aleluia, //
 Ție, Dumnezeul meu slăvit!
 // Cânt Aleluia, //
 Te iubesc căci Tu m-ai mântuit!

[V2]
 Jertfă mulțumirii ardă pe altar
 Tatălui Iubirii, Sfânt Izvor de har!

[V3]
 // Cânt cu credința //
 Ție, Dumnezeul credincios!
 // Cânt cu credința, //
 Fiului Tău Sfânt, Isus Hristos!

[V4]
 // Cânt cu-nchinare, //
 Ție, Dumnezeul minunat!
 // Cânt cu-nchinare, //
 Cânt cu focul care Tu mi-ai dat!</lyrics>
</song>