<?xml version="1.0" encoding="UTF-8"?><song><title>Eu Te chem Doamne</title>
<lyrics>[V1]
 Eu Te chem, Doamne,
 Tu să mă conduci;
 Fă-mi drumul neted printre stânci.
 Stai lângă mine,
 Doamne, mereu,
 Tu eşti singur sprijinul meu!

[V2]
 Eu Te-aştept, Doamne,
 Tu să mă înveţi,
 Tu eşti izvorul de poveţi.
 Stai lângă mine,
 Doamne, mereu,
 Tu eşti singur sprijinul meu!

[V3]
 Eu Te rog, Doamne,
 Tu să mă păzeşti,
 Ocrotitorul meu Tu eşti.
 Stai lângă mine,
 Doamne, mereu,
 Tu eşti singur sprijinul meu!</lyrics>
</song>