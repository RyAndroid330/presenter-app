<?xml version="1.0" encoding="UTF-8"?><song><title>Străin am fost odată</title>
<lyrics>[V1]
 Străin am fost odată,
 Străin și alungat;
 // Nici frați n-avem, nici tată,
 Nici mamă-nduiosata
 Să mângâie vreodată
 Obrajii-nlăcrimați. //

[V2]
 Dar Te-am aflat pe Tine,
 Isuse preaiubit;
 // În chinuri și-n suspine,
 La toți le-a fost rușine
 Să vina lângă mine -
 Tu, singur, ai venit. //

[V3]
 Necazurile-mi toate
 La Tine m-au adus;
 // De-atunci, Tu-mi ești de toate:
 Și milă și dreptate
 Și mamă-mi ești, și frate
 Și tată, Tu, Isus. //

[V4]
 Rămân deci pan' la moarte,
 Sub crucea Ta, Isus;
 // Bucăți de m-ar împarte,
 Pe drumuri să mă poarte,
 Tot nu mă vor desparte
 De Tine, nu, Isus! //
 Comentarii Ada</lyrics>
</song>