<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Am cămin mai sus de nori în ţara gloriei //
 Când vine Isus.

[V2]
 Cor:
 // Da Isus, da Isus, aminteşte-mă //
 Când vii în curând.

[V3]
 // Am cămin mai sus de nori, vrei să ai şi tu //
 Când vine Isus.

[V4]
 // Jos port crucea, sus cununa-n ţara gloriei //
 Când vine Isus.

[V5]
 // Dacă îl primeşti pe Isus, în veci vei trăi //
 Când vine Isus.

[V6]
 // Isus ne va duce-acasă'n țara gloriei, //
 Când vine Isus!</lyrics>
<title>Am cămin mai sus de nori</title>
</song>