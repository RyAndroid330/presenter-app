<?xml version="1.0" encoding="UTF-8"?><song><title>Osana Celui care vine</title>
<lyrics>[V1]
 // Osana Celui care vine //
 // Osana lui Isus Hristos căci El e Domn al domnilor //

[V2]
 // Osana Îl slăvea mulţimea //
 // Când spre Ierusalim venea căci praznicul s-apropia //

[V3]
 //Căci iată Fiul cel prea sfânt //
 // Se cobora pe-asin smerit şi-n Duhul Lui era mâhnit //

[V4]
 // Poporu-ntreg Îl lăuda //
 // Şi hainele şi le-aşterneau cu mii de flori Îl aşteptau //

[V5]
 // Osana Îi cântăm şia stăzi //
 // Cu ramuri de finici în mâini Îl laudă pe cel prea sfânt //</lyrics>
</song>