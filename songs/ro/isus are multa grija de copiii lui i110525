<?xml version="1.0" encoding="UTF-8"?><song><title>Isus are multa grija de copiii lui</title>
<key>D</key>
<lyrics>[V1]
.D                   G          D
 Isus are multa grija de copiii lui,
.G           D   A            D
 El le da in dar pace si mult har.
.D                   G         D
 Isus binecuvanteaza pe copiii Lui,
.G           D   A            D
 El le da in dar pace si mult har

[C1]
.     D        A      G                D
   // Dragi copii, veniti, cu toti cantati
.  G          D           A
   O cantare despre Isus! La El, alergati!
.  D        A      G                D
   Dragi copii, cantati cu toti, voiosi!
.  G           D            A            D
   Isus pe toti va iubeste, sa fiti bucurosi. //

[V2]
 Isus este fericirea! Voi sa nu uitati
 // Lui sa va rugati! //
 Ziua, noaptea, El vegheaza, El este cu voi,
 El va da in dar pace si mult har.

[V3]
 Soarele, pamantul, luna, stelele de sus
 // Canta lui Isus; //
 Florile, iarba-n gradina, cerul fara nori
 // Toate-s pentru voi. //</lyrics>
</song>