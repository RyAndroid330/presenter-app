<?xml version="1.0" encoding="UTF-8"?><song><title>Osana amin osana</title>
<lyrics>[V1]
 Osana, amin, osana
 O, aleluia, maranata!

[V2]
 // Isus e domn, El a înviat
 Si este viu în veci de veci //

[V3]
 // El mă iubeşte, El te iubeşte
 El ne iubeşte, pe noi pe toţi //

[V4]
 // El vine iar, şi va răpi
 In cerul sfânt, pe-aleşi săi //

[V5]
 // Eşti pregătit, să mergi în cer
 Să-L întâlneşti, pe Dumnezeu //</lyrics>
</song>