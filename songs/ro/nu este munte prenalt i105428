<?xml version="1.0" encoding="UTF-8"?><song><title>Nu este munte pre-nalt</title>
<key>G</key>
<lyrics>[V1]
.G
 Nu este munte prea-nalt,
.            Am
 Să nu-l doboare
.C                    D
 Nu e problemă prea grea,
.            G
 Să n-o măsoare
.G
 Nu e încercare sub stea,
.            Am
 Să n-o topească
.                     D
 Nu știu durere de-ar fi,
.         C      G
 Să n-o cunoască.

[V2]
 REF:
.      G
 //  Dacă umerii săi au purtat,
.       Am
 Povara lumii.
.   D
 El poate lua, chiar acum
.        C      G
 Povara ta!  //

[V3]
 Nu este drum prea înalt,
 Să nu mă urce
 Nu-i suferință mai grea,
 Decât pe cruce
 Nu-s frământări prea adânci,
 Să nu le-atingă
 Nu e furtună prea grea,
 Să nu o stingă.</lyrics>
</song>