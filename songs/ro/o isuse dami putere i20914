<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // O Isuse,da-mi putere! //
 // Sa-mi port crucea cu credinta,
 chiar cind toti ma ameninta,
 Tu fi a mea mingiiere! //

[V2]
 // O Isuse,fi cu mine! //
 // In dureri si in suspine,
 pe drumul cu maracine,
 Tu Isuse fi cu mine! //

[V3]
 // O Isuse,o Isuse! //
 // Inima mea e patrunsa
 de iubirea Ta nespusa,
 o Isuse,o Isuse! //

[V4]
 // Ada Doamne la lumina //
 // omenirea cea straina,
 ca in sfinta-mparatie
 sa formam o familie! //</lyrics>
<title>O Isuse da-mi putere</title>
</song>