<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mi-e aşa de dor de Tine
 Isuse, Dumnezeu;
 // Te chem să vii la mine
 Şi plâng de dorul Tău. //

[V2]
 Ce-aş face-n suferinţă,
 Ce-aş face la necaz,
 // De n-ai fi Tu să-mi mângâi
 Lovitul meu obraz? //

[V3]
 De n-ai fi Tu cu mine,
 Ca mâna să-mi întinzi,
 // Şi-n dulcea mângâiere
 La sân să mă cuprinzi? //

[V4]
 Să-mi legi atâtea rane,
 Să-mi ştergi atâta chin,
 // Isuse alinarea
 Sărmanului străin ! //

[V5]
 Şi iarăşi plâng sub cruce
 Şi iar privesc în sus;
 // Mi-aşa de dor de Tine,
 Iubitul meu Isus ! //</lyrics>
<title>Mi-e aşa de dor de Tine</title>
</song>