[V2]
 Pe cararea mantuirii, munti-s 'nalti, urcusu-i lung;
 // Calea-i stramta, // multi pornesc, putini ajung. //

[V3]
 Pe cararea mantuirii, vanturi mari si nori te-ncing;
 // Lupta-i crunta, // multi incep, putini inving. //

[V4]
 Pe cararea mantuirii, crucea-i grea, dar bine-i sus;
 // Usa-i stramta, // dar ce plat-ai la Isus-! //

[V5]
 Pe cararea mantuirii, mersu-i greu, dar trecator;
 // Viata-i aspra, // dar ce har ai de-ajutor! //

[V6]
 Pe cararea mantuirii, multi pornesc, putini s-aleg;
 // Fericiti sunt, // cei ce suie drumu-ntreg. //</lyrics>
