<?xml version="1.0" encoding="UTF-8"?><song><title>Vrednic esti de cinste</title>
<key>C</key>
<lyrics>[V1]
.   C                              Em Am
 // Vrednic eşti de cinste şi-nchinare
.    F            Dm
