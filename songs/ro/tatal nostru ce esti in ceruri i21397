<?xml version="1.0" encoding="UTF-8"?><song><title>Tatăl nostru ce eşti în ceruri</title>
<lyrics>[V1]
 Tatăl nostru ce eşti în ceruri,
 Sfinţească-se Numele Tău
 Şi voia Ta să se facă,
 // Sfinţească-se Numele Tău //

[V2]
 Precum în cer şi pe pământ,
 Sfinţească-se Numele Tău
 Şi dă-ne nouă pâinea azi
 // Sfinţească-se Numele Tău //

[V3]
 Şi ne iartă greşelile,
 Sfinţească-se Numele Tău
 Cum şi noi iertăm altora,
 // Sfinţească-se Numele Tău //

[V4]
 Nu ne lăsa duşi în ispită,
 Sfinţească-se Numele Tău
 Ne izbăveşte de orice rău,
 // Sfinţească-se Numele Tău //

[V5]
 Că-a Ta este Împărăţia,
 Slava şi gloria
 În veci de veci, în veci de veci,
 // Sfinţească-se Numele Tău //

[V6]
 Amin, amin, aşa să fie,
 Sfinţească-se Numele Tău
 // Amin, amin, amin, amin
 //  Sfinţească-se Numele Tău //  //</lyrics>
</song>