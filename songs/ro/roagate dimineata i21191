<?xml version="1.0" encoding="UTF-8"?><song><title>Roaga-te dimineaţa</title>
<lyrics>[V1]
 Roagă-te dimineaţa;
 Roagă-te şi la prânz;
 // Roagă-te pe înserate;
 Roagă-te orişicând. //

[V2]
 Ascultă-L dimineaţa;
 Ascultă-L şi la prânz;
 // Ascultă-L pe înserate;
 Ascultă-L orişicând. //

[V3]
 Fă bine dimineaţa;
 Fă bine şi la prânz;
 // Fă bine pe înserate;
 Fă bine orişicând. //

[V4]
 Dă-I slavă dimineaţa;
 Dă-I slavă şi la prânz;
 // Dă-I slavă pe înserate;
 Dă-I slavă orişicând. //</lyrics>
</song>