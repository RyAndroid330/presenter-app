<?xml version="1.0" encoding="UTF-8"?><song><title>În fiecare dimineata</title>
<lyrics>[V1]
 // In fiecare dimineata, //
 Cand este cerul luminos,
 // Mi-e inima de cantec plina //
 Si-s fericit ca sunt al lui Hristos...

[C1]
   // Si-s fericit, //
   Si-s fericit ca sunt al lui Hristos... //

[V2]
 // In fiecare zi senina, //
 Cand mii de flori aduc prinos,
 // Mi-e inima de cantec plina //
 Si-s fericit ca sunt al lui Hristos...

[V3]
 // In fiecare clipa sfanta, //
 Cand bate vantul mangaios,
 // Intregu-mi dor spre zari se-avanta //
 Si-s fericit ca sunt al lui Hristos...

[V4]
 // Chiar daca anii vietii zboara //
 Si cer senin de-a pururi nu-i,
 // La Domnul meu e-o primavara //
 Cand, fericit, voi fi pe veci al Lui...</lyrics>
</song>