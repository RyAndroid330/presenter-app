<?xml version="1.0" encoding="UTF-8"?><song><title>Stăruiţi acum cu toţii</title>
<lyrics>[V1]
 Stăruiţi acum cu toţii
 După Duhul Sfânt //,
 //Căci Isus Domnul vieţii,
 Va veni-n curând//.

[V2]
 //Domnul cu glasul Său dulce,
 Din cer va striga//
 //Biserica din morminte
 Se va deştepta //.

[V3]
 //Şi în nori apoi cu toţii
 Se vor ridica//
 //Cu toţi binecuvântaţii
 Spre-a-L întâmpina//.

[V4]
 //Cu oştirea Lui cerească
 Îi va număra//
 //Îmbrăcaţi în haine albe
 Se vor bucura//.</lyrics>
</song>