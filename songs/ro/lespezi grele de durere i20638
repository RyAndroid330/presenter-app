<?xml version="1.0" encoding="UTF-8"?><song><title>Lespezi grele de durere</title>
<lyrics>[V1]
 Lespezi grele de durere
 De m-ar apăsa, de m-ar apăsa
 // Și de-aș bea oțet cu fiere
 Şi-aș fi dus pentru-njunghere
 Nu te voi lăsa Isuse, nu te voi lăsa //

[V2]
 Carnea chiar de mi-ar desface
 Cei ce mă urăsc, cei ce mă urăsc
 // Facă răul cât mi-ar face
 Plămădind-u cât le-or place
 Nu te părăsesc Isuse. nu Te părăsesc //

[V3]
 În prigoană și rănire
 Chiar de va veni, orice va veni
 // Din credința-mi, din iubire,
 De sub crucea Ta pe mine
 Nu mă va clinti Isuse, nu mă va clintii //</lyrics>
</song>