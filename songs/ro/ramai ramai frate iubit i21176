<?xml version="1.0" encoding="UTF-8"?><song><title>Ramai ramai frate iubit</title>
<lyrics>[V1]
 Rămâi, rămâi frate iubit,
 Nu-ţi părăsi chemarea
 // Rămâi în dragostea dintâi,
 Cu toată Adunarea //

[V2]
 O, nu pleca căci bine ştii,
 Căci viaţa noastră-ntreagă
 // A fost izvor de bucurii,
 În Adunarea-ntreagă //

[V3]
 Cum poţi să uiţi iubirea Lui
 Şi-a Lui Isus chemare
 // Şi tot-atâtea mângăieri,
 În flori de primăvară //

[V4]
 O, poate dorul ţi s-a stins
 Iar tu te-ai dus o frate
 // Păcatul singur te-a învins,
 El singur te desparte //

[V5]
 O, nu-i uita pe fraţii tăi,
 Cu care-ai plâns odată
 // Cu care-ai plâns şi-ai mers pe drum,
 Cu faţa-nlăcrimată //

[V6]
 Mai stai puţin căci nu e mult
 Cu plata vine Domnul
 // Să fii şi tu Mireasa Lui
 Chemarea să-ţi răsune //

[V7]
 Gândeşte-te la Cel ce-a zis,
 Odată fiind cu tine
 // AScultă-L pe Acel ce-a zis,
 De pleci nu dai de bine //

[V8]
 Rămâi, rămâi, lângă ISsus,
 în locul Adunării
 // Căci plata ţi-o va da Isus,
 Atunci când vine Domnul //</lyrics>
</song>