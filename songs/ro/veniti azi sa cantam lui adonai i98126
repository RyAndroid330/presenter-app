<?xml version="1.0" encoding="UTF-8"?><song><title>Veniți azi să cântăm lui ADONAI</title>
<lyrics>[V1]
 // VENIȚI AZI SĂ CÎNTĂM LUI ADONAI
 CĂCI EL NE-A FĂCUT MULT BINE
 SĂ-L ÎNĂLȚĂM CU TOȚI PE ADONAI
 CĂCI ÎN BRAȚUL SĂU NE ȚINE //

[C1]
   ȘI MUNȚII SE PLEACĂ JOS
   ȘI NOI CU EI NE-NCHINĂM
   'NAINTEA LUI ADONAI
   ȘI MUNȚII SE PLEACĂ JOS
   ȘI NOI CU EI NE-NCHINĂM
   'NAINTEA LUI EL-SHADDAI

[V2]
 // UNIVERSUL ÎNTREG EL L-A CREAT
 PRIN PUTEREA-I INFINITĂ
 SFÂNTĂ A NUMIT ZIUA DE SHABBAT
 IUBIREA LUI FIE MĂRITĂ //

[V3]
 // ADUCEȚI MULȚUMIRI NEÎNCETAT
 CU INIMĂ CURATĂ
 ÎN FATA MARELUI NOST'ÎMPĂRAT
 CE NE RIDICĂ ȘI NE IARTĂ //

[V4]
 // CEL CE NE-A CREAT E ADONAI
 ÎNGENUNCHEM NAINTEA LUI
 CEL CE NE-A CREAT E ADONAI
 NOI NE SUPUNEM LUI //</lyrics>
<author>Jamie Hilsden</author>
</song>