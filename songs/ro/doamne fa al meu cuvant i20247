<?xml version="1.0" encoding="UTF-8"?><song><title>Doamne fa al meu cuvânt</title>
<lyrics>[V1]
 // Doamne fă al meu cuvânt
 Şi al minţii mele gând
 Ţie, Doamne, să le-nchin,
 Domnul meu. //

[V2]
 Stânca mea Tu eşti,
 Salvator pe veci.

[V3]
 // Doamne, fă viaţa mea
 Sfântă înainta Ta
 Totul Ţie să îţi spun,
 Domnul meu. //

[V4]
 // Doamne, rugăciunea mea
 Fă-o cum a fost a Ta
 Totul Ţie să îţi spun,
 Domnul meu. //

[V5]
 // Doamne, fă lumina mea
 Să lucească ca o stea
 Far în noapte, Tu, mă fă,
 Domnul meu. //

[V6]
 // Doamne, fă iubirea mea
 Ca să fie ca a Ta,
 Toţi să fie prinşi în ea,
 Domnul meu. //</lyrics>
</song>