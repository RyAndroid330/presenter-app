<?xml version="1.0" encoding="UTF-8"?><song><title>La Tine venim</title>
<key>A</key>
<lyrics>[V1]
.          A
 La Tine venim, la Tine venim
.            D          Bm
 Mântuiţi in faţa Ta noi stăm
.         A         E
 Cu capul sus, inima plină de laudă
.A          E
 Ţie ne inchinăm
.         A
 Te preamărim, Ta preamărim
.          D       Bm
 Indurarea Ta o inălţăm
.                A                   E
 Căci ne-ai eliberat, lanţurile le-ai rupt
.                 A E
     Care ne-au robit

[C1]
.           A
   Noi Te iubim, noi Te iubim
.              D         Bm
   Al Tău nume mare-L inălţăm
.                   A                   E
   Căci în Tine e puterea, în Tine-i măreţia
.            A          E
   Prin care suntem biruitori
.             A
   Ţie ne-nchinăm, Ţie ne-nchinăm
.             D                Bm
   Cu podoabe sfinte în faţa Ta stăm
.                     A
   Doar pe tine Te-nălţăm
.           E        A
   Domneşte Tu printre noi.</lyrics>
</song>