<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Te-am gasit pe munti inalti,
 Te-am gasit pe margini de rau.
 // Te-am gasit in stropi de parfumuri
 Te-am gasit Isuse, Te-am gasit. //

[V2]
 Te-am gasit pe cerul senin,
 Te-am gasit pe dealuri si stanci.
 // Te-am gasit in padurea-nverzita
 Te-am gasit Isuse, Te-am gasit. //

[V3]
 Te-am gasit in fulgul de nea,
 Te-am gasit in stele si nori.
 // Te-am gasit in stropii de ploaie
 Te-am gasit Isuse, Te-am gasit. //

[V4]
 Te-am gasit sus pe Golgota,
 Te-am gasit si atunci pe mormant.
 // Te-am gasit fericirea mi-ai dat
 Te-am gasit Isuse, Te-am gasit. //</lyrics>
<title>Te-am gasit pe munti inalti</title>
</song>