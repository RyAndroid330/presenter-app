<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<author>Камил Муса, Али Язар</author>
<title>Сонсуз Оланъм Дер, Беним Адъм TY34</title>
<key>G</key>
<lyrics>[V1]
.   G.                 D
 // Сонсуз оланъм дер, беним адъм,
.Em         C       G
 Сонсузлуа дек бен вар оланъм. //
.   G              D
 // Кушактан кушаа беним, варъм.
.Em        C      D
 Адъм: Бен варъм, ьойле яшаръм. //

[C1]
.     G             D
   // Беним, варъм, хер заман яшаръм, //
.     Em           C
   // Инанлъя яшам баъшларъм, //
.     D           C
   // Яшам баъшларъм. //

[V2]
.   G                   C
 // Сени гьондерен ким, дийе соран
.Em.         C          G
 Дурмадан дуйар бир сес илк ве сон. //
.   G              D
 // Кушактан кушаа заман заман
.Em          C        D
 Вар олан беним дер, бен езелден. //</lyrics>
</song>