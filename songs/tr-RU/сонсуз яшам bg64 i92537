<?xml version="1.0" encoding="UTF-8"?><song><author>Мехмет Айшеко Октай</author>
<hymn_number>64</hymn_number>
<title>Сонсуз Яшам BG64</title>
<lyrics>[V1]
.   Em             Dm
 // Сенде хаятънда изин вер Раб'бе
.F               Dm        Em
 изин вер яшасън Иса калбинде //

[C1]
.     Em                 Dm
   // Изин вер, изин вер Кутсал Руха
.  F              Dm      Em
   Йьонетсин сени дорулукта //

[V2]
.   Em            Dm
 // Деишиклик олсун хаятънда
.F                   Dm        Em
 Севги калбин долсун Кутсал Рухла //</lyrics>
<key>C</key>
</song>