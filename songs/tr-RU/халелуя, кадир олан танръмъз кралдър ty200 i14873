<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>200</hymn_number>
<title>Халелуя, Кадир Олан Танръмъз Крал'дър! TY200</title>
<key>D</key>
<lyrics>[V1]
.       D    D7 G   D        A   A7   D
 // Халелуя, кадир олан Танръмъз Крал'дър! //
.    D7   G          D
 Биз джошалъм, севинелим,
.  E    E7        A   A7
 О'на иззетини де верелим!
.    D    D7 G   D        A   A7   D
 Халелуя, кадир олан Танръмъз Крал'дър!</lyrics>
</song>