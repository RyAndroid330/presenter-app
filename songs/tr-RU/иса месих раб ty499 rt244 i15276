<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[C1]
.     Em
   //  Иса Месих Раб, Иса Месих Раб,
.  C              Am            D   Em
   Иса Месих Раб, Иса Месих Раб улусларда! //

[V1]
.C     D     Em
 О дорулукла хюкмедер,
.C    D     Em
 О адалетле хюкмедер.
.C        D           G           Em
 Иса'нън канъ джан дюшманъмъзъ йенди.
.C       Am       B7
 Егемен, гючлю куртаръджъ!</lyrics>
<title>Иса Месих Раб TY499 RT244</title>
<hymn_number>499</hymn_number>
<author>Рамон Пинк</author>
</song>