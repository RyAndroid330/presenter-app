<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<title>Аллахъм Гючлюсюн</title>
<lyrics>[V1]
 // Аллахъм Гючлюсюн
 ЬОвгюйе Лайък сън //

[V2]
 // Хамтларън Раббисин
 Хер шейден юстюнсюн
 Сен кадир танръсън
 Ъшък сън Раб иса //

[V3]
 // Кудретисин сен Аллахъм
 Евренин Кралъсън //

[V4]
 // Гьокте йерде бир тане син
 Хершейин хакимисин //

[V5]
 // Раб иса Аллахъм
 Темизле калбимизи //

[V6]
 // Куввет вер сен бизе
 Шейтани Езелим
 Заферлер казаналъм
 Йюзюню гьорелим //</lyrics>
</song>