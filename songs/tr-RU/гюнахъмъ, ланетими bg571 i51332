<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Гюнахъмъ, ланетими
 Аджъ чектим, зехире яндъм. //
 // Йюджелийими она индим.
 О кърълдъ, алчак олду. //

[V2]
 // Онун яраларъндан,
 Йюксеклийимден баръш олду. //
 // Хепимиз йолу шашърдък,
 Кенди йолумуза дьондюк. //

[V3]
 // Раббим билир гюнахъмъ.
 Йолумуза гене койду. //
 // Аджъмъзъ ташъдъ,
 Инанчларъ о йюкленди. //

[V4]
 // Йолландърдъ джезъя яврусуну,
 Ама бизи джеза бозду. //</lyrics>
<title>Гюнахъмъ, ланетими BG571</title>
<hymn_number>571</hymn_number>
</song>