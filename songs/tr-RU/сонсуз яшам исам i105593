<?xml version="1.0" encoding="UTF-8"?><song><title>сонсуз яшам исам</title>
<lyrics>[V1]
 // Севинсин сана сиинан херкес
 Есенлик ичинде ятсън уйусун
 Сана гювенсин я раб ьомрюню версин
 Сонсуз яшамънда кендини булсун //

[V2]
 // Сенде севиндж булуп хеп джосаджагим
 Йолундан хич сапмайип хеп кошаджаъм
 Сенсин беним бабам сенсин ефендим
 Адънъ йюректен хайкираджагим //

[V3]
 // Херкес бъракъп гитсе сен бенимлесин
 ЬОвгюлер сана олсун дюня динлесин
 Хем яръм хем йолдашъм хем сирдасимсин
 Гюджюн ве кудретинле йер гьок инлесин //</lyrics>
<author>Джихан Думан</author>
</song>