<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Бен сени чок севдим.
 Сенин йолуна чектим.
 Сен бана ярдъм ет,
 Сана гювенийом бен. //

[C1]
   Халелуя сана.
   Халелуя сана.
   Шюкюр, шюкюр
   Иса Месих'е.

[V2]
 // Бюйюк дердим вар беним.
 Сен билирсин, Аллахъм.
 Сен бана ярдъм ет.
 Сана гювенийом бен. //</lyrics>
<title>Бен сени чок севдим BG526</title>
<hymn_number>526</hymn_number>
</song>