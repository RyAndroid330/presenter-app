<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар, Мехмет Акйюрек</author>
<title>Аллахъм Раббимиз Иса</title>
<lyrics>[V1]
 // Аллахъм Раббимиз Иса Джанъмъзъ кьолеликтен куртардън чаресиз Перишан калмъшкен Раббим иса Елини Узаттън //

[V2]
 // Саде сени дюшюнеджем саде сени Бен ьоведжем саде сана тапънаджам Раббим иса //

[V3]
 // Танръм ве Куртаръджъм сенсин Беним ичин чармъхта сен ьолдюн Йюреим Гюнахларлан долуйкен Канънла бени сен Йъкадън //</lyrics>
</song>