<?xml version="1.0" encoding="UTF-8"?><song><author>Сюмер Ташкъран, Башак Ишчи</author>
<hymn_number>29</hymn_number>
<title>Чюнкю Нереде Късканчлък TÇ29</title>
<lyrics>[V1]
.Em     C      D
 Чюнкю нереде късканчлък,
.Em
 Бенджиллик варса,
.         C
 Орада каръшъклък
.D               Em
 Ве хер тюр кьотюлюк вардър.
.    D         Em
 // Йакуп юч оналтъ.  //</lyrics>
<key>G</key>
</song>