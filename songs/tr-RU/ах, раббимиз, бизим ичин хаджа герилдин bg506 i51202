<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Ах, Раббимиз, бизим ичин хаджа герилдин.
 Гюнахларъмъз ичин канънъ дьоктюн //
 // Йъка бени, Раб Исам, сенин канънла
 Сенинле олайъм бен хер даима //

[C1]
   // Гьордюм, гьордюм, гьордюм, гьордюм,
   Куртлушуму гьордюм.
   Бир куш гиби сана учтум,
   Саалам бир каяя кондум //

[C2]
   // Иса гелди ми, йерйюзюне сен хазър мъсън ?
   Иман ет сен Аллахъна, сени О алсън //
   // Йъка бени, Раб Исам, сенин канънла
   Сенинле олайъм бен хер даима //</lyrics>
<title>Ах, Раббимиз, бизим ичин хаджа герилдин BG506</title>
<hymn_number>506</hymn_number>
</song>