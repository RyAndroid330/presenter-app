<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Аджъларънда съкънтъларъмда
 Хер заман Рабби ара
 Иманла йюрю иманла яша
 Герчеи яз йюреинин левхасъна //
 // Раб Иса'нън ъшъъ гьорюлсюн хаятънда //

[C1]
   // Ибрахимин иманънъ давудун йюреини
   Павлусун ишчилиини Иса'нън севгиси //
   Истийорум
   // Сени хошнут етмек ичин яраб //
   «. Неден юзгюнсюн, ей гьонлюм,
   Неден ичим хузурсуз?
   Танръ'я умут бала,
   Иманла йюрю иманла яша
   // Раб Иса'нън ъшъъ гьорюлсюн хаятънда //

[C2]
   // Ибрахимин иманънъ давудун йюреини
   Павлусун ишчилиини Иса'нън севгиси //</lyrics>
<title>Иманла йюрю иманла яша</title>
<author>Схериф Левит</author>
</song>