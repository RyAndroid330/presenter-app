<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>35</hymn_number>
<title>Кимсесизим Аллахъм BG35</title>
<lyrics>[V1]
 // Кимсесизим Аллахъм
 Чаресизим я Раб'бим
 Гювенийом бен Сана
 Сен бана ярдъм едесин //

[C1]
   // Каранлъктан чъкардън бени
   Мутлулук вердин бана
   Хер вакът ол бенимле Раб'бим
   Сенинле дженнетте олайъм //

[V2]
 // Бен Сени билмездим
 Севгини гьормездим
 Бени Сен куртардън
 Сен бана ярдъм еттин //</lyrics>
</song>