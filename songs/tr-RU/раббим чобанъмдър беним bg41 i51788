<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>41</hymn_number>
<title>Раб'бим чобанъмдър беним BG41</title>
<lyrics>[V1]
 // Раб'бим чобанъмдър беним ексиим олмаз //
 Бени йемйешил чайърда бени йемйешил чайърда
 ятърър сакин сулар къйъсънда

[V2]
 // Каранлък ьолюм вадисинден гечсем биле //
 кьотюлюктен коркмам, кьотюлюктен коркмам
 чюнкю Сен бенимлесин Сен бенимлесин

[V3]
 // Бана дору йолларда ьонджюлюк едерсин //
 Сенин чомаън сенин денейин
 гювен верендир бана, гювен верендир

[V4]
 // ЬОмрюм бойунджа ийилик севги излейеджек бени //
 хеп Танръмън евинде, хеп Раб'бимин евинде
 бен отураяджаъм, бен отураджаъм

[V5]
 // Я Раб бютюн йюреимле Сана шюкредеджеим //
 яптъгън харикалар яптъън муджизелер
 хепсини анлатаджаъм ве дуйураджаъм</lyrics>
</song>