<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em
 Херкесин дерди вар,
.Dm.     G
 Дердини чекер.
.G.          Dm
 Сабър верийорум,
.          Em
 О сана йетер.

[V2]
.   Em.          Am
 // Хаста олсам да, а...а...а...
.Dm.        G
 Аджъм олса да, а...а...а...
.C.         F
 ЬОлюм олса да, а...а...а... //

[V3]
.Dm.    Em
 Аллаха дуа.

[V4]
 Сен беним евиме
 Хич гирмедин ми ?
 Сен беним адъмъ
 Ишитмедин ми ?

[V5]
 // Сен беним яврум, а...а...а...
 Сен беним кузум, а...а...а...
 Дженнете язайъм,.
 Сенин адънъ //

[V6]
 Шюкюр, аминлер олсун,
 Аллахъмъза.
 Бир йол ачтъ бизе,
 Куртулмамъза.

[V7]
 // Хаста олсам да, а...а...а...
 Аджъм олса да, а...а...а...
 ЬОлюм олса да, а...а...а...
 Аллаха дуа. //</lyrics>
<title>Херкесин дерди вар BG699</title>
<hymn_number>699</hymn_number>
</song>