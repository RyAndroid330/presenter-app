<?xml version="1.0" encoding="UTF-8"?><song><title>Гьоркемли Раб'бим BG18</title>
<aka>Йюджеликлер Раб'бе</aka>
<lyrics>[V1]
.   E
 // Гьоркемли Раб'бим
.Am           E
 Йюдже кутсал Раб //

[C1]
.     Am          E
   // Йюджеликлер Раб'бе
.  E    Dm    E
   Ебед Ебединдже //

[V2]
 // Ешсиз севгинле
 Бени Яратан Раб //

[V3]
 // Бени аффеттин
 Бени баъшладън //

[V4]
 Кусурсуз канънла бени йъкадън
 Кусурсуз канънла бени сатън алдън</lyrics>
<key>E</key>
<author>Салим Сасхев (Башко)</author>
<hymn_number>18</hymn_number>
</song>