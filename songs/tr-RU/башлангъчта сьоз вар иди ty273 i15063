<?xml version="1.0" encoding="UTF-8"?><song><title>Башлангъчта Сьоз Вар Иди TY273</title>
<lyrics>[V1]
 // Башлангъчта Сьоз вар иди,
 Сьоз Танръ'нън кендисийди.  //
 // О'нсуз хичбир шей олмадъ,
 Хер шей О'нун иле олду.  //

[V2]
 // Яшам О'нун кендисийди
 Ве инсанларън ъшъъ;  //
 // Ъшък каранлъкта парлар
 Каранлък О'ну билмеди.  //

[V3]
 // Инсан айдънлансън дийе
 Ъшък дюнямъза гелди.  //
 // Арамъзда конут курду,
 Дюня гьоркемийле долду.  //

[V4]
 // О'ну кабул еденлере,
 Яшамъна аланлара  //
 // Герчек Танръ чоджукларъ
 Олма йеткисини верди.  //</lyrics>
<hymn_number>273</hymn_number>
<author>Али Язар</author>
</song>