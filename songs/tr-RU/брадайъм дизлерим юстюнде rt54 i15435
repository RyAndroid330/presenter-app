<?xml version="1.0" encoding="UTF-8"?><song><title>Брадайъм дизлерим юстюнде RT54</title>
<capo>4</capo>
<key>C</key>
<lyrics>[V1]
.Am                 C
 Бурдайъм, дизлерим юстюнде
.          G             F
 Теслим олурум, теслим олурум

[V2]
.Am                C
 Бени бул, кендине яклаштър
.          G              F
 Сана мухтаджъм, сана мухтаджъм

[C1]
.            Am            C
   // Теслим олдум, теслим олдум
.       Dm              F
   Сени истийорум, сени истийорум //

[V3]
.Am                     C
 Бени долдур, мерхамет, лютуфла
.          G            F
 Сана аджъктъм, сана аджъктъм

[V4]
.   Am                 C
 Колларъм ачък, сесими дуярсън
.           G             F
 Бана конуш Раб, Бана конуш Раб

[B1]
.  (A)     F     C      G
    Бир рюзгар гиби, ичиме юфле
.           Dm7           Am     G
   Истеин олсун, истеин олсун бенде
.       F    C         G
   Фъртъна гиби, джанъмда ишле
.           Dm7           Am     G
   Истеин олсун, истеин олсун бенде</lyrics>
<aka>Теслим Олдум</aka>
<hymn_number>54</hymn_number>
<author>Хиллсонг Унитед</author>
</song>