<?xml version="1.0" encoding="UTF-8"?><song><title>БИЛЛИЙОРУМ Я РАБ ГЮДЖЮМ СЕНСИН</title>
<lyrics>[V1]
 // БИЛЛИЙОРУМ Я РАБ ГЮДЖЮМ СЕНСИН,
