<?xml version="1.0" encoding="UTF-8"?><song><title>Яшам, Герчек, Йол Бен'им TY39</title>
<lyrics>[V1]
 // Яшам, герчек, йол бен'им,
 Иса Месих'тир адъм.  //
 // Бана гелен херкесе
 Колларъмъ ачаръм.  //

[C1]
   // Яшам екмеи бен'им,
   Аджъкан бана гелсин.  //
   // Яшам суйу вар бенде,
   Сусаян гелсин ичсин.  //

[C2]
   // Каранлъкта йюрюйен,
   Герчек нуру ьозлейен,  //
   // Йюрю беним ардъмджа,
   Нуруйум бен дюнянън.  //

[C3]
   // Ийи чобандър адъм,
   Кузуларъ северим.  //
   // Танръ'нън атадъъ
   Герчек курбан бен олдум.  //

[C4]
   // Яшам, герчек, йол бен'им,
   Иса Месих'тир адъм.  //
   // Бана гелен херкесе
   Колларъмъ ачаръм.  //</lyrics>
<hymn_number>39</hymn_number>
<author>Али Язар</author>
</song>