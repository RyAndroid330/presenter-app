<?xml version="1.0" encoding="UTF-8"?><song><title>Гьок бизим евимиз BG561</title>
<lyrics>[V1]
 // Гьок бизим храмъмъз
 Иса гене капъмъз. Алелуя! //

[V2]
 // Ол бенимле, ей Раббим.
 ЬОмрюмюн олдуу кадар. Алелуя! //

[V3]
 // Иса беним йолдашъм.
 Беним ичин о ьолдю. Алелуя! //

[V4]
 // Каранлъън ичиндейдим,
 Раббим шълаттъ бени, Алелуя! //

[V5]
 // Ваз гечмишим дюнядан.
 Унутмушум хер шейи. Алелуя! //

[V6]
 // Илери гидерим бен.
 Хич гери дьонмейеджем. Алелуя! //

[V7]
 // Чеки чекмейе гелдим.
 Аллахъм, бу дюняя. Алелуя! //

[V8]
 // Кору бени гюнахтан.
 Раб, айдънлатър бени. Алелуя! //</lyrics>
<hymn_number>561</hymn_number>
</song>