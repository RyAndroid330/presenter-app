<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>329</hymn_number>
<author>Фарук Пекер</author>
<lyrics>[C1]
   Иса Месих Раб'дир, илан един!
   Куртаръджъмъздър, шюкредин!
   Иса Месих Раб'дир, иман един!
   Кутсал олан яшам верендир!

[V1]
 //  (Кадън) Иса, (Еркек) Иса,
 (Кадън) Егеменсин, (Еркек) Егеменсин,  //
 //  Калплердесин, ишлердесин,
 Тюм евренде бир чаресин.  //

[V2]
 //  (Кадън) Баба, (Еркек) Баба,
 (Кадън) Баъшларсън, (Еркек) Баъшларсън,  //
 //  Темизлерсин, денетлерсин,
 Хер гюнюмде бенимлесин.  //

[V3]
 //  (Кадън) Кардеш, (Еркек) Кардеш,
 (Кадън) Динле бени, (Еркек) Динле бени,  //
 //  Калбим' ачтъм, гьонлюм' вердим,
 Раб Иса'да яшам булдум.  //</lyrics>
<title>Иса Месих Раб'дир, Илан Един! TY329</title>
</song>