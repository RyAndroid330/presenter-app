<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>501</hymn_number>
<lyrics>[V1]
 // Аджъма севинч катар Иса.
 Дердиме дерман верир Аллах. //

[V2]
 // Узактан сейретме, кардеш,
 Ал сонсуз хаятъ, кардеш. //

[V3]
 // Битки гюню гюнахлълар
 дору йолдан айръланлар, //

[V4]
 // дорулар Аллахлан яшар,
 Кьотюлерин йолу йок олур. //

[V5]
 // Бугюн Аллахън сьозюню
 Иман иле кабул един. //

[V6]
 // Аллахън дири сьозюдюр.
 Гедже гюндюз дуа един. //

[V7]
 // Не къйметли кутсал пънар,
 Орада беним Месихим яшар. //

[V8]
 // Бу сьозлерден севинч дуян
 Гюнахларъндан куртулур. //

[V9]
 // Кьотюлерле йюрюмейин,
 Гюнах йолунда дурмайьн, //

[V10]
 // Алайджъларла отурмайън,
 Аллахън йолунда олун. //</lyrics>
<title>Аджъма севинч катар Иса BG501</title>
</song>