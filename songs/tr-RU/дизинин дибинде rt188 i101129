<?xml version="1.0" encoding="UTF-8"?><song><title>Дизинин дибинде RT188</title>
<key>C</key>
<lyrics>[V1]
.C(add9)       C/E Fm7          G
  Дизинин дибинде   Сени беклийорум
.C(add9)        C/E Fm7         G
  Беним севдиим Раб  Сени истийорум

[C1]
.                   C
   // Я Раб, Сен бана гел, лютфен
.                 Am
   Я Раб, бана сеслен, лютфен
.                Dm
   Сесини дуймак истерим
.                 G
   Калбини билмек истерим //</lyrics>
<author>Еун-Жоо Жеон</author>
<hymn_number>188</hymn_number>
</song>