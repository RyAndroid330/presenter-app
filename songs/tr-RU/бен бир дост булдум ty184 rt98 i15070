<?xml version="1.0" encoding="UTF-8"?><song><author>Мемдух Уйсал</author>
<hymn_number>184</hymn_number>
<title>Бен Бир Дост Булдум TY184 RT98</title>
<lyrics>[V1]
.Dm
 Бен бир дост булдум,
.A7             Dm
 ЬОйле бир дост ки!
 Калбиме гирен,
 Бени аффеден!

[C1]
.                Gm
   // Суч йюкюмю ташъян,
.             Dm
   Борчларъмъ ьодейен,
.            A7
   Севгисини гьостерен
.                  Dm
   Бир дост булдум бен. //

[V2]
.Dm
 Бу дост Иса'дър,
.A7         Dm
 Бамбашка Иса!
 Курбан едилен
 Танръ кузусу!

[C2]
.               Gm
   // Яшам йолу гьостерен,
.            Dm
   Гюнахларъ калдъран,
.             A7
   Севмейи де ьоретен
.                 Dm
   Дост булдун му сен? //

[V3]
.Dm
 Гелин инсанлар,
.A7           Dm
 Гелин бу доста!
 О'ну чаърън,
 Севинчле джошун!

[C3]
.                 Gm
   // Хасталъктан калдъран,
.              Dm
   ЬОлюм баънъ чьозен,
.           A7
   Каранлъъ алт еден
.           Dm
   Досту чаърън! //</lyrics>
<key>F</key>
</song>