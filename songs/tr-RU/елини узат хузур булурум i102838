<?xml version="1.0" encoding="UTF-8"?><song><aka>Даха Чок Ишимиз Вар</aka>
<lyrics>[V1]
.Am               Em
 // Йюреимде калбимде
. Dm                 Em/Am
 Аджълар бир бир бирикти //
.   Am               Em
 //  Сен Раб дуян сесими
.Dm                    Em/Am
 Не олур ал бенден бенлиими //

[V2]
.   Am                   Em
 // Гьоз капакларъм аърлашър
.Dm                    Em/Am
 Йоргунум Раб, чок йорулдум //
.   Am                   Em
 //  Чълъкларъмъ дуй Раб Исам
.Dm                 Em/Am
 Елини узат хузур булурум //

[V3]
.   Am                        Em
 // Учурум кенаръндайкен бен, Иса'м
.Dm                         Em/Am
 Сесленди, &quot;Даха чок ишимиз вар&quot; //
.Am                         Em
 // &quot;Сени ьоледжек кадар севийорум
.Dm                  Em/Am
 Йетер ки гювен бана, гел&quot; //</lyrics>
<key>Am</key>
<title>Елини Узат Хузур Булурум</title>
<author>Анъл ЬОзтюрк</author>
</song>