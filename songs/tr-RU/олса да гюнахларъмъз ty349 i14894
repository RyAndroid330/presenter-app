<?xml version="1.0" encoding="UTF-8"?><song><author>Фарук Пекер</author>
<hymn_number>349</hymn_number>
<lyrics>[V1]
.Dmin
 // Олса да гюнахларъмъз,
.Gmin
 Олса да сорунларъмъз,
.Dmin         Gmin
 Раб бизим куртаръджъмъз.
.Dmin        Eb          Dmin
 Кутсал олан тек Бабамъз. //

[C1]
.                                       F
   Раб, биз сенинлейиз, сенин хизметиндейиз.
.  Gmin              Dmin
   Башка хичбир шейи истемейиз.
.           Eb     Dmin
   Хеп сенинле гидериз.

[V2]
 // Гиден хузур булуйор, неше севинч долуйор.
 Кутсал оланъ тадъйор,
 Хеп дюрюст калъйор.  //</lyrics>
<key>Bb</key>
<title>Олса Да Гюнахларъмъз TY349</title>
</song>