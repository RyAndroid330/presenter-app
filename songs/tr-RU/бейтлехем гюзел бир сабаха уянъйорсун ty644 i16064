<?xml version="1.0" encoding="UTF-8"?><song><author>Онур Йьош</author>
<hymn_number>644</hymn_number>
<title>Бейтлехем Гюзел Бир Сабаха Уянъйорсун TY644</title>
<key>Em</key>
<lyrics>[V1]
.   Em                   B7
 // Бейтлехем Гюзел Бир сабаха уянъйорсун
.Em                     B7
 Бейтлехем куртаръджън доду //

[V2]
.Em       Am      B7              Em
 // Раб Иса доду, Йюджелиинден сойунду
.  Am     B7               Em
 Дюняя гелди, бир бебек олду //

[V3]
.Em         Am        B7           Em
 Кралларън кралъ, Гьоркемли бюйюк Танръ
.    Am       B7              Em
 Хер шейин сахиби бир инсан олду.</lyrics>
</song>