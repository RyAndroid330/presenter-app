<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>118</hymn_number>
<author>Али Язар</author>
<title>Танръ Бизим Каямъздър TY118</title>
<key>F</key>
<lyrics>[V1]
.   Dm          Am    Dm
 // Танръ бизим каямъздър,
.Dm        Am      Dm
 Съънаджак гюджюмюздюр. //
.   Gm                  Bb
 // Дененмеде, зорлукларда
.Dm          Am      Dm
 Хемен хазър ярдъмджъдър. //
.           Am     Dm      Am7
 // Биз коркмайъз, биз коркмайъз. //

[V2]
.   Dm         Am      Dm
 // Бютюн дюня алт юст олса,
.Dm        Am       Dm
 Далар денизе деврилсе, //
.   Gm                  Bb
 // Сулар кюкрейип каръшса,
.Dm         Am       Dm
 Еврен коркудан титресе, //
.           Am     Dm      Am7
 // Биз коркмайъз, биз коркмайъз. //

[V3]
.   Dm          Am    Dm
 // Чюнкю Танръ каямъздър,
.Dm        Am      Dm
 Съънаджак гюджюмюздюр. //
.   Gm                  Bb
 // Съкънтъда, зорлукларда //

[V4]
 Хемен хазър ярдъмджъдър. //
.            Am     Dm      Am7
 //  Бир коркмайъз, биз коркмайъз.</lyrics>
</song>