<?xml version="1.0" encoding="UTF-8"?><song><title>СУСАДЪМ СЬОЗУНЕ</title>
<lyrics>[V1]
 СУСАДЪМ СЬОЗУНЕ
 ОКШАЯН ЕЛИНЕ
 НЕРДЕСИН НЕРЕДЕ

[C1]
