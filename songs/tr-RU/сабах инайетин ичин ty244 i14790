<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Сабах инайетин ичин,
 Гедже садакатин ичин  //
 //  Сана шюкюр йюкселтирим,
 Кутсал олан йюдже Танръм!  //

[V2]
 //  Сазъм иле, сьозюм иле,
 Давулларла, кашъкларла,  //
 //  Сесим иле, джанъм иле
 Сана шюкюр йюкселтирим!  //</lyrics>
<title>Сабах Инайетин Ичин TY244</title>
<hymn_number>244</hymn_number>
<author>Али Язар</author>
</song>