<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   Ей Танръм, гьоклер юстюне йюксел!
   Гьоркемин йерйюзюню долдурсун!

[V1]
 //  Улуслар арасънда
 Сана шюкюр едерим!
 Инсанлар арасънда
 Сана ьовгю сунаръм!  //

[V2]
 //  Раб, сенин инайетин
 Гьоклер кадар йюксектир.
 Ей Раб, сенин герчеин
 Тюм евренден ашкъндър.  //</lyrics>
<title>Ей Танръм, Гьоклер Юстюне Йюксел! TY250</title>
<author>Али Язар</author>
<hymn_number>250</hymn_number>
</song>