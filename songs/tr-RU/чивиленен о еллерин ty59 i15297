<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>59</hymn_number>
<title>Чивиленен О Еллерин TY59</title>
<lyrics>[V1]
.   Em            Am
 // Чивиленен о еллерин,
.F               G
 Я Раб, беним урумайдъ. //
.   C               F
 // Беним ичин дикенлерден
.Dm                 Em
 Тач койдулар Раб башъна. //

[V2]
.   Em                Am
 // Раб, гюнахъм ичин иди
.F                  G
 Чармъхтаки коркунч азап. //
.   C                 F
 //  Бу не бюйюк бир инайет,
.Dm                    Em
 Не ешсиз бир йюдже севги! //

[V3]
.   Em                Am
 //  Сана олан гьонюл борджум
.F                G
 Хичбир заман ьоденемез. //
.   C                    F
 //  Хамт йюкселтир сана рухум,
.Dm                Em
 Сени ьовер, Раб, яшамъм! //</lyrics>
<key>Am</key>
</song>