<?xml version="1.0" encoding="UTF-8"?><song><title>Сен дюняйъ севдин, Аллахъм BG677</title>
<lyrics>[V1]
 // Сен дюняйъ севдин, Аллахъм
 Бириджик Оглуну вердин. //

[C1]
   // Гел Раббим, гел Иса.
   Мубарекле сен бизи.
   Гел Раббим, гел Исам.
   Мубарекле хепимизи. //

[C2]
   // Бир ел сен де узат, я Раббим.
   Мубарекле шимди бизи. //

[C3]
   // Бизим ичин Исам ьолдюн.
   Бизим ичин сен дирилдин. //

[C4]
   // Ал бизи Иса, сенин янъна.
   сенинле Олалъм йукарда . //

[V2]
 // Шюкюр сана, Иса месих ,
 беним Гюнахларъмъ аф еттин. //
 // Куртулушу бана вердин,
 Исмими дженнете яздън. //</lyrics>
<hymn_number>677</hymn_number>
</song>