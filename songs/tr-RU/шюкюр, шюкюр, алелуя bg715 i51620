<?xml version="1.0" encoding="UTF-8"?><song><title>Шюкюр, шюкюр, Алелуя BG715</title>
<lyrics>[C1]
   // Шюкюр, шюкюр, Алелуя,
   Гюзел Аллахъмъза. //

[C2]
   // Кимсесиз калдъм,
   Бен бу дюняда,
   Иса'йъ арадъм,
   Бенимле олсун. //

[C3]
   // Каранлък дюняда
   Гюнах ишледим.
   Шимди айдънлъкта,
   Куртулуш булдум. //

[C4]
   // Иса Месих, Раббим,
   Бен сенин яврун.
   Сен бени арадън,
   Сен бени куртардън. //</lyrics>
<hymn_number>715</hymn_number>
</song>