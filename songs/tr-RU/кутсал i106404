<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Сен конушунджа динлемек истийорум
   О татлъ сеси хер заман ,дуймак истийорум
.      
       Муса'я конуштуун гиби Яраб
.      
       Бана да конуш истийорум //

[C2]
   // Кутсал кутсал кутсал сън сен сен олан //

[C3]
   // Бенимле сен сен олан Танръ сън
   Дуня чолунде бени дойурансън
.      
       Хер заман акан бир пънар сън
   Ихтияджъм олан хер шей сенде вар //</lyrics>
<title>Кутсал</title>
<author>Схериф Левит</author>
</song>