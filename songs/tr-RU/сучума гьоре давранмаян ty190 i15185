<?xml version="1.0" encoding="UTF-8"?><song><author>Зафер Йюрюмез</author>
<hymn_number>190</hymn_number>
<lyrics>[V1]
 //  Сучума гьоре давранмаян,
 Кутсал канъйла паклаян,
 Гьоркемде бана йер айъран
 Бир севги, бир севги,
 Бир севги булду бени!  //

[V2]
 //  Иса, исмине хамдолсун!  //
 Исмине хамдолсун!</lyrics>
<title>Сучума Гьоре Давранмаян TY190</title>
</song>