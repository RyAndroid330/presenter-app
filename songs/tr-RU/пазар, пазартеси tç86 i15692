<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.  G D         G
   Пазар, пазартеси, салъ ве чаршамба,
.                D                G
   Першембе ве джума, джумартеси де:
.      G                  D          G
   // Мутлуйум, мутлуйум, Иса беним достумдур.  //

[C2]
   // Инджили оку сен, Чюнкю Раб'бин сьозюдюр.  //

[C3]
   // Дуа ет, дуа ет, Раб дуамъзъ динлер.  //

[C4]
   // Баъшла, баъшла, баръш дюняда олсун.  //

[C5]
   // Ярдъм ет, ярдъм ет, иш бьойле хафифлесин.  //

[C6]
   // Севиндир, севиндир, херкес достунуз олсун.  //

[C7]
   // Тешвик ет, тешвик ет, дост аяа калкаджак.  //</lyrics>
<key>G</key>
<title>Пазар, Пазартеси TÇ86</title>
<author>Хилтруд Стрьохлеин</author>
<hymn_number>86</hymn_number>
</song>