<?xml version="1.0" encoding="UTF-8"?><song><author>Али Пекташ</author>
<key>C</key>
<lyrics>[V1]
.   Em
 // Бенден ьондже севди бени
.Am
 Бенлиимден алдъ бени. //

[C1]
.     G
   // Гьормедим бьойле севени
.  Dm         F     Em
   Бен Иса'йъ севийорум. //

[V2]
 // Канъ иле сатън алдъ
 Аджъ вердим бана гюлдю. //

[V3]
 // О беним йериме ьолдю
 Бен Иса'йъ севийорум. //

[V4]
 // Беденин чармъха герди
 Иманла ьолюмю йенди. //

[V5]
 // Дирилди Баба'я дьондю
 Бен Иса'йъ севийорум. //

[V6]
 Иса, Иса, Иса, Иса,</lyrics>
<title>Бенден ьондже Севди Бени</title>
</song>