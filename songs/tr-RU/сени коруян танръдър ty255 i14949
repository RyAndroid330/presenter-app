<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>255</hymn_number>
<title>Сени Коруян Танръ'дър TY255</title>
<lyrics>[C1]
.   Em               Am
   Сени коруян Танръ'дър,
.              F     G
   Сени сарсълмая коймаз.
.  Em                F
   Уйукламаз ве йорулмаз,
.           Dm     Em
   Сени коруян уйумаз.

[V1]
 // Аръйорум тюм даларъ,
 Ярдъм нереден геледжек? //
 Йери ве гьою яратан
 // Танръдандър бана ярдъм. //

[V2]
 // Са янъмда О гьолгедир,
 Гюндюз икен гюнеш вурмаз. //
 Геджелейин ай докунмаз,
 // Танръ ели юстюмдедир. //

[V3]
 // Раб хер шейден бени корур,
 Беним рухуму куртарър. //
 Шимдиден ебеде кадар
 // Шюкюр олсун, Танръ корур. //</lyrics>
<key>C</key>
</song>