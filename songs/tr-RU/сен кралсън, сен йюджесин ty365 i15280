<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>365</hymn_number>
<author>Саадеттин Юнал</author>
<lyrics>[C1]
   Сен Кралсън, сен йюджесин,
   Месих, сен Куртаръджъмсън!

[V1]
 Сана ачтъм, бак, калбими
 // Раббим ве Танръм сенсин.  //
 Сана ачтъм, бак, калбими
 // Раббим ве Танръм сенсин.  //

[V2]
 Долдур Кутсал Рухунла
 // Раббим ве Танръм сенсин.  //
 Долдур Кутсал Рухунла
 // Раббим ве Танръм сенсин.  //

[V3]
 Сен яшамсън, сен герчексин.
 // Раббим ве Танръм сенсин.  //
 Сен яшамсън, сен герчексин.
 // Раббим ве Танръм сенсин.  //

[V4]
 Сонсуз йюджеликлер сана!
 // Раббим ве Танръм сенсин.  //
 Сонсуз йюджеликлер сана!
 // Раббим ве Танръм сенсин.  //

[V5]
 Тапънъръм, сана Иса.
 // Раббим ве Танръм сенсин.  //
 Тапънъръм, сана Иса.
 // Раббим ве Танръм сенсин.  //</lyrics>
<title>Сен Кралсън, Сен Йюджесин TY365</title>
</song>