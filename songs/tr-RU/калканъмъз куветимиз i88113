<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<lyrics>[V1]
 // Калканъмъз куветимиз тек сенсин
 сенсин бизим юмюдюмюз ве гювенджемиз //

[V2]
 // Севги олан Танръ бизи чок севди
 шейтанън елинден бизи чекти //

[V3]
 // Йюдже иса сана хамдлар едериз
 куртулушу канънда бизе вердин //</lyrics>
<title>калканъмъз куветимиз</title>
</song>