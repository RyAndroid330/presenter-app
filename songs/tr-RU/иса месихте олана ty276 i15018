<?xml version="1.0" encoding="UTF-8"?><song><title>Иса Месих'те Олана TY276</title>
<lyrics>[C1]
   //  Иса Месих'те олана
   Артък хичбир яргъ йоктур,
   Яргъ йоктур, яргъ йоктур.  //

[V1]
 //  Месих Иса сайесинде
 Бени гюнах чемберинден.  //
 //  Хем де ьолюм баларъндан
 ЬОзгюр етти Раб'бин Рух'у.  //</lyrics>
<hymn_number>276</hymn_number>
<author>Али Язар</author>
</song>