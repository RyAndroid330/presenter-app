<?xml version="1.0" encoding="UTF-8"?><song><title>Чюнкю Танръ Дюняйъ TY274</title>
<key>G</key>
<lyrics>[V1]
.   Em                 Bm
 // Чюнкю Танръ дюняйъ ьойле севди ки, //
.   Em                D
 // Бириджик Олуну верди,
.Bm                C
 Бириджик Олуну верди,
.Am                Em
 Бириджик Олуну верди. //

[C1]
.  G
   Шьойле ки, О'на иман еден
.     Em                   D
   // Сонсузларджа йок олмасън,
.  Bm                    C
   Сонсузларджа йок олмасън,
.  Am                   Em
   Анджак сонсуз яшамъ алсън. //</lyrics>
