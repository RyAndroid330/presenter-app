<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>57</hymn_number>
<author>Зафер Йюрюмез</author>
<key>Am</key>
<lyrics>[V1]
.   Am               E7         Dm         Am
 // Хичбир шефкат ве севги булунмаз Исам гиби. //
.   Am                 Dm       E7         Am
 // Хичбир дост бу аджълара даянмаз Исам гиби. //

[C1]
.     Am                     Dm
   // Чок севди, Раб, чок севди!
.         G7         C
   Хем джанънъ да верди,
.     F           Dm
   Хаятъмъз олсун дийе
.        E7        Am
   Калплеримизе гирди. //</lyrics>
<title>Хичбир Шефкат Ве Севги Булунмаз Исам Гиби TY57</title>
</song>