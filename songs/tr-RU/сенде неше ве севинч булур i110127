<?xml version="1.0" encoding="UTF-8"?><song><author>Дурмуш Тюнел</author>
<title>Сенде неше ве севинч булур</title>
<lyrics>[V1]
 // Сенде неше ве севинч булур,
 Гюнахтан сана йьонеленлер. //
 // Раб йюджедир десин хер диллер.
 Куртаръшънъ ьозлейенлер. //

[V2]
 // Не олур я Раб, куртар бени,
 Ярдъмъма кош, йетиш я Раб. //
 // Гюнахтан дьондюм, тьовбе еттим.
 Мерхамет я Раб, ишит бени. //

[V3]
 // Сенин севгин ешсиз ве дерин.
 Сана гелдим битер кедерим. //
 // Бугюн ярън хеп сенинлейим.
 Чюнкю сен бенде бен сендейим. //</lyrics>
</song>