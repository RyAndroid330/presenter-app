<?xml version="1.0" encoding="UTF-8"?><song><author>булгаристан илахиси</author>
<title>Не пара не де дюня 'нън севгиси</title>
<lyrics>[C1]
   // Не пара не де дюня'нън севгиси,
.      
       аджъмъ диндиремийор
   кимсе калбими теселли едемийор //

[C2]
   // Гючлю олмак истийорум
.      
       Теселли булмак
   ярдъмджъм олсун истийорум //

[C3]
   // Чармъха герилмиш Ъса'йъ
   хаятъма ве де калбиме истийорум
   куртулмак истийорум //</lyrics>
</song>