<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>587</hymn_number>
<lyrics>[C1]
   // Ей Аллахъм, Аллахъм ! //

[C2]
   // Кору бизи, Аллахъм ! //

[C3]
   // Беяз гьомлек вердим сана. //

[C4]
   // Ал да гий сен ону. //

[C5]
   // Иса Месих геледжек, //

[C6]
   // Бизи бурдан аладжак. //</lyrics>
<title>Ей Аллахъм, Аллахъм ! BG587</title>
</song>