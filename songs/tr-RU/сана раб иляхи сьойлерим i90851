<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[C1]
.      D             A
   // Сана Раб илахи сьойлерим
.  G                   F#m      Bm
   Кабул ет сен бу курбанъмъ //
.           Bm      A     G
   // Гьоркемли Кралсъ сен
.    F#m     Bm
   Ве лайъксън //

[C2]
   // ЬОвюйоум Танръм, шимди бен сени
.      
       тюм калбимле сени, йюджелтирим //
   // Кутсал, ве окадар ийи
.      
       ве лайъксън //

[C3]
   // Хамдолсун хамдолсун
   Сенин Йюдже исмине //
   // Мухтешемсин ей Раббим
   ве лайъксън //</lyrics>
<title>Сана Раб иляхи сьойлерим</title>
<author>Деджхко Деджхков</author>
</song>