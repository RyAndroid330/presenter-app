<?xml version="1.0" encoding="UTF-8"?><song><author>Ерен Атик</author>
<title>Танръм Бени Неден Теркеттин</title>
<key>Am</key>
<lyrics>[V1]
.   Am              G                 F
 // Танръм, Танръм, бени неден терк еттин? //
.F                E
 Ничин бана ярдъм етмектен
.Am          G
 Хайкъръшъма кулак вермектен
.F           E
 Узак дуруйорсун я Раб

[V2]
.   Am            G
 // Ей Танръм, гюндюз сесленийорум,
.F            E
 янът вермийорсун бана
.Am             G                     F
 Гедже сесленийорум, йине рахат йок бана
.F                 E
 Тек Калдъм Бурада Бир Башъма //

[C1]
.      Am               G
   /// Ама сен бенден я Раб
.    F             E
   Биран биле хич узак дурма
.  Am                  G
   Бу Дерттен Куртар Бени
.     F               E
   Сеслендиимде кош ярдъмъма ///</lyrics>
</song>