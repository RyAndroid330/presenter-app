<?xml version="1.0" encoding="UTF-8"?><song><author>Гюркан Чамсун, Левент Кънран</author>
<hymn_number>496</hymn_number>
<title>Сени Андъъмда TY496</title>
<lyrics>[V1]
.   Emin
 // Сени андъъмда,
.B7
 Дерин дюшюндююмде
.Emin
 Джанъм дояр сана.
.B7                 Emin           B7
 Азъм севинчли дудакларла хамт едер. //

[V2]
.Amin
 Шефкатине докунмак ичин
.Emin              B7
 Джанъм сени ьозлер,
.Amin
 Канатларънън гьолгесинде
.Emin             B7
 Джанъм сени истер.
.           Emin
 ЬОзлерим сени!</lyrics>
<key>Em</key>
</song>