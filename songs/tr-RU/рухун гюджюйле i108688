<?xml version="1.0" encoding="UTF-8"?><song><title>Рух'ун Гюджюйле</title>
<lyrics>[V1]
.   Dm              C              F
 // Рух'ун гюджюйле далар йеринден ойнар //
.   Dm                  Dm          F
 // Атештен диллер гиби инди юстюмюзе //
.   Dm                     C             F
 // Кутсал Рух'ла конуштук халклар арасънда //
.   Dm                  Dm               F
 // Кудретле илан еттик Иса'нън адънъ //
.   Dm                C            F
 // Сарсълдъ каранлък адънъ дуйунджа //
.   Dm                   Dm               F
 // Кьор гьозлер ачълър, ьолюлер джан булур //
.   Dm             C                 F
 // Далар денизлер ьонюмюзден качаджак //
.   Dm               Dm          F
 // Дирилиш доладжак хер бир сокаа //</lyrics>
<key>Dm</key>
<author>Мустафа Керем Кьосем</author>
</song>