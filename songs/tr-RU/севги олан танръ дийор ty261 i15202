<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Севги олан Танръ дийор:
 &quot;Бен сени хич унутамам.  //

[V2]
 //  Бир анне хич унутур му
 Емзиктеки яврусуну?  //

[V3]
 //  Онлар сени унутса да
 Асла сени бен унутмам.  //

[V4]
 //  Чюнкю сени еллеримин
 Ортасъна накъш еттим.&quot;  //</lyrics>
<title>Севги Олан Танръ Дийор TY261</title>
<hymn_number>261</hymn_number>
<author>Али Язар</author>
</song>