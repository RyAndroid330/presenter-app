<?xml version="1.0" encoding="UTF-8"?><song><title>Кан дьокюлмеден баъшлама олмаз</title>
<lyrics>[V1]
 // Кан дьокюлмеден баъшлама олмаз  //
 Ама шимди исе, шимди исе
 Месих'ин дьокюлен канъ сайесинде
 Гюнахтан аръндък канъ сайесинде
 // Баъшландък  //
 Канъ сайесинде
 // Куртулдук  //
 Канъ сайесинде
 Ибранилер, Ибранилер 9:22</lyrics>
<author>Серап Гюнай</author>
<hymn_number>20</hymn_number>
</song>