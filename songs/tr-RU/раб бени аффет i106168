<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em             Bm7
 // Раб бен кимим ки бени севдин? //
.Am7                     B7
 // Сенин севгин куртулуштур Раб'бим //
.C                   Em
 \\ Беним ичин ьолдюн, Раб бени аффет
.D                 Am7
 Гюнахъмъ ьорттюн, Раб бени аффет \\ x2

[V2]
.Em             Bm7
 // Раб сен беним хер шейимсин //
.Am7                     B7
 // Сенин севгин куртулуштур Раб'бим //
.C                   Em
 \\ Беним ичин ьолдюн, Раб бени аффет
.D                Am7
 Гюнахъмъ ьорттюн канънла, Раб бени аффет \\ x2

[V3]
 /// Раб бени аффет ///

[V4]
 /// Раб бана тьовбе еден алчалмъш бир йюрек вер. ///</lyrics>
<title>Раб бени аффет</title>
<author>Нисан ЬОзлем ЬОзяпъджъ</author>
</song>