<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>135</hymn_number>
<author>Давид Гоодман</author>
<lyrics>[V1]
 //  Бени кувветлендиренде
 Хер шей япабилирим.  //
 //  Не заман да зайъф исем,
 О заман кувветлийим.  //

[V2]
 //  Кенди зайъфлъкларънъ
 Биленлерин хепсине.  //
 //  Раб якън ве ярдъм едер,
 Бу сьоз гечерли бизе.  //

[V3]
 //  Иса'я гювендиимде
 Имкансъз бир шей калмаз.  //
 //  О'нун йолунда йюрюркен
 Мюмкюн олмаян олмаз.  //

[V4]
 //  Бени кувветлендиренде
 Хер шей япабилирим.  //
 //  Хаят теджрюбелеримде
 Галип гелебилирим.  //</lyrics>
<title>Бени Кувветлендиренде TY135</title>
</song>