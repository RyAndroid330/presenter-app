<?xml version="1.0" encoding="UTF-8"?><song><title>Лютуф Тахтъна, Сенин Хузуруна TY619</title>
<lyrics>[V1]
 //  Лютуф тахтъна, сенин хузуруна,
 Яклашъръм Раббим, ихтияч анънда.  //

[C1]
   //  Гьоркемли Раб,
   Гючлю Танръ,
   Йюджелик Раб'би.  //

[V2]
 //  Сана яклашъръм Месих'ин канъйла,
 Кутсал бир яшамън сунусуйла Раббим.  //</lyrics>
<author>Биллие Wаллет</author>
<hymn_number>619</hymn_number>
</song>