<?xml version="1.0" encoding="UTF-8"?><song><title>Я раб сенден башка</title>
<lyrics>[V1]
 // Я Раб сенден башка
 киме гидейим
 сенсин бени ярадан,
 ен ийи анлаян //

[C1]
   // Сана съънъйорум
   Сана баръйорум
   Бени рахатлатан Аллах'ъ
   Сенин севгин чок, бюйюк
   Сенин сабрън чок бюйюк
   Бени аякта тутан Раббим //

[V2]
 // Хер гюн сенин йюзуну аръйорум бен
 чюнкю дердиме чаре олуйорсун сен //

[V3]
 // Сьозюню окумактан
 тат алъйорум,яшамам ичин юмит верийор //</lyrics>
</song>