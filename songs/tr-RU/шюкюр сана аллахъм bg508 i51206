<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>508</hymn_number>
<key>D</key>
<lyrics>[V1]
.D    G        D
 Аллаха диз чьокюйорум,
.       G          D
 хем алъйом,хем дуа япийом.
.Bm               G
 // Чоджууму калдърдън.
.   Em    A      D
 Она куввет сен вердин. //

[V2]
.D        G       D
  Шюкюр сана, Аллахъм.
.    G     D
 Дуамъ ишиттин.
.Bm                G
  // Чоджууму калдърдън.
.   Em    A        D
 Она куввет сен вердин. //

[V3]
.D       G      D
 Бютюн дюня гезеджем,
.        G        D
 Исмини бен ьоведжем.
.Bm                G
 // илахилер сана япаджам.
.   Em    A        D
 Раббими бен ьоведжем. //
.D     G      D
 Инанън кардашлар,
.      G       D
 Инанън къзкардашлар!
.Bm                 G
 // Раб Иса тезде геледжек,
.    Em    A      D
 Бизи бурдан аладжак. //</lyrics>
<aka>Аллаха диз чьокюйорум</aka>
<title>Шюкюр сана Аллахъм BG508</title>
</song>