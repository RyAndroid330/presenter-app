<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<lyrics>[V1]
 // Гювен яврум гювен бана хер заман сенинлейим хер заман сана дестеим //

[V2]
 // Ал бени яралъ елерине раб иса хер заман бенимле ол херзаман ве бени кайър //

[V3]
 // Гьоз яшларъмъз динеджек бир гюн аджъларъмъз сона еришеджек хеп берабер раб бин оладжаъз дженнете сенинле севинеджеиз //

[V4]
 // Мутлу гюнлер чок якънда инан яврум инан буна гелишим чок тез //

[V5]
 // хазърла бени раб бим сана уйгун ет бени Хер Заман айък тут бени ве сана садък //</lyrics>
<title>Гювен Яврум</title>
</song>