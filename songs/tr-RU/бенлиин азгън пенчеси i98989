<?xml version="1.0" encoding="UTF-8"?><song><title>Бенлиин азгън пенчеси</title>
<lyrics>[V1]
 // Бенлиин азгън пенчеси,
 Бизи ьолюме хапсетти. //
 // ТАНРЪ бизе лютуф етти,
 Севгили олу джан верди. //

[C1]
   Хамд един севгиси ичин,
   Шюкредин кайрасъ ичин.
   ЬОвгюйле Гьоксел Баба'йъ,
   Рух ве герчекте йюджелтин.

[V2]
 // Месих'ин яра излери
 Хер ярама шифа верди. //
 // Дьоктюю хер кан зерреси,
 Ебеди яшамъ верди. //</lyrics>
<author>Дурмуш Тюнел</author>
</song>