<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>558</hymn_number>
<key>D</key>
<lyrics>[V1]
.D         G   A
  Хузурунда дурмак,
.D      G   A
 Янънда отурмак,
.D          G  A
 Севгинин сардъъ,
.D         G   A
  О йерде булунмак.

[C1]
.     D         G6      A
   //  Тек истеим бу, Раббим,
.            D
   Тек истеим бу  //

[V2]
.D         G  A
 Янънда динленмек,
.D         G A
  Аджеле етмеден.
.D            G   A
  Хер андан тат алмак,
.D          G   A
  Хеп бурада калмак.</lyrics>
<title>Хузурунда Дурмак TY558</title>
</song>