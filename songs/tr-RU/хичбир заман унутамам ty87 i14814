<?xml version="1.0" encoding="UTF-8"?><song><author>Ерол ЬОзер, Али Язар</author>
<hymn_number>87</hymn_number>
<title>Хичбир Заман Унутамам TY87</title>
<lyrics>[C1]
   Хичбир заман унутамам
   Раб'бин ийиликлерини.
   Джошар калбим севинч иле
   Дюшюндюкче севгисини.
   Джошар калбим севинч иле,
   Танръмън кайрасъ иле.

[C2]
   //  Кардеш, насъл унутайъм
   Чамурдан чъкаръшънъ.
   Джошар калбим севинч иле
   Дюшюндюкче севгисини.  //

[C3]
   //  Не кьотюйдю ески яшам!
   Севги, севинч нередейди?
   Боша гечти хеп гюнлерим,
   Бенлиим де мутсуз иди.  //

[C4]
   //  Не гюзелмиш йени яшам
   Месих'ин севгиси иле!
   Герчек йол ве сонсуз яшам
   Сьоз верилди Иса иле.  //</lyrics>
</song>