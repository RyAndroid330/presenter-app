<?xml version="1.0" encoding="UTF-8"?><song><title>Бизе Вер, Вер, Вер, Вер, Вер, Бизе Вер TY301</title>
<lyrics>[C1]
   //  Бизе вер, вер, вер, вер, вер, бизе вер
   Кутсал Рухуну бизе вер!
   Бизе гел, гел, гел, гел, гел, бизе гел
   Я Раб Исам, калбиме гел!  //

[V1]
 //  Шефкатини, севгини, кутсал олан хер шейи.  //
 //  Яраттъън севгийи, дюрюст олан герчеи.  //

[V2]
 //  Исам яшамън болдур, йолун тек герчек йолдур.  //
 //  Калбимизи сен долдур, берекетлерин чоктур.  //</lyrics>
<hymn_number>301</hymn_number>
<author>Фарук Пекер</author>
</song>