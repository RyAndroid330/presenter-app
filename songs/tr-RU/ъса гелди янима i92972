<?xml version="1.0" encoding="UTF-8"?><song><title>Ъса гелди янима</title>
<lyrics>[V1]
 // Ъса гелди янима
 Сонсуз хаят верди бана //
 // Шюкюрлер ьовгюлер олсун сана //

[V2]
 // Хаятими вердим сана
 Яшамими вердим сана //
 // Сен сахип джик бана ей алахим //

[V3]
 // Хер дердиме дерман иса
 Хер астая шифа иса //
 // Дуй беним дуами ей алахим //</lyrics>
</song>