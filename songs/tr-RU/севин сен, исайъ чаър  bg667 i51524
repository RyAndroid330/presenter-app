<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>667</hymn_number>
<lyrics>[V1]
 /// Севин сен, Иса'йъ чаър !
 Гедже гюндюз Ону ан ! ///
 // Гунахларънъ
 Денизе О аттъ. //

[V2]
 /// Сенин ичин Раб Иса
 Хачта чекти аджъйъ. ///
 // Адънъ яздъ
 Хаят китабъна. //

[V3]
 /// Сен Хизмет ет Иса'я,
 ЬОдюлюн бюйюк олсун ! ///
 // Севинчле сенин
 Йюрейинде калсън. //</lyrics>
<title>Севин сен, Иса'йъ чаър ! BG667</title>
</song>