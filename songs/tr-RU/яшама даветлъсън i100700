<?xml version="1.0" encoding="UTF-8"?><song><author>&quot;Едwин&quot; Джордж Бахчеджиолу, Арапча'дан</author>
<title>ЯШАМА ДАВЕТЛЪСЪН</title>
<lyrics>[V1]
 // Яшама яшама Месихте бол яшама
 //  Даветлисин унутма Месихле бол яшама

[V2]
 // Сакън акълсъз олма ве О йълана канма
 //  Адем яшаян джандъ ве кандъ О йълана

[V3]
 // Сулара сулара гелин дири сулара
 //  Сусаян гелсин ичсин яшам суйу бедава

[V4]
 // Яшам герчек йол беним гьоктен инен екмеим
 //  Бу екмеи йийене сонсуз яшам вереним

[V5]
 // Хоссанна хоссанна Раббимизе хоссана
 //  Сусаян гелсин ичсин яшам суйу бедава

[V6]
 // Беденими йийенде ве канъмъ ичинде
 //  Яшаръм артък онда ве ода артък бенде

[V7]
 // Яшама яшама Месихте бол яшама
 //  Даветлисин унутма Месихле бол яшама</lyrics>
</song>