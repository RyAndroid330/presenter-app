<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Сусадъм Сана я Раб
 ЬОзлем атешийле янъйорум
 Беклийорум Сени я Раб
 Варлъънъ хиссетмек истийорум

[V2]
 // Гел Раб бени йениле
 Гел Раб бени тазеле
 Чюнкю Сана мухтаджъм Раб //
 Гюджюм Сенсин ей Танръм

[V3]
 // Сени беклийорум гел Иса
 Сени беклийорум гел я Раб //</lyrics>
<title>Варлъънъ ЬОзледим BG51</title>
<hymn_number>51</hymn_number>
<author>Кати Аниова, Микерем Друмева, Аско Коче</author>
</song>