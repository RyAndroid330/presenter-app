<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>324</hymn_number>
<author>Марк Нелсон</author>
<copyright>1987 Меркы / Винеярд Публишинг</copyright>
<key>E</key>
<lyrics>[V1]
.E    A         B
 Иман едерим Иса'я,
.E         A        B
 Инанъръм Танръ Олуна!
.E         A         B
 Еминим ьолюп дирилдиине,
.E        A        B
 Джезамъ да чектиине.

[C1]
.             A        B     E
   (Еркеклер) Еминим, О бурададър!
.                           A
   (Кадънлар)  Еминим, О бурада,
.              B       E
   (Берабер)   Арамъздадър.
.              A       B         E
   (Еркеклер)  Шифа верир кудретийле!
.                              A
   (Кадънлар)  О'нда вар шифа гюджю,
.                     B      E
   (Берабер)   Лютфуйла аффедер.</lyrics>
<title>Иман Едерим Иса'я TY324</title>
</song>