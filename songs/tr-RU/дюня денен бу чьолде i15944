<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Дюня денен бу чьолде
 Йюрюрюм гюндюз гедже //
 // Рух'ун йьонлендирдикче
 Йюрюрюм о севиндже //

[V2]
 Йюрюрюм ашкла Йюрюрюм шевкле
 Йюрюрюм зевкле, Сенинле.
 Йюрюрюм ашкла Йюрюрюм шевкле
 Йюрюрюм зевкле, сонсуза.

[V3]
 // Хаят денен бу йолда
 Йюрюрюм дюше калка //
 // Гьонюл Месих олдукча
 Йюрюрюм коркусузджа //

[V4]
 Йюрюрюм ашкла Йюрюрюм шевкле
 Йюрюрюм зевкле, Сенинле.
 Йюрюрюм ашкла Йюрюрюм шевкле
 Йюрюрюм зевкле, сонсуза.</lyrics>
<title>Дюня денен бу чьолде</title>
<author>Тургай Ючал</author>
</song>