<?xml version="1.0" encoding="UTF-8"?><song><title>Гел Аллахъм сен иса</title>
<lyrics>[V1]
 // Гел Аллахъм сен Ъса
 Гел сен янъма
 Сана мухтаджъм
 Дестек ол бана //

[V2]
 // Кутсал Рухунла куввет вер бана
 Бен чок зайъфъм Ярдъм ет Бана //

[V3]
 // Беним ичин Аллахъм иса
 Тахтънъ сен брактън
 Канънла Йъка бени
 Ей мерхаметли Ъса //

[V4]
 // Хазърла бени Раббим Ъса
 Сана уйгун Ет
 Нурлу йюзюню
 Бенде Гьорейим //</lyrics>
<author>Адил Яшар</author>
</song>