<?xml version="1.0" encoding="UTF-8"?><song><title>БАК КАЛБИМЕ ГЬОР БЕНИ</title>
<lyrics>[V1]
 ЧАРЕСИЗМ АЛЛАХИМ
 СЕН ЯРДЪМ ЕТ БАНА
 ГЕЛГЬОР БУ ХАЛИМИ
 ДИНЛЕТЕИМ САНА

[C1]
   БАК КАЛБИМЕ ГЬОР БЕНИ
   ТУТ ЕЛИМДЕН АЛ БЕНИ
   ЙЕП ЙЕНИ ИНСАН ЯПБЕНИ
   СЕН ГЮЧЛЮСУН ИСА

[V2]
 ДЮШЕНИН ДОСТУСУН
 ЙЮДЖЕ СИН ИСАМ
 ХЕРКЕСЕ КОШАРСЪН ЙЮДЖЕСИН ИСА</lyrics>
</song>