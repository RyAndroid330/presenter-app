<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Йълларджа йерйюзюнде долаштъ Иса,
 Инсанлара дорулуу ьоретти Иса,
 Шейтана уярлар кьотюйе тапарлар,
 Ебединдже джехеннемде янаджаклар. //

[C1]
   // Бу дюня битеджек, йълдъзлар дюшеджек.
   Каранлък оладжак, Иса геледжек.
   Йолуну билмейен перишан оладжак,
   Ебеди джехеннемде янаджаклар. //

[V2]
 // Ей перишан инсанлар вазгечин долашмактан.
 Бу дюнянън чевресинде сизе йоктур ватан.
 Кабул един Иса'йъ , иман един инсанлар,
 Сизе рахатлък версин , Иса Месих. //</lyrics>
<title>Йълларджа Йерйюзюнде Долаштъ Иса BG70</title>
<hymn_number>70</hymn_number>
</song>