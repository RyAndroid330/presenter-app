<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // каранлъктан кьолеликтен гелийорум сана иса
 гюнахъмъ йюкюмю ал бенден сен иса //

[V2]
 хамдедерим сана раббим дуамъ сен ишиттин
 // мутлу еттин севинч вердин
 йюреими теселли еттин //

[V3]
 // сана хизмет едеджеим сени раб бим ьоведжеим чаресиздим перишандъм
 дердиме чаре олдун //</lyrics>
<title>каранлъктан кьолеликтен</title>
<author>Адил Яшар</author>
</song>