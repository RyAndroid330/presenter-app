<?xml version="1.0" encoding="UTF-8"?><song><title>Гюджю Хер Шейе Йетен Раб Танръ</title>
<lyrics>[V1]
 // Гюджю Хер Шейе Йетен Раб Танръ
 Сенин Ишлерин Бюйюк
 Ве шашъладжак ишлердир Ей Улусларън Кралъ //

[V2]
 // Раб Сенден Коркмайъп
 Адънъ Йюджелтмейеджек Олан ким Вар?
 Чюнкю Кутсал Олан Ялнъз сенсин Раб Иса //

[V3]
 // Ей Танръмъзън Бютюн Кулларъ
 Кючюк Бюйюк Ондан
 Коркан Хепиниз Ону сиз ьовюн она сиз Тапънън //</lyrics>
</song>