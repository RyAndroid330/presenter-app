<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<title>Ей Перишан Джанъм TY126</title>
<lyrics>[V1]
.   Em  B7     Em
 Ей перишан джанъм,
.         Am    B7
 Вазгеч долашмактан!
.   Em         Am6  B7
 // Бу дюнянън чевресинде
.  Em    B7    Em
 Сана йоктур ватан. //

[V2]
.  Em      B7   Em
 Иште, Раб'бин еви!
.       Am    B7
 Иште, ачък капъ!
.   Em              Am6   B7
 // Гир, ей джанъм, бу мескене!
.   Em     B7 Em
 Ал сонсуз хаятъ! //

[V3]
.   Em   B7   Em
 Ор'да отур емин,
.       Am      B7
 Сени север Раббин.
.   Em         Am6   B7
 // Арзуларън' едер татмин,
.    Em    B7    Em
 Хер шей олур сенин. //

[V4]
.   Em  B7     Em
 Ей перишан джанъм,
.         Am    B7
 Вазгеч долашмактан!
.   Em         Am6  B7
 // Бу дюнянън чевресинде
.  Em    B7     Em
 Сана йоктур ватан. //</lyrics>
<key>Em</key>
</song>