<?xml version="1.0" encoding="UTF-8"?><song><title>Рабби Андъм Бен</title>
<lyrics>[V1]
 // Рабби андъм Бен дуамда
 Ишитти сесими О анънда
 Диз чьокюп аф диледим
 Баъшла бени Раббим дедим //

[C1]
   // Гечмишим некадар Каранлък
   Гюнях юстюне Гюняхмиш
   Алданмъшъм чок аджъйъмъш
   Гюняхъм Бана зарарлъймъш //

[V2]
 // Тьовбе едип баърдъм
 Хер дуамда аладъм
 Гюнахларъмъ Итираф едип
 Раббе умут Баладъм //

[V3]
 // Раб Месих Капими чалдъ
 Каранлъъмъ айдънлаттъ
 Гюняхларими силип баъшладъ
 Бени йеп йени Инсан яптъ //</lyrics>
<author>Хюсейин Кумбе, Ахмед Музафер</author>
</song>