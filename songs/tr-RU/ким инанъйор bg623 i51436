<?xml version="1.0" encoding="UTF-8"?><song><title>Ким инанъйор BG623</title>
<lyrics>[V1]
 // Ким инанъйор
 Иса Месихе
 ЬОлмейеджек,
 Яшаяджак. //

[V2]
 // Верин гиделим
 Онун изинден,
 Шюкюр еделим
 Иса Месихе. //

[V3]
 // Йъка сен бени,
 Бесле сен бени,
 Сула сен бени,
 Терк етме бени. //

[V4]
 // Янгън олджак,
 Атеш оладжак,
 Баъръш оладжак,
 Дюня янаджак. //

[V5]
 // Аллах геледжек,
 Йере инеджек,
 О бейенеджек,
 Темизлейеджек. //</lyrics>
<hymn_number>623</hymn_number>
</song>