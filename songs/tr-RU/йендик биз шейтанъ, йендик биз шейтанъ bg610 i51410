<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>610</hymn_number>
<lyrics>[V1]
 // Йендик биз шейтанъ, йендик биз шейтанъ,
 Йендик биз шейтанъ Иса'йла. //

[V2]
 // О Алелуя, о Алелуя
 Йендик биз шейтанъ Иса'йла. //

[V3]
 // Иса'нън адънъ, Иса'нън адънъ
 Иса'нън адънъ ьовюйоз. //

[V4]
 // О Алелуя, о Алелуя
 Иса'нън адънъ ьовюйоз. //
 // Артък биз сербезиз, артък биз сербезиз,
 Артък биз сербезиз Шейтандан. //

[V5]
 // О Алелуя, о Алелуя
 Артък биз сербезиз Шейтандан. //
 // Йендик биз шейтанъ, йендик биъ шейтанъ,
 Йендик биз шейтанъ Иса'йла. //

[V6]
 // О Алелуя, о Алелуя
 Йебдик биз шейтанъ Иса'йла. //</lyrics>
<title>Йендик биз шейтанъ, йендик биз шейтанъ BG610</title>
</song>