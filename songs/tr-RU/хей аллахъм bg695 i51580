<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>695</hymn_number>
<title>Хей Аллахъм BG695</title>
<lyrics>[C1]
   // Хей Аллахъм,
   Чок севдим сени.
   Йюзюню гьормеден
   Инандъм сана. //

[V1]
 // Шюкюр сенин адъна.
 Шюкюр сенин канъна.
 Кой севаплъ елини
 Беним башъма. //

[C2]
   // Йъка бени, Аллахъм,
   Кувветли суйунла.
   Йъка бени, Аллахъм,
   О темиз канънла. //

[C3]
   // Еллерими калдърдъм,
   Сана дуамъ вердим.
   Бен сана йемин еттим,
   Сенинле олайъм. //

[C4]
   // Вер бана шифа, Аллахъм,
   Шифанъ булайъм.
   Вер бана севинч, Аллахъм,
   Севинчли олайъм. //

[C5]
   // Кору бени, Аллахъм,
   Сон гюне кадар.
   Аффет бени, Аллахъм,
   Сон гюне кадар. //</lyrics>
</song>