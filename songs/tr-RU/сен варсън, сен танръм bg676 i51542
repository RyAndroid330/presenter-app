<?xml version="1.0" encoding="UTF-8"?><song><title>Сен варсън, сен Танръм BG676</title>
<lyrics>[V1]
 // Сен варсън, сен Танръм,
 Шу йерйюзюнде.
 Сен гьоктесин,
 сен йерде, а... а... а...
 Сен бютюн дюняда. //

[C1]
   // Бизим ичин герилдин,
   Бизим ичин ьолдюн.
   Ал бизи янъна, а... а... а...
   Шюкюрлер еделим сана. //

[C2]
   // Сана ялваръйоз,
   Сенден истийоруз.
   Бизим бу зайъф
   дуамъзъ, а... а... а...
   Кабул ет, сен Иса. //</lyrics>
<hymn_number>676</hymn_number>
</song>