<?xml version="1.0" encoding="UTF-8"?><song><title>Ей Танръ, Темиз Бир Йюрек Ярат TÇ41</title>
<key>D</key>
<lyrics>[V1]
.    Bm        A           G    A
 // Ей Танръ, темиз бир йюрек ярат!  //
.    Bm          Em              Bm     A
 // Йениден карарлъ бир рух вар ет ичимде!  //
.A    Bm       A
 Ичимде, ей Танръ!
.Bm         A           G
 Мезмурлар еллибир айет он.
.     A
 Ичимде!</lyrics>
