<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>673</hymn_number>
<lyrics>[V1]
 // Сен ачтън гьозлеримизи, Аллах,
 Гьорелим дюняйъ. //

[C1]
   Факирлере, хаста оланлара,
   Раб Исам, сен гелдин.
   Факирлере, хаста оланлара,
   Раб Исам, сен вердин.

[C2]
   // Чок гюнахлъ олуйоз, Аллахъм,
   Аръндър сен бизи. //

[C3]
   // Бизим гюнахларъмъздан ичин,
   Месихим, сен ьолдюн. //

[C4]
   // Сен куртардън бизи, ей Аллахъм,
   Каранлък дюнядан. //</lyrics>
<title>Сен ачтън гьозлеримизи, Аллах BG673</title>
</song>