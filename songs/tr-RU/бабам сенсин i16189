<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.Dm
 Бен ялнъз олмам
.Gm         Dm
 Янъмда Сенсин
.Gm                 F
  // Бен ьоксюз калмам
.Dm
 Бабам Сенсин //

[V2]
.Dm         Cm
  Бени билир бени анлар
.Gm          Dm
 &quot;Яврум&quot; дерсин
.Dm          Cm
  Дар гюнюмде янъмдасън
.Gm        Dm
 Бени северсин

[V3]
.Dm           Gm
  // Сучларъмъ аффедерсин
.Cm           Gm
 Бени йенилерсин
.Gm        Cm
  Бу дюняда тек ъшъъм
.Gm         Dm
 Раббим Сенсин //

[V4]
.Dm
  Сен варсан янъмда
.Gm        Dm
 Атештен янмам
.Gm                F
  // Сен варсан хайатъмда
.Dm
 Иблис'е канмам //

[V5]
.Dm            Cm
  Сен теселлим, Сен умудум
.Gm        Dm
 Яшам кайнаъм
.Dm              Cm
  Сен куртаръджъм йюдже Раббим
.Gm      Dm
 ве съънаъм

[V6]
.Dm           Gm
  // Бу дюняда герчек достум
.Cm          Gm
 Дерде дерманъм
.Gm          Cm
  Йерлеш йюреимде Раббим
.Gm         Dm
 Артсън иманъм //</lyrics>
<key>Bb</key>
<title>Бабам Сенсин</title>
<author>Сели МЪДЪСЪ</author>
</song>