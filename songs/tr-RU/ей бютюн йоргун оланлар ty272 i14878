<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Ей бютюн йоргун оланлар,  //
 //  Йюклери аър геленлер,  //
 //  Бана гелин чекинмеден  //
 //  Сизе рахат веририм бен.  //

[V2]
 //  Бойундуруум' такънън,  //
 //  Джанларънъз рахат булсун.  //
 //  Бойундуруум колайдър,  //
 //  Йюкюм исе чок хафифтир.  //

[V3]
 //  Бана гелин ей йоргунлар,  //
 //  Хем де бенден там ьоренин.  //
 //  Бен йумушак хуйлуйум,  //
 //  Хем де алчак гьонюллюйюм.  //</lyrics>
<title>Ей Бютюн Йоргун Оланлар TY272</title>
<hymn_number>272</hymn_number>
<author>Али Язар</author>
</song>