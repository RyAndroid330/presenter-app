<?xml version="1.0" encoding="UTF-8"?><song><title>Шюкюр, хамдлар олсун саде BG714</title>
<lyrics>[V1]
 // Шюкюр, хамдлар олсун саде
 Раб Иса'я, Раб Иса'я, Раб Иса'я //
 // Шюкюр, хамдлар олсун саде Иса'я
 (Халелуя), Иса'я, Иса'я. //

[V2]
 // Куджаъна сен ал бени, мубарекле,
 Мубарекле, мубарекле. //
 // Куджаъна сен ал Иса, мубарекле
 (Халелуя), мубарекле, мубарекле. //

[V3]
 // Истийом даътайъм татлъ хабери,
 Татлъ хабери, татлъ хабери. //
 // Истийом даътайъм татлъ хабери
 (Халелуя) татлъ хабери, татлъ хабери. //

[V4]
 // Алелуя, Алелуя, (Алелуя),
 Алелуя, Алелуя. //
 // Алелуя, Алелуя, (Алелуя),
 Алеллуя, Алелуя. //</lyrics>
<hymn_number>714</hymn_number>
</song>