<?xml version="1.0" encoding="UTF-8"?><song><title>Аллах гелдийи гиби BG507</title>
<lyrics>[V1]
 // Аллах гелдийи гиби,
 Хава карараджак,
 Хава карараджак.
 Къзанлар аалаяджак. //

[C1]
   Аллахъмъз Иса,
   Канънъ сен дьоктюн,
   Канънъ сен дьоктюн,
   Бютюн дюня ичин.

[C2]
   // Аллах гелдийи гиби,
   Атеш бракаджак,
   Атеш бракаджак,
   Имансъзлар янаджак. //
   // Аллах гелдийи гиби,
   Хава карараджак,
   Хава карараджак,
   Инанчларъ аладжак. //</lyrics>
<hymn_number>507</hymn_number>
</song>