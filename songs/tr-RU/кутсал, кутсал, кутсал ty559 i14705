<?xml version="1.0" encoding="UTF-8"?><song><title>Кутсал, Кутсал, Кутсал TY559</title>
<lyrics>[V1]
.   Am      Dm      Am
 // Кутсал, Кутсал, Кутсал!
.  G         Em         Am         A
 Я Раб, Танръмъз, гьоклерин Рабби!  //

[C1]
.         A            G         D       A
   // Вар олмуш, вар олан, сонсузларджа олан! //

[V2]
.   Am      Dm      Am
 // Кадосх, Кадосх, Кадосх //
.    G     Em        Am
 Адонай Елохим Тзева'от!

[C2]
.        A    G        D       A
   // Асхер хаях ве'ховех ве'яво. //</lyrics>
<key>C</key>
<author>Элишева Шомрон</author>
<hymn_number>559</hymn_number>
</song>