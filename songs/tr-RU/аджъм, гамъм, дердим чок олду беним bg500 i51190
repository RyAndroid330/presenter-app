<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Аджъм, гамъм, дердим чок олду беним.
 // Нерелере гидейим, дерман истейим ? //

[V2]
 Йум сен гьозлерини, калдър еллерини.
 // Баър, сьойле дердини, ишитеджем. //

[V3]
 // Бен де чок севинийом, хани беним олдунуз. //

[V4]
 // Хер бир дердинизе дерман олуйорум. //

[V5]
 // ЬОнюме гелен бени вуруп дьовдюлер. //

[V6]
 // ЬОнюме геленлере бойун ейдим бен. //
 // Бьойле чиле, яврум, вермем бен сизе. //</lyrics>
<title>Аджъм, гамъм, дердим чок олду беним BG500</title>
<hymn_number>500</hymn_number>
</song>