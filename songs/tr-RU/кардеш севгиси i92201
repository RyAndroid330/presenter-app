<?xml version="1.0" encoding="UTF-8"?><song><title>Кардеш Севгиси</title>
<key>Am</key>
<lyrics>[V1]
.Am                F                  Am
 // Кардешлер, дюня сизден нефрет едерсе
.F            Am
 шашмайън. //

[V2]
.Dm                                  Am
 // Кардешлери севдиимизде ьолюмден йашама
.F      Am
 гечериз. //

[V3]
.Am            F                Am    F Am
 Явруларъм сьозле деил ейлемле севелим
.Am           F                Am       F Am
 Явруларъм дилде деил ичтенликле севелим

[V4]
.Dm                         Am
 // Бьойлеликле герчее аит олдуумузу
.F     Am
 билириз. //</lyrics>
<author>Ерджан Вурал</author>
</song>