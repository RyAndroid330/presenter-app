<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.   Em
 // Тек герчек, тек йол Сенсин,
. B7            Em
 Раббим, халелуйа! //
.    Em              B7             Em
 // Иса, севинджимиз Сенсин, халелуйа! //

[V2]
.Em
 // Кралларън Кралъ Сенсин,
.B7             Em
 Раббим, халелуйа! //
.Em                  B7            Em
 // Иса, Баръш Пренси Сенсин, халелуя! //</lyrics>
<title>Тек Герчек Тек Йол Сенсин TY203</title>
<author>Наоми Батя, Софие Конты</author>
<hymn_number>203</hymn_number>
</song>