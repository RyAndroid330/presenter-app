<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Дюня'нън Сонун'да Иса йине геледжек
 Бизи алъп гидеджек дженнете гьотюреджек //

[V2]
 // Сенде гел гюнахкàр гел оку келамъ
 Иман ет Иса'я баъшласън гюнахънъ //

[V3]
 Вакит чок аз калдъ Иса тезде геледжек,
 Бизи она чекеджек, дженнете гьотюреджек
 Вакит чок аз калдъ Иса тезде геледжек,
 Сен хазъмъсън буна гьоксел дююнде бирликте

[V4]
 // Ачън калбинизи иман един она
 Куртулуш ондадър гелин гелин Иса'я //</lyrics>
<title>Дюня'нън Сонун'да Иса йине геледжек</title>
<author>Адил Яшар</author>
</song>