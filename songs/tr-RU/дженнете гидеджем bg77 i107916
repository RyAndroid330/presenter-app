<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>77</hymn_number>
<lyrics>[C1]
   // Дженнете гидеджем гидеджем
   Гидеджем гидеджем дженнете //
   Гидеджем гидеджем бен дженнете гидеджем - /2

[V1]
 // Бен иса'йи такип едийор
 Ве севийорум
 Онун ярдиндан бен бен хер заман гидийорум //

[V2]
 // Сенде гелл ардъндан
 Шимди гел дженнете //</lyrics>
<title>Дженнете Гидеджем BG77</title>
</song>