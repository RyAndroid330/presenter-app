<?xml version="1.0" encoding="UTF-8"?><song><author>Мустафа Керем Кьосем</author>
<title>Беним Аллах'ъм Сенсин</title>
<key>Am</key>
<lyrics>[V1]
.   Am                     Em
 // Беним Аллах'ъм сенсин я Раб Иса
.Am                   Em
 Сехер вактинде сени араръм
.Am                 Em
 Джанъм сана сусамъштър
.Em                  Am
 Йюреим сени ьозлер Иса //

[V2]
.Am
 Ятаъмда сени андъъм
.Am
 Дерин дерин дюшюндююм
.Am                   Em
 Йюреими сана ачтъъм заман
.Em             Em
 Яклашъръм варлъъна

[V3]
.   Am
 // Беним Аллах'ъм сенсин
.Am
 Гьоркемин бени сарсън
.Am                     Em
 Беним Аллах'ъм сенсин я Раб Иса //</lyrics>
</song>