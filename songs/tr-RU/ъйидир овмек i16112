<?xml version="1.0" encoding="UTF-8"?><song><author>Аманда Фалк, Бетел Мусик</author>
<key>G</key>
<lyrics>[V1]
.    G         C     D   C     D
 // Ъйидир Ъсмини овмек Раб Ъсам
. G          C       D   C     D
 Онур ве йуджелик сана хер заман!
. G      C        D
 Сени овмек Раб Ъсам
.        Am       D
 Ве гуджуне гувенмек! //

[V2]
.          G      C       D C D
 // Джунку Сен буйуксун Раб,
. G    C      D   C D
 Буйуктур ислерин!
. G      C     D
 Сен буйуксун Раб,
.            Am
 Буйуктур севгин,
.            D
 Буйуктур исмин! //

[V3]
. G       C       G
 Ъйидир исмини овмек!</lyrics>
<title>Ъйидир Овмек</title>
</song>