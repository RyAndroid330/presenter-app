<?xml version="1.0" encoding="UTF-8"?><song><author>Шабан Ок</author>
<hymn_number>578</hymn_number>
<lyrics>[V1]
 // Мелеклер мюжде гетирди,
 Бугюн Иса Месих доду.  //
 // Севинин чобанлар, севинин,
 Бугюн Иса Месих доду.  //

[C1]
   // Йюдже Танръ'нън Олу'дур,
   Гелиши дюняя нурдур.
   Бизим куртулушумуздур,
   Бугюн Иса Месих доду.  //

[V2]
 // Крал Давут'ун кентинде,
 Иса ятъйор йемликте.  //
 // Мелеклер тапънър бирликте,
 Бугюн Иса Месих доду.  //</lyrics>
<title>Мелеклер Мюжде Гетирди TY578</title>
</song>