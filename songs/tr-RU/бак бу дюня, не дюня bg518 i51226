<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>518</hymn_number>
<title>Бак бу дюня, не дюня BG518</title>
<lyrics>[V1]
 // Бак бу дюня, не дюня
.    
     Чок алдаттъ, ойнаттъ.
.    
     Чок алдаттъ, ойнаттъ.
.    
     Истедийи гиби яптъ. //

[V2]
 // Аллахъм бени булду,
.    
     Бени елимден тутту.
.    
     'Бу йолдан гитме.' деди.
.    
     'Не ичин янаджан.' деди. //

[V3]
 // Вакът йоктур, яврулар.
.    
     Кувветими бракаджам.
.    
     Бирер бирер тутаджам.
.    
     Хепинизи аладжам. //

[V4]
 // Дюняйъ куртараджам.
.    
     Сонра пар пар якаджам.
.    
     Инсанларъ аладжам.
.    
     Гьоклере учураджам. //

[V5]
 // Инанмадък инсанлар,
.    
     Буну хепси гьореджек.
.    
     Гьозлери йукаръда каладжак,
.    
     Бойну бюкюк оладжак. //</lyrics>
</song>