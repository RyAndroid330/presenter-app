<?xml version="1.0" encoding="UTF-8"?><song><title>кутсал месих</title>
<lyrics>[V1]
 // Кутсал месих танрънън олу //

[V2]
 // Бен билийорум акан бир дере
 О дереде сифа вар сизе //

[V3]
 // Бу кенди дере Иса Месих тир
 Куртаръджъмъз баъшлайъджъмъз //

[V4]
 Гелин инсанлар сизде Месихе
 Аф етсин сизин гюнахларнъзъ
 Гелин хасталар Иса чаъръйор
 Бу дири судан сизе де версин</lyrics>
</song>