<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>670</hymn_number>
<title>Севинчсин сен бана BG670</title>
<lyrics>[V1]
 // Севинчсин сен бана,
 Беним джанъма.
 Сенин инайетине
 Месих'те олайъм. //

[C1]
   // Севинч, севинч вар
   Саде Месих'те.
   Есинлик, севги ташъйор
   Сенин тахтъндан. //

[C2]
   // Брак сен кендини
   Иса'нън елине.
   Татлъ сьойлесин
   Кенди сьозлерини. //

[C3]
   // Садък кьоле ол
   Мерхаметли Баба'на.
   Сана теслим етсин
   Аллахън герчейини. //</lyrics>
</song>