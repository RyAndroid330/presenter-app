<?xml version="1.0" encoding="UTF-8"?><song><author>Фред Хаммонд</author>
<hymn_number>136</hymn_number>
<lyrics>[V1]
.   Em
 //  Кутсал Рух иле долунджа
.  B7             Em
 Давут гиби джошаръм. //
.       Am        Em
 // Севинирим, севинирим!
.  B7             Em
 Давут гиби джошаръм. //

[V2]
.   Em
 // Кутсал Рух иле долунджа.
.    B7           Em
 Павлус гиби ишлерим. //
.       Am         Em
 // Чалъшъръм, чалъшъръм,
.   B7            Em
 Павлус гиби ишлерим. //

[V3]
.   Em
 //  Кутсал Рух иле долунджа.
. B7           Em
 Иса гиби северим. //
.       Am      Em
 // Северим, северим,
. B7           Em
 Иса гиби северим. //</lyrics>
<key>Em</key>
<title>Кутсал Рух Иле Долунджа TY136 RT103</title>
</song>