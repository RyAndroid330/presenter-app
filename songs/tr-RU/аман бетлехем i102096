<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Аман бейтлехем джанъм бейтлехем
 Иса месих'и ми гьормедин ми //
 // шимди бурдан гечип гитти
 Шу каршъки тапънаа сор //

[V2]
 // Аман тапънак джанъм тапънак
 Иса месих'и ми гьормедин ми //
 // Шимди бурда шифа верди
 Шу каршъ ки чармъха сор //

[V3]
 // Аман чармъх джанъм чармъх
 Иса месих'и ми гьормедин ми //
 // шимди бенден индирдилер
 Шу каршъки мезара сор //

[V4]
 // Аман мезар гючсюз мезар
 Иса месих'и ми гьормедин ми //
 // шимди бурдан къям етти
 Шу каршъки гьоклере сор //

[V5]
 // Аман гьоклер джанъм гьоклер
 Иса месих'и ми гьормедин ми //
 // шимди бурдан учуп гитти
 Баба'нън са тарафъна //

[V6]
 // Аман Баба джанъм Баба
 Иса месих'и ми гьормедин ми //
 // Иса бенде бен ондайъм
 Кутсал Рух та О сиздедир //</lyrics>
<title>АМАН БЕТЛЕХЕМ</title>
</song>