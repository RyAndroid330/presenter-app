<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>67</hymn_number>
<lyrics>[V1]
 // Сон заманлар гелди инсанлар
 Гелин берабер иман еделим //

[C1]
   // Килисейе гиделим дуа еделим
   Иса гелдиинде бизи алсън //

[V2]
 // Бизи алдъъ заман Аллахъм
 Хепимиз онун йюзюню гьореджеиз //

[V3]
 // Гьоклере бинеджем Иса'йъ гьореджем
 Иса'йла оладжам бен севинеджем //</lyrics>
<title>Сон Заманлар Гелди BG67</title>
</song>