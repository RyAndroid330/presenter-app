<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>663</hymn_number>
<title>Сабахлайън калктън мъ BG663</title>
<lyrics>[V1]
 // Сабахлайън калктън мъ
 сен уйкудан, //
 // Шюкюр еттин ми //
 Куртаръджъна
 Иса Месих'е ?

[V2]
 // Не вакът алъйорсу.н
 Нийметинден, //
 // Шюкюр еттин ми //
 Куртаръджъна
 Иса Месих'е ?

[V3]
 // На заман гьорюйон
 Онун ийилийини, //
 // Шюкюр еттин ми //
 Куртаръджъна
 Иса Месих'е ?

[V4]
 // Не вакът ишидийон
 Онун буйурдууну, //
 // Хазър мъсън сен //
 Гечесен ьолюмден хаята ?</lyrics>
</song>