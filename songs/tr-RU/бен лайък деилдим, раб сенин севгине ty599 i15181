<hymn_number>599</hymn_number>
<title>Бен Лайък Деилдим, Раб Сенин Севгине TY599</title>
<lyrics>[V1]
.   Am            Dm                  Am
 // Бен лайък деилдим, Раб сенин севгине
.               G              Am
 Ама сен лютфедип кендине чектин. //

[V2]
 // Еллерими сана бен ачъйорум,
 Баъшла Раб Иса, сенден дилийорум. //

[V3]
 // Дуаларъмъ сана бен сунуйорум,
 Сен кабул ет Иса'м, ялваръйорум. //</lyrics>
<key>C</key>
</song>