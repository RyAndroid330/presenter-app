<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Раббе ьовгюлер олсун, гюджюм калканъмдър.  //
 //  Йюреим чошуйор, О'на шюкредийорум
 Раббе умут балаянлар йюрекли олун  //

[V2]
 //  Не мутлу исянъ баъшланан инсана  //
 //  Не мутлу руху хиле ташъмаяна
 Тадън гьорюн Раб не ийидир, тюм инсанлара  //

[V3]
 //  Раббе балъ оланлар, илахийле ьовюн  //
 //  Кутсаллъънъ анарак шюкредин
 Чюнкю ьофкеси бир ан сюрер, лютфу бир ьомюр  //</lyrics>
<title>Раб Гюджюм Калканъмдър</title>
<author>Тургай Ючал</author>
</song>