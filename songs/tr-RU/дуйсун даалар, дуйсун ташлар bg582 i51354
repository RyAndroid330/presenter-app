<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>582</hymn_number>
<lyrics>[V1]
 // Дуйсун даалар, дуйсун ташлар.
 Севийорум, ичим янар. //

[C1]
   Аллахъм беним,
   Аллахъм беним
   Ийи Чобанъм,
   Севдиим беним.

[C2]
   // Бен Исамъ севейим,
   Джанъмъ верейим.
   Йолундан гидейим,
   Ей Исам беним, //

[C3]
   // Калбим ялнъз сана тапар,
   Аллахъмъ бен севейим. //

[C4]
   // Атеш олдун, калбимдесин.
   Сен сьоз олдун, дилимдесин. //

[C5]
   // Ъшък олдун, ьонюмдесин,
   Аллахъмъ бен севейим. //</lyrics>
<title>Дуйсун даалар, дуйсун ташлар BG582</title>
</song>