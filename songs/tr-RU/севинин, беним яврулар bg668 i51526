<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Севинин, беним яврулар, //
 Беним гелишиме.
 // Гери дьонмейин сиз //
 Бени беклейин, яврулар.

[V2]
 // Сиз ьолесениз де,
 яшаяджаксънъз. //
 Беним исмимде сиз ьолюн.
 // Беним емримдедир бу //
 Севесениз бирбиринизи.

[V3]
 // Бу севги вар мъ сизде, //
 Инанън ки, сиз хепиниз бенде.
 // Бени севен, бени севенлер, //
 Онлар да кардашънъ север.

[V4]
 // Бенимле мисиниз, яврулар ? //
 Бир шейден коркмайън сиз.
 // Саде сиз даянън. //
 Беним гелдийим гюне кадар.
 // Севинин сиз яврулар, //
 Берабердже гьокте оладжаз.</lyrics>
<title>Севинин, беним яврулар BG668</title>
<hymn_number>668</hymn_number>
</song>