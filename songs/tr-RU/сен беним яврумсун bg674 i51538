<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>674</hymn_number>
<title>Сен беним яврумсун BG674</title>
<lyrics>[V1]
 // Сен беним яврумсун,
 Сен беним кузумсун. //
 // Бен сени гьорюйом,
 Бен сени севийом. //

[V2]
 // Гел беним евиме,
 Ан беним адъмъ. //
 // Шюкюр амин олсун
 Иса Месих'е. //

[V3]
 // Бен сени йъкадъм,
 Беним темиз канъмла. //
 // Бен сана верийом
 Беним темиз Рухумдан. //

[V4]
 // Гез беним адъмла,
 Ан беним адъмъ. //
 // Шюкюр амин олсун
 Иса Месих'е. //

[V5]
 // Сен беним яврумсун,
 Сен беним кузумсун. //
 // Бен сени гьорюйом,
 Бен сени севийом. //</lyrics>
</song>