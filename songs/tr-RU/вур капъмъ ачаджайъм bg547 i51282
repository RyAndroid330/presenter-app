<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>547</hymn_number>
<lyrics>[V1]
 // Вур капъмъ ачаджаъм бен ону сана //
 // Ал бени йюреине ярдъмджъйъм бен сана //

[V2]
 // Шейтан (Дюшман) алдъ да гитти иманлъларъ йок етти //
 // Кайболду койунларъм йоктур артък саямда //

[V3]
 // Йине актъ гьозяшларъм деря дениз олду сизе //
 // Сизи бабамдан бен дилеркен явруларъм/ //

[V4]
 // Актъ йине канларъм ачълдъ яраларъм //
 // Гелин гелин дуа евине шифанъзъ верейим сизе //

[V5]
 // Баърън баърън гьокте олана
 гьокте олан Месихе //
 Дженнете давет едер инанмъш ( темиз калпли) оланларъ</lyrics>
<title>Вур капъмъ ачаджайъм BG547</title>
</song>