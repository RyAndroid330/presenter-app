<?xml version="1.0" encoding="UTF-8"?><song><title>Чок Гючлю Олмалъйъм, Чюнкю Раб Иса Янъмда TY306</title>
<lyrics>[V1]
 Чок гючлю олмалъйъм, чюнкю Раб Иса янъмда.
 Севинчле долмалъйъм, чюнкю Раб Иса янъмда.

[C1]
   //  Хеп мутлу олмалъйъм, хеп бьойле гюлмелийим,
   Коркмадан севмелийим, чюнкю Раб Иса янъмда.  //</lyrics>
<hymn_number>306</hymn_number>
<author>Селин Деер</author>
</song>