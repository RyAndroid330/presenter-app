<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Калдъралъм хепимиз,
 Еллеримизи йукаръ.
 ЬОвелим Аллахъмъзъ,
 О бизи куртарсън. //

[C1]
   Дуа един, дуа един.
   Аллахъмъз бизи гьорюйор.
   Дуа един, дуа един.
   Аллахъмъз бизи севийор

[V2]
 // Аллахъмъз геледжек,
 Бу дюняйъ тез якаджак.
 Хер иман еден Она
 Сонсузларджа ьолмесин. //

[V3]
 // Абба Раббимиз Îса,
 Явруларънъ чок севдин.
 Хепимиз ичин ьолдюн.
 Ебединдже яшаялъм. //</lyrics>
<title>Калдъралъм хепимиз BG620</title>
<hymn_number>620</hymn_number>
</song>