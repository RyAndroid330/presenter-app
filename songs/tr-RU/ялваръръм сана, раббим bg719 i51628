<?xml version="1.0" encoding="UTF-8"?><song><title>Ялваръръм сана, Раббим BG719</title>
<lyrics>[V1]
 // Ялваръръм сана, Раббим
 Сен гелесен, сен гелесен. //

[C1]
   // Елини сен узат, Раббим.
   Мубарекле хепимизи.
   Гьотюресен бизи, Раббим,
   Ебеди хаята. //

[C2]
   // Ялваръръм сана, Раббим,
   Баба бизе сен оласан. //</lyrics>
<hymn_number>719</hymn_number>
</song>