<?xml version="1.0" encoding="UTF-8"?><song><title>Хер гюн йюкюмю ташъян колларъъйла</title>
<lyrics>[V1]
 /// Хер гюн йюкюмю ташъян колларъъйла бени саран
 Съкънтъда ярдъм еден Танръма ьовгюлер олсун ///

[V2]
 // Хер гюн йюкюмю ташъян
 Бени ьолюмден куртаран
 Бана сонсуз яшам
 верен Танръма ьовгюлер олсун //

[V3]
 // Хергун бен Иса'я тапарим
 Чармъхта чок аджъ чектин
 Шюкюр олсун Раббим Сана
 Бени ьолюмден куртардин //</lyrics>
</song>