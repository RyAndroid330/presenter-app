<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>79</hymn_number>
<author>Мустафа Абидов</author>
<lyrics>[V1]
.   Am                     Em
 // Мерйем'ден доан Куртаръджъ
.    Am                F
 Дюнянън гюнахънъ калдъран
.  Dm           Em          G
 Иса'дър адъ куртарър кайболанъ
.  Am    G     F      Dm
 Иште Месих'им беним ичин гелди //

[C1]
.          Am   F
   // Аджъ чектин чекмейейим
.     G               Em
   Дьовюлдюн, дьовюлмейим
.           Dm         Am
   Сен ьолдюн бен яшаяйъм
.       Am      G   F  Dm    Em
   Иште Месих'им джанънъ верди //
   Иште Месих'им чармъхта ьолдю

[V2]
 // Хер шейи япарсън беним ичин
 Танръм'сън Сана съънъръм
 Тьовбе, иман етим Сана гелдим
 Иште бу Севги джанънъ верди //</lyrics>
<key>Am</key>
<aka>Иште Месих'им</aka>
<title>Мерйем'ден Доан Куртаръджъ BG79</title>
</song>