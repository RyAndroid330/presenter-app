<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Елемлерин адамъ
 Иса Месих'ин адъ.  //
 //  Гюнахлъйъ куртардъ,
 Сонсуз яшам саладъ,
 Сонсуз яшам саладъ.  //

[C1]
   //  Иса алдъ йюкюмю,
   Гийди беним хюкмюмю.  //
   //  Канъйла аф саладъ,
   Бени Раб'бе баладъ,
   Бени Раб'бе баладъ.  //

[C2]
   //  О чармъха чакълдъ,
   &quot;Тамам олду!&quot; О деди.  //
   //  ЬОлюмю биле йенди,
   Раб катъна йюкселди,
   Раб катъна йюкселди.  //

[C3]
   //  Раб оларак геледжек,
   Инанлъйъ аладжак.  //
   //  Йер, гьок хамт чънлатаджак,
   Илахи бу оладжак,
   Илахи бу оладжак.  //</lyrics>
<title>Елемлерин Адамъ TY47</title>
<hymn_number>47</hymn_number>
<author>Али Язар</author>
</song>