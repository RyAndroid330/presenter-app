<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>25</hymn_number>
<lyrics>[V1]
 // Аксада гьоз яшъм
 Акар гюнахъм ичин
 Раб Иса бени аффет
 Гюнахлъйъм ьонюнде //

[C1]
   // Сенин канън актъ топраа
   ЬОлдюн бизим ичин голготада //

[V2]
 // Юч гюн сонра дирилдин
 Бизе яшам Сен вердин
 Бизи чок Севдин
 Гьоклере Сен гиттин //</lyrics>
<title>Аксада гьоз яшъм BG25</title>
</song>