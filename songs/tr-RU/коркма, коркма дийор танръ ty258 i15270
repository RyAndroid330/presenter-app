<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[C1]
.      Em                  F
   // Коркма, коркма дийор Танръ,
.   Am                Em
   Бен сенинле бераберим. //

[C2]
   // Етрафъна хич бакънма,
.   Am                   Em
   Чюнкю сенин Танрън беним. //

[V1]
 // Пекиштиреджеим сени,
 Сана ярдъм едеджеим. //
 // Адалетимин елийле
 Сана дестек оладжаъм. //</lyrics>
<title>Коркма, Коркма Дийор Танръ TY258</title>
<hymn_number>258</hymn_number>
<author>Али Язар</author>
</song>