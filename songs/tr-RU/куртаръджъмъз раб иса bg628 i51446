<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>628</hymn_number>
<lyrics>[C1]
   // Куртаръджъмъз Раб Иса
   Елимден тутар бени.
   Бу гюнахтан узак олсам,
   Шимди сенин елиндейим. //

[C2]
   // Бени атешине атма.
   Бени ялнъз сен бракма. //

[C3]
   // Шимди сенин ардъндайъм,
   Мутлу олайъм. //

[C4]
   // Беним ичин, ей Аллахъм,
   Аджъ чектин, сен даяндън. //

[C5]
   // Айръламам сенден артък,
   Шюкюрлер олсун. //

[C6]
   // Беним ичин, ей Аллахъм,
   Аджъ чектин. сен даяндън. //

[C7]
   // ЬОлюрюм, айрълмам сенден.
   Сенин олдум бен. //</lyrics>
<title>Куртаръджъмъз Раб Иса BG628</title>
</song>