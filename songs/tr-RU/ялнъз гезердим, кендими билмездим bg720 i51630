<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   Ялнъз гезердим, кендими билмездим.
   // Ювей баба елинде чок чилелийдим. //

[C2]
   Аллахъм, Аллахъм,
   // Сенсин беним ярдъмджъм.
   Хем куртаръджъм. //

[C3]
   Чок хастайдъм бен, кендими билмездим.
   // Аллах бени дюзелтти, хепсини аффетти. //

[C4]
   Чок хастайдъм бен, чок ялнъздъм бен.
   // Иса бана еш олду, хем кардеш олду. //

[C5]
   Ялвар Иса'я, о ишитеджек.
   // Ер геч сизе геледжек, егер беклерсениз. //</lyrics>
<title>Ялнъз гезердим, кендими билмездим BG720</title>
<hymn_number>720</hymn_number>
</song>