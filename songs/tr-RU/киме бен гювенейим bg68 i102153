<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>68</hymn_number>
<key>Em</key>
<lyrics>[V1]
.   E    Am
 //  О бени Севийор
.       E
 Раббим бени истийор
.    Dm
 Она иман едейим
.   F   Dm   E
 Бютюн калбимле //

[C1]
.  E    Am
   Киме бен анлатайъм
.       Em
   Киме бен гювенейим
.       Dm
   Киме бен съънайъм
.       F  Dm    E
   Аллахъмдан башка

[C2]
.  E    Am
   Киме бен анлатайъм
.       E
   Киме бен гювенейим
.       Dm
   Киме бен съънайъм
.       F   Dm    E
   Раб иса'дан башка

[V2]
.   E   Am
 // Дердимин дерманъ
.     E
 Раб Иса Сенсин
.      Dm
 Йюджедир Адън
.      F Dm  E
 Беним Месихим //</lyrics>
<title>Киме Бен Гювенейим BG68</title>
</song>