<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Калк, айдънлан ей дюшкюн,
 Чюнкю ъшъън гелди!  //
 // Танръ'нън йюджелии
 Юзеринде парладъ!  //

[V2]
 // Бютюн дюня карарса,
 Доаджак Месих сана.  //
 // Ъшъъна геледжек
 Улуслар ве краллар.  //

[V3]
 // Калдър да бак башънъ,
 Тюмю сана гелийор.  //
 // Сана доан гьоркеме
 Инсанлар хамдедийор.  //

[V4]
 // Гьореджексин о заман,
 Парлаяджак тюм йюзюн.  //
 // Севинеджек йюреин,
 Оладжак хер шей сенин.  //</lyrics>
<title>Калк, Айдънлан Ей Дюшкюн TY265</title>
<hymn_number>265</hymn_number>
<author>Юмит Мусесолу, Али Язар</author>
</song>