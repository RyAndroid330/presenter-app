<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>212</hymn_number>
<author>ЬОзгюр Тунч</author>
<key>G</key>
<lyrics>[V1]
.   Em
 // ЬОзлем долду йюреим
.D
 Арар олдум тюкендим
.C
 Гел бир сес вер
.Em
 Аджъ долду йюреим
.D
 Зайъф дюштюм еридим
.C
 Гел бир сес вер //

[C1]
.        Em        D            C
   Гелийорум гелийорум тахтънън ьонюне
.        Em        D          C
   Бакъйорум бакъйорум йюджелиине

[C2]
.          Em           D
   // Гюзеллиини гьорюйорум
.      Am            C
   Гьордюкче хайран олуйорум
.      Em          D
   Хузурунда дуруйорум
.     Am           C
   Дурдукча яшам булуйорум //</lyrics>
<aka>Гел бир сес вер</aka>
<title>Тюкендим RT212</title>
</song>