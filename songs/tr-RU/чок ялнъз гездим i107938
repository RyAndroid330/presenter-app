<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Чок ялнъз гездим
 каранлъкта, бен гидердим. //

[V2]
 // Месих бени сатън алдъ,
 Гюнахъмдан куртардъ. //

[V3]
 Чармъхта чок аджъ чекти,
 Сучумузу О йюкленди.
 // Канънъ дьокерек,
 Дженнете давет етти. //

[V4]
 // Бу дюнянън атешинден,
 Бени чектин, яшам вердин. //

[V5]
 // Артък чок мутлуйум бен,
 Дженнете давет еттин. //</lyrics>
<title>Чок ялнъз гездим</title>
</song>