<?xml version="1.0" encoding="UTF-8"?><song><title>Чок севги вер бана BG705</title>
<lyrics>[V1]
 // Чок севги вер бана,
 Аллахъм, Раб Иса.
 Юзюлмек истемйом
 бу дюняда. //

[C1]
   // Чъкар бизи, Аллахъм, съкънтъдан.
   Куртар бизи, Аллахъм, каранлъктан. //

[C2]
   // Чок хаста, ве дюшкюн,
   ве дертли бирийдим.
   Сен бени булдун дийе,
   севинчлийим. //

[C3]
   // Гелирим дюняя
   тезлерде яврулар..
   Сьозюмле даваладжам
   бен херкеси. //

[C4]
   // Сьозюмю динлейен
   херкеси севийом,
   Дженнетте оладжаклар
   хеп бенимле. //</lyrics>
<hymn_number>705</hymn_number>
</song>