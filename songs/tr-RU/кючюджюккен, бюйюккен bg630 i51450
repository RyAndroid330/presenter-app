<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>630</hymn_number>
<title>Кючюджюккен, бюйюккен BG630</title>
<lyrics>[V1]
 // Кючюджюккен, бюйюккен
 Чоуро бюйюмюшюм бен. //

[C1]
   // Бракма бени, сен Раббим.
   Сенин еллерине бракъйом кендими. //

[C2]
   // Кьойден кьойе гезеджем,
   Бен адънъ ьоведжем. //

[C3]
   // Канънъ бана дьоктюн,
   Йюрейими йъкадън. //</lyrics>
</song>