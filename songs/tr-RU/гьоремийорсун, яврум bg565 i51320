<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>565</hymn_number>
<title>Гьоремийорсун, яврум BG565</title>
<lyrics>[V1]
 // Гьоремийорсун, яврум,
 Сенин янлъш ишлерини. //
 // Ач гьозюню, гьор сени,
 Яргълама кимселери. //

[C1]
   // Дьон гери, гел бери. //
   // ЬОлюмден куртар сени. //

[V2]
 // Бир дереде, кьошеде,
 Урашърдън дертлеринле. //
 // Алдъм сени дереден,
 Куртардъм дертлеринден. //

[V3]
 // Бакърдън етрафъна,
 Кошан йок ярдъмъна. //
 // Халин йок даянмая.
 Коштум сана ярдъма. //

[V4]
 // Доору, доору сьойлейин.
 Бен яланъ севмейим. //
 // Доору йолумдан гидин,
 Доору янъма гелин. //</lyrics>
</song>