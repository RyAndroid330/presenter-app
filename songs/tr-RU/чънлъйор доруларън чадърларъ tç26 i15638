<?xml version="1.0" encoding="UTF-8"?><song><author>Джоание Мурфы</author>
<hymn_number>26</hymn_number>
<lyrics>[V1]
.    B7   Em
 // Чънлъйор доруларън чадърларъ
.              Bm   Em
 Севинч зафер сесийле. //
.Em
  Гючлю ишлер яптъ,
.Em
 Раб'бин са ели не йюджедир!
.Em          B
 Йоктур бензери,
.         Em
 Гючлю ишлер яптъ
.Em
 Раб'бин са ели.
.              Bm7     Em
 // Гьоклерде хюкюм сюрер. //</lyrics>
<key>G</key>
<title>Чънлъйор Доруларън Чадърларъ TÇ26</title>
</song>