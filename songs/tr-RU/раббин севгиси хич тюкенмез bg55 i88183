<?xml version="1.0" encoding="UTF-8"?><song><title>Раб'бин Севгиси Хич Тюкенмез BG55</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 // Раб'бин Севгиси хич тюкенмез
.C
 Мерхамети асла сон булмаз
.Am
 Хер сабах тазеленир онлар
.B7                        Em
 Садакатин не бюйюктюр Танръм //

[C1]
.     G
   // Беним пайъма дюшен Сенсин
.  Am
   Дийор джанъм
.  Em9              B7         Em
   Бу йюзден Сана умут баълъйорум //

[V2]
.   Em
 // Коркмам, чюнкю Сен бенимлесин
. C
 Йълмам чюнкю беним Танръмсън
.Am
 Бени гючлендиреджексин
.B7            Em
 Ярдъм едеджексин //</lyrics>
<hymn_number>55</hymn_number>
<author>Мустафа Абидов</author>
</song>