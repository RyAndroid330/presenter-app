<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Bm     Em D    C
 // Каранлъъ  даътъйор,
.Am   D  C      Bm
 Ъшъъйла парлатъйор, //
.   Em     Bm  C     D
 // Харикалар йаратъйор,
.Am7    C   D      Bm
 Куртаръджъ Иса Месих! //

[C1]
   // Гюнахлъйъ чаъръйор,
   Гюнахъндан арътъйор, //
   // Хузур, есенлик верийор,
   Куртаръджъ Иса Месих! //

[C2]
   // О сени де чок севийор,
   Севгисийле куджаклъйор, //
   // Сонсуз яшамъ верийор
   Куртаръджъ Иса Месих! //

[C3]
   // Каранлъъ даътъйор,
   Севгисийле парлатъйор, //
   // Харикалар яратъйор,
   Йюдже олан Иса Месих! //</lyrics>
<key>Bm</key>
<title>Каранлъъ Даътъйор TY33</title>
<hymn_number>33</hymn_number>
<author>Али Язар</author>
</song>