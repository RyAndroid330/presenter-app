<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>192</hymn_number>
<title>Танръ Адъ Йюджедир! TY192</title>
<lyrics>[V1]
 //  Танръ адъ йюджедир!
 Сунаръз О'на шюкюр.  //
 //  Яратан ве коруян
 Танръ адъ йюджедир!  //

[V2]
 //  Йюджедир Танръ адъ,
 Дюняда вюджут алдъ.  //
 //  Беним урума ьолдю,
 Танръ адъ йюджедир!  //

[V3]
 //  Танръ адъ йюджедир!
 Гюнахлъйъ арътър.  //
 //  Йюреклерде отурур,
 Танръ адъ йюджедир!  //

[V4]
 //  Танръ адъ йюджедир!
 Инананъ куртарър.  //
 //  Сонсуз яшамъ верир,
 Танръ адъ йюджедир!  //</lyrics>
</song>