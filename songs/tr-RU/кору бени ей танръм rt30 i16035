<?xml version="1.0" encoding="UTF-8"?><song><author>Жеремй Периго, Алпер Гюрсу, Метин ЬОзкая</author>
<hymn_number>30</hymn_number>
<key>G</key>
<lyrics>[V1]
.Em        D      Em
 Кору бени ей Танръм
.C           D      Em
 Чюнкю Сана съънъйорум
.Em        D      Em
 Касеме дюшен Сенсин
.C         D      G
 Яшамъм Сенин елинде!

[C1]
.            Em    Am      G     Em
   // Раб'бе дедим ки ефендим Сенсин
.         C         B7           Em
   Сенден ьоте мутлулук йоктур бана //

[V2]
.Em           D      Em
 Гьозюмю Раб'ден айърмам
.C          D    Em
 Саъмдадър сарсълмам
.Em           D        Em
 Бу йюзден севинч долуйум
.C          D      G
 Йюреим джошуйор Сенде

[B1]
.     C                 D
   // Яшамъм Сенин елинде
.                    C
   Яшамъм Сенин елинде
.                      D
   ЬОверим Сени Раб Иса'м //</lyrics>
<title>Кору Бени Ей Танръм RT30</title>
</song>