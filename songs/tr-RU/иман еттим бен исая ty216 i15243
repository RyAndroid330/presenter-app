<?xml version="1.0" encoding="UTF-8"?><song><author>Селин Деер</author>
<hymn_number>216</hymn_number>
<title>Иман Еттим Бен Иса'я TY216</title>
<key>Am</key>
<lyrics>[V1]
.Am       E         Am
 Иман еттим бен Иса'я,
.Am         E         Am
 Хузур булдум ен сонунда.
.Am                 E
 Севгисини верди бана,
.E                 Am
 Яшам сунду инсанлара.

[V2]
.   Am           Dm
 // Танръм гел бана,
.      G          C
 Калбими ачтъм сана.
.   F          Dm
 Сонсуза дек инан,
.   E           Am
 Севгим дерин сана. //</lyrics>
</song>