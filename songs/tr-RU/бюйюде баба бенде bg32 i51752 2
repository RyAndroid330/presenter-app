<lyrics>[C1]
   // Бюйюде Баба бенде
   Бюйю Раб Иса бенде //

[V1]
 // Севгин чоалсън
 Кутсал рухун янсън
 Бюйюде Баба бенде //

[V2]
 // Дертлер кайболсун
 Съкънтълар учсун
 Бюйюде Баба бенде //

[V3]
 // Хер шейе йетенсин
 Гьокте йерде тексин
 Бюйюде Баба бенде //</lyrics>
