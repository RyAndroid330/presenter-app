<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>164</hymn_number>
<author>Хилтруд Стрьохлеин</author>
<title>Селам Айше TÇ164</title>
<key>E</key>
<lyrics>[V1]
.E  B7  E        B7  E
 Селам Айше*, селам Айше!
.     B7 E        B7 E
 Хош гелдин, хош гелдин!
.E    B7     E        B7     E
 Иса'нън сьозюню, Иса'нън сьозюню
.   B7   E      B7   E
 Динлейелим, динлейелим!

[V2]
 Селам Айше, селам Айше!
 Хош гелдин, хош гелдин!
 Иса сени севийор, Иса сени севийор.
 Севинелим, севинелим!

[V3]
 *(Чоджукларън исимлерини кулланън!)</lyrics>
</song>