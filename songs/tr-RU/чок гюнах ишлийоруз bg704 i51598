<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>704</hymn_number>
<title>Чок гюнах ишлийоруз BG704</title>
<lyrics>[C1]
   // Чок гюнах ишлийоруз
   Сана, Раббим, Аллахъм,
   Давет едийоз сени
   Бизимле яшаясан. //

[C2]
   Сенсиз яшамъйоруз
   Сенсиз оламъйоруз.
   Сенсиз дурамъйоруз.
   Хер вакът баъръйоруз.

[C3]
   // Раб ансъзън геледжек,
   Йемишлери аладжак.
   Кимин йемиши гюзел,
   Ону кесин аладжак. //

[C4]
   // Сенин Раббин о хачта,
   Сенин ве беним ичин,
   Шюкюр олсун Иса'я,
   Шанлар олсун адъна. //

[C5]
   // Сенин де куртаръджън,
   Сенин Танрън о олсун.
   Хер вакът сени беклер,
   Сени куртармак истер. //</lyrics>
</song>