<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>119</hymn_number>
<author>Али Язар</author>
<title>Раб'бе Гювен, Раб'бе Гювен TY119</title>
<lyrics>[V1]
 //  Раб'бе гювен, Раб'бе гювен,
 Раб'бе гювен, Раб'бе гювен.  //
 //  Инайети иле беслен,
 Ийиликлерини гьонен.  //
 //  Раб'бе гювен, Раб'бе гювен.  //

[V2]
 //  Раб'бе гювен, Раб'бе гювен,
 Раб'бе гювен, Раб'бе гювен.  //
 //  Йолларънъ О'на бърак,
 Парлатаджак о йолуну.  //
 //  Раб'бе гювен, Раб'бе гювен.  //</lyrics>
</song>