<?xml version="1.0" encoding="UTF-8"?><song><aka>Йол Ачансън</aka>
<key>G</key>
<lyrics>[V1]
.       F             C        G             Am
 // Бурадасън, арамъздасън, тапънъръм, тапънъръм
.      F           C        G             Am
 Бурадасън, янъмъздасън, тапънъръм, тапънъръм //

[C1]
.         F                             C
   // Йол ачансън, шифа веренсин, ваат еденсин,
.                  G                Am
   сен саф севгисин Раббим, иште бу сенсин //

[V2]
.         F                 C         G         Am
 // Бурадасън, йюреиме бакарсън, тапънъръм, тапънъръм
.       F              C         G         Am
 Бурадасън, хамда лайъксън, тапънъръм, тапънъръм //

[V3]
.  F
 Сени гьормеден де чалъшъйорсун
. C
 Сени гьормеден де чалъшъйорсун
. G
 Хер заман бенде ишлийорсун
. Am
 Хер заман бенде ишлийорсун</lyrics>
<title>Бурадасън, Арамъздасън RT85</title>
<hymn_number>85</hymn_number>
<author>Синач</author>
</song>