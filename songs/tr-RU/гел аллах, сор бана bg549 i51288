<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>549</hymn_number>
<lyrics>[V1]
 // Гел Аллах, сор бана,
 Сен ачасан калбими.
 Оламам сенсиз, Аллах,
 Бьойле бен юзгюнюм. //

[C1]
   // Хем бен ялнъздъм,
   Хем чок хастайдъм.
   Аллахъм бени булду,
   Бана сабърлък верди. //

[V2]
 // Беним йолум, явруларъм,
 Чок дардър, чок узун.
 Истейин сизе иман,
 Иманлъ оласанъз. //

[V3]
 // Сиз, беним явруларъм,
 Сизе чок гюлерлер
 Истейин сиз Аллахтан,
 Даянабилесениз. //

[V4]
 // Инан олун, инан олун.
 Хер вакът дуая дурун.
 Аллах сизе геледжек,
 Дженнете гьотюререджек. //</lyrics>
<title>Гел Аллах, сор бана BG549</title>
</song>