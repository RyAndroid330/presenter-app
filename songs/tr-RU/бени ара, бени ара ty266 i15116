<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Бени ара, бени ара,
 Бени ара, бени ей сен.
 Бени ара, Танръйъм бен.  //
 //  Бени ара, бени ей сен,
 Бени ара, Танръйъм бен.  //

[V2]
 //  Бени арарса йюреин,
 Бени булурсун о заман.  //

[V3]
 //  Бени ара тюм джанънла,
 Бени ара йюреинле,
 Булурсун бени о заман.  //</lyrics>
<title>Бени Ара, Бени Ара TY266</title>
<author>Али Язар</author>
