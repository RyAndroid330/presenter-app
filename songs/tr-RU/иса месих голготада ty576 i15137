<?xml version="1.0" encoding="UTF-8"?><song><author>Шабан Ок</author>
<hymn_number>576</hymn_number>
<title>Иса Месих Голгота'да TY576</title>
<lyrics>[V1]
 //  Иса Месих Голгота'да,
 Гюнахъм ичин чармъхта.  //
 //  Дирилди, гелишине дек,
 Отурду Баба'нън саънда.  //

[C1]
   //  Иса Месих'им геледжек,
   Дюняйъ яргълаяджак.
   Ама О'на иман еден,
   Сонсуз яшамъ аладжак.  //

[V2]
 //  Иса Месих'ин канъйла,
 Аръндък биз гюнахлардан.  //
 //  О боазланмъш Кузу'йла,
 Кавуштук биз сонсуз яшама.  //</lyrics>
</song>