<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>283</hymn_number>
<title>Севинин, Севинин TY283</title>
<lyrics>[V1]
 //  Севинин, севинин.  //
 Раб'де даима севинин,
 Текрар дерим севинин.

[V2]
 //  Севинин, севинин.
 Танръ иле севинин,  //
 Раб Иса'да севинин.</lyrics>
</song>