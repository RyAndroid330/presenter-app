<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>722</hymn_number>
<title>Чок татлъсън сен, Аллах'ъм BG722</title>
<lyrics>[V1]
 // Чок татлъсън сен, Аллах'ъм.
 Чок татлъсън сен, Бабаджъъм.
 Чок мерхаметлисин. //

[V2]
 // Ахърда кузулар, йувада кушлар,
 Хеп рахат булуйорлар.
 Факат башънъ кояджак бир йер йоктур сана,
 Раб Иса'м. //

[V3]
 // Чок татлъсън сен, Аллах'ъм.
 Чок татлъсън сен, Бабаджъъм.
 Чок мерхаметлисин. //

[V4]
 Чок татлъсън сен, Аллах.
 Чок мерхаметлисин, Раб.

[V5]
 // Раббим, гелди ми бу дюняя,
 Имансъзлар янаджак.
 Иса гелди ми бу дюняя,
 Инанлар куртуладжак. //

[V6]
 // Чок татлъсън сен, Аллах'ъм.
 Чок татлъсън сен, Бабаджъъм.
 Чок мерхаметлисин. //

[V7]
 Чок татлъсън сен, Аллах.
 Чок мерхаметлисин, Раб.

[V8]
 // Чок чеки чектин сен чармъхта,
 Чок чеки бу дюняда.
 Краллъънъ сен бърактън, Аллах'ъм,
 Гелдин сен бу дюняя. //

[V9]
 // Чок татлъсън сен, Аллах'ъм.
 Чок татлъсън сен, Бабаджъъм.
 Чок мерхаметлисин. //

[V10]
 Чок татлъсън сен, Аллах.
 Чок мерхаметлисин, Раб.</lyrics>
</song>