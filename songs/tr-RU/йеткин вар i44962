<?xml version="1.0" encoding="UTF-8"?><song><author>Фатош Йусеинова, ЬОмер Салиеw, Асан Асан</author>
<title>Йеткин вар</title>
<lyrics>[V1]
 // Ким сенин гиби //
 // Ъса рабим хаятънъ верди бизим ичин //

[V2]
 // Йеткин вар тум улуслара раббим //

[V3]
 // Сенин гюджюн вар
 Йюксек даларда иса //</lyrics>
</song>