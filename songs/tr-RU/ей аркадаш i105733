<?xml version="1.0" encoding="UTF-8"?><song><title>Ей аркадаш</title>
<lyrics>[V1]
 // судан ве атештен
 гечеркен сеени коруяджам
 елим юзеринде
 корку олмасън йюреинде //

[V2]
 // Некадар гюзел Аллах сън сен
 Мукаддес баба
 Некадар мерхамелисин сен
 шюкюр кутсал адъна //

[V3]
 // ей аркадаш вазгеч //
 Сен бу дюнядан
 бак голготая
 канънъ дьоктю иса</lyrics>
</song>