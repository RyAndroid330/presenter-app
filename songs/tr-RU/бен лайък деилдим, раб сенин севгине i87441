<?xml version="1.0" encoding="UTF-8"?><song><author>Едип Авджъолу</author>
<key>Am</key>
<lyrics>[V1]
.   Am            Dm                  Am
 // Бен лайък деилдим, Раб сенин севгине
.               G              Am
 Ама сен лютфедип кендине чектин. //

[V2]
 // Еллерими сана бен ачъйорум,
 Баъшла Раб Иса, сенден дилийорум. //

[V3]
 // Дуалар сана бен япъйорум,
 Сен кабул ет Иса, сана ялваръйорум. //</lyrics>
<title>Бен Лайък Деилдим, Раб Сенин Севгине</title>
</song>