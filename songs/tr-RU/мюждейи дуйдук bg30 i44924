<?xml version="1.0" encoding="UTF-8"?><song><title>Мюждейи Дуйдук BG30</title>
<lyrics>[V1]
 // Мюждейи дуйдук Месих'те додук
 Севинчте джошарак яшадък //

[C1]
   /// Килисе дененди тартъшмалара дюштю
   късканчлък ве гурур арамъза гирди ///

[V2]
 // Сонрадан дуйдук ихтияч вардъ
 Баръштък ве мейвалар вердик //

[B1]
   // Хамтлар олсун Раб Иса'я чъкъш
   йолу верди бизе килисейи йюджелтти //</lyrics>
<author>Иско (Поморие)</author>
<hymn_number>30</hymn_number>
</song>