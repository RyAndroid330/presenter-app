<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>361</hymn_number>
<title>Сана Бакъйорум, Раббим TY361 RT43</title>
<key>Dm</key>
<lyrics>[V1]
. Dm      A   (Dm  A)
 Сана бакъйорум, Раббим. (3x)
.             Dm D7
 Аркама бакмадан!
.                 Gm       C
 //  Излерим йолуну, Раббим
.              F         Dm
 Излерим севинчле, Раббим
.          Gm         A
 Излерим дурмадан, Раббим
.               Dm   (D7)
 Аркама бакмадан  //

[V2]
.(Dm)       A
 Сени севийорум, Раббим. (3x)
.             Dm D7
 Аркама бакмадан!
.                 Gm       C
 //  Северим хузуруну, Раб.
.              F        Dm
 Северим достлууну, Раб.
.              Gm         A
 Северим дурмадан, Раббим.
.             Dm     (D7)
 Аркама бакмадан  //

[V3]
.(Dm)         A
 Сени беклийорум, Раббим. (3x)
.             Dm D7
 Рухунла долайъм!
.               Gm         C
 //  Северим гелишини, Раб.
.              F        Dm
 ЬОзлерим гелишини, Раб.
.              Gm        A
 Хазърла бени, ей Раббим.
.            Dm     (D7)
 Сенинле олайъм  //</lyrics>
</song>