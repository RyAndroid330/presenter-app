<?xml version="1.0" encoding="UTF-8"?><song><author>Давид Брымер, Рян Халл</author>
<hymn_number>152</hymn_number>
<title>Сен Лайъксън ЬОвгюйе RT152</title>
<aka>Азизлер, Мелеклер Седжде едерлер</aka>
<lyrics>[V1]
.A          B
 Азизлер, мелеклер
.  A          B
 Седжде едерлер.
.  A           B              A
 Ихтиярлар Раб'бе тачларънъ сунар
.  B      E
 Езги сьойлер

[C1]
.  E
   Сен лайъксън ьовгюйе
.                    B
   Сен лайъксън хершейе
.                   A                B
   Сенден ве Сенин ичин хершей вар олду
.                   E
   Тюм гьоркеме лайъксън

[B1]
.  E                          G#m
   Гедже гюндюз, гюндюз гедже йюкселсин
.     C#m                   A
   ЬОвгюлер Сенин ьонюнде бухур гиби
.  E                          G#m
   Гедже гюндюз,гюндюз гедже йюкселсин
.     C#m                   A
   ЬОвгюлер Сенин ьонюнде бухур гиби

[B2]
.      C#m    B     A      E    C#m    B
   Тек лайък олан галип гелди- Яхуда Асланъ
.      C#m    B     A      E     C#m    B
   Тек лайък олан галип гелди- Давут'ун Кьокю

[B3]
.     F#m              B
   Танръм, Сен инсан олдун
.          E             C#m
   Беден алдън, Сен не гюзелсин</lyrics>
<key>E</key>
</song>