<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>54</hymn_number>
<title>Уян, Уян, Уйкуджу! TY54</title>
<lyrics>[V1]
 // Уян, уян, уйкуджу!
 Месих сени аръйор. //
 // Уян артък, уйкуджу!
 Месих сени ча'ръйор. //

[C1]
   // Фърсатънъ качърма!
   Гюнлер олдукча фена. //
   // Сакън акълсъз олма!
   Месих Иса'йъ ара! //

[V2]
 // Ики,киши тарлада,алънаджак
 Бириси вай она ки вай о
 тарлада калана //</lyrics>
</song>