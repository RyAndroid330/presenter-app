<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Есенлик Баръш Кайнаъ
 Олан Танръма ЬОвгю
 Сени бени севен Раб'бе
 Сонсузджа хамт олсун //

[V2]
 // Кендини Алчалтъп
 Дюнямъза гелен
 Боазланмъш кузу гиби
 Чармъха Герилен //

[V3]
 // Йюджелердеки Раббиме
 Сонсузларджа Миннеттаръм
 Сучларъмдан Гюнахъмдан
 Бени куртардъ //</lyrics>
<title>Есенлик Баръш Кайнаъ</title>
<author>Адил Яшар</author>
</song>