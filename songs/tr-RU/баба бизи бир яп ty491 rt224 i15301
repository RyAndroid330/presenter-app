<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>491</hymn_number>
<key>G</key>
<lyrics>[V1]
.   G      C      D
 // Баба бизи бир яп //
.       C    D
 Тюм дюня билсин
.Bm   Em
 Иса Месих Олун,
.    C    D     C  G
 Тек куртулуш О'дур.
.      C       D
 Кардешлер бир арая
.  G       C     D
 Сенин адънда топланънджа
.    C    D      Bm     Em
 Сен ор'дасън ве берекетлерсин
.C      D    C  G
 Кутсал олан Раб.</lyrics>
<title>Баба Бизи Бир Яп TY491 RT224</title>
</song>