<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Хасталара, факирлере сен гелдин, Аллахъм. //
 // Сен ачтън калбими, сен шифаладън бени. //

[C1]
   А...а...а - сен ачтън калбими.
   А...а...а - сен шифаладън бени

[C2]
   // Чок хастайдъм, Аллахъм. Сен дюзелтирдин бени. //
   // Сен шифаладън бени, сен ачтън калбими. //

[C3]
   // Сен канара, Аллахъм. Сен гьоклерде дирисин. //
   // Йени Йерушалимде гюнеш гиби парларсън. //

[C4]
   // Гьок капъсънъ ачтъм, Аллахъмъ бен булдум. //
   // Аллахъмла биле олайъм, гьоклере учайъм. //

[C5]
   // Гедже гюндюз дуа едийом. Аллахъм сана ялваръйом. //
   // Гел Аллахъм, биле олалъм. Дженнете гиделим. //

[V2]
 // Иман едерим Иса'я, инанъръм Танръ Оолуна. //
 // Еминим ьолюп дирилди, джезамъ да о чекти. //</lyrics>
<title>Хасталара, факирлере сен гелдин, Аллахъм BG694</title>
<hymn_number>694</hymn_number>
</song>