<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>474</hymn_number>
<author>Джуан Салинас, Маркос Витт</author>
<title>Кедерими Данса Чевирдин TY474</title>
<lyrics>[V1]
.Em    C         D    Em
 // Кедерими данса чевирдин.
.      C             D   Em
 Бени там джошкуйла кушаттън. //

[V2]
.D  G           D
 Сана хамдедеджеим,
.        C      D          Em
 ЬОвгюм Сенсин, ЬОвгюм Сенсин.
.D   G             D
 Тек Сана данс едерим,
.        C                 B7
 ЬОвгюм Сенсин, ЬОвгюм Сенсин.

[V3]
.Em          B7     Em
 // Ох Адонай, Ох Адонай!
.  C       D    Em
 Евренин егеменисин,
. B7          Em
 Алемлерин Рабби! //

[V4]
.    D                G
 // Гьоклер Сени анлатърлар,
.    D            G
 чоджукларън тапънърлар,
.  B7             Em
 Бютюн харикаларънла,
.C   B7
 Адонай! //</lyrics>
<key>Em</key>
</song>