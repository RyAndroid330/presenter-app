<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>636</hymn_number>
<lyrics>[V1]
 // Не заман ялваръйом, Раббим, бен сана,
 Ишит сен беним, беним дуаларъмъ. //
 Раббим, Раббим, Раббим Иса,
 Ишит сен беним, беним дуаларъмъ.

[V2]
 // Сен мубарекле, Раббим, беним ханеми,
 Беним ханеми, беним явруларъмъ. //
 Раббим, Раббим, Раббим Иса,
 Ишит сен беним, беним дуаларъмъ.

[V3]
 // Мубарекле, Раббим, топлулуумузу,
 Топлулуумузу, бизим гюдюджюмюзю. //
 Раббим, Раббим, Раббим Иса,
 Ишит сен беним, беним дуаларъмъ.

[V4]
 // Мубарекле Раббим, сенин ектийини,
 Сенин гюджюнле ону сен бюйютесен. //
 Раббим, Раббим, Раббим Иса,
 Сенин Рухунла, сенин гючлю сьозюнле.

[V5]
 // Мубарекле, Раббим, кардашларъмъ,
 Къзкардашларъ, хеп сени дюшюнсюнлер. //
 Раббим, Раббим, Раббим Иса,
 Сенин ишине йюрютсюнлер хер йерде.</lyrics>
<title>Не заман ялваръйом, Раббим, бен сана BG636</title>
</song>