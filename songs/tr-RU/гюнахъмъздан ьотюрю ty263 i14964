<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>263</hymn_number>
<lyrics>[V1]
 //  Гюнахъмъздан ьотюрю
 О езилди, яраландъ.  //
 О езилди, яраландъ.
 //  Фесадъмъздан ьотюрю,  //
 //  Аджъ чекти, зеделенди.  //

[V2]
 //  Тюм джезамъз О'на инди,  //
 //  О вурулду, алчалтълдъ.  //
 О'нун яраларъйла биз
 //  Есенлик ве баръш булдук.  //

[V3]
 //  Хепимиз йолу шашърдък,
 Кенди йолумуза дьондюк.  //
 Кенди йолумуза дьондюк.
 //  Раб бизлерин гюнахънъ  //
 //  О'нун юзерине койду.  //

[V4]
 //  Аджъмъзъ О ташъдъ,  //
 //  Елемлери О йюкленди.  //
 Сандък джезая урадъ,
 //  Ама бизим джезамъздъ.  //

[V5]
 //  О'на кьотюлюк еттилер,
 Азънъ ачмадъ биле.  //
 Азънъ ачмадъ биле.
 //  Боазланан кузу гиби  //
 //  О хич каршълък вермеди.  //

[V6]
 //  Раб тарафъндан вурулду,  //
 //  Тамамен О алчалтълдъ.  //
 О'нун елемлерийле биз
 //  Яшъйоруз ве куртулдук.  //</lyrics>
<title>Гюнахъмъздан ЬОтюрю TY263</title>
</song>