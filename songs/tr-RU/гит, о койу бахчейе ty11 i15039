<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Em      G        Em
 // Гит, о койу бахчейе
.Em    G         Em
 Дененмейе дюшен джан. //
.Em
 Бир ан Иса'йла бекле;
.G
 Бак, сен О'нун халине.
.G                     Em
 Канлъ терлер дьокенден
.G            Em
 Дуа етмейи ьорен.

[V2]
.   Em       G       Em
 // Бак, Голгота йолуна,
.Em    G         Em
 О дьовюлмюш, яралъ. //
.Em
 Ама йине инсана
.G
 Дерин севгийле балъ.
.G                Em
 Чармъхъ ташъяндан
.G               Em
 Насъл ташъдъ, ьорен.

[V3]
.   Em       G      Em
 // Гит, Голгота даъна,
.Em      G         Em
 Бак, о курбан Иса'я, //
.Em
 Бютюн инсан уруна
.G
 Акан сучсуз о кана.
.G                   Em
 Ве тамамдър дийенден
.G              Em
 ЬОлмесини де ьорен.</lyrics>
<key>Em</key>
<title>Гит, О Койу Бахчейе TY11</title>
<hymn_number>11</hymn_number>
<author>Али Язар</author>
</song>