<?xml version="1.0" encoding="UTF-8"?><song><title>Нерелерде бен гезмишим BG648</title>
<lyrics>[C1]
   // Нерелерде бен гезмишим,
   Башъма чаре булмадъм. //

[C2]
   // Оламам, оламам Аллахъм.
   Бен сенсиз бурада дурамам. //

[C3]
   // Кьойден кьойе бен гезердим,
   Шифа, Раббим, буламадъм. //

[C4]
   // Докторлара бен гитмиштим,
   Дерман, Раббим, буламадъм. //

[C5]
   // Бен, Аллахъм, хаста олдум,
   Сенде Аллахъм умудум. //

[C6]
   // Бен, Аллахъм, кимсесизим,
   Бракма бени ялнъзъм бен. //</lyrics>
<hymn_number>648</hymn_number>
</song>