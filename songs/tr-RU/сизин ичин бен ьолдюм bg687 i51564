<?xml version="1.0" encoding="UTF-8"?><song><title>Сизин ичин бен ьолдюм BG687</title>
<lyrics>[V1]
 // Сизин ичин бен ьолдюм,
 Канъмъ сизе дьоктюм.
 Инанън явруларъм,
 Сизинле бен олайъм. //

[C1]
   // Чармъхта ьолдюм,
   Ючюнджю гюн дирилдим.
   Сизин ичин чок ааладъм,
   Сизи бен куртарайъм. //

[C2]
   // Шимди гьокте дирийим,
   Инанън, явруларъм.
   Янъма гелесениз,
   Дженнети гьоресениз. //</lyrics>
<hymn_number>687</hymn_number>
</song>