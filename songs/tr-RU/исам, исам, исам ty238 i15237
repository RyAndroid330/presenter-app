<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>238</hymn_number>
<title>Исам, Исам, Исам TY238</title>
<lyrics>[V1]
 Исам, Исам, Исам,
 Севгин калбими чалдъ.
 Исам, Исам, Исам,
 Севгин калбими ачтъ.

[V2]
 Исам, Исам, Исам,
 Лютфун бени куртардъ.
 Исам, Исам, Исам,
 Канън бени пак кълдъ.</lyrics>
</song>