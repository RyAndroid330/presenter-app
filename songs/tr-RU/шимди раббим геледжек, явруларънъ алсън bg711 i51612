<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>711</hymn_number>
<lyrics>[V1]
 // Шимди Раббим геледжек, явруларънъ алсън,
 Явруларънъ алсън, онун янъна. //

[V2]
 // Аллах сенсин Иса. Сен бизим Раббимиз.
 Ал бизи янъна, сенинле олалъм. //

[V3]
 // Иман ет Раб Исая. сана сабур верийор.
 О дерманъ верийор бютюн дюняя. //

[V4]
 // Аллах сенсин Иса. Сен бизим Раббимиз.
 Ал бизи янъна сенинле олалъм. //</lyrics>
<title>Шимди Раббим геледжек, явруларънъ алсън BG711</title>
</song>