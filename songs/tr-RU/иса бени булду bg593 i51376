<?xml version="1.0" encoding="UTF-8"?><song><title>Иса бени булду BG593</title>
<lyrics>[V1]
 // Иса бени булду,
 О бени куртардъ.
 Янъна гидеджем,
 Ону гьореджем. //

[C1]
   // Билирсин бени,
   Аллахъм,
   Неден хастайъм.
   Янъма гел, Аллахъм,
   Шифа верирсин. //

[V2]
 // Ишит бени, Баба.
 Бен ялнъз калдъм.
 Сана гювенийорум бен,
 Сенсиз оламам. //

[V3]
 // Нерейе гидеджем
 Иса'йъ ьоведжем.
 Херкес дуйсун, ьоренсин,
 Дженнете гелсин. //</lyrics>
<hymn_number>593</hymn_number>
</song>