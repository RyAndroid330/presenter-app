<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>566</hymn_number>
<author>Глориа Джларке</author>
<title>Кутсал Рух Гел! TY566</title>
<key>Am</key>
<lyrics>[V1]
.    Amin
 // Кутсал Рух гел!  //
.Dmin    Amin  E     Amin
 Чьолюмюзден бизи калдър,
.     Dmin Amin  E
 Куру кемиклеримизе,
.Amin                Dmin
  // Сьозюню сьойле, бизи йениле,
.Amin        E
 Юзеримизе юфле!  //
.   Amin    Dmin G       C
 // Калкаджаъз,  джошаджаъз,
.F       Dmin      E        Amin
 Сьозлерини йерине гетиреджеиз.  //

[V2]
.    Amin
 // Кутсал Рух гел!  //
.Dmin Amin  E     Amin
 ЬОлюмден бизи куртар,
.     Dmin Amin  E
 Куру йюреклеримизе,
.Amin                Dmin
  // Сьозюню сьойле, бизи йениле,
.Amin        E
 Юзеримизе юфле!  //
.   Amin    Dmin G       C
 // Калкаджаъз,  джошаджаъз,
.F       Dmin      E        Amin
 Сьозлерини йерине гетиреджеиз.  //</lyrics>
</song>