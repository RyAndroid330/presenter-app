<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>512</hymn_number>
<title>Аллахъм нердесин ? BG512</title>
<lyrics>[V1]
 // Аллахъм нердесин ?
 Ач гьозлерини,
 Аллахъм, инансънлар,
 Гьорсюнлер, Аллахъм. //

[C1]
   Раб Исам,
   Шюкюрлер сана.
   Раб Исам,
   Канънъ дьоктюн.

[C2]
   Раб Исам,
   Бизим ичин сен ьолдюн.
   // Яшларъмла, Раб Исам,
   Аякларънъ йъкадъм. //

[C3]
   Сачларъмла, Раб Исам,
   Силдим бен онларъ. //
   //  Инанън, сиз кардашлар,
   Инанън, къзкардашлар !
   Иса тезде геледжек,
   Бизи бурдан аладжак.</lyrics>
</song>