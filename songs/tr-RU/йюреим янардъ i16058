<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   Em
 // Бир баджъ гибисин
.D
 Будайъп темизлерсин бени
.C           D
 Сенде калан бириси
.C         D
 Сенде чок мейве верирди //
.Em            Am
 // Севгин яшам верирди бана
.C           D
 Йюреим шюкредерди сана
.Em         Am
 Сенде ачълдъ гьозлерим
.C            D
 Джанъма джан катар сьозлерин //

[V2]
.Em        D      C           D
 // Йюреим янардъ сесини дуймадъъм заман
.Em     D       C            D
 Йюреим канардъ йюзюню гьормедиим заман //</lyrics>
<title>Йюреим Янардъ</title>
<author>ЬОзгюр Тунч</author>
</song>