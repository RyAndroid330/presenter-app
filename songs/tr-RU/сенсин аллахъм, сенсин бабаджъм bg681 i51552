<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>681</hymn_number>
<lyrics>[V1]
 // Сенсин Аллахъм, сенсин Бабаджъм,
 Сана ялваръйоз, хани биз факириз. //

[C1]
   // Истейин бен вереджем,
   Калбинизи долдураджам,
   Калбинизи долдураджам,
   Сизин ичин бен ьолдюм. //

[C2]
   // Сенсин Аллахъм, сенсин Бабаджъм,
   Сана ялваръйоз, хани биз хастайъз. //

[C3]
   // Сенсин Аллахъм, сенсин Бабаджъм,
   Сана ялваръйоз, шифаладън бизи. //</lyrics>
<title>Сенсин Аллахъм, сенсин Бабаджъм BG681</title>
</song>