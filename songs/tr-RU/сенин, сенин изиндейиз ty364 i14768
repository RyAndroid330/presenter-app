<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.     Dm           A     Dm
   // Сенин, сенин изиндейиз.
.                 A        Dm
   Кутсал, кутсал химайендейиз.
.  Gm          A       Dm
   Биз сенинле бирликтейиз,
.  A                Dm
   Хузур ве севинчлийиз. //

[V1]
.                  Gm   A                Dm
 // Кимин зулмю айърър, бизи сенин севгинден?
.               Gm A               Dm
 Ким кьотюлюк едер сенин гьозетиминде? //

[V2]
.                    Gm  A                 Dm
 // Не ьолюм не де яшам, не кълъч не де заман
.           Gm  A           Dm
 Бизи айърамаз, бизи копарамаз. //</lyrics>
<key>Dm</key>
<title>Сенин, Сенин Изиндейиз TY364</title>
<author>Фарук Пекер</author>
<hymn_number>364</hymn_number>
</song>