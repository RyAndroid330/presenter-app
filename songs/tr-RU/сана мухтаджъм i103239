<?xml version="1.0" encoding="UTF-8"?><song><title>Сана мухтаджъм</title>
<lyrics>[V1]
 // Сана мухтаджъм //
 Анламак ичин кендими сана мухтаджъм
 // Чъкмак ичин чъкмазъмдан сана мухтаджъм //

[V2]
 // Не варса сенде вар // (яраб)
 Каранлък даълър, сенин ъшъън парлар
 Канатларънън гьолгесинде, сонсуз хузур вар
 // Дюня денизинде лиманъмсън, Иса //</lyrics>
</song>