<?xml version="1.0" encoding="UTF-8"?><song><author>Дурмуш Тюнел</author>
<lyrics>[V1]
 // Бен РАБ'бин ашъъйъм,
 Бир тек О'на тапаръм. //
 // Гьормез гьозюм дюняйъ,
 Ялнъз О'на бакаръм. //

[V2]
 // Бен РАБ'бин ашъъйъм,
 Сервети бен нейлерим. //
 // Севгисини татмъшъм,
 Джандан да вазгечерим. //

[V3]
 // Бен РАБ'бин ашъъйъм,
 Санмайън ки ялнъзъм. //
 // Гюндюз ве геджелерим,
 Раббимле бераберим. //

[V4]
 // Бен РАБ'бин ашъъйъм,
 Йолундан шашар мъйъм? //
 // О елимден тутту я,
 ЬОлюмю ашмаз мъйъм? //</lyrics>
<title>Бен РАБ'бин ашъъйъм</title>
</song>