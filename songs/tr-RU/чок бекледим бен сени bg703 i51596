<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Чок бекледим бен сени.
 Шимди сен бени булдун. //
 // Сен йени инсан олдун.
 Бени насъл унуттун ? //

[V2]
 // Бенсиз сен дурамаздън.
 Бени насъл унуттун ? //
 // Бен сени чок севердим.
 Шимди сен беним олдун. //

[V3]
 // Беним Иса Месихим,
 Беним гюзел Аллахъм. //
 // Чок чилейе даяндън,
 Гюнахъмъ йюклендин. //

[V4]
 // Калбимизи билийорсун.
 Сен бизи гьорюйорсун. //
 // Сени севен чок олду,
 Инанчларън аз олду. //

[V5]
 // Коруйун кендинизи,
 Хер гюн хазърда олун. //
 // Анламадан геледжем.
 Бен сизи аладжам. //

[V6]
 // Коркма, яврум, гел бери.
 Севийорум бен сизи. //
 // Аффедеджем хепсинизи.
 Дженнетте биле олалъм. //

[V7]
 // Саяма сиз топланън.
 Бен сизе чобан олдум. //
 // Суйунуздан гечин сиз,
 Кутсал Рух'у верейим. //</lyrics>
<title>Чок бекледим бен сени BG703</title>
<hymn_number>703</hymn_number>
</song>