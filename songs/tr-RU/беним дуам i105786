<?xml version="1.0" encoding="UTF-8"?><song><title>Беним дуам</title>
<lyrics>[V1]
 // Беним дуам йюдже Бабам сана
 Бизи алмая гелишине дек //

[V2]
 // Гюнахла , Дюняйла , Кендимле //

[V3]
 // Сенин гюджюнле савашмак истийорум
.    
     Сенин сабрън ла даянмак истийорум
.    
     Сенин севгинле севмек истийорум
.    
     Сенин лютфю ла алчалмак истийорум
.    
     Сенин сьозюнле бесленмек истийорум
.    
     Сенин рухунла бюйюмек истийорум //

[V4]
 Иса Месих ин исминле Амин.</lyrics>
<author>Давид Стефанов</author>
</song>