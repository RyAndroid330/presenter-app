<?xml version="1.0" encoding="UTF-8"?><song><title>Месих Иса'нън Адънда TY281</title>
<lyrics>[V1]
 //  Месих Иса'нън адънда
 Гьоктекилер, йердекилер  //
 //  Диз чьоксюнлер, еилсинлер,
 Танръм, сана тапънсънлар.  //

[V2]
 //  Танръ йюджелии ичин
 Хер дил Иса Раб'дир десин.  //
 //  Хер дил О'ну ачъкласън,
 Евет, Иса Раб'дир десин!  //

[V3]
 //  Месих Иса'нън адънда
 Йердекилер, гьоктекилер  //
 //  Еилсинлер, диз чьоксюнлер,
 Баба, сана тапънсънлар.  //</lyrics>
<author>Али Язар</author>
<hymn_number>281</hymn_number>
</song>