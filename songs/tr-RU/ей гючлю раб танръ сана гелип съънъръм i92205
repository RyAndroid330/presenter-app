<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<lyrics>[V1]
 // Ей гючлю Раб Танръ
 Сана гелип Съънъръм
 Ал бенден Зайъфлъъмъ
 Йьонелт сен Хаятъмъ //

[V2]
 // Гьорюйорум Сени Яврум
 Гьозлерим хеп юзеринде
 Юзюлюп Кайгъланма
 Балъ кал Сьозлериме //

[V3]
 // Ей Гючлю Раб Танръ
 Сен син беним Куртаръджъм
 Съкънтъда сана Баръръм
 Бана янът сен верирсин //</lyrics>
<title>Ей гючлю Раб Танръ Сана гелип Съънъръм</title>
</song>