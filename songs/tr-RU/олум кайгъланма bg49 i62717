<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em           D          C
 // Олум кайгълънма дедим сана,
.Em         D           C
 Хер диледиини сьойле Бана. //

[C1]
.     G                 D
   // Бен сенин Зенгин Бабан,
.       Am         Em
   Хершейе гюджю йетен.
.       C          D
   Бана дердини анлат,
.     Am           Em
   Бенде хузур бул сен. //

[V2]
 // Артък кайгъланмак йок бана,
 Хер диледиими бърактъм сана. //

[C2]
   // Сен беним Зенгин Бабам,
   Хершейе Гюджю йетен.
   Сана дердими анлаттъм,
   Сенде хузур булдум. //</lyrics>
<title>Олум Кайгъланма BG49</title>
<author>Ясим Недков</author>
<hymn_number>49</hymn_number>
</song>