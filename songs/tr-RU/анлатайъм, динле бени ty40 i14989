<?xml version="1.0" encoding="UTF-8"?><song><title>Анлатайъм, Динле Бени TY40</title>
<lyrics>[V1]
 // Анлатайъм, динле бени,
 Йюдже Раб'бин севгисини.  //
 // Гьоктен акъп яшам верир,
 Хич дурмадан пънар гиби.  //
 // Инсанларън севгиси
 Гелир, гечер рюзгар гиби.  //
 // Месихимин севгиси
 Дурур салам кая гиби.  //

[C1]
   // Ат темелин' бу каяя,
   Пишман олма фъртънада.  //
   // Дененмеде, зорлукларда
   Сарсълмазсън, гювен О'на.  //
   // Инсанларън севгиси
   Гелир, гечер рюзгар гиби.  //
   // Месихимин севгиси
   Дурур салам кая гиби.  //</lyrics>
<author>Али Язар</author>
<hymn_number>40</hymn_number>
</song>