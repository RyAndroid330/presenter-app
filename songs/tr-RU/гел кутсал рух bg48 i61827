<?xml version="1.0" encoding="UTF-8"?><song><title>Гел Кутсал Рух BG48</title>
<key>Em</key>
<lyrics>[C1]
.     Em                              Am
   //  Гел Кутсал Рух хатърлат иманъмъзъ
.   C                  D              Em
   Сен гел Кутсал Рух хатърлат севгимизи //

[V1]
.   G                   D
 // Илк гюнлеримиздеки Севги
.Am                           B
 Кардешлерле насъл пайлашъйордук
.G                      D
 Месихе хизмет едерек дуада дуруп
.Am                          B
 Ъшък чоджукларъ гиби парлардък //

[V2]
.   G                          D
 // Мюждейи дуйуруп тюм инсанлара
.Am                          B
 Хизмет едерек гючлю аскер гиби
.G                              D
 Танрънън истейини йерине гетирип
.Am                             B
 Йюджелик ве гьоркем Она сунардък //

[V3]
.     Am                   Em        D           G
 //// Кутсал рух иманъмъза ве севгимизе ярдъмджъ ол ////</lyrics>
<author>Иско (Поморие)</author>
<hymn_number>48</hymn_number>
</song>