<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Кара гюнлер юстюме гелиндже
 Шейтан салдъръп гюджюм битиндже
 // Сазъм ве сьозюм иле
 Дуа ве ьовгю иле
 Йюджелтирим Танръмъ  //

[V2]
 // Раб Куртарър  //

[V3]
 Сорун съкънтъларъм артънджа
 Йоклуктан дерттен кайгъланънджа
 // Ялваръръм Раббиме
 Алчалъръм ьонюнде
 Съънъръм Танръма  //

[V4]
 // Раб лûтфедер  //

[V5]
 Шейтан аяртмак истедиинде
 Гюнахлар чекиджи гелдиинде
 // Тьовбе иле алчалъп
 Баланъръм сьозюне
 Гювенирим Раббиме  //

[V6]
 // Раб баъшлар  //

[V7]
 Корку, дюшманлар чоалдъънда
 Гюджюм, джесаретим йок олунджа
 // Калканъмдър Раб Иса
 Корур бени мутлака
 Гючлю олан янъмда  //

[V8]
 // Раб гюджюмдюр  //</lyrics>
<title>Кара Гюнлер Юстюме Гелиндже</title>
<author>Дурмуш Тюнел</author>
</song>