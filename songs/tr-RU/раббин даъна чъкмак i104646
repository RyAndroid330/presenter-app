<?xml version="1.0" encoding="UTF-8"?><song><author>Мустафа Абидов</author>
<title>Раб'бин Даъна Чъкмак</title>
<lyrics>[V1]
.   E                      F
 // Сенин даъна чъкмак истерим
.Dm                  E
 Гьорюшмек Сана тапънмак
.E                   F
 Сьозюне бойун еледжейим
.Dm                    E
 Кутсал Рухунла доладжайъм //

[C1]
.     Am                  E
   // Хер улус Сана тапънаджак
.  F       Dm       E
   Хер дил Сени ьоведжек
.  Am                E
   Хер халк Сана геледжек
.  F         Dm      E
   Танръмсън Сен дийеджек... //

[V2]
.    E                  F
 // Даъндан фъшкъран пънар
.Dm                 E
 Бизе олду гюч ве шифа
.E                F
 ЬОвериз Сенин Адънъ
.Dm                  E
 Чюнкю Сен гючлю калесин //</lyrics>
<key>Am</key>
</song>