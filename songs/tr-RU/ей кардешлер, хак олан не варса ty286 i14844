<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>286</hymn_number>
<author>Мурат Кърълмаз</author>
<title>Ей Кардешлер, Хак Олан Не Варса TY286</title>
<lyrics>[V1]
 //  Ей кардешлер, хак олан не варса,  //
 //  Сайгън олан не варса, адил олан не варса,  //
 //  Саф олан не варса, севимли олан не варса,  //
 //  ЬОвюледжек не варса, бунларъ дюшюнюн.  //</lyrics>
</song>