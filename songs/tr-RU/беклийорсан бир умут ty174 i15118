<?xml version="1.0" encoding="UTF-8"?><song><title>Беклийорсан Бир Умут TY174</title>
<lyrics>[V1]
 //  Беклийорсан бир умут,
 Аръйорсан дору йолу,  //
 //  Сен де гел, сен де гел,
 Умут йолудур, Раб'бин йолу.  //
 //  Яшамдан тат алмъйорсан,
 Ве севинч аръйорсан,  //
 //  Сен де гел, сен де гел,
 Севинч йолудур, Раббин йолу.  //</lyrics>
<hymn_number>174</hymn_number>
<author>Зафер Йюрюмез</author>
</song>