<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<lyrics>[V1]
 // Коркма Ей Кючюк Сюрю
 Бен Сизинле Бирликтейим //
 // Сона Кадар Даянън
 Куртулуш Гюню чок Якън //

[V2]
 // Йер ве Гьоклер Калкса Биле
 Деишмейендир Аллахъм
 Бир Нокта Биле Ексилмез Ебедидир Сьозлери //

[V3]
 // Аллахъмън Сьозлери Гювенилир ве Герчектир //
 // Аллахъмън Ваатлери Гювенилир ве Герчектир //</lyrics>
<title>коркма ей кюджюк сюрю</title>
</song>