<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>467</hymn_number>
<author>Али Язар</author>
<title>Узун Йъллар Йюреимде TY467</title>
<key>C</key>
<lyrics>[V1]
.Em           Am
 // Узун йъллар йюреимде
.F              Em
 Севинч, севги арадъм бен. //
.   Am              Em
 // Керелердже сени сордум,
.F          Em
 Арадъм хеп сени дурдум. //

[V2]
 // Узун йъллар хеп истедим
 Сени сенде танъяйъм. //
 // Бен севгини йюреимде,
 Сени бенде яшаяйъм. //

[V3]
 // Евет, шимди сени булдум
 Сенин иле долувердим. //
 // Бен сендейим, сен де бенде,
 Херкес гьорсюн сени бенде. //

[V4]
 // Баъшларкен, хем северкен
 Хошгьорюйле давранъркен, //
 // Сенин гиби дюшюнюркен,
 Херкес бенде сени гьорсюн. //

[V5]
 // Тюм яшамъм сенде олсун
 Херкес бенде сени гьорсюн. //
 // Елем, аджъ олса биле,
 Херкес бенде сени гьорсюн. //</lyrics>
</song>