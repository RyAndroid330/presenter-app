<?xml version="1.0" encoding="UTF-8"?><song><author>Тургай Ючал</author>
<key>Am</key>
<lyrics>[V1]
.   Am          E  Am
 // Ей гьоклер, ей йер! //
.   Dm       E7        Am
 // Танръмъз ьовгюйе деер. //
.   Am      E7       Am
 // Хепимиз гюнахлъйдък //
.G       F      E
 Лютфуна мухтачтък,
.   G             F         B7       E7   Am
 // Гьоктен гелен Месих'ле, биз аффа улаштък. //

[V2]
.   Am          E  Am
 // Ей гьоклер, ей йер! //
.   Dm      E7         Am
 // Хепимиз о лютфа бедел. //
.   Am      E7       Am
 // Хепимиз гюнахлъйдък, //
.G       F      E
 Севгийе хеп ачтък,
.   G             F        B7        E7   Am
 // Гьоктен гелен о ашкла, биз хакка улаштък. //

[V3]
.   Am          E  Am
 // Ей гьоклер, ей йер! //
.   Dm       E7          Am
 // Раббимиз хер шейе йетер. //
.   Am      E7       Am
 // Хепимиз гюнахлъйдък, //
.G      F        E
 Гюнаха баланмъштък,
.   G             F       B7       E7       Am
 // Гьоктен гелен баъшла, лютфунла акланмъштък. //

[V4]
.   Am          E  Am
 // Ей гьоклер, ей йер, //
.   Dm      E7         Am
 // йолумуз сонсуза гидер. //</lyrics>
<title>Ей Гьоклер Ей Йер</title>
</song>