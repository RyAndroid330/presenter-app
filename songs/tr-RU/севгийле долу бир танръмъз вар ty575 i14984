<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>575</hymn_number>
<author>Шабан Ок</author>
<lyrics>[V1]
 // Севгийле долу бир Танръ'мъз вар.
 О'на иман еден бу зевки тадар.  //
 // Башлангъч, езелден сонсуза кадар,
 Яшам долудур Иса Месих'им.  //

[V2]
 // Зорлукларъмъзда, съкънтъларда,
 О хеп янъмъзда, Иса Месих'им.  //</lyrics>
<title>Севгийле Долу Бир Танръ'мъз Вар TY575</title>
</song>