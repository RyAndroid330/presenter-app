<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Гуджлу олан Танрия
 йуджелерден ьовгу олсун //

[V2]
 // Ей йуджелер йуджеси исмини йуджелтирим
 Йуджелер йуджеси исмини йуджелтирим //
 Джунку сен Раб иса лайиксин
 ЬОвгуйе Раб Ъсам лайиксин

[V3]
 // Баба дан гелен Рухтан доган
 Раб иса месихе йуджелик олсун //

[V4]
 // Баба огул кутсал рух иште
 Уджлу бирлик //
 // ЬОвгуйе лайик тек Танри //</lyrics>
<title>Ей Йюджелер Йюджеси</title>
<author>Рухсал езгилер дуисбург пештера топлулугу</author>
</song>