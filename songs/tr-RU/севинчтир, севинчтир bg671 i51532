<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Севинчтир, севинчтир,
 Севинчтир Аллахъм. //
 // Онунла, онунла
 Севинийор джанъм. //

[C1]
   // Алелуя, Алелуя,
   Алелуя сана. //
   // Бизден бир шей истемийор,
   Саде гюнахъмъзъ //

[C2]
   // Йъкасън, пакласън,
   О темиз канъйла. //
   // Бизден бир шей истемийор,
   Саде йюрейимизи //

[C3]
   // Йъкасън, пакласън,
   О темиз канъйла. //
   // Бизден бир шей истемийор,
   Саде инаналъм. //

[C4]
   // Исая, Исая,
   Нурлу Раббимизе. //</lyrics>
<title>Севинчтир, севинчтир BG671</title>
<hymn_number>671</hymn_number>
</song>