<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>56</hymn_number>
<author>Джемил Осман</author>
<presentation>C</presentation>
<title>Сана Гелдим BG56</title>
<key>C</key>
<lyrics>[V1]
.        C            G            F            C
 // Сана Гелдим Бени Аффетин Бени Аффетин Бени Аффетин //
.   F    G      C        F      G   C       Bmb5
 // Бени-и Куртаран Сенсин, Сени Излерим //

[C1]
.     Am    G         F       G
   //  Беним Ичин Сен ЬОлюмю Йендин
.      F         G       C    E
   Чармъхта Канънъ Дьоктюн //

[V2]
.           C            G              F              C
 // Краллъм Сенсин Гювенирим Сана Гювенирим Сана Гювенирим //
.   F    G        C           F     G        C    Bmb5
 // Бени-и Гючлендирен Сенсин, Сана Хамдедерим //

[C2]
.     Am     G      F       G
   //  Беним Ичин Савашан Сенсин
.  F       G         C
   Зафер Казанан Сенсин //</lyrics>
</song>