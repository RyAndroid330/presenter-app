<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>717</hymn_number>
<title>Шюкюрлер олсун сана, Раббимиз Иса ! BG717</title>
<lyrics>[V1]
 // Шюкюрлер олсун сана, Раббимиз Иса ! //

[C1]
   // Шюкюрлер, шюкюрлер олсун сана,
   Раббимиз Иса. //

[C2]
   // Еллерими калдърдъм, сенден истерим. //

[C3]
   // Гел, яврум, бенден исте, бен де вереджем. //

[C4]
   // Юзгюн дурма, гел яврум, калбин соумасън. //</lyrics>
</song>