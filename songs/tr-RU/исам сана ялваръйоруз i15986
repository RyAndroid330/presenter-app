<?xml version="1.0" encoding="UTF-8"?><song><title>Исам Сана Ялваръйоруз</title>
<key>Em</key>
<lyrics>[V1]
.   Em        Am
 // Исам сана ялваръйоруз
.D         Em
 Бизи аффетмен ичин  //

[C1]
.  Em      Am             B7
   Факат сучумуз йок дийоруз
.  Em         Bm                     Em
   Месихимсин Раб'бимизсин, Раб'бимизсин

[V2]
.   Em          Am
 // Бизи севдин джанънъ вердин
.D              Em
 ЬОлюп дирилдин бизим ичин  //

[C2]
.  Em       Am               B7
   Сен яклаштъкча биз узаклаштък
.  Em          Bm                         Em
   Сени текрар чармъха гердик, чармъха гердик

[V3]
.   Em           Am
 // Сенден ьозюр дилемедик
.D          Em
 Факат йине сана дьондюк  //

[C3]
.  Em     Am            B7
   Сана шюкюрлер олсун Исам
.  Em            Bm                   Em
   Сенин канънла темизлендик, темизлендик.</lyrics>
<author>Анъл Акън, Али Сафи Чичек</author>
</song>