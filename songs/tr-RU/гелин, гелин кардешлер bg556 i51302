<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>556</hymn_number>
<lyrics>[V1]
 // Гелин, гелин кардешлер,
 Хеп берабер биз олалъм.
 Хеп берабер ялваралъм,
 Берабер гьоке варалъм. //

[C1]
   Шюкюр олсун Аллаха,
   Шюкюр еделим,
   Аллахъ севиндирелим.
   Шюкюр олсун Аллаха,
   Шюкюр еделим,
   Хепсини севиндирелим.

[C2]
   // Гелин, гелин кардешлер.
   Чок, чок калаба гелин.
   Аллахъмъзъ ьовелим,
   Аллахъ севиндирелим. //

[C3]
   // Беним зайъф кулларъм,
   Онлара дарълмаялъм.
   Аллахън кувветинлен,
   Онлара даяк олалъм. //

[C4]
   // Диз чьокюп истейелим,
   Вереджек О, беклейелим.
   Аллахъмън вердийине
   Хепсимиз севинелим. //

[C5]
   // Гелин, гелин кардешлер.
   Чок калаба олалаъм.
   Аллахън кувветийлен
   Шейтанъ езелим. //</lyrics>
<title>Гелин, гелин кардешлер BG556</title>
</song>