<?xml version="1.0" encoding="UTF-8"?><song><title>Неден съкълдън, яврум BG644</title>
<lyrics>[V1]
 // Неден съкълдън, яврум,
 Неден дюшюндюн.
 Неден сен бана, яврум,
 Хич гювенмедин ? //

[V2]
 // Билмез мисин, сен яврум,
 Бен курбан гиттим.
 Хепиниз ичин, яврум,
 Канъмъ дьоктюм. //

[V3]
 // Доору йолдан гит, яврум.
 Иман ет бана.
 Йерин хазърдър, яврум,
 Гьоклер йюзюнде. //

[V4]
 // Калдър кафанъ, яврум.
 Инат олма сен.
 Аала бана, яврум, сен.
 Аала бана сен. //

[V5]
 // Дюшюнджени сен, яврум,
 Теслим ет бана.
 Ал беним Рухуму,
 Шен ол дюняда. //</lyrics>
<hymn_number>644</hymn_number>
</song>