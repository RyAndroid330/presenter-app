<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   // Раббим бизи чок севди,
   Гьокйюзюнден о инди,
   Йерйюзюнде яшадъ.
   Танръ'йъ ачъкладъ. //

[C2]
   // Имануел доду дюняя.
   Бизи куртарсън гюнахтан.
   Имануел, Имануел,
   Йюджедир о, дюняда. //

[C3]
   // Чок чекилер о чекти,
   Гюнахларъ йюкленди.
   Бизим ичин о ьолдю,
   Юч гюн сонра дирилди. //

[C4]
   // Бюйюк мюжде Инджилде,
   Йол ве яшам Иса'да.
   Херкес дуйсун, ьоренсин,
   Куртулушумуз Месих'те. //</lyrics>
<title>Раббим бизи чок севди BG657</title>
<hymn_number>657</hymn_number>
</song>