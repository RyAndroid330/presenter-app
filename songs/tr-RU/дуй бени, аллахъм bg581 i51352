<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>581</hymn_number>
<title>Дуй бени, Аллахъм BG581</title>
<lyrics>[V1]
 // Дуй бени, Аллахъм,
 сана Илахи сьойлюйом.
 Чюнкю сен бизим ичин
 Чармъха сен герилдин //

[C1]
   // (кадънлар) Аллахъм сен, (еркеклер) Аллахъм сен.
   (кадънлар) Татлъсън,
   (еркеклер) Татлъсън,
   (херкес) Биз сени чок
   севийоруз.
   (кадънлар) Биз хер заман,
   (еркеклер) Биз хер заман
   (кадънлар) Ялваръйоз,
   (еркеклер) Ялваръйоз.
   (херкес) Йени йеримизе
   гиделим. //

[V2]
 // Раббим Иса, Аллахъм,
 Бизе херкес чок гюлюйор.
 онлар билйорлар ки
 Онлар ичин де сен олдун //

[V3]
 // Тез геледжен аллахим
 бу Дюняйъ сен якаджан
 Йени йер ве йени гьок
 Бизе сен хазърладън. //</lyrics>
</song>