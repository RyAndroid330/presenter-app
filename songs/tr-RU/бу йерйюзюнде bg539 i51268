<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Бу йерйюзюнде
 Нерейе гидейим,
 Илахи сьойлейим,
 Аллахъ арайъм? //

[C1]
   // А а а, Раббим севгилим,
   А а а, Раббим кувветли,
   А а а, Алелуя. //

[V2]
 // Бизи чок севди, Иса Раббим,
 Хаджа теслим бизе олду. //

[V3]
 // Иса Месих'те беним шифам,
 Одур бана гьокте чобан. //

[V4]
 // Гел, Раббим Иса, ал бизи сен,
 Рахатъна гьотюр бизи. //</lyrics>
<title>Бу йерйюзюнде BG539</title>
<hymn_number>539</hymn_number>
</song>