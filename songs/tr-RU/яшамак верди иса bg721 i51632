<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>721</hymn_number>
<lyrics>[V1]
 // Яшамак верди Иса,
 Шюкюрлер еттим бен она.
 О канъйла ьодеди,
 Кенди темиз канъйла. //

[C1]
   // Бракма, бракма бени сен,
   Сени севийорум.
   Сенсиз бен яшаямам,
   Сенсиз бен оламам. //

[V2]
 // Сенин еллеринден
 Яшъйоруз чок исля.
 Калбими сана вердим,
 Яшамак хеп булдум. //

[V3]
 // Аллах геледжек,
 О бизи аладжак,
 О бизи аладжак,
 Бизимле оладжак. //

[V4]
 // Атеш янаджак,
 Ким иман едерсе
 Ким иман едерсе,
 Раббимле яшаяджак. //</lyrics>
<title>Яшамак верди Иса BG721</title>
</song>