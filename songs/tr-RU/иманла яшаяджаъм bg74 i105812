<?xml version="1.0" encoding="UTF-8"?><song><aka>Иманла Йюрюйеджеим</aka>
<lyrics>[V1]
.   Dm
 // Иманла йюрюйеджеим
.Bb
 Иманла дюшюнеджеим
.Gm
 Иманла конушаджаъм
.A
 Иманла яшаяджаъм //

[V2]
.Dm
 Башкасънън гьоремедиини
.Bb
 Иманла бен гьореджеим
.Gm          Gm7
 Башкасънън аламадъънъ
.A                Dm
 Иманла бен аладжаъм

[C1]
.     Dm    F       Gm
   // Иман Сенде бир армаан
.  A            Dm C Bb A
   Бедава Сенде са-ланан
.  Bb         Gm    Gm7  A
   Бу бюйюк лютфун ичин Раб
.  A             Bb A  Dm
   Хамтлар олсун Сана Иса //

[V3]
.   Dm
 // Хаятъмън кадерисин
.Bb
 Беним геледжеимсин
.Gm     Gm7
 Яшама себебимсин
.A                 Dm
 Сен беним нефесимсин. //

[V4]
.    Dm
 /// Иманла (иманла)
.Bb
 Гюджюнле (Гюджюнле)
.Gm       Gm7
 Капълар ачъладжак
.A                 Dm
 Дююмлер чьозюледжек ///

[V5]
.Dm
 Иманла (иманла)
.Bb
 Гюджюнле (Гюджюнле)
.Gm        Gm7
 Хасталар ийилешиджек
.A                  Dm
 Аджълар сон буладжак ///  ///</lyrics>
<key>Dm</key>
<title>Иманла Яшаяджаъм BG74</title>
<author>Иско Йовджхев</author>
<hymn_number>74</hymn_number>
</song>