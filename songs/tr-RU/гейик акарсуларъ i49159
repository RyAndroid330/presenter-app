<?xml version="1.0" encoding="UTF-8"?><song><author>Румен Илиев</author>
<key>Em</key>
<lyrics>[V1]
.Em               F         Em
 Ей Ъсам сенсин беним Танръм
.   Am              F
 сени чок ьозлюйорум
.Am                    G
 // джанъм сана сусамъш
.F                                Em
