<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>609</hymn_number>
<title>Иште гелдим, сенин калбине BG609</title>
<lyrics>[V1]
 Иште гелдим, сенин калбине.
 // Шифаладъм сени, беним оласън. //

[C1]
   Бен сени чок севдим, бракмам сени
   Янгън, атешлерде бракмам сени.
   Иште вакът гелди, яврум, беним олсаън

[C2]
   // Айдънлаттъм йюзюню, гьордюн бени. //
   Узаттъм еллерими, туттум сени,
   // Гьостердим сана, яврум, дженнетими. //

[C3]
   Гедже гюндюз ишледин, гедже гюндюз ишледин.
   // Бен гьордюм сени, тарлайъ биттирдин. / //

[C4]
   Яктърмам сени, гьостердим сана,
   // Яврум, мутлу йюзюмю. //</lyrics>
</song>