<?xml version="1.0" encoding="UTF-8"?><song><author>МАХМУТ КАРДЕШ</author>
<hymn_number>614</hymn_number>
<title>Йюдже Танръм бинлердже BG614</title>
<lyrics>[V1]
 // Йюдже Танръм бинлердже
 Шюкюрлер еделим сана.
 Саа салим топладън бизи
 Сенин татлъ саяна. //

[C1]
   // Орада беяз евимиз,
   Орада бизим бахчемиз,
   Дьон гел артък сен Иса,
   Теслим ет бизи янъна. //

[C2]
   // Шюкюр, шюкюр Раб Иса'я
   Сенсин гьозлетлейен бизи,
   Канънла йъка бизи,
   Иманла долдур бизи. //

[C3]
   // Шюкюр, шюкюр Раб Иса'я
   Канънъ дьоктю бизе,
   Канънла йъка бизи,
   Иманла долдур бизи. //</lyrics>
</song>