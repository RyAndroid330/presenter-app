<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Гел Аллахъм, гел Бабаджъъм !
 Сен йъка бени канъйла. //

[C1]
   // Ей Аллахъм, о Бабаджъъм.
   Гайретлисин, чилелисин. //

[V2]
 // Сизи, яврум, гьорюйорум,
 Сизи джандан севийорум. //

[V3]
 // Бахчемдеки гюллер гиби,
 Хер гюн сизи коклуйорум. //

[V4]
 // Сизин калбиниз капалъ.
 Сиз хер вакът дуа япън. //

[V5]
 // Бизи чамурдан чъкардън.
 Бизи сенде темизледин. //</lyrics>
<title>Гел Аллахъм, гел Бабаджъъм ! BG550</title>
<hymn_number>550</hymn_number>
</song>