<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // О Месихтир, Раб ве Аллахтър,
 О тек йолдур, герчек хаяттър. //

[C1]
   // Алелуя, Шейтан йенилди,
   Алелуя, шюкюр Иса'я. //

[C2]
   // О падишах падишахлара,
   О хакимдир, тюм хакимлере. //

[C3]
   // Шифа булдук
   Яраларийлан.
   Айдънландък
   Онун канийлан. //

[C4]
   // Тешеккюрлер
   Аллахъмъза.
   О аффетти
   Гюнахъмъзъ. //</lyrics>
<title>О Месихтир, Раб ве Аллахтър BG654</title>
<hymn_number>654</hymn_number>
</song>