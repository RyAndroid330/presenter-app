<?xml version="1.0" encoding="UTF-8"?><song><author>Сефа Гьормезьоз, Гюркан Чамсун</author>
<hymn_number>401</hymn_number>
<title>Калдъръръм Еллерим' Сана TY401 RT65</title>
<lyrics>[V1]
.         Em               B7
 //  Калдъръръм еллерим' Сана,
.                    Em
 ЬОверим Сени, Иса Месих  //
.         D              G
 //  Йюджедир, йюджедир Иса,
.      D            Em
 Йюджелсин топлулуунда  //

[V2]
.            Em               B7
 //  Хич бир шей аламаз ки бенден,
.                       Em
 Сендеки сонсуз севинджими  //
.          D                G
 //  Данс едерим Сенин ьонюнде,
.     D              Em
 Дудакларъмда езгилерле  //

[V3]
.            Em                B7
 //  Йол, герчек ве яшам Месих'те
.                      Em
 О'нда сонсуз умут булунур.  //
.         D               G
 //  Шюкредерим Месих Иса'я
.      D            Em
 Хамдолсун Иса Раббиме.  //

[V4]
.        D                 G
 //  Халелу-, Хале-, Халелуя!
.    D                 Em
 Халелу-, Хале-, Халелуя!  //</lyrics>
<key>G</key>
</song>