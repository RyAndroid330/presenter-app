<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Чок чеки гечирдим, Исам,
 Чок чеки гечирдим бен.
 Гюнахъмъ гьорюйорсун,
 Сана сьойлерим. //

[C1]
   А-а-а-а-а
   Сен бизи булдун.
   А-а-а-а-а
   Селамет вердин.

[C2]
   // Не сьойлейим сана, Аллах,
   Не сьойлейим сана, бен?
   Чок татлъсън, севен Аллах,
   Чок татлъ зенгин. //

[C3]
   // Истерим гезейим, Аллах,
   Истерим гезейим бен.
   Бу дюняда, севен Аллах,
   Чок татлъ зенгин. //

[C4]
   // Юзгюн ве зайъфъм, Аллах,
   Юзгюн ве зайъфъм, бен.
   Бана куввет вер сен, Аллах,
   Сенин гюджюнден. //</lyrics>
<title>Чок чеки гечирдим, Исам BG707</title>
<hymn_number>707</hymn_number>
</song>