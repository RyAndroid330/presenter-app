<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   G         C
 Сенсиз ъшъъм йок
.   D             G
 Сенсиз хич йолум йок
.   G          C
 Сенсиз юмидим йок
.   D        G    G7
 Сенсиз иште ьолюм

[C1]
.            C        D       G D Em
   Чюнкю тюм дюня Сенин елинде
.         Am D        G  G7
   Иште я Раб Сана гелдим
.             C       D       G D Em
   Чюнкю тюм дюня Сенин елинде
.    Am D         G
   Я Раб куртар бени

[V2]
.   G             C
 Сенсиз бир шейим йок
.    D            G
 Сенсиз бир шей деилим
.   G           C
 Сенсиз хич олмадъ
.   D        G  G7
 Сенсиз япамадъм

[C2]
.            C        D       G D Em
   Чюнкю тюм дюня Сенин елинде
.         Am D        G  G7
   Иште я Раб Сана гелдим
.             C       D       G D Em
   Чюнкю тюм дюня Сенин елинде
.    Am D         G
   Я Раб куртар бени

[C3]
.             C       D       G D Em
   Чюнкю тюм дюня Сенин елинде
.    Am D         G
   Я Раб куртар бени
.    Am D         G
   Я Раб куртар бени,
.       Am  D        Cm G
   Иште Раб, сана гелдим</lyrics>
<title>Сенсиз Ъшъъм Йок TY596</title>
<author>Мбай</author>
<hymn_number>596</hymn_number>
</song>