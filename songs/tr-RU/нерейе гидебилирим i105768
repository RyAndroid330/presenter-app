<?xml version="1.0" encoding="UTF-8"?><song><title>Нерейе Гидебилирим?</title>
<key>Am</key>
<lyrics>[V1]
.   Am         F     G   F      G  Am
 // Ей Танръ йокла бени, танъ йюреими
.Am           F     G  F       G       Am
 ЬОнджюлюк ет чоджууна сонсуз яшам йолунда //

[V2]
.   Am                 F         G Am
 // Нерейе гидебилирим Сенин Рухундан?
.Am              Dm   E/E7    (Am)
