<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<author>Мустафа Абидов</author>
<title>Тапънъръм Лайъксън BG58</title>
<lyrics>[V1]
.   D      G
 // Варлъънда олдуумда
.A           D
 Сана гювенирим
.D       G              A
 Бенимле ол сонсуз бойунджа
.        D
 Сен сонсузсун //

[C1]
.     D    G         A
   // Тапънъръм лайъксън
.  D    G        A
   ЬОверим лайъксън
.  D      G           A
   Диз чьокерим лайъксън
.       G     A    D
   Лайъксън я Раб Иса //

[V2]
.   D         G
 // Чеврем кьотюлюк
.       A     D
 Джанъмда Сенде
.D      G
 Бени коруян
.     A      D
 Дойуран Рабсин //</lyrics>
<key>C</key>
</song>