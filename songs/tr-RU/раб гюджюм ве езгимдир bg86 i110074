<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am           Em
 // Даънда конут курду,
.Am                    Em
 Сулар саънда, солунда дувар олду.
.Dm
 Халкън Сени ьовгюйле анар,
 Раб гюджюм ве езгимдир. //

[C1]
   // Дениз ярълдъ йоллар ачълдъ,
   Халкън ьозгюрлюе кавушту.
   Са елинле куртулуш гелди,
   Адън сонсуза дек РАБ'дир. //

[V2]
 // Гюч ве зафер йюдже РАБ'биндир,
 Езгилер сунун РАБ'бе.
 Чюнкю йуджелдикче, йюджелди,
 Йуджелдикче, йюджелди. //</lyrics>
<key>Am</key>
<title>Раб Гюджюм Ве Езгимдир BG86</title>
<hymn_number>86</hymn_number>
<author>Муса Месих Олу, Мустафа Абидов, Тахир Тодоров</author>
</song>