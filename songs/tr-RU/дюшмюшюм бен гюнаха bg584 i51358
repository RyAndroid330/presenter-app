<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Дюшмюшюм бен гюнаха,
 Дири суйла бени йъка. //
 Сенде калмак истерим,
 Булдун ве севдин бени

[V2]
 // Не йъкар гюнахъмъ?
 Анджак Иса'нън канъ. //
 Иса херкеси север,
 Хеп ярдъм етмек истер.

[V3]
 // Сенин дири сьозлерин
 Дерин калбиме гирер. //
 Иса, сенин ъшъън,
 Бени гюнахтан чекер.

[V4]
 // Херкес сени инкяр етти,
 Кимсе сени севмеди. //
 Сьозлерини аттълар,
 Сени ьолюме койдулар.</lyrics>
<title>Дюшмюшюм бен гюнаха BG584</title>
<hymn_number>584</hymn_number>
</song>