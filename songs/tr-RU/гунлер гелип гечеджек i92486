<?xml version="1.0" encoding="UTF-8"?><song><title>ГУНЛЕР ГЕЛИП ГЕЧЕДЖЕК</title>
<lyrics>[V1]
 ГУНЛЕР ГЕЛИП ГЕЧЕДЖЕК
 ДУНЯ БИТЕДЖЕК
 АЛЛАХА ИТААТ ЕДЕНЛЕР
 О ЙУЗЮНЮ ГЬОРЕДЖЕК

[C1]
   АЛЛАХЪМ АЛЛАХЪМ
   АЙЪРМА БИЗИ АЛЛАХЪМ
   АЛ БИЗИ ЯНЪНА

[V2]
 ГЬОКТЕ ОЛАН МЕЛЕКЛЕР
 БИЗИ БЕКЛЕРЛЕР
 АЛЛАХА ИТААТ ЕДЕНЛЕР
 ХОШ ГЕЛДИН ДЕРЛЕР

[V3]
 ЕН БЮЙУК АЛЛАХ ГЬОКЛЕРДЕ
 КИМСЕДЕН КОРКМАЗ
 РУХ ДЖЕННЕТИ О ВЕРДИ
 ШЕЙТАНЪ О ЙЕНДИ</lyrics>
</song>