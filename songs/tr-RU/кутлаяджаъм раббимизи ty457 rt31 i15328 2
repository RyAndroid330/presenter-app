<?xml version="1.0" encoding="UTF-8"?><song><title>Кутлаяджаъм Раббимизи TY457 RT31</title>
<lyrics>[V1]
.    Em         Am
 //  Кутлаяджаъм Раббимизи
. B7            Em
 Йени бир илахи иле.  //
.Em   Am D  G
  //  ЬОведжеим
. C    B7        Em
 йени бир илахи иле.  //

[C1]
.      Em
   //  Халелуя, (Халелуя)
.  Am
   Халелуя, (Халелуя)
.  B7             Em
   Халелуя, Халелуя!  //

[V2]
.    Em          Am
 //  Иса дирилди, ьолюм йенилди,
.B7              Em
 Танръ'я шюкюрлер олсун.  //
.    Em Am    D    G   C    B7        Em
 //  Зафер казанълдъ, Танръ'я шюкюрлер олсун.  //

[V3]
.    Em           Am
 //   Езги сьойлейин, Раб'би йюджелтин,
.B7             Em
 Чюнкю харикалар яптъ  //
.    Em  Am     D   G
 //  Бабамъза тапънън,
. C    B7       Em
 Чюнкю харикалар яптъ  //</lyrics>
<key>G</key>
<hymn_number>457</hymn_number>
<author>Дон Моен</author>
</song>