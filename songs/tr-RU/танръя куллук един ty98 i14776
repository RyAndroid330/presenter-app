<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Танръ'я куллук един
 Севинч иле, хамтлар иле.  //
 //  Раб'бин ьонюнде дурун
 Севинч иле шюкюр иле.  //

[C1]
   //  Капъларъна гирин
   Севинч иле, хамтлар иле.  //
   //  Авлусунда отурун
   Севинч иле, шюкюр иле.  //

[C2]
   //  Раб'бе шюкюр йюкселтин,
   Раб ийидир, севеджендир.  //
   //  Адънъ мутлу кълън,
   Инайети ебедидир.  //</lyrics>
<title>Танръ'я Куллук Един TY98</title>
<hymn_number>98</hymn_number>
<author>Али Язар</author>
</song>