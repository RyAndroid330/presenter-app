<?xml version="1.0" encoding="UTF-8"?><song><title>Я Раб Севгин Тюкенмез BG33</title>
<key>Em</key>
<lyrics>[V1]
.   Em
 //  Я Раб севгин тюкенмез
.Am        G   D       Em
 Севгийи сулар сьондюрмез //
.   Am
 //  Сана гелен сусамаз
. Em       D
 Дюня суйуну арамаз //

[V2]
.   Em
 //  Я Раб мюхюрледин бени
.Am     G   D    Em
 Еллеринин ортасъна //
.   Am
 // Бени ьойле чок севдин'ки
. Em       D
 Йюрюдюн таа чармъха //

[V3]
.   Em
 // Анне унутса биле
. Am     G D     Em
 Емзиктеки яврусуну //
.   Am
 //  Сен унутмазсън севдиин
. Em       D
 Сечтиин олуну //

[V4]
.   Em
 //  Раб'бе ьовгюлер олсун
.Am  G       D    Em
 Раб бизлери корусун //
.Am
 // Онун берекетлери
. Em              D
 йюреклери долдурсун //</lyrics>
<hymn_number>33</hymn_number>
<author>Байрам Токгьоз</author>
</song>