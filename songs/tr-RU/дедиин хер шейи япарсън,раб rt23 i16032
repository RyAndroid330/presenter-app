<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>23</hymn_number>
<author>Амй Охлер</author>
<key>Eb</key>
<lyrics>[V1]
.Cm                Fm      Gm
  Дедиин хер шейи япарсън Раб
.Bb                    Gm
  Вердиин хер ваади герчеклештирирсин
.Cm                   Fm    Gm
  Сьозюн Сана бош дьонмейеджек
.Bb            Gm          Cm
  Истемини йерине гетиреджек

[C1]
.     Cm       Ab              Eb
   //  Инанъръм, Сана гювенирим
.              Bb        Cm
   Бенден тек истеин будур //

[V2]
.Cm                Fm    Gm
  Инсан деил йюдже Танръсън
.Bb              Gm
  Дюшюнджелерини деиштирмезсин
.Cm                   Fm     Gm
  Сен сьойлерсин де япмаз мъсън
.Bb                   Gm          Cm
  Сьоз верирсин де тутмаз мъсън....

[B1]
.     Cm         Ab
   // Гювенилир, садък Олан,
.  Eb               G
   Хершейе гюджю йетен Рабсин. //</lyrics>
<aka>Инанъръм</aka>
<title>Дедиин Хер Шейи Япарсън,Раб RT23</title>
</song>