<?xml version="1.0" encoding="UTF-8"?><song><author>Хилтруд Стрьохлеин</author>
<hymn_number>145</hymn_number>
<title>Бир Бебек Доду TÇ145</title>
<lyrics>[V1]
.D
 Бир бебек доду, бир бебек доду.
.A7        D
 Онун исми Иса.

[V2]
 // Йемликте яттъ. //
 Бизим ичин доду.

[V3]
 // Танръ'дан гелди, //
 Бизи севдии ичин.

[V4]
 // Чок севинириз. //
 Танръ'я шюкюрлер!</lyrics>
<key>D</key>
</song>