<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>73</hymn_number>
<title>Йерим Мекянъм Вардър Бенъм BG73</title>
<lyrics>[V1]
 Ябанджъйъм шу дюнянън елинде.
 // Аллахимла олайъм, онунла биле. //

[V2]
 // Йерим, мекянъм вардър беним,
.    
     Дженетте мекянъм вар,
.    
     Дженетте мирасъм вар. //

[V3]
.    
     Истемийом шу дюнянън олайъм.
 // Чюнкю бен хазър олдум, гьоке гидейим. //

[V4]
.    
     Йорулдун му, Рабби ара, булурсун.
 // Билирим ки Аллахъм, бана ярдъмджъ. //

[V5]
.    
     Шу дюнянън йолунда Раб бенимле,
 // Бана хер вакът Иса, йолдаш олуйор. //

[V6]
.    
     Куртаръджъ Раб Месихе гелесен,
 // Беклийор сени шимди, иман едесин. //

[V7]
.    
     Артък вакът яклашъйор, Раб гелсин.
 // Хер джанън соргусуну, о япаджактър. //</lyrics>
</song>