<?xml version="1.0" encoding="UTF-8"?><song><title>бен сизи йюкледим яврулар</title>
<lyrics>[V1]
 // Бен сизи йюкледим яврулар
 Сизи сатън бен алдъм //

[V2]
 // Гери дьонмейин Месихин йолундан
 Сизин ичин герилдим канъмъ сизе дьоктюм //

[V3]
 // Кутсал Рухуму верийом
 Сизин калбинизе //

[V4]
 // Иманда дурун севгиде дурун //

[V5]
 // Инанън сиз Месихе
 Чюнкю о тез геледжек //

[V6]
 // Ким хазър алънаджак
 Хазър олмаян янаджак //</lyrics>
</song>