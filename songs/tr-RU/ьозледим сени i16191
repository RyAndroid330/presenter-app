<?xml version="1.0" encoding="UTF-8"?><song><title>ЬОзледим Сени</title>
<lyrics>[C1]
.  Am                Dm
   // ЬОзледим сени,  Беклерим сени
.  Em             Am
    Истерим сени, Раб'бим //

[V1]
.Am
 // Сенсин бени чаъран
.Em
  Сенсин бени араян
.Dm
  Сенсин бени куртаран
.F         G
  Ефендим Раб'бим Иса //

[V2]
.Am
 // Мутлуйум бен сенинле
.Em
  ЬОзгюрюм сьозлеринле
.Dm
  Гючлюйюм бен севгинде
.F         G
  Ефендим Раб'бим Иса //

[V3]
.Am
 // Баъшландъм канънла
.Em
  Акландъм бен Рухунла
.Dm
  Айдънландъм сьозюнле
.F         G
  Ефендим Раб'бим Иса //</lyrics>
<key>Am</key>
<author>Бедрос Мъдъсъ</author>
</song>