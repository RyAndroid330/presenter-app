<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>567</hymn_number>
<title>Гюнахъмъзъ аффедийорсун BG567</title>
<lyrics>[V1]
 // Гюнахъмъзъ аффедийорсун,
 шифа верийон, севги верийон.
 Шюкюр олсун сана, шимдиден ебединдже. //

[V2]
 // Бизим ичин чармъха герилдин,
 Ючюнджю гюню къям да еттин.
 Шимди йерин гьокюн кудрети сендедир. //

[V3]
 // Ялваръйоз сана, Иса Месих,
 Йине гелесин бу дюнямъза.
 Бизи аласън, сенинле олалъм ебединдже. //</lyrics>
</song>