<?xml version="1.0" encoding="UTF-8"?><song><author>Шабан Ок</author>
<hymn_number>577</hymn_number>
<lyrics>[V1]
 // Сен беним хаятъма гирдиинден бери,
 Бамбашка бир инсан олдум о гюнден бери. //
 Ески Адем'ден калмамъш гюнах излери,
 // Раб Иса гийдирди бана йени Адем'и. //

[C1]
   (Еркеклер) // Йениден додум Иса'йла,
   (Баянлар) Шюкюр, куртулдум Иса'йла,
   (Еркеклер) Севинджи булдум Иса'йла,
   (Херкес) Иса'йла.
   (Еркеклер) Гюлер, ойнаръм Иса'йла,
   (Баянлар) Алар, джошаръм Иса'йла,
   (Еркеклер) Шимди мутлуйум Иса'йла,
   (Херкес) Иса'йла. //

[V2]
 // Иса гийдиреджек бана яшам таджънъ,
 Чюнкю О ташъдъ гюнахъмъ, аджъмъ. //
 Шимди О'на бъракъръм тюм хаятъмъ,
 // Раб Иса йьонетсин беним тюм яшантъмъ. //</lyrics>
<title>Сен Беним Хаятъма Гирдиинден Бери TY577</title>
</song>