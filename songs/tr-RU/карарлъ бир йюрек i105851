<?xml version="1.0" encoding="UTF-8"?><song><author>Генджебай</author>
<lyrics>[V1]
 // Карарлъ бир йюрек бир калп вер бана
 сана аданмъш бир яшам вер бана
 йолунда йюрюйен сенин изинде гиден
 бир рух сала ичимде Танръм Раббим //

[V2]
 // Раб билирим ки сенин сьозюн
 дерин ве енгин бир дениз гибидир
 сенин севгин ешсиз бензерсиздир
 Сен кутсал кутсал кутсалсън Месих // ..

[V3]
 // Гьоркемине йюджелиине бакаркен
 ьовгю ве йюджелик дьокюлсюн дилимден
 кудрет йюджелик берекет ве хюрмет
 сонсузлара дек сениндир Танръм Раббим //</lyrics>
<title>Карарлъ бир йюрек</title>
</song>