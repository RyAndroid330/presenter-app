<?xml version="1.0" encoding="UTF-8"?><song><author>Адил Яшар</author>
<lyrics>[V1]
 // Мерхамет Долу Аллахъм
 Севгин бана Сънърсъздър
 Есирге бютюн Сучларъмъ
 Калдър бенден Йюклерими //

[V2]
 // Аллахъм Ей Аллахъм
 Дуй беним Дуаларъмъ
 Ялваръйом сана баръйом
 Ъшит Бени Ей гючлю Раб Танръ
 Сучларъмдан Гюнахъмдан
 Арът бени Кудретли Аллахъм //

[V3]
 // Гюч вер сен бана Кутсал Рух
 Йълмадан Хеп садък Калайъм
 ЬОмрюмюн бютюн гюнлеринде
 Сенинлен Хеп Яшайъм //</lyrics>
<title>Мерхамет Долу Аллахъм</title>
</song>