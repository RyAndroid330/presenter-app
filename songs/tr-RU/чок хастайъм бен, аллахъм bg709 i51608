<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>709</hymn_number>
<title>Чок хастайъм бен, Аллахъм BG709</title>
<lyrics>[V1]
 // Чок хастайъм бен, Аллахъм. //
 // Сен илачлаясан бени. //
 // Ялваръйорум бен сана, //
 // Аффет бени сен, Аллахъм. //
 // Еллерими бен калдърдъм, //
 // Гьозяшъмъ сил, сен беним. //
 // Ел калдър сен бана, яврум. //
 // Ярдъмджъйъм артък сана. //
 // Дюня битикиси оладжак. //
 // Сиз янъма геледжеиниз. //

[V2]
 Ааламайън, явруларъм.
 Ааламайън, кузуларъм.

[V3]
 // Бен сизе сабър вереджем. //
 Хепсинизи гьорюйорум,
 Хепсинизи язъйорум.
 // Сизе дава гьорюнеджек. //
 // Инанчларъ бен аладжам. //
 Инанмадък кулларъмъ
 Атешлерде бен якаджам.</lyrics>
</song>