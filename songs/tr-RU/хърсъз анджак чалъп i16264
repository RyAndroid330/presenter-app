<?xml version="1.0" encoding="UTF-8"?><song><title>Хърсъз анджак чалъп</title>
<key>G</key>
<lyrics>[V1]
.Em                         B                        Em
 // Хърсъз анджак чалъп ьолдюрмек ве йок етмек ичин гелир  //
.Em                 Am       C            D            Em
 Бенсе инсанлар яшама, бол яшама сахип олсунлар дийе гелдим.

[V2]
.Em      B     Em
 Йуханна 10 айет 10</lyrics>
<hymn_number>12</hymn_number>
<author>Линда Топчу</author>
</song>