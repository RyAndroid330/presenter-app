<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>602</hymn_number>
<lyrics>[V1]
 // Истемийом бен сенден, Аллахъм,
 Истемийом бен сенден зенгинлик.
 Бен истийом, Раббим, сенин олайъм,
 Сана, Раббим, чалъшайъм. //

[C1]
   // Аллахъм, Иса, гел янъма.
   Йъка бени сенин канънла.
   Аффет беним гюнахларъм.
   Сонсуз яшамак вер бана. //

[C2]
   // Инанън сиз кардашларъм,
   Инанън сиз къзкардашларъм,
   Инанън Иса тез геледжек,
   Херкесе дава вереджек. //</lyrics>
<title>Истемийом бен сенден, Аллахъм BG602</title>
</song>