<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Еллерими калдърдъм Аллаха
 Аллахтан бен истедим //
 // Чок инсан гелсин имана //

[V2]
 Бен Аллахтан истийорум
 Дуа евини мубареклесин
 Севгисини версин бана
 /// Сонуна кадар дурайъм ///

[V3]
 А а а Аллахъм Иса Месих куртаръджъм
 А а а Аллахъм Иса Раб'бим куртаръджъм
 /// Бир танесин сен ///</lyrics>
<title>Еллерими калдърдъм Аллаха BG37</title>
<hymn_number>37</hymn_number>
</song>