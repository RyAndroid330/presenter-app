<?xml version="1.0" encoding="UTF-8"?><song><title>Иман Едип Раб'бе Гелдим, Караръмъ Бен Вердим TY598</title>
<key>Am</key>
<lyrics>[V1]
.   Am        Dm              Am        Dm
 // Иман едип Раб'бе гелдим, караръмъ бен вердим,  //
.   Am         Em
 // Баба, Оул, Кутсал Рух'ла  //
.G         Am
 вафтиз олдум

[V2]
.   Am          Dm           Am             Dm
 // Хаста идим, шифа вердин, йоргун идим, рахат вердин,  //
.   Am         Em
 // ЬОлю идим йашам вердин  //
.G       Am
 Месих Иса'м

[V3]
.   Am         Dm             Am        Dm
 // Кьоле идим Сен куртардън, гюнахъмъ баъшладън  //
.   Am          Em
 // Канънла Раб Месих Иса  //
.G        Am
 бени йъкадън</lyrics>
<hymn_number>598</hymn_number>
<author>Едип Авджъолу</author>
</song>