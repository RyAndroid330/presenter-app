<?xml version="1.0" encoding="UTF-8"?><song><title>Уянъш Йълъ</title>
<key>Em</key>
<lyrics>[C1]
.     Em        B7
   // Ядър Исам Рухуну
.               Em
   Бу йъл уянъш йълъ олсун. //

[V1]
.   Em        Am
 // Бютюн улуслар билсин
.       Em
 Куртаръджъ сенсин.
.           Am
 Гюнахлълар тьовбе етсин
.B7              Em
 Кутсал Рух верилсин. //

[V2]
.Em        Am
 Мюжден хъзла яйълсън
.     Em
 Инанлълар чоалсън.
.        Am
 Кьотюлюклер азалсън
.   B7             Em
 // Исам мерхаметлисин. //</lyrics>
<author>Айше Йумушак, Али Сафи Чичек</author>
</song>