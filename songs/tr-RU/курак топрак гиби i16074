<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Курак топрак гиби
 Сени чок ьозлюйорум. //
 // Солгун япрак гиби
 Йолуну гьозлюйорум. //
 Месихим, Месихим Аман.

[V2]
 // Ъссъз чьоллер ичинде
 Бир ваха аръйорум. //
 // Йоргунум гьолген алтънда
 Динленмек истийорум. //
 Месихим, Месихим Аман.

[V3]
 // Хърчън денизлерде
 Бир лиман аръйорум. //
 // Йоргунум йъллар ичинде
 Динленмек истийорум. //
 Месихим, Месихим Аман- (Хиджаз)</lyrics>
<title>Курак топрак гиби</title>
<author>Тургай Ючал</author>
</song>