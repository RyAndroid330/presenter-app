<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>215</hymn_number>
<lyrics>[V1]
 //  Раб'бе шюкюр йюкселтин!  //
 //  Чюнкю Танръ ийидир.  //
 //  О'на ьовгюлер сунун,  //
 //  Инайети сонсуздур!  //

[V2]
 //  Раб'дир беним севинджим,  //
 //  Умудум ве ьовюнджюм,  //
 //  Куртаръджъм ве Раббим,  //
 //  Беним яшам екмеим.  //</lyrics>
<title>Раб'бе Шюкюр Йюкселтин! TY215</title>
</song>