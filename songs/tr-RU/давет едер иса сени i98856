<?xml version="1.0" encoding="UTF-8"?><song><title>Давет Едер Иса Сени</title>
<lyrics>[V1]
 // Давет едер Ъса сени
 Бана гетир дертлерини //
 // Гел ей йоргун аргън бана
 Веририм бен рахат сана
 Рахат сана //

[V2]
 // Давет едер иса сени
 Гел ей сусуз динле бени //
 // Дири хаят суйу бенде
 Шифан ичин гел ич сенде
 Гел ич сенде //

[V3]
 // Иште гелдим гюнахлъйдъм
 Иште гелдим аффедилдим //
 // иште гелдим севинч булдум
 иште гелдим де куртулдум
 Де куртулдум //

[V4]
 // Мутсуз идим коштум она
 Йени йюрек верди бана //
 // Сенде ач калбини она
 Версин сонсуз хаят сана
 Хаят сана //</lyrics>
</song>