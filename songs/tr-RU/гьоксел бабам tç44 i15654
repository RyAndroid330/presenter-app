<?xml version="1.0" encoding="UTF-8"?><song><title>Гьоксел Бабам TÇ44</title>
<lyrics>[V1]
.    Em            Am      Em
 // Гьоксел бабам дюняларъ яраттъ.  //
.    Em        D     Em
 // Гьоксел Бабам бюйюктюр!  //

[V2]
 ..... ай ве гюнеши ..... (йълдъзларъ, булутларъ, ...)
 ..... аачларъ ..... (чичеклери, чименлери, ...)
 ..... хайванларъ ..... (тавшанларъ, койунларъ, маймунларъ, асланларъ, йъланларъ, филлери, ...)
 ..... сени ве бени .....
 ..... Иса Месих'и гьондерди.
 ..... гюнахларъмъзъ баъшладъ.</lyrics>
<key>G</key>
<hymn_number>44</hymn_number>
</song>