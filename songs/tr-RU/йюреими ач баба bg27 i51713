<?xml version="1.0" encoding="UTF-8"?><song><title>Йюреими ач Баба BG27</title>
<key>Am</key>
<lyrics>[V1]
.   Am
 // Ким дуярса Иса'йъ
 Ким дуярса Аллахъ
.F         Dm      E
 калдърсън еллерини //

[C1]
.     F         E
   // Ишит бени Баба
.  F  Dm     E
   ач йюреими //

[V2]
 // Йюреими ач Баба
 фикрими ач Баба
 ичери Сен гиресин //

[V3]
 // Сана кувет вереджем
 сана кувет вереджем
 сонунакадар дурасън //</lyrics>
<aka>Ким дуярса Иса'йъ</aka>
<hymn_number>27</hymn_number>
</song>