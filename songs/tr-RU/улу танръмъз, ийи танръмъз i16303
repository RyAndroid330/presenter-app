<?xml version="1.0" encoding="UTF-8"?><song><author>Адриенне Неусджх</author>
<lyrics>[V1]
.Giriş: Dm C Bb A
  
.Dm                 C   Bb
  // Гьоркем хюкюм сюрене
.             C     Dm
 ЬОвгю тахтта отурана
.           C      Bb
 Онур харикалар япана
.                     A
 Не улусун, Танръ! //
 Не улусун!

[C1]
.  Dm                 C        Bb
   Гьоклери ьовгюйле долдураджаъз
.                    A          Dm
   Ен йюдже хамтларъ йюкселтеджеиз
.                  C          Bb
   Сени хер шейден чок севеджеиз
.           A               Dm (veya Bb - en son)
   Улу Танръмъз, ийи Танръмъз__
.            A               Dm
   (Улу Танръмъз, ийи Танръмъз)

[V2]
.Dm               C     Bb
  // Гьоркем ьолюмю йенене
.               C     Dm
 ЬОвгю бизи гючлю кълана
.              C       Bb
 Онур 'Бенимсиниз' дийене
.                     A
 Не ийисин, Танръ! //
 Не ийисин!

[B1]
.  Bb                      Dm               C         Bb
    // Йюдже адън яйълдъкча, Краллар Кралъ, Раблер Рабби
.  (Bb)                       A
   ЬОвгюлер де дюнянън дьорт буджаънда артъйор //</lyrics>
<key>Dm</key>
<title>Улу Танръмъз, Ийи Танръмъз</title>
</song>