<?xml version="1.0" encoding="UTF-8"?><song><title>Нередесин, сен Аллахъм ? BG646</title>
<lyrics>[V1]
 // Нередесин, сен Аллахъм ? //
 Ишит бени, сен Аллахъм.
 // Зор халдейим, гел
 гъор бени. //
 // Вур капъмъ, бен ачайъм. //

[V2]
 // Ачъп да сана бакайъм. //
 // Сьойле дердини сен бана. //
 Ярдъмджъйъм, яврум, сана.
 // Ярдъмджъйъм, кузум, сана. //

[V3]
 // Калдър еллерини бана. //
 Ярдъмджъйъм, яврум, сана.
 // Ярдъмджъйъм, кузум, сана. //
 // Нередесин, деме бана ! //

[V4]
 Хепсинизи гьорюйорум.
 // Хепсинизи язъйорум. //
 // Иса Месих давет етти. //
 // Херкесе иман инан верди. //

[V5]
 // Сизе рухуму ейледим. //
 Сизе шифалар вердим.
 // Сизе дженнет ейледим. //</lyrics>
<hymn_number>646</hymn_number>
</song>