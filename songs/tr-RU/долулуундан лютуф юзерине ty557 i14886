<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>557</hymn_number>
<title>Долулуундан Лютуф Юзерине TY557</title>
<lyrics>[C1]
.      Em         Am
   //  Долулуундан лютуф юзерине
.  B7             Em
    Хепимиз лютуф алдък.  //

[V1]
.              Am
 Лютуф, лютуф Бабамъздан
.B7       Em   B7
 Яшамъмъ долдурсун.
.Em            Am
 Лютуф, лютуф Бабамъздан
. B7              Em
 Иса Месих'ле гелди.

[C2]
.      Em         Am
   //  Долулуундан севги юзерине
.  B7             Em
    Хепимиз севги алдък.  //

[V2]
.              Am
 Севги, севги Бабамъздан
.B7       Em   B7
 Яшамъмъ долдурсун.
.Em           Am
 Севги, севги Бабамъздан
. B7              Emin
 Иса Месих'ле гелди.

[V3]
 Севинч...

[V4]
 Хузур...</lyrics>
<key>Em</key>
</song>