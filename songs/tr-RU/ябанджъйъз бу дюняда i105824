<?xml version="1.0" encoding="UTF-8"?><song><title>Ябанджъйъз бу Дюняда</title>
<lyrics>[V1]
 // Ябанджъйъз бу Дюняда
 Гюнахлъ инсанларъз
 Кьотюлюклер япъйоруз
 Биз бу йерйюзюнде //

[V2]
 // Бъктъм артък бу Гюнахтан
 Куртулмак истийорум
 Бири бана ярдим етсин
 Дийе бен баъръйорум //

[V3]
 // Бири бана ярдим етти
 Бири бана гюдж верди
 О Раб Иса месихти
 О бени куртардъ //

[V4]
 // Шюкюрлер олсун Месихе
 О бени куртарди
 Гюнахларъмдан куртулдум
 Раб Иса сайесинде //

[V5]
 // Сонсуз яшам вар шимди
 Артък бенде сахибим
 Гюнахларъмдан куртулдум
 Раб Иса сайесинде //</lyrics>
</song>