<?xml version="1.0" encoding="UTF-8"?><song><author>Сонгюл Дуран</author>
<title>Беним Танръ'м Диридир</title>
<key>Am</key>
<lyrics>[V1]
.   Am       G        Am
 // Беним Танръ'м диридир,
.Am        G        C  A
  Беним Танръ'м хаятта.
.Dm
  Сесленирсем дуяр,
.Am
  Бени янътлар,
.G      Em      Am
  Енгел йок ки О'на. //

[V2]
.   Am
 //  О гюнахъ йенди,
.Am
  ЬОлюмю алт етти.
.Dm
  Зафер казандъ.
.G              Am
  Дирилди, дирилди. //

[V3]
.Am                            Dm       Am
 // Иште бу йюзден гедже гюндюз тапънсам аздър,
.Am                       Dm         Am
  Бундан бьойле беним ичин хер гюн байрамдър.
.Dm                  G               Am
  Севинирим, джошаръм хер заман кутларъм,
.G/B C G         Em       Am
  Чюнкю беним Танръ'м диридир. //

[V4]
.   G         Em       Am
 //  Беним Танръ'м диридир. //</lyrics>
</song>