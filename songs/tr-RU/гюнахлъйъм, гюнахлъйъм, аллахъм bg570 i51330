<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>570</hymn_number>
<lyrics>[V1]
 // Гюнахлъйъм, гюнахлъйъм, Аллахъм, //
 // Аффет бени, гюнахъмъ, Месих Раббиджиим. //
 // Сонра сен севинеджексин гьок юзеринде. //
 // Куввет, иман, свеинч вердим сизе. //
 // ЬОйле иман булмадъм, ишлейим сизе. //
 // Хазър олун, яврум, бу йерйюзюнде. //
 // Калмайън бу йерйюзюне, янгън, атеше. //
 // Гезин, гезин, яврум, бени сьойлейин. //
 // Ораджъкта, бураджъкта топлайъм сизи. //
 // Сьойлейин бени, сьойлейин, яврулар. //
 // Кимселере кимсе ичин бир шей демейин. //</lyrics>
<title>Гюнахлъйъм, гюнахлъйъм, Аллахъм BG570</title>
</song>