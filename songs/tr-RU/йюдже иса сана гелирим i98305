<?xml version="1.0" encoding="UTF-8"?><song><title>Йюдже иса сана гелирим</title>
<lyrics>[V1]
 // Йюдже иса сана гелирим
 Сенсин Севги Кайнаъм
 Сонсуз яшам пънаръ
 Сана ихтияджъм Вар //

[V2]
 // Сенсин Яшам Екмеим
 Сенсин Дири суйум //
 // Аджъкмам Сусамам
 Чюнкю иса сен син Гъдам //

[V3]
 // Йюдже иса сана гелирим
 Яшам сьозлери сендедир
 Бен бу Гюнахлъ Кишийе
 Ваатлерин Рахат верир //

[V4]
 // Сенсин Яшам Екмеим
 Сенсин Дири суйум //
 // Аджъкмам Сусамам
 Чюнкю иса сен син Гъдам //</lyrics>
<author>Адил Яшар</author>
</song>