<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>320</hymn_number>
<author>Фарук Пекер</author>
<title>Халелуя, Халелуя, Халелуя, Хамтлар Сана! TY320</title>
<lyrics>[V1]
 //  Халелуя, халелуя, халелуя, хамтлар сана!  //

[V2]
 //  Йол, яшам, герчек сен олдун бизе.
 Хамтлар олсун Раббимизе!  //
 //  Халелуя, халелуя, халелуя, хамтлар сана!  //

[V3]
 //  Дирилдин, дирилиш сундун бизе.
 Йюджеликлер Раббимизе!  //
 //  Халелуя, халелуя, ьовгю олсун, Раб Иса'я!  //</lyrics>
</song>