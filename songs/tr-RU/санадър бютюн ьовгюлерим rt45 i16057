<?xml version="1.0" encoding="UTF-8"?><song><author>ЬОзгюр Тунч</author>
<hymn_number>45</hymn_number>
<key>G</key>
<lyrics>[C1]
.     Em                   Am
   // Санадър, бютюн ьовгюлерим.
.  (Am)
   Йюректен гелен сьозлерим
.  C        D        Em
    Санадър, санадър я Раб. //

[V1]
.Em
  Тоза топраа серилдим
.Am
  Ичим ерийор кедерден
.C        D      Em
  Гарибим бу дюняда.

[C2]
.     Em
   //  Бен садакат йолуну сечтим
.  Am
    Хюкюмлерини уйгун гьордюм
.  C               D         Em
    Сьозюн уярънджа яшам вер бана //

[C3]
.      Em
   // Ичимден бир сес дуйдум
.  Am
    Йюзюмю ара деди бана
.  C      D           Em
    Я Раб йюзюню аръйорум //</lyrics>
<title>Санадър Бютюн ЬОвгюлерим RT45</title>
</song>