<?xml version="1.0" encoding="UTF-8"?><song><title>нерелере бен гездим</title>
<lyrics>[V1]
 // Нерелере бен гездим
 башъма чаре булмадъм //

[V2]
 // Оламам, оламам Аллах'ъм
 Ани сенсиз беним бабаджъм //

[V3]
 // Бен Аллах'ъм хастайъм
 Сенде Аллах'ъм умудум //

[V4]
 // Докторлара бен гездим
 Шифа Аллах'ъм булмадъм //

[V5]
 // Кьойден кьое бен гездим
 Шифа Аллах'ъм булмадъм //

[V6]
 // Бен Аллах'ъм кимсесиз
 Бракма бени сен ялниз //</lyrics>
</song>