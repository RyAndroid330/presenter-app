<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>62</hymn_number>
<author>Мустафа Абидов</author>
<lyrics>[C1]
.  Em  Am             Em
    Дюня'нън курулушундан
.  Am          Em
   Ваат едилен Иса
.     Am            Em
   // Инсанлара дорулуу
.  C   D   Em
   ЬОретен Иса //

[C2]
.  Am           Em
   Сен курбан олдун
.  Am             Em
   Хич аъзънъ ачмадан
.     Am          Em
   // Беним йериме Сен
.  C    D      Em
   Голготая гиттин //

[C3]
.  Am                 Em
   Чармъхта яшам битмеди
.  Am                 Em
   Танръ Месих'и дирилти
.     Am             Em
   // Яшамъм Сенин елинде
.  C       D         Em
   Сен Дирисин Иса Раб'бим //</lyrics>
<key>Em</key>
<title>Ваат Едилен Иса BG62</title>
</song>