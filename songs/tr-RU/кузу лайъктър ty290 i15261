<?xml version="1.0" encoding="UTF-8"?><song><title>Кузу Лайъктър TY290</title>
<lyrics>[V1]
 //  Кузу лайъктър,  //
 Боазланмъш кузу
 Лайъктър!
 Алмая кудрети ве сервети ве хикмети
 Ве куввети ве хюрмети
 Ве иззети, берекети
 Кузу лайъктър,
 Боазланмъш кузу.</lyrics>
<hymn_number>290</hymn_number>
</song>