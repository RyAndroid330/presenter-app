<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>162</hymn_number>
<author>Хилтруд Стрьохлеин</author>
<title>Раб Ийидир TÇ162</title>
<lyrics>[V1]
.D       A           D           G
 Раб ийидир, Раб ийидир, Раб ийидир,
.        D  A  D
 Раб ийидир бана!

[V2]
 /// Бени север,  /// Раб ийидир бана.
 /// ... (чоджуун адъ) север,  /// Раб ийидир она.
 /// Иса гелди,  /// Танръ'дан гелди.
 /// Севинирим,  /// Раб ийидир бана.

[V3]
 // Тешеккюрлер,  // Бени севдиин ичин тешеккюрлер!
 // Тешеккюрлер,  // Достум олдуун ичин тешеккюрлер!
 // Тешеккюрлер,  // Гьозлерими вердиин ичин тешеккюрлер!
 // Тешеккюрлер,  // Гьоребилдиим ичин тешеккюрлер!

[V4]
 ..... (Кендиниз де башка сьозлерле йени къталар япабилирсиниз.)</lyrics>
<key>D</key>
</song>