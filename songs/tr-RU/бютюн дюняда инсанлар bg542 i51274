<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Бютюн дюняда инсанлар,
 Аллахъ беклийорлар.
 Аллахъ беклийорлар,
 Иман етсинлер. //

[C1]
   Шюкюр, шюкюр она,
   Шюкюр, шюкюр она,
   Шюкюр, шюкюр Аллаха,
   Иса Месихе.

[V2]
 // Иса Месих гелди,
 Ону оклан вурдулар,
 Ону оклан вурдулар,
 Канънъ дьоктюлер. //

[V3]
 // Люзгярлар еседжек,
 Иса месих геледжек,
 Инсанлар титрейеджек,
 Дуа едеджек. //</lyrics>
<title>Бютюн дюняда инсанлар BG542</title>
<hymn_number>542</hymn_number>
</song>