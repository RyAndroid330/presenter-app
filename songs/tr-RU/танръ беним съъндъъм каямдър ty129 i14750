<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>129</hymn_number>
<lyrics>[V1]
 //  Танръ беним съъндъъм каямдър,
 Калканъмдър, кувветимдир, Раббимдир.  //

[V2]
 //  Йюксек кулем, куртаръджъ пашамдър,
 Севинджимдир, умудумдур, Танръмдър.  //</lyrics>
<title>Танръ Беним Съъндъъм Каямдър TY129</title>
</song>