<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.   Dm            Gm    Dm
 // Хич бир шейде кайгъ чекмейин, //
.Gm              A7      Dm
 Факат хер шейде истеклериниз
.Gm             Dm
 Танръ'я дуа ве ялваръшла
.   (Dm)     A7  Dm
 // Шюкранла билдирилсин! //</lyrics>
<title>Хичбир Шейде Кайгъ Чекмейин TY285</title>
<hymn_number>285</hymn_number>
<author>Пекка Карванен</author>
</song>