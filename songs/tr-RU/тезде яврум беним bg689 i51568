<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Тезде яврум беним,
 Тезде геледжейим бен
 Гьостерейим сизе,
 Беним севинджими. //

[C1]
   ЬОрен сен юзюлесен,
   ЬОрен сен аалаясан,
   ЬОрен сен ташъясан
   Куртаръджъм гиби.

[C2]
   // Яра илачлаяджам,
   Вереджем теселли..
   Гьостерейим сизе
   Беним севинджими. //

[C3]
   // Кимлер юзюлюрсе,
   Сьойлесинлер бана.
   Онлар сьойлесинлер,
   Бен шифалаяджам. //

[C4]
   // Чок аз вакът калдъ,
   Иса геледжек.
   О топласън бизи
   Аллахън янъна. //</lyrics>
<title>Тезде яврум беним BG689</title>
<hymn_number>689</hymn_number>
</song>