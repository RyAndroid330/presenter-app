<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>124</hymn_number>
<title>Тюм Калбинле TÇ124</title>
<key>C</key>
<lyrics>[C1]
.  G         C   G      C
   Тюм калбинле, (калбинле)
.            G     C   G
   Тюм джанънла (джанънла)
   Тюм гюджюнле (гюджюнле)
.           C     G       C
   Раббини сев! (Раббини сев!)
.                        C7
   Бютюн калбинле, джанънла,
.            F          Dm
   Бютюн гюджюнле, аклънла
.           C        G           C
   Раббини бютюн хаятън бойунджа сев!
.  C7     F           Em A7
   Хер заман, хер йерде__
.      Dm G     C
   Раббим  бенимле.
.       D     Am     D
   Хер гюн бени коруйор.
.         G
   О'ну севийорум.

[C2]
   ()</lyrics>
</song>