<?xml version="1.0" encoding="UTF-8"?><song><author>Юмит Токгьоз</author>
<hymn_number>76</hymn_number>
<title>Сана Яклашъръз RT76</title>
<lyrics>[V1]
.        Em
 // Сана яклашъръз
.     Bm
 ЬОнюнде алчалъръз
.    Am
 Гюнахъмъздан дьонер
.     C    B7
 Йюзюню араръз //

[P1]
.        Am      Bm
   Сесимизи ишит бизи аффет
.        F          B7
   Сесимизи ишит ве бизе шифа вер

[C1]
.      Em
   Есенлиин гелсин
.      C
   Севгин дьокюлсюн
.        D        Bm      Em
   Куртулушун аксън юлкемизе
.      Em
   Мюжден дуйулсун
.        C
   Йюреклер ачълсън
.    D          Bm       Em
   Адън йюджелсин юлкемизде

[B1]
.          Am       D
   // Адън уруна я Раб
.  Bm          Em
    Сесимизи ишит
.  C          Am
    Дорулуумуздан деил
.  B7
    Лютфундан дилийоруз! //</lyrics>
<key>G</key>
<aka>Есенлиин Гелсин</aka>
</song>