<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Беним РАБ'бим бана йетер.
 Нейлейим джиханъ. //
 // Терк етмем Иса'йъ,
 Верселер дюняйъ. //

[V2]
 // Беним пайъм Раб Иса'дър.
 Ен бюйюк кâръмдър. //
 // Калсам да хеп ялнъз,
 Иса'м янъмдадър. //

[V3]
 // Беним РАБ'бим гювенилир.
 Сьозлери йок олмаз. //
 // О'на инананлар,
 Асла махволмазлар. //</lyrics>
<title>Беним РАБ'бим бана йетер</title>
<author>Дурмуш Тюнел</author>
</song>