<?xml version="1.0" encoding="UTF-8"?><song><author>Жай Моусса-Манн</author>
<hymn_number>28</hymn_number>
<lyrics>[C1]
   // Йени бир йер йени бир гьок
   Кутсал олан йени бир кент //
   // Сюзлю олан гелин ичин
   хазърланър хич беклемеден //

[V1]
 // Гьозлеримден тюм яшларъ
 силеджектир Аллахъмъз //
 // Олмаяджак орда елем
 йок оладжак олюм кедер //

[V2]
 // Олмаяджак хидж яс орда
 йок оладжак тюм алайъшлар //
 // елем аджъ сон буладжак
 ески шейлер хеп гечеджек //

[V3]
 // Йюджеликте отуран Раб
 иманлъларла оладжак //
 // Гьоркемли ве улу Танръ
 арамъзда оладжак //</lyrics>
<title>Йени бир йер, Йени бир гьок BG28</title>
</song>