<?xml version="1.0" encoding="UTF-8"?><song><title>Гедже Гюндюз Алъйом BG12</title>
<key>Em</key>
<lyrics>[V1]
.Em     C      Dm   Em
  Гедже гюндюз алъйом
.     C    Dm    Em
 Баба сана баъръйом
.        Am      G Em
 // Дерманъмъ аръйом
.   F     Dm        Em/E/
 Ярдъм еден кимсем йок //

[C1]
.         G            Dm
   // Аллахъм Сени севийом
.  F                 Em
   Калбими Сана верийом //

[V2]
.     C      Dm    Em
 Факирдим бен факирдим
.     C   Dm     Em/E/
 Йолларъмъ билмездим
.        Am         G Em
 // Каранлъкта гезердим
.     F   Dm      Em/E/
 Баба Сени билмездим //

[V3]
 Гелин, гелин инсанлар
 Аллахъмда хаят вар
 // Дердинизе дерман вар
 Иман един инсанлар //</lyrics>
<hymn_number>12</hymn_number>
</song>