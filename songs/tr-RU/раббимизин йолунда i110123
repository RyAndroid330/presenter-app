<?xml version="1.0" encoding="UTF-8"?><song><author>Яшар Ортач, Дурмуш Тюнел</author>
<lyrics>[V1]
 // РАБ'бимизин йолунда,
 Йюрюйелим джошкуйла. //
 // Йюджелтелим адънъ,
 Рухуйла дола дола. //

[V2]
 // Севинелим бирликте,
 РАБ'бин севинджи иле. //
 // Шюкределим адъна,
 ЬОвгюлер суна суна. //

[V3]
 // Хузур верди РАБ ИСА,
 Куртулуша чаърдъ. //
 // О бизлери чок севди,
 Сонсуз яшамъ верди. //

[V4]
 // Гюнахън ичиндейкен,
 Чърпънъп дуруйоркен. //
 // Куртардъ бизи МЕСИХ,
 Баъшладъ бизлери. //</lyrics>
<title>РАБ'бимизин йолунда</title>
</song>