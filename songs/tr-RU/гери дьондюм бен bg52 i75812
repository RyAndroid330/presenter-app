<?xml version="1.0" encoding="UTF-8"?><song><author>Мустафа Абидов</author>
<hymn_number>52</hymn_number>
<aka>Кайболан Оул Гиби</aka>
<key>Cm</key>
<lyrics>[V1]
.   Em                   Am
 // Бабамдан айръ бу дюняда
. C    D           Em
 Гезердим каранлъкта
.Em                    Am
 Танръдан айръ бу дюняда
. C       D      Em
 Бен мутлу оламадъм //

[C1]
.     Em                         D
   // Гери дьондюм, гери дьондюм бен //
.  Am
   Кайболан оул гиби
.  Em
   Кайболан оул гиби
.  B                          Em (E)
   Бабамън евине гери дьондюм бен

[C2]
.  Am
   Кайболан оул гиби
.  Em
   Кайболан оул гиби
.  B                            Em
   Раббимин евине гери дьондюм бен

[V2]
.   Em                  Am
 // Дюня хеп аджъ верди бана
.C        D        Em
 Ама артък Сенинлейим
.Em                   Am
 Раб Иса севгин чок гюзел
.C          D         E
 Сенин варлъън йетер бана //</lyrics>
<title>Гери дьондюм Бен BG52</title>
</song>