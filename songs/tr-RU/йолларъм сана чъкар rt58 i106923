<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<author>Мелтем Акбаш, Жосх Парк, Галатя Килисеси</author>
<lyrics>[V1]
.G               Bm7-Bbo
 Йолларъм Сана чъкар
.Am7         Dm7 G7
 Йюреим Сана а___кар
.  C2           G/B
 Ферахтър бютюн йоллар
. Am7        F         Dsus-D
 Иманла йюрю тек яшам Исам

[C1]
.     G         Bm7-Bbo
   Раббим тек калем
.  Am7         Dm7-G7
   сънаъм гювенджем
.     C2    G/B Gdim
   йоргун йюреимде
.   Am7  Dsus  G
   шифам тек Рабде

[V2]
.C2          G/B
 уян ач гьозюню
.     Am7    D      G
 каранлъктан калкда гел
.     C2      G/B
 айдънлък чок якън
.   Am7        F        Dsus-D
 сенде кош гел Раб сенинле

[C2]
.     G         Bm7-Bbo
   Раббим тек калем
.  Am7         Dm7-G7
   сънаъм гювенджем
.     C2    G/B Gdim
   йоргун йюреимде
.   Am7  Dsus  G
   шифам тек Рабде</lyrics>
<key>G</key>
<title>Йолларъм Сана Чъкар RT58</title>
</song>