<?xml version="1.0" encoding="UTF-8"?><song><key>Em</key>
<lyrics>[V1]
.Em
 // Келамън деер йюреиме //
.Am                C
 // Дилим лал олур дизим чьокер
.D          Em
 Еилирим хюрметимден //

[V2]
.   Em
 // Севдан бир атештир санки //
.   Am            C
 // Якар кор едер джиерими
.D           Em
 Кюле чевирирди бени //

[V3]
.   Em
 // Джемалини гьордююмде //
.   Am            C
 // Хайран олурум гюзеллиине
.D               Em
 Гьозлерим далар хейбетине //

[V4]
.   Em
 // Я Раб сенин варлъънда //
.   Am           C
 // Яшам булурум сенин рухунда
.D               Em
 Гьозлерим бакар Семâя //</lyrics>
<aka>Келамън деер йюреиме</aka>
<title>Дилим лал олур RT116</title>
<author>ЬОзгюр Тунч</author>
<hymn_number>116</hymn_number>
</song>