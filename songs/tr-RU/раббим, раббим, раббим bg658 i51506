<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>658</hymn_number>
<title>Раббим, Раббим, Раббим BG658</title>
<lyrics>[C1]
   // Раббим, Раббим, Раббим
   Сендедир куртулуш. //
   // Гьокте йълдъзлар янаджак,
   Ебеди атеш оладжак. //
   // Йерде качаджак джанлар,
   ЬОлюм чарчабук геледжек. //</lyrics>
</song>