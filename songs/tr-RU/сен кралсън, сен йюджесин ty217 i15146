<?xml version="1.0" encoding="UTF-8"?><song><author>Анталялъ Селахаттин</author>
<hymn_number>217</hymn_number>
<title>Сен Кралсън, Сен Йюджесин TY217</title>
<lyrics>[V1]
 //  Сен Кралсън, сен йюджесин,
 Раббим ве Куртаръджъмсън.  //
 //  Капалъ олан калбими
 Сана ачан, Исам сенсин.  //

[V2]
 //  Сен Кралсън, сен йюджесин,
 Раббим ве Куртаръджъмсън.  //
 //  Кутсал Рухунла долдуруп
 Бени йюкселтен, Исам сенсин.  //

[V3]
 //  Сен Кралсън, сен йюджесин,
 Раббим ве Куртаръджъмсън.  //
 //  Сен яшамсън, сен герчексин,
 Екмеим, дири суйумсун.  //

[V4]
 //  Сен Кралсън, сен йюджесин,
 Раббим ве Куртаръджъмсън.  //
 //  Тапънъръм, тапънъръм,
 Раб Исам, сана тапънъръм.  //</lyrics>
</song>