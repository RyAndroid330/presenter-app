<?xml version="1.0" encoding="UTF-8"?><song><title>Бърак хаятъ ач калбини</title>
<lyrics>[V1]
 // Брак хаятъ ач калбини йюрю севгийе дору //
 // Бърак гечен шейлери йюрю севене дору //
 // Беним арзум истеим сени гьонюл баъмдан //
 // Сонсуза кадар тутмак севгимин куджаънда //

[V2]
 // Гюнеш, йълдъз, ай чюрюр фани дюня йок олур //
 // Калк севдиим ей джанъм саръл сени севене //
 // Беним арзум истеим сени гьонюл баъмдан //
 // Сонсуза кадар тутмак севгимин куджаънда //

[V3]
 // Дениз акар денизе долашарак йолунда //
 // Атеш арар гюнсеши бирлешир кайнаънда //
 // Беним арзум истеим сени гьонюл баъмдан //
 // Сонсуза кадар тутмак севгимин куджаънда //</lyrics>
</song>