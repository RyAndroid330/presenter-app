<?xml version="1.0" encoding="UTF-8"?><song><title>Вердин бана куртулуш BG546</title>
<lyrics>[V1]
 // Вердин бана куртулуш,
 Ебеди хаятънъ.
 Есенлик йюрейиме гелди.
 Йюджелтелим Иса'йъ. //

[C1]
   Месих'им, Месих'им,
   Кахръмъ сен ал беним.
   Месих'им, Месих'им,
   Дертлерими сен дорулт.

[V2]
 // Саалам инанч яп бени.
 Бу беденде гюнах япмайъм.
 Къзгънлък, сьовмек олмасън.
 Ишлейесин хер гюн бенимле. //

[V3]
 // Иса'нън севгисинден вер,
 Севейим кардешлерими.
 Олалъм хепсимиз берабер.
 Онун йолунда йюрюйелим. //</lyrics>
<hymn_number>546</hymn_number>
</song>