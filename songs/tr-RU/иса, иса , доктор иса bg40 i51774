<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>40</hymn_number>
<title>Иса, Иса , доктор Иса BG40</title>
<aka>Сен Асмасън</aka>
<lyrics>[V1]
 // Сен асмасън бизсе чубук
 бизи ордан кесип атма //
 // Хеп(биз) асмада яшаялъм
 бол бол мейвалар верелим //

[C1]
   Иса, Иса, доктор Иса
   хер хастая шифа Иса
   Иса, Иса, доктор Иса
   Йюреиме мехлем Иса

[V2]
 // Куртаръджъ Месих Иса
 дюнямъза гелдин Иса //
 // Биз (хеп)асмада яшаялъм
 бол бол мейвалар верелим //</lyrics>
</song>