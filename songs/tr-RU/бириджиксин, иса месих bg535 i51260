<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>535</hymn_number>
<title>Бириджиксин, Иса Месих BG535</title>
<lyrics>[C1]
   // Бириджиксин, Иса Месих.
   Аллахън Олу сенсин.
   Бизим гюнахларъмъз ичин,
   Герилдин сен чармъха. //

[C2]
   // Иса Раббим, сен бизи куртар,
   Шу яланджъ дюнядан,
   Бизи сенин исмин ичин,
   Чок кьотю гьорюйорлар. //

[C3]
   // Тезлерде гел, Иса Месих,
   Явруларънъ ал сен.
   Сен билирсин, ей Аллахъм,
   Бизим калплеримизи. //

[C4]
   // Аллах, нерде бен гезерсем
   Хеп сени дюшюнюйом.
   Беним аклъм хеп сендедир,
   Сьозлерини дюшюнюйом. //</lyrics>
</song>