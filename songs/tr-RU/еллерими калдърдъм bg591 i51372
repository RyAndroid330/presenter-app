<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>591</hymn_number>
<title>Еллерими калдърдъм BG591</title>
<lyrics>[V1]
 // Еллерими калдърдъм,
 Сенден истерим, Исам,
 Сана гювендим, Бабам,
 Сени беклерим, Раббим. //

[V2]
 // Гел, евладъм, гел, гел.
 Исте бенден, вереджем.
 Калбини долдураджам.
 Сана хаят вереджем. //

[V3]
 // Юзгюн дурма, яврум.
 Калптен дюшме, евладъм.
 Беним илахими сьойле.
 Беним ичин сен яша. //

[V4]
 // Сана аффеттим, яврум.
 Яшларънъ силеджем,
 Сана сабър вереджем,
 Сана дженнет ейлейеджем. //</lyrics>
</song>