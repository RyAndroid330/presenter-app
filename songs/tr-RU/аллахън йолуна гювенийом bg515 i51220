<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>515</hymn_number>
<lyrics>[V1]
 // Аллахън йолуна гювенийом,
 Исадан беклийом. //

[C1]
   // Факирлере,
   хаста оланлара
   Аллахъм сен гелдин. //
   // Сен ачтън гьозлери-
   мизи Аллах,
   Гьорелим дюняйъ. //
   // Чок юзгюнюз биз, Аллах.
   Вер изин анлатайъм. //
   // Бизим гюнахларъмъз ичин,
   Месихим, сен ьолдюн. //
   // Сен куртардън бизи Аллах,
   Каранлък дюнядан. //</lyrics>
<title>Аллахън йолуна гювенийом BG515</title>
</song>