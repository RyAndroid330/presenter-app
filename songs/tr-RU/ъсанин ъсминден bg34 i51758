<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>34</hymn_number>
<aka>Дурма каршъмда</aka>
<lyrics>[V1]
 // Дурма каршъмда
 чюнкю иса бенимледир
 Бакма ябанджъ гиби
 чюнкю иса бенимледир //

[V2]
 // Иса'нън исминден,
 Иса'нън исминден
 Иса'нън исминден
 дюня бизи йенемейеджек //</lyrics>
<title>Ъсанин Ъсминден BG34</title>
</song>