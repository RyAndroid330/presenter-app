<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>527</hymn_number>
<lyrics>[V1]
 // Бен сенин аклънла
 йюрюйом, Иса.
 Бен сенин аклънла
 гьорюйом, Иса.
 Бен сенин аклънла
 яшаяйъм, Иса.
 Вер Раббим, вер. //

[V2]
 // Дири суйунла
 суладън сен бени.
 Вергилеринле
 гелдин сен бана.
 Инджилинле дойурдун
 бени, Иса.
 Вер Раббим, вер. //

[V3]
 // Сен беним аклъм
 олдун, Иса.
 Сен беним фикримде
 олдун, Иса.
 Сен беним хаятъм
 олдун, Иса.
 Вер Раббим, вер. //

[V4]
 // Геджелери сен кору
 бени, Иса.
 Гюндюзлейин сен ол
 бенимле, Иса.
 Севиндир хер вакът
 сен бени, Иса.
 Вер Раббим, вер. //

[V5]
 // Вер бана сабърънъ
 сен, Иса.
 Тут бени иманда
 сен, Иса.
 Бул бизи дуада
 сен, Иса.
 Вер Раббим, вер. //</lyrics>
<title>Бен сенин аклънла BG527</title>
</song>