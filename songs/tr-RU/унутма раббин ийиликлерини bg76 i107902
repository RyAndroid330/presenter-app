<?xml version="1.0" encoding="UTF-8"?><song><title>Унутма Раб'бин Ийиликлерини BG76</title>
<aka>Сен Гювен Раб'бине</aka>
<key>Am</key>
<lyrics>[V1]
.   Am        F
 // Сен Гювен Раббине
.G        Am
 Хич кайгъланма
.Am        F
 Одур сана бакан
.G          Am
 Ихтияджъ билен //

[C1]
.     Am         F             G
   // Унутма Раббин ийиликлерини
.  G       Em
   Хатърла яптъкларънъ
.  F            G       Am
   Сакън унутма шюкредесин //

[V2]
 // Сен гювен Раббине
 Сана кимсе докунмаз
 Хич бир шей олмаз
 Сени коруян Рабдир //

[V3]
 // Сен гювен Раббине
 Са сола бакма
 Раб йолунда йюрю
 Месих Дженнет сана //</lyrics>
<author>Мустафа Абидов</author>
<hymn_number>76</hymn_number>
</song>