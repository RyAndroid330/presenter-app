<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>264</hymn_number>
<author>Али Язар</author>
<title>Касъргая Тутулмуш TY264</title>
<lyrics>[C1]
   //  Касъргая тутулмуш
   Ей теселли булмамъш,
   Гьок якутларъ иле
   Атъладжак темелин.  //

[V1]
 //  Дорулукла донанъп
 Коркун хич олмаяджак.  //
 //  Теселли оладжаксън,
 Куртулуш буладжаксън.  //

[V2]
 //  Далар йеринден калкар,
 Тепелер де сарсълър.  //
 //  Беним тюм инайетим
 Юзеринден хич калкмаз.  //

[V3]
 //  Есенлик сундум сана,
 Вердиим сьоз сарсълмаз.  //
 //  Сана мерхамет еттим,
 Инайетими дьоктюм.  //</lyrics>
</song>