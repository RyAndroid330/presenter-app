<?xml version="1.0" encoding="UTF-8"?><song><title>Йийорлар, ичийорлар BG612</title>
<lyrics>[C1]
   // Йийорлар, ичийорлар,
   Гюнах ишлейорлар,
   Иса'нън исмини
   Истемийорлар. //

[C2]
   // Вер Аллахъм, вер бана,
   Иман севги вер бана,
   Кьойден кьойе гезейим,
   Исмини бен ьовейим. //

[C3]
   // Иса Месих геледжек,
   Бу каранлък дюнядан
   Бизи алъп гидеджек,
   Бизе дженнет вереджек. //

[C4]
   // Иман един Иса'я.
   Чюнкю бир гюн геледжек,
   Инанларъ аладжак,
   Имансъзлар янаджак. //</lyrics>
<hymn_number>612</hymn_number>
</song>