<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>66</hymn_number>
<title>Иса Къям Етти ЬОлюлерден BG66</title>
<lyrics>[V1]
 // Кач киши бу Йерйюзюнде яшъйолар кендилерине Йейолар ичийолар Исайъ истемийолар //

[C1]
   // Иса къям етти ьолюлерден инанъйонму сен буна еер инанмасан Иса'я гидеджексин джехендеме
   Даха вакит варкен бу йерде кабул ет сен Иса'йъ //

[V2]
 // Инанън сиз Иса'я чюнкю ондадър куртулуш гювенин сиз Иса'я о сизи куртараджак //

[C2]
   // Иса къям етти ьолюлерден инанъйон му сен буна?
   Еер инанмасан Иса'я гидеджексин джехендеме
   Даха вакит варкен бу йерде кабул ет сен Иса'йъ //

[V3]
 // Гел бана сен гел яврум чюнкю бендедир куртулуш чюнкю тез бен геледжем алъп сизи гидеджем //

[C3]
   // Иса къям етти ьолюлерден инанъйон му сен буна
   еер инанърсан Иса'я гидеджексин Дженнете
   Даха вакит варкен бу йерде кабул ет сен Иса'йъ //</lyrics>
</song>