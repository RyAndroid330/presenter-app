<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>87</hymn_number>
<author>Парусх Христов</author>
<title>Йъка Бени Иса Дири Суйунла BG87</title>
<lyrics>[V1]
 // Раббим Иса Сана дуа едийорум (бен)
 Раббим Иса Сени давет едийорум
 Мерхаметин долдурсун бени
 ешсиз севгинле ве сабрънла //

[C1]
   // Йъка бени Иса дири суйунла
   Йъка бени Иса канънла
   Шюкюр едерим бен сана Хамдедерим Иса //
   Йъка бени Иса дири суйунла

[V2]
 // Раббим Иса незаман геледжексин?
 Аласън бени бу дюнядан
 Гьотюресин дженнетине
 Бенде орда севинейим //</lyrics>
</song>