<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>640</hymn_number>
<lyrics>[V1]
 // Не мутлу рухта йоксул оланлара, //
 // Гьоклерин егеменлийи онларъндър. //

[V2]
 // Не мутлу, не мутлу аалаянлара, //
 // Хепси онлар теселли едиледжеклер. //

[V3]
 // Не мутлу йумушак хуйлу оланлара, //
 // Онлар йерйюзюню мирас аладжаклар. //

[V4]
 // Не мутлу дорулуа аджъканлара, //
 // Чюнкю онлар дойуруладжаклар. //

[V5]
 // Не мутлу мерхаметли оланлара, //
 // Онлара да мерхамет едиледжек. //

[V6]
 // Не мутлу йюрейи темиз оланлара, //
 // Чюнкю онлар Танръ'йъ гьореджеклер. //

[V7]
 // Не мутлу баръшъ гетиренлере, //
 // Онлар Танръ евлатларъ чаръладжак. //

[V8]
 // Не мутлу Танръ ичин чеки чекенлер, //
 // Гьоклерин егеменлии онларъндър. //</lyrics>
<title>Не мутлу рухта йоксул оланлара BG640</title>
</song>