<?xml version="1.0" encoding="UTF-8"?><song><title>Голготая Гьотюрюлдю Раббимиз</title>
<lyrics>[V1]
 // Голготая Гьотюрюлдю Раббимиз
 Бизим ичин Камчъландъ Тюкюрюлдю //

[V2]
 // Раббим Ъса Зулюм гьорен
 Аджъ чекен
 Бизим ичин Курбан гиден
 Аллахъмъз Ъса //

[V3]
 // ЬОрнек алалъм Кардешлер Раббими
 Баръш ичинде Яшалъм ону ЬОвелим //</lyrics>
<author>Адил Яшар</author>
</song>