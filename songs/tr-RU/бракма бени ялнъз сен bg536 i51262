<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>536</hymn_number>
<title>Бракма бени ялнъз сен BG536</title>
<lyrics>[V1]
 // Бракма бени ялнъз сен.
 Сана гювенийом бен. //

[C1]
   // Раббим, Раббим,
   Раббим'де куртулуш. //

[C2]
   // Гедже гюндюз баъръйом,
   Сенден, Аллахъм, беклийом. //

[C3]
   // Еллерими калдъръйом,
   Бен сана ялваръйом. //

[C4]
   // Сана авуч ачанлар,
   Дженнети алажаклар. //

[C5]
   // Исам сени севийом,
   Сенден имдат беклийом. //</lyrics>
</song>