<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>82</hymn_number>
<author>Мустафа Абидов</author>
<title>Я Раб Гюджюм Сенсин BG82</title>
<lyrics>[V1]
.   Em          F   Dm     G F Em
 // Билийорум я Раб гюджюм Сенсин
.Em          F  Dm  G      F    Em
 Бени куджаънда ташъйорсун Месих'им. //
.Em           Am(Am G F) Dm       Em
 Еллеринин есерини  бър__акмадън Месих'им.
.Em           Am(Am G F)   Dm     Em
 Еллеринин есерини  терк етмедън Месих'им.

[C1]
.     Em
   // Сенсин Танръ япарсън
.  G
   Сенсин Раб бакарсън
.  F        Dm
   Сенсин Месих северсин
.  F  Dm Em
   А__мин //

[V2]
 // Йоклуун я Раб курак топрак гиби
 Варлъън я Раб дженнеттир бана //
 Беним ичин савашърсън казанъръм Месих'им
 Беним ичин савашърсън яшам таджънъ верирсин</lyrics>
<key>Em</key>
</song>