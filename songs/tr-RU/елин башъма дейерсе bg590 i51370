<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>590</hymn_number>
<lyrics>[V1]
 // Елин башъма дейерсе,
 Шифаларсън, Аллахъм.
 Севийорум сени бен
 Чок темиз бир калбимле. //

[C1]
   // Билийом сен,
   Аллахъм,
   Хер дерде сен
   дермансън.
   Билийом сен,
   йюдже Танръм,
   Хер хастанън
   иладжъсън. //

[V2]
 // Сана Исам, ялваръйом,
 Сенден дилийорум ярдъм.
 Кутсалла кардашларъ
 Ве къзкардашларъмъ. //</lyrics>
<title>Елин башъма дейерсе BG590</title>
</song>