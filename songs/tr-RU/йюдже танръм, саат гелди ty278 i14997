<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Йюдже Танръм, саат гелди,
 Шимди сен Олуну йюджелт.
 Оул да сени йюджелтсин,
 Тюм дюня йеткини гьорсюн.  //
 //  Вердиин бу инсанлара
 Сонсуз яшамъ да версин.
 Ей Аллахъм, вакит гелди,
 Шимди сен Олуну йюджелт.  //

[V2]
 //  Сонсуз яшам да шудур ки,
 Садедже герчек Танръ'йъ,
 Гьондердиин Раб Месих'и
 Кабул едип де билсинлер.  //
 //  Бана вердиин тюм иши
 Башардъм бен йерйюзюнде.
 Гьостердим, Танръм, адънъ
 Дюняда сечтиклерине.  //

[V3]
 //  Бана вердиин сьозлерин
 Тюмюню онлара вердим.
 Онлар сенден гелдиими
 Билерек иман еттилер.  //
 //  Танръм, шимди ялваръръм бен
 Иман еденлер ичин,
 Онларъ адънла кору,
 Бизим гиби бир олсунлар.  //

[V4]
 //  Беним севинджим онларда
 Хер заман Раб, тамам олсун.
 Бен бу дюнядан деилим,
 Онлар да дюнядан деил.  //
 //  Онлар ичин бен кендими
 Кутсуйорум, йюдже Танръм.
 Онларъ герчекле кутса,
 ЬОйле ки тюмю бир олсун.  //

[V5]
 //  Сен бендесин, бен де сенде,
 Онлар да бизде олсунлар.
 Биз бир олдуумуз гиби
 Онлар да там бир олсунлар.  //
 //  Бютюн дюня буну гьорсюн,
 Бу неденле иман етсин.
 Бен онларда, сен де бенде,
 Тамамланмъш олсунлар, Раб.  //</lyrics>
<title>Йюдже Танръм, Саат Гелди TY278</title>
<hymn_number>278</hymn_number>
<author>Али Язар</author>
</song>