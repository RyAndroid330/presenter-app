<?xml version="1.0" encoding="UTF-8"?><song><author>Абрахам Минасолу</author>
<hymn_number>229</hymn_number>
<key>G</key>
<lyrics>[V1]
.    Bm
 //  Танръ куртулушумуздур
.              C
 О'на гювенеджеиз
.D             C
 Коркмаяджаъз, йълмаяджаъз
.D               Bm
 Хеп О'на бакаджаъз  //

[C1]
.  C             D             Em           Bm
   Севги Сенсин, Севги Сенсин, Севги Сенсин Раб
.  Am           Bm
   Севги Сенсин Раб

[V2]
.    Bm
 //  Не ъсътълмъш фъръндан
.                   C
 Не кюкрейен о асландан
.D             C
 Коркмаяджаъз, йълмаяджаъз
.D                Bm
 Раб'дир бизим каямъз  //

[V3]
.    Bm
 //  Не гедженин дехшетинден
.                    C
 Не гюндюз учан оклардан
.D             C
 Коркмаяджаъз, йълмаяджаъз
.D             Bm
 Раб'дир съънаъмъз  //</lyrics>
<title>Севги Сенсин RT229</title>
</song>