<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Гюзеллиин не хоштур,
 Не татлъдър бакъшън.
 Гюзеллиин гьоркемлидир,
 Сарълмак истийорум сана.  //

[V2]
 //  Раб сенин гюзеллиин
 Хич азалъп тюкенмейеджек.
 Сенин чехренин нуру
 Даима парлаяджак.  //</lyrics>
<title>Гюзеллиин Не Хоштур TY617</title>
<hymn_number>617</hymn_number>
</song>