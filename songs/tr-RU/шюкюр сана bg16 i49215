<?xml version="1.0" encoding="UTF-8"?><song><title>Шюкюр Сана BG16</title>
<lyrics>[V1]
.Em              Dm        Em
 // Иса Месих сана бен тапаръм
.Em                 Dm          Em
 Истерим сана бен чалъшайъм. //

[V2]
. Am                  Em
 Йалнъз сени бен ьовейим
. Am                   Em
 Йалнъз сана хизмет едейим.
.   Em(G)    F
 Чюнкю сен беним ичин
.    Em          Dm
 Дьовюлдюн, сьовюлдюн..
.Am         G
 Ючюнджю гюн дирилдин
.  F           Em
 Бизе яшам вердин Иса.

[V3]
.Am                 Bm         Dm         Em          FG
 // Шюкюр сана, шюкюр сана, шюкюр сана, шюкюр сана //

[V4]
.   Em         Dm            Em
 // Киме бен дердими сьойлейейим?
.Em           Dm          Em
 Гючлю иман вер бана сен Исам. //

[V5]
.Am          Em
 // Дердиме дерман ол,
.Am         Em
 Гюнахъмъ сен аффет.
.  G             Dm             Em
 Адъмъ яз дженнете Аллах'ъм. //

[V6]
.   Am           Em        Dm        Em   FG
 // Халелуя, халелуя, халелуя, халелуя //

[V7]
.       Am                 Bm         Dm         Em   FG
 // Шюкюр сана, шюкюр сана, шюкюр сана, шюкюр сана //</lyrics>
<key>Em</key>
<hymn_number>16</hymn_number>
</song>