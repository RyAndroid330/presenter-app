<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>395</hymn_number>
<title>Ишлерин - Ишлерин TY395</title>
<key>D</key>
<lyrics>[V1]
.   D
 // Ишлерин - Ишлерин
.Bm7
 Не улу, - Не улу,
.G         Em7
 Гюджюн, - Гюджюн,
.Asus4              (A)
 Не йюдже! - Не йюдже! //

[C1]
.  C   G     D
   Йюджедир ишлерин,
.  C    G    D
   Йюджедир, Раб!
.  C  G      D
   Улу ве гючлю,
.  C         Asus4 A
   Улудур, Раб.

[V2]
 // Хакимсин, - Хакимсин,
 Даима, - Даима,
 Гючле, - Гючле,
 Хакимсин! - Хакимсин! //

[V3]
 // Чюнкю Раб, - Чюнкю Раб,
 Йюджелиин, - Йюджелиин,
 Тюм йерйюзю, - Тюм йерйюзю,
 Хамд едер! - Хамд едер! //</lyrics>
</song>