<?xml version="1.0" encoding="UTF-8"?><song><author>Хилтруд Стрьохлеин</author>
<hymn_number>57</hymn_number>
<lyrics>[C1]
.    G                          D        G
   Хо-хо-хозана, хо-хо-хозана, Давут Олуна!
.    G                          D        G
   Хо-хо-хозана, хо-хо-хозана, Давут Олуна!
.                   G                       C   D G
   // Раб'бин адъйла гелене ьовгюлер олсун!  //
.              G                            D  G
   Хо-хо-хозана, хо-хо-хозана, ен йюджелерде!__
.              G                            D  G
   Хо-хо-хозана, хо-хо-хозана, ен йюджелерде!__
.  G                C    D    G
   Иса съпая бинип Кудюс'е гитти.
.  G                     C    D    G
   Херкес О'нун ардъндан баъръп деди:

[C2]
   Гийсилери сердилер, О'нун ьонюне.
   Херкес О'нун ардъндан баъръп деди:

[C3]
   Аачлардан дал кесип йола сердилер,
   Херкес О'нун ардъндан баъръп деди:

[C4]
   Чоджуклар йюксек сесле Иса'йъ ьовдю,
   Херкес О'нун ардъндан баъръп деди:

[C5]
   Есенлиин Кралъ'дър, О'ну кабул ет!
   О заман сана гелир йюджелиийле.</lyrics>
<key>G</key>
<title>Хо-хо-хозана TÇ57</title>
</song>