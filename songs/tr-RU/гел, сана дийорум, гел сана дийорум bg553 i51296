<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Гел, сана дийорум, гел сана дийорум.
 Яшамайъ гьостердин, качма бенден.
 Гюверджин гиби неден качарсън. //
 /// Иса Месих'им, Аллахъм беним. ///

[V2]
 // Бана сен узаттън татлъ еллерини.
 Куртардън бени бу каранлъктан.
 Гюверджин гиби неден качарсън ? //
 /// Иса Месих'им, Аллахъм беним. ///

[V3]
 // Гел, долдур йюрейими, северсен бени.
 Сенинле олайъм хер бир йерлерде.
 Гюверджин гиби неден качарсън ? //
 /// Иса Месих'им, Аллахъм беним. ///

[V4]
 // Чок зайъфъм бен бу беденде.
 Чьолде яшадъкча чок янмъшъм.
 Гюверджин гиби неден качарсън ? //
 /// Иса Месих'им, Аллахъм беним. ///

[V5]
 // Сен чок бекледин, тьовбе едейим.
 Тьовбе еттим, Иса'йъ севдим.
 Бана сьоз вердин гайръ качмаяджан. //
 /// Севгилим джанъм, хаятъм беним. ///</lyrics>
<title>Гел, сана дийорум, гел сана дийорум BG553</title>
<hymn_number>553</hymn_number>
</song>