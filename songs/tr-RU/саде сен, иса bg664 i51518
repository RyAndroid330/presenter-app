<?xml version="1.0" encoding="UTF-8"?><song><title>Саде сен, Иса BG664</title>
<lyrics>[V1]
 // Саде сен, Иса,
 Беним каямсън.
 О татлъ адън
 Алдъ кахръмъ. //

[C1]
   Шюкюрлер, ьовгюлер
   олсун Иса'я.
   Шюкюрлер, ьовгюлер
   Баба Танръ'я.

[C2]
   // Сана гювендим,
   Калбими вердим.
   Бени гьотюр сен
   Айдънлъъна. //

[C3]
   // Сен куллан бени,
   Кенди елинле,
   Уйгун олайъм,
   Сана ей Бабам. //

[C4]
   // Калбими пакла,
   Сенин канънла.
   Сонсуз хаят вер,
   Бютюн джанлара. //</lyrics>
<hymn_number>664</hymn_number>
</song>