<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>562</hymn_number>
<lyrics>[V1]
 // Гьоклерде учар
 Бир мелек гиби,
 Йерлерде ачар,
 Бир чичек гиби. //

[C1]
   Аллахъм, Аллахъм,
   Раббим, Бабаджъм,
   Аллахъм, Аллахъм
   Иса Раббиджим.

[V2]
 // Нерейе гитсем
 Аклъмдасън.
 Гедже гюндюз сен
 Аклъмдасън. //

[V3]
 // Сен юзелсин,
 Гюверджин гиби.
 Дилим ьотер,
 Бир бюлбюл гиби. //</lyrics>
<title>Гьоклерде учар BG562</title>
</song>