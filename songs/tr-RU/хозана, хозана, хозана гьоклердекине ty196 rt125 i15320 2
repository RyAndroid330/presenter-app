<?xml version="1.0" encoding="UTF-8"?><song><title>Хозана, Хозана, Хозана Гьоклердекине! TY196 RT125</title>
<key>G</key>
<lyrics>[C1]
.       G       D       Em          C    D
   // Хозана, хозана, хозана гьоклердекине! //

[V1]
.C       D       G
 Исмини йюкселтириз,
.C        D        G
 Калбимиз хамтла долу!
.C      D         G  D  Em
 Йюджелтилсин Раб Аллахъмъз,
.  C           D    G
 Хозана гьоклердекине!

[C2]
.     G        D        Em                C   D
   // Гьоркем, гьоркем, гьоркем Краллар Кралъна! //

[V2]
.C      D        G
 Исмини йюкселтириз,
.C        D        G
 Калбимиз хамтла долу!
.C      D         G  D  Em
 Йюджелтилсин Раб Аллахъмъз,
.C                 D   G
 Гьоркем Краллар Кралъна!</lyrics>
<author>Карл Туттле</author>
<hymn_number>196</hymn_number>
</song>