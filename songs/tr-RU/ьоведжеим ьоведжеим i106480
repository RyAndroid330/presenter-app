<?xml version="1.0" encoding="UTF-8"?><song><author>Румен Илиев</author>
<lyrics>[V1]
.verse 1
 // ЬОведжеим ьоведжеим
 Бени яратан танримъ
 ЬОведжеим ьоведжеим
 // Раб Ъсайъ йюджелтеджеим //
 //  О бени куртарди
 Джанънъ О верди
 Яшам булдум онда
 Онун ади иса //
 // ЬОведжеим ьоведжеим
 Раб Танръмъ йюджелтеджеим
 ЬОведжеим ьоведжеим
 Раб Ъсая сюкредеджегим //
 //  О бени куртарди
 Джанънъ О верди
 Яшам булдум онда
 Онун ади иса //
 //  Севинсин Танръ халкъ джошсун
 илахилерле О ну ьовсюн
 Севинсин Танръ халкъ джошсун
 илахилерле О ну ьовсюн //
 // ЬОведжеим ьоведжеим
 Раб Танръмъ йюджелтеджеим
 ЬОведжеим ьоведжеим
 Раб Ъсая сюкредеджегим</lyrics>
<title>ЬОведжеим ьоведжеим</title>
</song>