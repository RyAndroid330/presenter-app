<?xml version="1.0" encoding="UTF-8"?><song><title>Танръм Танръм</title>
<lyrics>[V1]
 // Танръм, Танръм сенден башкасъна гювенемем
 колларъна алдън бени калбимдесин сен беним //

[V2]
 // Екмеим суйум сенсин Танръм
 калбимдесин йюреимдесин //

[V3]
 // Аджъланъйор йюреим, яраланъйор беним калбим
 йъка бени канънла долдур бени Кутсал Рухунла //</lyrics>
</song>