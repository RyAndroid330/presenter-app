<?xml version="1.0" encoding="UTF-8"?><song><title>О, Раб Исам, сен бюйюксюн BG655</title>
<lyrics>[V1]
 // О, Раб Исам, сен бюйюксюн,
 Хершейи сен гьорюйорсун //

[C1]
   // О, Раб Исам, бизим ичин ьолдюн,
   Бизим ичин канънъ дьоктюн. //

[C2]
   // Канън бизи куртаръйор,
   Хасталъктан калдъръйор //

[C3]
   // Сен хаджънда джан вериркен,
   Аджъларъ сен чекеркен //

[C4]
   // Юч гюн сонра къям еттин.
   Раб Исам, сен гьоке гиттин //

[C5]
   // Вер бизе сен сабурундан.
   Вер бизе сен мерхаметинден //</lyrics>
<hymn_number>655</hymn_number>
</song>