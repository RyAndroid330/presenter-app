<?xml version="1.0" encoding="UTF-8"?><song><title>Йюзюлме</title>
<lyrics>[V1]
 // Херкез йолджу бу дюняда ,
 факирлер'де , зенгинлер'де
 ьолюм шу ан сана гелсе
 сен гьоч етмейе хазърмъсън //

[V2]
 // Йюзюлме йюзюлме
 садедже вер калбини сен Месихе
 Йюзюлме йюзюлме
 Месих ьолюмю йенди сенде йенеджексин //</lyrics>
</song>