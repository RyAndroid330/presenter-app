<?xml version="1.0" encoding="UTF-8"?><song><author>Сефер Мигдиси</author>
<title>Раббими ьоведжеим бен</title>
<lyrics>[V1]
.   Em                G
 // Раббими ьоведжеим бен
.                 Am
 Чюнкю бени о чок севди
.                G
 Чекеджеим аджъларъ
.F               Em
 Алдъ кенди юзерине //

[V2]
.   Em                   Am
 // Рабби не кадар ьовсем де
.                     G
 ЬОвгюлер йетерли гелмез
.                  F
 Беним ичин яптъкларъ
.Dm              Em
 Асла асла ьоденемез //

[V3]
.   Em                G
 // Раббими ьоведжеим бен
.                Am
 Чюнкю бана деер верди
.                    G
 Беним ьолмем герекиркен
.F                 Em
 Беним йериме о ьолдю. //</lyrics>
<key>Em</key>
</song>