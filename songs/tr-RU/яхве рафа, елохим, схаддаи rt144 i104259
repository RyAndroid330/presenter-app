<hymn_number>144</hymn_number>
<title>Яхве Рафа, Елохим, Схаддаи RT144</title>
<lyrics>[V1]
.Em
 Гьоркемли, доа юстю
.     Bm                   C
 Гюджюню хисседийоруз, бурада
.                D
 Кендини Сен Ачъкла

[C1]
.     C       D      Bm        Em
   // Яхве, Рафа, Елохим, Схаддаи,
.    C      D        Bm     Em
   Йире, Адонай Варлъън бурада //

[V2]
.Em
 // Тапънънджа Рухуну Хисседериз
.Bm
 Арайънджа Рухуну Хисседериз
.C                       D
 Якарънджа Рухуну Хисседериз //

[V3]
.Em
 // Яхве Бизе Гьорюнеджек
.D
 Йире Бизе Гьорюнеджек
.C                                    Bm
 Рафа Бизе Гьорюнеджек, Бизе Гьорюнеджек //</lyrics>
<key>Em</key>
</song>