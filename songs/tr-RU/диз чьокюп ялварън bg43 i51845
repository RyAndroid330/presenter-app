<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>43</hymn_number>
<lyrics>[V1]
 // Диз чьокюп ялварън
 ел калдърън алайън
 Чиленизи гьорюйорум
 чекинизи билийорум //

[C1]
   // Бен геледжем топлайъм
   ен гюзел тохумларъ
   дикенлери айъраджам
   дюнянън сону олунджа //

[V2]
 // Ей Аллахъм, беним Аллахъм
 хер заман Сени арайъм
 Рухум Сана сусамъш
 Джанъм Сени ьозлер //</lyrics>
<title>Диз Чьокюп Ялварън BG43</title>
</song>