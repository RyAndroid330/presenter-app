<?xml version="1.0" encoding="UTF-8"?><song><title>Раб Гьостерди, - Раб Гьостерди TY462</title>
<lyrics>[V1]
 //  Раб гьостерди, - Раб гьостерди,
 Ей, адам - Ей, адам
 Ийи оланъ сана билдирди.  //

[V2]
 //  Доруйу япмайъ, - Доруйу япмайъ,
 Лютфуну севмейи - Лютфуну севмейи,
 Танрънла алчак гьонюллю йюрюмейи.  //</lyrics>
<hymn_number>462</hymn_number>
</song>