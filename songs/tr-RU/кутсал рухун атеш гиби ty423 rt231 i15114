<?xml version="1.0" encoding="UTF-8"?><song><title>Кутсал Рух'ун Атеш Гиби TY423 RT231</title>
<lyrics>[V1]
.    Em
 //   Кутсал Рух'ун атеш гиби
.D           Em
  Якъйор тюм йюреими.  //
.    G
 //   Яксън Кутсал Рух'ун яксън,
.Am           Em
  Даласън тюм бенлиими  //

[V2]
.Am
  Варлъъм варлъънла долсун,
.D            Em
  Донатсън Кутсал Рух бени
.Am
  Варлъъм варлъънла долсун
.D                      Em
  Донатсън Кутсал Рух бени

[V3]
.       D       Em      D             Em
 //  Кутсал, Кутсал, Кутсал Рух, як бени!  //</lyrics>
<key>G</key>
<hymn_number>423</hymn_number>
<author>Гюркан Чамсун, Азери Аноним</author>
</song>