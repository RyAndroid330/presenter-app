<?xml version="1.0" encoding="UTF-8"?><song><author>Онур Йьош</author>
<hymn_number>528</hymn_number>
<lyrics>[V1]
 // Йени бир езги сьойлейин.
 Йени бир езги сьойлейин.
 Нефеси оланлар сьойлесин.
 Йени бир езги сьойлейин.  //

[V2]
 // Чюнкю Раб улудур, О адил Олан'дър.
 О езги сьойленмейе лайък Танръ'дър.  //

[V3]
 // Чюнкю Раб ийидир, севгиси сонсуздур.
 О алкъшланмая лайък Танръ'дър.  //</lyrics>
<title>Йени Бир Езги Сьойлейин TY528</title>
</song>