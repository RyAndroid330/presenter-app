<?xml version="1.0" encoding="UTF-8"?><song><author>ЬОзгюр Тунч</author>
<key>Bm</key>
<lyrics>[V1]
.   Am
 // Неден юзгюнсюн ей гьонлюм
.G
 Неден ичим хузурсуз бугюн
.Dm         F       G  Am
 Сен Раб'бе умудуну бала //
.   F           G         Am
 // Чюнкю ьовгю сунаръм она //

[V2]
.   Am
 // Ей джанъм сен Раб'де хузур бул
.G
 Чюнкю умудум О'нда саклъдър
.Dm           F      G        Am
 Джанъм ялнъз Раб'де хузур булур //
.   F            G             Am
 // Куртулушумун йолу ондан гелир //

[V3]
.   Am
 // Сенин севгин яшамдан ийидир
.G
 Дудакларъм хеп сени йюджелтир
.Dm              F          G         Am
 ЬОмрюм бойунджа ьовгюлер сунаджаъм сана //
.   F            G               Am
 // Еллерими хеп калдъраджаъм адъна //</lyrics>
<title>Раб'де Хузур Бул</title>
<capo>2</capo>
</song>