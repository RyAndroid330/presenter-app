<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Танръ'нън сечтиклерини
 Ким сучлаябилир?  //
 // Танръ'нън та кендиси
 Бизи хаклъ чъкарър.  //

[V2]
 // Олуну есиргемеди,
 Та ьолюме верди.  //
 // Бьойле бизи куртардъ,
 Бизи не кадар севди.  //

[V3]
 // Раб Иса ьолюп дирилди,
 Бабасъна гитти.  //
 // Сатън алдъм дер Месих
 Сенин сечтиклерини.  //</lyrics>
<title>Танръ'нън Сечтиклерини TY149</title>
<hymn_number>149</hymn_number>
<author>Али Язар</author>
</song>