<?xml version="1.0" encoding="UTF-8"?><song><title>Бизи Кендинден Чок Севдин BG42</title>
<key>Am</key>
<lyrics>[V1]
.   Am         G        Em            F
 // Я Раб Исам Сен бизи кендинден чок севдин
.Am            G    Em        F
 Кендини бизим ичин феда еттин я Раб //

[C1]
.     Am        G        Em      F
   // Сен бизим Танръмъз, Рабимиз, Кралъмъз
.  Am            G     Em         F
   Шимди ьонунде еилип Сана гелир тапаръз //</lyrics>
<author>Аско Коче, Джемил Осман</author>
<hymn_number>42</hymn_number>
</song>