<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Месих Иса геледжек, бизе шифа вереджек //

[C1]
   // О мубарек Месих Иса.
   Йюзю, гьозю нурлуйду //

[C2]
   // Месих Иса геледжек,
   Бизи алъп гидеджек //

[C3]
   // Месих Иса геледжек, Бизи гьоклере
   теслим едеджек //

[C4]
   // Месих Иса бу муйду ?
   Гьоктеки мелеклер дуйду //</lyrics>
<title>Месих Иса геледжек, бизе шифа вереджек BG634</title>
<hymn_number>634</hymn_number>
</song>