<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Далар вар олмадан
 дюняйъ яратмадан
 ьонджеден сонсуза дек
 тек Аллах сенсин //

[C1]
   // Бунун ичин гюнлерими
   саймая бана ьорет Аллахъм
   Хикмет единейим //

[V2]
 // Ен гюзел йъллар да
 кедерле гечийор
 Чарчабук битийоруз
 учуп гидийоруз //

[V3]
 // Раб Аллахъмъз
 хошнут калсън
 елимизин яптъъ
 боша чъкмасън //</lyrics>
<title>Далар вар олмадан</title>
<author>Денджиан</author>
</song>