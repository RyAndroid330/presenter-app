<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Диз чьокюп ялварън,
 Ел калдърън, аалайън.
 // Чекинизи гьорюйорум
 Чиленизи язъйорум. //

[V2]
 Сизин ичин, яврум,
 Бен канъмъ дьоктюм.
 // Гюнахларънъзъ бен
 Чилейлен ташъдъм. //

[V3]
 Йълдъзлар дюшеджек,
 Дюня биткиси оладжак.
 // Бен геледжем,
 Хепсинизи куртараджам. //

[V4]
 Сизин гюнахларънъз
 Яраларъмъ ачъйор.
 // Севги, севинджиниз де,
 Ярама мейлем олуйор. //

[V5]
 Евиме топланън,
 Ел еле тутунун.
 // Берабер сизи булайъм,
 Хепсинизи алайъм. //

[V6]
 Уйкудан уянън,
 Айдънлъкта беклейин.
 // Рюзгярлан бен геледжем,
 Дженнете учураджам. //</lyrics>
<title>Диз чьокюп ялварън BG578</title>
<hymn_number>578</hymn_number>
</song>