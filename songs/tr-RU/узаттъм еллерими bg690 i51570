<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Узаттъм еллерими
 Бен Аллахъма. //
 // Аладжак Раббим бени
 Онун янъна. //

[V2]
 // Даянън явруларъм,
 Дайма даянън. //
 // Даянън кузуларъм,
 Дайма даянън. //

[V3]
 // Артък вакът гелийор,
 Аладжам сизи . //
 // Кушлар гиби учаджанъз
 Беним янъма. //

[V4]
 // Мелек гиби чок парлак
 Оладжаънъз. //
 // Даянън явруларъм,
 Дайма даянън. //

[V5]
 // Даянън кузуларъм,
 Дайма даянън. //
 // Даянън юмметлерим,
 Дайма даянън. //</lyrics>
<title>Узаттъм еллерими BG690</title>
<hymn_number>690</hymn_number>
</song>