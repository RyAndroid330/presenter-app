<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Хер заман бенимле, севги яшасън
 Иса Месих'ле, куртаръджъмла. //

[C1]
   // Сьойлейин илахи, сьойлейин Иса'я.
   О чалъшсън йюреклеримизде. //

[C2]
   // О гелди бу йере, сизи куртарсън,
   Ве гюнахтан азат етсин. //

[C3]
   // Гелин сизлер, бюйюклер, кючюклер,
   Йюджелтелим Иса'йъ йюрейимизле. //

[C4]
   // Шюкюр Иса'я, шюкюр Баба'я.
   Тез гелийор о йерйюзюне. //</lyrics>
<title>Хер заман бенимле, севги яшасън BG698</title>
<hymn_number>698</hymn_number>
</song>