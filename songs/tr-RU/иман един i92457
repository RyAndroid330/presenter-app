<?xml version="1.0" encoding="UTF-8"?><song><title>ИМАН ЕДИН</title>
<lyrics>[V1]
 ИМАН ЕДИН ей ИНСАНЛАР
 ИСА Месих ГЕЛЕДЖЕК
 БИЗИ БУРДАН АЛЛАДЖАК
 ДЖЕННЕТЕ ГЬОТУРЕДЖЕК

[C1]
   ОНУНЛА ОЛАДЖАЗ
   ОНУНЛА ЯШАЯДЖАЗ
   КАХЪРЛАР БИТЕДЖЕК
   СЕВИНЧЛЕ ДОЛАДЖАЗ
   ИЛАХИЛЕР СЬОЙЛЕЙЕДЖЕЗ
   ИНДЖИЛИ ДИНЛЕЙЕДЖЕЗ
   ДУАЛАР ЕДЕДЖЕЗ
   СЕВИНЧЛЕ ДОЛАДЖАиЗ</lyrics>
</song>