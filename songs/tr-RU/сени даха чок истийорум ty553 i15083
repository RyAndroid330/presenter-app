<?xml version="1.0" encoding="UTF-8"?><song><key>D</key>
<lyrics>[V1]
.   D        G    A7    D
 //  Сени даха чок истийорум  //
.           G   A   Bm
 Башка хичбир шей истемем
.        C  A    D
 Хер шейимсин, Раб Иса

[V2]
.       G
 Иса сусамъшъм
.A         G   D
 Гел ве бени долдур
.G   A   F#m   Bm
 Дюня бени курутту
.G    A      F#m Bm
  Бени татмин едемез
.Em       A   A7  D
 Тек истеим Сенсин, Раб</lyrics>
<title>Сени Даха Чок Истийорум TY553</title>
<hymn_number>553</hymn_number>
</song>