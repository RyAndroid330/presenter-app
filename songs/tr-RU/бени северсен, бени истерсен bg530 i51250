<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>530</hymn_number>
<title>Бени северсен, бени истерсен BG530</title>
<lyrics>[V1]
 // Бени северсен, бени истерсен, //
 // Беним оласън, беним оласън
 Севинчле беклерим. //

[V2]
 // Калбине бир бактъм,
 Не кадар карармъш. //
 // Беним оласън, бени буласън,
 Айдънлатаджам. //

[V3]
 // Гюнахларъна аф
 Истедин ми сен ? //
 // Гюнахларъна аф истедин ми ?
 Бен вереджем. //

[V4]
 // О, Иса Месих'им,
 Сенинле олайъм. //
 // Сенин олайъм, сени булайъм,
 Дженнете гирейим. //

[V5]
 // Бени северсен,
 Бени истерсен, //
 // Беним оласън, бени буласън,
 Дженнете гиреджен. //</lyrics>
</song>