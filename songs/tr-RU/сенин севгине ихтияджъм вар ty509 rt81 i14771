<?xml version="1.0" encoding="UTF-8"?><song><author>Даниел Гюнай, Давут Ясмин</author>
<hymn_number>509</hymn_number>
<title>Сенин Севгине Ихтияджъм Вар TY509 RT81</title>
<lyrics>[V1]
.    A     Em   G    Bm      A
 //  Сенин севгине ихтияджъм вар,
.      Em   G    Bm      A
 Сенин гюджюне ихтияджъм вар.  //

[V2]
.        Em       Cmaj7   D
 //  Рухуну дьок юзеримизе  //

[V3]
.       G         D
 //  Атешин яксън калбимизи
.  Am7       G/D-D
 Сени беклийоруз.  //</lyrics>
<key>G</key>
</song>