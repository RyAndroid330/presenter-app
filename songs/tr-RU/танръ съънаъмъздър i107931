<?xml version="1.0" encoding="UTF-8"?><song><author>Джихан ДУМАН</author>
<lyrics>[V1]
 // Не мютхиштир йюдже Раббим Иса месихим
 Са ели заферле долу танръмъз бизим
 Севинсин тюм кузуларън джошсун сенинле
 Хершейе егемен крал Раббим бизимле //

[V2]
 // Танръ съънаъмъздър гюджюмюз бизим
 Ярдъмджъм ве куртаръджъм Иса месихим
 Хеп сана ьовгюлер олсун йюджелик олсун
 Сенин севгин иманъмъз йолумуз бизим //</lyrics>
<title>Танръ съънаъмъздър</title>
</song>