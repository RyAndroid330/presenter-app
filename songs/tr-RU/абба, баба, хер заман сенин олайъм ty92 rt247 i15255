<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>92</hymn_number>
<title>Абба, Баба, Хер Заман Сенин Олайъм TY92 RT247</title>
<lyrics>[V1]
.G    C     D      G
 Абба Баба, хер заман
.C     D   G
 Сенин олайъм.
.G   C     D     G
 Яшамъм Сенин олсун,
.C      D     C G
 Хеп Сенин олсун.

[C1]
.  B      Em     B    Em
   Севгим хич кайболмасън,
.  C    Am   D
   Бени бъракма.
.  G     C     D      G
   Абба, Баба, хер заман
.  C     D    C G
   Сенин олайъм.</lyrics>
<key>Em</key>
</song>