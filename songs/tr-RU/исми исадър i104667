<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Сьозле анлатълмаз бана олан севгиси
 мутлу едер хер заман о беним калбими //
 билир о беним хер дердими
 теслим еттим бен она хер шейими

[V2]
 Бир ърмак вар ки суларъ севинч гетирир
 бир пънар вар ки сусамаз ондан иченлер
 бир йол варки ки сонсуз яшама гьотюрен
 бир капъ вар ки дженнете ачълан

[V3]
 // Исми Иса'дър
 Исми иса'дър
 Исми иса'дър о иса Месих'тир //</lyrics>
<title>Исми Иса'дър</title>
<author>Генджебай</author>
</song>