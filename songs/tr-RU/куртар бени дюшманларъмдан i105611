<?xml version="1.0" encoding="UTF-8"?><song><author>Ерен Еренулу</author>
<lyrics>[V1]
.       Am            C       G        D
 // Куртар бени дюшманларъмдан ей Танръм
.   Am             C       G           D
 Калем ол хасъмларъма каршъ йюдже Танръм //

[V2]
.       Am               C
 // Куртар бени суч ишлейенлерден
.    G                  D
 Я Раб сен гюджюм сарсълмаз калем //

[C1]
.        Am        C              G           D
   // Бенсе гюджюн ичин сабах езгилер сьойлейеджеим
.     Am          C             G          D
   Я Раб йюдже севгини севинчле диле гетиреджеим //

[B1]
.     Am             C
   // Гюджюм сенсин, Гюджюм сенсин
.  G               D
   Гюджюм сенсин , сени беклийорум Раб //</lyrics>
<key>Am</key>
<title>Куртар Бени Дюшманларъмдан</title>
</song>