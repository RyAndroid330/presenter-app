<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 //  Голгота'я гелен не гюзел йолдур: Исам!  //
 //  О йолун йолджусу, не гюзел кулдур.  //
 //  О йолу буланлар севинчле джошар. Исам!  //
 //  Чевирмезсин сен гери, гелени сана.  //
 //  Джанъм феда олсун сенин йолуна, Исам!  //
 //  Ол бенимле даима, бурада ве орада.  //
 //  ЬОмрюню вердин беним урума, Исам!  //
 //  Бен нийе вермейейим калбими сана.  //
 //  Долдур Кутсал Рухунла бени хер заман, Исам!  //
 //  Дуйсун ки хер араян Раббимиз Иса!  //</lyrics>
<title>Исам! TY312</title>
<hymn_number>312</hymn_number>
</song>