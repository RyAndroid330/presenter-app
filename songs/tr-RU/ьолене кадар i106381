<?xml version="1.0" encoding="UTF-8"?><song><author>Ахмед Музафер</author>
<lyrics>[V1]
 // Гюняхларимиз ичин о вурулду
 Фесатларъмъз ичин
 Онун йюзериме койдун //

[V2]
 Ону ювелим бойнумузун борджу
 Юведжем юведжем ЬОлене кадар

[C1]
   // ЬОленекадар Иса'йъ Севеджейим
   ЬОлене кадар Месîх'и Аллах Аллах юведжеим
   ЬОлене кадар Аллахлан оладжайим
   ЬОлене кадар ЬОлене кадар //

[V3]
 // Кайболанъ арадъ
 Гюняхларъ ташъдъ
 Кендини Курбан ададъ
 Йюдже Аллах'ън олу //

[V4]
 Ону ювелим Бьойле бир Кралъ
 Юведжем юведжем
 ЬОлене кадар</lyrics>
<title>ЬОлене Кадар</title>
</song>