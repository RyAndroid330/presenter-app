<?xml version="1.0" encoding="UTF-8"?><song><author>Грахам Кендрикк</author>
<hymn_number>16</hymn_number>
<key>C</key>
<lyrics>[V1]
.G          C        G     C G
 Раб'бин гюзеллиини гьор, (еко)
.          C          G    C Em
 Гюзел чехресине бир бак. (еко)
.                     C     Em
 Бак курбан олан кузуйа, (еко)
.                  C     Em
 Адън язълъ авджунда. (еко)
.                    G     Em
 Аджъмъз калбини делди. (еко)
.                 Cmaj7 Em
 Гурурумузун симгеси, (еко)
.   F     D  F D
 Дикенли тач.

[V2]
.G       C          G    C G
 Гюнахларъ юстлениркен, (еко)
.           C           G    C Em
 Калбинден сърф севги акар. (еко)
.                   C      Em
 Дудакларънда адъм вар, (еко)
.                   C      Em
 Джезамън йюкюню ташър. (еко)
.                     G     Em
 Бу севги бени шашърттъ. (еко)
.                     Cmaj7 Em
 Курбанъ бени хюр кълдъ. (еко)
.   F      D
 Хайат булдум!</lyrics>
<title>Раб'бин Гюзеллиини Гьор TY16</title>
</song>