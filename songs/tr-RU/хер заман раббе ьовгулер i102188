<?xml version="1.0" encoding="UTF-8"?><song><author>Дженгиз</author>
<lyrics>[V1]
 // Хер заман Раб'бе ьовгюлер
 Сунаджаъм бен //

[V2]
 // Чюнкю бени о куртардъ
 Гюнахъм'дан зайъфлъъм'дан //

[V3]
 // Карар вердим адъмларъма
 Диккат едеджеим бен //

[V4]
 // Я Раб Иса'м бундан сонра
 Бени сен куллан Раббим //

[V5]
 // Гюнахтан дюнядан узак
 Тут бени йюдже Раббим //

[V6]
 /// ЬОвгулер сунаджаъм бен
 Хер заман сана Раббим ///</lyrics>
<title>Хер заман Раббе ьовгулер</title>
</song>