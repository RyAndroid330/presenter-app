<?xml version="1.0" encoding="UTF-8"?><song><title>Бютюн Йюреимле TY603</title>
<lyrics>[V1]
 Бютюн йюреимле
 Ве бютюн гюджюмле Раб,
 Бютюн джанъмла
 Сени хеп севеджеим.

[V2]
 Бютюн йюреимле
 Ве бютюн гюджюмле Раб,
 Тюм варлъъмла
 Сени хеп севеджеим.
 //  Иса, Иса ьондже сен бени севдин.  //
 //  ЬОндже сен бени севдин.  //

[V3]
 //  Бютюн аклъмла,
 Бютюн гюджюмле,
 Сени хеп севеджеим.  //</lyrics>
<author>Армин Кноте</author>
<hymn_number>603</hymn_number>
</song>