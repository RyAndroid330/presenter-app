<?xml version="1.0" encoding="UTF-8"?><song><aka>Иса чармъхта О Голготада</aka>
<lyrics>[V1]
 // Иса чармъхта (Иса чармъхта)
 О Голготада (о голготада)
 Иса ьолдю ьолюмю йенди //

[C1]
   // Исанън канъ бу съджак севги
   Ериттиребилир бузланмъш калби //

[V2]
 // Дуйдунму кардаш? (дуйдунму къзкардаш)
 Бу съджак Севги (бу съджак севги)
 Танрънън мерхаметини //

[V3]
 // Танръ верди олуну (Танръ верди олуну)
 Дьоктю канънъ (дьоктю канънъ)
 Яшаялъм Иса Месихле //</lyrics>
<title>Исанън Канъ Бу Съджак Севги BG15</title>
<hymn_number>15</hymn_number>
</song>