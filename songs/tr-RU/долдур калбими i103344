<?xml version="1.0" encoding="UTF-8"?><song><author>Микерем Друмева</author>
<key>Bm</key>
<lyrics>[V1]
.   Bm      G         F#
 // Раб хузуруна гирмек истийорум
.Em     F#        Bm
 Раб варлъънда боулмак истийорум
.    D          B           Em
 Сенинле гьорюшмек ве Сана тапънмак
.   F#                     Bm
 Ичими Сана дьокмек истийорум. //

[V2]
.     B        B6        Em
 Бана куджаънъ ачармъсън Раб?
.     A                   D
 Бени севгинле сарармъсън Раб?
.      Bm      G         F#
 Сенин севгине мухтаджъм Раб?
.               G      F# D /C/
 Джанъмъ татмин едермисин Раб?

[V3]
.     B        B6        Em
 Бана куджаънъ ачармъсън Раб?
.     A                   D
 Бени севгинле сарармъсън Раб?
.      Bm      G         F#
 Сенин севгине мухтаджъм Раб?
.               G      F# Bm
 Джанъмъ татмин едермисин Раб?

[V4]
.     B   B6     Em
 // Джанъм Сана аджъктъ
.    A          D
 Йюреим Сана сусадъ
.    Bm     G         F#
 Варлъънла долдур калбими
.                  G      F#  D /C/
 Сенин варлъън хер шейден деерли //</lyrics>
<title>Долдур Калбими</title>
</song>