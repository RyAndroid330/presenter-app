<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>36</hymn_number>
<key>Em</key>
<lyrics>[V1]
. Emin        B
 Иса Месих ьондер,
.  B7        Emin
 ЬОнюмюзде сипер,
.   D   G      Emin
 // Хер гючлюю о анънда
.B     B7    Emin
 Хер заман йенер. //

[V2]
 Иса Месих салам,
 Сарсълмаян каям,
 // Йюреимде бютюнлешти,
 Ондан копамам. //

[V3]
 Иса Месих йюдже,
 Тапълър о гюдже.
 // Биз даима О'на тапаръз
 Гюндюз ве гедже. //

[V4]
 Иса Месих ьондер,
 ЬОнюмюзде сипер,
 // Хер гючлюю о анънда
 Хер заман йенер.  //</lyrics>
<title>Иса Месих ЬОндер TY36</title>
</song>