<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
 (Конушарак)
 // Рюзгар есийор, вувв, вувв. //
 Хъзлъ есийор, вувв, вувв, вувв, вувв.

[V2]
 // Фъртъна копуйор, вувв, вувв. //
 Кувветли артъйор, вувв, вувв, вувв, вувв.

[V3]
 Хер шей учуйор, вувв, вувв.
 Далгалар йюкселийор, фошш, фошш.
 Херкес коркуйор. Ууу, ууу, ууу, ууу!</lyrics>
<title>Рюзгар Есийор TÇ163</title>
<hymn_number>163</hymn_number>
<author>Хилтруд Стрьохлеин</author>
</song>