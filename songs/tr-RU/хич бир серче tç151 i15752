<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>151</hymn_number>
<author>Геоффрей Хардинг</author>
<title>Хич Бир Серче TÇ151</title>
<lyrics>[V1]
.F        Bb              C C7
 Хич бир серче йере дюшмез
.Bb            F                  C C7
 Гьоктеки Бабан'ън хабери олмадан.
.F        Bb               C C7
 Хич бир серче йере дюшмез.
.Bb            F                 C F
 Гьоктеки Бабан'ън хабери олмадан.

[V2]
 // Сиз кушлардан деерлисиниз.
 Гьоктеки Бабамъз сизи чок север. //

[V3]
 // Айхан* асла йере дюшмез
 Гьоктеки Бабан'ън хабери олмадан. //

[V4]
 // Сен кушлардан деерлисин,
 Гьоктеки Бабамъз сени чок север. //</lyrics>
<key>F</key>
</song>