<?xml version="1.0" encoding="UTF-8"?><song><author>Салвадор</author>
<title>Иманън бир хардал танеси гиби олса</title>
<lyrics>[V1]
 // Иманън бир хардал танеси гиби олса,
 Раб сана шуну сьойлер //
 // Далара сен, сесленип дерсен:
 Йеринден калк, денизе атъл //

[V2]
 /// Ве далар йеринден ойнар,
 Йеринден ойнар, Йеринден ойнар... ///
 Ве далар йеринден ойнар,
 Кутсал Рух'ун гюджюйле...</lyrics>
</song>