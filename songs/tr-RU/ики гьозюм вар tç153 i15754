<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>153</hymn_number>
<author>Хилтруд Стрьохлеин</author>
<key>E</key>
<lyrics>[V1]
.E                    B7
  Ики гьозюм вар, ики кулаъм вар,
.            E
 Ве тек бир бурнум вар.
.                   B7
 Ики елим вар, ики аяъм вар,
.            E
 Ве тек бир гьобеим вар.
.    B7           E
 Айръджа гюлмек ичин
.      B7        E
 Я да конушмак ичин
.           B7      E
 Танръ бана аъз верди.
.           B7    E
 Бунунла О'ну ьоверим.</lyrics>
<title>Ики Гьозюм Вар TÇ153</title>
</song>