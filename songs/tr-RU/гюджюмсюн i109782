<?xml version="1.0" encoding="UTF-8"?><song><author>Сабри Левит</author>
<title>Гюджюмсюн</title>
<lyrics>[V1]
 // Гючсюзлююмде беним гюджюмсюн
 Йюреимдеки бошлуу долдурансън
 Ихтияджъм Олан тек Танръмсън
 Сен беним куртаръджъмсън //

[V2]
 ПР // ЬОвгюлер сана йюдже Иса
.    
     Йюреими сунаръм Бен Сана
.    
     ЬОвгюлер Сана Йюдже Иса
.    
     Хаятъмъ Сунаръм бен сана //

[V3]
 // Елимден тутуп бени калдъран Танръм
.    
     Кенди чоджуун сен яптън
.    
     Мерхаметтинле бени сен куртардън
.    
     Сонсуз яшамъ Сагладън //</lyrics>
</song>