<?xml version="1.0" encoding="UTF-8"?><song><title>Иса'йла Яшъйорум бен</title>
<lyrics>[V1]
 // Иса'йла Яшъйорум бен
 Гьозюмюн яшъйла ялваръйом бен //

[V2]
 // Аллах'ъм Аллах'ъм Аллах
 Дуй сесими ялваръйом бен //

[V3]
 // Бунджа дерт яшъйор
 Беним калбимде
 Бир Атеш янъйор
 беним йюреимде //

[V4]
 // Еллерими калдърдъм Иса'я бен
 Бир ЬОксюз Явруя
 ялваръйом бен //</lyrics>
</song>