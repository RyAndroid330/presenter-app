<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Сучу Йокту, сучлу олду. //
 Лекесизди, гюнахсъздъ.
 // Йюрюйорду аджъ аджъ.
 Ташъйорду чармъхънъ. //

[V2]
 // Хор гьорюлдю, кючюмсенди. //
 Япаялнъз бъракълдъ.
 // Сучумузу О юстленди,
 ЬОлюме О бойун еди. //

[V3]
 // Чиви делди еллерини. //
 Бизим ичин дуа етти.
 // Йеримизе джанън верди.
 Хепимизи ьойле севди. //

[V4]
 // О'нун адъ Иса Месих! //
 Кутсал олан Танръ олу!
 // Халелуя Иса'я,
 Бабасънън са янънда! //</lyrics>
<title>Сучу Йокту, сучлу олду</title>
<author>Дурмуш Тюнел</author>
</song>