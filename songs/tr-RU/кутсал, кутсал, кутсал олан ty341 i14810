<?xml version="1.0" encoding="UTF-8"?><song><title>Кутсал, Кутсал, Кутсал Олан TY341</title>
<lyrics>[V1]
 //  Кутсал, кутсал, кутсал олан
 Йюдже Раббим сенсин!  //

[V2]
 //  Вар олмуш вар олан, вар оладжак олан
 Гюджю хер шейе йетен Раббим, Танръм!  //</lyrics>
<hymn_number>341</hymn_number>
<author>Наджи Ерим, Наджи Ерим, Кен Бердинг, Кен Бердинг</author>
</song>