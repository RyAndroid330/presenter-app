<?xml version="1.0" encoding="UTF-8"?><song><author>Суна Уйсал, Али Язар</author>
<hymn_number>165</hymn_number>
<title>Ей Дюшманъм, Ей Дюшманъм TY165</title>
<lyrics>[C1]
   //  Ей дюшманъм, ей дюшманъм,
   Бен дюшерсем, бен калкаръм.  //
   //  Дюштююм ичин севинме,
   Раб'дир елимден тутанъм.  //

[C2]
   //  Каранлъкта отурурсам,
   Раббим бана ъшък олур.  //
   //  О'ндан узаклашсам биле
   Бени арайъп да булур.  //

[C3]
   //  О заман дюшман гьореджек
   Ве ону утанч ьортеджек.  //
   //  Раб Иса адалетийле
   Бени хеп дестеклейеджек.  //</lyrics>
</song>