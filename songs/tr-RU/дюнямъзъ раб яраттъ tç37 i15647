<?xml version="1.0" encoding="UTF-8"?><song><title>Дюнямъзъ Раб Яраттъ TÇ37</title>
<key>D</key>
<lyrics>[V1]
.D
  Дюнямъзъ Раб яраттъ,
.       Em A   Em
 Дюнямъзъ Раб йараттъ,
.A      D            B7
  Дюнямъзъ Раб яраттъ,
.      Em      A     D
 Дюнямъзъ Раб йараттъ.

[V2]
 /// Ямуру, рюзгаръ гьондерир. ///
 Дюнямъзъ Раб яраттъ.

[V3]
 /// Кючюк бебеклери коруйор. ///
 Дюнямъзъ Раб коруйор.

[V4]
 /// Сени ве бени Раб севийор. ///
 Сени, бени Раб севийор.

[V5]
 (Кенди сьозлеринизле езгийи девам еттирин!)</lyrics>
<hymn_number>37</hymn_number>
</song>