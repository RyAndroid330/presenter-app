<?xml version="1.0" encoding="UTF-8"?><song><title>Иса шу вагт шу ерде CA42</title>
<key>Em</key>
<lyrics>[V1]
.   Em     D       C
 // Иса шу вагт шу ерде //
.C          D       G      Bm    Em
 Он гудраты шу ерде халас этмек үчин
.C          D        G    Bm    Em
 Он гудраты шу ерде шыпа бэрмек үчин
.C          D        G    Bm   Em
 Он гудраты шу ерде азат этмек үчин
.   C        D      Em
 // Иса шу вагт шу ерде //</lyrics>
<author>Виталий Ефремочкин</author>
<hymn_number>42</hymn_number>
</song>