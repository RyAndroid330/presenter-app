<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>74</hymn_number>
<title>Худай сөйги N74</title>
<lyrics>[V1]
.   Dm                      Gm
 // Худай сөйги. Биз нәхили багтлы.
.Dm           Bb  C     Dm
 Худай сөйги. Ол бизи сөйди. //

[C1]
.     Dm                         Gm
   // Хер бир адам айдым айтсын шөхратлап,
.  Dm           Bb C     Dm
   Оны шөхратлап. Худай шөйги. //

[V2]
.   Dm                      F
 // Худай сөйги. Ол Оглуны бэрди.
.F            C       F
 Худай сөйги. Гутулыш берди. //

[V3]
.   Dm                      F
 // Худай сөйги. Биз гүнәң гулудык,
.F          C          F
 Худай сөйги. Ол азат этди. //

[V4]
.   Dm                    F
 // Халасгәрим багышлады мэни,
.F         C        F
 Халасгәрим аклады мэни. //

[C2]
   // Сени айдымда бакы шөхратларын,
   Мен шөхратларын Сең сөйгиңи! //</lyrics>
<key>Dm</key>
</song>