<?xml version="1.0" encoding="UTF-8"?><song><title>Айдалың, айдалың! N9</title>
<lyrics>[V1]
 /// Айдалың, айдалың,
 Биз Худая өвги. ///
 Халелуя, Худая шөхрат.
 /// Ол дурмуш, Ол
 дурмуш, Ол ёл ве
 хакыкат. ///
 Халелуя, Худая шөхрат.

[V2]
 /// Исада, Исада,
 Дүнйәни газандык. ///
 Халелуя, Худая шөхрат.

[V3]
 /// Халелу-Халелуя,
 Худая шөхрат. ///
 Халелуя, Худая шөхрат.</lyrics>
<hymn_number>9</hymn_number>
</song>