<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>184</hymn_number>
<title>Ярадан асман, ери N184</title>
<lyrics>[V1]
 // Ярадан асман,
 ери, бүтин әлем Эйеси!
 Биз үчин Оглун берен,
 Атаҗанымы алкышлаң! //

[C1]
   // Алкышлар болсын, алкыш,
   Өвгүлер болсун сансыз!
   Деңи ёк Гүйч-
   Гудратының
   Чәги ёк Онуң
   мәхриниң! //

[V2]
 // Яшайҗы калбымызда,
 Екеҗе Патыша бизе,
 Өзүн гурбанлык эден
 Эйемизи алкышлаң! //

[V3]
 // Догры ёлы гөркезен,
 рухымызы пәк эден,
 гуваныш, умыт, багт берен,
 Мукаддес Рухы алкышлаң! //</lyrics>
</song>