<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.   G          Bm
 // Өвги Саңа Худайым,
.Em           Bm
 Өвги Саңа Мукаддес,
.C          G
 Өвги Иса үчин, Сениң
.F  D
 Оглуңа! //

[C1]
.  Bm        Em
   Инди эҗиз айдар:
.           Am
   «Мен гүйчли!»,
.         D           G
   Гарып айдар: «Мен бай!»,
.         Em     F
   Шол себәпли Худай,
.        D      G
   Бизе бэрди өвги.</lyrics>
<title>Өвги Саңа Худайым N125</title>
<hymn_number>125</hymn_number>
<author>Хенры Смит</author>
<copyright>1978 Интегриты'с Хосанна! Мусик</copyright>
</song>