<?xml version="1.0" encoding="UTF-8"?><song><author>Али Язар</author>
<hymn_number>12</hymn_number>
<title>Ахырсыз, Гүйчли Таңры! CA12 N3</title>
<lyrics>[V1]
.   Em          D           C       Em
 // Ахырсыз, Гүйчли Таңры, Дүнйәни ярадан. //
.Em      D      D  C
 Ол говшамаз, укламаз,
.C    Em   Em   D
 Ол ядамаз, Ол ядамаз,
. D   C      C  Em
 Ол ядамаз, Гүйчли Таңры!

[V2]
 // Гүйчли киши-де Ядав ве аргын боляр. //
 Даёв адам хем говшар хем йыкылар.
 Хем говшар хем йыкылар Гүйчли киши.

[V3]
 // Реббе гарашяның Кувваты тәзеленер. //
 Бүргүт кимин ганат герип Бейгелер ол.
 Бейгелер ол, бейгелер ол, Бүргүт кимин.

[V4]
 // Олар гынанарлар, Эмма ядамазлар. //
 Чүнки олар чын йүрекден Реббе гарашар.
 Реббе гарашар, Реббе гарашар, Чын йүрекден.</lyrics>
<key>Em</key>
</song>