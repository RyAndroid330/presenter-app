<?xml version="1.0" encoding="UTF-8"?><song><title>Таңрым, Халасгәрим Сен N176</title>
<lyrics>[C1]
   // Таңрым, Таңрым Сен мениң Халасгәрим Сен мениң. //

[V1]
 Бүтин дүнйә Нур сачан,
 Иса Худайым мениң.
 // Ягтылыга чыкаран,
 Халасгәрим Сен мениң. //

[V2]
 Дертлериң Дерманы,
 Гарыпларың Хоссары,
 // Дул, етимиң Гамхоры,
 Иса Таңрым Сен мениң. //

[V3]
 Җебир-җепалар чекдиң,
 Гүнәсиз Сен гул болдың,
 // Довзах ёлыны япып,
 Җеннете Сен ёл ачдың. //</lyrics>
<hymn_number>176</hymn_number>
</song>