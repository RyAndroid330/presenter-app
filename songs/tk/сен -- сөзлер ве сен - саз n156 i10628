<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>156</hymn_number>
<lyrics>[V1]
 Сен - Сөзлер,
 ве Сен - Саз
 Сен мен айдйән айдымым.
 Сен - Оваз,
 Сен - Сазлашык,
 Сөхрат эртерин Саңа.

[C1]
   Сен Гудратлы Худай!
   Сен диңе бир Худай!
   Шаларың Бейик Шасы!
   // Мен эртерин Саңа //

[V2]
 // Айдйән айдымымы,
 Сен мең айдйән
 айдымым! //</lyrics>
<title>Сен -- Сөзлер ве Сен - Саз N156</title>
</song>