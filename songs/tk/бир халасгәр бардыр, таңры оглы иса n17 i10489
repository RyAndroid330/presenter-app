<?xml version="1.0" encoding="UTF-8"?><song><title>Бир Халасгәр бардыр, Таңры Оглы Иса N17</title>
<key>D</key>
<lyrics>[V1]
.   C            F   C
 // Бир Халасгәр бардыр
.G          C G
 Таңры Оглы Иса,
.C         F      C
 Гымматлы Таңры Гузысы,
.G         C
 Иң улы болан. //

[C1]
.     C     F    C
   // Саңа шүкүр Атаҗан
.  G         C G
   Исаң ганы үчин,
.  C          F     C
   Инди Сениң Рухуң билен
.  G         C
   доланарыс биз. //

[V2]
 // Иса Халасгәрдир башга
 бири ёк,
 Хорматлы Таңры Гузусы,
 эл чекерин гүнәден. //
 Гайталама:</lyrics>
<author>Мелоды Греен</author>
<hymn_number>17</hymn_number>
</song>