<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>106</hymn_number>
<title>Мениң непесимсиң N106</title>
<lyrics>[V1]
 // Мениң Непесимсиң, //
 Менде яшаян Мукаддес
 Барлыгың;
 // Гүнлүк Чөрегимсиң! //
 Сениң хер Сөзүң
 маңа айдылан
 Инди Саңа мәтәч мен,
 Инди Сенсиз йитен мен.
 // Мениң Непесимсиң, //
 Менде яшаян
 Мукаддес Барлыгың
 // Гүнлүк Чөрегимсиң, //
 Сениң хер Сөзүң
 маңа айдылан.
 Инди Саңа мәтәч мен
 Инди Сенсиз йитен мен.</lyrics>
</song>