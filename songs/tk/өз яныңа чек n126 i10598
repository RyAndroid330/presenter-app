<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>126</hymn_number>
<lyrics>[V1]
 Өз яныңа чек,
 Сенден гитмәйин,
 Бар затларымы берйән,
 Достумдыгыңы билйән.
 Сен мең ислегим,
 Саңа дең хич ким,
 Болмаз ве Ериңи алмаз,
 Реб Сең сөйгиң гутармаз,
 Ёлы тапайын,
 Өз яныңа чек.

[C1]
   Мең ислегим,
   Эбеди Мәтәҗимсиң,
   Мең ислегим,
   Мениң Көмекчим Сен!</lyrics>
<title>Өз яныңа чек N126</title>
</song>