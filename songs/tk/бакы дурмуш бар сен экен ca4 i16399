<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>4</hymn_number>
<author>Таш ака</author>
<key>Em</key>
<lyrics>[V1]
.Em               Am
  Бакы дурмуш бир Сен экен
.B7              Em
  Азашып, йөр экеним
.C          D          Em
  Ойланмага бир пурсат гелди

[V2]
.Em          Am
  Даянҗым болды бир дост
.B7               Em
  Дурмушумы өзгертди
.C             D         Em
  Вепадар, ынамдар, мукаддес

[V3]
.        G            D
 Первердигәр, Первердигәр
.Am          Bm         Em
  Худайың гурбанлык Гузусы
.        G            D
 Первердигәр, Первердигәр
.Am        Bm         Em
  Асмандан гелен Халасгәр</lyrics>
<title>Бакы дурмуш бар Сен экен CA4</title>
</song>