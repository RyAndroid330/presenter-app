<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>41</hymn_number>
<author>Блане Моррис</author>
<key>D</key>
<lyrics>[V1]
.D               Bm
 Реб Худайым арамызда
.   Em        A
 Башарыҗы Башарыҗы

[C1]
.     G           A
   Ол гөтерсин хеммеден бейик
.    Bm                  A
   Хөкүмли ве гүйчлы ве шатлыклы

[V2]
.    D          Bm
 Ол баштутан арамызда
.  Em          D
 Асырдан асыра Омин.</lyrics>
<title>Реб Худайым арамызда Башарыҗы CA41</title>
</song>