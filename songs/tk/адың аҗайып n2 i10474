<?xml version="1.0" encoding="UTF-8"?><song><title>Адың аҗайып N2</title>
<lyrics>[V1]
 /// Адың аҗайып ///
 Иса Худай,
 Реббим Кувватлы,
 Иса Худай!
 Чопан рехимли,
 халка галадыр
 Ол гудратлы Худай!
 Худая баш эгиң,
 сылаң ве сөйүң.
 Адың аҗайып,
 Иса Худай.</lyrics>
<hymn_number>2</hymn_number>
</song>