<?xml version="1.0" encoding="UTF-8"?><song><title>Доганларым ве җигилерим N27</title>
<lyrics>[V1]
 // Доганларым ве
 җигилерим,
 Хош Хабардан
 айдайын сизе.
 Иса бизиң дүня гелип,
 Ярадан рахатлык берди. //

[C1]
   // Гөклер якынлашды, //
   // Арамызда яшады. //
   Бизи сечди бүтүн
   халклардан,
   Бүтүн миллетлерден
   сечди.

[V2]
 // Бизиң атларымыз
 язылып,
 Гөзел гөклер китабында. //
 Перишделер хатара
 дуруп,
 Шатланйәлар бизиң билен.</lyrics>
<hymn_number>27</hymn_number>
</song>