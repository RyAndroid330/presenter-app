<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>573</hymn_number>
<lyrics>[V1]
 Mahereza, ry sakaiza
 Votom-pahoriana !
 Matokia, aza kivy,
 Kristy mialoha anao ;
 // Matokia //
 Mahereza hianao.

[V2]
 Aza mba matoky tena,
 Foana ny herinao ;
 Tano mafy ny ampinga
 'Zay atolony anao ;
 // Raiso koa //
 Ny Fanahy ho sabatrao.

[V3]
 Maizina izao ny andro,
 Sarotra ny lalanao ;
 Ao ambony ny mazava
 Ampy hanazava anao ;
 // Mba jereo //
 Ilay mazava amboninao.

[V4]
 Vetivety, afa-doza,
 Vita ny alehanao ;
 Ao an-danitra ambony
 Misy hifalianao ;
 // Miravoa //
 Tapitra ny adinao.</lyrics>
<title>Mahereza ry sakaiza FFPM573</title>
</song>