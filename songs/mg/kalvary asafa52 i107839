<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>52</hymn_number>
<author>Landy RABENIRAINY / John M. Moore</author>
<title>KALVARY ASAFA52</title>
<lyrics>[V1]
 Fiainana efa ratsy ety,
 Kivy reraka am-po,
 No nentin'olona ao Kalvary,
 An-tongotr'i Jeso,
 Entana maro navela ao,
 Kalvary, Kalvary,
 No nentin'olona ao Kalvary,
 An-tongotr'i Jeso.

[V2]
 N'inona mahory anao,
 Ota maro tokoa,
 Jereo fa mbola ao Kalvary,
 Miandry anao Jeso,
 Entana maro navela ao,
 Kalvary, Kalvary,
 Jereo fa mbola ao Kalvary,
 Miandry anao Jeso.

[V3]
 Ts'isy zava-miseho ety,
 'Zay tsy hitany,
 Ny sento sy ny tomany,
 Ento eo Aminy,
 Entana maro navela ao,
 Kalvary, Kalvary,
 Ny sento sy ny tomany,
 Ento eo Aminy.</lyrics>
</song>