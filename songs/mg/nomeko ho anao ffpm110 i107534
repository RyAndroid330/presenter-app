<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>110</hymn_number>
<author>P.P. Bliss</author>
<lyrics>[V1]
 Nomeko ho anao
 Ny rako masina,
 Hanavotra anao,
 Izay tsy marina !
 // Ka dia mba inona izao
 No Ahy taminao ? //

[V2]
 Nafoiko ho anao
 Ny zava-tsoa be,
 Mba hanatonanao
 Ny Raiko lehibe !
 // Ka dia mba inona ..sns. //

[V3]
 Izaho Tomponao
 Nijaly mafy re,
 Hanafaka anao,
 Mpanota lehibe !
 // Ka dia mba inona ..sns. //

[V4]
 Ny vonjy lehibe
 Nataoko ho anao,
 Ny rako nitete
 Handio ny otanao !
 // Ka dia mba inona ..sns. //

[V5]
 Jesosy Tompo ô !
 Izao no teniko :
 Atolotro Anao
 Ny aiko sy ny fo !
 // Izany no isaorako
 Anao Mpamonjiko ! //

[V6]
 Ny foko raisonao,
 Oneno hatretý,
 Ataovy lapanao
 Na eto na arý !
 // Dia tano aho, Tompo ô,
 Mba ho fanananao ! //</lyrics>
<title>Nomeko ho anao FFPM110</title>
</song>