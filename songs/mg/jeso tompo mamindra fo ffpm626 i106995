<?xml version="1.0" encoding="UTF-8"?><song><author>J.R. Sweney</author>
<hymn_number>626</hymn_number>
<lyrics>[V1]
 Jeso Tompo, mamindrà fo
 Amin'ny mpanomponao,
 Fa tsy misy famonjena
 Afa-tsy ao Aminao ;
 // O ! vonjeo //
 Ny mifona Aminao. (in-2)

[V2]
 Fa kamboty sy mahantra,
 Ory, osa, reraka
 Izahay atý an-tany,
 Raha tsy vimbininao ;
 // O ! ampio //
 Ny miankina Aminao. (in-2)

[V3]
 Tokinay sy Vatolampy,
 Aro sy ampinganay !
 Afa-tahotra, afa-doza,
 Tsy ho ketraka izahay ;
 // O ! arovy //
 Ny mialoka Aminao. (in-2)</lyrics>
<title>Jeso Tompo, mamindra fo FFPM626</title>
</song>