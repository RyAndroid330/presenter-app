<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>311</hymn_number>
<author>G.J. Webb</author>
<lyrics>[V1]
 Miely lavitra any
 Ny olo-marobe
 Koa iza no hankany,
 Hamonjy azy re ;
 Hanorina sekoly,
 Hitory teny koa,
 Hamaky ny Baiboly
 Milaza zava-tsoa ?

[V2]
 Indreny olona ory
 Tsinjovy rizareo !
 Tsy misy ny mpitory,
 Ka moa hafoinareo ?
 Tsarovy Jeso Tompo
 Nandao ny lapa soa,
 Ka tonga mba hanompo,
 Nanolotra aina koa.

[V3]
 Ry Lohan'ny mpiandry !
 Tendreo ny irakao,
 Fa reraka mandry
 Ny ondrikelinao ;
 Iraho ny mpitory
 Handeha ankehitrio,
 Ka tsy handà akory
 Hanao veloma anio.

[V4]
 Ny tia famonjena
 Miaramila soa ;
 Izay manolo-tena
 No iraka tokoa ;
 Na lavitra ny tany,
 Hanendry tena hoe :
 &quot; Izaho no hankany,
 Iraho aho e ! &quot;</lyrics>
<title>Miely lavitra any ny olo-marobe FFPM311</title>
</song>