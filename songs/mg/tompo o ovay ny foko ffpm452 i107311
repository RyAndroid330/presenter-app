<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Tompo ô ! ovay ny foko
 Mba ho mora anarina
 Toy ny any zazakely
 Tsotra sady marina,
 // Tsy mialona, tsy maditra,
 Fa manao ny sitrakao //

[V2]
 Zaza, ka tsy te-hifidy
 Izay homenao ahy anio ;
 Ny ho azoko ampitso
 Dia ankinina aminao ;
 // Koa tsy manahy aho,
 Fa efa niantohanao //

[V3]
 Zaza tsy maharo tena,
 Fa miankina amin-dray.
 Tsy mahery, tsy mba hendry,
 Ary tsy mahay mandeha ;
 // Hianao no Raiko tia,
 Raiko be fahari-po //</lyrics>
<title>Tompo o! Ovay ny foko FFPM452</title>
<hymn_number>452</hymn_number>
<author>G.C. Stebbins</author>
</song>