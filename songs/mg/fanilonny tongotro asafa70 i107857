<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>70</hymn_number>
<author>Ndriana RAMAMONJY</author>
<title>FANILON'NY TONGOTRO ASAFA70</title>
<lyrics>[V1]
 Fanilon'ny tongotro
 Sy fanazavana koa
 Ny làlako ny Teninao
 Andriamanitra ô !

[V2]
 Ny Teninao Masina
 No mpitarika anay
 Handresenay ny Devoly
 Hanafika anay

[V3]
 Madio ny Teninao
 Ka hianaranay
 Ka omeo ny fahendrena
 Ho tia ny Teninao</lyrics>
</song>