<?xml version="1.0" encoding="UTF-8"?><song><author>Landy RABENIRAINY</author>
<hymn_number>17</hymn_number>
<lyrics>[V1]
 Raha itodihana ireo andro lasa
 Dia hita taratra ao
 Ny fitantananao
 Ny Tananao mahery
 Miaro lalandava
 Ka ny voninahitra
 No mendrika Anao
 Fiv. Ny dera sy laza
 Ary fihobiana
 Ny haja avo indrindra
 Atolotra Anao
 Ry Tompo ô! ry Tompo ô!
 Ny mpanomponao
 Miara-manandra-peo
 Hankalaza anao

[V2]
 Ny Famindramponao
 Tsy tratry ny saina
 Ary ny fitiavanao
 Tsy hay tantaraina
 Manerana ny tany
 Ny Hasoavanao
 Ka ny Voninahitra
 No mendrika Anao.</lyrics>
<title>NY VONINAHITRA NO MENDRIKA ANAO ASAFA17</title>
</song>