<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 O ! miaingà izao, ry
 miaramila soa,
 Antsoin'ny Tomponao hiady
 hianao.
 Ny fahavalo ao, kanefa
 mandrosoa,
 // Mahery re no momba
 anao //

[V2]
 Izao tontolo izao izay feno
 fahotana
 No iantsoana anao mba
 hotafihinao
 Indreo mihoraka ao ny
 fehin'ny Satana
 // Jeso anefa momba anao //

[V3]
 Ny aizim-be izay mandrakotra
 ny tany
 No iantsoana anao ka andeha
 mba savao ;
 N Tompo no tafio, alao ny
 hazavany,
 // Tsilovy izao tontolo izao //

[V4]
 Ny fahoriam-be izay
 manarona eto
 No iantsoana anao, ka moa
 ve handà ?
 Ampiononinao ny ory sy
 misento
 // O ! mazotoa ka miaingà //

[V5]
 Na inona hanjo mbola ao ny
 famonjena
 Hahery hianao ! izay no
 antenao ;
 Ampoizinao tokoa izao ny
 fandresana,
 // Mahery Ilay arahinao //

[V6]
 O ! mahereza izao, ry
 miaramila soa !
 Ny hatrotrahanao iareto sy
 zakao.
 Jesosy no jereo, ka matokia
 tokoa.
 // Fa Izy re no herinao //</lyrics>
<title>O! Miainga izao, ry miaramila soa FFPM287</title>
<author>L.J. Delaborde</author>
<hymn_number>287</hymn_number>
</song>