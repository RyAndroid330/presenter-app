<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>799</hymn_number>
<author>C.F. Witt</author>
<title>Zaza sambatra tokoa FFPM799</title>
<lyrics>[V1]
 Zaza sambatra tokoa,
 Ry Jesosy, izahay,
 Fa ny Tompo Zanahary
 No mamelona anay.

[V2]
 Zaza sambatra tokoa,
 Ry Jesosy, izahay,
 Hianao nijaly mafy
 Hanavotanao anay.

[V3]
 Zaza sambatra tokoa,
 Ry Jesosy, izahay,
 Ny Fanahy Mpanadio
 Manamasina anay.

[V4]
 Zaza sambatra tokoa,
 Ry Jesosy, izahay,
 Fiarovanay tsy toha
 Hianao, ry Tomponay !</lyrics>
</song>