<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mivory eto izahay,
 Jeso Tompo ô ;
 Avia hanazava anay,
 // Hinoanay Anao //

[V2]
 Maniry mafy izahay,
 Hihaona Aminao ;
 Omeo hosotroinay,
 // Ny rano velona //

[V3]
 Ny mofon'aina mba zarao
 Ho anay, ry Tompo ô !
 Tahio re ny irakao,
 // Ho voninahitrao //

[V4]
 Ny fonay dia atolotray
 Anao, Jesosy ô !
 Omeo hery izahay
 // Hanao ny sitrakao //

[V5]
 Raha tapitra ny andronay,
 Izay voafetranao,
 Dia ento mody izahay
 // Ho any Aminao //</lyrics>
<title>Mivory eto izahay FFPM221</title>
<author>N. Herman</author>
<hymn_number>221</hymn_number>
</song>