<?xml version="1.0" encoding="UTF-8"?><song><author>J.C. Rinck</author>
<hymn_number>715</hymn_number>
<lyrics>[V1]
 Tonga ny maraina,
 Dimbin'alina,
 Ka ny Tompon'aina
 No isaorana.

[V2]
 Raha mbola nandry
 Aho Tompo ô,
 Hianao Mpiandry
 Dia aroko.

[V3]
 Tano sy ampio
 Ny madinikao,
 Sao hanota anio,
 Ka handao Anao.

[V4]
 Aoka ny anjara
 Fanompoako
 Mba ho vita tsara
 Ka ho sitrakao.

[V5]
 Ary raha lany
 Ny fotoako,
 Izaho hody any
 Anatrehanao.</lyrics>
<title>Tonga ny maraina FFPM715</title>
</song>