<?xml version="1.0" encoding="UTF-8"?><song><title>AZA MATAHOTRA IANAO ASAFA47</title>
<lyrics>[V1]
 Aza matahotra ianao fa momba anao Aho,
 Ary aza miherikerika foana,
 Fa Izaho no Andriamanitrao.
 Mampahery anao Aho sady mamonjy anao,
 Eny mitantana anao amin'ny
 Tanan-ankavanan'ny fahamarinako Aho.</lyrics>
<author>Ndriana RAMAMONJY</author>
<hymn_number>47</hymn_number>
</song>