<?xml version="1.0" encoding="UTF-8"?><song><title>O, rankizy izay mivory FFPM811</title>
<lyrics>[V1]
 O, rankizy izay mivory,
 Mba derao ny Tompo soa,
 Ka ny fonao atolory,
 Ny fanahy, tena koa
 // Mba venteso re ny hira,
 Ka derao ny Tomponao //

[V2]
 O, ry Tompo be fitia,
 Mba henoy ny zanakao ;
 Fa miantso hoe : Avia !
 Manatreha anay izao !
 // Izay hataonay re tahio
 Ho madio sy masina //

[V3]
 Mba tolory fahendrena
 Izahay madinikao,
 Ka omeo ny famonjena
 Hifikirana aminao ;
 // O, tarihonao ny dia
 Hahitana Anao, ry Ray ! //

[V4]
 He, ny fonay manontolo,
 Izay mangetaheta re,
 Dia atolotray daholo,
 Aza dia lavina e !
 // Mba onenonao ny fonay
 Ho Anao mandrakizay //</lyrics>
<hymn_number>811</hymn_number>
<author>A. Nettleton</author>
</song>