<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ao an-dapany, Jesosy
 Dia derain'ny tapitrisa,
 Fa ny lanitra sy tany
 Dia samy mankamamy
 // Ilay Mpandresy mora fo ! //

[V2]
 Jeso Tompo dia ho avy
 Ho Mpitsara atý an-tany,
 Na ny ratsy na ny tsara
 Samy hanana anjara,
 // Valin'ny natao tatý ! //

[V3]
 Ry Mpiantra be fitia,
 Iantrao izahay mania ;
 Raiso ho Anao, tahio,
 Hafanao, ampifalio,
 // Ento any Aminao ! //</lyrics>
<title>Ao an-dapany, Jesosy FFPM153</title>
<hymn_number>153</hymn_number>
<author>L.M. Linderman</author>
</song>