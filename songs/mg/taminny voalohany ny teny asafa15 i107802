<?xml version="1.0" encoding="UTF-8"?><song><author>Landy RABENIRAINY</author>
<hymn_number>15</hymn_number>
<lyrics>[V1]
 Tamin'ny voalohany ny teny
 Dia tao amin'Andriamanitra
 Nahariana izao tontolo izao
 Ary koa nisiam-piainana

[C1]
   Io Ilay Mazava ho antsika
   Tolotry ny Ray ambony ao
   Ka ny haizina dia tsy ho hita
   Jesosy no mamirapiratra ao

[V2]
 N'iza n'iza no nandray Azy
 Dia nomeny ny fahefana
 Mba ho tonga zanak'Andriamanitra
 Izay mino ny Anarany</lyrics>
<title>TAMIN'NY VOALOHANY NY TENY ASAFA15</title>
</song>