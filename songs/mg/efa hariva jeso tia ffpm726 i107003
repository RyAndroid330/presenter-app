<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>726</hymn_number>
<author>J.B. Dykes</author>
<lyrics>[V1]
 Efa hariva, Jeso tia !
 Tomoera aminay ;
 Ny fanahinay tahio,
 Fa hatory izahay.

[V2]
 Fa ny helokay ekenay,
 Mahavonjy Hianao ;
 Ny manjo anay lazainay,
 Fa miantra ny fonao.

[V3]
 Alina maharitra ela,
 Aizi-mampivadi-po,
 Fa ny olona fidinao
 Tsy mba takona aminao.

[V4]
 Hianao no mitahiry
 Ny miankina aminao ;
 Voahodidin'ny anjely
 Ny mialoka aminao.

[V5]
 Raha anio no tapitra andro
 Izahay mpanomponao,
 Aoka izahay hifoha
 Ao an-dapa soanao.</lyrics>
<title>Efa hariva Jeso tia! FFPM726</title>
</song>