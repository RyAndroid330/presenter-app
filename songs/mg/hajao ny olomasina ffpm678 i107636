<?xml version="1.0" encoding="UTF-8"?><song><title>Hajao ny olo-masina FFPM678</title>
<lyrics>[V1]
 Hajao ny olo-masina
 Mpanaraka ny Tomponao,
 Miely sy Manerana
 Izao tontolo izao ;
 Ireo dia tonga ohatra,
 Ka tokony harahinao,
 Na efa olon-dehibe,
 Na zaza hianao ;
 Tanteraka ny sasany,
 Ka efa nody amin-dRay ;
 Ny sasany dia mbola atý
 Milasy amin-day.

[V2]
 Ka betsaka ny isany,
 Na atý, na ao an-danitra ;
 Ny Rainy kosa dia iray,
 Andriamanitra ;
 Ireo maro namanao
 Miantso koa maka anao
 Hiaraka hiezaka
 Hankao an-danitra ;
 Ka dia miezaha re,
 Ka aza kivy hianao ;
 Jereo ao aloha ao
 Ny loka ho anao.</lyrics>
<hymn_number>678</hymn_number>
</song>