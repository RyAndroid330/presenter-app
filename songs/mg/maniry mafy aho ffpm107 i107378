<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>107</hymn_number>
<author>F.C. Maker</author>
<title>Maniry mafy aho FFPM107</title>
<lyrics>[V1]
 Maniry mafy aho ry Jeso
 Tompo ô,
 Hialoka eo ambany hazo-
 fijalianao ;
 Tsy misy toeran-kafa re izay
 tena mamiko,
 Ny hazo-fijalianao no
 fiarovako.

[V2]
 Ny hazo-fijalianao no
 itazanako
 Ny tenanao Izay nijaly mba
 ho avotro ;
 Ka dia kotsan-dranomasom-
 pitiavana
 Ny tavako, ry Tompo ô, fa
 afa-keloka !

[V3]
 Am-pototry ny hazo izay
 nijalianao
 No itoerako hohazavain'ny
 tavanao ;
 Ataoko fatiantoka ny zava-
 mora lo,
 Ny hazo-fijalianao no
 tombon-dahiko !</lyrics>
</song>