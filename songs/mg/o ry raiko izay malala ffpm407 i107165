<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>407</hymn_number>
<author>H.S. Oakeley</author>
<lyrics>[V1]
 O ry Raiko izay malala,
 Tonga aho zanakao,
 Izay nania, fa adala,
 Ka mifona Aminao ;
 Mamelà ny fahotako
 Teo anatrehanao ;
 Ary ny fahadalako
 Aza mba heverinao !

[V2]
 He, izaho nanantena
 Izao fiainana izao,
 Ka nandà ny famonjena,
 Izay lazain'ny teninao ;
 Kanjo hitako tokoa,
 Fa izao tontolo izao
 Tsy mba manan-java-tsoa
 Hampiadana ny fo.

[V3]
 Enga aho, izay mahantra,
 Mba ho isan'ny Anao ;
 Hianao ry Ray Mpiantra,
 Miantrà ny zanakao,
 Ary nohon'ny Mpamonjy,
 Izay nanavotra ahy re,
 Raiso aho ho tra-bonjy,
 Ha Anao, ry Ray ! Amen !</lyrics>
<title>O, ry Raiko, Izay malala FFPM407</title>
</song>