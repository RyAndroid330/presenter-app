<?xml version="1.0" encoding="UTF-8"?><song><author>Ndriana RAMAMONJY</author>
<hymn_number>33</hymn_number>
<lyrics>[V1]
 Jeso no tsy miova,
 Na omaly na anio,
 Eny, ho mandrakizay ('Lay)
 Vatolampy tsy mikoro.
 Vato fanorena-mafy,
 Azo itokiana tokoa,
 Raha hanorenana,
 Ny fiainana (mahasambatra),
 Mandrakizay.

[V2]
 'Zaho izay novonjeny,
 Mety hangovitra ihany,
 Eo ambony vatolampy (fa)
 Izy tsy miova akory.
 Jeso ô! ampianaro,
 Aho ho tahaka Anao izao,
 Ka ny fiainako,
 Jeso Tompo ô ! (Mba ho entiko)
 Hiderana Anao.</lyrics>
<title>JESO NO TSY MIOVA ASAFA33</title>
</song>