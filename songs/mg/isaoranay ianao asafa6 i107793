<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Isaoranay Ianao Jehovah Ray
 Fa narovanao 'zahay
 Ka navelanao hankalaza
 Izao fotoana anio izao

[V2]
 Ny fitahianao tsy tapaka
 No nahatraranay izao
 Ka hotsaroanay lalandava
 Ny Anara-masinao

[V3]
 Ataonay fantatry ny olona
 Ny Anara-masinao
 Ny Asam-pamonjen-dehibe
 Ho an'izao tontolo izao</lyrics>
<title>ISAORANAY IANAO ASAFA6</title>
<author>Tatavao MANOELA</author>
<hymn_number>6</hymn_number>
</song>