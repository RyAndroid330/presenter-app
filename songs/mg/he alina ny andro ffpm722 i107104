<?xml version="1.0" encoding="UTF-8"?><song><author>H.L. Hassler</author>
<hymn_number>722</hymn_number>
<title>He, alina ny andro FFPM722</title>
<lyrics>[V1]
 He alina ny andro,
 Ka mba esorinao
 Ny fahotako maro,
 Mba tsy ho hitanao ;
 Reseo ny mpamely
 Ny zanakao, ry Ray ;
 Iraho ny anjely
 Hiambina anay.

[V2]
 Raha maizina ny tany,
 Ny andro tapitra,
 Tsaroanay ihany
 Ny fasa-maizina ;
 Arovy lalandava
 Izahay, ry Tomponay,
 Ka aoka ho mazava
 Ny hitsangananay.</lyrics>
</song>