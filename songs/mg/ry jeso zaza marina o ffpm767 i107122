<?xml version="1.0" encoding="UTF-8"?><song><title>Ry Jeso, Zaza marina o FFPM767</title>
<lyrics>[V1]
 Ry Jeso, Zaza masina ô !
 Izay tonga zaza toa anay ;
 Nafoinao ny lapanao
 Hitondra vonjy ho anay,
 Ry Jeso, Zaza masina ô !

[V2]
 Ry Jeso, Zaza masina ô !
 Nanetry tena Hianao ;
 Nilaozanao ny lanitrao
 Noho ny fitiavanao,
 Ry Jeso, Zaza masina ô !

[V3]
 Ry Jeso, Zaza masina ô !
 Hianao no fihavanana ;
 Izahay izay nandà ny Ray
 Tadiavanao ho Azy indray,
 Ry Jeso, Zaza masina ô !

[V4]
 Ry Jeso, Zaza masina ô !
 Hihira ho Anao izahay,
 Hianao nanondrotra anay ;
 Ny lapan-dRay ho azonay,
 Ry Jeso, Zaza masina ô !</lyrics>
<hymn_number>767</hymn_number>
<author>J.S. Bach</author>
</song>