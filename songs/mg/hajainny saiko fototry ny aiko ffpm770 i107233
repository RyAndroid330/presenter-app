<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>770</hymn_number>
<lyrics>[V1]
 Hajain'ny saiko
 Fototry ny aiko,
 Itsaohan'ny fanahiko,
 Tokana iriko,
 Malala tiako :
 Hianao, Jeso Mpamonjiko !

[V2]
 Mety malazo
 Ny voninkazo,
 Ny ahi-maintso koa re !
 Fa misy lova
 Tsy mba miova :
 Jesosy Perla soa e !

[V3]
 Ao lalandava
 Ny andro mazava,
 Ny kintana, ny volana ;
 Jesosy irery
 Tompon'ny hery :
 Tsy azo ihoarana.

[V4]
 He, igagàna
 Ny hatanorana,
 Fa na mahafinaritra,
 Mety mihena
 Ny herin-tena :
 Jesosy no maharitra.

[V5]
 Tsy misy fetra
 Zavatra rehetra
 Hianao Jesosy, Tokiko,
 Akaiky ahy,
 Zoky Mpiahy,
 Ny tsara indrindra amiko.

[V6]
 Raha ho lasa,
 Fa vita ny asa,
 Tohano aho, Jeso ô !
 Ampio aho
 Sy atanjaho,
 Ho sambatra eo an-tratranao.</lyrics>
<title>Hajain'ny saiko, fototry ny aiko FFPM770</title>
</song>