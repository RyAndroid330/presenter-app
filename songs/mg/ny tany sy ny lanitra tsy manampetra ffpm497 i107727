<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>497</hymn_number>
<title>Ny tany sy ny lanitra tsy manampetra FFPM497</title>
<lyrics>[V1]
 Ny tany sy ny lanitra tsy
 manam-petra
 Hiaraka amin'ny mino
 rehetra
 Manaiky fa Jeso no aina
 hamonjy
 Ny olona ory izay mila vonjy.

[V2]
 Na dia manenjika ahy ny
 ratsy,
 Tsy lany ny hery, fa Jeso
 manampy
 Dia Izy no tanako mafy
 tokoa,
 Ka tsy ialako, fa Tompo
 Tsitoha.

[V3]
 Jesosy Sakaizako dia miahy
 Ny Azy, ka afaka ny ahiahy,
 Ny fo malahelo ovany ho
 faly,
 Ka tretrika indray ireo olo-
 mijaly.

[V4]
 Jesosy fidiko ho Tompo
 tokoa,
 Efaiko ny asa sy hevitra soa,
 Izay halan'ny Tompo tsy
 tiako intsony,
 Ka tena iraisako tsara any
 fony.

[V5]
 Izay tanako mafy sy mamy
 hambara
 Rehefa ho faty, ka tonga ny
 anjara :
 Jesosy, Jesosy irery ihany
 No aina, harena tsy mety ho
 lany.</lyrics>
</song>