<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>699</hymn_number>
<author>J. Barnby</author>
<lyrics>[V1]
 Midera Anao ny olo-masina
 Noho ny fandresena
 nomenao ;
 Ry Jeso ô ! Mpitari-dalana !
 Haleloia ! Haleloia !

[V2]
 Ory sy lao, fadiranovana,
 Natao ho zava-tsinontsinona
 Nefa ireo no tsy nivadi-po ;
 Haleloia ! Haleloia !

[V3]
 Mafy ny ady aman-tafika,
 Izay nihatra tao an-dalana,
 Fa Hianao no nitokiany ;
 Haleloia ! Haleloia !

[V4]
 Indro ! mpandresy no idirany
 Ao afovoan'ny ao an-danitra,
 Handray ny satro-boninahitra ;
 Haleloia ! Haleloia !

[V5]
 « Mpanompo tsara sady
 mahasoa,
 Midira am-pifalian'ny
 Tomponao »
 He, sambatra izy, fa efa
 voaray ;
 Haleloia ! Haleloia !

[V6]
 Aoka ireo no hotahafinay
 Amin'ny ady iadiana,
 Hiraisam-boninahitra aminy :
 Haleloia ! Haleloia !

[V7]
 Ankehitrio, Anao ny fiderana,
 Ry Ray sy Zanaka, Fanahy koa
 Eran'ny tany aman-danitra :
 Haleloia ! Haleloia !</lyrics>
<title>Midera Anao ny olo-masina FFPM699</title>
</song>