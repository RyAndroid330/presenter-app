<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Fanavaozana izay mahagaga
 tokoa
 Nomen'i Jeso ahy re !
 Fahazavan'ny fanahy izay
 mahafa-po
 Nomen'i Jeso ahy re !
 // Hatramin'izao dia
 endrey, endrey //
 Ny fitempon'ny foko izay
 ravo tokoa
 Onenan'ny Tompo Jeso.

[V2]
 Ny fiainako be siasia taloha
 Voaova mihitsy izao
 Eny, ny fahotako, izay
 nahavoa
 Voasasany koa izao,
 // Hatramin'izao, ..sns. //

[V3]
 Ny finoako, ny fanantenako
 dia be
 Ny tokiko fatratra koa
 Ny fisalasalana dia levona re,
 Ny saiko mandroso ho soa.
 // Hatramin'izao, ..sns. //

[V4]
 Tonga mamirapiratra fatratra
 erý
 Ny aloky ny faty re !
 Ka dia tsinjoko ilay vavahady
 arý
 Mankao an-tanàn-dehibe
 // Hatramin'izao, ..sns. //

[V5]
 Tsy miato, mizotra mankany tokoa
 Ny diako hatramin'izao
 Hovantaniko any Ilay Tompo soa
 Jesosy malala no ao.
 // Hatramin'izao, ..sns. //</lyrics>
<title>Fanavaozan'izay mahagaga tokoa FFPM487</title>
<hymn_number>487</hymn_number>
<author>Ch. H. Gabriel</author>
</song>