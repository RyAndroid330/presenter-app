<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>338</hymn_number>
<author>G.J. Webb</author>
<title>Arovy aho, Tompo FFPM338</title>
<lyrics>[V1]
 Arovy aho, Tompo,
 Atolotro izao
 Ny tenako hanompo
 Sy hankalaza Anao.
 Omeo ahy hery
 Sy faharetam-po,
 Arovy tsy ho very
 Izay anjarako !</lyrics>
</song>