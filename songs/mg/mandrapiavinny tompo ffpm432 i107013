<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mandra-pihavin'ny
 Tompo, mivavaha ;
 Ny teny tsara nomeny
 tadidio,
 Ny adidinao, tontosay
 sy efao,
 Mijery ny ataonao
 ny Ray.
 Raha mpanompo tsara
 hianao,
 He, ny Tompo faly
 aminao,
 Koa tanteraho ireo
 adidinao,
 Mba ho mpanompo
 mahasoa.

[V2]
 Mandra-pihavin'ny
 Tompo, miasà ;
 Ampitomboy ireo
 talenta azonao :
 Vola, fahaizana, aina,
 hery koa
 No anompoy ny Tompo
 Tsitoha.
 Raha mpanompo ..sns.

[V3]
 Moa tianao va
 Ilay Mpamonjy
 Tompo soa ?
 Ny rany anie
 nanavotany anao !
 Ny hafany tanteraho
 sy hajao
 Valio ny fanavotany
 anao.
 Raha mpanompo ..sns.</lyrics>
<title>Mandra-piavin'ny Tompo FFPM432</title>
<author>P. Ramilison</author>
<hymn_number>432</hymn_number>
</song>