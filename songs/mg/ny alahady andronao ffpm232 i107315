<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>232</hymn_number>
<author>F. Duckworth</author>
<lyrics>[V1]
 Ny Alahady andronao,
 Jeso Tompo masina ô !
 Fotoana nitsangananao,
 Ka maminay mpianatrao.

[V2]
 Anio, mivory izahay,
 Tahaka ireo mpianatrao ;
 Ka enga anie ho hitanay
 Ny hazavan'ny tavanao.

[V3]
 Omeo anay, omeo indray
 Ny herin'ny Fanahinao ;
 Havaozy ao anatinay
 'Lay Pentekosta fahizay.</lyrics>
<title>Ny alahady andronao FFPM232</title>
</song>