<?xml version="1.0" encoding="UTF-8"?><song><title>He, miandrandra Anao, FFPM608</title>
<lyrics>[V1]
 He miandrandra Anao,
 Jehovah Tompo ô !
 Ny olonao;
 Henoy ny vavakay,
 Vonoy ny helokay,
 Hahafantaranay
 Fa Zanakao.

[V2]
 Raha hodiavinay
 Ny tany maizina,
 Tarihonao ;
 Fafao ry Jesosy
 Ny ranomasonay !
 Ka mba esorinao
 Ny tahotray.

[V3]
 Mba manomeza anay
 Ny hasoavanao,
 Ry Tompo ô !
 Mba hahazoanay
 Ny hasambarana
 Tsy mety levona,
 An-danitra.

[V4]
 Tohanonao Izahay,
 Rehefa tapitra
 Ny andronay,
 Ray ô ! mba hamoray
 Ny hanalana anay
 Ho any Aminao,
 mandrakizay.</lyrics>
<hymn_number>608</hymn_number>
<author>F. Giardini</author>
</song>