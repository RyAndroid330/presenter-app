<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ry Jesosy Tomponay
 Ravoravo izahay ;
 Tonga izahay izao
 Mba hihaona Aminao ;
 Indro misy tranonao
 Hitokananay izao.

[V2]
 Ka mangataka Aminao
 Izahay, ry Tompo ô !
 Aoka mba horaisinao
 Izay nataonay ho Anao :
 Trano fiangonana
 Trano fivavahana.

[V3]
 Aoka mba ho fantatray
 Eto ny alehanay,
 Fa vahiny izahay,
 Ka ny tanindrazanay
 Dia any Aminao ;
 Koa mba tarihonao.

[V4]
 Aoka ny Anaranao
 Mba hohamasininao ;
 Aoka ny Fanahinao,
 Mba ho tonga hanavao
 Ny mpanota marobe,
 Dia hovoavonjy re !

[V5]
 Ka ny fiadananao
 Ampombay ny olonao,
 Hampikambana ny fo,
 Ka ho toy ny iray tam-po,
 Mba hifankatiavanay
 Izao sy rahatrizay.</lyrics>
<title>Ry Jesosy Tomponay FFPM321</title>
<hymn_number>321</hymn_number>
</song>