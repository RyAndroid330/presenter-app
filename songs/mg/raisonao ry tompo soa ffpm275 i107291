<?xml version="1.0" encoding="UTF-8"?><song><title>Raisonao, ry Tompo soa FFPM275</title>
<lyrics>[V1]
 Raisonao ry Tompo soa,
 Ny fanatitray izao ;
 Hamasino avokoa
 Izay atolotray Anao,
 // Raiso re, ho Anao,
 Ho fanati-tsitrakao ! //

[V2]
 He, Anao, ry Tompo soa
 Izay rehetra anananay
 Ny harena, vola koa,
 Taminao, Jehovah Ray,
 // Raiso re, ..sns. //

[V3]
 Na dia kely aza, Tompo,
 Ka tsy mendrika Anao,
 Raiso ho entina hanompo
 Sy hanao ny sitrakao.
 // Raiso re, ..sns. //

[V4]
 Indro, Tompo, raiso koa
 Tena, fo, fanahinay,
 Mba ho fiasana koa
 Eo an-tananao izahay.
 // Raiso re, ..sns.
 Ho voninahitrao. //</lyrics>
<author>W.H. Doane</author>
<hymn_number>275</hymn_number>
</song>