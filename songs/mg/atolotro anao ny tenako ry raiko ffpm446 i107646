<?xml version="1.0" encoding="UTF-8"?><song><title>Atolotro Anao ny tenako, ry Raiko FFPM446</title>
<lyrics>[V1]
 Atolotro Anao
 ny tenako, ry Raiko !
 Fa Hianao no tena
 loharanon-tsoa
 Izao tontolo izao
 manintona ny saiko
 Hiataka Aminao
 ho babony tokoa.

[V2]
 Atolotro Anao
 ny tenako, ry Raiko !
 Ho eo an-tananao
 hosakambininao,
 Hohatanjahanao
 ny tena sy ny saiko
 Hisikina tokoa
 hiady ho Anao.

[V3]
 Atolotro Anao
 ny tenako, ry Raiko !
 Fa izany indrindra re
 no hetahetako ;
 Ny ran'ny Zanakao
 mitory ao an-tsaiko
 Mba hanolorako Anao
 ny tenako.</lyrics>
<hymn_number>446</hymn_number>
</song>