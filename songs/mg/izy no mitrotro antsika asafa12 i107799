<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>12</hymn_number>
<author>Faly Henintsoa RAFIDIMANANA</author>
<lyrics>[V1]
 Tsy misy masina tahaka Anao
 Ry Andriamanitra Ray ô!
 Tompon'ny fahalalàna
 Sy henika ny voninahitra Ianao
 Lay mahavelona sy mahafaty
 Lay mampisandratra sy manpietry
 Anao ny hery sy ny fahalehibiazana
 Ry firenena ô! izay mbola lavitra
 Ny fahamarinana
 Meteza ka mihainoa ny Teniny
 F'Izy hitarika anao
 Izy no nanao antsika
 Izy no mitrotro antsika
 Izy no mitondra antsika
 Mpanafaka amin'ny fahoriana
 Ny zavaboary noforoniny
 Dia miova sy miserana
 F'Izy dia efa nitoetra hatrizay
 Sy maharitra mandrakizay</lyrics>
<title>IZY NO MITROTRO ANTSIKA ASAFA12</title>
</song>