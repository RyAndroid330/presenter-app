<?xml version="1.0" encoding="UTF-8"?><song><author>J.C.H. Rinck</author>
<hymn_number>794</hymn_number>
<lyrics>[V1]
 Ry Jesosy tsara
 Ao an-danitra
 Izahay dia zaza
 Saro-tahotra.

[V2]
 Koa ny anjely
 Mba irahonao
 Ho anay izay kely,
 Raha sitrakao.

[V3]
 Dia mba tantano,
 Jeso, izahay,
 Ary mba fahano
 Ny fanahinay.

[V4]
 Hianao, Mpamonjy,
 Dia tianay;
 Izahay voavonjy
 Tia Anao indray.</lyrics>
<title>Ry Jesosy tsara ao an-danitra FFPM794</title>
</song>