<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 &quot;Mpivahiny ! mba lazao ;
 Zovy moa hianao ?&quot;
 &quot;Izaho namanao ity,
 Fa miandry Ilay ary.&quot;
 &quot;Mpivahiny ! mba lazao :
 Iza no andraisanao ?&quot;
 &quot;Jeso, Havako arý,
 No andrasako aty.&quot;

[V2]
 &quot;Mpivahiny ! mba lazao :
 Aiza no halehanao ?&quot;
 &quot;Lalana ety avokoa
 Sady sarotra tokoa.&quot;
 &quot;Mpivahiny ! mba lazao :
 Iza no harahinao ?&quot;
 &quot;Jeso, Zoky be fitia,
 Tsy mamela mba hania.&quot;

[V3]
 Mpivahiny ! mba lazao :
 Aiza no hodianao ?&quot;
 &quot;Ao an-danitra madio
 No aleha ankehitrio.&quot;
 &quot;Mpivahiny ! mba lazao :
 Iza no handray anao ?&quot;
 &quot;Jeso, Ilay Mpanjaka soa,
 Tompo, Havako tokoa.&quot;</lyrics>
<title>Mpivahiny! mba lazao FFPM505</title>
<hymn_number>505</hymn_number>
<author>G.J. Elvey</author>
</song>