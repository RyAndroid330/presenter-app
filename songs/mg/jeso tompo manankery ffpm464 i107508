<?xml version="1.0" encoding="UTF-8"?><song><author>E.W. Bullinger</author>
<hymn_number>464</hymn_number>
<title>Jeso Tompo manan-kery FFPM464</title>
<lyrics>[V1]
 Ry Tompo manan-kery,
 Miarova anay !
 Ry mpitady ondry very,
 Mamonje anay !

[V2]
 Jeso Tompo be fitia,
 Mitsinjova anay !
 Ny fanahinay mania,
 Miantrà anay !

[V3]
 Jeso Tompo be fiantra,
 Mijere anay !
 Ny fanahinay mahantra,
 Mitahia anay !

[V4]
 Jeso Tompo mahalala,
 Mananara anay !
 Ny fanahinay adala,
 Mitariha anay !</lyrics>
</song>