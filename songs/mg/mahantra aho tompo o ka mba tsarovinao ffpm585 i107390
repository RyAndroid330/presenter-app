<?xml version="1.0" encoding="UTF-8"?><song><author>C.G. Glaser</author>
<hymn_number>585</hymn_number>
<lyrics>[V1]
 Mahantra aho, Tompo ô !
 Ka mba tsarovinao
 Maniry ho madio fo
 Sy mendrika Anao.

[V2]
 Manolo-tena aho izao,
 Ry Jeso Tompo ô !
 Ka aza dia lavinao
 Izay atolotro.

[V3]
 Izaho voasoratrao
 Ao amim-bokinao
 Ho isan'ny mpianatrao
 Hianatra aminao.

[V4]
 Ataovy izay hahaizako
 Hanaraka Anao
 Amin'ny fahadiovam-po
 Ho voninahitrao.</lyrics>
<title>Mahantra aho Tompo o ka mba tsarovinao FFPM585</title>
</song>