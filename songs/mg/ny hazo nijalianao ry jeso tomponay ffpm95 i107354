<?xml version="1.0" encoding="UTF-8"?><song><author>Mendelssohn-Bartholdy</author>
<hymn_number>95</hymn_number>
<title>Ny hazo nijalianao ry Jeso Tomponay FFPM95</title>
<lyrics>[V1]
 Ny hazo nijalianao,
 Ry Jeso Tomponay !
 Maneho ny fitianao.
 Dia iankinanay, (in-3) *
 Maneho ny fitiavanao.

[V2]
 Mitazana ny masonay,
 Mangoraka ny fo ;
 Na meloka aza izahay.
 Ny teninao ho to. (in-3) *
 Na meloka aza izahay.

[V3]
 Ny avotr'aina vitanao
 No itokianay ;
 Ny entanay voaesotrao.
 Ka afaka izahay. (in-3) *
 Ny entanay voaesotrao.

[V4]
 Ny hazo nihomboanao
 Dia voninahitray;
 Ny nanalam-baraka Anao
 No isandratanay ! (in-3) *
 Ny nanalam-baraka Anao.
 *) Ho an'ny feony (1) ihany</lyrics>
</song>