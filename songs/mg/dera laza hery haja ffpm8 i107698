<?xml version="1.0" encoding="UTF-8"?><song><title>Dera, Laza, Hery, Haja FFPM8</title>
<lyrics>[V1]
 Dera, Laza, Hery, Haja,
 Ho an'Andriamanitra
 Tompon'aina, Zanahary,
 Rain'ny voninahitra,
 Izy no mpanao antsika,
 Sady ivelomana;
 Fototr'aina, foto-tsoa,
 Izy ivavahana.
 Hihira isika hoe : Haleloia!
 Dera ho an'Andriamanitra
 // Dia Haleloia! Haleloia! //

[V2]
 Ray Tsitoha, tsy miova,
 Tia sy mamindra fo,
 Mahasoa isan'andro,
 Izy no isaorana;
 Vatolampy tsy mifindra,
 Tokin'olombelona;
 Fiarova-mahavonjy,
 Izy itokiana
 Hihira isika hoe : Haleloia!
 Dera ho an'Andriamanitra
 // Dia Haleloia! Haleloia! //</lyrics>
<hymn_number>8</hymn_number>
</song>