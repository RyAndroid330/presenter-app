<?xml version="1.0" encoding="UTF-8"?><song><title>FA MANDRAKIZAY NY FAMINDRA-MPONY ASAFA4</title>
<lyrics>[V1]
 Miderà fa tsara Jehovah
 Miderà ny Avo Indrindra
 Miderà ny Tompo'ny tompo
 Mpanao fahagagana lehibe
 Izy no nanao ny lanitra
 Tamim-pahendrena lalina
 Ka ny tany novelarina
 Teo ambony ranomasina</lyrics>
<hymn_number>4</hymn_number>
<author>Landy RABENIRAINY</author>
</song>