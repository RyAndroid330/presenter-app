<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>692</hymn_number>
<title>He! Misy tany soa FFPM692</title>
<lyrics>[V1]
 He ! misy tany soa
 Izay tsy atý ;
 Maro ny olona
 Faly arý ;
 Tsara fonenana
 Sambatra sy tretrika
 Sady finaritra
 Izay mponina ao.

[V2]
 Aza sondriana
 Foana atý ;
 O ! miomàna re
 Mba ho arý ;
 Be fiadanana,
 Tsara fitoerana,
 Be haravoana
 Izay mponina ao.

[V3]
 Mafy izay manjo
 Hita atý,
 Ka misikìna re
 Mba ho arý ;
 Jeso mitandrina,
 Sy mitahy fatratra
 Ary mahenina
 Izay mponina ao.

[V4]
 Aza variana
 Foana atý ;
 O ! miaingà izao
 Mba ho arý ;
 Jeso Sakaizanao
 No Mpitari-dalana,
 Ka dia hitondra anao
 Ho tonga ao.</lyrics>
</song>