<?xml version="1.0" encoding="UTF-8"?><song><title>Ry Andriamanitry ny famonjena FFPM602</title>
<lyrics>[V1]
 Ry Andriamanitry ny
 famonjena,
 Sy Kintana antenain'ny
 firenena,
 Henoy ny fangataham-
 pandresena,
 Ry Ray Tsitoha !

[V2]
 Ilay fitopaton'alondrano
 Sy reharehan-drafinao foano !
 Ny olonao mahantra
 mba tantano,
 Ry Ray Mpiaro !

[V3]
 Raha osa, Hianao mahay
 mitana,
 Raha reraka
 asiam-pahotana,
 Ny herinao
 tsy resin'i Satana,
 Ry Ray Mahery !

[V4]
 Ampionao izahay
 handresy rafy,
 Ampionao mba haharitra
 ny mafy,
 Ampionao tsy ho ketraka
 mihafy,
 Ry Ray Mpanampy !</lyrics>
<author>F.F. Flemming</author>
<hymn_number>602</hymn_number>
</song>