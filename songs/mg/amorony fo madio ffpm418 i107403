<?xml version="1.0" encoding="UTF-8"?><song><author>Ph. Razafindraraoty</author>
<hymn_number>418</hymn_number>
<title>Amorony fo madio FFPM418</title>
<lyrics>[V1]
 Amorony fo madio
 Aho, ry Jehovah ô !
 Ka havaozinao anio
 Ny fanahiko izao.
 Be ny ratsy vitako
 Ka ny heloko sasao ;
 Mamindrà fo amiko,
 Ry Jehovah Tompo ô !

[V2]
 Amorony fo madio
 Aho, ry Jehovah ô !
 Ka diovy ankehitrio
 Ny fiainako izao.
 Simba ny fanahiko,
 Ka amboary ho vaovao ;
 Aza esorina amiko,
 Ny Fanahy Masinao.

[V3]
 Amorony fo madio
 Aho, ry Jehovah ô !
 Ka ny foko ahitsio,
 Hamasino ho Anao.
 Taminao dia taminao
 No mba nanotàko, Ray ;
 Ka ny heloko avelao
 Ny fanahiko ovay.

[V4]
 Amorony fo madio
 Aho, ry Jehovah ô !
 Ka ny fo omeko anio,
 Raiso ho fanananao ;
 Fo mangorakoraka
 Noho ny ratsy izay natao ;
 Fo miaiky heloka,
 Ka mba raiso, Tompo ô.</lyrics>
</song>