<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Tafatsangana tokoa,
 Haleloia !
 Jeso Kristy Tomposoa,
 Haleloia !
 Maty nefa velona
 Haleloia !
 Mihirà, ry olona,
 Haleloia !

[V2]
 Foana ny fasana,
 Haleloia !
 Indro, Jeso velona,
 Haleloia !
 Toky tsy mamitaka,
 Haleloia !
 Mihirà, ry olona,
 Haleloia !

[V3]
 Andro lehibe tokoa,
 Haleloia !
 Andro fihobiana,
 Haleloia !
 Afaka ny tahotra,
 Haleloia !
 Mihirà, ry olona,
 Haleloia !

[V4]
 Haja, laza, aterinay
 Haleloia !
 Jeso ô, Mpanjakanay,
 Haleloia !
 Raiso re ny saotranay,
 Haleloia !
 Raiso koa ny tenanay
 Haleloia !</lyrics>
<title>Tafatsangana tokoa FFPM142</title>
<hymn_number>142</hymn_number>
<author>Lyra Davidica</author>
</song>