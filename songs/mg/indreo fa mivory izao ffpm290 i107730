<?xml version="1.0" encoding="UTF-8"?><song><title>Indreo fa mivory izao FFPM290</title>
<lyrics>[V1]
 Indreto fa mivory izao
 Zatovo vonon-kanavao
 Ilay fanekena tsara ;
 Mba raisonao, Rainay ô !
 Ny fitarainanay izao.
 Omeo toky tsara,
 Henoy, fenoy
 Aim-panahy, mba ho sahy
 Lalandava
 Ho mpanaiky ny mazava.

[V2]
 Mandà ny ratsy izy izao,
 Manaiky fa ho zanakao
 Handia ny lalan'aina ;
 Ry Ray ô ! mba tsarovinao
 Ireto voasoratrao
 Ao amim-bokin'aina ;
 Tezao izao
 Tsy ho resy, fa handresy,
 Ka omeo
 Azy hery mahaleo.

[V3]
 Natsanganao ho zanakao
 Sy ondry mba handrasanao,
 Ka tena sarobidy ;
 Arovy re ny ondrinao,
 Tantano ny malalanao.
 Ry Tompo Izay nifidy
 Anay handray
 Lova soa tsy miova,
 Ka hazony
 Tsy handao Anao intsony !</lyrics>
<hymn_number>290</hymn_number>
<author>Ph. Nicolai</author>
</song>