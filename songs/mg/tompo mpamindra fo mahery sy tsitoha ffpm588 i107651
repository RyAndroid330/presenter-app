<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Tompo Mpamindra fo !
 Mahery sy Tsitoha
 Izay nidina tatý
 Hamonjy ny mania !
 Mivavaka Aminao
 Mifona e ! izahay,
 Ny gadranay tapaho
 Hahafaka anay.

[V2]
 Tompo ô ! Mpanjaka,
 Amin'ny olonao ;
 Faingàna, iantrao
 Ireo izay narovanao
 Miondreha, mijere,
 Izahay niandrandra Anao ;
 Ny herinao anie
 Hatafinao ireo.

[V3]
 Tompo Mpanova fo,
 Mpampionona tokoa,
 Midina ka ampio
 Izahay hahery izao.
 Toky mamy loatra
 No omena anay ;
 Hatrany an-koatra,
 Arovinao izahay.</lyrics>
<title>Tompo Mpamindra fo mahery sy tsitoha FFPM588</title>
<hymn_number>588</hymn_number>
</song>