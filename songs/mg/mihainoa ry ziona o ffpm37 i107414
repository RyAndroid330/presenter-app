<?xml version="1.0" encoding="UTF-8"?><song><author>G.F. Haendel</author>
<hymn_number>37</hymn_number>
<lyrics>[V1]
 Mihainoa, ry Ziona ô !
 Avy ny Mpanjakanao !
 Re hatrany lavitra
 Fa hobin'ny olona.
 Mifalia hianao
 Indro Izy, ka tsenao !

[V2]
 Indro Ilay miakatra
 Mila tsy ho fantatra
 Ho Mpanjaka marina,
 Fa mietry lalina ;
 Izy no Mpanjakanao,
 Ry Ziona ka derao !

[V3]
 Mandrosoa, Tompo ô !
 Mba hanjaka amiko !
 Faly re ny olonao
 Raha tonga Hianao,
 O, hosana, Tomponay !
 Ry Ilay nandrasanay !</lyrics>
<title>Mihainoa ry Ziona, o! FFPM37</title>
</song>