<?xml version="1.0" encoding="UTF-8"?><song><author>J. Cruger</author>
<hymn_number>590</hymn_number>
<lyrics>[V1]
 Kristy Tsitoha, Tomponay
 mahery,
 Mba mitodiha re ny olom-
 bery,
 Ka mamonje anay izay
 mania ;
 O, mba avia !

[V2]
 He, Hianao kiadin'ny mivalo,
 Ka mba reseonao ny fahavalo,
 Ny ta-hanimba ny Anao
 sakano,
 Izahay tantano !

[V3]
 Ny fiangonanao ampiadano,
 Ny tanindrazanay re mba
 tohano
 Ny tena sy fanahinay tahio,
 Ampifalio !

[V4]
 Ny asanao, ry Zana-Janahary,
 Dia manakalaza Anao
 miharihary,
 Ka izahay midera Anao
 Mpamonjy,
 Fa voavonjy !</lyrics>
<title>Kristy Tsitoha, Tomponay mahery FFPM590</title>
</song>