<?xml version="1.0" encoding="UTF-8"?><song><author>J.P. Holbrook</author>
<hymn_number>741</hymn_number>
<lyrics>[V1]
 Jehovah Tompo ô !
 Tahio sy hatsarao
 Ny taninay ;
 Tahio ny namanay
 Ho tia ny teninao,
 Dia mba hazavao
 Ny nosinay.

[V2]
 Ovay ny fombanay
 Ho foin'ny taninay
 Ny sampiny ;
 Omeo fo marina
 Izao rehetra izao,
 Ka dia mba iantrao
 Ny nosinay.

[V3]
 Jehovah Tompo ô
 Tahio ny olonao
 Ny zanakay,
 Tahio ho zanakao
 Tahio ho marina
 Ka dia mba ho taninao
 Ny nosinay.

[V4]
 Izay mpitondra anay
 Tahio ho tia Anao,
 Jehovah ô !
 Omeo sai-marina
 Hanao ny sitrakao,
 Ka ampanompoy Anao
 Ny nosinay.</lyrics>
<title>Jehovah Tompo o! FFPM741</title>
</song>