<?xml version="1.0" encoding="UTF-8"?><song><title>Endrey! Endrey! Tompo o! FFPM768</title>
<lyrics>[V1]
 Endrey ! endrey ! Tompo ô !
 He, ny hasoavanao,
 Fa tsy tapaka hatrany
 Izany fitahianao ;
 Notantananao, ry Tompo
 Itony ondrikelinao.

[V2]
 Endrey ! endrey ! Tompo ô !
 He, ny fitiavanao ;
 Efa elabe tokoa no mba
 niheveranao
 Izany zaza Malagasy
 Izay irinao mba ho soa.

[V3]
 Anio izahay, Tompo ô !
 Mankasitraka Anao,
 Fa ny sandrinao mahery
 No niaro toy izao
 Tratranay mandrakariva
 Ny androm-pahasoavanao !

[V4]
 Tahio tokoa, Jeso ô !
 Madagasikaranay
 Mba handroso ka ho tonga
 Madagasikaranao ;
 Izany re no faniriana
 Ho tanteraka anie !</lyrics>
<hymn_number>768</hymn_number>
<author>E. Husband</author>
</song>