<?xml version="1.0" encoding="UTF-8"?><song><author>Ira D. Sankey</author>
<hymn_number>177</hymn_number>
<lyrics>[V1]
 Ry Fanahy Mpanazava !
 Mitariha anay izao
 ! 'Zay nampanoratinao !
 // Dia hifaly //
 Izahay tarihinao ! (in-2)

[V2]
 Ry Fanahy Mpanazava !
 Maminay ny anatrao,
 Fa matanjaka sy hendry
 'Zay ampianarinao !
 // Hatanjaho //
 Izahay mpianatrao ! (in-2)

[V3]
 Ry Fanahy Mpanazava !
 Aoka tsy hangia anay
 Ny angano sy tantara
 'Zay hamily dia anay !
 // Mba sakano //
 Tsy handavanay Anao ! (in-2)

[V4]
 Ry Fanahy Mpanazava !
 Ny Baiboly taminao
 Dia fanilo sady toky
 Hanatonanay Anao !
 // Mba tsilovy //
 'Zay miankina Aminao (in-2)</lyrics>
<title>Ry Fanahy Mpanazava mitariha anay izao FFPM177</title>
</song>