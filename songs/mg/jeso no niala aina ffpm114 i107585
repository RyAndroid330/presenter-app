<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Jeso no niala aina
 Hanavotany anao,
 // Iza re no tsy hanaiky
 Azy izao ? //

[V2]
 Fa ny lapany ambony
 Nialany fahizay,
 // Hamonjeny olom-bery,
 Very tokoa //

[V3]
 Fa izay manatona Azy,
 Ka mibebaka ao am-po
 // Tsy hariany akory,
 Ka matokia ! //

[V4]
 Mba avia, ry havanay ô !
 Maneke ny Tomponao,
 // Maneke ny Tompon'aina
 Ho Tomponao ! //

[V5]
 Iantrao, ry Tomponay ô !
 Ny mialoka aminao,
 // Raisonao 'zahay mpanota
 Ho olonao ! //</lyrics>
<title>Jeso no niala aina FFPM114</title>
<author>L. Mason</author>
<hymn_number>114</hymn_number>
</song>