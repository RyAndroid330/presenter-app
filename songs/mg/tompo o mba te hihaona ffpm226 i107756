<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>226</hymn_number>
<author>W.B. Bradbury</author>
<lyrics>[V1]
 Tompo ô ! mba te-hihaona
 Aminao ny olonao.
 Ka ny oran-dohataona
 Ampombay ny teninao ;
 Ny Fanahinao iraho
 Aminay izay mitalaho ;
 // Mba vokiso zava-tsoa
 Ny mangetaheta Anao //</lyrics>
<title>Tompo o! Mba te hihaona FFPM226</title>
</song>