<?xml version="1.0" encoding="UTF-8"?><song><title>Manenoa, ry farara FFPM43</title>
<lyrics>[V1]
 (Maintimolaly)

[V2]
 Manenoa, ry farara !
 Horohoroy, ry tany !
 Ka miantsoa ny maty,
 Fa akaiky ny Mpitsara;
 // Indro ! Kristy //
 Avy amin-drahona !

[V3]
 Ny feony no hampifoha
 Ny any am-pasana ;
 Ny teniny no hamory
 Ny velona rehetra ;
 // Samy handray //
 Ny valin'ny nataony.

[V4]
 Ny tsy mino hilazany :
 &quot;Mialà voaozona,
 Mandehana, mitoera
 Ao amin'ny maizina&quot;
 // Ry mpanota //
 Any ny anjaranao.

[V5]
 Fa ny mino hilazany :
 &quot;Avia, notahina,
 Mandrosoa, mankanesa
 Ho amin'ny mazava&quot;
 // Io, ry mpino //
 Indro ! ny anjaranao.</lyrics>
<hymn_number>43</hymn_number>
<author>St. Albans</author>
</song>