<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hosana ! Hosana !
 Hosana !
 Hosana no asandratray
 Ho an'i Jesosy
 Fa Izy no Mpanjakanay
 Sy Tompo tia koa ;
 Hosana no atolotray
 Anao, ry Tomponay !
 Ity no andro Jobily,
 Jobily, Jobily, Jobily,
 Ity no andro Jobily,
 Ka hifalianay !

[V2]
 Hosana ! (in-3) *
 Hosana ho Anao anie,
 Ry Kristy Tomponay !
 Fa avy Hianao tokoa
 Hanjaka aminay !
 Hosana no atolotray, ..sns.

[V3]
 Hosana ! (in-3) *
 Hosana ! fa ho sambatra
 Izay mpanomponao ;
 Tsy hisy fahoriana
 Etý an-taninao !
 Hosana no atolotray, ..sns.

[V4]
 Hosana ! (in-3) *
 Hosana ! fa miomana
 'Zahay vahoakao
 Hitsena Anao Mpanjakanay
 Raha avy Hianao !
 Hosana no atolotray, ..sns.

[V5]
 Hosana ! (in-3) *
 Hosana ! raisonao tokoa,
 Ry Tompo tianay,
 Ny dera, laza, saotra koa,
 Izay aterinay !
 Hosana no atolotray, ..sns.
 *Ho an'ny feo (1) ihany
 NY FANAHY MASINA</lyrics>
<title>Hosana no asandratray ho an'i Jesosy FFPM173</title>
<author>S. Randrianandraina</author>
<hymn_number>173</hymn_number>
</song>