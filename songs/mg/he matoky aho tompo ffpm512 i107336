<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>512</hymn_number>
<author>J. Zundel</author>
<title>He! matoky aho, Tompo FFPM512</title>
<lyrics>[V1]
 He ! matoky aho, Tompo,
 Azoko ny teninao ;
 Teny soa mahafaly,
 Teny avy Aminao.
 He ! matoky aho, Tompo,
 Azoko ny teninao ;
 Teny soa mahafaly
 No omenao ahy izao.

[V2]
 Tahotra amana ahiahy
 Dia ariako izao ;
 Fa nomenao toky aho
 Sady tô ny teninao,
 He ! matoky, ..sns.

[V3]
 Izay rehetra fahotana
 Entiko hesorinao ;
 Hianao no mahadio
 Ka diovy aho izao.
 He ! matoky, ..sns.

[V4]
 Mahasasa, mahadio
 Mahavonjy Hianao,
 Ka mandray sy mahatondra
 Tsara ho ao an-tranonao.
 He ! matoky, ..sns.

[V5]
 Jeso Tompo ! avy aho,
 Avy hankalaza Anao ;
 Raisonao re izay omeko ;
 Vola, tena, aina koa.
 He! matoky, ..sns.</lyrics>
</song>