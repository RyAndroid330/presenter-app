<lyrics>[V1]
 &quot;M&quot; ampiana &quot;I&quot; manao hoe &quot;MI&quot;,
 &quot;T&quot; ampiana &quot;E&quot; manao hoe &quot;TE&quot;,
 &quot;N&quot; ampiana &quot;E&quot; manao hoe &quot;NE&quot;,
 &quot;N&quot; ampiana &quot;A&quot; manao hoe &quot;NA&quot;.
 'Reo rehetra ireo hatambatra,
 Dia manao hoe : &quot;MITENENA&quot;,
 Mitenena Jehovah ô !
 Fa mihaino ny mpanomponao.</lyrics>
