<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>760</hymn_number>
<lyrics>[V1]
 Aza mba manadino ny ray
 sy reninao ;
 Fa izy no nitaiza sy nanasoa
 anao,
 Ka na aiza na aiza aleha
 an-tany lavitra,
 Aza mba manadino ny ray sy
 reninao :
 Tsara izay ! tsara izay !
 Eny, tsy ho hadinonay ny
 ray sy reninay.

[V2]
 Aza mba manadino ny
 Tanindrazanao,
 Tsarovy ny tanàna izay nahabe
 anao.
 Fadio izay tsy mety fanaony
 fahizay.
 Aza mba manadino ny
 Tanindrazanao :
 Tsara izay ! Tsara izay !
 Eny, tsy ho hadinonay ny
 tanindrazanay.

[V3]
 Aza mba manadino ireo
 mpitondra anao,
 Araho ny lalàna mba
 hiadananao.
 Ka na aiza, na aiza aleha
 an-tany lavitra.
 Aza mba manadino izay
 mpitondra anao :
 Tsara izay ! Tsara izay !
 Eny, tsy ho hadinonay izay
 mpitondra anay.

[V4]
 Aza mba manadino ny
 fivavahanao,
 Ataovy isan'andro mba
 hamonjena anao ;
 Mpitondra, ray, sy reny,
 ny tany, tena koa,
 Aza mba manadino ny
 fivavahanao :
 Tsara izay ! tsara izay !
 Eny, tsy ho hadinonay ny
 fivavahanay.</lyrics>
<title>Aza mba manadino ny ray sy reninao FFPM760</title>
</song>