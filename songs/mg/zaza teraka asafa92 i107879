<?xml version="1.0" encoding="UTF-8"?><song><author>Andrianavalona RABENJA</author>
<hymn_number>92</hymn_number>
<lyrics>[V1]
 Zaza teraka,
 Zazalahy nomena ;
 Mba hanafaka
 Ny olona ho vonjena.

[V2]
 Manana Anarana
 'Zay mamelon'aina,
 Dia Mahagaga
 Sy Mpanolotsaina

[V3]
 Anaran-danitra,
 Azy samy irery ;
 Andriamanitra
 Mahery

[V4]
 Rain'ny mandrakizay,
 Andriam-piadanana ;
 'Zay tia hatrizay
 Tsy azo faranana</lyrics>
<title>ZAZA TERAKA ASAFA92</title>
</song>