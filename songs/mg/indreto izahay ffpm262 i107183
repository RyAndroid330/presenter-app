<?xml version="1.0" encoding="UTF-8"?><song><title>Indreto izahay FFPM262</title>
<lyrics>[V1]
 Indreto izahay,
 Ry Jeso ô !
 Manaraka izao,
 Ny hafatrao,
 Ny fahorianao,
 Tsaroanay izao,
 Fa fatratra tokoa
 Ny nentinao.

[V2]
 Ny mofo haninay,
 Ry Jeso ô !
 Milaza aminay
 Ny tenanao ;
 Ny fanavotanao
 Mahafaka anay,
 Fa saotra re izao
 Atolotray.

[V3]
 Misotro ny divay
 Izahay izao
 Hahatsiarovanay
 Ny antranao ;
 Ny ra nilatsaka
 No manadio anay,
 Manafaka tokoa
 Ny olonao.

[V4]
 Tarihonao ny fo,
 Ry Jeso ô !
 Ho tia sy hankatò
 Ny didinao ;
 Ka tsy ny sitrakay,
 Fa ny Anao, Jeso,
 No aoka ho maminay,
 Ry Tompo ô !</lyrics>
<author>A. Sullivan</author>
<hymn_number>262</hymn_number>
</song>