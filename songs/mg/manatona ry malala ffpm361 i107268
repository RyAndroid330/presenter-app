<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Manatòna, ry malala !
 An'i Jeso Tomponao ;
 Raiso re ny famonjena,
 // Tsy ho faty hianao //

[V2]
 Indro Jeso, fa miandry
 Mba handray anao izao ;
 Miverena aza kivy,
 // Mazotoa, sy matokia //

[V3]
 Aza mba mangataka andro,
 Sao dia tratra hariva etý
 Tahotra sy horohoro
 // Hampivadi-po anao //

[V4]
 Ao ny tany soa homeny
 Mampifaly fo erý
 Sady tsy mba misy ratsy,
 // Mandrosoa ho tonga arý //</lyrics>
<title>Manatona, ry malala! FFPM361</title>
<author>F. Voiglander</author>
<hymn_number>361</hymn_number>
</song>