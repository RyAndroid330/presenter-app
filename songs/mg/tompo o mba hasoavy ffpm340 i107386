<?xml version="1.0" encoding="UTF-8"?><song><author>G.C. Tuller</author>
<hymn_number>340</hymn_number>
<lyrics>[V1]
 Tompo ô ! mba hasoavy
 Sy arovy izahay ;
 Tompo ô ! mba aposahy
 Aminay ny tavanao ;
 Tompo, mitodiha anay,
 Dia hiadana izahay ;
 Ray sy Zanaka, Fanahy,
 Mitahia anay, Amen !</lyrics>
<title>Tompo o, mba hasoavy FFPM340</title>
</song>