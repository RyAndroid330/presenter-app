<?xml version="1.0" encoding="UTF-8"?><song><title>Any an-danitra ambony FFPM553</title>
<lyrics>[V1]
 Any an-danitra ambony
 Misy mijery anao ;
 // He, feno antra ny fony,
 Koa mangina izao ! //

[V2]
 Ry rera-po mitomany,
 Jeso onena anao ;
 // Ampy ho toky izany,
 Koa mangina izao ! //

[V3]
 Na dia be ny mahory,
 Izy hiaro anao ;
 // Tsy ho tra-doza akory,
 Koa mangina izao ! //

[V4]
 Mba mahareta miandry,
 Izy hanafaka anao ;
 // Haka anao hodimandry,
 Koa mangina izao ! //</lyrics>
<hymn_number>553</hymn_number>
</song>