<?xml version="1.0" encoding="UTF-8"?><song><author>Ph. Nicolai</author>
<hymn_number>184</hymn_number>
<title>Fanahy Mpanazava anay! FFPM184</title>
<lyrics>[V1]
 Fanahy Mpanazava anay !
 Midina eto aminay,
 Tarihonao ny sainay ;
 Ny alahelonay savao,
 Ny toetray havaozinao,
 Velomy re ny ainay !
 Sento renao
 Mba valio, ka tahio
 Ny mahantra,
 Ry Fanahin'ny Mpiantra !</lyrics>
</song>