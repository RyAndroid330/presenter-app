<?xml version="1.0" encoding="UTF-8"?><song><title>Indrisy ry sakaiza ory fo FFPM569</title>
<lyrics>[V1]
 Indrisy ! ry sakaiza ory fo !
 Holazainao aiza ny manjo ?
 Jeso no Mpamonjy ho anao ;
 Izy mahavonjy, ambarao
 // Azy, ry tra-bonjy !
 ny manjo ao am-po //

[V2]
 Indrisy ! ry mahantra !
 lozanao ;
 Aiza ny Mpiantra ? Indro ao ;
 Jeso hanazava aizim-po,
 Izy hampisava ny manjo ;
 // Soa lalandava
 No hatao aminao //

[V3]
 Harena be an-tany tsy anao ;
 Zava-mora lany ka mandao,
 Nefa indro Jeso Zaranao ;
 Hira no venteso, ka derao
 // Izay nataon'i Jeso
 Ho anao hatrizao //

[V4]
 Ny lanitra mivoha rahateo ;
 Andrandrao ny loha ka jereo !
 Jeso Tompo soa no arý,
 Havanao tokoa hatretý ;
 // Dia mazotoa
 Hiditra ao Hianao //</lyrics>
<author>H.M. Warner</author>
<hymn_number>569</hymn_number>
</song>