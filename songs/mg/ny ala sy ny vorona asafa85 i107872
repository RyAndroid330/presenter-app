<?xml version="1.0" encoding="UTF-8"?><song><title>NY ALA SY NY VORONA ASAFA85</title>
<lyrics>[V1]
 Iza no namorona
 Ny lanitra sy ny tany
 Ny ala sy ny vorona
 Ary ny olombelona ?

[V2]
 Andriamanitra
 Izy no namorona
 Izy no nampisy koa
 'Zao tontolo izao</lyrics>
<author>Patrick J . RAKOTO RAMIARANTSOA</author>
<hymn_number>85</hymn_number>
</song>