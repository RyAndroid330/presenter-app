<?xml version="1.0" encoding="UTF-8"?><song><title>ANKALAZAO ASAFA93</title>
<lyrics>[V1]
 Ankalazao
 Ny fitiavan'Andriamanitra anao
 Fa lehibe tokoa,
 Derao,derao
 Fa tonga ho antsika Ilay Mpanavotra
 Jesosy Tompo soa

[C1]
   : Fa toy izao no nitiavan'Andriamanitra
   Izao tontolo izao, fa nomeny
   Ny Zanany Lahitokana
   Mba tsy ho very izay rehetra
   Izay rehetra mino Azy
   Fa hanana fiainana
   Fiainana mandrakizay

[V2]
 Lazao, lazao
 Ny fitiavan'Andriamanitra anao
 Fa lehibe tokoa
 Ka ambarao
 Fa Izy no nanaisotra
 Ny fahotan'izao tontolo izao</lyrics>
<author>Tsy fantatra</author>
<hymn_number>93</hymn_number>
</song>