<?xml version="1.0" encoding="UTF-8"?><song><author>Mendelssohn-Bartholdy</author>
<hymn_number>76</hymn_number>
<lyrics>[V1]
 Miderà anio, ry mino,
 Ny Mpanavotra anareo !
 Manandrata feo hidera
 An'i Kristy, Tompo soa ;
 Zanaky ny vehivavy,
 Nefa Andriananahary ;
 Teraka ho olona,
 Mba hanavotra anareo ;
 Teraka any Betlehema
 'Lay Mpanavotra anareo !

[V2]
 Taitra ny mpiandry ondry,
 Ary koa nivadi-po,
 Tamin'ny anjely maro
 Tonga tany aminy.
 Fa isika tsy ho taitra,
 Fa ho faly sy ho ravo ;
 Sitraky ny Tompo soa
 Nidina nankatý ;
 Teraka any Betlehema
 Jeso Kristy ,Tompo soa !

[V3]
 Aza taitra, matokia,
 Manatòna, mihainoa,
 Mazotoa, ka avia,
 Maneke ny Tompo soa,
 Arahaba, Tomponay ô !
 Tompom-pihavananay,
 Teraka ho Tomponay ;
 Tompon'ny fiainanay ;
 Arahaba, Tomponay !
 Ry Mpanavo-dehibe !</lyrics>
<title>Midera anio, ry mino FFPM76</title>
</song>