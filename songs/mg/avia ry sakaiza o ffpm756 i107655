<?xml version="1.0" encoding="UTF-8"?><song><author>G. Rudd</author>
<hymn_number>756</hymn_number>
<lyrics>[V1]
 Avia ry sakaiza ô !
 Antsoin'ny Mpanjaka izao
 Handray fiadiana
 Hoentina hanafaka.
 Velona ny baikonao,
 Andrandrainay Hianao
 Ka arahinay tokoa,
 Ry Mpandresy ao Ziona !

[V2]
 Ny sabatra atolony
 Dia ny teny masina,
 Ampinga fiarovana
 Mahery ny finoana.
 Velona ny baikonao, ..sns.

[V3]
 Ny vatsy izay atolony
 Dia ny ra sy tenany
 Ho herintsika olony
 Izay miaramilany.
 Velona ny baikonao, ..sns.

[V4]
 Jesosy ô, arahinay
 Ny fiantsoanao anay,
 Ka manampia ny olonao
 Hiady sy handresy izao.
 Velona ny baikonao, ..sns.</lyrics>
<title>Avia, ry sakaiza o! FFPM756</title>
</song>