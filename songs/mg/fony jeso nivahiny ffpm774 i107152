<?xml version="1.0" encoding="UTF-8"?><song><title>Fony Jeso nivahiny FFPM774</title>
<lyrics>[V1]
 Fony Jeso nivahiny
 Nisy zazakely koa
 Tonga tao, ka notahiny
 Sy noraisiny tokoa :
 // He, rankizy !
 Hy fitiavan-dehibe //

[V2]
 Manatòna, izao, rankizy !
 An'i Jeso Tompo soa,
 Fa mandray ny zaza Izy
 Ka mitahy azy koa :
 // He, rankizy ! ..sns. //

[V3]
 Maro be ny zaza faly
 Ao an-dapan-dRainy ao,
 Afaka ota, afa-jaly,
 Sambatra izay tonga ao :
 // He, rankizy ! ..sns. //

[V4]
 Mihobia izao, rankizy !
 Fa isika koa hankao ;
 Eny, mifalia, fa Izy
 Ho Sakaizantsika ao :
 // He, rankizy ! ..sns. //</lyrics>
<hymn_number>774</hymn_number>
</song>