<?xml version="1.0" encoding="UTF-8"?><song><author>W.H. Doane</author>
<hymn_number>579</hymn_number>
<title>Aza mba mandao ahy ry Mpamonjy o FFPM579</title>
<lyrics>[V1]
 Aza mba mandalo ahy,
 Ry Mpamonjy ô !
 Aza mba manary ahy,
 Jeso Tompo ô !
 Ry Mpanjaka, mihainoa re !
 Mamonje fa mitaraina
 Ny vahoakao.

[V2]
 Fantatrao fa malahelo
 Ny mpanomponao ;
 Raha mbola eto aho,
 Mba tsinjovinao.
 Ry Mpanjaka, ..sns.

[V3]
 Indro ! fa miandry eto
 Ny navotanao ;
 Aoka tsy mba halahelo,
 Mba falio izao.
 Ry Mpanjaka, ..sns.

[V4]
 Eny, manomeza hery
 Mba ho ahy re,
 Ka hahery sy handresy
 Ny mpanomponao.
 Ry Mpanjaka, ..sns.</lyrics>
</song>