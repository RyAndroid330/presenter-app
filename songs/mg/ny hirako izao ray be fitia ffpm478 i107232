<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>478</hymn_number>
<author>J.B. Dykes</author>
<title>Ny hirako izao Ray be fitia FFPM478</title>
<lyrics>[V1]
 Ny hirako izao,
 Ray be fitia,
 Ny ho akaikinao
 Bebe kokoa,
 Izay re no hirako,
 Mandra-pahafatiko ;
 // Akaikinao //

[V2]
 Raha mba sarotra
 Ny diako
 Ka zary maizina
 Ny làlako,
 Ry Ray ! akaikinao
 No tian'ny zanakao :
 // Akaikinao //

[V3]
 Ao no hiseho re
 Ny tohatra
 Mba hanatonako
 Ny lanitra,
 Anjely miantso ahy
 Akaikinao, ry Ray !
 // Akaikinao //

[V4]
 Ny fahoriana
 Sy loza koa,
 Raha eo anilanao
 Dia mody soa,
 Ka dia tano aho
 Ho ao akaikinao ;
 // Akaikinao //

[V5]
 Na dia hilentika
 Ny androko,
 Ary izao hita izao
 Hilaozako,
 Mbola ho hirako
 Ry Andriamanitro !
 // Akaikinao //</lyrics>
</song>