<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mivory eto izahay,
 Handre ny teninao
 Izay hambara aminay,
 Andriamanitra ô !

[V2]
 Tolory fahendrena,
 Ka ampio ny irakao,
 Izay hitory aminay
 Ny teninao izao.

[V3]
 Ny fon'izay mihaino koa
 Sokafy rahateo,
 Ho tia sy hirakitra
 Ny teny mahasoa.</lyrics>
<title>Mivory eto izahay, handre FFPM243</title>
<author>N. L. von Zinzendorf</author>
<hymn_number>243</hymn_number>
</song>