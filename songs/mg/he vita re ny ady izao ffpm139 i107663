<?xml version="1.0" encoding="UTF-8"?><song><author>G. Palestrina</author>
<hymn_number>139</hymn_number>
<lyrics>[V1]
 Haleloia ! haleloia !
 Haleloia !
 He ! vita re ny ady izao !
 Ny ota efa resy re,
 Ny feo mifaly no atao,
 Haleloia !

[V2]
 Fahafatesana no tao
 Fa Kristy naharesy izao,
 Ny fandreseny no derao,
 Haleloia !

[V3]
 Ny andro nijaliana e !
 Nisolo fifaliam-be,
 Ka mihirà izay mandre :
 Haleloia !

[V4]
 Ny gadra voatapany,
 Ny efitra efa ravany ;
 Ka miderà ny heriny
 Haleloia !

[V5]
 Ry Tompo ô ! ny fiainanao,
 Mamelona ny olonao,
 Ka hoderaina Hianao :
 Haleloia !</lyrics>
<title>He! Vita re ny ady izao! FFPM139</title>
</song>