<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hosana! Hosana!
 Ho an'ny Zanak'i Davida
 Hosana, Hosana
 Ho amin'ny Avo Indridnra
 Isaorana anie
 Izay avy amin'ny Anaran'i Jehovah
 Andriamanitra mahery
 Hatramin'ny taloha indrindra
 Ka mandrakizay</lyrics>
<title>HOSANA HO AN'NY ZANAK'I DAVIDA ASAFA84</title>
<hymn_number>84</hymn_number>
<author>Patrick J . RAKOTO RAMIARANTSOA</author>
</song>