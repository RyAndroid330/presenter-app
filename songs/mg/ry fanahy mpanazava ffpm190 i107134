<?xml version="1.0" encoding="UTF-8"?><song><title>Ry Fanahy Mpanazava FFPM190</title>
<lyrics>[V1]
 Ry Fanahy Mpanazava !
 Miandrandra Anao izahay !
 Aza ela, fa tongava,
 Taomy ny fanahinay,
 Mba ho fantatray mazava
 Izay lazain'ny teninao ;
 Areheto lalandava
 Ao am-po ny afonao.

[V2]
 Ry Jesosy ! mitenena
 Araka ny fombanao,
 Aminay izay manantena
 Mba handre ny teninao ;
 Fo marary sy manahy
 Mba tsaboy sy iantrao ;
 Ny te-hino fa tsy sahy,
 Anehoy ny holatrao !

[V3]
 Rainay, Mpanome ny soa,
 Mba henoy ny hatakay
 Ka ny tananao tsy toha
 Iarovinao anay ;
 Ny tanora mba tahio,
 Ny vaventy hafanao,
 Mba ho hitanay anio
 Fa atý ny tenanao !</lyrics>
<hymn_number>190</hymn_number>
<author>Elevine Heede</author>
</song>