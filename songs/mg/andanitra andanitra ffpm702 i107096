<?xml version="1.0" encoding="UTF-8"?><song><title>An-danitra, an-danitra FFPM702</title>
<lyrics>[V1]
 An-danitra, an-danitra
 Tempolin'i Jehovah,
 No hahitàna Azy, re
 Am-boninahitra !
 // Ka masina i Jehovah //
 No hohiraina ao.

[V2]
 An-danitra, an-danitra
 No mba hamiratra
 Ny voninahi-dehibe
 Hananantsika e !
 // Raha tonga
 ny fihaonana //
 Ao amin'ny Jehovah.

[V3]
 An-danitra, an-danitra
 No ho finaritra
 Ny tena izay nijaly be
 Am-pahoriana
 // Fa any no hifaly e //
 Fahasambarana.

[V4]
 Ny fo sy ny fanahy e,
 No faly anie,
 Fa afaka ny entana,
 Izay nivesarany ;
 // Ka fitsaharan-dehibe //
 Omen'i Jehovah..

[V5]
 Tsy hain'ny lela anie
 Hanonona izao
 Ny soa antenaina e,
 Raha Anatrehany,
 // Manenika ny lanitra //
 Ny fitiavany.

[V6]
 Ry Jeso Kristy Tomponay
 Tariho izahay,
 Ka mamelà ny helokay,
 Mba hitokianay,
 // Fa tsy ho menatra
 izahay //
 Fa ao i Jehovah.

[V7]
 Raha avy ny hodianay
 Ho anatrehany
 Tariho izahay,
 Mba ento, Jeso, izahay
 Hankany Aminy !
 // Mba ho anay
 mandrakizay //
 Ny fitsaharana !</lyrics>
<hymn_number>702</hymn_number>
</song>