<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ity fonenana ity
 Tsy manam-pitsaharana ;
 Maniry aho ho arý
 An-koatry ny fasana ;
 Ny lanitra no hitodiako,
 Fa tena tanindrazako.

[V2]
 Kanefa mahatahotra
 Ny ranobe alehako,
 Fa ny tafio-drivotra
 Manohitra ny samboko ;
 Ny tselatra, ny kotrokorana,
 Mamely sy mandrahona.

[V3]
 Ny sambon'ny fiainako
 Mamaky onja sarotra,
 Ka amin'ny alehako
 Mitopatopa fatratra
 Ny alondranom-pahoriana,
 Kanefa tsy maninona.

[V4]
 Fa ny Mpamonjy tokana
 Mitarika ny samboko ;
 Ny Tompon'ny fiainana
 Miara-mita amiko,
 Mba ho tafita aho olony,
 Ka honina any aminy.</lyrics>
<title>Ity fonenana ity FFPM558</title>
<hymn_number>558</hymn_number>
</song>