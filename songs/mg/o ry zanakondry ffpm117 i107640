<?xml version="1.0" encoding="UTF-8"?><song><author>Nic. Decius</author>
<hymn_number>117</hymn_number>
<lyrics>[V1]
 (Hiraina in-3 no fanao ity)

[V2]
 O, ry Zanakondry,
 He ! Hianao nijaly ;
 Ory, voahombo,
 Anefa tsy namaly ;
 Ny helokay nalainao,
 Ka maty re ny ainao.

[V3]
 Mba iantrao izahay, ry Jeso !

[V4]
 Ampiadanonao izahay re !</lyrics>
<title>O, ry Zanak'ondry! FFPM117</title>
</song>