<?xml version="1.0" encoding="UTF-8"?><song><title>Rehefa vita ny asako ety FFPM518</title>
<lyrics>[V1]
 Rehefa vita ny asako etý
 Ka ny fanahiko raisina erý,
 Miara-mitoetra Aminao,
 Tomponay,
 No hasambarako
 mandrakizay
 Mandrakizay, sambatra re,
 Azoko ilay fahasambarana
 be !

[V2]
 Rehefa ataoko veloma ny etý
 Ka azoko 'lay paradisa erý,
 Sady mahita ny tavan'ny Ray
 No fahasambarako
 mandrakizay ;
 Mandrakizay, ..sns.

[V3]
 Miombom-pahasambarana
 arý
 Amin'ireo olon-tiako tatý
 Ka tsy misaraka mandrakizay
 No hasambarako
 mandrakizay ;
 Mandrakizay, ..sns.</lyrics>
<hymn_number>518</hymn_number>
<author>Ch. H. Gabriel</author>
</song>