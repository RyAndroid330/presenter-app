<author>Swedish melody, Zionstoner</author>
<title>Mba tsarovy re rankizy FFPM793</title>
<lyrics>[V1]
 Mba tsarovy re, rankizy
 Ao am-piangonana,
 // Tsy hatory fa haniry
 Mba ho zaza maotina //

[V2]
 Tonga ao Jesosy Tompo,
 Ka mihaino vavaka ;
 // Ny manatona hanompo
 Raisiny ho zanaka //

[V3]
 Mba hirao ny fiderana,
 Ka ezaho mafy hoa :
 // &quot; Arahaba re, hosana !
 Ry Mpanjaka lehibe &quot; //

[V4]
 Eny, Tompontsika Izy,
 Tompo tsara, mora fo,
 // Ka hatoninao, rankizy,
 O ! hatòny eram-po //

[V5]
 Aza mba misalasala,
 Atolory izao ny fo,
 // Fa ny Tomponao malala
 Faly ta-hamindra fo //

[V6]
 Ry Mpamonjiko mahery,
 Raiso aho ho Anao,
 // Raiso ho Anao irery,
 Raiso re, ka anjakao //</lyrics>
</song>