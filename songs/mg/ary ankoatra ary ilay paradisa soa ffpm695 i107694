<?xml version="1.0" encoding="UTF-8"?><song><author>J. Cruger</author>
<hymn_number>695</hymn_number>
<lyrics>[V1]
 Arý an-koatra arý
 Ilay Paradisa soa
 Toa takona atý,
 Kanefa ao tokoa,
 Mamirapiratra ao,
 Ny endriky ny Ray ;
 Jesosy Tompo ao
 Miandry mba handray.

[V2]
 Tsy misy ny hanjo
 Izay tafiditra ao ;
 Ny ranomaso koa
 Tsy afaka hankao
 Ny hazavana soa
 Manelatrelatra ao ;
 Ny zava-mahasoa
 Tsy misy izay tsy ao.

[V3]
 Anjely marobe
 Mihira any koa ;
 Ireo olo-masina e
 Mifaly avokoa.
 Andeha re izao,
 Sakaiza marobe,
 Ario ny tahotrao,
 Ka dia mizora re !

[V4]
 Raha misy loza etý,
 Jereo ny Tomponao ;
 Fa izy raha tetý
 Nitondra toy izao.
 Ireo fahoriana atý
 Odio tsy hita re,
 Handraisantsika arý
 Ny fiadanam-be.</lyrics>
<title>Ary an-koatra ary ilay Paradisa soa FFPM695</title>
</song>