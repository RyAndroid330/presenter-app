<?xml version="1.0" encoding="UTF-8"?><song><title>He, alina indray izao FFPM723</title>
<lyrics>[V1]
 He, alina indray izao,
 Jesosy Tompo ô ,
 Ka aoka ny mpanomponao
 // Homban'ny elatrao //

[V2]
 Fa iza no hahita anay,
 Raha azon-doza izao,
 Kanefa kosa aronay
 // Ireo anjelinao //

[V3]
 Ka raha hatory izahay,
 Ry Rainay tsara ô !
 Ny tena sy fanahinay
 // Dia mba arovinao //

[V4]
 Ka raha haposakao indray
 Ny masoandronao,
 Fohazy tsara izahay
 // Hisaoranay Anao //</lyrics>
<hymn_number>723</hymn_number>
</song>