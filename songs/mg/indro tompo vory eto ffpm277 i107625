<?xml version="1.0" encoding="UTF-8"?><song><title>Indro, Tompo, vory eto FFPM277</title>
<lyrics>[V1]
 Indro, Tompo, vory eto
 Anatrehanao izahay,
 Mba hanatitra ireto
 Vokatry ny asanay,
 // Raiso re, raiso re !
 Ho fanati-tsitrakao //

[V2]
 Hianao no mampaniry
 Sy mampisy vokatra ;
 Izahay dia mpitahiry,
 Fa Anao ny zavatra.
 // Raiso re, ..sns. //

[V3]
 Ary na tsy mendrika aza,
 Aoka tsy holavinao,
 Fa ho enti-mankalaza
 Ny Anaran-tsoanao.
 // Raiso re, ..sns. //

[V4]
 Raiso koa re, ry Tompo,
 Ho Anao ny tenanay,
 Amboary ho mpanompo
 Mahafatra-po izahay.
 // Raiso re, ..sns. //</lyrics>
<author>Wm. Stevenson</author>
<hymn_number>277</hymn_number>
</song>