<?xml version="1.0" encoding="UTF-8"?><song><author>J.H. Burke</author>
<hymn_number>285</hymn_number>
<lyrics>[V1]
 Mivory maro eto
 Izahay navotanao,
 Ny saotranay no ento
 Ho voninahitrao ;
 Mifaly sy mihoby
 Mandray ny irakao,
 Ka eto no mitoby
 Mangataka aminao.

[V2]
 Ry Kristy tena Andry
 Sy Vatolampinay !
 Ry Lohan'ny mpiandry
 Sy Tompo tokinay !
 Tohano mba hijoro
 Ity mpanomponao,
 Tinendry ho mpanoro,
 Mpilaza hafatrao.

[V3]
 Handray ny asa mafy,
 Koa aza ilaozanao ;
 Hitory, ho mpamafy,
 Ka dia mba hazavao.
 Vokiso lalandava
 Ny saina tianao ;
 Omeo ny andro lava
 Hanao ny asanao.

[V4]
 Tahio mba ho salama
 Hahefa ny anao,
 Ho iraka mafana
 Ampian'ny herinao ;
 Mandrava manda mafy
 Mba hampanjaka Anao,
 Koa aoko mba hihafy,
 Fa izay no sitrakao.

[V5]
 Ny fitaizam-panahy
 Adidy lehibe,
 Ampio mba tsy hanahy
 Ny asa maro be,
 Ka dia tahio ny asa
 Hataony ho Anao ;
 Ny fony no mikasa
 Hanoa izay didinao.</lyrics>
<title>Mivory maro eto 'zahay navotanao FFPM285</title>
</song>