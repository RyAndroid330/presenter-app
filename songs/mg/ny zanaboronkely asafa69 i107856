<?xml version="1.0" encoding="UTF-8"?><song><author>Henri Samuel RALAMBONDRAINY /S.W. STRAUB</author>
<hymn_number>69</hymn_number>
<lyrics>[V1]
 Ny zana-boronkely re
 Raha sendra latsaka,
 Vonjen'Andriamanitra,
 Arovany tokoa.

[C1]
   Izaho koa dia tiany na kely aza re,
   Jesosy Tompo Lehibe Mpiaro ahy koa.

[V2]
 Tantely ary vitsika
 Sy lolo kely koa,
 Dia tian'Andriamanitra,
 Omeny zava-tsoa .

[V3]
 Ny voninkazo he! Jereo
 Tafiany tsara ery
 Omeny fofo-manitra
 Ka tretrika tokoa

[V4]
 Nomeny ray sy reny koa
 Izaho kely ity,
 Nomeny ny Mpamonjy koa
 Ka faly fo ery.</lyrics>
<title>NY ZANA-BORONKELY ASAFA69</title>
</song>