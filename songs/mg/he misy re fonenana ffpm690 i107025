<?xml version="1.0" encoding="UTF-8"?><song><title>He! Misy re fonenana FFPM690</title>
<lyrics>[V1]
 He ! misy re fonenana ;
 // Tsara e ! //
 Kanefa tsy mba lavitra ;
 // Tsara e ! //
 Ny trano ao voavoatra ;
 Ho an'izay mangataka ;
 Fa Jesosy no Tompony,
 // Tsara e ! //

[V2]
 Tsy misy fahoriana ao ;
 // Tsara e ! //
 Tsy misy alahelo ao ;
 // Tsara e ! //
 Ny ota tsy tafiditra ao,
 Ny devoly tsy monina ao,
 Fa ny anjely masina ;
 // Tsara e ! //

[V3]
 Ny Tompo dia miantso anao ;
 // Tsara e ! //
 Ny teniny henoinao ;
 // Tsara e ! //
 &quot; Avia atý ry zanako !
 Ka mibebaha re anio,
 Tsy misy 'zay holaviko &quot;
 // Tsara e ! //

[V4]
 Efa azonay ny santatra ;
 // Tsara e ! //
 Voavelany ny heloka ;
 // Tsara e ! //
 Ho any faingana izahay,
 Fa Kristy manome anay
 Fiainana mandrakizay ;
 // Tsara e ! //</lyrics>
<hymn_number>690</hymn_number>
</song>