<?xml version="1.0" encoding="UTF-8"?><song><title>Raiso ho Anao ny foko FFPM443</title>
<lyrics>[V1]
 Raiso ho Anao ny foko,
 Ry Jehovah Raiko ô !
 Mitoera atý am-poko
 Mba ho tompon-
 trano ao,
 // O, ry Raiko !
 Mitoera ao izao //

[V2]
 Raiso ho Anao ny foko,
 Ry Jesosy Tompo ô !
 Tsy mba vola, fa ny foko
 No atolotro Anao :
 // Raiso, Tompo !
 Fa fanati-tsitrapo //

[V3]
 Raiso ho Anao ny foko,
 Ry Fanahy Masina ô !
 Hazavao ny ao am-poko,
 Diovy ho tempolinao :
 // Indro, raiso !
 Itokany ho Anao //

[V4]
 Tsy harindriko ny foko,
 Fa vohako ho anao ;
 Ka midira atý am-poko,
 Manjakà irery ao :
 // Eny, Tompo !
 Raiso aho ho Anao //</lyrics>
<hymn_number>443</hymn_number>
</song>