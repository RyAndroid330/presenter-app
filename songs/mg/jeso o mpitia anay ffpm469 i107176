<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>469</hymn_number>
<author>W.B. Bradbury</author>
<title>Jeso o, Mpitia anay FFPM469</title>
<lyrics>[V1]
 Jeso ô, Mpitia anay !
 Maminay ny teninao,
 Osa ny fanahinay,
 Fa mahery Hianao ;
 Mamy, ry Jeso ! (in-3)
 Ny fitiavanao.

[V2]
 Jeso ô, Mpitia anay !
 Mahadio Hianao ;
 Ka ny halotoanay,
 Aoka ho voasasanao :
 Mamy, ry Jeso ! ..sns.

[V3]
 Jeso ô, Mpitia anay !
 Tompon'aina Hianao ;
 Maro ny aretinay,
 Nefa samy afakao :
 Mamy, ry Jeso ! ..sns.

[V4]
 Jeso ô, Mpitia anay !
 Aoka hotarihinao ;
 Aza mba mandao anay,
 Mandra-pahafatinay :
 Mamy, ry Jeso ! ..sns.</lyrics>
</song>