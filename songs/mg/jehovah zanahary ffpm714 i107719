<?xml version="1.0" encoding="UTF-8"?><song><author>H.O.C. Zinck</author>
<hymn_number>714</hymn_number>
<lyrics>[V1]
 Jehovah Zanahary,
 Izahay miderà Anao ;
 Ny alina nanjary
 Ho firaketanao.
 Maraina izao ny andro,
 Ka lao ny maizina ;
 Savao, ry Masoandro,
 Izay fahoriana.

[V2]
 Ry Kintan' ny maraina,
 Jesosy Havanay,
 Arovinao ny aina,
 Tahio izahay ;
 Ny asanay anio
 Mba hasoavinao,
 Ny dianay tariho
 Ho any aminao.</lyrics>
<title>Jehovah Zanahary FFPM714</title>
</song>