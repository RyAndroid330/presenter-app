<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>14</hymn_number>
<author>Laza RAHARISON</author>
<lyrics>[V1]
 Notiavin'Andriamanitra fatratra
 Izao tontolo izao
 Ka nomeny ny Zanany Lahitokana
 Jesosy Kristy
 Fanomezana 'Zay tsara indrindra
 No atolotra antsika anio
 Fanomezana tsy manampaharoa Jesô
 Mahasambatra
 2-Lay Jesô 'Zay tonga ho antsika
 Dia nanetry tena
 Nefa Zanaky ny Avo Tompo Lehibe
 Sy Mpanavotra
 Koa izay rehetra nandray Azy
 Dia tonga zanaky ny Ray
 Manana fiainana tena maharitra
 Mandrakizay</lyrics>
<title>FITIA FATRATRA ASAFA14</title>
</song>