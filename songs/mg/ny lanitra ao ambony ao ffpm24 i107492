<?xml version="1.0" encoding="UTF-8"?><song><title>Ny lanitra ao ambony ao FFPM24</title>
<lyrics>[V1]
 Ny lanitra ao ambony ao,
 // Andriamanitra ô !
 Izay rehetra vitanao
 Dia mahagaga anay. (in-3) //

[V2]
 Ny volana aman-kitana,
 // Ny masoandro koa,
 Ny tany aman-danitra,
 Mitory avokoa. (in-3) //

[V3]
 Ny andro amana alina,
 // Milaza aminay
 Fa hendry Andriamanitra,
 Jehovah Tomponay. (in-3) //

[V4]
 Ny tenanay, fanahy koa,
 // Dia avy taminao
 Ka mampiseho tsara koa
 Ny voninahitrao. (in-3) //

[V5]
 Izay rehetra vitanao,
 // Atý sy any koa
 Miara mankalaza Anao
 Fa Tompony tokoa. (in-3) //</lyrics>
<hymn_number>24</hymn_number>
<author>T. Jarman</author>
</song>