<?xml version="1.0" encoding="UTF-8"?><song><title>Lasa ny Mpanavotsika FFPM147</title>
<lyrics>[V1]
 Lasa ny Mpanavotsika
 Ao an-danitra arý,
 Mba hanoman-trano tsara,
 Hitoerantsika ao.
 // Mifalia //
 Ho tafiditra ao tokoa !

[V2]
 Lasa ny Mpisorontsika,
 Ao an-danitra arý,
 Ho Mpisolovava koa,
 Ho an'olo-marobe.
 // Matokia //
 Tsy ho very hianao.

[V3]
 Lasa ny Mpanjakantsika
 Ao an-danitra arý,
 Mba handray ny fanjakana
 Mety ho anjarany.
 // Mihobia //
 Asandrato re ny feo.</lyrics>
<author>W.L. Viner</author>
<hymn_number>147</hymn_number>
</song>