<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ny tenin'ny Baibolinao Jehovah,
 Fanilo manazava anay ety,
 Manoro koa ny lalam-pamonjena,
 Hizoranay ho tonga soa ary,

[C1]
   Ry boky mpanasoa anay (Baiboly soa)
   Baibolim-pamonjena
   Harena sy fanananay (Harena sy)
   Fanananay tsy azom-bolamena.

[V2]
 Ny Tenin'ny Baibolinao Jehovah,
 Dia sabatra entinay mandresy koa,
 Koa tsy ho resin'ny fakam-panahy,
 Ny manana ny Teny mahasoa.

[V3]
 Ny Tenin'ny Baibolinao Jehovah,
 Dia mofon'aina ivelomanay,
 Sakafo mahatanjaka ny saina,
 Vatsim-panahy mandrakizay.

[V4]
 Isaoranay, isaoranay Jehovah,
 Fa lovanay ny Baiboly soa,
 Hahaizanay mamantatra mazava,
 Ny Fitiavanao anay tokoa.</lyrics>
<title>NY TENIN'NY BAIBOLINAO ASAFA66</title>
<hymn_number>66</hymn_number>
<author>Tsy fantatra</author>
</song>