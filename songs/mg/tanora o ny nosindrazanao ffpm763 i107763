<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>763</hymn_number>
<author>J.R. Sweney</author>
<lyrics>[V1]
 Tanora ô !
 Ny Nosin-drazanao
 Miandry izao
 Manasa anao.
 Ingao anio
 Ilay fanevanao,
 O ! tafio
 Ny herinao.
 O ! mifohaza izao,
 Tafio ny herinao
 Injao ny Nosinao,
 Manantena anao !
 Jereo ny namanao,
 Taninin-doza izao
 O ! vonjeo
 Fa mitoreo.

[V2]
 Avia, jereo
 Ny Fiangonanao ;
 O! mba vonjeo
 Fa mila anao.
 Tanora soa
 No mba ilaina koa
 O ! avia
 Hiara-dia,
 O ! mifohaza ..sns.

[V3]
 Omeo anio
 Ny herinao izao,
 Ka dia falio
 Ireo tapakao.
 Ireo didy soa
 Sy baikon'ny Tsitoha,
 Tanteraho
 Sy hajao.
 O ! mifohaza ..sns.</lyrics>
<title>Tanora o! Ny Nosindrazanao FFPM763</title>
</song>