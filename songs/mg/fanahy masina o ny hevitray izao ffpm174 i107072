<?xml version="1.0" encoding="UTF-8"?><song><author>E. Bunnett</author>
<hymn_number>174</hymn_number>
<lyrics>[V1]
 Fanahy Masina ô !
 Ny hevitray izao
 Ovay ho vao ;
 Vonoy ny otanay,
 Diovinao izahay,
 Ka ny fanahinay
 Onenonao.

[V2]
 Fanahy Masina ô !
 Tsinjovinao izao
 Ny olonao ;
 Mpananatra ô ! ovay
 Ny eritreritray ;
 Ny hadisoanay
 Esorinao.

[V3]
 Fanahy hendry ô !
 Jereo izahay izao,
 Ka hazavao !
 Adala izahay,
 Mania ny hevitray ;
 Dia atoroy anay
 Ny lalanao.

[V4]
 Fanahy Masina ô !
 Mba asehoy izao
 Ny antranao ;
 Be tahotra izahay,
 Henoy ny hatakay,
 Ka ny fanahinay
 Ononinao.</lyrics>
<title>Fanahy Masina o ny hevitray izao FFPM174</title>
</song>