<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>22</hymn_number>
<lyrics>[V1]
 Ry Rainay Izay namorona
 Izao rehetra izao,
 Ny hita sy ny takona
 // Dia asan-tananao //

[V2]
 Ny volana aman-kitana,
 Ny biby marobe,
 Ny ala maitso mavana
 // Hitsaoka Anao anie //

[V3]
 Ny tany sy ny lanitra,
 Ny ranomasina,
 Ireo tendrombohitra
 // Manolo-kasina //

[V4]
 Ny ory sy ny mpanana,
 Dia fototra iray,
 Fa samy asan-tanana
 // Nataonao Tomponay //

[V5]
 Dia saotra no atolotray,
 Anao, ka raisonao,
 Fa fanomezan-ko anay
 // Ny asan-tananao //</lyrics>
<title>Ry Rainay Izay namorona FFPM22</title>
</song>