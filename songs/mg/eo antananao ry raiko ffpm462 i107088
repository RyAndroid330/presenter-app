<?xml version="1.0" encoding="UTF-8"?><song><title>Eo an-tananao, ry Raiko! FFPM462</title>
<lyrics>[V1]
 Eo an-tananao, ry Raiko !
 No apetrako izao
 Ny fiainako rehetra,
 Mba tahio ny zanakao ;
 Marobe ny fahavalo
 Ta-hamely ahy e ;
 Ry Jehovah, Ray Mpiaro !
 Mba arovanao anie.

[V2]
 Raha mbola eto aho,
 Zaza be fisiasia,
 Tia ratsy noho ny soa,
 Ka mandà ny Tompo tia ;
 Aza mba manary ahy,
 Ry Mpamonjy tsy mandao !
 Aza manalavitra ahy,
 Andrao dia takona Aminao.

[V3]
 Na ho lava, na ho fohy
 No hiainako etý,
 Tsy mba sitrako akory
 Ny handà 'zay tendrinao ;
 Raha tonga anio ny andro
 Izay handaozako ity,
 Eo an-tànanao no tiako,
 Raiso aho ho arý.

[V4]
 Eo an tànanao, ry Raiko !
 No apetrako izao
 Aina, tena sy fanahy,
 Mba vonjeo ny Zanakao,
 Ampianaro hahazaka
 Fitondrana tianao ;
 Ilazao mba hahalala
 Fa izao no sitrakao.

[V5]
 Eny Raiko ! mba valio
 Izao fivavako izao,
 E, jereo ka mba tahio
 Izaho miandrandra Anao ;
 Mba sasao ny ranao soa,
 Dia hadio aho izao ;
 Ry Mpamonjy ! mihainoa
 Ny mpanomponao izao.</lyrics>
<hymn_number>462</hymn_number>
<author>S.J. Vail</author>
</song>