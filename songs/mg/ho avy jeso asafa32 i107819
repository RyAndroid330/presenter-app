<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>32</hymn_number>
<author>Samuel RASETAHARISON</author>
<lyrics>[V1]
 Raha ho avy eny an-drahona eny Jeso,
 Moa vonona hitsena Azy ianao ve ?
 Ho avy tampoka tsy hampandre Izy izay,
 Toy ny mpangalatra ny fihavian'indray.

[C1]
   Ho avy Jeso, miambena ianao,
   Tsy mba somonga fa tena ho avy tokoa,
   Fifaliana e! tsy hay tanisaina,
   No ho an'ireo olom-boavonjy.

[V2]
 Fanasana izay fanaperana tokoa,
 No indro, efa novononin'i Jeso,
 'Reo nasaina namaly ny antso tam-po,
 No hiara-mihinana amin'Ilay Tsitoha.</lyrics>
<title>HO AVY JESO ASAFA32</title>
</song>