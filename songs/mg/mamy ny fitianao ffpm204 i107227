<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mamy ny fitianao,
 Ry Jehovah Tompo ô !
 Nahafoy ny Zanakao
 Hanavotanao anay.

[V2]
 Mamy ny antranao,
 Ry Jeso Mpamonjy ô !
 Ta-hamonjy Hianao
 Sy hanafa-keloka.

[V3]
 Mamy ny fitaomanao,
 Ry Fanahy Masina ô !
 Ny Fanahinay ovay
 Hankatò ny anatrao.
 NY SORATRA MASINA,
 TENIN'ADRIAMANITRA</lyrics>
<title>Mamy ny fitianao FFPM204</title>
<author>C.M. von Weber</author>
<hymn_number>204</hymn_number>
</song>