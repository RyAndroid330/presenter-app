<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10</hymn_number>
<author>Ndriana RAMAMONJY</author>
<lyrics>[V1]
 Misaotra Anao 'zahay, ry Ray
 Noho ny fitiavanao
 Ny haizi-kitroka nisy ahy
 Indro, fa nidiranao
 He hazavana lehibe no
 Indro fa naposakao
 Ka ravoravo ery ny fo
 Izay midera Anao

[C1]
   Inona àry no havaliko Anao
   Noho ireo soa efa narotsakao
   He hazavana lehibe no
   Indro, fa naposakao
   Ka ravoravo ery ny fo
   Izay midera Anao

[V2]
 Na dia tsy mendrika, ry Ray
 'Reto te hidera Anao
 Dia notoloranao tokoa
 Ny fanavotan-dehibe
 Na dia mahantra aza re dia
 Novidin'ny Zanakao
 Tamin'ny Rany izay madio
 Mba ho isan'ny Anao

[V3]
 He menatra tokoa ry Ray
 Hifanatrika Aminao
 Kanefa noho ny Zanakao
 Indro fa manatona aho
 Manery ahy 'zany foko
 Resin'ny fitiavanao
 'Lay fo maniry mafy Anao
 Ka indro, anjakao</lyrics>
<title>MISAOTRA ANAO 'ZAHAY, RY RAY ASAFA10</title>
</song>