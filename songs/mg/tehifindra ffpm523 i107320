<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Te-hifindra //
 Aho, ry Jesosy ô !
 Be manjo atý an-tany,
 Fifaliam-be no any
 Aminao, ry Tompo ô.

[V2]
 // Ny anjely //
 Sy ny olo-masina
 Tafahaona ka mihoby :
 Sambatra ny tafatody,
 Faly fa noraisina.

[V3]
 // Faly koa //
 Aho, ry Mpamonjiko.
 Manantena fa hahita
 Ny fonenana ao am-pita,
 Ka handray ny lovako.

[V4]
 // Tsy tamana //
 Aho, amin'ny manjo,
 Fa vahiny atý an-taný
 Ka maniry mba ho any
 Aminao, ry Tompo ô.

[V5]
 // Ao tsy misy //
 Ota na aretina !
 Tsara raha hodimandry,
 Nefa aho te-hiandry
 Ny fetr'andro marina.</lyrics>
<title>Te-hifindra FFPM523</title>
<hymn_number>523</hymn_number>
<author>C. Voigtander</author>
</song>