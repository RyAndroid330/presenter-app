<?xml version="1.0" encoding="UTF-8"?><song><author>L. Mason</author>
<hymn_number>513</hymn_number>
<title>Jeso Sakaizanay FFPM513</title>
<lyrics>[V1]
 Jeso Sakaizanay,
 Jeso anay ;
 Sady tsy mahafoy,
 Jeso anay ;
 Raha ny olona
 Mety mandao anay,
 Jeso no tsy mandao,
 Jeso anay

[V2]
 Jeso Sakaizanay,
 Jeso anay ;
 Izy no Avotray,
 Jeso anay ;
 Maty ny Tomponay
 Noho ny helokay ;
 Afaka izahay,
 Jeso anay.

[V3]
 Jeso Sakaizanay,
 Jeso anay ;
 Izy no aronay,
 Jeso anay ;
 Reraka izahay
 Noho ny adinay,
 Jeso no herinay,
 Jeso anay.

[V4]
 Jeso Sakaizanay,
 Jeso anay ;
 Izy no lalanay,
 Jeso anay ;
 Lalana marina
 Hahatongavanay
 Any an-danitra,
 Jeso anay.

[V5]
 Jeso Sakaizanay,
 Jeso anay ;
 Manana izahay,
 Jeso anay ;
 Jeso Sakaizanay
 No hovantaninay
 Any an-danitra,
 Jeso anay.</lyrics>
</song>