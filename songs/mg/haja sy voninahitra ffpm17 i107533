<?xml version="1.0" encoding="UTF-8"?><song><title>Haja sy voninahitra FFPM17</title>
<lyrics>[V1]
 (Maintimolaly)

[V2]
 Haja sy voninahitra
 Omena an'Andriamanitra,
 Fa Izy ihany no mahefa
 // Izay sitrakin'ny fony //

[V3]
 Masina, tsy azo haratsina,
 Mahery, tsy azo resena ;
 Marina, tsy azo laingaina ;
 // Hendry, tsy azo fitahina //

[V4]
 Ny am-po toy ny am-bava;
 Ny maizina toy ny mazava
 Ny takona toy ny miseho ;
 // Tsy misy àry tsy hitany //

[V5]
 Tsy miova ny fombany ;
 Lehibe ka tsy oharina ;
 Tia, tsy azo arovana ;
 // Miantra, tsy azo ferana //

[V6]
 Saotra amam-bavaka atao
 Dera sy laza ho Azy ;
 Izy no ivavahana
 // Fa anton'izao tontolo
 izao //</lyrics>
<author>Union Harmonist</author>
<hymn_number>17</hymn_number>
</song>