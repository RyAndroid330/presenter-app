<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>230</hymn_number>
<author>Sunday School Union</author>
<title>Mba trotroy ny olona ory FFPM230</title>
<lyrics>[V1]
 Mba trotroy ny olona ory,
 Ry Jesosy Tompo ô !
 Tsy hirenireny saina,
 Fa handray ny teninao.
 // Olona osa, olona osa,
 Ento mora, Tompo ô //

[V2]
 Faly izahay, Jesosy,
 Tratr'izao anio izao,
 Tafavory ka hihaino
 Ny Filazantsaranao.
 // Raisonao re, raisonao re
 Izao fisaoranay izao ! //

[V3]
 Jesosy Tomponay Tsitoha !
 Taomy ny sakaizanay
 Mba ho tonga mpino koa
 Sy hiankina Aminao.
 // Mba tariho, mba tariho
 Izy ho mpanomponao ! //</lyrics>
</song>