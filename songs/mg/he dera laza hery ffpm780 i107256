<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 He, dera, laza, hery,
 Anao, Jeso ô !
 Ny zaza no hilaza
 Ny voninahitrao
 Hianao Mpanjaka tia,
 Hianao no Tomponay
 Izay tonga ho Mpamonjy
 Sy ho Mpisolonay.
 He, dera, laza, hery,
 Anao, ry Jeso ô !
 Ny zaza no hilaza
 Ny voninahitrao.

[V2]
 Midera Anao, ry Jeso !
 Anjely marobe
 Ka izahay an-tany
 Ta hankalaza Anao,
 Toy izay nataon'ny zaza
 Izay tao Jerosalema,
 Nitondra ny rofia
 Ho fanajana Anao.
 He, dera, ..sns.

[V3]
 Raha mbola tsy nijaly
 Hianao, ry Tompo ô !
 Nidera Anao ny zaza,
 Ka faly Hianao ;
 Koa mbola hoderaina
 Hianao ankehitrio,
 Ry Jeso Tompo tia !
 Mandrakizay doria.
 He, dera, ..sns.</lyrics>
<title>He, dera, laza, hery FFPM780</title>
<hymn_number>780</hymn_number>
<author>A. Rossini</author>
</song>