<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Misaora an'i Zanahary
 'Zao olona tontolo izao;
 Dia mankalazà Azy,
 Fa anton'izao rehetra izao

[V2]
 Izay zavatra nomeny
 Mahafaly, mahasoa;
 Toy ny andro fararano,
 Toy ny andro mipoaka.

[V3]
 Dia ampitomboy ny sainay
 Hahalala ny teninao,
 Hahafantatra marina
 Izay sitraky ny fonao.</lyrics>
<title>Misaora an'i Zanahary FFPM2</title>
<hymn_number>2</hymn_number>
<author>Old 19th Cent.</author>
</song>