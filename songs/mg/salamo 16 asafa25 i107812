<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Arovy aho Andriamanitra ô!
 Fa mialoka Aminao
 Tsisy soa ananako oharina Aminao
 'Zany no hifaliako, ravo ny fanahy
 Ianao no anjarako Andriamanitro

[V2]
 Ho be ny fahorian'izay
 Tsy miaiky anao ho Tompo
 Fa eo ankavananao tsisy ahiahy
 Eo anatrehako mandrakariva
 Ianao Jehovah Andriamanitro
 Ianao no Tompo Andriamanitro

[V3]
 ANDRIAMANITRA MPAMORONA</lyrics>
<title>SALAMO 16 ASAFA25</title>
<author>Jean Patrick RAKOTO RAMIARANTSOA</author>
<hymn_number>25</hymn_number>
</song>