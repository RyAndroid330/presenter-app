<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>58</hymn_number>
<author>Fr. Gruber</author>
<title>Alina masina FFPM58</title>
<lyrics>[V1]
 Alina masina
 Tonga ny Mpanavotra ;
 Indro teraka ao Betlehema
 Ny Mpanjakan'ny Jerosalema,
 // Izay Mpamonjy anao //

[V2]
 Alina masina
 Ny anjely midina
 Ka miara-mihoby hoe :
 Indro ny fiadanam-be,
 // Jeso teraka izao //

[V3]
 Alina masina
 Nisehoan'ny Zanaka ;
 Ny mazava niposaka,
 Ka ny tahotra afaka ;
 // Mifalia izao //</lyrics>
</song>