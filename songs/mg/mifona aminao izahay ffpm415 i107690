<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mifona Aminao izahay,
 Andriamanitra ô !
 Mba mamelà ny helokay,
 // Fa diso izahay //

[V2]
 Mivavaka Aminao izahay,
 Ry Jeso Tompo ô !
 Avoty ny ranao izahay,
 // Fa very izahay //

[V3]
 Mangataka Aminao izahay,
 Fanahy Masina ô !
 Velomy ny fanahinay,
 // Fa maty izahay //

[V4]
 Jehovah ô ! Izay iray,
 Kanefa Telo koa,
 Mba atokàny izahay,
 // Ho olonao tokoa //</lyrics>
<title>Mifona aminao izahay FFPM415</title>
<hymn_number>415</hymn_number>
</song>