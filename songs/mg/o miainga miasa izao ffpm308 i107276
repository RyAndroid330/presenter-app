<?xml version="1.0" encoding="UTF-8"?><song><title>O! miainga, miasa izao FFPM308</title>
<lyrics>[V1]
 O ! miaingà, miasà izao,
 Irak'i Jesosy hianao ;
 Ny masoandro miposaka ao
 Mba hanazava ny dianao,
 // Ka dia mazotoa ô //
 O ! miaingà, miasà,
 mitoria,
 Aza ho kivy, fa mba
 mihafia ;
 Dia mba lazao ny nataony
 tatý,
 Mba hanazava ny maizina
 atý.

[V2]
 O ! miaingà, miasà izao,
 Ka afafazo ny voanao
 Ho ao an-tany mahantra ao ;
 Jeso Mpamonjy no aronao
 // Hitahy ny asanao //
 O ! miaingà, .. sns.

[V3]
 O ! miaingà, miasà izao,
 Aoka hiezaka fatratra ;
 Jeso hanambina anao atý
 Mandra-pahazo ny vokatra
 // Izay valin'ny asanao //
 O ! miaingà, .. sns.

[V4]
 O ! miaingà, miasà izao,
 Fa mby akaiky ny Tomponao
 Mba hanome valisoa anao,
 Araka izay voa nafafinao,
 // Ka dia miasa izao //
 O ! miaingà, .. sns.</lyrics>
<hymn_number>308</hymn_number>
<author>P.P. Bliss</author>
</song>