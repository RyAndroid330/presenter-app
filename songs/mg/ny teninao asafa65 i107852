<?xml version="1.0" encoding="UTF-8"?><song><title>NY TENINAO ASAFA65</title>
<lyrics>[V1]
 Ny Teninao, ny Didinao,
 Ray ô ataoko an-kira,
 Tsy hohadinoiko mandrakizay Hosaintsainiko,
 Ny Làlan'ny fahamarinanao
 No finidiko,
 Apetrako eo anatrehako
 Ny Fitsipikao ( Teninao)
 Ny Teninao, ny Didinao,
 Ray ô! ataoko an-kira,
 Tsy hohadinoiko mandrakizay
 Amena !</lyrics>
<hymn_number>65</hymn_number>
<author>Mahefanirina RAKOTOMALALA</author>
</song>