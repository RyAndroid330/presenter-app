<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Izy no lehibe
 Ka hatao hoe Zanaky ny Avo Indrindra,
 Ary Jehovah Andriamanitra Ray,
 Hanome Azy
 Ny seza fiandrianan'i Davida rainy.
 Hanjaka amin'ny
 Taranak'i Jakoba mandrakizay Izy,
 Ary ny fanjakany tsy hanam-pahataperana.</lyrics>
<title>IZY NO LEHIBE ASAFA27</title>
<hymn_number>27</hymn_number>
<author>Landy RABENIRAINY</author>
</song>