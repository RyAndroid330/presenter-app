<?xml version="1.0" encoding="UTF-8"?><song><author>E.J. Hopkins</author>
<hymn_number>143</hymn_number>
<lyrics>[V1]
 Vita izao ny fandresena,
 Haleloia !
 Jeso Kristy no hobiana,
 Haleloia !
 Azo re famonjena,
 Haleloia !
 Verinay tarý Edena
 Haleloia !

[V2]
 Ka izao dia arahabaina,
 Haleloia !
 'Lay Mpanjakanay
 hajaina,
 Haleloia !
 Ka na zovy mitaraina
 Haleloia !
 Misy vonjy azo maina
 Haleloia !

[V3]
 Betlehema niandohana,
 Haleloia !
 Kalvary niafarana,
 Haleloia !
 Fasana tsy nahatana,
 Haleloia !
 Toro teo 'lay menarana
 Haleloia !

[V4]
 Saro-bidy re ny rany !
 Haleloia !
 Ny fitiavany tsy lany
 Haleloia !
 Ny fatoranay vahany,
 Haleloia !
 Ka hobionareo, ry tany
 Haleloia !</lyrics>
<title>Vita izao ny fandresena FFPM143</title>
</song>