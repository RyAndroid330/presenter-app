<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Raha mafy ny manjo,
 Raha be ny hovitray,
 Raha malahelo fo,
 Mihainoa, Jeso ô !

[V2]
 Endrikay notafinao,
 Nentinao ny entanay,
 Nitomany Hianao,
 Mihainoa, Jeso ô !

[V3]
 Mafy ny nanjo Anao
 Nefa tsy mba meloka ;
 Helokay ny nentinao,
 Mihainoa, Jeso ô !

[V4]
 Voahombo Hianao,
 Voatsindron-defona,
 Nandry tao am-pasana,
 Mihainoa, Jeso ô !

[V5]
 Raha ory izahay,
 Ka ny fitarainanay
 Tonga eo an-tsofinao,
 Mihainoa, Jeso ô !

[V6]
 Raha tapitra aminay
 Ny fe-taom-boatendrinao,
 Aza mba mandao anay,
 Mihainoa, Jeso ô !</lyrics>
<title>Raha mafy ny manjo FFPM566</title>
<hymn_number>566</hymn_number>
</song>