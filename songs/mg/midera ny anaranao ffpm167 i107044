<?xml version="1.0" encoding="UTF-8"?><song><author>W. Shrubsole</author>
<hymn_number>167</hymn_number>
<lyrics>[V1]
 Midera ny Anaranao
 'Zahay, ry Tompo ô !
 Ka hira no Ventesinay
 Hoe : haja, saotra, hery,
 Mba raiso ho Anao.

[V2]
 He ! voahombo Hianao
 Nisolo heloka,
 Ka mendrika hanaovanay
 Hoe : haja, saotra, hery,
 Mba raiso ho Anao.

[V3]
 Endrey ! ny fitiavanao
 Endrey ! ny herinao,
 Tra-pamonjena izahay,
 Ka haja, saotra, hery,
 Mba raiso ho Anao.

[V4]
 Raha tonga ao an-danitra
 'Zahay mpanomponao,
 Hitohy re ny hiranay
 Hoe : haja, saotra, hery,
 Mba raiso ho Anao !</lyrics>
<title>Midera ny Anaranao FFPM167</title>
</song>