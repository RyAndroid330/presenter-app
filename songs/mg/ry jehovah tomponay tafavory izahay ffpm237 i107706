<?xml version="1.0" encoding="UTF-8"?><song><author>J.D. Farrer</author>
<hymn_number>237</hymn_number>
<lyrics>[V1]
 Ry Jehovah Tomponay !
 Tafavory izahay ;
 Avy hankalaza Anao
 Izahay vahoakanao.

[V2]
 Faly, ravo izahay
 Noho ny soa azonay ;
 Tonga mba hisaotra Anao
 Izahay voavotrao.

[V3]
 Saotra tsara entinay,
 Hira no asandratray,
 Mba ho fiderana Anao,
 Rain'izao rehetra izao,
 Amen.</lyrics>
<title>Ry Jehovah Tomponay! Tafavory izahay FFPM237</title>
</song>