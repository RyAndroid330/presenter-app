<?xml version="1.0" encoding="UTF-8"?><song><author>Fr. Gruber</author>
<hymn_number>71</hymn_number>
<lyrics>[V1]
 Mihainoa! Mihainoa!
 Ny feon'anjely sambatra,
 Milaza fa vao teraka
 Ny Zanak'Andriamanitra,
 Mihainoa izao!

[V2]
 Mifalia! Mifalia!
 Ry zanak'olombelona,
 Fa tonga Ilay Mpanavotra
 Antsika izay nifatotra,
 Mifalia izao!

[V3]
 Mba omeo! Mba omeo!
 Ny fonao fa angatahiny;
 Ny tenany natolony
 Anao izay malalany;
 Mba omeo izao!

[V4]
 Matokia! Matokia!
 Ka manaraha Azy izao;
 Ilay Mpamonjy be fitia
 Nanetry tena ho anao;
 Matokia izao!</lyrics>
<title>Mihainoa! Mihainoa! FFPM71</title>
</song>