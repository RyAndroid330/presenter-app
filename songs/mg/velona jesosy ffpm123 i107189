<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Velona Jesosy,
 Nitsangana tokoa ;
 Ny kristiana marobe,
 Mihoby sy mihira hoe !
 // Dera ho Anao,
 ry Mpandresy ! //

[V2]
 Velona Jesosy,
 Ny helo dia resy,
 Tanteraka ny avotra,
 Ka afaka ny heloka !
 // Dera ho Anao,
 ry Mpandresy ! //

[V3]
 Velona Jesosy,
 Ka velona isika,
 Hiara-monina Aminy,
 Hohazavain'ny tavany !
 // Dera ho Anao,
 ry Mpandresy ! //</lyrics>
<title>Velona Jesosy FFPM123</title>
<author>L.M. Linderman</author>
<hymn_number>123</hymn_number>
</song>