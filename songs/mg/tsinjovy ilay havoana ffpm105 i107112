<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>105</hymn_number>
<author>A. Ralison</author>
<lyrics>[V1]
 Tsinjovy ilay havoana
 Arý Jerosalema,
 Fa io Golgota !
 Mba tadidio ange !
 Fa tao, nivesatra ny ota
 Ny Tompo Masina
 Nijaly sy nolavina
 Ka novonoina !

[V2]
 Tsy takatra heverina
 Ny entan-dehibe,
 Izay nentin'ny Mpisolo
 Ka mba diniho re !
 Fa nentiny daholo
 Ny heloka natao
 Fa tonga Izy hanavao
 Izao tontolo izao

[V3]
 Ny helotsika koa izao
 Dia nivesarany,
 Ka manaraha Azy,
 Mba ho mpianany !
 Raha tao Golgota Izy,
 Ny rany nitete,
 Ka vita ho antsika re
 Ny vonjy lehibe !
 Ny Ho resy sy ho faty.</lyrics>
<title>Tsinjovy ilay havoana FFPM105</title>
</song>