<?xml version="1.0" encoding="UTF-8"?><song><author>C.C. Balle</author>
<hymn_number>266</hymn_number>
<lyrics>[V1]
 Ry Jeso Tompo, Hianao
 Isaorako tokoa izao,
 Ny ranao sy ny tenanao
 No nihinanako izao.

[V2]
 Ry foko faly, ambarao
 Ny soa azonao izao ;
 Jesosy monina ao am-po
 Endrey ny hafaliako !</lyrics>
<title>Ry Jeso Tompo, Hianao FFPM266</title>
</song>