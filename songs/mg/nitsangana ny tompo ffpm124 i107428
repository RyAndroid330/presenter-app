<?xml version="1.0" encoding="UTF-8"?><song><author>J. Klugelmann</author>
<hymn_number>124</hymn_number>
<lyrics>[V1]
 Nitsangana ny Tompo,
 Neken'ny Ray ny avotra,
 Ka ravo ny mpanompo :
 Misokatra ny lanitra !
 Ilay Tompom-pandresena
 Nandrava fasana,
 Andriam-pamonjena,
 Tolory hasina !
 Jesosy no Mpanjaka
 Am-boninahitra,
 Hiarahako mizaka
 Ny zon'ny lanitra !</lyrics>
<title>Nitsangana ny Tompo FFPM124</title>
</song>