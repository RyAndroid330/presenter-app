<?xml version="1.0" encoding="UTF-8"?><song><title>Niakatra ao an-danitra FFPM152</title>
<lyrics>[V1]
 Niakatra ao // an-danitra //
 Ny Zanak'Andriamanitra,
 // Haleloia ! //

[V2]
 Ka monina ao // an-danitra //
 Jesosy Tompon-danitra,
 // Haleloia ! //

[V3]
 Izao zavatra // rehetra izao //
 Ry Jeso ô, hazoninao,
 // Haleloia ! //

[V4]
 Isaoranay // ry Tompo ô //
 Ny herinao sy indrafo !
 // Haleloia ! //

[V5]
 Fa ny devoly resinao
 // he resinao ! //
 Ny ratsy nofongoranao,
 // Haleloia ! //

[V6]
 Ry tany sy // ry lanitra //
 Derao Andriamanitra !
 // Haleloia ! //</lyrics>
<hymn_number>152</hymn_number>
<author>L.M. Linderman</author>
</song>