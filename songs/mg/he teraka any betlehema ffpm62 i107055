<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 He, teraka any Betlehema,
 Ao Betlehema,
 Ny Tompon'i Jerosalema.
 // Haleloia ! //

[V2]
 Ny vilona // nandriany //
 Nihoby ny anjeliny.
 // Haleloia ! //

[V3]
 Ny magy dia // nanatitra //
 Ny miora sy ny hanitra
 // Haleloia ! //

[V4]
 Voaisotra // ny helokao //
 Fa tonga ny Mpanavotrao.
 // Haleloia ! //

[V5]
 Isika dia // noraisiny //
 Hiombon-dova aminy.
 // Haleloia ! //

[V6]
 Isika koa // hianatra //
 Ny fideran'ny lanitra.
 // Haleloia ! //

[V7]
 Isika ao // an-danitra //
 Ho velona finaritra.
 // Haleloia ! //

[V8]
 Ho naman'ny // anjelinao //
 Izahay, ry Jeso Tompo ô !
 // Haleloia ! //

[V9]
 Hidera ny // Anaranao //
 Manatrika ny tavanao.
 // Haleloia ! //</lyrics>
<title>He, teraka any Betlehema FFPM62</title>
<author>L.M. Linderman</author>
<hymn_number>62</hymn_number>
</song>