<?xml version="1.0" encoding="UTF-8"?><song><title>Lay ora tao Getsemane FFPM88</title>
<lyrics>[V1]
 Ilay ora tao Getsemane
 Tsy mba hadino re,
 Raha Hianao no tsembo-dra,
 Ry Tompon'avotra
 // Tsahiviko //
 Ny fahorianao,
 Raha tsinjoko ny ady be,
 Ilay tao Getsemane.

[V2]
 Nafoin-dRay irery tao,
 Nilaozan-kavanao
 Handraisana anay indray
 Ho zanaky ny Ray.
 // Tsahiviko ..sns //

[V3]
 Nandroso mba hijaly tao,
 Ry Tompo, Hianao ;
 Fadiranovana sy may
 Hanavotra anay.
 // Tsahiviko ..sns //

[V4]
 Fa vinitra Jehovah Ray
 Noho ny ditranay ;
 Ninianay nolavina
 Ny didy masina.
 // Tsahiviko ..sns //

[V5]
 Ka Hianao nasiana
 Ho solo-voina ;
 Ny dinitrao, ry Tomponay,
 Dia valin'otanay.
 // Tsahiviko ..sns //

[V6]
 Fa sitrakao ho afaka
 Ny olo-meloka;
 Endrey ny fitiavanao
 Anay navotanao !
 // Tsahiviko ..sns //

[V7]
 Raha mila hangatsia-po
 Izaho, Tompo ô,
 Mba ampisaino aho re
 Ny tao Getsemane !
 // Tsahiviko ..sns //</lyrics>
<author>Asa Hull</author>
<hymn_number>88</hymn_number>
</song>