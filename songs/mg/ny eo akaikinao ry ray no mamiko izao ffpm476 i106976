<?xml version="1.0" encoding="UTF-8"?><song><author>I.D. Sankey</author>
<hymn_number>476</hymn_number>
<lyrics>[V1]
 Ny eo akaikinao, ry Ray,
 No mamiko izao,
 Hanjary tena tafaray
 Ny foko sy ny Anao,
 Soa re, ry Raiko ô !
 Raha eo anilanao ;
 Ny hazo fijaliana
 Ho tonga maivana.

[V2]
 Ny eo akaikinao, ry Ray,
 No herin-janakao ;
 Hianao irery no mahay
 Manampy ahy izao.
 Soa re, ry Raiko ô !
 Raha eo anilanao ;
 Ny ota tsy hanapaka
 Ny olona afaka.

[V3]
 Ny eo akaikinao, ry Ray,
 No mandako tokoa ;
 Ny ratsy dia tsy hahay
 Handrombaka ahy koa,
 Soa re, ry Raiko ô !
 Raha eo anilanao ;
 Ny ora izay manjombona
 Ho fiadanana.

[V4]
 Ny eo akaikinao, ry Ray,
 No fifaliako izao,
 Ny tanako dia hifandray
 Amin'ny tananao.
 Soa re, ry Raiko ô !
 Raha eo anilanao ;
 Fenoinao fanambinan-tsoa
 Ilay kapoakako.</lyrics>
<title>Ny eo akaikinao ry Ray no mamiko izao FFPM476</title>
</song>