<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>341</hymn_number>
<author>W.B. Bradbury</author>
<title>Tompo o! ampitandremo FFPM341</title>
<lyrics>[V1]
 Tompo ô ! ampitandremo
 Izay lazainao izahay ;
 Hazavao ka mba omeo
 Hery ny fanahinay ;
 Ka ny fo ampionony
 Tsy hitebiteby intsony ;
 // Mba diovy, hamasino
 Izahay, ry Tompo ô ! //

[V2]
 Ka rehefa hodimandry
 Izahay, ry Tomponay,
 Tsy ho taitra, fa hiandry
 Ny handraisanao anay,
 Ry Jesosy Tompon'aina,
 Hianao no antenaina,
 // Hianao no hanazava
 Ny hodianay arý //</lyrics>
</song>