<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 O, ry Mpanefa ny toky rehetra,
 Moa ho ela vao tonga ny
 fetra ?
 Tena andrasanay ny
 fihavianao ;
 // Aza ela, re //

[V2]
 He ! izahay fa vahiny mandala,
 Indro manenjika ny fahavalo ;
 Koa henoy re ny senton'ny
 olonao ;
 // Aza ela, re //

[V3]
 He ! ny voavotrao dia miandry,
 Na izahay na ireo nodimandry ;
 Tompo, Tsinjovy ny fasan'ny
 olonao ;
 // Aza ela, re //

[V4]
 Ary ny zavatra eto an-tany
 Samy miara-misento ihany,
 Ka manantena ny mba
 hihavianao ;
 // Aza ela, re //

[V5]
 Mbola ho ela ve Ilay
 antenaina ?
 Tsia, fa akaiky izao ny
 maraina ;
 Koa andrandrao sy antsoy
 ny Tompo hoe :
 // Aza ela, re //

[V6]
 «Tsy mbola ho ela, fa faingana
 Aho,
 Ary hanafaka ny mitalaho».
 « Eny, avia, faingàna,
 ry Tompo ô ! »
 // Aza ela, re //</lyrics>
<title>O! ry Mpanefa ny toky rehetra FFPM46</title>
<hymn_number>46</hymn_number>
</song>