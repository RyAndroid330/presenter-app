<?xml version="1.0" encoding="UTF-8"?><song><author>O. Mailling</author>
<hymn_number>133</hymn_number>
<lyrics>[V1]
 Efa namangy ny olony
 Jeso, izay Tompon'ny aina
 Lasa ny alina maizina,
 // Tonga indray ny maraina //

[V2]
 Maty ny Tompo, nalevina
 Nidina nita ny ony,
 Nefa nitsangana velona
 // Koa tsy maty intsony //

[V3]
 Ory ny fon'ny sakaizany,
 Aiza Ilay nantenaina ?
 Hitany nefa tsy fantany,
 // Jeso, Izay
 Tompon'ny aina //

[V4]
 Teniny tsy mba mivadika
 Amin'ny olona ory.
 Tonga ny Tompo mitsidika
 // Ireo mpianany vory //

[V5]
 Tonga ny taom-pamangiana,
 Tondraka ny famonjena.
 Velona ny fihobiana,
 // Aina vaovao no nomena //

[V6]
 Teraka ny fifaliana,
 Tonga ny Filazan-tsara,
 Andron'ny fitomaniana
 // Mody ho Pasaka tsara //</lyrics>
<title>Efa namangy ny olony FFPM133</title>
</song>