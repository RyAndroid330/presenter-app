<?xml version="1.0" encoding="UTF-8"?><song><title>Foana ny fasanao FFPM135</title>
<lyrics>[V1]
 Foana ny fasanao,
 Jeso Tompon'aina ;
 To tokoa ny teninao
 Ka notontosaina.

[V2]
 Foana ny fasanao,
 Tompo mana-kery,
 Gaga teo ny rafinao,
 Resy 'lay Mahery !

[V3]
 Foana ny fasanao,
 Fa efa novohana ;
 Maito ny fatoranao,
 Tsy mba nahatana !

[V4]
 Foana ny fasanao,
 Zanaky ny Avo !
 Aina no nasehonao,
 Zava-maharavo !</lyrics>
<hymn_number>135</hymn_number>
<author>St. Albans</author>
</song>