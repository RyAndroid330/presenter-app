<?xml version="1.0" encoding="UTF-8"?><song><title>O! Ray Malala, asehoy FFPM233</title>
<lyrics>[V1]
 O ! Ray Malala, asehoy
 Ny hasoavanao ;
 Sasao ho afa-keloka
 Izahay ho zanakao ;
 Ho mafy ny fiezakay
 Handia ny lalanao
 Tsy hisy hijanonanay
 Raha tsy an-tranonao.

[V2]
 O ! Ray Malala, mba henoy
 Ny feonay zanakao ;
 Tantano ao an-dalana
 Hankany Aminao ;
 Ho mafy ....sns.

[V3]
 O ! Ray Malala, hitanao
 Ny hasambaranay ;
 Ny avotr'ain'ny Zanakao
 No itokianay ;
 Ho mafy ....sns.</lyrics>
<hymn_number>233</hymn_number>
</song>