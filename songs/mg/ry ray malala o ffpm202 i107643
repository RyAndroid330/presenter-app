<?xml version="1.0" encoding="UTF-8"?><song><author>Ch. Rasoanaivo</author>
<hymn_number>202</hymn_number>
<title>Ry Ray malala o! FFPM202</title>
<lyrics>[V1]
 Ry Ray malala ô !
 Mba raisonao
 Ny haja entiko
 Hidera Anao.
 Ny fitiavanao
 No maiko izao
 Izaho dia Anao,
 Ry Raiko ô !

[V2]
 Ry Jeso tia ô !
 Mpanavotra,
 Ta-hankalaza Anao
 Ny vavako ;
 Ny avo-dehibe
 Manafaka ahy e !
 Izaho dia Anao,
 Ry Jeso ô !

[V3]
 Fanahy Masina ô !
 Mpananatra,
 Mahiratra tokoa
 Ny masoko,
 Mazava re izao
 Ny lalako hankao ;
 He ! fifaliam-be
 No ahy izao.</lyrics>
</song>