<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Eny Raiko ! mba tariho
 Ny fanahin-janakao,
 Ka ny saiko atodiho
 Hankatò ny teninao ;
 Zaza be fisiasia,
 Tano re ny zanakao,
 Dia taomy mba ho tia
 Sy hanao ny sitrakao.

[V2]
 Eny Raiko ! mba tsilovy
 Ny alehan-janakao,
 Ka tantano sy arovy
 Mba hankatý Aminao ;
 Mora reraka ny aina
 Raha tsy fahananao,
 Ka tohano tsy halaina
 Mba hanao ny sitrakao.

[V3]
 Eny Raiko ! raha mafy
 Izany tsorakazonao,
 Ka ny aiko tsy mahahafy
 Mba vonjeo ny zanakao ;
 Ka ny foko izay adala
 Mba ovay sy hazavao,
 Dia taomy hahalala
 Mba hanao ny sitrakao.

[V4]
 Eny Raiko ! mba tohano
 Raha mihatra ny manjo,
 Ka vimbino sy tantano
 Tsy ho kivy re ny fo ;
 Raha tapitra ny aiko,
 Raiso hody Aminao;
 Eny, ento aho, Raiko !
 Fa izay no sitrakao.</lyrics>
<title>Eny, Raiko! Mba tariho FFPM618</title>
<hymn_number>618</hymn_number>
<author>I.D. Sankey</author>
</song>