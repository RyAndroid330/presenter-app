<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>64</hymn_number>
<author>Patrick J. RAKOTO RAMIARANTSOA</author>
<lyrics>[V1]
 Vao mifoha aho dia midera Anao,
 Ny androko ankiniko Aminao,

[C1]
   (2) Ny fiainako rehetra,
   Anao ts'isy fetra,
   Tompo ô Ianao no miahy.

[V2]
 Ny Fitiavanao no iainako,
 Tsy mba sambatra aho raha tsy eo Ianao,

[V3]
 Raha tonga indray ny alina,
 Tsy hatahotra aho fa eo Ianao,

[V4]
 Ny hany faniriako Tompo ô!
 Dia ny hanompo Anao hatrany.

[V5]
 NY TENIN'ANDRIAMANITRA</lyrics>
<title>IANAO NO MIAHY ASAFA64</title>
</song>