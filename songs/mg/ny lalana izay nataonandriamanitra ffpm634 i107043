<?xml version="1.0" encoding="UTF-8"?><song><title>Ny lalana izay nataon'Andriamanitra FFPM634</title>
<lyrics>[V1]
 (Maintimolaly)

[V2]
 Ny lalana izay nataon'
 Andriamanitra
 Tamin'ny olombelona
 // Marina indrindra //

[V3]
 Raha manaraka izany,
 Dia tsy manan-tsiny
 Fa nanota ny olona
 // Ka nanan-keloka //

[V4]
 Raha tsy mino an'i Kristy
 Ny olombelona,
 Fa matoky ny tenanay,
 // Tsy azo hitsina //

[V5]
 Fa Jeso no manafaka
 Ny ota rehetra,
 Ny manaiky ny teniny
 // No azo hitsina //</lyrics>
<hymn_number>634</hymn_number>
</song>