<?xml version="1.0" encoding="UTF-8"?><song><title>HOY JESOSY TOMPO ASAFA94</title>
<lyrics>[V1]
 Hoy Jesosy Tompo
 Raha tety an-tany :
 &quot;Mba avelao ny zaza
 Avelao, avelao hankaty&quot;

[C1]
   &quot;Tena tiako izy
   Na dia mbola ankizy
   K'aza mba rarana
   Tsy hanatona Ahy
   Na dia kely aza
   Na dia mbola zaza
   Ho tahiko re!&quot;

[V2]
 Tiako ny zazakely
 Zaho no mpiandry tsara
 Tsy foiko hisy ho very
 O! avia, ô! avia hankaty

[V3]
 Avia ry zazakely
 Jesosy no miantso
 Avia ho tahiany
 O! avia. O! avia hankaty</lyrics>
<author>Benjamin RABENJA RAMIARISON</author>
<hymn_number>94</hymn_number>
</song>