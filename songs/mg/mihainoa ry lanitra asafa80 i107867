<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>80</hymn_number>
<author>Faly Henintsoa RAFIDIMANANA</author>
<title>MIHAINOA, RY LANITRA ASAFA80</title>
<lyrics>[V1]
 Mihainoa, ry lanitra, fa hiteny Aho
 Mandrenesa, ry tany, ny Tenin'ny vavako
 Fa ny Anaran'i Jehovah
 No hotoriako,
 Maneke ny ahalehibeazan'Andriamanitsika
 Ny amin'ny vatolampy, tanteraka ny Asany
 Ary ny asany rehetra
 Dia amin'ny rariny avokoa
 Izy no Andriamanitra, tena mahatoky
 Andriamanitry ny fahamarinana</lyrics>
</song>