<?xml version="1.0" encoding="UTF-8"?><song><title>Hitako ny lalan-tsara FFPM540</title>
<lyrics>[V1]
 (Maintimolaly)

[V2]
 Hitako ny lalan-tsara,
 Ka hizorako izao,
 Azoko ny famonjena,
 Ka hotanako tokoa
 // Manampia //
 Ry Fanahy Masina ô !

[V3]
 Ravoravo aho, Jeso !
 Hianao no Tompoko ;
 Faly aho, ry Mpamonjy !
 Afakao ny heloko ;
 // Gaga aho //
 Noho ny fanavotanao.

[V4]
 Fitiavana ihany
 No natolotrao anay :
 Nefa kosa fahotana
 No navalinay Anao :
 // Aza isaina //
 Re ny hadisoanay.

[V5]
 Ny mpanota hilazako,
 Ny Mpamonjy tànako ;
 Hilazako fa ny rany
 No nataony avotra :
 // Matokia //
 He, ny fitiavany !</lyrics>
<hymn_number>540</hymn_number>
</song>