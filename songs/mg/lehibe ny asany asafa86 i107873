<?xml version="1.0" encoding="UTF-8"?><song><author>Patrick J . RAKOTO RAMIARANTSOA</author>
<hymn_number>86</hymn_number>
<title>LEHIBE NY ASANY ASAFA86</title>
<lyrics>[V1]
 Izy no namorona
 Ny tany sy ny lanitra
 Ny maraina sy hariva.
 Izy no Andriamanitra
 Ny trondro ny vorona
 Ary indrindra ny olona
 Miderà, mihobia
 An'Andriamanitra
 Lehibe ny Asany
 Mahafinaritra</lyrics>
</song>