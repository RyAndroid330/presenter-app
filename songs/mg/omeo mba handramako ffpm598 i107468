<hymn_number>598</hymn_number>
<title>Omeo mba handramako FFPM598</title>
<lyrics>[V1]
 Omeo mba handramako
 Ny fitiavanao,
 Hahaizako, ry Jeso ô,
 // Hihavana Aminao //

[V2]
 Iriko re ny tavanao,
 Ry Ilay malalako,
 Fa tiako ny hahita Anao,
 // Izay Sakaizako //

[V3]
 Hanjavona ny masoko,
 Hamoy ny namako,
 Fa Hianao Jesosy ô,
 // Ho eo anilako //

[V4]
 Raha ao ny ali-maizim-be
 Izay handehanako,
 Ho eo an-tananao anie
 // No hahafatesako //

[V5]
 Ka tsy mba hatahorako
 Ny aizim-pasana,
 Hatsanganao ny tenako
 // Ho tena sitrana //</lyrics>
</song>