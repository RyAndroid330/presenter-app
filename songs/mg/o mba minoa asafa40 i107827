<?xml version="1.0" encoding="UTF-8"?><song><author>Binjamin RABENJA RAMIARISON/J.R. SWENEY</author>
<hymn_number>40</hymn_number>
<lyrics>[V1]
 O! mba minoa an'i Jesosy Tompo
 O! mba minoa, ô! mba minoa
 Ka maneke ny famonjena re!
 O! Avia maneke.

[C1]
   'Zay mino Azy izao
   Zay manana Azy izao
   Tena sambatra, ao an-danitra
   Jeso no làlana
   Fahamarinana, Ary koa fiainana

[V2]
 O! maneke an'i Jesosy Tompo
 O! maneke. O! maneke.
 Ka mba mandraisa azy ao am-po
 O! avia maneke

[V3]
 O! miderà an'i Jesosy Tompo
 O! miderà. O! miderà
 Fa lehibe ny vonjy azo re!
 O! avia miderà</lyrics>
<title>O! MBA MINOA ASAFA40</title>
</song>