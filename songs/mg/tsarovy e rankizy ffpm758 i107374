<?xml version="1.0" encoding="UTF-8"?><song><author>S. Salvatori</author>
<hymn_number>758</hymn_number>
<lyrics>[V1]
 Tsarovy e ! rankizy
 Ilay Mpanao anao !
 Ka tadiavo Izy !
 Dieny hitanao ;
 Dieny mbola kely,
 Tsarovy rahateo,
 Ka aza manadino
 Ilay Mpanao anao.

[V2]
 Tsarovy ry zatovo
 Ilay Mpanao anao !
 Ilaozy ny mpanota,
 Fandrao manimba anao.
 Tsarovy ny Jehovah
 Namorona anao,
 Mampanantena lova
 Sy nahatoy izao.

[V3]
 Tsarovy, ry sakaiza,
 Jehovah Tomponao !
 Fa Izy no mitaiza
 Sy manasoa anao ;
 Koa aza manadino
 Ilay Mpanao anao ;
 Ny teniny araho,
 Fa Izy no Rainao.</lyrics>
<title>Tsarovy e! rankizy FFPM758</title>
</song>