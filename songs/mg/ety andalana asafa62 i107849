<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>62</hymn_number>
<author>Landy RABENIRAINY /John F. Peterson</author>
<title>ETY AN-DALANA ASAFA62</title>
<lyrics>[V1]
 Ety an-dàlan'ity fiainako ity,
 Dia misy efa nitokiako,
 Ka ny aizina hazava raha tarihiny,
 Io 'Lay Mpamonjy ny fanahiko.

[C1]
   Tsy tahotro ny alon-drano mafy,
   Ny rivo-doza tsy hahatohina,
   Fa ampy ho ahy ny mino sy matoky,
   Fa Jeso miara-dia amiko.

[V2]
 An-taona maro no efa nahafantarako,
 Ny fahamarinan'ny fitiavany,
 Ny nanomboana Azy tamin'ny hazo,
 Nisarik'ahy hanaiky ao am-po.</lyrics>
</song>