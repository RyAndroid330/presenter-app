<?xml version="1.0" encoding="UTF-8"?><song><title>Andriamanitra hendry FFPM25</title>
<lyrics>[V1]
 (Maintimolaly)

[V2]
 Andriamanitra hendry,
 // Loharanon-tsaina //
 // Ka manolo-pahendrena
 Izay manaiky Azy //

[V3]
 Andriamanitra mahay,
 // Izao rehetra izao //
 // Ka Izy no akana saina
 Hahahendry antsika //

[V4]
 Ary isika mila saina,
 // Hanitsy antsika //
 // Amin'ny fianarana
 Hanarahana Azy //

[V5]
 Izy no ihavian'
 // Ny soa rehetra //
 // Hiainana mandrakizay,
 Ka Izy no omen-tsaotra //</lyrics>
<author>Old 19th</author>
<hymn_number>25</hymn_number>
</song>