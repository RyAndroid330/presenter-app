<?xml version="1.0" encoding="UTF-8"?><song><author>W.H. Doane</author>
<hymn_number>344</hymn_number>
<title>Fiadanana be FFPM344</title>
<lyrics>[V1]
 Fiadanana be,
 Hasambarana re,
 No miandry antsika ao
 an-danitra e !
 Ka handeha handao
 Izao tontolo izao,
 Ka hitady tokoa ilay
 tany vaovao.
 Miaingà hody ao !
 Miaingà hatrizao !
 Mba modia hianao (izao)
 Ao amin'i Jesosy !</lyrics>
</song>