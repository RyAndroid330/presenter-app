<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Jesô Tompo amboary
 'Reto voninkazonao
 Hitomboanay hatrany
 Noho ny hasoavanao
 Voninkazo vao maniry
 Ao an-tanimbolinao
 Hasoavy tsy hariry
 Mba ho voninahitrao

[V2]
 Toera-mendrika sy tsara
 Tony fiangonanao
 Ka indreo voakarakara
 Izahay mpianatrao
 Ianao no mpiandry Tsara
 No mikolokolo ao
 Samy henika anjara
 'Zay rehetra tonga ao

[V3]
 Ny sekoly alahady
 Io no zaridainanay
 Ka misantatra sahady
 Ho finaritra izahay
 Izahay no voninkazo
 'Zay hisahirananao
 Manantena tsy handazo
 Noho ny fanamboaranao</lyrics>
<title>JESO TOMPO AMBOARY ASAFA28</title>
<hymn_number>28</hymn_number>
<author>Tsy fantatra</author>
</song>