<?xml version="1.0" encoding="UTF-8"?><song><author>Tsy fantatra</author>
<hymn_number>73</hymn_number>
<lyrics>[V1]
 He! ny fifaliako, faly izao ny foko,
 Fa Jesosy Kristy no Mpamonjiko,
 'Zao no faniriako, 'zao no tena tiako,
 Tsy hisaraka Aminao.

[V2]
 'Zao no tiako (bis)
 Hiara-belona Aminao, ry Jeso,
 Ka iriko (bis)
 Tsy hisaraka Aminao.</lyrics>
<title>HE NY FIFALIAKO ASAFA73</title>
</song>