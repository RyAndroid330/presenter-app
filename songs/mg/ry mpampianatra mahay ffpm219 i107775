<?xml version="1.0" encoding="UTF-8"?><song><author>J. Klug</author>
<hymn_number>219</hymn_number>
<lyrics>[V1]
 Ry Mpampianatra mahay
 Fanahy Mpanazava,
 Ampianaro izahay
 Handroso lalandava,
 Ny indrafon'ny Tomponay,
 Velaro eo imasonay
 Ho fantatray mazava.

[V2]
 Mivory eto izahay
 Handre ny tenin'aina,
 Ka hazavao ho fantatray
 Ny hevitra lazaina ;
 Ovay ny sainay sy ny fo
 Hamantatra sy hankatò
 Ny tenin'ny Mpamonjy.

[V3]
 Raha hodimandry izahay
 Ka tonga ny anjara,
 Bitsiho ao an-tsofinay
 Ny tokon'aina tsara ;
 Ataovy mora hitanay
 Ny tavan'ny Mpanavotray,
 Izay hery mahavonjy.</lyrics>
<title>Ry Mpampianatra mahay FFPM219</title>
</song>