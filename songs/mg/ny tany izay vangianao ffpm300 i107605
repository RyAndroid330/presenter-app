<?xml version="1.0" encoding="UTF-8"?><song><author>F. Duckworth</author>
<hymn_number>300</hymn_number>
<lyrics>[V1]
 Ny tany izay vangianao,
 Ry Jeso Masoandronay,
 Tsy maintsy lasanao, Jeso,
 Mba hanjakanao avokoa.

[V2]
 Ny fo sy tany lasanao
 Ho feno hasambarana,
 Ny loza hosakananao,
 Ny soa hampidinina.

[V3]
 Ny vavakay sy dera koa
 Tsy manam-pitsaharana,
 Hiakatra Aminao tokoa
 Hitady fiadanana.

[V4]
 Ireo olona voaforona,
 Dia àry ho Anao tokoa :
 Hohasoavinao ireo
 Hanjary masina avokoa.

[V5]
 Ny maty hovelominao,
 Ny ratsy hohavaozinao,
 Ny very hotadiavinao,
 Ny diso, re, horaisina.

[V6]
 Ry vazantany efatra !
 Ry Nosy tanindrazanay !
 Mba raiso Ilay Mpanavotra
 Ho Tomponao mandrakizay !</lyrics>
<title>Ny tany izay vangianao FFPM300</title>
</song>