<?xml version="1.0" encoding="UTF-8"?><song><title>VONINAHITRA ASAFA88</title>
<lyrics>[V1]
 Voninahitra ho amin'ny Avo Indrindra
 Ho amin'ny Avo Indrindra
 Avo Indrindra ho an'Andriamanitra
 Fiadanana ho ety ambonin'ny tany
 Ho an'ny olona
 Ny olona ankasitrahany
 He! voninahitra (He! voninahitra)
 Ho an'Andriamanitra(Ho an'Andriamanitra)
 Hobio, derao ankalazao
 Ny Tompo, mandrakizay, Amena</lyrics>
<author>Patrick J . RAKOTO RAMIARANTSOA</author>
<hymn_number>88</hymn_number>
</song>