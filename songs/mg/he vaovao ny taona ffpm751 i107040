<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>751</hymn_number>
<title>He, vaovao ny taona FFPM751</title>
<lyrics>[V1]
 He, vaovao ny taona,
 Ry Jesosinay,
 // Ka mba te hihaona
 Aminao izahay //

[V2]
 Hianao mitahy
 Ny mpanomponao
 // Koa tsy manahy
 Izay tarihinao //

[V3]
 Ary izaho koa
 Mba tantanonao
 // Dia hahita soa
 Ao an-danitrao //</lyrics>
</song>