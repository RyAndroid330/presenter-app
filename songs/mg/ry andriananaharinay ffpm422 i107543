<?xml version="1.0" encoding="UTF-8"?><song><title>Ry Andriananaharinay FFPM422</title>
<lyrics>[V1]
 Ry Andriananaharinay !
 Ny hamasinanao
 Dia tena lehibe tokoa,
 Raha te-hahita Anao
 izahay,
 Tsy maintsy tsara fo.

[V2]
 Ny mason'ny anjelinao
 Mahita Anao tokoa,
 Ka tsy mba manjambena
 ireo,
 Na dia mamirapiratra,
 Ny hamasinanao.

[V3]
 Fa tsy nanota taminao
 Akory izy ireo,
 Tsy meloka, tsy menatra,
 Ka misy hahazoany
 Hijery tsara Anao.

[V4]
 Fa izahay, maloto fo,
 Raha te-hahita Anao,
 Tsy mana-mahamendrika,
 Fa zanak'olombelona ;
 Ahoana no hatao ?

[V5]
 Ry Andriananaharinay !
 Ny ran'ny Zanakao,
 Ny asan'ny Fanahy koa,
 No zava-mahamendrika
 Anay hahita Anao.</lyrics>
<hymn_number>422</hymn_number>
<author>Ch. Rasoanaivo</author>
</song>