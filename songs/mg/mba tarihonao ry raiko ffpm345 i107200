<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Mba tarihonao, ry Raiko,
 Ny fanahy sy ny foko,
 // Mba ho any Aminao ! //
 O, ry Loharanon'aiko,
 Izao ihany no ilaiko,
 // Dia ny hahita Anao ! //</lyrics>
<title>Mba tarihonao, ry Raiko FFPM345</title>
<author>H. Wetterling</author>
<hymn_number>345</hymn_number>
</song>