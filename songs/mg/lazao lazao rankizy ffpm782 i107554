<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 « Lazao, lazao rankizy !
 Izay nandaozan'i
 Jeso ny fanjakany
 Mba honina tetý »
 « Ry mpampianatray ô !
 Hamonjy sy handio
 Antsika olom-bery
 No nihaviany »
 // Mifalia izao //
 Misy avotra sy vonjy
 Ho antsika atý.

[V2]
 « Rankizy ô, rankizy !
 Mpitrosa hianao,
 Ka inona no homenao
 Hanefa trosanao ? »
 « Ry mpampianatray ô !
 Ny saina amam-po
 Homenay mba ho Azy
 Raha velona izahay »
 // Mifalia izao, ..sns. //

[V3]
 « Rankizy ô, rankizy !
 Hamonjy sy handray
 Anao ve Jeso Tompo
 Raha mino hianao ? »
 « Ry mpampianatray ô !
 Matoky izahay
 Fa efa maty Izy
 Ho avotray tokoa »
 // Mifalia izao, ..sns. //

[V4]
 « Rankizy ! angataho
 Ny indrafony izao »
 « Ry Jeso ô, Mpamonjy !
 Mba iantrao izahay »
 Ry Tompo ô ! ry Tompo !
 Henoy, henoy izahay,
 Na kely na vaventy,
 Izay mitaraina izao ;
 // Mifalia izao, ..sns. //</lyrics>
<title>Lazao, lazao, rankizy FFPM782</title>
<hymn_number>782</hymn_number>
<author>Sunday School Choralist</author>
</song>