<?xml version="1.0" encoding="UTF-8"?><song><author>C.F. Witt</author>
<hymn_number>259</hymn_number>
<lyrics>[V1]
 Ny latabatrao, ry Jeso !
 Dia atrehinay izao ;
 Ny fanahinay vokiso
 Amin'ny fitianao.

[V2]
 Tsy nitady zo sy laza
 Hianao, ry Tomponay !
 Foinao ny ainao aza
 Nanavotanao anay.

[V3]
 Jeso ô ! ny ranao soa
 No nataonao avotray,
 Mba hanafaka avokoa
 Izay tsy mahadio anay.

[V4]
 Manomeza mofon'aina
 Tompo ô ! ho tanjakay ;
 Mihainoa ny mitaraina,
 Mamalia ny hatakay.

[V5]
 Ny fanahinay ry Tompo !
 Raiso, fa atolotray ;
 Faly izahay hanompo
 Sy hanao ny sitrakao.</lyrics>
<title>Ny latabatrao ry Jeso! FFPM259</title>
</song>