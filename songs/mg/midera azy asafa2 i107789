<?xml version="1.0" encoding="UTF-8"?><song><title>MIDERA AZY ASAFA2</title>
<lyrics>[V1]
 Miderà an'i Jehovah
 Miantsoa ny Anarany
 Ambarao ny firenena
 Ny asan'ny Tànany
 Ataovy ho rehareha
 Ny Anarany masina
 Aoka hifaly ny fonao
 Izay mitady Azy

[V2]
 Katsaho mandrakariva Jehovah
 (Mitadiava, mitadiava an'i Jehovah mandrakariva)
 Dia ianareo olona voafidiny
 (Dia ianareo, dia ianareo olona voafidiny)</lyrics>
<hymn_number>2</hymn_number>
<author>Landy RABENIRAINY /Alice Hawthrone</author>
</song>