<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>161</hymn_number>
<author>R. Rafihavanana</author>
<lyrics>[V1]
 Mivelatra eo imasoko
 Ny fiandrianan-dehibe
 Itoeran'ny Mpamonjiko,
 Dia Jeso Ilay nandresy re.
 Fa niakatra Izy ka nandao
 Ity tany fandalovana ;
 Manjaka ao an-dapany,
 Ka feno voninahitra.

[V2]
 Anjely no manotrona
 Arahin'ny olo-masina
 Ireo dia mandohalika
 Am-panajana fatratra,
 Ny Tompo eo afovoany,
 Mamiratra ny tavany,
 Ka feno hasambarana
 Izay mahazo taratra.

[V3]
 Kanefa tsy mipetraka
 Ho endriky ny lanitra
 'Lay Zanak'Andriamanitra
 Fa miasa tsy mijanona.
 Renao va ny fifonany,
 Ho an'ny Fiangonany
 'Zay novidiny tamin-dRà,
 Ka tiany hampakarina ?

[V4]
 Ekeo, ry Fiangonana ô !
 'Lay hany Mpanalàlana
 'Zay mandohalika amin-dRay,
 Ka mitomany hoa anao !
 Ry Tompo aza sasatra,
 Ifony lalandava e !
 'Zahay izay navotanao.
 Fa te-hankao an-danitra !</lyrics>
<title>Mivelatra eo imasiko FFPM161</title>
</song>