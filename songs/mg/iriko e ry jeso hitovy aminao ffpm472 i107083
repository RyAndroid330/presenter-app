<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>472</hymn_number>
<title>Iriko e, ry Jeso hitovy aminao FFPM472</title>
<lyrics>[V1]
 Iriko e, ry Jeso !
 Hitovy Aminao,
 Izay tsy manan-keloka,
 Fa masina tokoa ;
 Iriko e, ry Jeso !
 Ho tonga toa Anao,
 Namonjy sy nanafaka
 Fanahy, aina koa.

[V2]
 Iriko, ry Mpamonjy !
 Mba ho sakaizanao,
 Hiaraka ory Aminao ;
 Ka tsy handao Anao ;
 Iriko, ry Mpamonjy !
 Hanar-dia Anao ;
 Ny hazofijaliana
 Ho entiko izao.

[V3]
 Iriko, ry Mpandresy !
 Hiaraka Aminao,
 Ho eo an-toby lehibe,
 Ho miaramilanao ;
 Iriko, ry Mpandresy !
 Hanaraka Anao ;
 Mitondra ny fanevanao,
 Handray ny herinao.

[V4]
 Iriko, ry Mpanjaka !
 Ho ao an-dapanao
 Hiara-paly Aminao,
 Fa tonga Zanakao ;
 Iriko, ry Mpanjaka !
 Ho eo anilanao
 Handray ny lova atolotrao,
 Mpanjaka be fitia !</lyrics>
</song>