<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Hevero ny fihaonambe
 Arý an-danitra ;
 Vahoaka izany re !
 // He, samy sambatra //

[V2]
 Ho vory ao ny iraky
 Ny Tompom-bokatra,
 Mitondra amboarany
 // Am-pihobiana //

[V3]
 Ny isam-pirenena atý
 Dia samy misy ao,
 Ny teny izay ninoany
 // Tanteraka izao //

[V4]
 Ny feon'ny fisaorany
 Ho toy ny riana,
 Ny hira iray iraisany,
 // Ka samy mirana //

[V5]
 Ny lanitry ny lanitra
 Dia feno hobiny,
 Ny Zanakondry masina
 // No ao anivony //

[V6]
 Ry Ray be fitiavana,
 Izahay mba taominao,
 Mba samy ho tafangona
 // Ao anatrehanao //</lyrics>
<title>Hevero ny fihaonam-be FFPM673</title>
<hymn_number>673</hymn_number>
</song>