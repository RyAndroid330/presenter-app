<?xml version="1.0" encoding="UTF-8"?><song><author>G.C. Stebbins</author>
<hymn_number>297</hymn_number>
<lyrics>[V1]
 Ry havanay malala !
 Manolo-tena izao,
 Fotoana mahafaly
 Iraisantsika anio ;
 Faly izahay mandray anao,
 Hiara-manompo ny Ray,
 Jeso anie handray anao !
 Mba ho sakaizany tokoa.

[V2]
 Hajao ny fanekena,
 Adidinao efao
 Ataovy tsy terena
 Izay andraikitrao.
 Jereo Jeso, ka matokia,
 Fa Izy no hiahy anao,
 Ka mandrosoa sy mifalia
 Hanefa izay anjaranao.</lyrics>
<title>Ry havanay malala! FFPM297</title>
</song>