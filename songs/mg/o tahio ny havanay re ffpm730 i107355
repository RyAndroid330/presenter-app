<?xml version="1.0" encoding="UTF-8"?><song><title>O! tahio ny havanay re FFPM730</title>
<lyrics>[V1]
 O ! tahio ny havanay re
 Izay handeha lavitra ;
 Be tokoa ny alahelo
 Noho ny fisarahana ;
 // Manatreha //
 Izao veloma atao izao.

[V2]
 Mba sakanonao ny loza
 Tsy hamely azy izao,
 Raha misy mampahosa,
 Asehoy ny herinao ;
 // Mba tantano //
 Tsy hisaraka aminao.

[V3]
 Aoka mba ho tonga soa,
 Tsy ho azon-tsampona ;
 Aoka mba hampodina
 Eto aminay indray,
 // Ka hisaotra //
 Noho ny fivimbinanao.</lyrics>
<hymn_number>730</hymn_number>
</song>