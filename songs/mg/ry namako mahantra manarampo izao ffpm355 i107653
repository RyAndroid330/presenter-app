<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Ry namako mahantra
 Manaram-po izao !
 Ny ota no mandratra,
 Sao simba hianao ;
 Izay anao rehetra
 Ho lasa avokoa,
 Fa tsy mba misy fetra,
 Ho levona avokoa.

[V2]
 Ny Tompo be fiantra
 Mangora-po tokoa
 Mahita anao mahantra
 Fa tsy mahita soa ;
 Natolony ny ainy
 Ho vidin'ny ainao,
 Nalatsany ny rany
 Mba hanadio anao.

[V3]
 Ny Tompo malahelo,
 Tsy foiny hianao,
 Ny feo mamelovelo
 Mibitsika aminao ;
 Onena anao ny fony
 Ka mitaraina hoe :
 Ny ota ajanòny,
 Mba ajanòny re !</lyrics>
<title>Ry namako mahantra, manaram-po izao FFPM355</title>
<author>W.H. Doane</author>
<hymn_number>355</hymn_number>
</song>