<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>412</hymn_number>
<title>Jehovah Tompo o! FFPM412</title>
<lyrics>[V1]
 Jehovah Tompo ô !
 Indreto izahay
 Mifona Aminao ;
 Fa be ny helokay ;
 Henoy izao, ry Ray !
 Henoy ankehitrio,
 Henoy ny vavakay,
 Henoy ka mba valio.
 Ry Andriamanitray !
 mijere !
 Jeso Kristy Tomponay !
 mamonje !

[V2]
 Vonjeo, vonjeo, ry Ray !
 Vonjeo ny olonao ;
 Mifona izahay,
 Isao ho zanakao ;
 Henoy izao, ..sns.

[V3]
 Mpanota izahay,
 Mba mamelà anay ;
 Maloto ny fonay,
 Sasao ho voadio ;
 Henoy izao, ..sns.

[V4]
 Jereo ny Zanakao
 Misolo vava anay ;
 Ilay Malalanao,
 Mifona ho anay ;
 Henoy izao, ..sns.</lyrics>
</song>