<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>134</hymn_number>
<author>L.M. Lindeman</author>
<lyrics>[V1]
 Mifaly tokoa ny foko izao
 Fa misy manambara
 Ny Filazantsara,
 // O, mba raisonao //

[V2]
 Nitsangana Jeso,
 Haleloia re !
 Henoy teny soa
 Ka dia minoa
 // Fa marina re ! //

[V3]
 He ! rava ny fasana, ka mijere,
 Fa efa niala
 Ny Tompo malala,
 // Fa velona e ! //

[V4]
 Ny fahafatesana resy tokoa,
 Ka tsy mba mijaly
 Ny mino, fa faly
 // Sy tretrika am-po //

[V5]
 Misaotra, midera Anao
 izahay
 Ry Jeso Mpamonjy,
 // Ho mandrakizay //

[V6]
 Haleloia !
 Tsara ny Pasaka e !
 Ny Tompon'ny aina
 Izao hoderaina,
 // Haleloia re ! //</lyrics>
<title>Mifaly tokoa ny foko izao FFPM134</title>
</song>