<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>159</hymn_number>
<author>W. Shrubsole</author>
<lyrics>[V1]
 Satrohy voninahitra,
 Anjely masina ô !
 Ilay voasatro-tsilo teo,
 Dia Jeso, Jeso, Jeso,
 Tompo tokana !

[V2]
 Ry afa-pahoriana,
 Izay ao an-dapany !
 Nombany tao an-dalana,
 Ka saotra, laza, hery,
 Aoka ho Azy re !

[V3]
 Taranaky ny lavo ô,
 Izay natsangany,
 Ekeo Izy eram-po,
 Ka saotra, laza, hery,
 Aoka ho Azy re !

[V4]
 Ry firenena marobe
 Ambany lanitra !
 Miankohofa, maneke
 Fa Jeso, Jeso, Jeso,
 No Mpanjaka re !</lyrics>
<title>Satrohy voninahitra FFPM159</title>
</song>