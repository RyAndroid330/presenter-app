<?xml version="1.0" encoding="UTF-8"?><song><title>Jeso o, Mpiandry tsara! FFPM624</title>
<lyrics>[V1]
 Jeso ô, Mpiandry tsara !
 Sambatra ny ondrinao,
 Hianao no mialoha
 Hanarahanay Anao ;
 // Mitariha, mitariha
 Ny fanahinay izao //

[V2]
 Jeso ô, Mpiandry tsara !
 Fohy ny fisainanay ;
 Hianao mahay manoro
 Lalana halehanay :
 // Mitariha, mitariha
 Ny fanahinay izao //

[V3]
 Jeso ô, Mpiandry tsara !
 Tsinjonao ny dianay ;
 Ondry very ka ho faty
 Raha tsy hatoninao ;
 // Mitariha, mitariha
 Ny fanahinay izao //

[V4]
 Jeso ô, Mpiandry tsara !
 Izao alehanay izao
 Ala be sy làla-mafy,
 Maty re ny ondrinao ;
 // Miarova, miarova
 Ny fanahinay izao //

[V5]
 Jeso ô, Mpiandry tsara !
 Mafy re ny tahotray ;
 Bibidia mamiravira
 Mampivadi-po anay :
 // Miarova, miarova
 Ny fanahinay izao //

[V6]
 Jeso ô, Mpiandry tsara !
 Ento mody izahay ;
 Aminao ny valan'ondry
 Tsy mba misy tahotra,
 // Mitariha, mitariha
 Ny fanahinay izao //</lyrics>
<hymn_number>624</hymn_number>
<author>W.B. Bradbury</author>
</song>