<?xml version="1.0" encoding="UTF-8"?><song><title>Jesosy no Mpiandry ny Fiangonanay FFPM268</title>
<lyrics>[V1]
 Jesosy no Mpiandry
 Ny Fiangonanay ;
 Ny feon'izy ireny
 No feo fantatray,
 Ka tsy mba vala maro
 Ny Fiangonanay ;
 Iray tsy hay zaraina,
 Tapahin-Tompo iray.

[V2]
 Iray no Vatolampy
 Izay iorenanay,
 Iray no Fehizoro
 Izay ikambanany,
 Iray no Mofon'aina
 Fihinanay etý,
 Iray no antenaina
 Ho azonay arý.

[V3]
 Tabain'ny hevi-diso,
 Kanefa mbola iaraý ;
 Ny saina tsy mitovy
 Tsy mahazara anay ;
 Fisoko maromaro,
 Kanefa vala iray
 Ny Tompo no mpiaro
 Ny Fiangonanay.

[V4]
 Ny teny samy hafa,
 Ny fomba tsy miray,
 Tsy misy maharava
 Ny fikambananay ;
 Ny fanenjehana aza
 Vao mainka mampiray
 Sy mahatsara laza
 Ny Fiangonanay.

[V5]
 Ry Jeso ! hatanjaho
 Ny Fiangonanao,
 Ny fony halalaho
 Mba hitoeranao ;
 Izay firaisan-tsaina
 Miseho hatretý,
 Velomy hanana aina
 Hitohy hatrarý.</lyrics>
<hymn_number>268</hymn_number>
<author>S.S. Wesley</author>
</song>