<?xml version="1.0" encoding="UTF-8"?><song><author>J.P.E. Hartmann</author>
<hymn_number>333</hymn_number>
<title>Hody, Tompo, izahay FFPM333</title>
<lyrics>[V1]
 Hody Tompo, izahay
 Miaraha aminay,
 Ka tahio ny teninao
 Mba hamorona aim-baovao,
 Sao mivory foana
 Izahay mpiangona.

[V2]
 Marobe ny rafinay
 Ta-hamandrika anay ;
 Tompo, miarova anay,
 Sao dia very izahay ;
 Mitoera aminay
 Ao an-tokantranonay.

[V3]
 Efa renay taminao
 Fa anay ny lanitrao,
 Efa namboarinao
 Mba ho an'ny olonao ;
 Ka tariho, Tompo ô,
 Hody ao ny Zanakao !</lyrics>
</song>