<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>129</hymn_number>
<author>L.M. Linderman</author>
<lyrics>[V1]
 Any naraina
 // Ilay Avotr'aina //
 Natsangan-dRay ;
 Resy ny ota
 // Ka ny mpanota //
 Mihoby indray.
 Any naraina, ...sns.

[V2]
 Hira hiraina
 // ny Tompon'aina //
 Isaoranay ;
 Ory ny fony
 // mba hamitony //
 Ny sentonay.
 Hira hiraina, ...sns.

[V3]
 Faly ny very
 // tsy manan-kery //
 Ny helokay ;
 Jesosy Tompo
 // dia mampanompo //
 Ny rafinay.
 Faly ny very, ...sns.

[V4]
 Hisy maraina
 // ny Tompon'aina //
 Ho avy indray ;
 Izy hizara
 // ny lova tsara //
 Homena anay.
 Hisy maraina, ...sns.</lyrics>
<title>Any naraina, Ilay Avotr'aina FFPM129</title>
</song>