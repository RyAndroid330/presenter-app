<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>565</hymn_number>
<title>Mandrahona ny andronay FFPM565</title>
<lyrics>[V1]
 Mandrahona ny andronay,
 Ka raiki-tahotra izahay ;
 Avia, manampia anay:
 Ry Tompo ô ! vonjeo !

[V2]
 Ny teninao no tokinay,
 Ny herinao no tanjakay ;
 Afaho loza izahay :
 Ry Tompo ô ! vonjeo !

[V3]
 Fa misy ifaharanay,
 Ka toky be no azonay ;
 Hianao no iankinanay :
 Ry Tompo ô ! vonjeo !

[V4]
 Noho ny nahaterahanao,
 Noho ny nahafatesanao,
 Sy noho ny fifonanao :
 Ry Tompo ô ! vonjeo !</lyrics>
</song>