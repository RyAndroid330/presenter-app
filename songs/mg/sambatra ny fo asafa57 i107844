<?xml version="1.0" encoding="UTF-8"?><song><title>SAMBATRA NY FO ASAFA57</title>
<lyrics>[V1]
 Sambatra ny fo izay matoky Anao
 Tsy atopatopan'onja raha manana Anao
 Na dia samy hisedra ihany
 Zava-tsarotra eto an-tany dia
 Sambatra ny fo matoky Anao

[V2]
 Odidinin'ny famindram-ponao isan'andro
 Na ririnina aza mbola mahita masoandro
 Na dia samy hisedra ihany
 Zava-tsarotra eto an-tany dia
 Ravo izay misaina toa Anao

[V3]
 Sambatra ny saina iray safidy Aminao
 Saina mankahala ota nanimba hatrizay
 Na dia samy hisedra ihany
 Zava-tsarotra eto an-tany dia
 Ravo izay misaina toa anao</lyrics>
<hymn_number>57</hymn_number>
<author>Ndriana RAMAMONJY</author>
</song>