<?xml version="1.0" encoding="UTF-8"?><song><author>C.M. Bellman</author>
<hymn_number>813</hymn_number>
<title>Tia zaza FFPM813</title>
<lyrics>[V1]
 Tia zaza
 Tia zaza
 Ny Jesosinay !
 Lanitra nafoiny,
 Zaza notrotroiny,
 Tia zaza
 Tia zaza
 Ny Jesosinay !

[V2]
 Trano tsara
 Tany tsara
 Namboariny ;
 Trano be anjely,
 Ho anay izay kely,
 Trano tsara, ..sns.

[V3]
 Voankazo,
 Voninkazo
 Tsara fofona,
 Tsy halazo intsony
 Ao Edena ambony,
 Voankazo, ..sns.

[V4]
 Zazakely
 Sy anjely
 Samy sambatra ;
 Hira no hirainy
 Ao an-tranon-dRainy.
 Zazakely, ..sns.

[V5]
 Seza tsara,
 Lamba tsara
 Ho antsika ao
 Hiakanjo lava
 Fotsy lalandava
 Seza tsara, ..sns.

[V6]
 Ento mora,
 Ento mody
 Jeso, izahay,
 Ho an-tranon-dRainao,
 Fa ao no tranonay ô !
 Ento mora, ..sns.</lyrics>
</song>