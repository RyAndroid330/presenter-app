<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>193</hymn_number>
<author>Rabanus Maurus</author>
<lyrics>[V1]
 Tahio re, ny teninao
 Ankalazao ny Zanakao,
 Izay nasandratrao ry Ray,
 Ho kiady sy ho aronay.

[V2]
 Ry Jeso ô ! Mpanjakanay,
 Ampandreseo izahay ;
 Ho menatra ny rafinao,
 Raha hitany ny herinao.

[V3]
 Ry Mpampionona anay,
 Ampikambano ho iray
 Ny sampam-piangonana,
 Hiray am-pitiavana.</lyrics>
<title>Tahio, re, ny teninao FFPM193</title>
</song>