<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>162</hymn_number>
<author>A.P. Berggreen</author>
<lyrics>[V1]
 Amen, Jeso no Mpifehy
 Amen, ny Fanahiny,
 Amen, Amen re ny teny
 Mbamin'ny fandraisany
 Amen, ny batisany,
 Amen, ny fiainany.

[V2]
 Amen, Jeso no Mpanjaka,
 Amen, ny Anarany ;
 Amen, Jeso tonga maka
 Ahy ho anjarany
 Amen, Amen ary to
 Izy, Izay inoako !

[V3]
 Amen, ny fanantenana
 Zavatra maharitra ;
 Amen re, ny fifindrana,
 Raha mankao an-danitra
 Amen, ny fiadanana,
 Amen, ny fiainana !

[V4]
 Aoka isika hihira Amen,
 Amen ho mandrakizay !
 Jeso, mba valio Amen,
 Dia ho faly izahay ;
 Amen, no ho hiranay
 Raha mby Aminao izahay.</lyrics>
<title>Amen, Jeso no Mpifehy FFPM162</title>
</song>