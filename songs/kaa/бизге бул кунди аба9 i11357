<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9</hymn_number>
<author>Джой Ф. Паттерсон</author>
<title>Бизге бул кунди Аба9</title>
<lyrics>[V1]
.   G
 // Бизге бул кунди //
.     D
 // Қудай жаратқан. //
.   D
 // Шадланамыз, //
.     G
 // Ойнап-күлемиз! //
.C                  D        G
 Бизге бул кунди, Қудай жаратқан!
. C             D      G
 Шадланамыз, ойнап-күлемиз!
.    G
 // Бизге бул кунди //
.  G    D    G
 Қудай жаратқан!

[V2]
 // Ийса - Тәңир! //
 // Сени сүйемиз! //
 // Өмиримизди, //
 // Саған арнаймыз! //
 Ийса - Тәңир, Сени сүйемиз!
 Өмиримизди, Саған арнаймыз!
 // Ийса - Тәңир! //
 Сени сүйемиз!

[V3]
 // Кел кел достым //
 // Ийса масыхқа //
 // Ол береди //
 // Мангилик өмирди //
 // Кел-кел достым Ийса масихқа //
 // Ол береди Мангилик өмирди //</lyrics>
<key>G</key>
</song>