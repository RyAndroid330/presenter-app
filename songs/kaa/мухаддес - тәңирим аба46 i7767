<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.    Dm                                          Gm
 //  Мен ушын Сен, келгенсең, бул дүнъяға, бизлерге,
.                 Dm  A               Dm
 Қутқарыўға бизлерди, жаманлықтан мәңгиге!  //

[C1]
.                     Gm             Dm
   //  Мухаддес - Тәңирим, Сени суйемен!
.                 A              Dm
   Мухаддес - Тәңирим, Саған келемен!  //

[V2]
 //  Мен ушын қымбат болған, мени суйген - Әзизим!
 Азап шектиң, мен ушын, Өз қаныңды төктиң - Сен!  //

[V3]
 //  Алғысымды айтаман Саған, Қутқарғаныңа мәңгиге,
 Журегимнен сыйлайман, Өз өмириңди бергениңе!  //</lyrics>
<key>F</key>
<title>Мухаддес - Тәңирим Аба46</title>
<author>Гулмира (Мойнақ), Рустам</author>
<hymn_number>46</hymn_number>
</song>