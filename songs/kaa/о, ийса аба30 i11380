<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>30</hymn_number>
<author>Кеңесғали Айимбетов</author>
<lyrics>[V1]
.   G                              Bm
 // Қудайым - деп, алғыслайман атыңды,
.C                             D
 Тәңирим - деп, тән аламан - Балаңды! //

[C1]
.         G                    Bm
   // О, Ийса - Сени мақтайман мен,
.    C                       D
   Шын жүректен, атыңды алғыслайман! //

[V2]
 // Бизлер ушын атанаққа қағылдың - Сен!
 Гүна ушын қурбан болып тирилдиң - Сен! //

[V3]
 // Қарақалпак елинеде келипсең
 Өз атыңды таныстырдың бизлерге! //

[V4]
 // Қутқарылыў жолын бердиң бизлерге,
 Мәңгиликке сөзиң менен жетеле! //</lyrics>
<key>G</key>
<title>О, Ийса Аба30</title>
</song>