<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>38</hymn_number>
<author>Гулмира (Мойнақ), Рустам</author>
<lyrics>[V1]
.    Em          Am           C               Dm   Em
 //  Меҳриңди дәрьяға теңесем, дәрьялардың, шеги болар,  //
.               Am          G          Dm     Em
 //  Теңиздей терең десем, теңизлерде қурып қалар!  //
.    Em                                         Am
 //  Таўдай бийик көз жетпес десем, таўлардыңда шыңы болар,  //
.               Am           C      Dm        Em
 //  Қуяштың өзине теңесем, оның да нуры аз болар!  //

[V2]
 //  Меҳриңе тең келер Сениң, ешнәрсе жоқ, ойлап қарасам!  //
 //  Қүдиретли-кушли Қудайым, барлықты Сен - жаратқансаң!  //
 //  Меҳирге толған көзлериңди, нур жайнаған жүзлериңди,  //
 //  Кулимлеп турған - Өзиңди, ҳеш нәрсеге теңеп болмас!  //</lyrics>
<key>C</key>
<title>Теңи жоқ меҳриң Сениң Аба38</title>
</song>