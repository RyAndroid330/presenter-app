<?xml version="1.0" encoding="UTF-8"?><song><title>Ҳәй халқым! Аба56</title>
<key>Dm</key>
<lyrics>[V1]
.   Dm
 // Тәңиримди алғыслайман,
.Gm
 қәлем алып мен жазаман,
.F
 Журегимнен қосық айтып,
.Cm           Dm
 қосықларымды мен жазаман! //

[C1]
.     Dm
   // Дүнъя мени суймесе де,
.  Gm
   Тәңир мени суйиер екен.
.  Bb
   Дүньяда орын болмаса да,
.  A(Cm)            (Dm)
   Тәңирде орын бар екен! //

[V2]
 // Тәңиримди - алғыслаңлар,
 Оны, ҳеш ўақыт, умытпаңлар!
 Умытсаңыз, ҳәй, адамлар,
 Қараңғылықта қаласыз! //

[V3]
 // Қуўанаман менТәңирге,
 Мени Өзи қутқарғанына.
 Шадланаман мен мәңгиге,
 Тәңирдиң мени тапқанына! //</lyrics>
<author>Гулмира (Мойнақ), Рустам</author>
<hymn_number>56</hymn_number>
</song>