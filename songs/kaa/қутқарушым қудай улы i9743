[V2]
 // Егер сен Оған айтсаң
 Усы сөзди қайталап
 Қутқарыушы кирип келер
 Өмириңди Ол өзгертер //

[V3]
 // Қутқарыушы Ийем бол Сен
 Кешир мени гүнәлыман деп
 Жүрегиңнен шықса бул сөз
 Өмириңди Ол өзгертер //</lyrics>
