<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>47</hymn_number>
<author>Рустам, Гулмира (Мойнақ)</author>
<lyrics>[V1]
.   Em                  C
 // Ийса мени ҳақыйқатқа, Ийса мени муҳаббатқа,
.D                      C        D     Em
 Ийса мени сабыр-тақатқа уйретуши - Устазым! //

[C1]
.     C                    D
   // Ийса мени еркинликке, Ийса мени тура жолда,
.  G                     C         D       G
   Ийса мени мәңги өмирге жетелеушим - Қутқарушым! //

[V2]
 // Ийса мениң - Қурбан қозим, ақлар мени әзиз қаны,
 Журегимде Патшалығы, мәңги Патша - Ийса Өзиң! //</lyrics>
<key>Em</key>
<title>Устазым Аба47</title>
</song>