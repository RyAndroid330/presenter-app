<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>77</hymn_number>
<author>Гулмира (Мойнақ), Рустам</author>
<key>Dm</key>
<lyrics>[V1]
.   Dm                Gm
 // Сен үшин дунъяға келген,
.F   Cm        Dm
 Өзин қурбан еткен! //
.   Dm               Gm
 // Мәңгилик өмирди берген,
.F           C      Dm
 Ийсаға кел, Ийсаға кел! //

[C1]
.     Dm
   // Шөллесең, булақ - Ол, ағып турған,
.  Gm                       Dm
   Аш болсаң, наның - сени тойдырған! //
.     Gm                 Dm
   // Жолыңда, жолдасың болған,
.  F           Cm     Dm
   Ийсаға кел, Ийсаға кел! //

[V2]
 // Қуўантады, Оның - Меҳри,
 Жубатады, айтқан Сөзи! //
 // Қутқарыўшы, Оның - Өзи,
 Ийсаға кел, Ийсаға кел! //</lyrics>
<title>Ийсаға кел! Аба77</title>
</song>