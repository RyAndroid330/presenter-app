<?xml version="1.0" encoding="UTF-8"?><song><author>Гулмира (Мойнақ), Рустам</author>
<hymn_number>35</hymn_number>
<title>Журегимде - Сен! Аба35</title>
<key>C</key>
<lyrics>[V1]
.   Em          Am      Dm        Em
 // Атқан таңлардай жарқырап шықтың,
.         Am     Dm        Em
 Түнек ишинде, жарқырап турдың! //

[C1]
.      Em       Am               Em
   // Ойларымдасаң, журегимде - Сен,
.           Am      Dm          Em
   Алғысым шексиз, мақтаўым шексиз! //

[V2]
 // Билемен Сени әзелден барсаң,
 Көремен Сениң муҳаббатыңды! //

[V3]
 // Сени сүйемиз, Тәңиримиз - Ийса,
 Уллылайман мен мәңгиге Ийса! //</lyrics>
<aka>Атқан таңлардай...</aka>
</song>