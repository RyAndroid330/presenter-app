<?xml version="1.0" encoding="UTF-8"?><song><aka>Жолымды таңладым</aka>
<key>Cm</key>
<lyrics>[V1]
.   C#m
 // Душпанымыз адамлар емес
 Ал қараңғылықтың күшлери
 Душпанымыз адамлар емес
 Ал шайтанның жауыз күшлери //

[C1]
.              C#m
   // Жолымды таңладым
   Душпанды жеңиуге
.           F#m
   Жолымды таңладым
   Мен кейин қайтпайман
.    G#m   C#m
   Жолымды таңладым
   Мен гүресемен
.      F#m              A        H         C#m B C#
   Хәм душпанды жеңемен Қудайдың сөзи менен //

[B1]
.       C#m   Ab Bb
   //// Ийса қәдир Патша,
.  C#m     F#m   G#m
   Ийса жалғыз Тәңир,
.  C#m             A   B
   Ийса Яхуда арысланы! ////</lyrics>
<title>Душпанымыз адамлар емес</title>
<author>Дон Поттер</author>
</song>