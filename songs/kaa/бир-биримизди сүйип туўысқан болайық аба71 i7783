<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>71</hymn_number>
<author>Клаудиа Виллиамс</author>
<title>Бир-биримизди сүйип туўысқан болайық Аба71</title>
<lyrics>[V1]
.Dm        A        Asus      Dm
 Бир-биримизди сүйип туўысқан болайық,
.    Gm      Dm        A      Asus  Dm/D7
 //   Сабырлы, меҳрибан, кишипейил болайық!  //

[V2]
 Ийса мени кеширип, гүнамды алғандай,
 //  Биз де бир-биримизге кеширим берейик!  //

[B1]
   ///  Кеширим берейик!  ///</lyrics>
<key>Dm</key>
</song>