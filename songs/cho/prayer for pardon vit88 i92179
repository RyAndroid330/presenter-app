<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>88</hymn_number>
<author>Loring S. Williams</author>
<aka>Pi̱ki holitopa</aka>
<lyrics>[V1]
 Pi̱ki holitopa
.    
     Chihowa,
 Pi̱ki Chohowa ma!
 Hatak pilbʋsha hosh
 E chi hoho̱yoshke,
.    
     Pi̱ki ma!

[V2]
 Il ayoshoba yʋt
.    
     Pin la̱wa;
 Il aheka yoka
 Ish pi̱ kashoffashke;
 E chim ilbʋshʋshke,
.    
     Pi̱ki ma!

[V3]
 Chi Shilombish okʋt
.    
     Ʋlashke;
 Pi chu̱kʋsh fehna ka
 Ish pi nukfokashke;
 Chi Shilombish okʋt
.    
     Ʋlashke.

[V4]
 Chu̱kʋsh ilbʋsha ya̱
.    
     Et pimá;
 Chu̱kʋsh ilbʋsha ya̱
 Et ish pihi̱mashke;
 E chim ilbʋshʋshke,
.    
     Pi̱ki ma!

[V5]
 Chim anukfila ha̱
.    
     Pi bʋnna;
 Nan isht ilaiyukpa
 Ʋba aiasha ka
 Et ish pihi̱mashke,
.    
     Pi̱ki ma!

[V6]
 Ish pi̱ nukha̱klashke;
.    
     Chisʋs ma!
 Pillikma, Ʋba ya̱
 Pi Shilombish oka
 Ant pisht ish onashke,
.    
     Chisʋs ma!</lyrics>
<title>Prayer for pardon. ƲIT88</title>
<time_sig>6.3.6.6.6.3.</time_sig>
</song>