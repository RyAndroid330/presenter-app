<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>78</hymn_number>
<author>Loring S. Williams</author>
<title>Iloh itibapishi ma! ƲIT78</title>
<time_sig>8.7.8.7.4.7.</time_sig>
<aka>Farewell at the Close of Worship</aka>
<lyrics>[V1]
 Iloh itibapishi ma!
.    
     Himonasi fehna ka
 Eho tishela chi̱ mak osh
.    
     E taloho̱wa hokʋt,

[C1]
   Chisʋs oka
   Il aiokpahanchashke.

[V2]
 Ʋba Pi̱ki im anumpa
.    
     E haiyaklo tuk okʋt
 Ik pi̱ kʋnio pulla hosh,
.    
     Isht il anukfihinlit

[C2]
   Chisʋs oka
   Il im antihi̱yashke.

[V3]
 Il iti̱ filʋmmi kia,
.    
     Pi chu̱kʋsh fehna hokʋt,
 Iti halʋlli pulla na,
.    
     Il itʋnoho̱washke;

[C3]
   Chisʋs oka
   Iloh iakaiyashke.

[V4]
 Pi yʋmohmi pulla tukmʋt
.    
     Pi okcha̱ya ta̱kla kʋt
 Kil iti pesokmak heto,
.    
     Chisʋs pulla tok mak o̱

[C4]
   Ʋba yakni
   Il ai itafamashke.</lyrics>
</song>