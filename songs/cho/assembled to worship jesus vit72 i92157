<?xml version="1.0" encoding="UTF-8"?><song><time_sig>C.M. (8.6.8.6.)</time_sig>
<title>Assembled to worship Jesus ƲIT72</title>
<lyrics>[V1]
 Chisʋs holitopa yokʋt,
.    
     Hatak yoshoba ya̱
 I̱ nukha̱klo hatuk mak osh,
.    
     Ʋlhtobʋt illi tok.

[V2]
 Yʋmohmi pulla tok ona,
.    
     Himak nitak oka,
 Il im itʋnaha kʋto
.    
     Pi yakoho̱mishke.

[V3]
 Hatak e hikia moma
.    
     Pilbʋsha fehna hosh,
 Nana asilhha nitak o̱
.    
     Il itʋnahʋshke.

[V4]
 Hatak eho moyuma kʋt
.    
     Chisʋs pulla hoka,
 Hʋpi chu̱kʋsh mominchi hosh
.    
     E holitoblashke.

[V5]
 Klaist iloh i̱ yimmi tuk osh,
.    
     Nitak ishtaiyopi,
 Ʋba yakni taloho̱wʋt
.    
     Eho chukowashke.</lyrics>
<aka>Chisʋs holitopa yokʋt</aka>
<hymn_number>72</hymn_number>
</song>