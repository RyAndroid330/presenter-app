<?xml version="1.0" encoding="UTF-8"?><song><title>Oh sinners hear, believe and live. ƲIT18</title>
<time_sig>6.3.6.6.6.3.</time_sig>
<aka>Ho Haklo</aka>
<lyrics>[V1]
 Hatak yoshoba ma!
.    
     Ho haklo;
 Chi chu̱kʋsh okʋto
 Okpulo fehnʋshke,
 Chisʋs ʋt achishke:
.    
     Ho haklo.

[V2]
 Aiashʋcheka yʋt
.    
     Chin la̱wa,
 Ik chi̱ kashofokmʋt,
 Nitak cheki kia
 Ilbʋshʋt chilla chi̱;
.    
     A̱hlishke.

[V3]
 Hatak pi̱ kana ma!
.    
     Ho minti;
 Nanta katihmi ho̱
 Chi Okchalinchi ya̱
 Hʋsh shitilema cho
.    
     Oh issa.

[V4]
 Hatak ilbʋsha ma!
.    
     Oh okcha;
 Chi nusi chohmi kʋt
 Chi okcha pullashke;
 Ile kostinichi;
.    
     Oh okcha.

[V5]
 5 Himak a fehna ka
.    
     Ho yimmi;
 Nan isht ilaiyukpa
 Ik chi bʋnno ka wa;
 A̱hli, hʋsh ahnashke;
.    
     Ho yimmi.

[V6]
 Hatak ihinli ma!
.    
     Okcha̱ya;
 Chisʋs pulla hokʋt
 Chi 'lhtobʋt illi tok;
 Hʋsh yimmi pullashke;
.    
     A̱hlashke.</lyrics>
<hymn_number>18</hymn_number>
<author>Loring S. Williams</author>
</song>