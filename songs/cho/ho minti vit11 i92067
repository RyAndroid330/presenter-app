<author>Cyrus Byington</author>
<lyrics>[V1]
 // Hatak h čsh puta ma!
.    
     Ho minti; //
 Hatak h čsh puta ma!
 Yakni achukma k čt
 ∆≤ba talai čshke;
.    
     Ho minti.

[V2]
 // Hatak h čsh moma ma
.    
     Ho yimmi; //
 Hatak h čsh moma ma!
 Chis čs im anumpa
 H čsh yimmi pullashke;
.    
     Ho yimmi.

[V3]
 // Okla e moma k čt,
.    
     Kil ia // /
 Chis čs piŐĪ hullo hosh
 Pi  člhtob čt illit,
 Falam čt tani tok;
.    
     Kil ia.

[V4]
 // Chis čs im anumpa
.    
     Ke yimmi //
 Chis čs im anumpa
 Achukma fehna ka
 ChuŐĪk čsh isht aŐĪlhi hosh
.    
     Ke yimmi.

[V5]
 // ∆≤ba ayukpa y čt
.    
     Pimma chiŐĪ; //
 Chis čs ai ahanta
 Y čmma il onakm čt
 ∆≤ba ayukpa y čt
.    
     Pimma chiŐĪ.

[V6]
 // ∆≤ba il onakm čt
.    
     Pilla wa; //
 Yakni achukma yaŐĪ
 Y čmma il onakm čt,
 Ant čt e bilia;
.    
     Pilla wa.</lyrics>
