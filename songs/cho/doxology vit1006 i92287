<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1006</hymn_number>
<aka>Ʋba Pi̱ki okʋt</aka>
<lyrics>[V1]
 Ʋba Pi̱ki okʋt,
 Ushi Chisʋs fehna,
 Shilombish achi kʋt,
 Chihowa mak oke:
.    
     Pi chu̱kʋsh a̱ mominchi hosh,
.    
     Isht il aiokpahanchashke.</lyrics>
<title>Doxology ƲIT1006</title>
<time_sig>H.M. (6.6.6.6.8.8.)</time_sig>
</song>