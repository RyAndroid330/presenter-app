<?xml version="1.0" encoding="UTF-8"?><song><author>Captain Joseph Dukes</author>
<hymn_number>153</hymn_number>
<title>Sacramental ƲIT153</title>
<time_sig>L.M. (8.8.8.8.)</time_sig>
<aka>Chisʋs pi Okchalinchi ma!</aka>
<lyrics>[V1]
 Chisʋs pi Okchalinchi ma!
 Hatak nan ashʋchi puta
 Ʋlhtobʋt a chilla̱ he mʋt,
 Chim ʋlla ish i̱ hullo tok.

[V2]
 Yohmi ma okcha̱ya ta̱klʋt
 Chithaha̱nʋt impa hi o̱,
 Nan ʋlhpisa holitopa
 Ilʋppa ish apesa tok.

[V3]
 Yʋmohmi ka himak nitak
 Chim antia yʋt chim impʋt,
 Yakoht il aiasha hoka
 Ish pi aiokpahanchashke.

[V4]
 Nan il ashʋchi chatuk ʋt
 Pi nukha̱klo fehna kak osh
 E chim ilbaha̱sha hoka,
 Momint ish pi̱ kashoffashke.

[V5]
 Yohmi pulla na, chim a̱hlit,
 Nitak ont pim ai ʋhli cha,
 Ʋba ish ai ahanta ka
 Onʋt e chibai impashke.</lyrics>
</song>