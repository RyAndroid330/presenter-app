<?xml version="1.0" encoding="UTF-8"?><song><author>Captain Joseph Dukes</author>
<hymn_number>138</hymn_number>
<aka>Aiokcha̱ya anumpa hos</aka>
<lyrics>[V1]
 Aiokcha̱ya anumpa hosh
 A̱ya ka, ho haklo;
 Yoshobʋt ilbʋsha puta
 Isht kostini yoke.

[V2]
 Ayoshoba a kʋniʋt
 Aiokhlilika yo̱
 Il itʋnowa hoh kia
 Isht pi kuchi yoke.

[V3]
 Aiokcha̱ya yoke yakni
 Moma fullota kʋt
 Ik achi; Ʋba ai okla't
 Achi mak inlashke.</lyrics>
<title>The Gospel ƲIT138</title>
<time_sig>C.M. (8.6.8.6.)</time_sig>
</song>