<?xml version="1.0" encoding="UTF-8"?><song><time_sig>8.7.8.7.4.7.</time_sig>
<title>Close of Worship ƲIT77</title>
<lyrics>[V1]
 Itibapishi li puta
.    
     Chisʋs a binili kʋt
 Yakni achukma fehna ka
.    
     Eho pesa pullashke:

[C1]
   Chisʋs oka
   Il i̱yimmi pullashke.

[V2]
 Chisʋs im anumpa hoka
.    
     E haiyaklo tuk okʋt,
 Ik pi̱ kʋnio pulla hosh
.    
     Il ithana pullashke

[C2]
   Chisʋs oka
   Il i̱ yimmi pullashke.

[V3]
 Ʋba yakni achukma kʋt
.    
     Pim ʋlhtaha tok oke:
 Il ai okcha̱ya he mak o̱,
.    
     Chisʋs ʋt pim ikbi tok:

[C3]
   Chisʋs oka
   Il i̱ yimmi pullashke.</lyrics>
<aka>Itibapishi li puta</aka>
<hymn_number>77</hymn_number>
<author>Loring S. Williams</author>
</song>