<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>110</hymn_number>
<title>Hima̱k nitak fehna kʋn ƲIT110</title>
<time_sig>C.M. (8.6.8.6.)</time_sig>
<aka>Wedding Song</aka>
<lyrics>[V1]
 Hima̱k nitak fehna kʋno,
.    
     Ʋba Pi̱ki ʋto,
 Ik yʋmohmi, ish ahni na,
.    
     E taloho̱wʋshke.

[V2]
 Hatak yak hikia hokʋt
.    
     Ohoyo ilʋppa
 Halʋllit hikia tuk ʋt,
.    
     I̱ holitopashke.

[V3]
 Ʋba pin Chitokaka ma!
.    
     Okcha̱ya ta̱kla ka,
 Chishno puyulla i̱ kanʋt
.    
     Ish apehinlashke.

[V4]
 Okcha̱ya iti̱ ta̱kla kʋt
.    
     Iti̱ hoyullashke:
 Chihowa holitopa ma!
 Ish aiokpanchaske.

[V5]
 Nana achukma bieka
.    
     Anukfihinli kʋt,
 Iti halʋlli achukmʋt
.    
     Bilia pullashke.

[V6]
 Nan okpuyulo hokʋto
.    
     Ik onutolo hosh,
 Nitak moma itapela
.    
     Achukma pullashke.

[V7]
 Shilombish Holitopa ma!
.    
     Chu̱kʋsh hanta 'chukma
 Isht ish aiokpahanchi na,
.    
     Na̱ yukpa pullashke.</lyrics>
</song>