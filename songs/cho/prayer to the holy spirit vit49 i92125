<?xml version="1.0" encoding="UTF-8"?><song><author>Loring S. Williams</author>
<hymn_number>49</hymn_number>
<title>Prayer to the Holy Spirit ƲIT49</title>
<time_sig>8.6.8.6.</time_sig>
<aka>Chihowa Holitopa ma!</aka>
<lyrics>[V1]
 Chihowa Holitopa ma!
 Himak nitak oka,
 Chi Shilombish achukma yʋt
 Pi chu̱kʋsh pulla ka.

[V2]
 Nuktalala he mak ona,
 E chim asi̱lhhʋshke;
 Chisʋs pulla tok mak ona,
 Ish pi̱ nukha̱klashke.

[V3]
 Chisʋs pi Okchalinchi ma!
 Et pi̱ nukha̱klo cha,
 Chim anukfila achukma
 Ish pi nukfokashke.

[V4]
 Chi Shilombish achukma yʋt
 Nitak moma hoka
 Pi apehinla hi oka,
 E chim asilhhʋshke.</lyrics>
</song>