<?xml version="1.0" encoding="UTF-8"?><song><time_sig>C.M. (8.6.8.6.D.)</time_sig>
<title>This is a world of sorrow ƲIT115</title>
<lyrics>[V1]
 Yakni 'lʋppa anukha̱klo
.    
     Chinto pihi̱sa li;
 Nishkin okchi a mihinti
.    
     Bano pihi̱sa li;

[C1]
   Illi kia a sahanli
.      
       Ʋlla't ʋm ihinli;
   Pihi̱sa li kʋt sʋlbʋsha,
.      
       Ai ilbʋsha yoke.

[V2]
 An chuka achʋfa kia
.    
     Ihinli pisa li;
 Hatak moma mʋt ihinli;
.    
     Anukha̱klo yoke:

[C2]
   Ayukpa afoha a̱hli't
.      
       'Lʋppak inli kʋno
   Iiksho kʋt, a̱hli pulla,
.      
       Aiahni li fehna.

[V3]
 Nana ai a̱hli 'chukma kʋt
.    
     Yakni 'lʋppa iksho;
 Ʋba yoka a̱sha pulla,
.    
     Aiahnit sa yukpa,

[C3]
   Hatak ʋt na̱ yukpa, miha
.      
       Pi yukpa, il achi;
   Ʋba yak o̱ a fehna he
.      
       Aiahni li hoke.

[V4]
 Ʋba yak o̱ hʋpin chuka
.    
     A̱hli yʋt aiasha;
 Yʋmma nana aiilbʋsha
.    
     Iksho ka hi oke.

[C4]
   Himonasi ya̱ pilbʋsha
.      
       Pi nukha̱klo't laua,
   Ʋba ya̱ il onakmʋto,
.      
       Pi yukpa chinta he.</lyrics>
<aka>Yakni 'lʋppa anukha̱klo</aka>
<hymn_number>115</hymn_number>
</song>