<?xml version="1.0" encoding="UTF-8"?><song><author>Tʋnʋp in Chʋfa</author>
<hymn_number>70</hymn_number>
<lyrics>[V1]
 Himak nitak fehna hoka
.    
     Pim anukfila ha̱
 Ish pi̱ kashoffi pullashke;
.    
     Chisʋs pi̱ Shahli ma!

[V2]
 Ʋba Pi̱ki Chihowa hʋt
.    
     Ish apihi̱sa hosh,
 Ik yʋmohmi, ish ahni na,
.    
     Hatak e toba tok.

[V3]
 Hatak ʋt okcha̱ya chi̱ ho̱
 Chihowa Ushi mʋt
 Im anumpa holitopa
 Hatak a̱ ima tok.

[V4]
 Chisʋs pi̱ Shahli chia ma!
.    
     Chu̱kʋsh yohbi fehna
 Auet ish pima pullashke,
.    
     E chim ilbʋshʋshke.

[V5]
 Himak nitak fehna hoka,
.    
     Ʋba anumpa ha̱
 Haklo pi bʋnna fehna hosh
.    
     Il itʋnahʋshke.

[V6]
 Pit e chim anumpohonli
.    
     Auet ish haklashke;
 Shilombish Holitopa ya̱
.    
     Ish pima pullashke.</lyrics>
<time_sig>C.M. (8.6.8.6.)</time_sig>
<title>Himak nitak fehna hoka ƲIT70</title>
</song>