<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (شايل من طبعك همي .. وأنا من طبعي أناني
 تملي واقف جنبي .. بردوا بسيبك وأعاني)2
 (أنا عارف إني عنيد .. بس رافض كده
 عايش عيشة عبيد .. نفسي متمردة)2
 القرار - (بس أنا جاي ليك واثق فيك .. قلبك مليان حنان
 وإن مرة تهت عن عينيك .. هارجع وأخد أمان)2
 (أنا عارف إنك مستني هناك .. والراحة ديَّ تكون وياك)2
 (ربي جاي أقول لك .. هاعيش معاك)2
 (بس أنا جاي ليك واثق فيك .. قلبك مليان حنان
 وإن مرة تهت عن عينيك .. هارجع وأخد أمان)2
 2- (زمان من صغر سني .. وإنت تملي هنا
 نفسي يا نفسي تحني .. وتكوني مع ربنا)2
 (سيبك من العناد .. وكفاية كتر البعاد
 ربي مستني هناك .. واقف لك في المعاد)2</lyrics>
<title>طبعي أناني</title>
<hymn_number>11207</hymn_number>
<author>مينا إسحق, مينا إسحق</author>
</song>