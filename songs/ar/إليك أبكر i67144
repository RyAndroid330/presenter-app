<hymn_number>1914</hymn_number>
<title>إليك أبكر</title>
<lyrics>[V1]
 1- إليـــك أبكــــر .. يا إلهــــــــــي .. عطشت لك نفسي
 كأرضٍ يابســــــة .. لا مـــاء فيهــا .. هكذا نحوك قلبي
 كلـــــت عينـــــايَ .. مــن انتظــــارك .. وتعبت من صراخي
 (ككثرة مراحمك .. التفـــت إلـــــيَّ .. بحق خلاصك نجني)2
 2- اقترب إلــــيَّ .. فكنــــــــــــــــــــــي .. أسرع إلى معونتي
 حبال الهـــــاوية .. أطبقــت علــــيَّ .. تعبت من شقاوتي
 لا تطرحنـــــــــــي .. مــن أمامـــــــــك .. وجهك لا تحجبه عني
 (إليـــك أخطـــــــأت .. والشــــر صنعـــت .. ألا تعود أنت فتحيني)2
 3- أحتاج لدمـــــك .. يا إلهـــــــــــي .. ليســــتر خطيتـــــي
 حمـــــــــاماً مقـــدسًا .. حتى العظـــام .. ارحمني وانهض قلبي
 عنــــد صليبــــــــــك .. ارســـــــــل نــــــارك .. لتحـــرق كل آثامــي
 (أتأمل في حبك .. في صدق وعدك .. أراك إلهي تمسح دمعتي)2
 4- احبـــك يا إلهــي .. يا قوتـــــــــــي .. مبــــاركٌ يا صخــــــرتي
 حمايتـي سنــــدي .. ملجــــــأي متكلـــــــي .. أنت ربي منير ظلمتي
 أحيـــــا لمجــــــدك .. لطـــــوع أمــــــــرك .. لا بقوتي بل بروحك
 (اشعلني بنـــارك .. لأبقــــــى قربـــــك .. ضعفي يرفع بشخصك)2</lyrics>
</song>