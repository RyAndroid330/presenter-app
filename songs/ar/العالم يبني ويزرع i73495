<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (العالم يبني ويزرع .. وتملي مش شبعان)2
 (همه يلبس ويقلع .. وعن يسوع غفلان)2
 القرار- (لكن أنا مش من هنا .. ده هنا عالم فاني)2
 (لا مال ولا جاه ولا غنى .. أنا ليَّ وطن تاني)2
 2- (الناس بتجري وتكدح .. ورا سيد اسمه المال)2
 (وزرع الشر ما ينفع .. ده كل شيء زوال)2
 3- (شايل هم الأيام .. محروم من السلام)2
 (دي شكوى وكتر كلام .. من الضيق والآلام)2
 4- (واحد منفوخ ع التاني .. زي الحصان الجامح)2
 (يعمل للكلمة معاني .. ولا يعرف مرة يسامح)2
 5- (يبكوا على الحظ الخاين .. مش جاي على هواهم)2
 (عاوزين في الدنيا جناين .. والعمر يستناهم)2</lyrics>
<title>العالم يبني ويزرع</title>
<hymn_number>799</hymn_number>
<author>الأب مكاري يونان, الأب مكاري يونان</author>
</song>