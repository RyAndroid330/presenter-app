<?xml version="1.0" encoding="UTF-8"?><song><title>إذا غابت الشمس</title>
<lyrics>[V1]
 إذا غَابت الشَّمسُ خلفَ الغيومْ
 وأضحى النَّهَارُ كَليلٍ طَويلْ
 وإن غَطَّتْ السُحْبُ نورَ النجومْ
 وقُلْتَ في ضيقِكَ أَينَ السبيلْ

[C1]
   هَلُمَّ.. هَلُمَّ ضعيفَ الفؤادْ
   فَنورُ الرجاءِ يَعُم العبادْ
   وكُلُّ طريقٍ مريرٍ تراهْ
   سَيُفْضِي بِنَفْسِكَ نَحْوَ الحَيَاهْ

[V2]
 وإنْ كُنْتَ تَقْضي طِوالَ السنينْ
 تجوب بنفسك عرض القفارْ
 وتَسعَى وتَسعَى بقلبٍ حَزينْ
 لأنك تَبْغى سَريعَ الثمارْ

[V3]
 تَعَالَ وَ قِفْ تَحْتَ نَجْمِ السَّماءْ
 ففي الشرقِ ذَا قدْ بَدَا مُرشدًا
 وسِرْ في الطَّريقِ عَلَىْ هَدْيِهِ
 هُنَاكَ يسوعُ هُنَاكَ الهدىْ

[V4]
 سيملأ قلبك نور المسيح
 ويهدأ روعُك إذ تستريح
 ففي جنبه قد تركنا الجراح
 ومن قلبه فاض حب صريح</lyrics>
<aka>إذا غابت الشمس خلف الغيوم</aka>
<hymn_number>10200</hymn_number>
<author>Ezzat Zaki, Willian Gendy</author>
</song>