<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8430</hymn_number>
<lyrics>[V1]
 1- (قلبي في اشتياقٍ .. إلى لحظة اللقاء)2
 (فمتى ستأتي .. ويتم الرجاء)2
 القرار- (هو كل آمالي .. وانا في الغربة)2
 (يسوع حبيبي .. كل منيتي)2
 2- (إن طال إنتظاري .. فلابد أن أراك)2
 (هذا شوق قلبي .. أبقى في سماك)2
 3- (العواصف تهدأ .. وستسكن الرياح)2
 (وأرى حبيبي .. والقلب يرتاح)2</lyrics>
<title>قلبي في اشتياق</title>
</song>