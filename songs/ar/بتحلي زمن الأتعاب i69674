<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (بتحلي زمن الأتعاب تتمجد في لهيب النار)2
 (ولا يسكن في العمر صعاب دي حياتنا في إيدين جبار)2
 القرار- (ده الهنا ينبوع أفراح بيبدل بالحب جراح)2
 كل حياتنا تقول لا سواك وحدك ولاحدش وياك
 كل حياتنا تقول وحدك لا سواك
 2- (وإيمانا بيمد جسور بنخطي من فوقها أنين)2
 (والفخ بيصير مكسور وتعوض أيام وسنين)2
 3- (خطاوينا بتشهد عن حي موجود بيحقق أعاجيب)2
 ( في الحاضر وزمنا الجاي راح يصبح الفرح سكيب)2
 4- (وجهك قدامنا بيسير وبنعبر والمجد يذيد)2</lyrics>
<title>بتحلي زمن الأتعاب</title>
<hymn_number>4373</hymn_number>
<author>هاني أنيس, قس أمجد سعد</author>
</song>