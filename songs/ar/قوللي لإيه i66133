<?xml version="1.0" encoding="UTF-8"?><song><author>باسم شكري, باسم شكري</author>
<hymn_number>11136</hymn_number>
<lyrics>[V1]
 1- (قول لي إيه شاغل بالك .. ومخليك مش متطمن
 وبتشتكي دايمًا حالك .. وبتحسبها وبتخمن)2
 (شكلك كده ناسي إلهك .. ناسي وعوده وكلامه
 وإختبارات الماضي معاه .. ياللا أطلب منه سلامه)2
 2- (قول لي فين فرحة قلبك .. ليه واخداك الدوامة
 ليه شايل دايمًا همك .. راحت فين الإبتسامة)2
 (شكلك كده ناسي إلهك .. مشغول أوي أوي بظروفك
 أو عندك شك في حبه .. قوم صلي وإهزم خوفك)2
 3- (قول لي ليه خايف قلقان .. مش مستمتع بحياتك
 بقالك على الحال ده زمان .. فين تسبيحك وصلاتك)2
 (شكلك كده ناسي إلهك .. ناسي إنه معاك في الضيق
 هيمشيك فوق الأمواج .. أو يفتح في البحر طريق)2
 4- (قول لي ليه مشغول بالناس .. بتراقب كل تصرف
 وبقيت على طول حساس .. بقيت غريب أوي متكلف)2
 (شكلك كده ناسي إلهك .. اللي طبع فيك بصماته
 خلقك على صورته وشبهه .. عشان تحيا بنفس حياته)2</lyrics>
<title>قوللي لإيه</title>
</song>