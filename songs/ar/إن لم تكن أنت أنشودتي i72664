<?xml version="1.0" encoding="UTF-8"?><song><author>ماهر فايز, ماهر فايز</author>
<hymn_number>723</hymn_number>
<lyrics>[V1]
 1- (إن لم تكن أنت أنشودتي)2 .. (فلن أرنم للأبد)2
 (فأنت لي نشيدي سيدي)2
 القرار- (أنت أمامي وعن يميني)2 .. (أنت بقربي أنت بقلبي)2
 (ولاسمك ربي يسوع أنتمي)2
 2- (إن لم يسر أمامي وجهك)2 .. (لن أخطو من هنا بدونك)
 (فأنت لي نوري مرشدي)2
 3- (لو لم يكن كلامك لذتي)2 .. (لهلكت إذن في مذلتي)2
 (فأنت لي نبع تعزيتي)2
 4- (إن لم تبني وتحرس قلعتي)2 .. (فباطلٌ تعبي وسهري)2
 (فأنت صانعي وصخرتي)2
 5- (إن لم تباركني سيدي)2 .. (لن أطلقك ولو كسرتني)2
 (فأنت لي الآن قوتي)2</lyrics>
<title>إن لم تكن أنت أنشودتي</title>
</song>