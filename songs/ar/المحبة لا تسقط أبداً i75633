<?xml version="1.0" encoding="UTF-8"?><song><title>المحبة لا تسقط أبداً</title>
<lyrics>[V1]
 (المحبة لا تسقط أبدًا)2
 ونحن قد عرفنا نحن قد صدقنا
 (المحبة التي لله فينا)2
 (الله محبة أحبنا الله محبة يحبنا)2
 ومن يثبت في المحبة (يثبت في الله)2
 والله فيه
 (المحبة لا تسقط أبدً)5</lyrics>
<author>يوحنا 16:4 و 1كورنثوس 8:13, جوني هاشم</author>
<hymn_number>9936</hymn_number>
</song>