<?xml version="1.0" encoding="UTF-8"?><song><title>روح الرب الساكن</title>
<lyrics>[V1]
 1- (روح الرب الساكن في أعماق قلبي .. يجعلني أبتهج)2
 (أبتهج أبتهج .. أبتهج دومًـــــــا)2
 2- (روح الرب الساكن في أعماق قلبي .. يجعلني أهلل)2
 (أهلل أهلل .. أهلل دومًــــــا)2
 3- (روح الرب الساكن في أعماق قلبي .. يجعلني أصفق)2
 (أصفق أصفق .. أصفق دومًـــــا)2</lyrics>
<author>مترجمة, لحن أجنبي</author>
<hymn_number>218</hymn_number>
</song>