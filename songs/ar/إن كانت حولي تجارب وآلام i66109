<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (إن كانت حولي تجارب وآلام
 فالفرح في قلبي دومًا وسلام)2
 (ويسوع ربي من أحبه
 في أتون النار أنظر شخصه)2
 هللويا هللويا هللويا
 القرار- هللويا هللويا هللويا
 كل شعب الرب يفرح هللويا
 (كل الآلام تزول والحزن والدموع
 أفراحنا تدوم مادام مع يسوع)2
 هللويا هللويا هللويا
 2- (حتى إن سكت لساني في ثبات
 قلبي يفرح قلبي يهتف للممات)2
 (أن رب المجد قد أحبني
 روحه القدوس قد وهبني)2
 هللويا هللويا هللويا
 3- (ليس لي غيره سند أو معين
 فهو إلى الأبد سيظل أمين)2
 (إن قلبي ينسبي في حبه
 ويغني دائمًا بفضله)2
 هللويا هللويا هللويا
 4- (ربنا يسوع بهاء مجد الله
 جاء للإنسان بالدم إفتداه)2
 (صار لي أغلى حبيبٍ وصديق
 حبه يسندني طول الطريق)2
 هللويا هللويا هللويا</lyrics>
<title>إن كانت حولي تجارب وآلام</title>
<hymn_number>11112</hymn_number>
</song>