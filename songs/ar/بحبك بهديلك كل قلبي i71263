<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 بحبك بهديلك كل قلبي .. بحبك
 بهديلك كل عمري ..
 بحبك بحبك بحبك .. يا يسوع
 يا يسوعي حبك لي هو
 أغلي ما فى حياتي
 بحبك تتغير كل قلبي
 .. بحبك
 بتغير من طبيعتي ..
 بحبك بحبك بحبك .. يا يسوع
 لولا حبك مين أنا لولا عطفك فين هالاقي الهنا

[V2]
 وألقى حبك يضمني بكل ما فيا بتحبني

[V3]
 يا رحيم .. يا رحيم .. يا رحيم .. يا رحيم

[V4]
 وجوه حضنك أرتاح أنا وفى جمالك هاملي الدنيا غني

[V5]
 يا أحلى حاجة فى دنيتي ده أنت الفرحة يا بسمتي

[V6]
 يا يسوع .. يا يسوع .. يا يسوع .. يا يسوع</lyrics>
<title>بحبك بهديلك كل قلبي</title>
<hymn_number>5893</hymn_number>
</song>