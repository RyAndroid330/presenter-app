<?xml version="1.0" encoding="UTF-8"?><song><title>ع باب قلبي</title>
<lyrics>[V1]
 ع باب قلبـــي بليـــلة مرّيـــــــــت
 نورك شعشـــــع عمــــري ضــــوّيت
 لوّنت حيــاتي بلمســـــة
 حســــيت صـــــارت حلـــوة أيــــــــــــامي
 ياما بالخطيـــــة سنينــي قضيـــت
 شهـوة بـــــاعتني وأنـــــا اشتريــت
 ولما كتير يئست ركعت وصــليت دخلك شيــــل
 عنـــــــي آلامـــي
 يـــــــا يســــــوع خلينـي حـدك أنــا
 بدي كمـــــل معـــــك هــــالمشـــــــــــوار
 من الدنيــــا غيـــرك ما بـــــــــدي
 صــــدّقني مـــارح احتـــــــــــــــــــار
 إنت حبيبـــي رفيقــــي
 وسنــــــدي حوّلتلّـــي ليـلــــــي لــنــهــــــــــــــــار
 ووقت العتمــــة ووقت الشـــــــــدة
 بتخــــلـيـنـــــــي (كــــــون منـــــــــار)2
 لما بهاك الليـــــــلة طليــــــــــــــت
 مـــا عـــاد في وجود لكلمـــة يا ريت</lyrics>
<author>منار المصري, منار المصري</author>
<hymn_number>9257</hymn_number>
</song>