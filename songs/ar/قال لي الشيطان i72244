<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-(
 قال لي الشيـطَان خطـايـاك خـلـت يسـوع ينـسـاك)2
 (لكنـي بنفـسـي سمعتـه بيـقـول لـي أنـا ويــاك
 )2
 القرار-
 صليبـي دا كـان بـدالـك
 وقـبـري دا كـان مكـانـك
 أنا بدمي فديتك وبموتي قد أحييتك( تعال تعال تعال تعال إلـي الآن)2
 2-(
 قـال لـي يسـوع تـعـال بـلاش تـنـظـر للحـالـة)2
 (دا أنـا فـي لحـظـة أغيـرك ما عنـدي حـاجـة محـالة)2
 3-(
 أنـا بخـطَـاياي أجي لـك وتـوبـة قـلبـي أدي لـك)2
 (دا إنـت اللـي حبيـتـنـي ميـن يغفـر ذنـبـي غيـرك
 )2
 4-(
 يـا يـسـوع الحـبـيـب فـادي وأغـلى نصـيـب)2
 (ادي لـك كـل حـيـاتـي عنـد قـدميـك سكـيـب
 )2</lyrics>
<title>قال لي الشيطان</title>
<hymn_number>6855</hymn_number>
</song>