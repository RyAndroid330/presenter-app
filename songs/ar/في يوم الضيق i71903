<?xml version="1.0" encoding="UTF-8"?><song><title>في يوم الضيق</title>
<lyrics>[V1]
 (في يوم الضيق أنت الصديق
 لن تتركني لن تنساني)2
 (ربي أنت معي تهمس في مسمعي
 تقول لا تخاف... لا لا تخاف)2
 (قد أيدتك وأعنتك وعضدتك بيميني)2</lyrics>
<author>إياد حداد, إياد حداد</author>
<hymn_number>6532</hymn_number>
</song>