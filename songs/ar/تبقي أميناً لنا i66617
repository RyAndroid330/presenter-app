<?xml version="1.0" encoding="UTF-8"?><song><author>سالى برسوم, سالى برسوم</author>
<hymn_number>138</hymn_number>
<lyrics>[V1]
 1- تبقى أمينًا لنا .. لا تنكر نفسك
 تضمن العهد لنا .. تقيم وعودك
 لن نخدم غيرك .. نحن نحبك .. وننحني لنيرك
 القرار- (أنت خلاصنا .. ليس مثلك
 أخذت ما لنا .. أعطيتنا مالك)2
 2- دفعت ديننا .. أخذتنا لك
 أنقذتنا وإلى .. الرحب أخرجتنا
 نعظم دمك .. أنت فداؤنا .. نحيا لمن أحبنا</lyrics>
<title>تبقي أميناً لنا</title>
</song>