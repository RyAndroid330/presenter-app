<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (طوبى لنا سننشد .. أمام كرسي عرشه
 مجدًا وعزًا نهتف .. معه نبقى للأبد)2
 القرار- سبحوه ورنموا له .. سبحوه يا جميع قديسيه
 واعلنوا جلال ملكه .. (اقترب مجيئه)2
 2- (طوبى لنا سنجلس .. في عشاء حفل عرسه
 خمر حبه نشرب .. معه نبقى للأبد)2
 3- (طوبى لنا سنملك .. معه لمدح مجده
 بزًا نقيًا نلبس .. معه نبقى للأبد)2</lyrics>
<title>طوبى لنا سننشد</title>
<author>سامح وليم, لحن أجنبي</author>
<hymn_number>675</hymn_number>
</song>