<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 (أحلى ما في حياتي إنت .. حبيبي يا يسوع
 يا هنايا وعزي وفرحي .. وشبعي في الجوع)2
 (لو حطوا العالم في كفي .. مش ممكن أبدًا هايكفي)2
 (دا الرب اللي ف قلبي مكانه .. هاقدر أسيب الكل عشانه)2
 خطواتي واختباراتي .. تعلن عن مجدك في حياتي
 وأحلى ما في حياتي إنت .. (حبيبي يا يسوع)2</lyrics>
<title>أحلى ما في حياتي</title>
<author>ناصف صبحي, ناصف صبحي</author>
<hymn_number>115</hymn_number>
</song>