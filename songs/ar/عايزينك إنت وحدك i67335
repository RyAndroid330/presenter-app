<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (عايزينك إنت وحدك .. يا صاحب الوعود
 عايزينك إنت وحدك .. بخيرك لينا تجود)2
 القرار- (وتتمجد في وسطينا .. وتفيض بروحك فينا)2
 (يا يســــــوع .. يا يســــــوع .. يا يســــــوع)2
 2- (عايزينك إنت وحدك .. وحدك يا يسوع
 عايزينك إنت وحدك .. تشبع الجموع)2
 3- (عايزينك إنت وحدك .. وحدك يا جبار
 عايزينك إنت وحدك .. تخطف من النار)2
 4- (عايزينك إنت وحدك .. وحدك يا قدوس
 عايزينك إنت وحدك .. تلمس النفوس)2
 5- (عايزينك إنت وحدك .. ترعش العظام
 عايزينك إنت وحدك .. تملانا سلام)2</lyrics>
<title>عايزينك إنت وحدك</title>
<hymn_number>210</hymn_number>
</song>