<?xml version="1.0" encoding="UTF-8"?><song><title>بنحبك نسجد ليك</title>
<lyrics>[V1]
 القرار- بنحبك نسجد ليك انت فـــادينــــــــا بنحبك نرفــع ليك كـــــــل أغــــانينا
 بنحبــــك أنت لينـــا كـــــــل مــــــا لينـا بنحبك يا اللي ساكن فــــــــــي أوانـيـنـــا
 1- يــا سـاكن جـوه قلـوبناعينينا بتـــتــرجــــــــاك
 مش ممكن قلب هايشبع يــــا يسوع إلا بمــــرآك
 سبب فـــرح قلــوبنا إننـــا جـــنبيــــك
 واللي يسكن في سترك يلقى حمايتـــه فيــك
 2- قلبك مليان بالرحمة والخيـــر للمــؤمنين
 وبتغمرنـــا بــالنعمة وبـــدمــك مستورين
 سبب راحـة قـلوبنا اننــــا في إيــــديــك
 واللي يآمن بصليبك يلقى ضمانه فيـــــك</lyrics>
<author>منال سمير, منال سمير</author>
<hymn_number>7028</hymn_number>
</song>