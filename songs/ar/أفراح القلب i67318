<?xml version="1.0" encoding="UTF-8"?><song><title>أفراح القلب</title>
<lyrics>[V1]
 1- (أفـراح القلـب شوقـت نفـسـي أشـواق الـحـب ذوبـت قـلـبـي)2
 القرار - (حبه بيسبينـي شخصـه يعزينـي) 2 (شــخــصــه يـعـزيــنـي)2
 2- (لـي اشتيـاق أكـون مـع ربـي أسكـن معـاه يـفـرح بـه قلـبـي)2
 3- (لي اشتيـاق أكـون مـع المسيـح أسكـن مـعـاه والقلـب يستيـريـح)2
 4- (لـي اشتيـاق أكـون مـع يسـوع أسكـن معـاه يمسـح لـي الدمـوع)2
 5- (يسوع ربـي وحـده عايـل همـي كـل الظـروف أراه واقـف جانبـي)2</lyrics>
<hymn_number>2091</hymn_number>
</song>