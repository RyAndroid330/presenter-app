<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (بالأحـضـان الأبــويــة قـلبـك بـيـنادي عـلـي)2
 أرجـع وأتمـتـع بـرضـاك عـنـي هـناك في المحـبـوب
 واسمـع لـنـداء الغـفـران بـالإيـمـان جـاي أتــوب
 القرار - (راجـع لـلآب الحـنـان واثـق إن أنـا لـي مـكـان)2
 (بـذنـوبـي أنـا راجـع بـدمـوعـي أنـا راجــع)2 واثــق إن أنـا لـي مـكــان
 2- (جايلـك بخطـايا سنيـنـي عمري اللـي اتقضى في أنينـي)2
 دقـت مـرار البعـد قاسيـت واتمـنـيـت أرجــع لـيـك
 عدت لنفسـي بدمعـي بكيـت عنـد البـيـت صارخ لـيـك</lyrics>
<title>بالأحضان الأبوية</title>
<hymn_number>9328</hymn_number>
</song>