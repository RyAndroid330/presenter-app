<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (وانا عليل في ليل طويل .. وعدك دليل راح يهديني
 والقاك بنور بتشق سور .. حزني اللي كان بيبكيني)2
 وارتوي بغناك وارتمي في حماك .. لما افتكر ضعفي بمرار
 (والقاني فيك نقش ف إيديك .. أشبع أمان في وسط نار)2
 في وسط نار
 2- (وف قلب الخوف غيرك ما اشوف .. أجي ارتمي بحملي عليك
 وانسى البكا لما الشفا .. يبقى سكيب ما بين إيديك)2
 واعيش وياك شبعان بلقاك .. اسمك بيجري في العروق
 (تشفي وترفع تسبي وتجعل .. أنهار مياه بين الشقوق)2
 بين الشقوق</lyrics>
<title>وانا عليل</title>
<hymn_number>637</hymn_number>
<author>هاني أنيس, منال سمير فريد</author>
</song>