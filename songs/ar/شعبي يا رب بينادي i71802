<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (شعبي يا رب بينادي .. تعال بنهضة في بلادي
 تملا الصحرا والوادي .. ونشوفك إنت يا قدوس)2
 القرار- (يا قدوس يا قدوس .. يا قدوس يا إله الكون)2
 2- (بالإيمان أنا شايفك .. أكيد سهران على وعدك
 هاتيجي وتفتقد شعبك .. بلمسة ايدك يا قدوس)2
 3- (هاتيجي ومش هاتتأخر .. وبصلواتنا هانسهر
 وبالخير السما تمطر .. بكلمة منك يا قدوس)2</lyrics>
<title>شعبي يا رب بينادي</title>
<hymn_number>643</hymn_number>
<author>منال سمير, منال سمير</author>
</song>