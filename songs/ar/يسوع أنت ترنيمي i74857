<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>9228</hymn_number>
<lyrics>[V1]
 يسوع أنت ترنيمي وكلمات
 شعري

[V2]
 أنت لحن عمري ونشيد حبي

[V3]
 فلاسمك أغني

[V4]
 بل أنت فرحتي ونبع قوتي

[V5]
 ملكي وإلهي

[V6]
 فاقبل مني ربي ذبيحة حبي

[V7]
 يسوع لحن عمري</lyrics>
<title>يسوع أنت ترنيمي</title>
</song>