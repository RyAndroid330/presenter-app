<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>2423</hymn_number>
<author>هرماس سمير, هرماس سمير</author>
<lyrics>[V1]
 1- (تملي فاكر لمسة إيديه .. وهي حاملاني
 وقلبي شاكر حبه وعينيه .. اللي حارساني)2
 (أنا قلبي فيك بيصدق .. كطفل وحداني)2
 القرار- (مافيش بحور تقدر كفاية .. تفصلني عن حبك
 مافيش جبال عالية في سمايا .. تعلى على حبك)2
 (مافيش تمن غالي .. يمنعني عن حبك)2
 2- (إزاي أنا أنسى صلبك وموتك .. اللي نجاني
 إزاي جلدت وإزاي ذبحت .. وكله علشاني)2
 (أنا قلبي ليك مديون .. فالمسني من تاني)2
 3- (آسرني فيك حبك لي ثابت .. وعمره ما اتغير
 جاذبني ليك إنك قابلني .. مهما بأتعير)2
 (أجري عليك واثق .. وفي حضنك أتغير)2</lyrics>
<title>تملي فاكر</title>
</song>