<?xml version="1.0" encoding="UTF-8"?><song><title>جاي بذبيحة حمد</title>
<lyrics>[V1]
 1- (جاي بذبيحة حمد .. باقدمها بقلبي الفرحان
 جايب لحن في إيدي .. وكلمة باقدمها بإيمان)2
 (جاي وباقدم ليك .. من اللي في إيدك ليك)2
 (يا وطن الإنسان .. يا وطن الإنسان)2
 القرار- (علمني أقدم ليك .. تسبيح يرفعني إليك)2
 وأكون كذبيحة حمد .. أنا بين إيديك
 2- (ياللي إديتني حياتك حب .. أنا باهدي حياتي إليك
 حبك ساكن جوة القلب .. وقلبي ساكن في إيديك)2
 (قلبي يغني أكيد .. طول ما الحب يزيد)2
 (ويزيد الإيمان .. يا وطن الإنسان)2
 3-(اسمك أحلي أسامي الدنيا .. وأحلي أسامي الكون
 مجد لاسم يسوعنا الغالي .. وللجنب المطعون)2
 (شمس الأرض تغيب .. والنور يبقي صليب)2
 (راية الحق تبان .. يا وطن الإنسان)2
 4- (ملك المجد واسمك عالي .. وفي إيديك السلطان
 أمم الأرض وكل شعوبها .. وكل ملوكها كمان)2
 (بكره هتسجد ليك .. تخضع تحت إيديك)2
 (يا صاحب السلطان .. يا وطن الإنسان)2</lyrics>
<author>ماهر فايز, ماهر فايز</author>
<hymn_number>593</hymn_number>
</song>