<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (في وقت ضعفي أراك تشفي من سقطتي وعند
 ضيقي تبقى صديقي وسلوتي)2
 إلـي تدنـو إليـك أرنـو مسلـماً
 القرار- (لست لذاتي وشهواتي بل ها حياتي ملكك يا رب إني
 لك أعني وخذ يدي بيدك)2
 2- (عند رجوعي تمسح دموعي وترثي لي تشبع جوعي
 ربي يسوعي وتهدني)2
 إلـي تدنـو إليـك أرنـو مسلـماً
 3- (ربي أراك أراك دربـي ونسمتي من كل قلبي
 أهديك حبي وبسمتي)2
 إلـي تدنـو إليـك أرنـو مسلـماً</lyrics>
<title>في وقت ضعفي</title>
<hymn_number>6064</hymn_number>
</song>