<?xml version="1.0" encoding="UTF-8"?><song><author>ترجمة/ فيليب وأوليس ويصا, لحن أجنبي</author>
<hymn_number>60</hymn_number>
<title>يسوع ما أعظمك</title>
<lyrics>[V1]
 يســـوع ما أعظمك .. ما أعظمك يســـــوع
 مـــا أعظمـــــك
 أنت ربي من أحـب .. كل قلبي والحيــاة
 أعـطـيـتــــــــــك
 يسوع ما أعظمك</lyrics>
</song>