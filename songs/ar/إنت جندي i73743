<?xml version="1.0" encoding="UTF-8"?><song><author>هاني منير, هاني فخري</author>
<hymn_number>8221</hymn_number>
<lyrics>[V1]
 1-
 أنت
 جندي يسوع البــــار أوعى تكون غرقان في النوم
 صحصح و أعرف أن عـــــدوك
 حربه معاك طول اليـــوم
 القرار- لما تحس انك مهزوم وإنك خايف
 م الشيطان أعرف أنه يسوع موجـــــــود
 بيقويك و عليك
 سهـــــــــــران
 2-
 أوعي
 تقول أنا لسه صــغير بص و شـــــــــوف داود ازاى
 لما جه جليات راح قــاله بقوة
 ربــــــــــى ليك أنا جاى
 3-
 اوعى
 عدو الخير يغريك
 عن اوقات الصلاة
 بحاجــات علشان يسحب كل سلاحــك تبقى وحيد من غير قــــــوات</lyrics>
<title>إنت جندي</title>
</song>