<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-أنا الحقير صرت امير هللويا القرار - هللويا ..هللويا .. هللويا
 2-دا مسك إيدي ورفعني سيدي هللويا
 3- انا الهالك خلاني مالك هللويا
 4-شفاني بجروحه اعطاني روحه هللويا
 5-أعطاني قوة بالروح من جوه هللويا
 6-ساندني بوعده ودعاني لمجده هللويا
 7-قال لا تهتم شارك بالدم هللويا
 8-شايل أحمالي ويقول يا غالي هللويا
 9- وهبني الجنسيه السماويه هللويا
 10-أعد مكاني وجايلي تاني هللويا
 11-دا هو وعدني هيجي ياخدني هللويا
 12-وهعيش وياه وانظر بهاه هللويا</lyrics>
<title>أنا الحقير</title>
<hymn_number>7574</hymn_number>
</song>