<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10740</hymn_number>
<author>أمير تادروس, كيرلس ميلاد وكريم مدحت</author>
<title>أبى الملك</title>
<lyrics>[V1]
 كنت تعلم انى سأضعف ..
 ولكنك أحببتنى

[V2]
 أنزلتك أنا من سماك .. وبصلبك رفعتنى

[V3]
 فمن أنا حتى أكون .. فى نظرك ابن حبيب

[V4]
 تسهر وتنجى وتصون .. لأشعر كم انت قريب

[V5]
 كم ضاقت بى حياتى وصرت لشهواتى أسير

[V6]
 قلت لنفسى الآن أرجع أحيا فى بيتى ولو أجير

[V7]
 ونظرتنى من بعيد .. فأتيتنى مسرعاً

[V8]
 سقطت نادماً .. أمسكتنى رافعاً

[V9]
 وحملتنى بحبك .. وهتفت يا ذا الجلال

[V10]
 عاش من كان ميتاً .. وعاد ابنى الضال

[V11]
 وها الآن حياتى أحيا حراً من جديد

[V12]
 ولم لا فأبى الملك وفى ملكه أنا أدعى أمير</lyrics>
</song>