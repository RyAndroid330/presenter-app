<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>10341</hymn_number>
<author>القس فخري يعقوب, عادل حبيب</author>
<lyrics>[V1]
 1- ياروح الله املك عليا واملاني ياروح الله سد علي فكري ووجداني

[V2]
 ياروح الله الهب قلبي وكياني ياروح الله امسح ايدي ولساني

[V3]
 2- ياروح الله قدس نظري واوقاتي ياروح الله حدد انت علاقاتي

[V4]
 ياروح الله احيي عظامي وصلاتي ياروح الله اظهر ثمرك في حياتي

[V5]
 3- ياروح الله جدد زهني واحلامي ياروح الله قدني في كل ايامي

[V6]
 ياروح الله اعن ضعف ايماني ياروح الله اعلن حقك في كلامي

[V7]
 4- ياروح الله زد حبي للي فداني ياروح الله جهزني لمجيئة التاني

[V8]
 ياروح الله فرحني في كل احزاني ياروح الله مستنيك تيجي باغاني

[V9]
 5- ياروح الله خليني اصبر في ضيقاتي ياروح الله اشهد عنك في حياتي

[V10]
 ياروح الله خليني ثابت في ايماني ياروح الله نور انت كل ايامي

[V11]
 6- ياروح الله قويني بصليب الفادي ياروح الله احميني من عالم فاني

[V12]
 ياروح الله يا ضامن دايماً سلامي يا روح الله تعالي اسكن في دياري</lyrics>
<title>يا روح الله</title>
</song>