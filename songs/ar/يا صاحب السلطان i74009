<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (يا صاحب السلطان أنت عين الحنان
 نزلت من السما .. فداءٍ للإنسان)2
 القرار- هللويا هللويا .. يسوع حبك عجيب)2
 (أظهرت حبًا خالدًا .. دليله الصليب)2
 2- (ففي الصليب حياةٌ .. وفي الحبيب رجاءٌ
 وفي المقام خلودٌ .. لنا فيه هناءٌ)2
 3- (تركت حضن الآب .. وجزت في الصعاب
 في أرضنا التراب .. لتحمل العقاب)2
 4- (وعشت كالإنسان .. أخذت صورة عبدٍ
 وقد تركت المجد .. لترفعنا للمجد)2</lyrics>
<title>يا صاحب السلطان</title>
<author>نبيل أرتيل, نبيل أرتيل</author>
<hymn_number>8463</hymn_number>
</song>