<?xml version="1.0" encoding="UTF-8"?><song><author>ماهر فايز, ماهر فايز</author>
<hymn_number>1584</hymn_number>
<lyrics>[V1]
 1- (عايشيـن لـك بالحـب ولـيـك كـل حياتنـا دي مـلـك إيـديـك)2
 (إن عشنـا ليـك وإن متنـا ليـك)2 (منـك وليـك عايشيـن لـك إنـت)2
 2- (عايشيـن لـك عايشيـن لرضـاك وحيـاتـنـا يحـيـيـهـا نــداك)2
 (ترفـع إيدينـا بقلـوب أميـنـة)2 (ونقول فادينـا عايشيـن لـك إنـت)2
 3- (عايشـيـن لـك غـربـة أيــام هـتـعـدي ولــو فـيـهـا آلام)2
 (إنـت الصديـق وإنـت الطريـق)2 (لو فيها ضيـق عايشيـن لـك إنـت)2
 4- (عايشيـن لـك عايشيـن للـقـاك ماشيـيـن لــك ماشيـيـن ويـاك)2
 (ماسـك إيدنـا وإنـت السفينـة)2 (وإنت المدينـة رايحييـن لـك إنـت)2</lyrics>
<title>عايشين لك بالحب</title>
</song>