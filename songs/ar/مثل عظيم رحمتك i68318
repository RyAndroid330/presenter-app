<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- مثل عظيم رحمـتك يا خالقي إرحمـني ومـثل فرط رأفـتـك امـح الـخطـا عـنـي
 القرار- إرحمـني إرحمـني امـح الـخطـا عـنـي مـثل عظيـم رحمـتك يـا خالقي ارحمني
 2- اغـسل كثـيـراً سـيدي نفـسي مـن الـذنـب وهـكذا خـذ بـيـدي مـطـهــراً قـلـبـي
 إني بـاثمـي عـارف مـعـتـرف جـهـراً وهـو أمـامي واقـف أنـظـره الـدهــر
 3- أخطأت يـا ربي إلـيك بـالـقـول والـفـعـل والـشـر مـا بيـن يديـك صـنـعـت فاصفـح لـي
 قـلـبـاً نـقـياً طـاهـراً أخـلقـه بي مـولاي وروح عـدل ظـاهـراً جـدده فـي حـشـاي</lyrics>
<title>مثل عظيم رحمتك</title>
<hymn_number>309</hymn_number>
<author>ناصيف اليازجي</author>
</song>