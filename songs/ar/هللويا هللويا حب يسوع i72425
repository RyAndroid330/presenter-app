<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 القرار- (هللويا هللويا حب يسوع خلاني فرحان هللويا هللويا صوته الحلو ملاني أمـان)2
 1- (ماشي ومهما طريقي يطول قلبي أهـه سـامــع صـــوت بـيـقــول
 &quot; أنـا دايمـاً ويـاك علـى طـول رنـم إنـت تـمـلـي وقــول &quot; )2
 2- (فرحة تسعنـا بكـل حنـان قلـب يـسـوع بـقـى لـيـنـا مـكـان
 قـالـوا الأرض عـذاب وهــوان قـلـنـا فـي بيـت الآب عـنـوان)2
 3- (تـايـه كـنـت فـي عالـم تـاه فـتـش عـنـي رجـعـت مـعــاه
 جـايـب لـي الفـرحـة مـعـاه دفـــع ثـمـن الـفـرح دمــاه)2
 4- (أنـا بـالـنـعـمـة وبالإيـمـان بلقـي ف معنـى جـهـادي ضـمـان
 لازم أقولـهـا واقولـهـا كـمـان طـول ما انا عايـش فـيـه فرحـان)2</lyrics>
<title>هللويا هللويا حب يسوع</title>
<author>ماهر فايز, ماهر فايز</author>
<hymn_number>701</hymn_number>
</song>