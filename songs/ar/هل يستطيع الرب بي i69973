<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (هل يستطيع الرب بي .. أن يـصنـع العجائـب
 وإن طـلبت تكريسي .. هل يستجيب الطلب)2
 القرار- نعـم نعـم نعـم يقول ربنا .. تـقـدسـوا لـلـعــمــل
 غـداً سأعـمـل بـكـم في وسطكم .. في وسطكم عجائبي
 2- (هل يستطـيـع الرب أن .. يـقـدس ذا الـجـسـد
 مـع ضعفـه وإثمـه .. بـه يـحـل لـلـمــدى)2
 3- (هل يستطيـع الرب أن .. يشـغـل مـواهـبي
 مـقـدسًا عـواطـفـي .. لـمجـد من أحـبـني)2
 4- (هل يستطيـع الرب أن .. يـبـارك في خدمـتـي
 مـكرسًـا لـمـجـده .. كـلي لـه بجمـلـتـي)2</lyrics>
<title>هل يستطيع الرب بي</title>
<hymn_number>465</hymn_number>
</song>