<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (يـا إلـهـي أنـت تعـلـم ضعـف نفـسـي كـم يكـون إنـما فـي الضـعـف أنـت تحيـى روحـي بـل تصـون)2 القرار- (أدنـو مـنـك يـا مـلاذي وسـط هـمـي والشـجـون أنسـى معـك يا نجـاتـي كـل دمـع فـي العـيـون)2 2- (سيـدي علـمـنـي كيـف أسكـب الـنـفـس لـديـك واثــقــاً أن الأمـــور دائـمـاً بـيـن يـديــك)2 3- (شـكـلـن فـي إنــائـي لـيـس حـسـبـمـا أريــد بـل بـروحـك المـعـزي كـيـفـمـا أنـت تـريـد)2</lyrics>
<title>يا إلهي أنت تعلم</title>
<author>جوزيف نصرالله, جوزيف نصرالله</author>
