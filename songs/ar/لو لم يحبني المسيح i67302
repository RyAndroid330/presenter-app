<?xml version="1.0" encoding="UTF-8"?><song><author>إبراهيم سركيس, هاغوب جمبازيان</author>
<hymn_number>2077</hymn_number>
<title>لو لم يحبني المسيح</title>
<lyrics>[V1]
 1- لَوْ لَمْ يُحِبَّنِي الْمَسِيحْ
 مَا كَانَ أَشْقَانِي
 طَهَّرَنِي ذَاكَ الذَّبِيحْ
 وَالْعَفْوَ أَعْطَانِي

[V2]
 2- لَوْ لَمْ يُحِبَّنِي الْغَفُورْ
 كُنْتُ مَعَ الأَشْرَارْ
 أَبْقَى إِلَى دَهْرِ الدُّهُورْ
 مُعَذَّبًا بِالنَّارْ

[V3]
 3- لَوْ لَمْ يُحِبَّنِي الْقَدِيرْ
 وَيَغْفِرِ الذَّنْبَ
 مَا كَانَ إِمْكَانٌ بِأَنْ
 أُسَاكِنَ الرَّبَّ

[V4]
 4- لَوْ لَمْ يُحِبَّنِي الَّذِي
 كُلِّلَ بِالأَشْوَاكْ
 كُنْتُ إِذًا مُقَيَّدًا
 فِي وَهْدَةِ الْهَلاكْ

[V5]
 5- فَالشُّكْرُ مِنِّي وَاجِبٌ
 مَا دُمْتُ فِي الْحَيَاهْ
 لِمَنْ فَدَى نَفْسِي وَمَنْ
 قَدْ جَادَ بِالنَّجَاهْ</lyrics>
</song>