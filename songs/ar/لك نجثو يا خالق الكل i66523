<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 لك نجثو يا خالق الكل
 نرفع التسبيح لك أيا قدير
 (نبــــارك اسمــــك)2 .. أنت هو القـدوس
 عــــالٍ ومهــــوب .. مــلكٌ ورب الأربـــاب
 (نبــــاركك)2 .. نبــــارك اسمــــك</lyrics>
<title>لك نجثو يا خالق الكل</title>
<author>ماجد جرجس, لحن أجنبي</author>
<hymn_number>1303</hymn_number>
