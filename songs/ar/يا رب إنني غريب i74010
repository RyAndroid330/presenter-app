<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8465</hymn_number>
<author>ناصف صبحي, صليب إلياس</author>
<lyrics>[V1]
 1- يَا رَبُّ إِنَّنِي غَرِيبٌ
 فِي طَرِيقِي لِلدِّيَارْ
 فَمَتَى تَأْتِي حَبِيبِي؟
 (طَالَ وَقْتُ الاِنْتِظَارْ)2

[C1]
   القرار: آمِينْ تَعَالَ يَا حَبِيبِي
   آمِينْ تَعَالَ يَا يَسُوعْ
   (كَوَعْدِكَ آمِينْ تَعَالَ
   يَا أَيُّهَا الرَّبُّ يَسُوعْ)2

[V2]
 2- سَتَأْتِي رَبِّي عَنْ قَرِيبٍ
 لاِخْتِطَافِ شَعْبِكَ
 قَلْبُهُمْ تَاقَ إِلَيْكَ
 (وَالْعُيُونُ نَحْوَكَ)2</lyrics>
<title>يا رب إنني غريب</title>
</song>