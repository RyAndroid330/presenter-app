<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7121</hymn_number>
<lyrics>[V1]
 (يارب إسمع صلاتي .. إقبل واستجيب
 تعالى وزور حياتي .. واملاها لهيب)2
 (أنا طلبي إني أشوف المجد .. أملي إني أشوفك
 وحتى إن آخر باب إتسد .. هالمس هدب ثوبك)2
 إنت شافي نفسي .. إنت شافي جسدي
 إنـت طـبـيـبـــــــي
 (إنـت إلـه عظــيم .. إنـت إلهــــــي
 معاك مافيش مستحيل .. تحييني من مماتي)2
 (إنـت إلهـــــــي)3 .. إنـت يســــوع الفــــادي
 (إنت واهب الحياة .. إنت لي طوق نجاة)2
 (وفــي إيـدك ظـروفــــي)2
 (إنت بتدي سلام .. إنت فيك الأمان)2
 (إنـت مـاحــــي خـوفـــــي)2
 (أنا بس محتاج لصوتك .. أنا هدفي رضاك وخوفك)2
 (أنا طلبي إني أشوف المجد .. أملي إني أشوفك
 وحتى إن آخر باب إتسد .. هالمس هدب ثوبك)2</lyrics>
<title>إنت شافي نفسي</title>
</song>