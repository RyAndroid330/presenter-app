<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 قرار- أنا فرحان يسوع حررني
 عشان كده انا غونا يسوع حررني
 1-شيطان ربطني يسوع فكاني
 عشان كده انا غونا يسوع فكاني
 2-لما كنت ميت يسوع قومني
 عشان كده انا غونا يسوع قومني
 3-لما كنت عيان يسوع شفاني عشان
 كده انا غونا يسوع شفاني</lyrics>
<title>أنا فرحان</title>
<hymn_number>10659</hymn_number>
</song>