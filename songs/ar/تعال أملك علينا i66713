<?xml version="1.0" encoding="UTF-8"?><song><author>رامى مكرم, رامى مكرم</author>
<hymn_number>14</hymn_number>
<lyrics>[V1]
 (تعال أملك علينا .. روحـــك يعمــــل فـــينا
 نتغير عن أشكالنا .. يكمل عملك وسطينا)2
 (تعال واسكن في بيوتنا .. يتغير معنى حيـــــاتنا
 نتحــــــــرر من كل قيــــودنا .. يظهر نورك وسطينا)2</lyrics>
<title>تعال أملك علينا</title>
</song>