<?xml version="1.0" encoding="UTF-8"?><song><title>أمانينا معاك تتحقق</title>
<lyrics>[V1]
 1- (أمانينا معاك تتحقق .. أتعابـنا بنصرة تغيب
 ماشيين وياك بنصدق .. في وعدك العجيب)2
 (أفراحنا اليوم راح تشهد .. بإيمانا في شخص البار
 والروح جـوانا يأكد .. غالبـين أوجاع ومرار)2
 (وحياتنا ماليها سلامك .. سلطانك ويا كلامك
 وأنين في القلب بيهرب .. ومكانه بييجي حنانك)2
 ومكانه بييجي حنانك
 2- (وبروحك فينا ننادي .. بوعودك لينا يا فادي
 لقلوب بجروح مأسورة .. وعمر عايش باكي)2
 (دا في حضنك كل الراحة .. حضنك مليان بأمان
 وإن جت سهام جراحة .. يفضل قلبنا فرحان)2
 (وهـتفضل لينا فادينا .. وملكنا وأحلى ما لينا
 نوهب لك عمرنا كله .. ونفرح قلبك بينا)2
 ونفرح قلبك بينا</lyrics>
<author>هاني أنيس, قس أمجد سعد</author>
<hymn_number>376</hymn_number>
</song>