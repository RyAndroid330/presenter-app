<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 القرار-
 جعان قلبي ليــك يــا فادى جعانـة نفسي للمسة قوية ولعشــرة
 بيـــــــك حقيقية وأعبـــــــدك بـــالـــــروح جعـــان
 أبصـر قوتـــــــــك وأتــلامس بمحبتـــــــــــك
 وامتـــــلى
 مـــن هيبتـــــك حمـــــــل الله المــذبــــوح 1-
 خذنى لعمق جديـد ويـــاك
 قيس واعبر عبرني
 معاك ده
 القـلب دايب للقـــــــــاك ما أنت كنــــزي ونصيبـي يوم
 وراء يوم أنـا باستناك
 باستني حضورك ورضاك تحكى
 كخلي وأحكى معـاك ولا اطـــــلب إلا حــــبيبـي 2-
 أحضـــرت قــارورة طيبي جــــــــلست دون رقــــيب</lyrics>
<title>جعان قلبي</title>
<hymn_number>7770</hymn_number>
</song>