<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (أحبك معنى كل وجود .. واحبك والكلام محدود)2
 وحبك عدى كل سدود .. (حبيبي يا يسوع البار)2
 2- (أحبك تنتهي الآلامات .. واحبك تبتدي النغمات)2
 وحبك حب للنهايات .. (حبيبي يا يسوع البار)2
 3- (أحبك رب للإنسان .. واحبك راحة للحيران)2
 وحبك راية للإيمان .. (حبيبي يا يسوع البار)2
 4- (أحبك فوق صليب العار .. واحبك بين لهيب النار)2
 وحبك حب للأسرار .. (حبيبي يا يسوع البار)2
 5- (أحبك القساوة تدوب .. واحبك ترفع المغلوب)2
 وحبك خلي قلبي يتوب .. (حبيبي يا يسوع البار)2
 6- (أحبك إنت أوفى صديق .. واحبك حتى لو في الضيق)2
 وحبك ليَّ أعظم شيء .. (حبيبي يا يسوع البار)</lyrics>
<title>أحبك معنى كل وجود</title>
<author>ماهر فايز, ماهر فايز</author>
<hymn_number>720</hymn_number>
</song>