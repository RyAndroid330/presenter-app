<?xml version="1.0" encoding="UTF-8"?><song><author>أشرف فهمي, أشرف فهمي</author>
<hymn_number>6528</hymn_number>
<lyrics>[V1]
 1- (تأمر الرياح تطيعك عمرها ما تقدر تخالفك)2
 (م البدايه دى صنع إيدك تنتهر بكلمه منك)2
 القرار- (ما أنت مالي الكون بروحك
 مافي شئ متداري عنك)2
 كل أمر الكون في إيدك
 (وأنت ليك الملك وحدك)2
 2-(تأمر الأمواج بتهدي لما تسمع صوت نداك)2
 (ويرجع القارب ويهدي ويبقى في دايرة حماك)2
 3-(تأمر الموت ينتهي والحياه ترجع تعود)2
 (وعمر تاني يبتدي ليا ما بين كفيك وعود)2</lyrics>
<title>تأمر الرياح</title>
</song>