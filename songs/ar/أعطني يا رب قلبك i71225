<?xml version="1.0" encoding="UTF-8"?><song><author>رولا شلالا, شارل شلالا</author>
<hymn_number>5858</hymn_number>
<lyrics>[V1]
 أعطني يا رب قلبك هبني
 أن أختار حبك

[V2]
 يا قلب يسوع إلهي أرغب أن أتبعك

[V3]
 قلبك يا رب راحتي هو غناي هو عذوبتي

[V4]
 أجذبني إليك إلهي وحدك أنت ساعدني

[V5]
 وجهك يا رب موطني قلبك يا رب مسكني

[V6]
 هلم و وحدني بك وأجعلني أحيا لأجلك</lyrics>
<title>أعطني يا رب قلبك</title>
</song>