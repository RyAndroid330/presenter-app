<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>777</hymn_number>
<lyrics>[V1]
 1- (طال إنتظاري إليه .. والقلب إشتاق عليه)2
 (هيريح بالي .. ويزيل أحزاني)2
 القرار- (أنا رايح وطني)4
 ويسوع الغالي .. هيجينا تاني
 ويسوع الغالي .. هاشوفه تاني
 2- (يا هنايا يا فرحتي بيه .. لما أشوفه والاقيه)2
 (ياخذني تاني .. إلى الأمجاد)2
 3- (هتمتع وافرح بيه .. ينشغل فكري بيه)2
 (حبه سباني .. نبعه رواني)2
 4- (بجواره يجلسني .. على صدره يتكئني)2
 (وأنا يا إخواني .. يسوع هناني)2</lyrics>
<title>طال انتظاري إليه</title>
</song>