<?xml version="1.0" encoding="UTF-8"?><song><title>أبوابك مفتوحة لي</title>
<lyrics>[V1]
 1- إزاي يـا رب حـنــانـك بـيـسـاع كـل البـشـريـة وأي حـد بـيـجـيـلـك تـرفـعـه من الـعـبـوديـة)2 القرار- (أبـوابـك مفتـوحـة لـي مـهـما كـان فـي خـطـية بالحـب تسـتـر عيـوبـي وعلى صخرة تثبت رجـلـي)2 2- (وضعـت في قلبـي ترنيـمة ترفـع المجـد لشـخـصـك حـتـى في بـريـة اليـمـة هأعيش عمري اطلـب مجـدك)2 3- (كـل التـعـابـى تعـالـوا يـســوع دعـاكـم إلـيـه الكـل يلـقـي أحـمـالـه بالإيـمـان عنـد رجـليـه)2</lyrics>
<hymn_number>6105</hymn_number>
</song>