<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 القرار - (بِيحبِّنِي مِش لأنِّي انا حَبِّيتُه)

[V2]
 (هوَّ الِّلي بَدَا بالحبّ قَبل ما جِيتُه)

[V3]
 1- (ولأنِّي خاطي وعبد رفضته وعاديتُه

[V4]
 وللجحيم انا ماشي وعمري ما ناديتُه)
 حَوَّطني بالحبّ وأشرق في قلبي النور

[V5]
 خبط على بابي فتحت له وِملاني سرور

[V6]
 هوَّ الِّلي بَدَا بالحبّ قَبل ما جِيتُه

[V7]
 2- (يا بَهجِتي بالِّلي دعاني وانا لبِّيتُه

[V8]
 وقال لي: إنت ابني الغالي إللي حميتُه)

[V9]
 في الأرض هدايَه وف السما أنا عندي ميراث

[V10]
 وكل ما لِيَّ صار مِلكك ما انت ابني خلاص

[V11]
 هوَّ الِّلي بَدَا بالحبّ قَبل ما جِيتُه</lyrics>
<title>هو اللي ابتدأ</title>
<author>القمص زكريا بطرس, بهجت عدلي</author>
<hymn_number>10395</hymn_number>
</song>