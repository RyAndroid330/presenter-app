<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (أنا اللي ضليت في الوادي سنين وضاعت في عنادي)2
 يسوع سمعني وانا بنادي
 القرار- (حن علي حن على)2 حن علي وريحني حن علي وفرحني
 2- (هو حبيبي ومانساني وعينيه وأنا تايه شايفاني)2
 يسوع بنفسه اللي لقاني
 3- (حس بكسري وبظروفي شافي الجرح لمس خوفي)2
 هاحكي واصقف بكفوفي
 4- (كنت بعيد قرب مني شافني وحيد قام طمني)2
 عمري ما حاجة هاتإلمني</lyrics>
<title>أنا اللي ضليت في الوادي</title>
<hymn_number>706</hymn_number>
<author>ماهر فايز, ماهر فايز</author>
</song>