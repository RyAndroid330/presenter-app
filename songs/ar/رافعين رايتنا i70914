<?xml version="1.0" encoding="UTF-8"?><song><author>هرماس سمير, هرماس سمير</author>
<hymn_number>550</hymn_number>
<lyrics>[V1]
 القرار- (رافعيـن راياتـنا وبأغانيـنا ماشييـن بقـوة روحـك فيـنا
 كـل فرحـنا وانتـصـارتـنا بيكلـلـهـا دم فاديـنـا)2
 1- (اسمـك رايتـنا والهتـافـات تعـلـن عـنـك انتصـارات
 دا بـدمـك نقـهـر قـوات دي قوتنـا في اسـم يسـوع)2
 2- (ماشييـن في غـربة منتصريـن بيـك أفراحـنا مـش خايفيـن
 دا احـنا بـدمـك محمـيـن دي قوتنـا في اسـم يسـوع)2
 3- (رافعيـن ايـديـنا لـفـاديـنا نعلـن سـلـطـانـه فيـنـا
 هـو راعـيـنـا وشافـيـنـا دي قوتنـا في اسـم يسـوع)2</lyrics>
<title>رافعين رايتنا</title>
</song>