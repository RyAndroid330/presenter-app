<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 ابـدأ فـي مصر النهضة واطلـق الشـرار
 2-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 أقـــم الــحــراس
 علـي كـل الأســوار 3-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 اعــط روح صـلاة صـلاة بــاقـتـدار 4-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 تـمــم لـيـنـا وعــدك اسـكـب روح الـنـار
 5-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 جــمـل بـالـ
 م
 ـواهــب جــمــل بـالــثـمــار 6-
 يـا الـلـه ابـانـا فـي اســم يسوع البار
 مــصـر للـمـســيــح صـلــوا يــا أبــرار</lyrics>
<title>يا الله أبانا</title>
