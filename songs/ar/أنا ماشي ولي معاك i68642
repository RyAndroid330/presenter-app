<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>339</hymn_number>
<author>هرماس سمير, هرماس سمير</author>
<lyrics>[V1]
 1- (أنـا مـاشـي ولـي معـاك بهجـة وعشـرة وفـرح سمـاك
 كـل دقيـقـة أنا باستـنـاك بـتـوجهنـي لفعـل رضـاك)2
 القرار- (فـرحـان أنا بإلهـي البـار رافـع راسـي بـإسـتـمـرار
 وفى قلبـي ليـه افتـخـار وبدمـه صـرت أنا جـبـار)2
 2- (أنا ماشـي معـاك مسـرور مهما قابـلـت تعـب وشـرور
 بيـك أنا غالـب بيك منصـور طول مابدمـه أنا مسـتـور)2
 3- (أنـا ماشـي وعينـي عليـك قـلبـي يا ربـي بيهتـف ليـك
 شبعـان أنا من خيـر إيديـك يـا أبـويا واعـز صـديـق)2
 4- (حمد وشكر في قلبـي ليـك كـل كيـانـي مأسـور بيـك
 كـل حياتـي ليك باهديـك وحدك ربـي يا أغلـى مليـك)2</lyrics>
<title>أنا ماشي ولي معاك</title>
</song>