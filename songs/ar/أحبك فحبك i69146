<?xml version="1.0" encoding="UTF-8"?><song><author>هرماس سمير و د/ رمسيس زكي, هرماس سمير و د/رمسيس زكي</author>
<hymn_number>386</hymn_number>
<lyrics>[V1]
 1- (أحبك فحبك .. يعجز فيه الكلام
 أحبك فصلبك .. شفاني بالتمام
 أحبك فقربك .. سباني في هيام)2
 القرار- (أحبك يا سيدي .. لا أخرج حرًا
 ونارك في داخلي .. تسبيني لك عبدًا)2
 2- (أحبك لشخصك .. يا سيدي القدير
 أحبك ونيرك .. هين لي يسير
 أحبك وشكرك .. في صدري أسير)2
 3- (أحبك فأنت لي .. شهيق ذي الحياة
 أحـبك فحبك .. قلبي قد إشتهـاه
 أحبك فدمك ل.. إثمي قد محاه)2</lyrics>
<title>أحبك فحبك</title>
</song>