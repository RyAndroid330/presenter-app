<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.    
     احـفـظ بـلادنـا يـارب وامـلاهـا من خــيـرك جـايـيـن بـكـل الـقـلب مـالـنـاش رجــاء غـيـرك مــجـدك يـعـود لـيهـا يـشــفـي أراضــيـهــا ومــذبــحــك فـيـهــا يـحـفــظ بـــلادنــا يــارب 1- احفظها م الحاجة وم الفقر ومـن جفاف ينابيع الـنهر
 احفـظـهـا م الإرهاب والـشـر احــفــظ بــلادنــا يــارب 2- احـفظ بـيـوتك في بـلادنـا وامـلـك عـليها يا سـيـدنـا واحــفــظ بـنـاتـنـا وأولادنــــا احـفــظ بــلادنــا يــارب 3- نـطـلـب حـماية لأبـوابهـا عـفـة وطـهـارة لـشـبابهـا دم الـحـمــل عــلي أعـتـابـهـا يـحـفـظ بــلادنــا يــارب</lyrics>
<title>احفظ بلادنا يا رب</title>
<hymn_number>9094</hymn_number>
</song>