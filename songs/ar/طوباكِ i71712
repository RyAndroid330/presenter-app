<?xml version="1.0" encoding="UTF-8"?><song><author>سهيل مدانات, سلام عميش</author>
<hymn_number>6326</hymn_number>
<lyrics>[V1]
 طوباك يا مسكين فها لك السماء
 طوباك يا حزين يحلو لك العزاء
 القرار- طوباك..طوباك فها لك السماء
 طوباك يحلو لك العزاء
 للودعاء طوبى فالأرض يورثون
 والرحماء إذ هم كذال يرحمون
 لأنقياء القلب فالله يبصرون
 لصانعي السلام أبناءه يدعون
 طوباك يا مسكين فها لك السماء
 طوباك يا حزين يحلو لك العزاء</lyrics>
<title>طوباكِ</title>
</song>