<?xml version="1.0" encoding="UTF-8"?><song><title>مين يقدر</title>
<lyrics>[V1]
 (مين
 يقدر يتكم عنك إلا لو اختبرك

[V2]
 مين يقدر يسمع صوتك إلا لو عرفك)2
 قرار- (مين
 يقدر يهزمنا مين واحنا فى دمك محميين)2 (ووعودك فى قلوبنا امين وايمانا بصلبك)2 (مين
 يقدر يسكن فى سماك إلا لو قبلك

[V3]
 مين يقدر يتعزى معاك إلا لو حبك)2
 قرار- (مين
 يقدر يهزمنا مين واحنا فى دمك محميين)2 (ووعودك فى قلوبنا امين وايمانا بصلبك)2 (مين
 يقدر يشبع من جودك إلا لو انتظرك

[V4]
 مين يقدر يمتلى من روحك إلا لو عهدك)2</lyrics>
<hymn_number>8174</hymn_number>
</song>