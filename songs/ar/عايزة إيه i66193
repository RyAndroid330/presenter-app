<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (عايزة إيه .. ليه جاية تاني .. في وشيليهبتضحكي
 كنت نسيتك .. ليه جاية تاني .. تاني ناحيتي)2
 (نسيتك أنا مسكت إيد .. اللي إتصلب مكاني
 نسيتك أنا ورجعت تاني .. لإيد اللي فداني)2
 تفتكري يعني .. بعدما دوقت .. حلاوة العشرة معاه
 هارجع لك تاني .. وأشرب مر .. كنت بدأت أنساه
 2- (يعني صليبي .. رافعه دايمًا .. على طول ماشي بيه
 هو الأمان .. وعرفته يوم .. لما لجأت ليه)2
 3- (يا خطية إنسي .. خلاص كفاية .. مالكيش مكان جوايا
 مسكت إيده .. أنا مش هاسيبه .. خلاص عايش معايا)2</lyrics>
<title>عايزة إيه</title>
<author>مينا إسحق, راجي - مفيد</author>
<hymn_number>11197</hymn_number>
</song>