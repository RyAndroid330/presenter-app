<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7182</hymn_number>
<author>جود الحارس, جود الحارس</author>
<lyrics>[V1]
 نسبح نمجد نعظم الهنا
 نسبح نغلب ونسحق عدونا
 نرقص نصفق ونرفع اسم الرب
 بدم الخروف نرفع رايات الانتصار
 نعلن ان الرب المقام
 سحق الشيطان</lyrics>
<title>نسبح نمجد</title>
</song>