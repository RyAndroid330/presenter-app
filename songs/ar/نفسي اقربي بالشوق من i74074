<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>8523</hymn_number>
<author>فواز عميش, فواز عميش</author>
<lyrics>[V1]
 1- (نفسي أقربي بالشوق من كرسي رحمته)2
 (حيث يسوع للدعا يصغي بنعمته)2

[V2]
 2- (يا من وعدت المتعب بالراحة العظمى)2
 (أقترب مطالبًا بوعدك الاسمى)2

[V3]
 3- (من حمل آثامي ومن ضغوط أعدائي)2
 (ربي أرحني إذ أنا آتي بأرزائي)2

[V4]
 4- (يا رب كن ترسًا لي وملجأً حصين)2
 (فحجتي للمشتكي فداؤك الثمين)2

[V5]
 5- (يدهشني الحب الذي بدا على الصليب)2
 (به غدوت باسمك أدعو فتستجيب)2</lyrics>
<title>نفسي اقربي بالشوق من</title>
</song>