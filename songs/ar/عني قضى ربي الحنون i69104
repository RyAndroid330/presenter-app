<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>382</hymn_number>
<author>ملحم ذهبية, لحن أجنبي</author>
<lyrics>[V1]
 1- عنـي قضـى ربـي الحنـون .. وذاق غـصــات الـمـنـون
 محـررًا أسـري السـجـون .. رب الـورى فــادي الأنــام
 القرار- جئـت شفـاءً مـت فـداءً .. فـيا لحـبــك العـجـيــب
 ليس سـواك فـفـي دمـاك .. نـجـوت مـن مـوت رهيـب
 فكيف أنسى شافـي جروحي .. ماحي آثامي فكيف أنسى
 لولاك أنـت حبـي وعونـي .. ربي أنت في الحشا فلن أنساك
 2- كيف قضـى يا للـعـجـب .. فـوق صلـيـب من خـشـب
 بالصلـب قد محـى الغضـب .. وسـيـط صـلــح وســلام
 3- سـالـت يـنابـيـع دمــــاه .. حـبًـا حـنـــانًـا للـخـطــــاة
 مـا مـن رجـاء بـســــواه .. يـولـي الخـلاص بالـتـمـــام</lyrics>
<title>عني قضى ربي الحنون</title>
</song>