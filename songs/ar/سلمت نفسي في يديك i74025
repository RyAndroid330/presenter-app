<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-سلمت
 نفسي في يديك ياسيدي يسوع
 قدني فتكلاني عليك كي أخدم الجموع
 كن حارسي من الضلال ومرشدي في كل حال
 والقلب قدس والفعال</lyrics>
<title>سلمت نفسي في يديك</title>
<author>نجيب إبراهيم, نجيب إبراهيم</author>
<hymn_number>8479</hymn_number>
</song>