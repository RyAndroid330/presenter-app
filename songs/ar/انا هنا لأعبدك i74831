<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 أنا هنا لأعبدك أحيا فقط لأكرمك لتجد مكان راحة لك
 من كل قلبي بحبك
 من كل فكري بحبك
 بل قدرتي بحبك بحبك
 بحبك بحبك بحبك يا الله
 آبا أنا بحبك يا يسوع أنا بحبك
 روح الله أنا بحبك
 بحبك بحبك بحبك يا الله</lyrics>
<title>انا هنا لأعبدك</title>
<hymn_number>9204</hymn_number>
</song>