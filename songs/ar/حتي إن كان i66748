<?xml version="1.0" encoding="UTF-8"?><song><author>ماهر فايز, ماهر فايز</author>
<hymn_number>1539</hymn_number>
<lyrics>[V1]
 1- [(حتي إن كان فيـه ألـف هامـان)2 بيجـهـزوا ليـنـا فـي صـلـبـان]2
 (إنت السايد وحدك مملكة الإنسـان وإنت الأعلي وسيد كل زمـان ومكـان)2
 وإنت الساكن في السما ضاحك ع الطغيان وتبدل تواريـخ وشرائـع لأجـل مهـان
 2- [(حتـي إن كـان قيافـا وحنـان)2 متحالفـيـن ويـــا الشـيـطـان]2
 (ضدك علشان يحموا الكرسي وعهد زمان ويسودوا الشعب الأعمي وهما العميـان)2
 بكره يشوفوا اللي طعنوه هـو الديـان والحجـر المرفـوض هـو رأس البنيـان
 3- [( حتي إن كـان العـدو سهـران)2 بـيـن الحـنـطـة يـحـط زوان]2
 (ويغربل علشان يفنـي فينـا الإيمـانْ ويجول يـزأر عـاوز يبتلـع التعبـان)2
 نفخة فمك تفني عدوك لو كطوفـان إسمك دايماً يا يسوع يرعب في الشيطـان</lyrics>
<title>حتي إن كان</title>
</song>