<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (سنين طويلة مضت .. والرب معتني بي
 وكل يوم محمول .. ع الأذرع الأبدية)2
 (ويسوع بيده ماسكني .. في مراعي الحب قايدني)2
 2- (ملك الملوك يا يسوع .. يا سيد الأسياد
 نفوسنا في انتظار .. تاخذنا للأمجاد)2
 (واتملى فيك بعينيَّ .. يا يسوع يا غالي عليَّ)2
 3- (يسوع سباني بحبه .. والقلب بقي فرحان
 وعد ييجينا من مجده .. وتنتهي الأحزان)2
 (تبقى السما كلها ليَّ .. وأعظم ما فيها فاديَّ)2</lyrics>
<title>سنين طويلة مضت</title>
<hymn_number>8551</hymn_number>
<author>تراث, تراث</author>
</song>