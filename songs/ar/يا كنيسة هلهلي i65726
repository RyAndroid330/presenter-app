<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 يا كـــــنــيــســة
 هـلهلي أتـحـــلـي و إتـزيـنـي
 بـجـيــة يـسـوع الغـالي الـكــنـيــســـة تـنـمـلي يا
 كـنـيـســــة أفــرحـي بأسـم يـسـوع أهـتـفـي
 إمبارحة جان مصلوب و اليوم عـريس مدلـلي يا شـعب
 أملوا الـمقاعـد إنـشـدوا و عـلوا النـشيد
 بترنيمة و صوت واحد أولادك صرنا مو عبيد</lyrics>
<title>يا كنيسة هلهلي</title>
<hymn_number>10706</hymn_number>
<author>سارة تفوح, ريتا وليم</author>
</song>