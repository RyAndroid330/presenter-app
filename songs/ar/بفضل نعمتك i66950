<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>1731</hymn_number>
<author>هرماس سمير, هرماس سمير</author>
<lyrics>[V1]
 1- بفضل نعمتك .. وعمق رحمتك
 آتي لمحبتك .. وارتمي عليك
 اروِ ظمأ قلبي .. وشوقي وحبي
 فراحتي يا ربي .. وحاجتي إليك
 القرار- تحمدك الشفاه .. وتنحني الجباه
 لشخصك يا الله .. فأنت خالقها
 تسبح القلوب .. أمامك تذوب
 فاسمك مهوب .. وأنت سيدها
 2- إلهي ما أبهاك .. ما أعظم غناك
 فعيشي في رضاك .. شوقي ولذتي
 لذا أنتظرك .. وعيني نحوك
 وتحت ظلك .. تطيب جلستي
 3- إلهي صخرتي .. حصني قوتي
 وكل بهجتي .. بقربك يسوع
 يا فرحتي بك .. فزت بحبك
 وقرب قلبك .. أحبك يسوع</lyrics>
<title>بفضل نعمتك</title>
</song>