<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (ياللي عرفت الرب يسوع .. واتمتعت بنور إنجيله)2
 (عالم كله أنين ودموع .. ليه حنيت لظلامه وليله)2
 2- (ليه دورت على الخرنوب .. والخير كله في بيت الآب)2
 (فكر دا انت ابنه المحبوب .. وارجع للبيت والأحباب)2
 3- (حبك ضحى بنفسه عشانك .. ذاق الموت بصليب العار)2
 (حضن الرب دا هو مكانك .. سيبك من مشي الأشرار)2
 4- (وبأعمالك كنت بتحزن .. روح الله الساكن فيك)2
 (دايمًا تنسى إنك مؤمن .. رغم دا كله عينه عليك)2
 5- (عسل العالم عمره ما ينفع .. إيه يحصل لو دست عليه)2
 (بس كلام الرب بيشبع عود .. لإلهك واشبع بيه)2
 6- (فرح العالم مش هيدوم .. باطل كله وقبض الريح)2
 (لكن بكره هييجي اليوم .. وهنتهنى مع المسيح)2</lyrics>
<title>ياللي عرفت الرب يسوع</title>
<author>فايز بشرى, فايز بشرى</author>
<hymn_number>831</hymn_number>
</song>