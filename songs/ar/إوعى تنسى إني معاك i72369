<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (إوعى تنسى إني معاك .. طول اليوم عيني بترعاك)2
 (نقشتك يا ابني على كفي .. علشان كده يا ابني ماتخافشي)2
 القرار- ماتخافشي ماتخافشي .. (في وعودي ليك أنا مارجعشي)2
 2- (وعدتك يا ابني أحميك .. وف خوفك سلامي ليك)2
 (وف ضعفك نعمتي تكفيك .. وف مرضك أنا اللي شافيك)2
 3- (أنا ساندك وسط الأزمات .. أنا رافعك فوق الضيقات)2
 (واعوض عن اللي فات .. دا أنا إله المستحيلات)2
 4- (أنا حافظك طول السنين .. إوعى تنسى أنا وعدي أمين)2
 (هانجيك من قلب النار .. هاعديك كل الأسوار)2
 5- (وقت خوفك أنا وياك .. وف ظروفك مش هانساك)2
 (في عالم مليان أشرار .. إلهك ده إله جبار)2
 6- (أنا جاي لك على السحاب .. إستناني مع الأحباب)2
 (هانسيك أرض الأتعاب .. تلقى الراحة ف بيت الأب)2</lyrics>
<title>إوعى تنسى إني معاك</title>
<author>أمجد سعد وماهر فايز, قس أمجد سعد</author>
<hymn_number>696</hymn_number>
</song>