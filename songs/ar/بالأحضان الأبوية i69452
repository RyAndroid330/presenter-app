<?xml version="1.0" encoding="UTF-8"?><song><title>بالأحضان الأبوية</title>
<lyrics>[V1]
 1- (بالأحضـــان الأبــويــة .. قلبـك بينـــادي علـيَّ)2
 أرجع واتمتـع برضـاك .. عني هناك في المحبـوب
 واسمـع لـنـداء الغـفـران .. بـالإيـمـان جـاي أتــوب
 القرار- (راجع للآب الحنـــان .. واثق إن أنا لي مكـان)2
 (بـذنوبـــي أنا راجـــــع .. بـدمـوعــــي أنـا راجـــــع)2
 واثــــق إن أنـا لـــيَّ مـكـــــــان
 2- (جاي لك بخطايا سنيني .. عمري اللي انقضى في أنيني)2
 دقت مــرار البعــد قاســــيـت .. واتمـــنـيـت أرجــــــع لـيـك
 عدت لنفسـي بدمعـي بكيـت .. عنـد البـيـت صارخ لـيـك</lyrics>
<hymn_number>415</hymn_number>
</song>