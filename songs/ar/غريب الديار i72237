<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (يهيم فؤادي ليوم الرحيل كفى يا غريب غياباً طويل)2
 (كفاني فحبي لذاك الوطن يشوق نفسي لقرب الزمن) 2
 القرار- (فما لي قرار)2 هنا في وجودي
 (غريب الديار)3
 2-(ولا ترهبن عناء المسير يغطيك ظل جناح القدير)2
 (وأيضاً متى جاء يوم السفر فهيا لنلبس ثوب الظفر)2
 3-(حياتي هنا تعتريها الهموم ففيها هناء وفيها غيوم)2
 (ولكن هناك صفاء السرور سلام خلود بذاك الودود)2
 4- (وحين تفوز بحظ الدخول إلى دار مجد يفوق العقول)2
 (بإكليل مجد أمام الألوف تنال وتحظى بالرب الرؤوف)2</lyrics>
<title>غريب الديار</title>
<hymn_number>6849</hymn_number>
</song>