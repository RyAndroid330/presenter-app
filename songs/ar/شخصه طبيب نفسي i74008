<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (شَخْصُهُ طَبِيبُ نَفْسِي
 صَوْتُهُ أَيْضًا عِلاجْ)
 (وَبِهِ يَطِيبُ قَلْبِي
 وَيَفِيضُ بِابْتِهَاجْ)

[V2]
 2- (كُلَّمَا أَصْبُو إِلَيْهِ
 لَذَّ لِي فِيهِ الْوِفَاقْ)
 (كُلَّمَا أَدْنُو لَدَيْهِ
 زَادَنِي لَهُ اشْتِيَاقْ)

[V3]
 3- (مَتَى تَسْمَعُ آذَانِي
 صَوْتَ هُتَافِ الْحَبِيبْ)
 (وَأَرَاهُ بِالْعِيَانِ
 فِي جَمَالِهِ الْعَجِيبْ)

[V4]
 4- (عِنْدَ ذَا يَنْتَهِي حُزْنِي
 وَكُلُّ هَمٍّ يَغِيبْ)
 (وَكَذَا يَفْرَحُ قَلْبِي
 وَالأحِبَّا بِالْحَبِيبْ)</lyrics>
<title>شخصه طبيب نفسي</title>
<hymn_number>8461</hymn_number>
<author>تراث, نجيب لبيب</author>
</song>