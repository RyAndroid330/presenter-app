<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>575</hymn_number>
<author>ناجي فؤاد, ناجي فؤاد</author>
<lyrics>[V1]
 سلمت قلبي .. خصصت حبي
 قدمت ذاتي .. لك يا ربي
 أنا لك .. كلي بجملتي
 وأنت لي .. هنا في غربتي
 تقودني .. تمشي برفقتي
 بـروحـــك .. تهدي لي خطواتي
 سأهتف مجدًا لك .. على مدى السنين
 سألهج بشخصك .. فأنت لي المعين
 وأخضع لصوتك .. دومًا في كل حين
 نعم أمين أمين
 سلمت قلبي .. خصصت حبي
 قدمت ذاتي .. لك يا ربي
 لك يا ربـــي</lyrics>
<title>سلمت قلبي</title>
</song>