<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (وقت شكوكي ألاقيك بتجيني .. أصرخ ليك وانت تنجيني
 ألقى مشاعر دافية في حضنك .. ما انت الحصن اللي بيحميني)2
 القرار- (ياللي بتسمع لي أنا بانده لك .. يا حمايتي باصرخ محتاج لك)2
 (تبقى معايا والقى حماية .. وتحفظ قلبي اللي بيشتاق لك)2
 2- (دايمًا شهواتي بتخدعني .. ماتسبنيش يا أبويا إرفعني
 وقت الضعف ألاقي إيديك .. من قلب الطين بتطلعني)2
 3- (كل جيوش إبليس حواليَّ .. لكن ربي ماسك بايديَّ
 أنا مش خايف لكن شايف .. ربي حبيبي فتح لي عينيَّ)2
 4- (عارف إني عايش في عنادي .. وفي عينيك زودت فسادي
 لكن جاي لك طالب وجهك .. بعد ما ضاقت بيَّ يا فادي)2</lyrics>
<title>وقت شكوكي</title>
<author>نشأت واصف, نشأت واصف</author>
<hymn_number>1444</hymn_number>
</song>