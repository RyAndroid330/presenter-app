<?xml version="1.0" encoding="UTF-8"?><song><title>لو كان غيرك سيدي</title>
<lyrics>[V1]
 1- ( لو كان غيرك
 سيدي لو غيرك امتلك الكيان
 من اين كنت سأعرف تلك المحبة
 والحنان)2
 ال
 قرار- يسوع لمن سواك أذهب ومن
 سواك ينفع
 والنفس ليست تهدأ (ما لم
 اليك ترجع)2
 2- ( لو كان غيرك سيدى لو
 كان بى يتحكم
 من أين كنت سأرحم فأنت
 وحدك ترحم)2
 3- ( لو كان غيرك سيدى لو
 كنت منه أقوم
 من أين كنت سأرفع وبذا
 المقام أكرم)2
 4- لو كان غيرك سيدى وأنا
 اهيم مشردا</lyrics>
<hymn_number>10442</hymn_number>
</song>