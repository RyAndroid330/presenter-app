<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (حبيتنا وفديتنا .. واديتنا حياة أبدية
 وفي موتنا إنت أحيتنا .. ووهبتنا أغلى عطية)2
 (شخصك مش حد تاني .. جيت من السما عشاني
 حبك ملا كل كياني .. وغفرت لي كل خطية)2
 2- (حبيتنا وشريتنا .. بدمك على الصليب
 وسترت علينا غطتنا .. حبك دا حب عجيب)2
 (سددت كل الدين .. وبقيت لي صديق ومعين
 صادق وراعى أمين .. أكثر من نفسى قريب)2
 3- (حبيتنا وحميتنا .. من شر وهم وضيق
 وضمنت لنا سلامتنا .. ويانا طول الطريق)2
 (ووعدت أنا هابقى معاكم .. طول الأيام هارعاكم
 وروحي القدوس يملاكم .. دايمًا يبقى الرفيق)2</lyrics>
<title>حبيتنا وفديتنا</title>
<author>هاني نبيل, هاني نبيل</author>
<hymn_number>1327</hymn_number>
</song>