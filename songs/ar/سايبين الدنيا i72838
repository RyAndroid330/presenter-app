<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>7398</hymn_number>
<author>ماهر فايز, ماهر فايز</author>
<lyrics>[V1]
 1- (سايبين الدنيا وأتعابها .. سايبينها بمالها وبترابها)2
 (لا إحنا منها ولا صحابها .. هايجينا اليوم ونسيبها)2
 القرار- (يا وطنا يا غالي علينا .. ده الصبر إشتاق في عينينا)2
 (إمتى يا يسوع هاتجينا .. يا سمانا يا أحلى مدينة)2
 2- (سايبين الدنيا وأعيادها .. لا تفرح قلب ولا بإيدها)2
 (نفرح ويا اللي فدانا .. والحزن هناك ينسانا)2
 3- (المركب أهيه معديانا .. الموجة إن عليت شايلانا)2
 (والفرحة دي مش سايعانا .. ده عريسنا بيستنانا)2
 4- (في السما هانرنم فرحانين .. وعلى القيثارات كلنا عازفين)2
 (وعلى العرش في وسطينا .. رب الأرباب وفادينا)2</lyrics>
<title>سايبين الدنيا</title>
</song>