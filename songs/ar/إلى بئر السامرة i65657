<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- إلى بئر السامرة جئت وحـدي لأمــلأ أجــراري مـيــاه وعنـدها التـقـيـت ربـي ففاض فـي قلبـي مـاء الحيـاة القرار- فض في قلبـي واملأ حياتـي إذ فـراغ العـالـم رهـيـب أنت المن نـازل من السـماء إملان واشبعن قلـبي السكيـب 2- كنت أسعى في الحياة لأمـور لا تشبـعـن جوعـي الشديـد لـكـنـنـي وجــدت أن لا مثيـل لـربـي المـجـيـد 3- يا صديقي هل ترى قد جذبـت من الخـطـاة ولا مـنــاص تعـالـى لـيـسـوع فـهـو يبـغـي أن يمنحـك الخـلاص</lyrics>
<title>إلى بئر السامرة</title>
<hymn_number>10644</hymn_number>
</song>