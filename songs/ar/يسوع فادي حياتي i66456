<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 يسوع فادي حياتي
 يسوع يامن فيك نجاتي
 تجذبني من عمق الخطايا
 ترفعني عاليًا فأغني
 أحبـــــك أحتـــــاجك
 وإن ضاق بي الزمان سأغني
 فادي أوفى صديق
 سأعبدك ربي طول الطريق</lyrics>
<title>يسوع فادي حياتي</title>
<author>ترجمة/ ماجد عادل</author>
<hymn_number>123</hymn_number>
</song>