<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 القرار-
 يـا الـله أبـانـا في إسـم يسوع البار ابـدأ فـي مصر النهضة واطـلـق الشـرار
 1-يـا الـلـه أبانا في إسـم يسوع البار أقـم الــحــراس عـلي كـل الأســوار 2-يـا الـله أبانا فـي إسـم يسوع البار أعــــط روح صــلاة صـــلاة بـاقـتــدار
 3-يـا الـله أبانا فـي إســم يسوع البار لاتـدعـوه يـسـكـت صـلوا لـيل ونهار 4-يـا الـله أبانا فـي إســم يسوع البار تـمـم لينا وعدك واسـكب روح الـنـار 5-يـا الـله أبانا فـي إســم يسوع البار جـمل بـالـمواهـب جــمـل بالـثـمــار 6-يـا الـله أبانا فـي إســم يسوع البار ألـسـنـة مـنـقـسـمـة كـأنـهـا من نار
 7-يـا الـله أبانا فـي إســم يسوع البار
 مـصـر للمـسـيــح صــلـــوا يــا أبــرار</lyrics>
<title>يا الله أبانا</title>
<hymn_number>7565</hymn_number>
</song>