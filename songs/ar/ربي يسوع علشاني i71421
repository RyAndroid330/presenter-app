<?xml version="1.0" encoding="UTF-8"?><song><title>ربي يسوع علشاني</title>
<lyrics>[V1]
 1-(ربي يسوع علشاني .. سبت مجدك جيت لمكاني
 واتولدت في مذود بسيط .. أشكرك لأنك جيت)2
 (ميلادك يا يسوع .. ميلادك يا يسوع
 ميلادك يا يسوع .. كان علشاني)2
 2-(ربي يسوع علشاني .. اتصلبت وخدت مكاني
 شلت عني كل العقاب .. وللسما فتحت لي الباب)2
 (صليبك يا يسوع .. صليبك يا يسوع
 صليبك يا يسوع .. كان علشانـي)2
 3-(ربي يسوع علشاني .. قريب هاتيجي تاني
 وتاخدني على السحاب .. وأكون معاك للأبد)2
 (هاتيجي يا يسوع .. هاتيجي يا يسوع
 هاتيجي يا يسوع .. تانـي علشانـي)2

[V2]
 (ميلادك يا يسوع .. حياتك يا يسوع .. صليبك يا يسوع
 كانوا علشاني .. كانوا علشاني .. كانوا علشاني)2</lyrics>
<author>منال سمير, منال سمير</author>
<hymn_number>603</hymn_number>
</song>