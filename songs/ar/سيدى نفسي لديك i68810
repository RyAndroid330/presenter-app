<?xml version="1.0" encoding="UTF-8"?><song><title>سيدى نفسي لديك</title>
<lyrics>[V1]
 1- سَيِّدِي نَفْسِى لَدَيْكْ
 عِنْدَ مَوْطِئْ قَدَمَيْكْ
 وَحَيَاتِي فِي يَدَيْكْ
 فَهْيَ مِنْكَ وَإِلَيْكْ

[C1]
   القرار- سَيِّدِي مَاذَا تُرِيدْ
   اِهْدِنِي حَيْثُ تُرِيدْ
   إِنَّنِي لَسْتُ أُرِيدْ
   غَيْرَ فِعْلِ مَا تُرِيدْ

[V2]
 2- رَبِّى هَبْنِى أَنْ أَرَاكْ
 كَيْ أَسِيرَ فِى خُطَاكْ
 أَنْتَ رَبِّى لا سِوَاكْ
 بُغْيَتِى نَيْلُ رِضَاكْ

[V3]
 3- بالتقى وبالخشوع
 باتضاعٍ وخضوع
 وبقلب لا يروع
 أعبد الرب يسوع</lyrics>
<hymn_number>3554</hymn_number>
<author>نجيب إبراهيم, نجيب إبراهيم</author>
</song>