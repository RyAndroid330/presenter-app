<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 القرار- يـا أبـو المـجـد الـنـورانـي بيــن تـسـبـيـح الأبــــرار
 آبـا الـمـجـد الـسـمــاوي آبـــا يـــا أبـــو الأنـــوار
 1- (ياللـي بـكـلـمـة منـك هـل فـي قـلـوبـنـا وأشـرق وأطــل
 مـجـد بـيـنـور لـلـكــل في وجـه الـرب يـسـوع الـبـار)2
 2- (فـي إحتفـالات السمـاء ع الأرض بـنـعـيـد بـذبـائـح الحـمــد
 وفي وسطينـا رب المجـد يقودنـا وروحــه يـفـيــض أنـهــار)2
 3- (نعمـة وصـارت ليـنـا بـحـب حمـلـت ليـنـا دمـاء الـصـلـب
 غسلـتـنـا وغـيـرت القـلـب وتـرفـعـنـا لآخـر الـمـشـوار)2</lyrics>
<title>يا ابو الانوار</title>
<hymn_number>1547</hymn_number>
<author>ماهر فايز, ماهر فايز</author>
</song>