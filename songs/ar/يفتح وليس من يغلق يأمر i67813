<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (يفتح وليس من يغلق يأمر فيهرب أعداءه وتقفز الجبال من أمامه) 2
 (كالصوان جعل جباهنا أصلب من كل أعدائنا
 أنجحنا فمن يعوقنا من مجد إلى مجد دوماً يقودنا) 2
 2- (قد فتح السماء لنا بالبركات أمر بعزنا نسأل أمطاره فيجيبنا) 2
 (يقول يرى مجدي من أمن بي وأجعل عليه من هيبتى
 أغير الأوقات والأزمنه وأفتح فمن يردني) 2</lyrics>
<title>يفتح وليس من يغلق يأمر</title>
<author>خدمة أنهار الحياة, خدمة أنهار الحياة</author>
<hymn_number>2605</hymn_number>
</song>