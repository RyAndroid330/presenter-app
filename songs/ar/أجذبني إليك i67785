<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>257</hymn_number>
<author>ترجمة/ فيليب ويصا, لحن أجنبي</author>
<lyrics>[V1]
 اجذبني إليك .. نحو قدسك
 تكلاني عليك .. أن أسمع صوتك
 أنت شوق القلب .. ليس غيرك
 أشعر بقربك .. وبدفء حضنك
 مد لي يدك .. أجري نحوك
 (أنت ربي .. فيك كل كفايتي
 سؤل قلبي .. أن أبقى قربك)2</lyrics>
<title>أجذبني إليك</title>
</song>