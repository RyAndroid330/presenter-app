<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (وياك بتزول هموم .. بمراحم كل يوم
 وقلوب تنهض وتقوم .. بتمجد من فدى)2
 القرار- (وهانرفع ليك أيادينا .. برايات مكتوبة بدمك
 ووعودك ساكنة فينا .. تشهد يا رب عنك)2
 2- (أوجاع بتروح بعيد .. تترك مكانها نشيد
 بالفرح وبالتمجيد .. لملكنا اللي شفى)2
 3- (أفراحك بين صعوبات .. وسلامك وسط آهات
 وبتوهب حريات .. نهزم بيك العدى)2
 4- (حبك في العمر أمان .. وعدك في الضيق سلطان
 نهـتف بإله حـنان .. على طول المدى)2</lyrics>
<title>وياك بتزول هموم</title>
<author>هاني أنيس, جوزيف نصرالله</author>
<hymn_number>594</hymn_number>
</song>