<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (القـلـب المحـتـاج لـحـنـان يلـقـي مـيـن زيـك يـا يـسـوع
 والـنـفـس العطـشـانـة أمـان تلـقـي فيـن غـيـرك يـنـبـوع)2
 القرار - (إنـت راعينـا يسـوع الـفـادي كـل قلوبـنـا إلـيـك بـتـنـادي)2
 شكـراً شكـراً ليـك يا يـسـوع مـجـداً مـجـداً ليـك يا يـسـوع
 2- الـعـالـم مـلـيـان أوجــاع مـش عـارف ميـن يشكـي لمـيـن
 والخاطـي العايـش فـي صــراع ميـن غيـرك يا إلـهـي مـعـيـن)2
 3- (عنـد صليبـك شـفـت جـراح واتـحـمـلــت عـشـانــا آلام
 يـوم مـا قابلتـك قلـبـي ارتـاح أول مــرة أشـعــر بـســلام)2</lyrics>
<title>القلب المحتاج</title>
<hymn_number>1589</hymn_number>
<author>ماهر فايز, ماهر فايز</author>
</song>