<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 (مئات ألوف ربوات قدامك .. رافعين اسمك يا يسوع
 وملايكة كتير كتير قدامك بالتهليل بيغنوا
 أغنية الخروف المذبوح)2
 (قدوسٌ قدوسٌ .. قدوسٌ الرب
 قدوسٌ قدوسٌ قدوسٌ .. مجدك ملء كل الأرض)

[V2]
 (كرامة ومجد ليك .. كرامة ومجد ليك
 كرامة ومجد ليك .. يا يسوع)2
 (ألوف ألوف أمامك .. ربوات ربوات تخدمك)2
 (كرامة ومجد ليك .. كرامة ومجد ليك
 كرامة ومجد ليك .. يا يسوع)2
 (مستحق يا يسوع .. كل المجد والسلطان
 في السماء .. وعلى أرضنا)2
 (ليس مثلك .. ليس مثلك
 ليس مثلك .. يا ربنا)2
 (كرامة ومجد ليك .. كرامة ومجد ليك
 كرامة ومجد ليك .. يا يسوع)2</lyrics>
<title>قدوس + كرامة ومجد ليك</title>
<author>الفريق, الفريق</author>
