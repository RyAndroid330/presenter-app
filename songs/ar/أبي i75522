<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 أبي يحبني يهتم بي يغفر لي

[V2]
 يترأف علي أبي

[V3]
 يهبني الحياة يعلم أموري

[V4]
 من الشر يحفظني أبي

[V5]
 يقبلني يشبعني يطلبني

[V6]
 يستمع إلي

[V7]
 يشفيني يعوضني يتحنن علي

[V8]
 أبي</lyrics>
<title>أبي</title>
<hymn_number>9836</hymn_number>
<author>راندو هارفي</author>
</song>