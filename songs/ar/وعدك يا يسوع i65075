<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 (وعدك يا يسوع لن تتركنا ترسل روحك يملا قلوبنا)2

[V2]
 (يُصرخ ويقول يا أبا الآب ينادي ويقول يا أبا الآب)2

[V3]
 يا بابا يا آبا الآب

[V4]
 (يا روح الله ده مكان سكناك احنا الهيكل ارتاح فينا)2

[V5]
 (اصرخ وقُـــل يا أبا الآب نادِ وقول يا أبا الآب )2

[V6]
 يا بابا يا آبا الآب

[V7]
 (فَجَّر ينبوعك في داخلنا اخرج أنهارك من بطوننا)2

[V8]
 (اصرخ وقُـــل يا أبا الآب ونادِ وقول يا أبا الآب)2

[V9]
 يا بابا يا آبا الآب</lyrics>
<title>وعدك يا يسوع</title>
<hymn_number>10116</hymn_number>
<author>الفريق</author>
</song>