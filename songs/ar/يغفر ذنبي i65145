<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (يغفر ذنبي يسوع ربي)2
 (يغسلني ويطهر بدماه قلبي)2
 (يشفي أمراضي يسوع الفادي)2
 (يفديني من الحفرة يهدي حياتي)2
 القرار- (فيا نفسي لا تنسي رحمته)2
 قويت عليك محبته
 2- (كلل رأسي برحمته)2
 (تابعًا إياي خيرًا برأفته)2
 3- (يشبع عمري بكل الخير)2
 (فيجدد شبابي قوة النسر)2</lyrics>
<title>يغفر ذنبي</title>
<hymn_number>1017</hymn_number>
<author>منال سمير, منال سمير فريد</author>
</song>