<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 يا خاطي إنــت مــــثــل
 الــحـجــر إنت
 ياخاطي ومـا يـــــطـلـع بــــيــــك ورد وتـكَـظي حـيـاتــك ويــة الـبـشـر إنــت يا خاطي ومـا مــــاخـــذ غـيـر الـــدرد روح
 لــــيـــســوع روح لــــيـــســـوع
 يزيح
 هـمــك و يـمـسـحـلـــك الـدمــوع
 روح لــــيـــســوع روح لــــيـــســـوع يـخـفــف عـنـك قــلــبــه مـثـل يـنـبـوع يا خاطي ومـا يــــطـلـع بــــيــــك ورد يا خاطي
 إنـــــت مثـل الـشمع إنـــــــت
 يا خاطي دومــك تـــظــــــــل تـــــذوب بـس مـن يـسكـن الــمـسـيـــح قـــلـــبــك يا خاطي يصير نورك يضّوي دروب يا خاطي
 إنــــت مـثـــل الـثــلـج إنــــت
 يا خاطي حــــــيــــاتــك فـتور وبـرود كون حار بأيـمانـك وأكــرز بالأنجـيل يا خاطي لا يـهـمك جـــــــاه ولا نـفوذ</lyrics>
<title>يا خاطي</title>
<hymn_number>10711</hymn_number>
<author>ريتا وليم, ريتا وليم</author>
</song>