<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- ما دمـت ربـي فـي الطريـق
 لـن أضـيــق لـن أخــور
 عـالـمـاً مـا فـي الطريـق
 ضـامـنـاً عـنـدي السـرور القرار-
 في
 الطريق أنت لي أنت سيدي الوفي
 وجهك يسيـر بي منك عزيمتـي
 حتى حيـن أضعف يدك تردني
 في الطريق أنت لي أنت إلهي العلي 2- وتـعـمـل دوماً لخـيـري
 بـل لــراحــة
 الـفــؤاد
 واثــق فـيـك يـسـوع
 طائـعـاً
 ولا عـنــــاد
 3-
 وسنـدي
 تبـقـى حبيـبـي
 غـربـتـي فـيـها الأمــان
 يــدك تـجـتــاز بــي
 فـي مـضـايـق الـزمــان</lyrics>
<title>مادمت ربي</title>
<hymn_number>7997</hymn_number>
<author>هاني منيبر حبيب, سامح روبيل</author>
</song>