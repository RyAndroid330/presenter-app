<?xml version="1.0" encoding="UTF-8"?><song><title>جايين لك بنصلي</title>
<lyrics>[V1]
 القرار- (جايين لك بنصلي .. يا يسوع الغالي)2
 (علشان يبقى إسمك .. في بلادنا عالي)2
 1- (بارك كل مدينة .. وكل شارع فيها
 يا يسوع قوينا .. نشهد عنك فيها)2
 (ونتكلم للنفوس .. عن صليبك يا قدوس)2
 2- (بنقدم أشواقنا .. تبقى بيوتنا ليك
 واخواتنا واصحابنا .. عينيهم تبقى عليك)2
 (وبتسبيحنا نرفع ليك .. أحلى ذبيحة يا مليك)2</lyrics>
<author>نعيم عاطف, إيمان الدويري</author>
<hymn_number>665</hymn_number>
</song>