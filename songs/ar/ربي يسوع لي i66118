<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>11122</hymn_number>
<author>فيليب عياد, وسلى عياد</author>
<lyrics>[V1]
 1- ربي يسوع لي .. لن يؤذني ظلام
 ساشدو بابتسام .. أعيش في سلام
 القرار- (فوعده وثيق .. معي كل الطريق)2
 في وسعٍ أو ضيق .. هو نعم الرفيق
 2- وعد يسوع لي .. معك رغم الظروف
 وقلبي العطوف .. يحميك بالألوف
 3- قول يسوع لي .. يشبع جوعتي
 ويشفي لوعتي .. ويهدي خطوتي
 4- حب يسوع لي .. محا خطيتي
 على مكانتي .. سر كرامتي
 5- صوت يسوع لي .. يهمس داخلي
 يسلي غربتي .. فيحيي أملي</lyrics>
<title>ربي يسوع لي</title>
</song>