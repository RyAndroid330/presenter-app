<author>ريتا وليم, ريتا وليم</author>
<title>يا ظالمني</title>
<lyrics>[V1]
 يا
 ظالمني يا محطم حـياتي يالـماحي إسـمي من سفـر الحـياة
 يا آسـرني يا مضّـيع رجاتي مو بس آني لـكـن آلآف ومـئات لـكن عـنـدي يــسوع يـسحـق راسـك يـوّطي راسـك يــسـوع هللويا يسوع يسوع هللويا يـسحـق راسك يسـوع يا شـيطان
 خليتـني كاذب خليتـني زاني لكن يسوع غيرني وخلاني
 ثاني
 خليتني كافر خليتني فاني لكن يسوع أنتشلني ولحضنة
 وداني هو هو يــســـوع يــسـحـق راسـك يـوّطي راســك
 يــســوع يا مالـك العـالم يا مـظـــلـل العالم ياللي للسلام
 ماخليت معــالم
 ما أدري شتريد روح عني بعيد بدم يسوع صرت آني ســالم

[V2]
 بــــــــدم يــــــــســـــــــــــوع عــــــــــل الــــصــــلـيــــ ب
 تـــحـــررت مـنــك يا شـيطان تـخـلـصـت مــنــك يا
 شـيطان</lyrics>
</song>