<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-(من غيرك في ذي الحياة يا رب يبقى
 او يدوم)2
 من غيرك يعطي العزاء ايضا شفاء للهموم
 (من غيرك يا منقذي ربي رجائي سيدي)2
 تبقى وانت لي الصديق امسي ويومي وغدي
 2-(من غيرك يا خالقي يسمع صراخي ويجيب)2
 يا عارفاً كل الانين من غيرك يبقى قريب
 3-(من غيرك ربي يسوع يشفي جروحي يا طبيب)2
 يا فاحصا عمق الضلوع مسيحي يا احلى حبيب</lyrics>
<title>من غيرك</title>
<hymn_number>10181</hymn_number>
</song>