<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1- (ويـاك بـتـزول هـمــوم بـمراحـم كـل يـوم وقلـوب تنـهـض وتـقـوم بـتمـجـد مـن فـدى)2
 القرار- (وهانـرفـع ليـك أياديـنا برايـات مكتـوبـة بـدمـك
 ووعـودك ساكـنـة فيـنا تـشـهـد يا رب عـنـك)2
 2- (أوجـاع بـتـروح بـعـيـد تـترك مكانها نـشـيد بـالفـرح وبـالتـمـجيـد لمـلكـنا اللي شفى)2
 3- (أفراحك بيـن صعـوبـات وسـلامك وسـط آهـات وبـتوهـب حريـات نـهـزم بـيـك العـدى)2
 4- (حبك في العمر أمان وعـدك في الضيق سلطان نهـتف بإله حـنان على طول المدى)2</lyrics>
<title>وياك بتزول هموم</title>
<author>هاني أنيس, قس أمجد سعد</author>
<hymn_number>4384</hymn_number>
</song>