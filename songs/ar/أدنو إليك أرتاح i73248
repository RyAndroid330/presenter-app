<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 1-
 أدنو إليك أرتاح تلقاني بالأفراح يفيض دمع
 العين حبًّا وليس جراح القرار- حبيبي
 سباني بحبه سباني شفاني ورواني
 بغمره رواني جذبني حبه
 إليه آتي وعيني عليك جلست بين
 يديه ووقتي نساني 2- شوقي يارب
 إليك إليك وليس سواك أكون ملكًا
 ليك فمبتغاي رضاك</lyrics>
<title>أدنو إليك أرتاح</title>
<hymn_number>7776</hymn_number>
</song>