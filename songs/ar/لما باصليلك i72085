<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 (لما بصليلك ربي وأنا واثق فيك
 بتيجي تعزيني ياربي حبك عجيب)2
 (مهما تواجهني آلام في حياتي وضيقات)2
 واثق فيك يا إلهي يسوع إنك حنان
 (لما بركعلك ربي وأنا مشتاق ليك
 بتيجي تلمسني ياربي حبك عجيب)2
 (مهما كنت ضعيف وعنك تهت بعيد )2
 واثق فيك يا إلهي يسوع هتقويني
 (لما بجيلك ربي وانا حزين
 بتيجي تفرحني ياربي حبك عجيب)2
 (مهما إن كنت مهموم في حياتي مظلوم)2
 واثق فيك يا إلهي يسوع هتنجيني</lyrics>
<title>لما باصليلك</title>
<hymn_number>6703</hymn_number>
<author>إبتسام, إبتسام</author>
</song>