<?xml version="1.0" encoding="UTF-8"?><song><author>صفاء صبحى, هاني نبيل</author>
<hymn_number>10403</hymn_number>
<title>صالح ياربي</title>
<lyrics>[V1]
 1- صالح ياربي ولو بتسمح

[V2]
 بالصعوبات والأحزان

[V3]
 ده انت بتعصب بعد ماتجرح

[V4]
 تسحق وايديك تشفيان

[V5]
 القرار - صالح ياربي كل الصلاح

[V6]
 وللابد لينا رحمتك

[V7]
 مع اشراقة كل صباح

[V8]
 بأشوف أمانتك ونعمتك

[V9]
 2- صالح ياربي ده رغم جراحي

[V10]
 بتلذذني ب عشرة معاك

[V11]
 وادوق شوية من أفراحي

[V12]
 اللي ها تكمل فوق في سماك

[V13]
 3- صالح ياربي ولو مافهمشي

[V14]
 اللي بيحصل من حواليا

[V15]
 تقول ما تشغلش بالك وامشي

[V16]
 ثبت عينك بس علي</lyrics>
</song>