<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>21</hymn_number>
<author>Молдабеков Мұса</author>
<key>Am</key>
<lyrics>[V1]
.Am      G     Am
 Әрдайым қуаныңдар,
.Dm     G      C/Am
 Тағы да қуаныңдар.
.   Dm        G       C/Am
 // Еш нәрсені уайымдамай
.F      G        Am
 Тәңірді мадақтаңдар. //

[C1]
.     F         G      C/Am
   // Қуаныңдар, қуаныңдар!
.  Dm      G     C/Am
   Тағы да қуаныңдар!
.  F         G      C/Am
   Қуаныңдар, қуаныңдар!
.  F       G     Am
   Иемізге қуаныңдар. //

[V2]
 Өздеріңе сонда Құдай
 Тыныштық сыйлайды.
 // Ақыл менен ойларыңды
 Иса Мәсіхте сақтайды. //</lyrics>
<title>Әрдайым қуаныңдар МЖЖ21 Қак45 ҮРәж20</title>
</song>