<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>63</hymn_number>
<author>Эддие Эспиноса</author>
<lyrics>[V1]
.     C        F        G       C Am
 // Жүрегімді өзгерт, о Құдай Ием,
.       F G          C
 Саған ұқсайын, о, Тәңір Ием! //
 // Сенімде нығайт, о Құдай Ием,
 Өзіңе ұқсат, о Тәңір Ием! //

[C1]
.  E     Am      F   G        C
   Қыш құюшысың Сен, мені жаратқан,
.  E       Am     D           G
   Жүрегімді өзгерт, Саған жалынам!</lyrics>
<key>Am</key>
<title>Жүрегімді өзгерт, о Құдай Ием РӘЖ81</title>
</song>