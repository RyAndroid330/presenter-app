<?xml version="1.0" encoding="UTF-8"?><song><author>Жанат Кусаинова</author>
<title>Иса күнәларды кешірдің</title>
<lyrics>[V1]
 // Иса күнәларды Сен кешірдің,
 Маған жаңа өмірді сыйладың.
 Қасиетті қаның Сенің төгілді,
 Мен үшін айқышта. //

[C1]
   // Бүкіл әлем Тәңір Сені даңқтайды,
   Жалғыз Сені киелі мадақтайды! //

[B1]
   Сен Ұлысың!
   Иса Саған мадақ
   Сен киелісің!
   Иса Саған мадақ
   Сен сұлусың!
   Иса Саған мадақ
   Сен ғажапсың!
   Иса Саған мадақ</lyrics>
</song>