<?xml version="1.0" encoding="UTF-8"?><song><author>Жанат Кусаинова</author>
<title>Нұрсың Сен өмірімде</title>
<aka>Бәрі де жақсы болады</aka>
<key>D</key>
<lyrics>[C1]
.     D           A      B
   //  Бәрі де жақсы болады,
.  Em                A
    Әрдайым Сен қасымда ,
.          G    Bm
   Иса - Тәңірім!
.          Em          A
   Мен сенемін Сен жетелейсің мені! //

[V1]
.   D            A    Bm
 //  Нұрсың Сен өмірімде,
.G          D   A
 Ең жақын жүрегіме,
.D          A      Bm    G
 Бақытсыздықтан бізді сақтайсын,
.D      A      D
 Әркезде бізбен бірге! //

[C2]
   // Бәрі де жақсы болады,
   Әрдайым Сен қасымда ,
   Иса - Тәңірім!
   Мен сенемін Сен жетелейсің мені! //

[B1]
.     A      Bm      G         A   B
   //  Менің атым мәңгі - Өмір Кітабында,
.  G     Em     A   D
    Жазылды мен сенемін!
.  Bm      G  A      Bm
    Бүкіл әлем шайқалса да,
.  G      Em         A    Bm
    Иса Тәңір - менің тірегім! //</lyrics>
</song>