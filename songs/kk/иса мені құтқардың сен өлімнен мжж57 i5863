<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 // Иса мені құтқардың Сен өлімнен,
 Содан бері үлгі алам тек Өзіңнен. //

[C1]
   // Жаратқан Ием жалынам Саған,
   Жаратқан Ием бата бер маған,
   Сөзіңді Сенің таратайын
   Халқыма Сені аңсаған. //

[V2]
 // Мен адасып жүргенде Өзің таптың,
 Ұлыңды қиып мен үшін күнәмды жаптың. //</lyrics>
<title>Иса мені құтқардың Сен өлімнен МЖЖ57</title>
<hymn_number>57</hymn_number>
<author>Қабдешов Руслан</author>
</song>