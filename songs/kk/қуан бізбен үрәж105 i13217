<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>105</hymn_number>
<author>Неизвестный</author>
<title>Қуан бізбен ҮРәж105</title>
<lyrics>[V1]
.D
 Қуан бізбен,
.D
 Қуан Құдайға,
.Cm
 Қуан бізбен,
.D  Cm  D
 Ән шырқа.

[V2]
.D
 Келіңдер, шалқиық,
.Cm
 Келіңдер, толқиық,
.D
 Құдайды мадақтап,
.D   Cm  D
 Шаттанайық.

[C1]
.      Gm
   /// Біздің Құдай бізбен, ///
.     Cm
   // Иса әрқашан менімен //
.  Cm      D
   Кел, шырқа,
.  Cm      D
   Кел, шырқа,
.          Gm   Cm  Gm
   СҮЙІКТІ ӘКЕ алдында.</lyrics>
<key>Gm</key>
</song>