<?xml version="1.0" encoding="UTF-8"?><song><title>О Иса Сен керемет Ұлысың</title>
<lyrics>[V1]
 // О, Иса Сен керемет Ұлысың,
 О, Ием салтанатқа бөлендің.
 Жарық Нұрды Сен шапандай киесің,
 Шындық Сөзің Сенің шынайы өмір берді! //

[C1]
   // Патша Сен орнатқан билікті
   Ешкім ешқашан қозғай алмайды.
   Иса төгілген Сенің қаның
   Аса бағалы, теңдесі жоқ бүкіл әлемде. //</lyrics>
<author>Жанат Кусаинова</author>
</song>