<?xml version="1.0" encoding="UTF-8"?><song><author>Жанат Кусаинова</author>
<title>Сүйемін Иса</title>
<lyrics>[V1]
 // Жалғызым менің сүйемін Сені Иса/Әке,
 Махаббатымсың, жарығымсың Сен Ием.
 Үмітім менің, ешбір қалдырмайсың Сен,
 Шын жүрегіммен Сені аңсаймын мен. //

[C1]
   // Иса!
   Шынайы, тірі жалғызым Сен менің! //

[V2]
 // Тәңірім жалғыз Сені алғыстайм
 Жалғыз киелісің,
 Жалғыз мейірімді ізгі,
 Тәңірім тек Сені сүйемін.
 Сені қастерлеймін,
 Бас иіп Саған келемін //</lyrics>
</song>