<?xml version="1.0" encoding="UTF-8"?><song><author>Нұр</author>
<key>C</key>
<lyrics>[V1]
.F        G        Am      Dm
 // Тыныштықта сездім Құдайымның,
 Жүрегіме сөйлегенін.
 Балам берген ақ жарылқауыңды
 Қабылда атымды менің //

[C1]
   // Ақ бата - сен менің қорғанымсың!
   Ақ бата көктен жарылқауымсың!
   Құдайдың берген сыйы,
   Тәңірмен жүрген жолы,
   Ақ бата, ақ бата! //

[V2]
 // Қайда жүрсем де сеземін сені,
 Жанымда жүрегімдесің.
 Шын өмір берген Құдайым,
 Батаңа толы өмірім! //</lyrics>
<title>Тыныштықта сездім Құдайым, жүрегіме сөйлегеніңді</title>
</song>