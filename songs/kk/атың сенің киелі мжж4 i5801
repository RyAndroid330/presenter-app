<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Am            Dm
 // Атың Сенің киелі,
.Dm            Am
 Иса бізді сүйеді.
.Am            Dm
 Күнәмізді кешіріп,
.E             Am
 Болдық өмір тиегі. //

[C1]
.     Am               Dm
   // Қуанайық, шаттанайық,
.  Dm                  Am
   Жарты жолда тоқтамайық.
.  Am            Dm
   Иса Мәсіх арқылы
.  E                Am
   Мәңгілікке аттанайық! //

[V2]
 // Иса Сені сағынамын,
 Айтқаныңа бағынамын.
 Иса Сөзі арқылы
 Құдайымды танығанбыз. //

[V3]
 // Сен бұл жердің тұзысың,
 Сен бұл жердің нұрысың.
 Құдай Әке жіберген
 Құтқарушы Ұлысың. //</lyrics>
<key>Am</key>
<title>Атың Сенің киелі МЖЖ4</title>
<hymn_number>4</hymn_number>
<author>Нұр</author>
</song>