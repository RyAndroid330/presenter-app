<?xml version="1.0" encoding="UTF-8"?><song><hymn_number>6</hymn_number>
<author>Илияс Турсун, DSJ</author>
<key>G</key>
<lyrics>[V1]
.         Em         C
 //  О, аспандағы Әкеміз,
.D       B7  Em
 Киелі болсын Сенің атың.  //
.  Am         Em
 Патшалығың орнасын,
. Am       C      B7
 Күнде нанды бере гөр.

[V2]
 //  О, аспандағы Әкеміз,
 Киелі болсын Сенің атың.  //
 Басқаларды кешірдік,
 Күнәмізді кешір.

[V3]
 //  О, аспандағы Әкеміз,
 Киелі болсын Сенің атың.  //
 Азғындыққа түсірме,
 Жамандықтан сақта.

[V4]
 //  О, аспандағы Әкеміз,
 Киелі болсын Сенің атың.  //
 Патшалық та, ұлылық,
 Мәңгі Сенікі. Аумин.

[V5]
 //  О, аспандағы Әкеміз,
 Киелі болсын Сенің атың.  //</lyrics>
<title>О, аспандағы Әкеміз РӘЖ6 Қак6</title>
</song>