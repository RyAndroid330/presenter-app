<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Иса келді менің өміріме
 Шындық Сөзі менің жүрегімде.
 // Алғыс айтам бар күшіммен,
 Табынамын бүкіл жаныммен,
 Лайықсың барлық мадаққа
 Жалғыз Сен! //

[C1]
   // Сүйемін Сені, сүйемін Сені,
   Толықтай өз жүрегімді мен Саған арнаймын Ием. //</lyrics>
<title>Иса келді менің өміріме</title>
<author>Жанат Кусаинова</author>
</song>