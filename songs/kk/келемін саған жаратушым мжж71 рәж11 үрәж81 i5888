<?xml version="1.0" encoding="UTF-8"?><song><title>Келемін Саған Жаратушым МЖЖ71 РӘЖ11 ҮРәж81</title>
<lyrics>[V1]
.    Am
 // Келемін Саған Жаратушым
.      F
 Сенің шексіз махаббатың,
.       G
 Таусылмайды рақымың.  //

[C1]
.       C
   // Ұлысың Сен,
.                Am
   Сен ғажайып ұлысың.
.                    F
   Сенен артық ешкім жоқ,
.          G
   Саған ешкім тең келмес.  //

[V2]
 // Келемін Саған, аңсап Сені.
 Жүрегімді жадыратшы,
 Мәңгілікке жасашы.  //</lyrics>
<key>C</key>
<author>Эва-Лена Хеллмарк</author>
<hymn_number>71</hymn_number>
</song>