<?xml version="1.0" encoding="UTF-8"?><song><author>Жанат Кусаинова</author>
<title>Сүйемін Сені Әке, шын жүрекпен</title>
<lyrics>[V1]
.    Gm             D7 Cm             Gm
 // Сүйемін Сені Әке, Сүйемін Сені Әке!
.Eb     Bb     Cm       Gm
  Шын жүрекпен Сені сүйемін!
.Cm  Eb        D7
 Сүйемін Сені Әке! //

[C1]
.      Gm/Eb/Cm/D         Gm/Eb
   // Әке - Ием Саған ризамын!
.  Cm     D         Gm
    Тек Саған табынамын
.       Bb         Eb/Cm/DE
   Мәңгі өмір сыйлаған үшін! //

[V2]
 // Сүйемін Сені Иса
 Сүйемін Сені Иса
 Шын жүрекпен Сені сүйемін
 Сүйемін Сені Иса! //

[C2]
   // Иса Ием Саған ризамын
   тек Саған табынамын
   Мәңгі өмір сыйлаған үшін! //</lyrics>
<key>Bb</key>
</song>