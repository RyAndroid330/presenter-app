<?xml version="1.0" encoding="UTF-8"?><song><title>Көтерілді шаңырақ</title>
<lyrics>[V1]
 Көтерілді шаңырақ,
 Жұмақтағы төрінде.
 Әке бәрін шақырып,
 Дайындаған үйіне.

[C1]
   // Тойға шақырылған кезіңде
   Дайын бол қашанда
   Дүниеге байланба
   Құщағына сыйғызады
   Әкеміз шақырғанда
   Алданып қалып қалма //

[C2]
   // Естімген көз көрмеген той басталды мәңгілік
   Құтқарылған әрбір жанның дайындады Әке орнын //
   // Күтіп отыр әр баласын дастарханның басында
   Келсін қалсын деп мәңгі жайындаған отбасында. //</lyrics>
<author>Нұр</author>
</song>