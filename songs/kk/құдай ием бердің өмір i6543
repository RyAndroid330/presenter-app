<lyrics>[V1]
.   Em            D         C                Em
 // Құдай Ием, бердің өмір, сүйгендіктен, Өз пендеңді! //
.   Em            D          C          Em
 // Алайда біз, надандықпен, ұмыттық, мейіріміңді! //

