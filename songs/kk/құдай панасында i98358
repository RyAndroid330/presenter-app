<?xml version="1.0" encoding="UTF-8"?><song><author>Жанат Кусаинова</author>
<lyrics>[V1]
 // Құдай панасында тұрған адам,
 Құдіреттінің саясында табады тыным. //

[V2]
 // Бас сауғалайтын панам, қорғаным,
 Сенімімді Саған артам Құдайым. //

[V3]
 // Ол мені құтқарады, қорғап-қоршайды,
 Мені аман-есен сақтап құрметтке Ол бөлейді.
 Мен Оған сиынам, Ол құлағын салады,
 Азап шеккен кезде, маған Ол жар болады. //</lyrics>
<title>Құдай панасында</title>
</song>