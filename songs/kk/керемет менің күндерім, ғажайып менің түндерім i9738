<?xml version="1.0" encoding="UTF-8"?><song><author>Нұр</author>
<title>Керемет менің күндерім, ғажайып менің түндерім</title>
<lyrics>[V1]
.C
 // Керемет менің күндерім,
.G
 Ғажайып менің түндерім.
 Қасымдасың Сен мәңгі Иса!
 Болдың Сен менің тірегім,
 Тыныштығыңда жүрегім,
 Алғыс айтып ән айтамын мен. //

[C1]
   // Еркелеген құстарына,
   Мадақтаған бауырларыма,
   Айналаңа қарашы жаңа,
   Бұл керемет Құдайдың ісі! //

[C2]
   // Алғыстайды әрбір демім Сені Ием!
   Алғыстайды әрбір ісім Сені Иса!
   Алғыстайды ой-пікірім, жан дүнием!
   Алғыстайды! //</lyrics>
</song>