<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<title>Tu Bikevî Tengasiyê</title>
<lyrics>[V1]
.   Dm.                  Gm.             F
 // Tu bikevî tengasiyê, bangî Îsa bike, ewê were. //
.   Gm                       F.             Eb.        2Cm
 // We xilas bike ji tariyê. Bangî Îsa bike, ewê were.  //

[V2]
 // Tu teslim bike canê xwe, barê giran li xwe bar neke. //
 // Ji gunehên xwe tobe bike. Bangî Îsa bike, ewê were. //

[V3]
 // Werin secde bikin ji wî re. Ew Xudanê Cihûda yê şêr e. //
 // Şikir bikin ji navê wî re. Bangî Îsa bikin, ewê were. //

[V4]
 // Ruhê Pîroz da hindava me. Wî got: &quot;Ez her dem bi we re me.&quot; //
 // Xudan digihîje hewara me. Bangî Îsa bike, ewê were. //</lyrics>
<key>Gm</key>
</song>