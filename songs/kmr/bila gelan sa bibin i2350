<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<lyrics>[V1]
.   Dm         F
 // Bila gelan şa bibin,
.Gm
 ew jîn bû ji mirinê. //
.   F
 // Rabin bi çar hawirdor,
.Eb           Dm
 belav kin mizgînîyê. //

[V2]
.   Dm          F
 // Ew Xilaskar Îsa ye,
.Gm
 bi xwe Kurê Xwedê ye. //
.   Dm
 // Ji bo kû em azad bin,
.Eb       Dm
 Îsa canê xwe daye. //

[V3]
.   Dm            F
 // Hemd ji Berxê Xwedê ra,
.Gm
 destê me girt, berneda. //
.   F
 // Ew Rûhê Pîroz da me,
.Cm           Dm
 hat rûnişt dilê me de. //</lyrics>
<key>Dm</key>
<title>Bila Gelan Şa Bibin</title>
</song>