<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.   Cm          Bb
 // Şivanê qenc tu yî,
.Gm          Cm
 Rêberê rast tu yî. //

[V2]
.   Eb                Bb
 // Roniya dunyayê tu yî,
.   Gm          Cm
 Padşê padşan tu yî. //

[C1]
.     Cm                  Bb
   // Stranên me ji te re ne,
.  Gm                  Cm
   Awazên me li ser te ne. //

[C2]
.     Fm                 Cm
   // Helbestên me ji bo te ne,
.  Bb         Cm
   Ey şivanê qenc. //

[V3]
 // Şivanê qenc tu yî,
 Şahî û aştî tu yî. //

[V4]
 // Mizgîn, azadî tu yî,
 Jiyana nû tu yî. //

[V5]
 // Şivanê qenc tu yî,
 Dengê me dibihîsê tu yî. //

[V6]
 // Can ji bo me fîda kir tu yî,
 Deriyê ezmanan tu yî. //</lyrics>
<key>Cm</key>
<title>Şivanê Qenc</title>
</song>