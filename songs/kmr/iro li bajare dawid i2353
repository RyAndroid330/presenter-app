<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.   Dm                         Gm
 //  Îro li bajarê Dawid kêf û şahiye!
.Gm                           Dm
  Milyaket li ezmanan dîlanê digirin. //
.Gm
 // Zarokek pêçayî ye di afirekî de,
.Dm                 Cm       Dm
 Ev zarok Xilaskarê hemû gelan e. //

[V2]
.   Gm
 //  Mizgîniya min li we,
.Dm
  Xilaskarê me hat.
.Cm
  şivanan bikevin rê,
 hemû netewan werin
.Gm          Dm
  bi perizin wî. //

[V3]
.   Dm                           Gm
 //  Qiralê min ne li text û ne li serayan e
.Gm                       Dm
  Cîranê wî dewar û pez û miya ne. //
.Gm
 // Ew ji bo me kerem kir hate dinyayê,
.Dm                     Cm        Dm
 Em jî odeya dilê xwe vekin ji wî re. //

[V4]
.   Dm                            Gm
 //  Şikir ya Xudan, te duaya min bihîst,
.Gm                        Dm
 Edî çavê min xilaskirina te dît. //
.Gm
 // Ev zarok ronahî ye ji bo hemû gelan,
.Dm                  Cm     Dm
 Bi saya Kurê Xwedê azadim, azad. //</lyrics>
<title>Îro li Bajarê Dawid</title>
<author>Şaban Ok</author>
</song>