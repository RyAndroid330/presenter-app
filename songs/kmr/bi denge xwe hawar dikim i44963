<?xml version="1.0" encoding="UTF-8"?><song><author>Nour Alo</author>
<title>Bi Dengê Xwe Hawar Dikim</title>
<lyrics>[V1]
.   Fm                   Eb
 // Bi dengê xwe hawar dikim,
.          Db        Cm
 Ji Xwedan re lava dikim. //
.          Fm          Cm
 // Ez dirêjim gazinên xwe,
.       Db      Eb     Cm
 Ez dibêjim tengahiyên xwe. //

[V2]
 // Min tiştek xwest ji Xwedan,
 Ez li wî geriyam. //
 // Hemû rojên jiyana xwe,
 Li mala wî biborînim. //

[V3]
 // Ronî û rizgariya min Xwedan e,
 Ez natirsim ji tu kesan. //
 // Xwedan hêza jîna min e,
 Bo çi ezê bitirsim ji hinan. //</lyrics>
<key>Fm</key>
</song>