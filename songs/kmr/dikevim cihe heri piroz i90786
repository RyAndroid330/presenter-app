<?xml version="1.0" encoding="UTF-8"?><song><title>Dikevim Cihê Herî Pîroz</title>
<key>Em</key>
<lyrics>[V1]
.   Em                D
 // Dikevim cihê herî pîroz,
.    Am    D        Em
 Bi navgîniya xwîna Îsa.
.               D
 Bi tenê te diperizim,
.  Am      D      Em
 Rêza navê te digirim. //

[V2]
.        G   D
 // Te diperizim,
.   Am    Em
 Te diperizim. //

[V3]
.             C        D           Em
 // Navê te pîroz e, pîroz e, ey Xudan. //</lyrics>
<author>Paul Wilbur</author>
</song>