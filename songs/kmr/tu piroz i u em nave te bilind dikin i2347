<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<title>Tu Pîroz î û Em Navê Te Bilind Dikin</title>
<key>Dm</key>
<lyrics>[V1]
.   F
 // -Tu pîroz î û em navê te
.Gm              F
  -bilind dikin, ey Mesîh //
.   Bb           Gm
 // -Erd û ezman - deşt û çiyan
.F            Eb    Dm
 -pesnê te didin Mesîh //

[C1]
.     Gm           F
   //  -Tu bê qusûr û bê gunehan-
.  Gm     F    Cm    Dm
   -ji bo me bûyî qurban //
.     Gm          F
   //  -Êş û elem tev te kişand-
.  Gm             Cm      Dm
   -ji bo xilas bikî hemû gelan //

[V2]
.   F
 // -Diperizin em ji te re
.Gm         F
 -navê te bilind dikin //
.   Bb           Gm
 // -Berxê Xwedê -tu hêjayi
.F               Eb      Dm
 -pesn û hemd ji te re dikin //</lyrics>
</song>