<?xml version="1.0" encoding="UTF-8"?><song><title>Halêlûya</title>
<lyrics>[C1]
.     Gm
   // Halêlûya //
.  Bb        Ab         Gm
   Bi çepik û lîlî halêlûya,
.  Bb        Ab         Gm
   bi govend û lîlî halêlûya.

[V1]
.   Gm               Ab
 // Her destên birîn ji te re vekirî,
.Cm               Ab
 bi histir û girî li hêviya me ye. //
.   Bb           Gm
 // Nameya jînê ji bo me name ye,
.Ab             Bb
 pirtûka evînê ew e roniye. //

[V2]
 // Deriya buharê ji me re vekirî,
 jiyana tarî, xem, bar û girî. //
 // Aştî, azadî, li deriya me kirî,
 bi çavên girî ji me re şa kirî. //

[V3]
 // Bi şev û roj çavê xwe li me ye,
 sebra wî nayê, ew Xwedê me ye. //
 // Ruha wî pîroz herdem ser me ye,
 xwîna wî şêrîn dermanê me ye. //</lyrics>
<key>Gm</key>
</song>