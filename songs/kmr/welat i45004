<?xml version="1.0" encoding="UTF-8"?><song><title>Welat</title>
<key>Dm</key>
<lyrics>[C1]
.     Dm
   // Dinya ji me re nebû welat,
.  Gm          Am     Dm
   welatê me li ba wî ye. //
.     Gm
   // Welatê me pîroz e,
.  F           Am    Dm
   Orşelîma li jorîn e. //

[V1]
.   D
 // Çend rojên me li dinyayê,
.Gm                Am    Dm
 piştî, bar kin ji va dinyê. //
.Gm                     F       Am     Dm
 Mîna mêvanê xewnê, bar dike li destê sibê,
.Gm                     F       Am     Dm
 mîna mêvanê şevê, bar dike li destê sibê.

[V2]
 // Amade bin bi hev re,
 xwîşk û birayên delal. //
 // Bawer bikin bi Îsa,
 ew xelasî li ba wî ye. //

[V3]
 // Îsa Mesîh ji me re got:
 Vejîn û jîn ez im. //
 // Yê ku bawer bikin bi min.
 heger bimirin dîsa dijîn. //</lyrics>
</song>