<?xml version="1.0" encoding="UTF-8"?><song><key>C</key>
<lyrics>[V1]
.   C                G    C
 // Çiqasî bawermendên te delal in,
.C             G     C
 Bi evîna te şêrîn û şepal in. //
.   G
 // Bi mizgîna te dilşa û heval in, //
.   C            G              C
 // Bawermendin, ji ber wê pir delal in. //

[V2]
 // Werin bigirin dîlana azadiyê,
 Kêf û şahî, aştî û rizgariyê, //
 // Îsa Mesîh Xwedanê vê rastiyê, //
 // Halêlûye, geş bikin vê şahiyê. //

[V3]
 // Yê ku rastiya te xweşik nas kirî,
 Mîna bazan li ezmanan difirî. //
 // Ne tirs û ne qehr û merez û girî, //
 // Bi şahî û bi jiyanek dil perî. //</lyrics>
<title>Çiqasî Bawermendên Te Delal in</title>
</song>