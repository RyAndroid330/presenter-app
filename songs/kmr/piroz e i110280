<?xml version="1.0" encoding="UTF-8"?><song><author>Rezan</author>
<title>Pîroz e</title>
<lyrics>[V1]
 // Pîroz e xwedî Soze Xwedanê min
 Aştî ye, Ronahî ye, Hêviya min
 Dadmend û Dilovan e, Şahiya min
 Hezkirin, Dan û Jiyane Bavê min //

[C1]
   // Hallêlûya Mesîh Wêneya wî bû
   Bi hatina wî çavên me ronî bû
   Halîlûya Mesîh bû Goriya me
   Bû Rêber û Padîşahê dilê me //

[V2]
 // Afirandar e, Rêzdar û Hêzdar e
 Durist e, Rastî ye, Rê û Mandar e
 Ji tunebûnê hebûnê çêdike
 Xweşikbûne, Lêborîne, Rizgar e //</lyrics>
</song>