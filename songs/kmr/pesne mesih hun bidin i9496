<?xml version="1.0" encoding="UTF-8"?><song><title>Pesnê Mesîh Hûn Bidin</title>
<lyrics>[C1]
   // Pesnê Mesîh, hûn bidin,
   Xweda bilind e, bang kin.
   Bi navê Îsa mêrxas bin,
   Xaça wî pêşiya xwe din. //

[V1]
 // Bêjin rabû Îsa ji mirinê,
 Xilasbûn bi xwîna wî bi tenê. //

[C2]
   Dengê xwe tevda rakin.

[V2]
 // Bêjin wî tariyê mexlûb kir,
 Jiyana me wî ronahî kir. //

[C3]
   Dengê xwe tevda rakin.

[V3]
 // Bi lîlî û çepik tevda şabin,
 Dîlana azadiyê geş bikin. //

[C4]
   Dengê xwe tevda rakin.</lyrics>
</song>