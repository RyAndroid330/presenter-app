<?xml version="1.0" encoding="UTF-8"?><song><title>Pesnê Te Dikim Îsa Mesîh</title>
<lyrics>[C1]
.     Gm                      F
   // Îsa Mesîh, pesna te dikim
.              Eb          D
   Her dem ezê li pey te bim //

[V1]
.Gm
 Êdî ew nebe, nikarim bijîm
.                             F
 Hezkirina wî nebe, ez jî nikarim
.                           Eb
 Ji boy vê hemûya pê bihesînin
.                        D
 Taca jiyanê wê Bav bide me

[V2]
 Dema derkevin hûzûra wî
 Ezê rû bi rû wî bibînim
 Dema gihîştim jiyana ebed
 Ezê hûzûra wî hemdê bikim</lyrics>
<key>Gm</key>
</song>