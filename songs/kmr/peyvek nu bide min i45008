<?xml version="1.0" encoding="UTF-8"?><song><title>Peyvek Nû Bide Min</title>
<lyrics>[V1]
.   Gm
 // Peyvek nû bide min,
.Eb
 ji te re bibêjim.
.F            Cm
 Xwedayê min, Mesîhê min,
.Dm           Gm
 ji te hez dikim. //

[V2]
.   Gm
 // Min bar kir ji vê jînê,
.F
 ji dest gunehên xwe.
.Gm          Cm
 Ez hatim ba te Xweda,
.Dm             Gm
 bibînim rastiya te. //

[C1]
.  Gm
   Îsa hebûna min e,
.  Eb
   Îsa rastiya min e,
.  F
   Îsa azadiya min e,
.     Cm  Dm  Gm
   // Halêlûya. //

[V3]
 // Soza te bi min re bû,
 çavê te li ser min bû.
 Xwedayê min, Mesîhê min,
 ji te hez dikim. //

[V4]
 // Dema tu ket dilê min,
 jiyan bi te dest pê bû.
 Kêf û aştî û şahî,
 bi te re ji nû ve bû. //

[C2]
   Xweda tu vîna min e,
   Xweda tu jîna min e,
   Xweda xilasiya min e,
   // Halêlûya. //</lyrics>
<key>Gm</key>
</song>