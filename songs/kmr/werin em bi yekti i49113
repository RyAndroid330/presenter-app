<?xml version="1.0" encoding="UTF-8"?><song><title>Werin Em bi Yektî</title>
<lyrics>[V1]
.   Am       Bb   Am
 // Werin em bi yektî,
.Am        Bb     Am
 navê Xudan mezin kin.
.Am        Bb     Am
 Kerema wî qebûl kin,
.Am      Bb    Am
 jîna nû da bijîn. //

[C1]
.     Am            Dm
   // Îsa te em hez kirin,
.  C          Bb     Am
   ji gunehan azad kirin.
.  Am            Dm
   Ruhê me paqij kirin,
.  C          Bb    Am
   li ezmanan cih kirin. //

[V2]
 // Îsa Xudan bilind kin,
 gelekî jê razî bin.
 Tu caran hûn newestin,
 navê wî tim bilind kin. //</lyrics>
<key>Am</key>
</song>