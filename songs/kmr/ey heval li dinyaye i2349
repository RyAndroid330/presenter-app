<?xml version="1.0" encoding="UTF-8"?><song><key>Dm</key>
<lyrics>[V1]
.Dm
 Ey heval li dinyayê,
.Gm        F         Eb
 tu digerî û bê çare yî.
.Dm
 Xudan Îsa li Golgota,
.Gm        F         Eb
 gunehê te bar kir ser xwe.

[V2]
.Dm
 Ew mirinê qebûl kir,
.Gm       F       Eb
 ji bo ku tu nemirî.
.Dm
 Jîn bû hilkişî ezman,
.Gm               F
 ji bo ku tu bighîjî,
.Eb        Dm
 jiyana ebedî.

[C1]
.     F           Eb
   // Çavên xwe veke,
.             Dm
   çavên xwe veke.
.  Gm              F
   Wê gavê tu yê bibînî,
.  Eb                  Dm
   qudreta Xweda yê hêzdar. //

[V3]
 Baweriyê bi Îsa bîne,
 ew çavkaniya zindî ye.
 Birînên te qenc dike,
 Xudan Mesîh jîyan bi xwe ye.

[V4]
 Vaye ew li ber derî ye,
 derî veke Ewê bê cem te.
 Heger tu qebûl bikî,
 wê gavê Ruhê Pîroz bikeve dilê te.</lyrics>
<title>Ey Heval li Dinyayê</title>
<author>Şaban Ok</author>
</song>