<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
 Bila zengil deng bidin,
 Zengilê Mizgîniyê bidin
 Mizgîniyê, Mizgîniyê, Mizgîniyê

[V2]
 Bi xaç te rizgar dike,
 Ji destê Şeytên derdixe,
 Îsa Mesîh rizgarkirê dinyayê ye

[V3]
 Îro cejineke mezin e,
 Cejina bûyîna Mesîh e
 Mizgîniyê, Mizgîniyê, Mizgîniyê</lyrics>
<title>Zengilê Mizgîniyê</title>
<author>Karên Torosyan, Milazim Rassoyan</author>
</song>