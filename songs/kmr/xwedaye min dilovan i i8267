<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
   //  Xwedayê min dilovanî,
   Tu Xwedayê erd û ezmanî.  //
   //  Destê xwe li ber te vedikim,
   Ez dua ji te dikim.  //
   ////  Xwedayê min.  ////
   Xwedayê min dilovanî.

[V1]
 //  Îsa tu rê û rast û jiyanî,
 Tu ronahiya cîhanî.  //
 //  Tu wê nanê vê jiyanê,
 Tu ji me re bûyî Qenc Şivanî.  //

[C2]
   Xwedayê min dilovanî.

[V2]
 //  Îsa tu berxê Xwedayî,
 Çûyî ser xaçê ji bo me giyayî.  //
 //  Te bi xwîna xwe yê ciwanî,
 Qelenê gunhê me danî.  //

[C3]
   Xwedayê min dilovanî.</lyrics>
<title>Xwedayê Min Dilovan î</title>
</song>