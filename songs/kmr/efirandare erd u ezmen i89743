<?xml version="1.0" encoding="UTF-8"?><song><key>A</key>
<lyrics>[V1]
.A     F#m    D     E
 Xudan tu yî efirandarê,
.A     F#m    D     E
 Erd û ezmên û her tiştî,
.A     F#m    D     E
 Tu qewat nagihîje ya te,
.A     F#m    D     E
 Zanebûna te bilind e.

[C1]
.  A     F#m    D     E
   Werin hevra em bistirên,
.  A     F#m    D     E
   Pesnê Xwedê jorin bidin.

[V2]
 Tu cîk tune, ku gunehkar,
 Xwe ji te li wir veşêre,
 Çavê te ser her deran e,
 Cîkî xewle boy te nîne.

[V3]
 Xwedê me gelek mezin e,
 Bê şirîkî bê heval e,
 Ew yekî merivhiz e,
 Xuliqdarê her milet e.</lyrics>
<title>Efirandarê Erd û Ezmên</title>
<author>Karên Torosyan, Milazim Rassoyan</author>
</song>