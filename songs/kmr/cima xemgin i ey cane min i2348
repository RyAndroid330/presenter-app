<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<title>Çima Xemgîn î Ey Canê Min</title>
<lyrics>[V1]
.   Gm
 // Çima xemgîn î ey canê min!
.Bb
 Bo çi dinale hinava min! //
.   Gm                    F
 // Hêviya xwe bi Xwedê ve girê de
.Eb                 Gm
 çimkî ew Xilaskarê min e //
.   Gm              F
 // Ezê dîsa werim hizura wî
.Cm        Dm    Gm
 hemd û şikir bikim. //

[C1]
.     Gm           F
   // Ronahî û rastiya xwe bişîne,
.  Eb            Gm
   Bila rê nîşanê min bidin. //
.     Gm             F
   // Min bibe çiyayê xwe yê pîroz
.  Cm         Dm      Gm
   Li wir biperizim te. //

[V2]
 // Çima xemgîn î ey canê min?
 Bo çi dinale hinnava min? //
 // Xwedê stargeh û hêza min e,
 ewê dîsa alikariya min bike. //
 // Bi keremkarî wê li min binêre
 saxbûnê bide canê min. //</lyrics>
<key>Gm</key>
</song>