<?xml version="1.0" encoding="UTF-8"?><song><key>G</key>
<lyrics>[V1]
.                          G
 // Gava Mesîh kete dilê min
.                       D
 Încîl bû kanîya hişê min //
.        Em      C           D
 // Reşiyê bar kir ji çavê min
.       Em       C      Bm
 Mesîh bû serwerê jîna min //

[V2]
 // Rabûm ji xewê û mirinê
 Ketim jiyana hezkirinê //
 // Îsa min hembêz kir bi vînê
 Bi êş û birîn û mirinê //

[V3]
 // Bi bawerî û bi hêviyê
 Ketim rastîya ronahiyê //
 // Dûrî kînê û xemgîniyê
 Mirovê aştî û şahiyê //</lyrics>
<title>Gava Mesîh Kete Dilê Min</title>
</song>