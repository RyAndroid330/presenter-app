<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<lyrics>[V1]
 &quot;Dengê Xudan hat min,
 Ez rabum serxwe
 Min berê xwe da wî
 cîhê herî pîroz.&quot;

[V2]
 &quot;Çîyayê Sîyonê
 tev buye agir,
 Ez dişewitim
 bi agirê Ruhê Pîroz&quot;

[V3]
 // Dengê Xudan
 tev digere ser avan e.
 Dike xumu xumîn
 çiqas hêzdare
 Dengê Xudan şêrîn
 çi heşmetkare
 Ez bume heyrana Wî.
 Ez bume heyecana Wî //

[V4]
 // Werin hemu gelno,
 bi dilekî paqij,
 Em bere xwe bidin
 cihê herî Pîroz. //

[V5]
 // Perestgeha Xudan
 buye canê me
 Em dişewitin
 bi agirê Ruhê Pîroz. //

[V6]
 // Dengê Xudan
 wekî bruskê davêje,
 Erd û ezman
 bi dengê wê dihêje
 Dengê Xudan
 xezalan dide zayîn,
 Em jê re diperizin
 Em jê re diperizin. //</lyrics>
<title>Dengê Xudan</title>
</song>