<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[C1]
.     Dm     F            C  Am              Dm
   //  Îsa Mesîh, Lawê Xwedê, çavkaniya jiyanê. //

[V1]
.              Gm                  Dm
 // Radikim destê xwe, bang dikim bi navê te.
.          Am            Dm
 Bi hemû dilê xwe diperizim te. //

[V2]
 // Te mizgîniyê da belengazan,
 Saxiyê jî ji bo dilşikestiyan. //

[V3]
 // Te azadiyê anî ji bo girtiyan,
 Vebûna çavan jî ji bo koran. //

[V4]
 // Ey hemû westiyayî û bargiran,
 Werin ba Îsa, ba Mesîh Xwedan. //</lyrics>
<key>Dm</key>
<title>Îsa Mesîh Lawê Xwedê</title>
<author>Gürkan Çamsun</author>
</song>