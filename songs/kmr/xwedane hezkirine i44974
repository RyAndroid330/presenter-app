<?xml version="1.0" encoding="UTF-8"?><song><key>Am</key>
<lyrics>[V1]
.   Am        Dm        C
 // Hey Xwedayê hezkirinê,
.Am      Dm        C
 Birîndarê çû mirinê. //
.      Dm    C    Bb    Am
 // Rengê jînê tu bi tenê,
.C       Bb        Am
 Avê bide dil dijenê. //

[C1]
.     Am    Dm
   // Halêlûya,
.        C
   Halêlûya, //
.       C     Bb       Am
   // Halêlûya Xwedayê min,
.    C    Bb       Am
   Halêlûya Mesîhê min. //

[V2]
 // Hey Mesîhê rîya jînê,
 Tim dixwazê xelkê bînê. //
 // Li dor Xwedê bicivînê,
 Bi bawerî me bigihînê. //

[V3]
 // Hey mizgîna rojê tînê,
 Tu maf û rastiya vînê. //
 // Pîroz î tu me digihînê,
 Rîya bêdawiya jînê. //</lyrics>
<title>Xwedanê Hezkirinê</title>
</song>