<?xml version="1.0" encoding="UTF-8"?><song><key>Cm</key>
<lyrics>[V1]
.   Cm
 // Min bihîstiye min hez dikî,
.Bb    Ab   Cm
 Îsayê Nûranî,
.Cm
 Û dixwazî min xilas kî,
.Bb       Ab   Cm
 tu gelek rehm î. //

[C1]
.     Cm         Fm
   // Ez jî hema hewcê wê me,
.  Ab        Cm
   Tu xwexwe zanî. //

[V2]
 // Îsa Xudan gunehkar im,
 gunehêd min behr in.
 Û ez zanim bi xwîna te,
 ew afû dibin. //

[C2]
   // Hîvî dikim min paqij ke,
   û lap pîroz ke. //

[V3]
 // Îsa Xudan dengê min bihîst,
 min hate rehmê,
 Bi rastiya wî rast hesab bûm,
 bûm para Xwedê. //

[C3]
   // Niha ez zara Xwedê me,
   xweywarê wî me. //</lyrics>
<title>Min Bihîstiye Min Hez Dikî</title>
</song>