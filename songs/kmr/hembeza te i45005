<?xml version="1.0" encoding="UTF-8"?><song><lyrics>[V1]
.C          Cmaj7
 Dikevim hembêza te,
.C         Cmaj7
 Dibînim hizûra te,
.Dm                   C
 Daxwaziya min rewanê te.

[V2]
.C      Cmaj7
 Tu Xudayê min î,
.C         Cmaj7
 Hêz û hebûna min î,
.Dm                    C
 Xem nema ji hezkirina te.
. Dm                     C
 (Tirs nema ji hezkirina te.)

[C1]
.       Am     Dm
   Dê were, bi rewanê xwe,
.  F        G    G7
   Min bibe jîna xwe.

[C2]
.    C          Em        F
   Anha, hêza Xuda me sax dike,
.           G  G7
   Bi destê xwe.

[C3]
.    C        Em           F
   Anha, çemê jînê, jînê dide,
.         G  G7
   Mirovê xwe.

[V3]
.C      Cmaj7
 Xudayê evînê,
.C          Cmaj7
 Ciyê kêf û mizgînê,
.Dm                    C
 Şa dibim ji vîna navê te.

[V4]
.C      Cmaj7
 Tu aştiya min î,
.C      Cmaj7
 Tu hêviya min î,
.Dm                C
 Padîşahê jîna min î.</lyrics>
<key>C</key>
<title>Hembêza Te</title>
</song>