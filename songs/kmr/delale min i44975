<?xml version="1.0" encoding="UTF-8"?><song><title>Delalê Min</title>
<lyrics>[V1]
.   Gm                 Cm
 // Delalê min li te geriyam,
.        F             Bb
 Bi sala li benda te mam,
.                   D
 Dema min tu li gel xwe dît,
.               Dm    Gm
 Bi ramanê te ez firiyam. //

[V2]
 // Dema tu hatî xewna min,
 Bûyî mêvanê dilê min,
 Dilê min ji nû ve jiya,
 Rêya te bû armanca min. //

[V3]
 // Hisreta dilê min ew bû,
 Naskirina rêya te bû,
 Rêya jînê te nîşan da,
 Îsa Mesîh gorî me da. //</lyrics>
<key>Gm</key>
</song>