<?xml version="1.0" encoding="UTF-8"?><song><author>Şaban Ok</author>
<title>Guh Bide Min</title>
<lyrics>[V1]
 // Guh bide min ey Rojava
 Bakûr, başûr û rojhilat. //

[V2]
 // Ezê we ji bindest rizgar kim
 Dibêje Îsa Mesîh //

[V3]
 // Ezê aş bikim zarokan,
 Paqij bikim hêstrên çavan
 Azad bikim hemu dilan
 Dibêje Îsa Mesîh. //

[V4]
 // Min bihîst qêrîna gelan,
 Keçêm fıratın li bazaran //

[V5]
 // Ezê heyfê hildim ji wan,
 Dibêje Îsa Mesîh //

[V6]
 // Hun werin ji min bawer bin
 Rê û rastî jîyan Ez im. //

[V7]
 // Tu caran Ez we bernadim,
 Dibêje Îsa Mesîh. //</lyrics>
</song>