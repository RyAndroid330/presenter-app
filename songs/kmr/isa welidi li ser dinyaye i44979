<?xml version="1.0" encoding="UTF-8"?><song><key>A</key>
<lyrics>[V1]
.A          F#m
 Îsa welidî li ser dinyayê,
.A                   E     A
 Şivanên çolê li wir hazir bûn,
.A             F#m
 Ji eşq û şahî tev ker û lal bûn.
.A                     E     A
 Ji eşq û şahî tev ker û lal bûn.

[C1]
   // Xwezî wan çavan, ku Îsa bibînin,
   Bi îmana temam, îman bistînin. //

[V2]
 Li rûyê ezmanan, stêrkek xuya bû,
 Nislê qîzekê bi rûmet temam bû,
 // Zaneyên rohlatê hatine mizgîniyê. //

[V3]
 Îsa welidî welatê Qudsê,
 Biçûk û mezin tev hatine pirsê,
 // Xwedê me yeke, kesên wî sisê. //

[V4]
 Îsa welidî nava miqarê,
 Silav da erdê, silav da behrê,
 // Milyaket hemû tev hatine xarê. //</lyrics>
<title>Îsa Welidî li ser Dinyayê</title>
</song>