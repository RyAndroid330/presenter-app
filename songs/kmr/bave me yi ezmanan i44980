<?xml version="1.0" encoding="UTF-8"?><song><title>Bavê Me yî Ezmanan</title>
<lyrics>[V1]
.   Fm                  Db       Eb   Cm
 // Bavê me yê ezmanan, navê te pîroz be, //
.Fm           Eb       Db   Eb  Cm
 Padşatiya te bê, bira emirê te be,
.   Fm        Eb       Db   Eb  Cm
 // Çawa li ezmanan, usa jî ser dinê. //

[V2]
 // Nanê me yê rojê, roj bi roj bide me, //
 Û bibaxşîne me, hemû deynên me,
 // Çawa em dibaxşînine deyndarên xwe. //

[V3]
 // Û me nebe ser cêribandinê, //
 Lê ji yê xirab tu me xilas ke,
 // Çimkî padşatî, qewat û rûmet,
 Ya te ye heta hetayê, Amîn. //</lyrics>
<key>Fm</key>
</song>